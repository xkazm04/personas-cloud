# Docker Compose local dev secrets
# Copy to .env and fill in values: cp .env.docker .env
#
# Generate secrets:
#   MASTER_KEY:   openssl rand -hex 32
#   TEAM_API_KEY: openssl rand -hex 24
#   WORKER_TOKEN: openssl rand -hex 24

MASTER_KEY=
TEAM_API_KEY=
WORKER_TOKEN=

# Optional: Claude token (or use OAuth flow via POST /api/oauth/authorize)
CLAUDE_TOKEN=

# Optional: worker ID (auto-generated if blank)
WORKER_ID=local-worker-1

# Optional: Anthropic API key for BYOK worker execution
ANTHROPIC_API_KEY=

# Log level (trace, debug, info, warn, error)
LOG_LEVEL=info

# CORS origins for local frontend dev
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
