# === Orchestrator ===
# Master encryption key (hex, 64 chars). Generate: openssl rand -hex 32
MASTER_KEY=

# Claude subscription token (OPTIONAL)
# If not set, use the OAuth flow instead:
#   1. POST /api/oauth/authorize → get authUrl
#   2. Open authUrl in browser, authorize with your Anthropic account
#   3. Copy the code from the redirect URL
#   4. POST /api/oauth/callback with { "code": "...", "state": "..." }
# Or paste a token directly via POST /api/token with { "token": "sk-ant-oat01-..." }
CLAUDE_TOKEN=

# Team API key for authenticating requests. Generate: openssl rand -hex 24
TEAM_API_KEY=

# Kafka connection (Upstash or self-hosted)
KAFKA_BROKERS=
KAFKA_USERNAME=
KAFKA_PASSWORD=

# HMAC signing key for Kafka message integrity (REQUIRED when Kafka is enabled).
# Signing covers topic + nonce + timestamp + payload to prevent cross-topic replay.
# Generate: openssl rand -hex 32
KAFKA_SIGNING_KEY=

# Unique deployment identifier for Kafka consumer group isolation.
# In multi-deployment environments, each deployment MUST have a unique value to prevent
# rogue consumers from intercepting messages. Generate: openssl rand -hex 8
KAFKA_DEPLOYMENT_ID=

# Kafka producer batching: accumulate messages for linger.ms or until batch.size is reached.
# Increasing these values improves throughput but adds latency.
KAFKA_BATCH_SIZE=16384
KAFKA_LINGER_MS=50

# GitLab webhook secret (must match the secret token configured in GitLab → Settings → Webhooks)
GITLAB_WEBHOOK_SECRET=

# Supabase JWT secret (optional, for multi-tenant user auth)
# SUPABASE_JWT_SECRET=

# Allowed CORS origins (comma-separated). Only these origins may make cross-origin
# requests to the orchestrator. Leave empty to deny all cross-origin requests.
# Example: http://localhost:5173,https://app.personas.dev
CORS_ORIGINS=

# Ports
WS_PORT=8443
HTTP_PORT=3001

# === Worker ===
# Orchestrator WebSocket URL
ORCHESTRATOR_URL=ws://localhost:8443

# Worker authentication token (must match orchestrator's expected token)
WORKER_TOKEN=

# Optional: fixed worker ID (auto-generated if absent)
WORKER_ID=
