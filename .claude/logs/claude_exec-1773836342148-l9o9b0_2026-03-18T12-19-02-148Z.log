[2026-03-18T12:19:11.156Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015549joz8rhUKQKYwJiV2wk","type":"tool_result","content":"     1→import { EventEmitter } from 'node:events';\n     2→import { deriveTenantKeyAsync } from '@dac-cloud/shared';\n     3→import type { Logger } from 'pino';\n     4→\n     5→interface CachedKey {\n     6→  key: Buffer;\n     7→  createdAt: number;\n     8→}\n     9→\n    10→export interface TenantKeyMetrics {\n    11→  hits: number;\n    12→  misses: number;\n    13→  cacheSize: number;\n    14→  derivations: number;\n    15→  avgDerivationMs: number;\n    16→}\n    17→\n    18→const DEFAULT_TTL_MS = 30 * 60 * 1000; // 30 minutes\n    19→const DEFAULT_RENEW_AHEAD_MS = 5 * 60 * 1000; // renew 5 min before expiry\n    20→\n    21→export type TenantIdSource = () => string[];\n    22→\n    23→export interface KeyDerivedEvent { tenantId: string; timestamp: number }\n    24→export interface TenantKeyEvents {\n    25→  'key:derived': [KeyDerivedEvent];\n    26→}\n    27→\n    28→/**\n    29→ * Manages per-tenant encryption keys with caching.\n    30→ *\n    31→ * Keys are derived from the master secret + tenant ID via PBKDF2 (shared/crypto.ts).\n    32→ * A single maintenance timer handles both renewal and eviction in a fixed order\n    33→ * (renew first, then evict) to prevent races between independent timers.\n    34→ *\n    35→ * Emits `key:derived` so audit concerns can subscribe externally.\n    36→ */\n    37→export class TenantKeyManager extends EventEmitter<TenantKeyEvents> {\n    38→  private cache = new Map<string, CachedKey>();\n    39→  private maintenanceTimer: NodeJS.Timeout;\n    40→  private tenantIdSource: TenantIdSource | null = null;\n    41→  private _hits = 0;\n    42→  private _misses = 0;\n    43→  private _derivations = 0;\n    44→  private _totalDerivationMs = 0;\n    45→\n    46→  constructor(\n    47→    private masterSecret: string,\n    48→    private logger: Logger,\n    49→    private ttlMs: number = DEFAULT_TTL_MS,\n    50→    private renewAheadMs: number = DEFAULT_RENEW_AHEAD_MS,\n    51→  ) {\n    52→    super();\n    53→    // Single timer for cache maintenance: renewal before eviction\n    54→    this.maintenanceTimer = setInterval(() => this.maintainCache(), 60_000);\n    55→  }\n    56→\n    57→  /**\n    58→   * Set a source function that returns all known tenant IDs.\n    59→   * Once set, pre-warms the cache. Proactive renewal runs automatically\n    60→   * via the unified maintenance timer when a tenant source is available.\n    61→   */\n    62→  async setTenantIdSource(source: TenantIdSource): Promise<void> {\n    63→    this.tenantIdSource = source;\n    64→    await this.warmAll();\n    65→  }\n    66→\n    67→  /**\n    68→   * Pre-derive and cache keys for all known tenants.\n    69→   */\n    70→  async warmAll(): Promise<void> {\n    71→    if (!this.tenantIdSource) return;\n    72→\n    73→    const tenantIds = this.tenantIdSource();\n    74→    let warmed = 0;\n    75→    const promises: Promise<void>[] = [];\n    76→    for (const tenantId of tenantIds) {\n    77→      const cached = this.cache.get(tenantId);\n    78→      if (!cached || Date.now() - cached.createdAt >= this.ttlMs) {\n    79→        promises.push(this.deriveAndCache(tenantId).then(() => { warmed++; }));\n    80→      }\n    81→    }\n    82→    await Promise.all(promises);\n    83→    if (warmed > 0) {\n    84→      this.logger.info({ warmed, total: tenantIds.length }, 'Pre-warmed tenant key cache');\n    85→    }\n    86→  }\n    87→\n    88→  /**\n    89→   * Eagerly warm the key cache for a single tenant (e.g., on tenant creation).\n    90→   */\n    91→  async warmTenant(tenantId: string): Promise<void> {\n    92→    await this.deriveAndCache(tenantId);\n    93→    this.logger.debug({ tenantId }, 'Eagerly warmed tenant key');\n    94→  }\n    95→\n    96→  /**\n    97→   * Get the encryption key for a tenant. Derives on first access, caches thereafter.\n    98→   */\n    99→  async getKey(tenantId: string): Promise<Buffer> {\n   100→    const cached = this.cache.get(tenantId);\n   101→    if (cached && Date.now() - cached.createdAt < this.ttlMs) {\n   102→      this._hits++;\n   103→      return cached.key;\n   104→    }\n   105→\n   106→    this._misses++;\n   107→    return this.deriveAndCache(tenantId);\n   108→  }\n   109→\n   110→  /**\n   111→   * Returns cache hit/miss metrics and derivation performance stats.\n   112→   */\n   113→  getMetrics(): TenantKeyMetrics {\n   114→    return {\n   115→      hits: this._hits,\n   116→      misses: this._misses,\n   117→      cacheSize: this.cache.size,\n   118→      derivations: this._derivations,\n   119→      avgDerivationMs: this._derivations > 0\n   120→        ? this._totalDerivationMs / this._derivations\n   121→        : 0,\n   122→    };\n   123→  }\n   124→\n   125→  /**\n   126→   * Invalidate all cached keys (e.g., after master key rotation).\n   127→   */\n   128→  invalidateAll(): void {\n   129→    this.zeroAllKeys();\n   130→    this.cache.clear();\n   131→    this.logger.info('All cached tenant keys invalidated');\n   132→  }\n   133→\n   134→  close(): void {\n   135→    clearInterval(this.maintenanceTimer);\n   136→    this.zeroAllKeys();\n   137→    this.cache.clear();\n   138→    this.removeAllListeners();\n   139→  }\n   140→\n   141→  private async deriveAndCache(tenantId: string): Promise<Buffer> {\n   142→    const existing = this.cache.get(tenantId);\n   143→    if (existing) existing.key.fill(0);\n   144→\n   145→    const start = performance.now();\n   146→    const key = await deriveTenantKeyAsync(this.masterSecret, tenantId);\n   147→    const elapsed = performance.now() - start;\n   148→\n   149→    this._derivations++;\n   150→    this._totalDerivationMs += elapsed;\n   151→\n   152→    this.cache.set(tenantId, { key, createdAt: Date.now() });\n   153→\n   154→    this.emit('key:derived', { tenantId, timestamp: Date.now() });\n   155→\n   156→    this.logger.debug({ tenantId, derivationMs: Math.round(elapsed) }, 'Tenant key derived');\n   157→    return key;\n   158→  }\n   159→\n   160→  /** Zero all cached key buffers. */\n   161→  private zeroAllKeys(): void {\n   162→    for (const cached of this.cache.values()) {\n   163→      cached.key.fill(0);\n   164→    }\n   165→  }\n   166→\n   167→  /**\n   168→   * Unified cache maintenance: renew near-expiry keys first, then evict expired ones.\n   169→   * Running both phases in a single callback with fixed ordering prevents the race\n   170→   * where independent timers could evict a key before renewal refreshes it, or\n   171→   * renewal re-derives a key that eviction immediately deletes.\n   172→   */\n   173→  private async maintainCache(): Promise<void> {\n   174→    const now = Date.now();\n   175→\n   176→    // Phase 1: Renew keys approaching expiry (only when a tenant source is set)\n   177→    if (this.tenantIdSource) {\n   178→      const renewThreshold = this.ttlMs - this.renewAheadMs;\n   179→      const promises: Promise<void>[] = [];\n   180→\n   181→      for (const [tenantId, cached] of this.cache) {\n   182→        const age = now - cached.createdAt;\n   183→        if (age >= renewThreshold) {\n   184→          promises.push(this.deriveAndCache(tenantId).then(() => {}));\n   185→        }\n   186→      }\n   187→\n   188→      // Pick up any new tenants not yet in cache\n   189→      for (const tenantId of this.tenantIdSource()) {\n   190→        if (!this.cache.has(tenantId)) {\n   191→          promises.push(this.deriveAndCache(tenantId).then(() => {}));\n   192→        }\n   193→      }\n   194→\n   195→      await Promise.all(promises);\n   196→      if (promises.length > 0) {\n   197→        this.logger.debug({ renewed: promises.length }, 'Proactively renewed tenant keys');\n   198→      }\n   199→    }\n   200→\n   201→    // Phase 2: Evict keys still past TTL (those not renewed above)\n   202→    for (const 