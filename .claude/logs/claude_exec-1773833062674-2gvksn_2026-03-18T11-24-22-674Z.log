nDays}`,\n    39→      );\n    40→    }\n    41→  }\n    42→\n    43→  /** Delete audit events older than retentionDays with volume safety cap. */\n    44→  purgeOld(): number {\n    45→    const cutoff = new Date(Date.now() - this.retentionDays * 86_400_000).toISOString();\n    46→\n    47→    // Pre-purge sanity check: refuse to delete more than MAX_PURGE_FRACTION of all rows\n    48→    const total = this.auditLog.countEvents();\n    49→    const candidates = this.auditLog.countEvents(cutoff);\n    50→\n    51→    if (total > 0 && candidates / total > MAX_PURGE_FRACTION) {\n    52→      this.logger.error(\n    53→        { total, candidates, cutoff, maxFraction: MAX_PURGE_FRACTION },\n    54→        'Audit purge aborted: deletion would exceed safety cap',\n    55→      );\n    56→      return 0;\n    57→    }\n    58→\n    59→    const totalDeleted = this.auditLog.purgeOlderThan(cutoff, PURGE_CHUNK_SIZE);\n    60→    if (totalDeleted > 0) {\n    61→      this.logger.info({ purged: totalDeleted, cutoff }, 'Purged old audit events');\n    62→    }\n    63→    return totalDeleted;\n    64→  }\n    65→\n    66→  /** Start daily purge timer. Returns the timer for cleanup. */\n    67→  startDailyPurge(): NodeJS.Timeout {\n    68→    this.purgeTimer = setInterval(() => {\n    69→      try { this.purgeOld(); } catch (err) {\n    70→        this.logger.error({ err }, 'Audit purge failed');\n    71→      }\n    72→    }, 24 * 60 * 60 * 1000);\n    73→    return this.purgeTimer;\n    74→  }\n    75→\n    76→  close(): void {\n    77→    if (this.purgeTimer) clearInterval(this.purgeTimer);\n    78→  }\n    79→}\n    80→"}]},"parent_tool_use_id":null,"session_id":"66460745-0f96-4924-809c-1a274158fd75","uuid":"f733c3aa-88bb-4219-860e-e04dbdb94f4d","timestamp":"2026-03-18T11:24:35.358Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\auditRetentionPolicy.ts","content":"import type { Logger } from 'pino';\nimport { getTableSpec, isEphemeral } from '@dac-cloud/shared';\nimport type { EphemeralTableSpec } from '@dac-cloud/shared';\nimport type { AuditLog } from './auditLog.js';\n\n// Derive retention constraints from the table registry — single source of truth\nconst auditSpec = getTableSpec('audit_events');\nif (!auditSpec || !isEphemeral(auditSpec)) {\n  throw new Error('audit_events must be registered as ephemeral in TABLE_REGISTRY');\n}\nconst _auditSpec = auditSpec as EphemeralTableSpec;\n\n/** Minimum allowed retention to prevent accidental wipe of the compliance trail. */\nexport const MIN_AUDIT_RETENTION_DAYS = _auditSpec.minRetentionDays ?? 90;\n\n/** Maximum fraction of rows a single purge cycle may delete (safety cap). */\nconst MAX_PURGE_FRACTION = _auditSpec.maxPurgeFraction ?? 0.8;\n\n/** Rows deleted per chunk to keep WAL size bounded during purge. */\nconst PURGE_CHUNK_SIZE = 5000;\n\n/**\n * Manages retention / purge lifecycle for the audit log.\n *\n * Separated from AuditLog so that the log itself enforces append-only\n * semantics structurally — only this class can delete audit rows.\n */\nexport class AuditRetentionPolicy {\n  private purgeTimer: NodeJS.Timeout | null = null;\n\n  constructor(\n    private auditLog: AuditLog,\n    private retentionDays: number,\n    private logger: Logger,\n  ) {\n    if (!Number.isFinite(retentionDays) || retentionDays < MIN_AUDIT_RETENTION_DAYS) {\n      throw new Error(\n        `auditRetentionDays must be >= ${MIN_AUDIT_RETENTION_DAYS}, got ${retentionDays}`,\n      );\n    }\n  }\n\n  /** Delete audit events older than retentionDays with volume safety cap. */\n  purgeOld(): number {\n    const cutoff = new Date(Date.now() - this.retentionDays * 86_400_000).toISOString();\n\n    // Pre-purge sanity check: refuse to delete more than MAX_PURGE_FRACTION of all rows\n    const total = this.auditLog.countEvents();\n    const candidates = this.auditLog.countEvents(cutoff);\n\n    if (total > 0 && candidates / total > MAX_PURGE_FRACTION) {\n      this.logger.error(\n        { total, candidates, cutoff, maxFraction: MAX_PURGE_FRACTION },\n        'Audit purge aborted: deletion would exceed safety cap',\n      );\n      return 0;\n    }\n\n    const totalDeleted = this.auditLog.purgeOlderThan(cutoff, PURGE_CHUNK_SIZE);\n    if (totalDeleted > 0) {\n      this.logger.info({ purged: totalDeleted, cutoff }, 'Purged old audit events');\n    }\n    return totalDeleted;\n  }\n\n  /** Start daily purge timer. Returns the timer for cleanup. */\n  startDailyPurge(): NodeJS.Timeout {\n    this.purgeTimer = setInterval(() => {\n      try { this.purgeOld(); } catch (err) {\n        this.logger.error({ err }, 'Audit purge failed');\n      }\n    }, 24 * 60 * 60 * 1000);\n    return this.purgeTimer;\n  }\n\n  close(): void {\n    if (this.purgeTimer) clearInterval(this.purgeTimer);\n  }\n}\n","numLines":80,"startLine":1,"totalLines":80}}}
