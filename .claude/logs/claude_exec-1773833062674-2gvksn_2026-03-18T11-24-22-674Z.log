ng | null;\n    55→}\n    56→\n    57→export class AuditLog {\n    58→  private db: Database.Database;\n    59→  private insertStmt: Database.Statement;\n    60→  private queryStmtCache = new Map<string, Database.Statement>();\n    61→\n    62→  constructor(\n    63→    dbPath: string,\n    64→    private logger: Logger,\n    65→  ) {\n    66→    this.db = new Database(dbPath);\n    67→    this.db.pragma('journal_mode = WAL');\n    68→    this.db.exec(AUDIT_SCHEMA);\n    69→    this.insertStmt = this.db.prepare(\n    70→      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',\n    71→    );\n    72→    logger.info({ dbPath }, 'Audit log initialized');\n    73→  }\n    74→\n    75→  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n    76→  countEvents(before?: string): number {\n    77→    const stmt = before\n    78→      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n    79→      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n    80→    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n    81→    return row.cnt;\n    82→  }\n    83→\n    84→  /**\n    85→   * Delete audit events older than `cutoff` in chunks of `chunkSize`.\n    86→   * Returns the total number of rows deleted.\n    87→   */\n    88→  purgeOlderThan(cutoff: string, chunkSize: number): number {\n    89→    const deleteChunk = this.db.prepare(\n    90→      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n    91→    );\n    92→    let totalDeleted = 0;\n    93→    while (true) {\n    94→      const result = deleteChunk.run(cutoff, chunkSize);\n    95→      totalDeleted += result.changes;\n    96→      if (result.changes < chunkSize) break;\n    97→    }\n    98→    return totalDeleted;\n    99→  }\n   100→\n   101→  /** Append an audit event (append-only, never updated). */\n   102→  record(entry: AuditEntry): void {\n   103→    try {\n   104→      this.insertStmt.run(\n   105→        new Date().toISOString(),\n   106→        entry.action,\n   107→        entry.tenantId ?? null,\n   108→        entry.actor ?? null,\n   109→        entry.resourceType ?? null,\n   110→        entry.resourceId ?? null,\n   111→        entry.detail ?? null,\n   112→        entry.ipAddress ?? null,\n   113→      );\n   114→    } catch (err) {\n   115→      this.logger.error({ err, entry }, 'Audit write failed — audit trail gap');\n   116→      throw new AuditWriteError(entry, err);\n   117→    }\n   118→  }\n   119→\n   120→  /** Query audit events with optional filters. */\n   121→  query(opts?: {\n   122→    tenantId?: string;\n   123→    action?: string;\n   124→    since?: string;\n   125→    limit?: number;\n   126→    offset?: number;\n   127→  }): AuditEvent[] {\n   128→    const params: unknown[] = [];\n   129→    const clauses: string[] = [];\n   130→    const keyParts: string[] = [];\n   131→\n   132→    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n   133→    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n   134→    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n   135→\n   136→    const key = keyParts.join('-') || 'none';\n   137→    let stmt = this.queryStmtCache.get(key);\n   138→    if (!stmt) {\n   139→      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   140→      stmt = this.db.prepare(\n   141→        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n   142→      );\n   143→      this.queryStmtCache.set(key, stmt);\n   144→    }\n   145→\n   146→    const limit = opts?.limit ?? 100;\n   147→    const offset = opts?.offset ?? 0;\n   148→\n   149→    return stmt.all(...params, limit, offset) as AuditEvent[];\n   150→  }\n   151→\n   152→  close(): void {\n   153→    try { this.db.close(); } catch { /* best effort */ }\n   154→  }\n   155→}\n   156→"}]},"parent_tool_use_id":null,"session_id":"66460745-0f96-4924-809c-1a274158fd75","uuid":"1c4d5a1e-b048-4ddf-9a32-9dbd3b11b1dd","timestamp":"2026-03-18T11:24:34.524Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\auditLog.ts","content":"import Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\n\nconst AUDIT_SCHEMA = `\nCREATE TABLE IF NOT EXISTS audit_events (\n  id INTEGER PRIMARY KEY AUTOINCREMENT,\n  timestamp TEXT NOT NULL,\n  action TEXT NOT NULL,\n  tenant_id TEXT,\n  actor TEXT,\n  resource_type TEXT,\n  resource_id TEXT,\n  detail TEXT,\n  ip_address TEXT\n);\nCREATE INDEX IF NOT EXISTS idx_audit_ts ON audit_events(timestamp);\nCREATE INDEX IF NOT EXISTS idx_audit_tenant_action_ts ON audit_events(tenant_id, action, timestamp);\nDROP INDEX IF EXISTS idx_audit_tenant_ts;\nDROP INDEX IF EXISTS idx_audit_action;\n`;\n\n/** Thrown when an audit event fails to persist — signals an audit trail gap. */\nexport class AuditWriteError extends Error {\n  constructor(\n    public readonly entry: AuditEntry,\n    cause: unknown,\n  ) {\n    super(`Audit write failed for action \"${entry.action}\"`);\n    this.name = 'AuditWriteError';\n    this.cause = cause;\n  }\n}\n\nexport interface AuditEntry {\n  action: string;\n  tenantId?: string;\n  actor?: string;\n  resourceType?: string;\n  resourceId?: string;\n  detail?: string;\n  ipAddress?: string;\n}\n\n/** Row shape returned by audit_events queries. */\nexport interface AuditEvent {\n  id: number;\n  timestamp: string;\n  action: string;\n  tenant_id: string | null;\n  actor: string | null;\n  resource_type: string | null;\n  resource_id: string | null;\n  detail: string | null;\n  ip_address: string | null;\n}\n\nexport class AuditLog {\n  private db: Database.Database;\n  private insertStmt: Database.Statement;\n  private queryStmtCache = new Map<string, Database.Statement>();\n\n  constructor(\n    dbPath: string,\n    private logger: Logger,\n  ) {\n    this.db = new Database(dbPath);\n    this.db.pragma('journal_mode = WAL');\n    this.db.exec(AUDIT_SCHEMA);\n    this.insertStmt = this.db.prepare(\n      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',\n    );\n    logger.info({ dbPath }, 'Audit log initialized');\n  }\n\n  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n  countEvents(before?: string): number {\n    const stmt = before\n      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n    return row.cnt;\n  }\n\n  /**\n   * Delete audit events older than `cutoff` in chunks of `chunkSize`.\n   * Returns the total number of rows deleted.\n   */\n  purgeOlderThan(cutoff: string, chunkSize: number): number {\n    const deleteChunk = this.db.prepare(\n      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n    );\n    let totalDeleted = 0;\n    while (true) {\n      const result = deleteChunk.run(cutoff, chunkSize);\n      totalDeleted += result.changes;\n      if (result.changes < chunkSize) break;\n    }\n    return totalDeleted;\n  }\n\n  /** Append an audit event (append-only, never updated). */\n  record(entry: AuditEntry): void {\n    try {\n      this.insertStmt.run(\n        new Date().toISOString(),\n        entry.action,\n        entry.tenantId ?? null,\n        entry.actor ?? null,\n        entry.resourceType ?? null,\n        entry.resourceId ?? null,\n        entry.detail ?? null,\n        entry.ipAddress ?? null,\n      );\n    } catch (err) {\n      this.logger.error({ err, entry }, 'Audit write failed — audit trail gap');\n      throw new AuditWriteError(entry, err);\n    }\n  }\n\n  /** Query audit events with optional filters. */\n  query(opts?: {\n    tenantId?: string;\n    action?: string;\n    since?: string;\n    limit?: number;\n    offset?: number;\n  }): AuditEvent[] {\n    const params: unknown[] = [];\n    const clauses: string[] = [];\n    const keyParts: string[] = [];\n\n    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n\n    const key = keyParts.join('-') || 'none';\n    let stmt = this.queryStmtCache.get(key);\n    if (!stmt) {\n      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n      stmt = this.db.prepare(\n        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n      );\n      this.queryStmtCache.set(key, stmt);\n    }\n\n    const limit = opts?.limit ?? 100;\n    const offset = opts?.offset ?? 0;\n\n    return stmt.all(...params, limit, offset) as AuditEvent[];\n  }\n\n  close(): void {\n    try { this.db.close(); } catch { /* best effort */ }\n  }\n}\n","numLines":156,"startLine":1,"totalLines":156}}}
