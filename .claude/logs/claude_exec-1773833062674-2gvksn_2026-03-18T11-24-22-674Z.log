[2026-03-18T11:24:42.111Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RYv9xG2yPiW37bb8H6QsYN","type":"tool_result","content":"     1→import pino from 'pino';\n     2→import { loadConfig } from './config.js';\n     3→import { createAuth } from './auth.js';\n     4→import { createTokenManager } from './tokenManager.js';\n     5→import { OAuthManager } from './oauth.js';\n     6→import { WorkerPool, type WorkerPoolEvents } from './workerPool.js';\n     7→import { createKafkaClient, createNoopKafkaClient } from './kafka.js';\n     8→import { Dispatcher } from './dispatcher.js';\n     9→import { createHttpApi } from './httpApi.js';\n    10→import { TenantDbManager } from './tenantDbManager.js';\n    11→import { TenantKeyManager, type TenantKeyEvents } from './tenantKeyManager.js';\n    12→import { AuditLog } from './auditLog.js';\n    13→import { AuditPolicy } from './auditPolicy.js';\n    14→import { AuditRetentionPolicy } from './auditRetentionPolicy.js';\n    15→import { startRetentionJob } from './retention.js';\n    16→import { startEventProcessor } from './eventProcessor.js';\n    17→import { startTriggerScheduler } from './triggerScheduler.js';\n    18→import { loadTlsConfig } from './tls.js';\n    19→import { TOPICS, type ExecRequest } from '@dac-cloud/shared';\n    20→\n    21→const logger = pino({ level: process.env['LOG_LEVEL'] || 'info' });\n    22→\n    23→async function main() {\n    24→  logger.info('Starting DAC Cloud Orchestrator...');\n    25→\n    26→  // Load configuration\n    27→  const config = loadConfig();\n    28→  logger.info({\n    29→    kafkaEnabled: config.kafkaEnabled,\n    30→    wsPort: config.wsPort,\n    31→    httpPort: config.httpPort,\n    32→    hasDirectToken: !!config.claudeToken,\n    33→  }, 'Configuration loaded');\n    34→\n    35→  // Initialize components\n    36→  const auth = createAuth(config.teamApiKey, config.supabaseJwtSecret || undefined);\n    37→  const tokenManager = await createTokenManager(config.masterKey, logger);\n    38→  const oauth = new OAuthManager(logger);\n    39→\n    40→  // If a direct Claude token is provided (from setup-token), store it\n    41→  if (config.claudeToken) {\n    42→    tokenManager.storeClaudeToken(config.claudeToken);\n    43→    logger.info('Direct Claude token loaded from environment');\n    44→  } else {\n    45→    logger.info('No direct Claude token — use OAuth flow via POST /api/oauth/authorize');\n    46→  }\n    47→\n    48→  // Tenant-isolated database manager\n    49→  const tenantDbManager = new TenantDbManager(config.dataDir, logger);\n    50→  logger.info({ dataDir: config.dataDir }, 'Tenant DB manager initialized');\n    51→\n    52→  // Worker pool (WebSocket server)\n    53→  const pool = new WorkerPool(config.workerToken, logger, {\n    54→    allowedDigests: config.allowedImageDigests,\n    55→    rejectUnverified: config.rejectUnverifiedWorkers,\n    56→  });\n    57→\n    58→  // Kafka client\n    59→  const kafka = config.kafkaEnabled\n    60→    ? createKafkaClient(config.kafkaBrokers, config.kafkaUsername, config.kafkaPassword, logger)\n    61→    : createNoopKafkaClient(logger);\n    62→\n    63→  // Audit log (separate append-only DB)\n    64→  const auditLog = new AuditLog(config.auditDbPath, logger);\n    65→  const auditRetention = new AuditRetentionPolicy(auditLog, config.auditRetentionDays, logger);\n    66→  auditRetention.startDailyPurge();\n    67→\n    68→  // Per-tenant key manager (cached key derivation with TTL)\n    69→  const tenantKeyManager = new TenantKeyManager(config.masterKey, logger);\n    70→\n    71→  // Declarative audit policy — maps emitter events to audit entries\n    72→  const auditPolicy = new AuditPolicy(auditLog);\n    73→\n    74→  auditPolicy.attach<TenantKeyEvents>(tenantKeyManager, {\n    75→    'key:derived': (e) => ({ action: 'key:derive', tenantId: e.tenantId }),\n    76→  });\n    77→\n    78→  auditPolicy.attach<WorkerPoolEvents>(pool, {\n    79→    'worker-connected': (info) => ({ action: 'worker:connected', detail: info.workerId }),\n    80→    'worker-disconnected': (workerId, executionId) => ({ action: 'worker:disconnected', detail: workerId, resourceId: executionId }),\n    81→  });\n    82→\n    83→  // Wire tenant ID source for key pre-warming and proactive renewal\n    84→  await tenantKeyManager.setTenantIdSource(() => tenantDbManager.listTenantIds());\n    85→  // Eagerly warm key cache when a new tenant is registered\n    86→  tenantDbManager.setTenantCreatedCallback((tenantId) => tenantKeyManager.warmTenant(tenantId));\n    87→\n    88→  // Dispatcher — uses OAuth manager for token refresh\n    89→  const dispatcher = new Dispatcher(pool, tokenManager, oauth, kafka, logger);\n    90→  dispatcher.setTenantDbManager(tenantDbManager);\n    91→  await dispatcher.setMasterKey(config.masterKey);\n    92→  dispatcher.setTenantKeyManager(tenantKeyManager);\n    93→  dispatcher.setAuditLog(auditLog);\n    94→\n    95→  // Connect Kafka\n    96→  if (config.kafkaEnabled) {\n    97→    await kafka.connect();\n    98→\n    99→    // Subscribe to execution requests\n   100→    await kafka.subscribe(async (topic: string, value: string) => {\n   101→      if (topic === TOPICS.EXEC_REQUESTS) {\n   102→        try {\n   103→          const request: ExecRequest = JSON.parse(value);\n   104→          dispatcher.submit(request);\n   105→        } catch (err) {\n   106→          logger.error({ err }, 'Failed to parse execution request from Kafka');\n   107→        }\n   108→      }\n   109→    });\n   110→  }\n   111→\n   112→  // Load TLS config and start WebSocket server for workers\n   113→  const tlsConfig = loadTlsConfig(logger);\n   114→  pool.listen(config.wsPort, tlsConfig.enabled ? tlsConfig : undefined);\n   115→\n   116→  // Start HTTP API (now includes OAuth endpoints + persona CRUD)\n   117→  // Set master key on Kafka for envelope encryption\n   118→  await kafka.setMasterKey(config.masterKey);\n   119→\n   120→  const httpServer = createHttpApi(auth, dispatcher, pool, tokenManager, oauth, logger, undefined, tenantDbManager, tenantKeyManager, auditLog);\n   121→  httpServer.listen(config.httpPort, () => {\n   122→    logger.info({ port: config.httpPort }, 'HTTP API listening');\n   123→  });\n   124→\n   125→  // Start event processor (2s tick) and trigger scheduler (5s tick) — tenant-aware\n   126→  const eventProcessorTimer = startEventProcessor(null, dispatcher, logger, 2000, tenantDbManager);\n   127→  const triggerSchedulerTimer = startTriggerScheduler(null, logger, 5000, tenantDbManager);\n   128→\n   129→  // Start daily retention job (purge old executions/events, aggregate metrics)\n   130→  const retentionTimer = startRetentionJob(tenantDbManager, config.retentionDays, logger);\n   131→\n   132→  // Token refresh loop — refresh OAuth token proactively every 30 minutes\n   133→  setInterval(async () => {\n   134→    if (oauth.hasTokens()) {\n   135→      const token = await oauth.getValidAccessToken();\n   136→      if (token) {\n   137→        tokenManager.storeClaudeToken(token);\n   138→      }\n   139→    }\n   140→  }, 30 * 60 * 1000);\n   141→\n   142→  // Log status periodically\n   143→  setInterval(() => {\n   144→    const counts = pool.getWorkerCount();\n   145→    const queueLen = dispatcher.getQueueLength();\n   146→    if (counts.total > 0 || queueLen > 0) {\n   147→      logger.info({\n   148→        workers: counts,\n   149→        queueLength: queueLen,\n   150→        activeExecutions: dispatcher.getActiveExecutions().length,\n   151→        hasOAuth: oauth.hasTokens(),\n   152→      }, 'Status');\n   153→    }\n   154→  }, 60_000);\n   155→\n   156→  // Graceful shutdown\n   157→  const shutdown = async () => {\n   158→    logger.info('Shutting down...');\n   159→    clearInterval(eventProcessorTimer);\n   160→    clearInterval(triggerSchedulerTimer);\n   161→    clearInterval(retentionTimer);\n   162→    dispatcher.shutdown();\n   163→    pool.shutdown();\n   164→    await kafka.disconnect();\n   165→    httpServer.close();\n   166→    tenantKeyManager.close();\n   167→    auditRetention.close();\n   168→    auditLog.close();\n   169→    tenantDbManager.close();\n   170→    oauth.dispose();\n   171→    process.exit(0);\n   172→  };\n   173→\n   174→  process.on('SIGINT', shutdown);\n   175→  process.on('SIGTERM', shutdown);\n   176→\n   177→  logger.info('DAC Cloud Orchestrator ready');\n   178→  logger.info(`  HTTP API: http://localhost:${config.httpPort}`);\n   179→  logger.info(`  Worker WS: ${tlsConfig.enabled ? 'wss' : 'ws'}://localhost:${config.wsPort}`);\n   180→  if (!config.claudeToken) {\n   181→    logger.info('  Connect subscription: POST /api/oauth/authorize');\n   182→  }\n   183→}\n   184→\n   185→main().catch((err) => {\n   186→  logger.fatal({ err }, 'Failed to start orchestrator');\n   187→  process.exit(1);\n   188→});\n   189→"}]},"parent_tool_use_id":null,"session_id":"66460745-0f96-4924-809c-1a274158fd75","uuid":"1dcf46c2-979d-4b23-b7b6-d9c7bee37c2a","timestamp":"2026-03-18T11:24:42.024Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\index.ts","content":"import pino from 'pino';\nimport { loadConfig } from './config.js';\nimport { createAuth } from './auth.js';\nimport { createTokenManager } from './tokenManager.js';\nimport { OAuthManager } from './oauth.js';\nimport { WorkerPool, type WorkerPoolEvents } from './workerPool.js';\nimport { createKafkaClient, createNoopKafkaClient } from './kafka.js';\nimport { Dispatcher } from './dispatcher.js';\nimport { createHttpApi } from './httpApi.js';\nimport { TenantDbManager } from './tenantDbManager.js';\nimport { TenantKeyManager, type TenantKeyEvents } from './tenantKeyManager.js';\nimport { AuditLog } from './auditLog.js';\nimport { AuditPolicy } from './auditPolicy.js';\nimport { AuditRetentionPolicy } from './auditRetentionPolicy.js';\nimport { startRetentionJob } from './retention.js';\nimport { startEventProcessor } from './eventProcessor.js';\nimport { startTriggerScheduler } from './triggerScheduler.js';\nimport { loadTlsConfig } from './tls.js';\nimport { TOPICS, type ExecRequest } from '@dac-cloud/shared';\n\nconst logger = pino({ level: process.env['LOG_LEVEL'] || 'info' });\n\nasync function main() {\n  logger.info('Starting DAC Cloud Orchestrator...');\n\n  // Load configuration\n  const config = loadConfig();\n  logger.info({\n    kafkaEnabled: config.kafkaEnabled,\n    wsPort: config.wsPort,\n    httpPort: config.httpPort,\n    hasDirectToken: !!config.claudeToken,\n  }, 'Configuration loaded');\n\n  // Initialize components\n  const auth = createAuth(config.teamApiKey, config.supabaseJwtSecret || undefined);\n  const tokenManager = await createTokenManager(config.masterKey, logger);\n  const oauth = new OAuthManager(logger);\n\n  // If a direct Claude token is provided (from setup-token), store it\n  if (config.claudeToken) {\n    tokenManager.storeClaudeToken(config.claudeToken);\n    logger.info('Direct Claude token loaded from environment');\n  } else {\n    logger.info('No direct Claude token — use OAuth flow via POST /api/oauth/authorize');\n  }\n\n  // Tenant-isolated database manager\n  const tenantDbManager = new TenantDbManager(config.dataDir, logger);\n  logger.info({ dataDir: config.dataDir }, 'Tenant DB manager initialized');\n\n  // Worker pool (WebSocket server)\n  const pool = new WorkerPool(config.workerToken, logger, {\n    allowedDigests: config.allowedImageDigests,\n    rejectUnverified: config.rejectUnverifiedWorkers,\n  });\n\n  // Kafka client\n  const kafka = config.kafkaEnabled\n    ? createKafkaClient(config.kafkaBrokers, config.kafkaUsername, config.kafkaPassword, logger)\n    : createNoopKafkaClient(logger);\n\n  // Audit log (separate append-only DB)\n  const auditLog = new AuditLog(config.auditDbPath, logger);\n  const auditRetention = new AuditRetentionPolicy(auditLog, config.auditRetentionDays, logger);\n  auditRetention.startDailyPurge();\n\n  // Per-tenant key manager (cached key derivation with TTL)\n  const tenantKeyManager = new TenantKeyManager(config.masterKey, logger);\n\n  // Declarative audit policy — maps emitter events to audit entries\n  const auditPolicy = new AuditPolicy(auditLog);\n\n  auditPolicy.attach<TenantKeyEvents>(tenantKeyManager, {\n    'key:derived': (e) => ({ action: 'key:derive', tenantId: e.tenantId }),\n  });\n\n  auditPolicy.attach<WorkerPoolEvents>(pool, {\n    'worker-connected': (info) => ({ action: 'worker:connected', detail: info.workerId }),\n    'worker-disconnected': (workerId, executionId) => ({ action: 'worker:disconnected', detail: workerId, resourceId: executionId }),\n  });\n\n  // Wire tenant ID source for key pre-warming and proactive renewal\n  await tenantKeyManager.setTenantIdSource(() => tenantDbManager.listTenantIds());\n  // Eagerly warm key cache when a new tenant is registered\n  tenantDbManager.setTenantCreatedCallback((tenantId) => tenantKeyManager.warmTenant(tenantId));\n\n  // Dispatcher — uses OAuth manager for token refresh\n  const dispatcher = new Dispatcher(pool, tokenManager, oauth, kafka, logger);\n  dispatcher.setTenantDbManager(tenantDbManager);\n  await dispatcher.setMasterKey(config.masterKey);\n  dispatcher.setTenantKeyManager(tenantKeyManager);\n  dispatcher.setAuditLog(auditLog);\n\n  // Connect Kafka\n  if (config.kafkaEnabled) {\n    await kafka.connect();\n\n    // Subscribe to execution requests\n    await kafka.subscribe(async (topic: string, value: string) => {\n      if (topic === TOPICS.EXEC_REQUESTS) {\n        try {\n          const request: ExecRequest = JSON.parse(value);\n          dispatcher.submit(request);\n        } catch (err) {\n          logger.error({ err }, 'Failed to parse execution request from Kafka');\n        }\n      }\n    });\n  }\n\n  // Load TLS config and start WebSocket server for workers\n  const tlsConfig = loadTlsConfig(logger);\n  pool.listen(config.wsPort, tlsConfig.enabled ? tlsConfig : undefined);\n\n  // Start HTTP API (now includes OAuth endpoints + persona CRUD)\n  // Set master key on Kafka for envelope encryption\n  await kafka.setMasterKey(config.masterKey);\n\n  const httpServer = createHttpApi(auth, dispatcher, pool, tokenManager, oauth, logger, undefined, tenantDbManager, tenantKeyManager, auditLog);\n  httpServer.listen(config.httpPort, () => {\n    logger.info({ port: config.httpPort }, 'HTTP API listening');\n  });\n\n  // Start event processor (2s tick) and trigger scheduler (5s tick) — tenant-aware\n  const eventProcessorTimer = startEventProcessor(null, dispatcher, logger, 2000, tenantDbManager);\n  const triggerSchedulerTimer = startTriggerScheduler(null, logger, 5000, tenantDbManager);\n\n  // Start daily retention job (purge old executions/events, aggregate metrics)\n  const retentionTimer = startRetentionJob(tenantDbManager, config.retentionDays, logger);\n\n  // Token refresh loop — refresh OAuth token proactively every 30 minutes\n  setInterval(async () => {\n    if (oauth.hasTokens()) {\n      const token = await oauth.getValidAccessToken();\n      if (token) {\n        tokenManager.storeClaudeToken(token);\n      }\n    }\n  }, 30 * 60 * 1000);\n\n  // Log status periodically\n  setInterval(() => {\n    const counts = pool.getWorkerCount();\n    const queueLen = dispatcher.getQueueLength();\n    if (counts.total > 0 || queueLen > 0) {\n      logger.info({\n        workers: counts,\n        queueLength: queueLen,\n        activeExecutions: dispatcher.getActiveExecutions().length,\n        hasOAuth: oauth.hasTokens(),\n      }, 'Status');\n    }\n  }, 60_000);\n\n  // Graceful shutdown\n  const shutdown = async () => {\n    logger.info('Shutting down...');\n    clearInterval(eventProcessorTimer);\n    clearInterval(triggerSchedulerTimer);\n    clearInterval(retentionTimer);\n    dispatcher.shutdown();\n    pool.shutdown();\n    await kafka.disconnect();\n    httpServer.close();\n    tenantKeyManager.close();\n    auditRetention.close();\n    auditLog.close();\n    tenantDbManager.close();\n    oauth.dispose();\n    process.exit(0);\n  };\n\n  process.on('SIGINT', shutdown);\n  process.on('SIGTERM', shutdown);\n\n  logger.info('DAC Cloud Orchestrator ready');\n  logger.info(`  HTTP API: http://localhost:${config.httpPort}`);\n  logger.info(`  Worker WS: ${tlsConfig.enabled ? 'wss' : 'ws'}://localhost:${config.wsPort}`);\n  if (!config.claudeToken) {\n    logger.info('  Connect subscription: POST /api/oauth/authorize');\n  }\n}\n\nmain().catch((err) => {\n  logger.fatal({ err }, 'Failed to start orchestrator');\n  process.exit(1);\n});\n","numLines":189,"startLine":1,"totalLines":189}}}
