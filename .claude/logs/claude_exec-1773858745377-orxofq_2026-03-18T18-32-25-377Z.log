) as { since?: string; until?: string };\n          if (parsed.since || parsed.until) opts = { since: parsed.since, until: parsed.until };\n        } catch { /* empty body or non-JSON — verify entire chain */ }\n      }\n      json(res, 200, auditLog.verify(opts));\n    },\n  });"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2898,"cache_read_input_tokens":39787,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2898},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"acc298eb-2a61-411d-9be8-97133940327a","uuid":"1bd3a62d-ea8d-492e-ba03-a85723e22595"}
