 += chunk.length;\n      if (totalBytes > MAX_BODY_BYTES) {\n        req.destroy();\n        reject(new Error('Payload too large'));\n        return;\n      }\n      chunks.push(chunk);\n    });\n    req.on('end', () => resolve(Buffer.concat(chunks).toString()));\n    req.on('error', reject);\n  });\n}\n","numLines":27,"startLine":1,"totalLines":27}}}
[2026-03-18T18:32:38.000Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SnAj6BpUcuHhJz5HzZ7cNc","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import type { KafkaClient } from './kafka.js';\n    11→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    12→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    13→import type { TriggerSchedulerHandle } from './triggerScheduler.js';\n    14→import type { TenantDbManager } from './tenantDbManager.js';\n    15→import type { TenantKeyManager } from './tenantKeyManager.js';\n    16→import type { AuditLog, AuditEntry, AuditAction } from './auditLog.js';\n    17→import type { EventProcessorHealth } from './eventProcessor.js';\n    18→import type { Logger } from 'pino';\n    19→import * as db from './db/index.js';\n    20→import { readBody, json } from './httpUtils.js';\n    21→\n    22→// --- Route types ---\n    23→\n    24→interface ParsedRoute {\n    25→  resource: string;\n    26→  id?: string;\n    27→  subResource?: string;\n    28→}\n    29→\n    30→type RouteHandler = (\n    31→  req: http.IncomingMessage,\n    32→  res: http.ServerResponse,\n    33→  ctx: RequestContext,\n    34→  route: ParsedRoute | null,\n    35→  queryString: string | undefined,\n    36→  tenantDb: Database.Database | undefined,\n    37→  scopedProjectId: string | undefined,\n    38→  reqLogger: Logger,\n    39→) => Promise<void> | void;\n    40→\n    41→interface RouteEntry {\n    42→  handler: RouteHandler;\n    43→  needsDb?: boolean;\n    44→  adminOnly?: boolean;\n    45→}\n    46→\n    47→/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\n    48→function resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n    49→  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n    50→}\n    51→\n    52→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n    53→function parseRoute(pathname: string): ParsedRoute | null {\n    54→  if (!pathname.startsWith('/api/')) return null;\n    55→  const segments = pathname.slice(5).split('/').filter(Boolean);\n    56→  if (segments.length === 0) return null;\n    57→  return {\n    58→    resource: segments[0]!,\n    59→    id: segments[1],\n    60→    subResource: segments[2],\n    61→  };\n    62→}\n    63→\n    64→export function createHttpApi(\n    65→  auth: Auth,\n    66→  dispatcher: Dispatcher,\n    67→  pool: WorkerPool,\n    68→  tokenManager: TokenManager,\n    69→  oauth: OAuthManager,\n    70→  logger: Logger,\n    71→  database?: Database.Database,\n    72→  tenantDbManager?: TenantDbManager,\n    73→  tenantKeyManager?: TenantKeyManager,\n    74→  auditLog?: AuditLog,\n    75→  getEventProcessorHealth?: () => EventProcessorHealth,\n    76→  kafka?: KafkaClient,\n    77→  onEventPublished?: () => void,\n    78→  triggerScheduler?: TriggerSchedulerHandle,\n    79→): http.Server {\n    80→\n    81→  /** Wrap a mutation handler to emit an audit event on successful response. */\n    82→  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    83→    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n    84→      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n    85→      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n    86→        try {\n    87→          auditLog.record({\n    88→            action,\n    89→            tenantId: ctx.projectId || 'default',\n    90→            actor: ctx.userEmail || ctx.projectId,\n    91→            resourceType,\n    92→            resourceId: route?.id,\n    93→            ipAddress: req.socket.remoteAddress,\n    94→          } as AuditEntry);\n    95→        } catch { /* logged inside record() */ }\n    96→      }\n    97→    };\n    98→  }\n    99→\n   100→  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n   101→  const exactRoutes = new Map<string, RouteEntry>();\n   102→\n   103→  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n   104→  for (const [path, method] of [\n   105→    ['/api/oauth/authorize', 'POST'],\n   106→    ['/api/oauth/callback', 'POST'],\n   107→    ['/api/oauth/status', 'GET'],\n   108→    ['/api/oauth/refresh', 'POST'],\n   109→    ['/api/oauth/disconnect', 'DELETE'],\n   110→    ['/api/token', 'POST'],\n   111→  ] as const) {\n   112→    exactRoutes.set(`${method}:${path}`, {\n   113→      adminOnly: true,\n   114→      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   115→        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger);\n   116→      },\n   117→    });\n   118→  }\n   119→\n   120→  exactRoutes.set('GET:/api/status', {\n   121→    handler: (_req, res) => {\n   122→      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   123→    },\n   124→  });\n   125→\n   126→  exactRoutes.set('POST:/api/execute', {\n   127→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   128→      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n   129→    }, 'execution:submit', 'execution'),\n   130→  });\n   131→\n   132→  exactRoutes.set('POST:/api/gitlab/webhook', {\n   133→    needsDb: true,\n   134→    handler: withHttpAudit(async (req, res, _ctx, _route, _qs, tenantDb) => {\n   135→      const body = await readBody(req);\n   136→      let parsed: Record<string, unknown> = {};\n   137→      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   138→      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   139→      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   140→      const event = db.publishEvent(tenantDb!, {\n   141→        eventType: `gitlab_${objectKind}`,\n   142→        sourceType: 'gitlab',\n   143→        sourceId: projectPath ?? null,\n   144→        payload: body,\n   145→      });\n   146→      onEventPublished?.();\n   147→      json(res, 201, event);\n   148→    }, 'event:publish', 'event'),\n   149→  });\n   150→\n   151→  // Admin routes\n   152→  exactRoutes.set('GET:/api/admin/users', {\n   153→    adminOnly: true,\n   154→    handler: (_req, res) => {\n   155→      if (tenantDbManager) {\n   156→        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   157→      } else if (database) {\n   158→        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   159→      } else {\n   160→        json(res, 200, { projectIds: [] });\n   161→      }\n   162→    },\n   163→  });\n   164→\n   165→  exactRoutes.set('GET:/api/admin/personas', {\n   166→    adminOnly: true,\n   167→    handler: (_req, res) => {\n   168→      if (tenantDbManager) {\n   169→        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   170→        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   171→        json(res, 200, allPersonas);\n   172→      } else if (database) {\n   173→        json(res, 200, db.listPersonasSummary(database));\n   174→      } else {\n   175→        json(res, 200, []);\n   176→      }\n   177→    },\n   178→  });\n   179→\n   180→  exactRoutes.set('GET:/api/admin/executions', {\n   181→    adminOnly: true,\n   182→    handler: (_req, res, _ctx, _route, queryString) => {\n   183→      const params = new URLSearchParams(queryString || '');\n   184→      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   185→      if (tenantDbManager) {\n   186→        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   187→        tenantDbManager.forEachTenant((tDb) => {\n   188→          allExecs.push(...db.listExecutions(tDb, { limit }));\n   189→        });\n   190→        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   191→        json(res, 200, allExecs.slice(0, limit));\n   192→      } else if (database) {\n   193→        json(res, 200, db.listExecutions(database, {\n   194→          limit,\n   195→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   196→        }));\n   197→      } else {\n   198→        json(res, 200, []);\n   199→      }\n   200→    },\n   201→  });\n   202→\n   203→  exactRoutes.set('GET:/api/admin/audit', {\n   204→    adminOnly: true,\n   205→    handler: (_req, res, _ctx, _route, queryString) => {\n   206→      if (!auditLog) { json(res, 200, []); return; }\n   207→      const params = new URLSearchParams(queryString || '');\n   208→      json(res, 200, auditLog.query({\n   209→        tenantId: params.get('tenantId') ?? undefined,\n   210→        action: (params.get('action') ?? undefined) as AuditAction | undefined,\n   211→        since: params.get('since') ?? undefined,\n   212→        limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   213→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   214→      }));\n   215→    },\n   216→  });\n   217→\n   218→  exactRoutes.set('GET:/api/admin/audit/stats', {\n   219→    adminOnly: true,\n   220→    handler: (_req, res, _ctx, _route, queryString) => {\n   221→      if (!auditLog) { json(res, 200, { byAction: [], byTenant: [], topActors: [], trend: [] }); return; }\n   222→      const params = new URLSearchParams(queryString || '');\n   223→      const bucket = params.get('bucket') === 'hour' ? 'hour' : 'day';\n   224→      json(res, 200, auditLog.stats({\n   225→        tenantId: params.get('tenantId') ?? undefined,\n   226→        since: params.get('since') ?? undefined,\n   227→        until: params.get('until') ?? undefined,\n   228→        bucket,\n   229→      }));\n   230→    },\n   231→  });\n   232→\n   233→  // ── Resource route table (O(1) lookup by `METHOD:resource[:id][:sub]`) ──\n   234→  const resourceRoutes = new Map<string, RouteEntry>();\n   235→\n   236→  // --- Persona CRUD ---\n   237→  resourceRoutes.set(resourceKey('GET', 'personas', false), {\n   238→    needsDb: true,\n   239→    handler: (_req, res, _ctx, _route, _qs, tenantDb, scopedProjectId) => {\n   240→      json(res, 200, db.listPersonasSummary(tenantDb!, scopedProjectId));\n   241→    },\n   242→  });\n   243→\n   244→  resourceRoutes.set(resourceKey('POST', 'personas', false), {\n   245→    needsDb: true,\n   246→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   247→      const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   248→      const persona = createPersonaWithDefaults({\n   249→        ...body,\n   250→        projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   251→      });\n   252→      db.upsertPersona(tenantDb!, persona);\n   253→      try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: persona.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   254→      reqLogger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   255→      json(res, 201, persona);\n   256→    },\n   257→  });\n   258→\n   259→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'tools'), {\n   260→    needsDb: true,\n   261→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   262→      json(res, 200, db.getToolsForPersona(tenantDb!, route!.id!));\n   263→    },\n   264→  });\n   265→\n   266→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'tools'), {\n   267→    needsDb: true,\n   268→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   269→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   270→      if (!persona) return;\n   271→      const body = JSON.parse(await readBody(req)) as { toolId: string };\n   272→      db.linkTool(tenantDb!, route!.id!, body.toolId);\n   273→      try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { toolId: body.toolId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   274→      reqLogger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route!.id!, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   275→      json(res, 200, { linked: true });\n   276→    },\n   277→  });\n   278→\n   279→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'full'), {\n   280→    needsDb: true,\n   281→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   282→      const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb!, route!.id!, reqLogger), scopedProjectId, res);\n   283→      if (!hydrated) return;\n   284→      json(res, 200, hydrated);\n   285→    },\n   286→  });\n   287→\n   288→  resourceRoutes.set(resourceKey('GET', 'personas', true), {\n   289→    needsDb: true,\n   290→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId) => {\n   291→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   292→      if (!persona) return;\n   293→      json(res, 200, persona);\n   294→    },\n   295→  });\n   296→\n   297→  resourceRoutes.set(resourceKey('DELETE', 'personas', true), {\n   298→    needsDb: true,\n   299→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   300→      db.deletePersona(tenantDb!, route!.id!, scopedProjectId);\n   301→      try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   302→      reqLogger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   303→      json(res, 200, { deleted: true });\n   304→    },\n   305→  });\n   306→\n   307→  // --- Persona sub-resources: credentials ---\n   308→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'credentials'), {\n   309→    needsDb: true,\n   310→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   311→      const creds = db.listCredentialsForPersona(tenantDb!, route!.id!);\n   312→      try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   313→      json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   314→    },\n   315→  });\n   316→\n   317→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'credentials'), {\n   318→    needsDb: true,\n   319→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   320→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   321→      if (!persona) return;\n   322→      const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   323→      db.linkCredential(tenantDb!, route!.id!, body.credentialId);\n   324→      try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { credentialId: body.credentialId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   325→      reqLogger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route!.id!, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   326→      json(res, 200, { linked: true });\n   327→    },\n   328→  });\n   329→\n   330→  // --- Persona sub-resources: subscriptions ---\n   331→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'subscriptions'), {\n   332→    needsDb: true,\n   333→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   334→      json(res, 200, db.listSubscriptionsForPersona(tenantDb!, route!.id!));\n   335→    },\n   336→  });\n   337→\n   338→  // --- Tool Definitions ---\n   339→  resourceRoutes.set(resourceKey('POST', 'tool-definitions', false), {\n   340→    needsDb: true,\n   341→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   342→      const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   343→      const tool = createToolDefinitionWithDefaults(body);\n   344→      db.upsertToolDefinition(tenantDb!, tool);\n   345→      try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'toolDefinition', resourceId: tool.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   346→      reqLogger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   347→      json(res, 201, tool);\n   348→    },\n   349→  });\n   350→\n   351→  // --- Credentials ---\n   352→  resourceRoutes.set(resourceKey('POST', 'credentials', false), {\n   353→    needsDb: true,\n   354→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   355→      const body = JSON.parse(await readBody(req));\n   356→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   357→\n   358→      if (!body.plaintext || typeof body.plaintext !== 'string') {\n   359→        json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   360→        return;\n   361→      }\n   362→      if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   363→        json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   364→        return;\n   365→      }\n   366→      if (!tenantKeyManager) {\n   367→        json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   368→        return;\n   369→      }\n   370→\n   371→      delete body.encryptedData;\n   372→      delete body.iv;\n   373→      delete body.tag;\n   374→\n   375→      const tenantId = body.projectId || ctx.projectId || 'default';\n   376→      const key = await tenantKeyManager.getKey(tenantId);\n   377→      const encrypted = encrypt(body.plaintext, key);\n   378→      body.encryptedData = encrypted.encrypted;\n   379→      body.iv = encrypted.iv;\n   380→      body.tag = encrypted.tag;\n   381→      delete body.plaintext;\n   382→\n   383→      const cred = db.createCredential(tenantDb!, body);\n   384→      try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: cred.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   385→      reqLogger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   386→      json(res, 201, cred);\n   387→    },\n   388→  });\n   389→\n   390→  resourceRoutes.set(resourceKey('DELETE', 'credentials', true), {\n   391→    needsDb: true,\n   392→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   393→      const changes = db.deleteCredential(tenantDb!, route!.id!, scopedProjectId);\n   394→      if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   395→      try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   396→      reqLogger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   397→      json(res, 200, { deleted: true });\n   398→    },\n   399→  });\n   400→\n   401→  // --- Event Subscriptions ---\n   402→  resourceRoutes.set(resourceKey('POST', 'subscriptions', false), {\n   403→    needsDb: true,\n   404→    handler: async (req, res, ctx, _route, _qs, tenantDb) => {\n   405→      const body = JSON.parse(await readBody(req));\n   406→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   407→      const missing: string[] = [];\n   408→      if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   409→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   410→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   411→      const sub = db.createSubscription(tenantDb!, body);\n   412→      try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: sub.id, detail: { personaId: body.personaId, eventType: body.eventType }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   413→      json(res, 201, sub);\n   414→    },\n   415→  });\n   416→\n   417→  resourceRoutes.set(resourceKey('PUT', 'subscriptions', true), {\n   418→    needsDb: true,\n   419→    handler: async (req, res, ctx, route, _qs, tenantDb) => {\n   420→      const body = JSON.parse(await readBody(req));\n   421→      db.updateSubscription(tenantDb!, route!.id!, body);\n   422→      const updated = db.getSubscription(tenantDb!, route!.id!);\n   423→      try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   424→      json(res, 200, updated);\n   425→    },\n   426→  });\n   427→\n   428→  resourceRoutes.set(resourceKey('DELETE', 'subscriptions', true), {\n   429→    needsDb: true,\n   430→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   431→      db.deleteSubscription(tenantDb!, route!.id!);\n   432→      try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   433→      json(res, 200, { deleted: true });\n   434→    },\n   435→  });\n   436→\n   437→  // --- Triggers (delegated to triggerHttpHandlers) ---\n   438→  const triggerHandler: RouteHandler = async (req, res, ctx, route, _qs, tenantDb) => {\n   439→    await handleTriggerRoute(route!, req.method!, req, res, tenantDb!, ctx, triggerScheduler);\n   440→  };\n   441→  resourceRoutes.set(resourceKey('POST', 'triggers', false), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:create', 'trigger') });\n   442→  resourceRoutes.set(resourceKey('PUT', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:update', 'trigger') });\n   443→  resourceRoutes.set(resourceKey('DELETE', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:delete', 'trigger') });\n   444→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'triggers'), { needsDb: true, handler: triggerHandler });\n   445→\n   446→  // --- Events ---\n   447→  resourceRoutes.set(resourceKey('GET', 'events', false), {\n   448→    needsDb: true,\n   449→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   450→      const params = new URLSearchParams(queryString || '');\n   451→      const events = db.listEvents(tenantDb!, {\n   452→        eventType: params.get('eventType') ?? undefined,\n   453→        status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n   454→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   455→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   456→        projectId: scopedProjectId,\n   457→      });\n   458→      json(res, 200, events);\n   459→    },\n   460→  });\n   461→\n   462→  resourceRoutes.set(resourceKey('POST', 'events', false), {\n   463→    needsDb: true,\n   464→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, tenantDb) => {\n   465→      const body = JSON.parse(await readBody(req));\n   466→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   467→      const missing: string[] = [];\n   468→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   469→      if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   470→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   471→      const event = db.publishEvent(tenantDb!, body);\n   472→      onEventPublished?.();\n   473→      json(res, 201, event);\n   474→    }, 'event:publish', 'event'),\n   475→  });\n   476→\n   477→  resourceRoutes.set(resourceKey('PUT', 'events', true), {\n   478→    needsDb: true,\n   479→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   480→      const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n   481→      const updated = db.updateEventWithMetadata(tenantDb!, route!.id!, body.status, body.metadata);\n   482→      if (updated) {\n   483→        json(res, 200, updated);\n   484→      } else {\n   485→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   486→        res.end(JSON.stringify({ error: 'Event not found' }));\n   487→      }\n   488→    }, 'event:update', 'event'),\n   489→  });\n   490→\n   491→  // --- Webhooks ---\n   492→  resourceRoutes.set(resourceKey('POST', 'webhooks', true), {\n   493→    needsDb: true,\n   494→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   495→      const personaId = route!.id!;\n   496→      const body = await readBody(req);\n   497→      const event = db.publishEvent(tenantDb!, {\n   498→        eventType: 'webhook_received',\n   499→        sourceType: 'webhook',\n   500→        sourceId: personaId,\n   501→        targetPersonaId: personaId,\n   502→        payload: body,\n   503→      });\n   504→      onEventPublished?.();\n   505→      json(res, 201, event);\n   506→    }, 'webhook:receive', 'webhook'),\n   507→  });\n   508→\n   509→  // --- Executions ---\n   510→  resourceRoutes.set(resourceKey('GET', 'executions', false), {\n   511→    needsDb: true,\n   512→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   513→      const params = new URLSearchParams(queryString || '');\n   514→      const executions = db.listExecutions(tenantDb!, {\n   515→        personaId: params.get('personaId') ?? undefined,\n   516→        status: params.get('status') ?? undefined,\n   517→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   518→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   519→        projectId: scopedProjectId,\n   520→      });\n   521→      json(res, 200, executions);\n   522→    },\n   523→  });\n   524→\n   525→  resourceRoutes.set(resourceKey('POST', 'executions', true, 'cancel'), {\n   526→    handler: (_req, res, _ctx, route) => {\n   527→      handleCancelExecution(res, dispatcher, route!.id!);\n   528→    },\n   529→  });\n   530→\n   531→  resourceRoutes.set(resourceKey('GET', 'executions', true), {\n   532→    handler: (_req, res, _ctx, route, queryString) => {\n   533→      const params = new URLSearchParams(queryString || '');\n   534→      const offset = parseInt(params.get('offset') || '0', 10);\n   535→      handleGetExecution(res, dispatcher, route!.id!, offset);\n   536→    },\n   537→  });\n   538→\n   539→  // ── Request handler ──\n   540→  const server = http.createServer(async (req, res) => {\n   541→    // Request correlation ID\n   542→    const reqId = nanoid();\n   543→    const reqLogger = logger.child({ reqId });\n   544→    res.setHeader('X-Request-Id', reqId);\n   545→\n   546→    // Security headers\n   547→    res.setHeader('X-Content-Type-Options', 'nosniff');\n   548→\n   549→    // CORS headers\n   550→    const origin = req.headers.origin ?? '';\n   551→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n   552→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n   553→    if (isAdminRoute) {\n   554→      if (origin && origin === allowedOrigin) {\n   555→        res.setHeader('Access-Control-Allow-Origin', origin);\n   556→      }\n   557→    } else {\n   558→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n   559→    }\n   560→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n   561→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n   562→\n   563→    if (req.method === 'OPTIONS') {\n   564→      res.writeHead(204);\n   565→      res.end();\n   566→      return;\n   567→    }\n   568→\n   569→    const url = req.url || '/';\n   570→    const [pathname, queryString] = url.split('?');\n   571→    const route = parseRoute(pathname ?? '');\n   572→\n   573→    // Unauthenticated endpoint\n   574→    if (pathname === '/health' && req.method === 'GET') {\n   575→      await handleHealth(res, pool, dispatcher, oauth, getEventProcessorHealth, database, tenantDbManager, kafka, triggerScheduler);\n   576→      return;\n   577→    }\n   578→\n   579→    // Auth check\n   580→    const ctx = auth.validateAndExtractContext(req);\n   581→    if (!ctx) {\n   582→      res.writeHead(401, { 'Content-Type': 'application/json' });\n   583→      res.end(JSON.stringify({ error: 'Unauthorized', reqId }));\n   584→      return;\n   585→    }\n   586→\n   587→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n   588→\n   589→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n   590→      if (tenantDbManager && projectId) {\n   591→        return tenantDbManager.getTenantDb(projectId);\n   592→      }\n   593→      return database;\n   594→    };\n   595→    const tenantDb = resolveDatabase(ctx.projectId);\n   596→\n   597→    try {\n   598→      // O(1) exact-path lookup\n   599→      const exactEntry = exactRoutes.get(`${req.method}:${pathname}`);\n   600→      if (exactEntry) {\n   601→        if (exactEntry.adminOnly && requireAdmin(ctx, res)) return;\n   602→        if (exactEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   603→        await exactEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   604→        return;\n   605→      }\n   606→\n   607→      // O(1) resource-route lookup\n   608→      if (route) {\n   609→        const resKey = resourceKey(req.method!, route.resource, !!route.id, route.subResource);\n   610→        const resEntry = resourceRoutes.get(resKey);\n   611→        if (resEntry) {\n   612→          if (resEntry.adminOnly && requireAdmin(ctx, res)) return;\n   613→          if (resEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   614→          await resEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   615→          return;\n   616→        }\n   617→      }\n   618→\n   619→      // No matching route\n   620→      json(res, 404, { error: 'Not found', reqId });\n   621→    } catch (err) {\n   622→      if (err instanceof Error && err.message === 'Payload too large') {\n   623→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   624→        res.end(JSON.stringify({ error: 'Payload too large', reqId }));\n   625→        return;\n   626→      }\n   627→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   628→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   629→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists', reqId }));\n   630→        return;\n   631→      }\n   632→      reqLogger.error({ err, url }, 'HTTP handler error');\n   633→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   634→      res.end(JSON.stringify({ error: 'Internal server error', reqId }));\n   635→    }\n   636→  });\n   637→\n   638→  return server;\n   639→}\n   640→\n   641→/**\n   642→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   643→ * Returns the entity on success, or null after sending a 404 response.\n   644→ */\n   645→function withScopedEntity<T extends { projectId?: string | null }>(\n   646→  entity: T | undefined,\n   647→  scopedProjectId: string | undefined,\n   648→  res: http.ServerResponse,\n   649→): T | null {\n   650→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   651→    json(res, 404, { error: 'Not found' });\n   652→    return null;\n   653→  }\n   654→  return entity;\n   655→}\n   656→\n   657→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   658→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   659→  if (ctx.authType !== 'admin') {\n   660→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   661→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   662→    return true;\n   663→  }\n   664→  return false;\n   665→}\n   666→\n   667→// --- Existing handlers ---\n   668→\n   669→/** Heartbeat age (ms) beyond which a worker is considered stale. */\n   670→const STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n   671→\n   672→async function handleHealth(\n   673→  res: http.ServerResponse,\n   674→  pool: WorkerPool,\n   675→  dispatcher: Dispatcher,\n   676→  oauth: OAuthManager,\n   677→  getEventProcessorHealth?: () => EventProcessorHealth,\n   678→  database?: Database.Database,\n   679→  tenantDbManager?: TenantDbManager,\n   680→  kafka?: KafkaClient,\n   681→  triggerScheduler?: TriggerSchedulerHandle,\n   682→): Promise<void> {\n   683→  const issues: string[] = [];\n   684→\n   685→  const counts = pool.getWorkerCount();\n   686→  const workers = pool.getWorkers();\n   687→  const now = Date.now();\n   688→  const staleWorkers = workers\n   689→    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n   690→    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n   691→\n   692→  if (staleWorkers.length > 0) {\n   693→    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n   694→  }\n   695→\n   696→  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n   697→  if (database) {\n   698→    try {\n   699→      database.prepare('SELECT 1').get();\n   700→      dbHealth.status = 'ok';\n   701→    } catch {\n   702→      dbHealth.status = 'error';\n   703→      issues.push('database unreachable');\n   704→    }\n   705→  }\n   706→  if (tenantDbManager) {\n   707→    try {\n   708→      const tenantIds = tenantDbManager.listTenantIds();\n   709→      dbHealth.tenantCount = tenantIds.length;\n   710→      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n   711→    } catch {\n   712→      dbHealth.tenantCount = -1;\n   713→      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n   714→      issues.push('tenant DB listing failed');\n   715→    }\n   716→  }\n   717→\n   718→  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n   719→  if (kafka) {\n   720→    const kh = await kafka.checkHealth();\n   721→    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n   722→    if (kh.status === 'error') {\n   723→      issues.push(`kafka: ${kh.detail || 'error'}`);\n   724→    }\n   725→  }\n   726→\n   727→  const queueDepth = dispatcher.getQueueLength();\n   728→  const activeExecutions = dispatcher.getActiveExecutions().length;\n   729→\n   730→  let eventProcessorHealth: EventProcessorHealth | undefined;\n   731→  if (getEventProcessorHealth) {\n   732→    eventProcessorHealth = getEventProcessorHealth();\n   733→  }\n   734→\n   735→  let verdict: 'healthy' | 'degraded' | 'unhealthy';\n   736→  if (issues.some(i => i.includes('database unreachable') || i.includes('kafka: '))) {\n   737→    verdict = 'unhealthy';\n   738→  } else if (issues.length > 0) {\n   739→    verdict = 'degraded';\n   740→  } else {\n   741→    verdict = 'healthy';\n   742→  }\n   743→\n   744→  const body: Record<string, unknown> = {\n   745→    status: verdict,\n   746→    timestamp: Date.now(),\n   747→    dependencies: {\n   748→      database: dbHealth,\n   749→      kafka: kafkaHealth,\n   750→      workers: {\n   751→        ...counts,\n   752→        staleWorkers: staleWorkers.length > 0 ? staleWorkers : undefined,\n   753→      },\n   754→    },\n   755→    queue: {\n   756→      depth: queueDepth,\n   757→      activeExecutions,\n   758→    },\n   759→    hasSubscription: oauth.hasTokens(),\n   760→  };\n   761→\n   762→  if (eventProcessorHealth) {\n   763→    (body.dependencies as Record<string, unknown>).eventProcessor = eventProcessorHealth;\n   764→  }\n   765→\n   766→  if (triggerScheduler) {\n   767→    (body as Record<string, unknown>).scheduler = triggerScheduler.getMetrics();\n   768→  }\n   769→\n   770→  if (issues.length > 0) {\n   771→    body.issues = issues;\n   772→  }\n   773→\n   774→  const httpStatus = verdict === 'unhealthy' ? 503 : 200;\n   775→  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n   776→  res.end(JSON.stringify(body));\n   777→}\n   778→\n   779→function handleStatus(\n   780→  res: http.ServerResponse,\n   781→  pool: WorkerPool,\n   782→  dispatcher: Dispatcher,\n   783→  tokenManager: TokenManager,\n   784→  oauth: OAuthManager,\n   785→): void {\n   786→  const oauthTokens = oauth.getTokens();\n   787→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   788→  res.end(JSON.stringify({\n   789→    workers: pool.getWorkers(),\n   790→    workerCounts: pool.getWorkerCount(),\n   791→    workerPoolMetrics: pool.getMetrics(),\n   792→    queueLength: dispatcher.getQueueLength(),\n   793→    activeExecutions: dispatcher.getActiveExecutions(),\n   794→    hasClaudeToken: tokenManager.hasToken(),\n   795→    oauth: {\n   796→      connected: oauth.hasTokens(),\n   797→      scopes: oauthTokens?.scopes || [],\n   798→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   799→    },\n   800→  }));\n   801→}\n   802→\n   803→async function handleExecute(\n   804→  req: http.IncomingMessage,\n   805→  res: http.ServerResponse,\n   806→  dispatcher: Dispatcher,\n   807→  logger: Logger,\n   808→  ctx?: RequestContext,\n   809→): Promise<void> {\n   810→  const body = await readBody(req);\n   811→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   812→\n   813→  try {\n   814→    parsed = JSON.parse(body);\n   815→  } catch {\n   816→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   817→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   818→    return;\n   819→  }\n   820→\n   821→  if (!parsed.prompt) {\n   822→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   823→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   824→    return;\n   825→  }\n   826→\n   827→  const request: ExecRequest = {\n   828→    executionId: nanoid(),\n   829→    personaId: parsed.personaId || 'manual',\n   830→    prompt: parsed.prompt,\n   831→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   832→    config: {\n   833→      timeoutMs: parsed.timeoutMs || 300_000,\n   834→    },\n   835→  };\n   836→\n   837→  dispatcher.submit(request);\n   838→\n   839→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   840→\n   841→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   842→  res.end(JSON.stringify({\n   843→    executionId: request.executionId,\n   844→    status: 'queued',\n   845→  }));\n   846→}\n   847→\n   848→function handleGetExecution(\n   849→  res: http.ServerResponse,\n   850→  dispatcher: Dispatcher,\n   851→  executionId: string,\n   852→  offset: number = 0,\n   853→): void {\n   854→  const exec = dispatcher.getExecution(executionId);\n   855→\n   856→  if (!exec) {\n   857→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   858→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   859→    return;\n   860→  }\n   861→\n   862→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   863→\n   864→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   865→  res.end(JSON.stringify({\n   866→    executionId,\n   867→    status: exec.status,\n   868→    outputLines: exec.output.length,\n   869→    output,\n   870→    durationMs: exec.durationMs,\n   871→    sessionId: exec.sessionId,\n   872→    totalCostUsd: exec.totalCostUsd,\n   873→    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n   874→  }));\n   875→}\n   876→\n   877→function handleCancelExecution(\n   878→  res: http.ServerResponse,\n   879→  dispatcher: Dispatcher,\n   880→  executionId: string,\n   881→): void {\n   882→  const cancelled = dispatcher.cancelExecution(executionId);\n   883→\n   884→  if (!cancelled) {\n   885→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   886→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   887→    return;\n   888→  }\n   889→\n   890→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   891→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   892→}\n   893→\n   894→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB\n   895→const MAX_QUERY_LIMIT = 500;\n   896→const MAX_QUERY_OFFSET = 100_000;\n   897→\n   898→/** Parse an integer query param and clamp it to safe bounds. */\n   899→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   900→  if (!value) return defaultValue;\n   901→  const parsed = parseInt(value, 10);\n   902→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   903→  return Math.min(parsed, max);\n   904→}\n   905→"}]},"parent_tool_use_id":null,"session_id":"acc298eb-2a61-411d-9be8-97133940327a","uuid":"995e3d03-98ea-434f-8b5e-f7b22f9b1fa2","timestamp":"2026-03-18T18:32:37.914Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TriggerSchedulerHandle } from './triggerScheduler.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog, AuditEntry, AuditAction } from './auditLog.js';\nimport type { EventProcessorHealth } from './eventProcessor.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\n// --- Route types ---\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\ntype RouteHandler = (\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  ctx: RequestContext,\n  route: ParsedRoute | null,\n  queryString: string | undefined,\n  tenantDb: Database.Database | undefined,\n  scopedProjectId: string | undefined,\n  reqLogger: Logger,\n) => Promise<void> | void;\n\ninterface RouteEntry {\n  handler: RouteHandler;\n  needsDb?: boolean;\n  adminOnly?: boolean;\n}\n\n/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\nfunction resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  kafka?: KafkaClient,\n  onEventPublished?: () => void,\n  triggerScheduler?: TriggerSchedulerHandle,\n): http.Server {\n\n  /** Wrap a mutation handler to emit an audit event on successful response. */\n  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n        try {\n          auditLog.record({\n            action,\n            tenantId: ctx.projectId || 'default',\n            actor: ctx.userEmail || ctx.projectId,\n            resourceType,\n            resourceId: route?.id,\n            ipAddress: req.socket.remoteAddress,\n          } as AuditEntry);\n        } catch { /* logged inside record() */ }\n      }\n    };\n  }\n\n  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n  const exactRoutes = new Map<string, RouteEntry>();\n\n  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n  for (const [path, method] of [\n    ['/api/oauth/authorize', 'POST'],\n    ['/api/oauth/callback', 'POST'],\n    ['/api/oauth/status', 'GET'],\n    ['/api/oauth/refresh', 'POST'],\n    ['/api/oauth/disconnect', 'DELETE'],\n    ['/api/token', 'POST'],\n  ] as const) {\n    exactRoutes.set(`${method}:${path}`, {\n      adminOnly: true,\n      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger);\n      },\n    });\n  }\n\n  exactRoutes.set('GET:/api/status', {\n    handler: (_req, res) => {\n      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n    },\n  });\n\n  exactRoutes.set('POST:/api/execute', {\n    handler: withHttpAudit(async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n    }, 'execution:submit', 'execution'),\n  });\n\n  exactRoutes.set('POST:/api/gitlab/webhook', {\n    needsDb: true,\n    handler: withHttpAudit(async (req, res, _ctx, _route, _qs, tenantDb) => {\n      const body = await readBody(req);\n      let parsed: Record<string, unknown> = {};\n      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n      const event = db.publishEvent(tenantDb!, {\n        eventType: `gitlab_${objectKind}`,\n        sourceType: 'gitlab',\n        sourceId: projectPath ?? null,\n        payload: body,\n      });\n      onEventPublished?.();\n      json(res, 201, event);\n    }, 'event:publish', 'event'),\n  });\n\n  // Admin routes\n  exactRoutes.set('GET:/api/admin/users', {\n    adminOnly: true,\n    handler: (_req, res) => {\n      if (tenantDbManager) {\n        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n      } else if (database) {\n        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n      } else {\n        json(res, 200, { projectIds: [] });\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/personas', {\n    adminOnly: true,\n    handler: (_req, res) => {\n      if (tenantDbManager) {\n        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n        json(res, 200, allPersonas);\n      } else if (database) {\n        json(res, 200, db.listPersonasSummary(database));\n      } else {\n        json(res, 200, []);\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/executions', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      const params = new URLSearchParams(queryString || '');\n      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n      if (tenantDbManager) {\n        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n        tenantDbManager.forEachTenant((tDb) => {\n          allExecs.push(...db.listExecutions(tDb, { limit }));\n        });\n        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n        json(res, 200, allExecs.slice(0, limit));\n      } else if (database) {\n        json(res, 200, db.listExecutions(database, {\n          limit,\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        }));\n      } else {\n        json(res, 200, []);\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/audit', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      if (!auditLog) { json(res, 200, []); return; }\n      const params = new URLSearchParams(q