[2026-03-18T17:51:52.794Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MFE7dk4KtF8KYfs35tHi7P","type":"tool_result","content":"     1→import pino from 'pino';\n     2→import { loadConfig } from './config.js';\n     3→import { Connection, type WorkerTlsConfig } from './connection.js';\n     4→import { Executor } from './executor.js';\n     5→import { installCredentialExitHandler, sweepOrphanedCredentialFiles } from './credentialInjector.js';\n     6→import { startHealthProbe } from './healthProbe.js';\n     7→import type { ExecAssign } from '@dac-cloud/shared';\n     8→\n     9→const logger = pino({ level: process.env['LOG_LEVEL'] || 'info' });\n    10→\n    11→async function main() {\n    12→  logger.info('Starting DAC Cloud Worker...');\n    13→\n    14→  const config = loadConfig();\n    15→  logger.info({ workerId: config.workerId, orchestratorUrl: config.orchestratorUrl }, 'Configuration loaded');\n    16→\n    17→  // Clean up any credential files left behind by a previous crash\n    18→  installCredentialExitHandler(logger);\n    19→  await sweepOrphanedCredentialFiles(logger);\n    20→\n    21→  const executor = new Executor(logger);\n    22→  let currentExecutionId: string | null = null;\n    23→\n    24→  const connection = new Connection(\n    25→    config.orchestratorUrl,\n    26→    config.workerId,\n    27→    config.workerToken,\n    28→    {\n    29→      onAssign(msg: ExecAssign) {\n    30→        if (currentExecutionId || executor.isBusy()) {\n    31→          logger.warn(\n    32→            { executionId: msg.executionId, currentExecutionId },\n    33→            'Received assignment while busy, sending busy nack',\n    34→          );\n    35→          connection.sendBusy(msg.executionId, 'Worker is already executing');\n    36→          return;\n    37→        }\n    38→\n    39→        currentExecutionId = msg.executionId;\n    40→\n    41→        executor.execute(msg, {\n    42→          onStdout(chunk: string, timestamp: number) {\n    43→            connection.sendStdout(msg.executionId, chunk);\n    44→          },\n    45→\n    46→          onStderr(chunk: string, timestamp: number) {\n    47→            logger.warn({ executionId: msg.executionId, stderr: chunk }, 'CLI stderr');\n    48→            connection.sendStderr(msg.executionId, chunk);\n    49→          },\n    50→\n    51→          onEvent(eventType: 'manual_review' | 'user_message' | 'persona_action' | 'emit_event', payload: unknown) {\n    52→            connection.sendEvent(msg.executionId, eventType, payload);\n    53→          },\n    54→\n    55→          onProgress(phase: string, percent: number, detail?: string) {\n    56→            connection.sendProgress(msg.executionId, phase, percent, detail);\n    57→          },\n    58→\n    59→          onComplete(status, exitCode, durationMs, sessionId, totalCostUsd, phaseTimings) {\n    60→            connection.sendComplete(msg.executionId, status, exitCode, durationMs, sessionId, totalCostUsd, phaseTimings);\n    61→            currentExecutionId = null;\n    62→\n    63→            // Signal ready for next assignment\n    64→            connection.sendReady();\n    65→          },\n    66→        }).catch((err) => {\n    67→          logger.error({ err, executionId: msg.executionId }, 'Execution error');\n    68→          connection.sendComplete(msg.executionId, 'failed', 1, 0);\n    69→          currentExecutionId = null;\n    70→          connection.sendReady();\n    71→        });\n    72→      },\n    73→\n    74→      onCancel(msg) {\n    75→        if (currentExecutionId === msg.executionId) {\n    76→          logger.info({ executionId: msg.executionId }, 'Cancelling execution');\n    77→          executor.kill();\n    78→        }\n    79→      },\n    80→\n    81→      onShutdown(msg) {\n    82→        logger.info({ reason: msg.reason, gracePeriodMs: msg.gracePeriodMs }, 'Shutdown requested');\n    83→\n    84→        if (currentExecutionId) {\n    85→          // Wait for current execution to finish, then exit\n    86→          logger.info('Waiting for current execution to complete before shutdown');\n    87→          const checkInterval = setInterval(() => {\n    88→            if (!currentExecutionId) {\n    89→              clearInterval(checkInterval);\n    90→              shutdown();\n    91→            }\n    92→          }, 1000);\n    93→\n    94→          // Force shutdown after grace period\n    95→          setTimeout(() => {\n    96→            clearInterval(checkInterval);\n    97→            executor.kill();\n    98→            shutdown();\n    99→          }, msg.gracePeriodMs);\n   100→        } else {\n   101→          shutdown();\n   102→        }\n   103→      },\n   104→    },\n   105→    logger,\n   106→    // Pass TLS config if CA or client certs are configured\n   107→    (config.tlsCaPath || config.tlsCertPath) ? {\n   108→      caPath: config.tlsCaPath,\n   109→      certPath: config.tlsCertPath,\n   110→      keyPath: config.tlsKeyPath,\n   111→      rejectUnauthorized: config.tlsRejectUnauthorized,\n   112→    } as WorkerTlsConfig : undefined,\n   113→    { imageDigest: config.imageDigest, claudeCliVersion: config.claudeCliVersion },\n   114→  );\n   115→\n   116→  // Connect to orchestrator\n   117→  connection.connect();\n   118→\n   119→  // Start health probe if configured\n   120→  let healthServer: import('node:http').Server | undefined;\n   121→  if (config.healthPort > 0) {\n   122→    healthServer = startHealthProbe(\n   123→      config.healthPort,\n   124→      connection,\n   125→      executor,\n   126→      config.workerId,\n   127→      logger,\n   128→    );\n   129→  }\n   130→\n   131→  // Graceful shutdown — waits for sandbox/credential cleanup before exiting\n   132→  let shuttingDown = false;\n   133→  async function shutdown() {\n   134→    if (shuttingDown) return;   // prevent double-shutdown\n   135→    shuttingDown = true;\n   136→    logger.info('Shutting down worker...');\n   137→    healthServer?.close();\n   138→    connection.disconnect();\n   139→\n   140→    // Drain the executor's finally-block cleanup (sandbox dirs, credential\n   141→    // files, proxy) before calling process.exit so nothing is leaked.\n   142→    await executor.waitForCleanup();\n   143→    process.exit(0);\n   144→  }\n   145→\n   146→  const onTermSignal = () => {\n   147→    if (currentExecutionId) {\n   148→      logger.info('Termination signal received, killing current execution');\n   149→      executor.kill();\n   150→    }\n   151→    shutdown();\n   152→  };\n   153→\n   154→  process.on('SIGINT', onTermSignal);\n   155→  process.on('SIGTERM', onTermSignal);\n   156→\n   157→  logger.info('DAC Cloud Worker started');\n   158→}\n   159→\n   160→main().catch((err) => {\n   161→  logger.fatal({ err }, 'Failed to start worker');\n   162→  process.exit(1);\n   163→});\n   164→"}]},"parent_tool_use_id":"toolu_01WnHBpnvYFko6UL4CMFQnL4","session_id":"d073280e-6082-4db5-95e6-287c162efeec","uuid":"c882ffd0-def7-4897-b420-d875b8eed231","timestamp":"2026-03-18T17:51:52.224Z"}
