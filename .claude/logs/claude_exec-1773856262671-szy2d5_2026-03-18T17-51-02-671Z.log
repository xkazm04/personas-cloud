[2026-03-18T17:54:00.755Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KUMNK8ShmU9pJmkeKn3oh7","type":"tool_result","content":"     1→import { type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type PhaseTimings, type EncryptedPayload, TOPICS, decrypt, DecryptionError, deriveMasterKeyAsync } from '@dac-cloud/shared';\n     2→import type Database from 'better-sqlite3';\n     3→import type { WorkerPool } from './workerPool.js';\n     4→import type { TokenManager } from './tokenManager.js';\n     5→import type { OAuthManager } from './oauth.js';\n     6→import type { KafkaClient } from './kafka.js';\n     7→import type { TenantDbManager } from './tenantDbManager.js';\n     8→import type { TenantKeyManager } from './tenantKeyManager.js';\n     9→import type { AuditLog } from './auditLog.js';\n    10→import type { Logger } from 'pino';\n    11→import * as db from './db/index.js';\n    12→import { resolveToken, ExecutionPreparer, type Decryptor } from './dispatchPipeline.js';\n    13→\n    14→interface QueuedExecution {\n    15→  request: ExecRequest;\n    16→  receivedAt: number;\n    17→}\n    18→\n    19→// Maximum number of times an execution will be re-queued after worker disconnect\n    20→const MAX_DISCONNECT_RETRIES = 2;\n    21→\n    22→/** All valid execution statuses. */\n    23→type ExecutionStatus = 'queued' | 'running' | 'completed' | 'failed' | 'cancelled';\n    24→\n    25→/** What triggered a state transition. */\n    26→type TransitionTrigger =\n    27→  | 'submit'\n    28→  | 'dispatch'\n    29→  | 'complete'\n    30→  | 'busy-nack'\n    31→  | 'disconnect-retry'\n    32→  | 'disconnect-exhausted'\n    33→  | 'assign-failure';\n    34→\n    35→// In-memory tracking for active executions (real-time output streaming)\n    36→interface ActiveExecution {\n    37→  workerId: string;\n    38→  startedAt: number;\n    39→  output: string[];\n    40→  status: 'running' | 'completed' | 'failed' | 'cancelled';\n    41→  progress?: ProgressInfo;\n    42→  completedAt?: number;\n    43→  exitCode?: number;\n    44→  durationMs?: number;\n    45→  sessionId?: string;\n    46→  totalCostUsd?: number;\n    47→  phaseTimings?: PhaseTimings;\n    48→  /** Original request kept for re-queuing on worker disconnect. Only present for in-flight executions. */\n    49→  request?: ExecRequest;\n    50→  /** How many times this execution has been re-queued after a worker disconnect. */\n    51→  disconnectRetries?: number;\n    52→}\n    53→\n    54→const OUTPUT_FLUSH_INTERVAL_MS = 500;\n    55→\n    56→export class Dispatcher {\n    57→  private queue: QueuedExecution[] = [];\n    58→  // In-memory map for real-time output + cancel routing (active executions only)\n    59→  private active = new Map<string, ActiveExecution>();\n    60→  private tenantDbManager: TenantDbManager | null = null;\n    61→  private masterKey: Buffer | null = null;\n    62→  private tenantKeyManager: TenantKeyManager | null = null;\n    63→  private auditLog: AuditLog | null = null;\n    64→  private preparer: ExecutionPreparer | null = null;\n    65→  // Maps executionId → projectId for DB resolution during callbacks\n    66→  private executionTenant = new Map<string, string>();\n    67→  // Batched output buffers: executionId → pending chunks\n    68→  private outputBuffers = new Map<string, string[]>();\n    69→  private outputFlushTimer: NodeJS.Timeout;\n    70→  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n    71→  private dispatching = false;\n    72→\n    73→  constructor(\n    74→    private pool: WorkerPool,\n    75→    private tokenManager: TokenManager,\n    76→    private oauth: OAuthManager | null,\n    77→    private kafka: KafkaClient,\n    78→    private logger: Logger,\n    79→  ) {\n    80→    // Periodic flush of batched output to DB\n    81→    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n    82→\n    83→    // When a worker becomes ready, try to dispatch queued work\n    84→    this.pool.on('worker-ready', () => {\n    85→      this.processQueue();\n    86→    });\n    87→\n    88→    // When a worker connects, try to dispatch\n    89→    this.pool.on('worker-connected', () => {\n    90→      this.processQueue();\n    91→    });\n    92→\n    93→    // Track stdout for execution output\n    94→    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n    95→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    96→    });\n    97→\n    98→    // Track stderr for debugging failed executions\n    99→    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n   100→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n   101→      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n   102→    });\n   103→\n   104→    // Handle execution completion\n   105→    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n   106→      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   107→        executionId: msg.executionId,\n   108→        status: msg.status,\n   109→        exitCode: msg.exitCode,\n   110→        durationMs: msg.durationMs,\n   111→        sessionId: msg.sessionId,\n   112→        totalCostUsd: msg.totalCostUsd,\n   113→        ...(msg.phaseTimings ? { phaseTimings: msg.phaseTimings } : {}),\n   114→      }), msg.executionId).catch(err => {\n   115→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n   116→      });\n   117→\n   118→      // Flush any remaining buffered output before persisting completion\n   119→      this.flushOutputForExecution(msg.executionId);\n   120→\n   121→      // Update in-memory\n   122→      const exec = this.active.get(msg.executionId);\n   123→      if (exec) {\n   124→        exec.status = msg.status;\n   125→        exec.completedAt = Date.now();\n   126→        exec.exitCode = msg.exitCode;\n   127→        exec.durationMs = msg.durationMs;\n   128→        exec.sessionId = msg.sessionId;\n   129→        exec.totalCostUsd = msg.totalCostUsd;\n   130→        exec.phaseTimings = msg.phaseTimings;\n   131→        // Remove from active after a short delay (allow polling to pick up final state)\n   132→        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n   133→      }\n   134→\n   135→      // Persist to DB\n   136→      const completeDb = this.resolveDbForExecution(msg.executionId);\n   137→      if (completeDb) {\n   138→        try {\n   139→          db.updateExecution(completeDb, msg.executionId, {\n   140→            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n   141→            completedAt: new Date().toISOString(),\n   142→            durationMs: msg.durationMs,\n   143→            claudeSessionId: msg.sessionId,\n   144→            costUsd: msg.totalCostUsd ?? 0,\n   145→          });\n   146→        } catch (err) {\n   147→          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n   148→        }\n   149→      }\n   150→\n   151→      // Clean up tenant mapping after completion delay\n   152→      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n   153→\n   154→      // Process next queued item\n   155→      this.processQueue();\n   156→    });\n   157→\n   158→    // Track execution progress\n   159→    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n   160→      const exec = this.active.get(msg.executionId);\n   161→      if (exec) {\n   162→        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n   163→      }\n   164→      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n   165→        executionId: msg.executionId,\n   166→        phase: msg.phase,\n   167→        percent: msg.percent,\n   168→        detail: msg.detail,\n   169→        timestamp: msg.timestamp,\n   170→      }), msg.executionId).catch(err => {\n   171→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n   172→      });\n   173→    });\n   174→\n   175→    // Forward persona events to Kafka\n   176→    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n   177→      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n   178→        executionId: msg.executionId,\n   179→        eventType: msg.eventType,\n   180→        payload: msg.payload,\n   181→        timestamp: Date.now(),\n   182→      }), msg.executionId).catch(err => {\n   183→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n   184→      });\n   185→    });\n   186→\n   187→    // Handle worker busy nack — re-queue the rejected execution\n   188→    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n   189→      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n   190→      const exec = this.active.get(msg.executionId);\n   191→      if (exec?.request) {\n   192→        const request = exec.request;\n   193→        this.active.delete(msg.executionId);\n   194→        // Mark as queued in DB\n   195→        const reqDb = this.resolveDbForExecution(msg.executionId);\n   196→        if (reqDb) {\n   197→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack'); }\n   198→        }\n   199→        this.queue.unshift({ request, receivedAt: Date.now() });\n   200→        this.processQueue();\n   201→      } else {\n   202→        // Fallback: reconstruct from DB if request was not stored (should not happen)\n   203→        this.active.delete(msg.executionId);\n   204→        const projectId = this.executionTenant.get(msg.executionId) || 'default';\n   205→        const reqDb = this.resolveDb(projectId);\n   206→        if (reqDb) {\n   207→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack fallback'); }\n   208→        }\n   209→        const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n   210→        if (dbExec) {\n   211→          this.queue.unshift({\n   212→            request: {\n   213→              executionId: msg.executionId,\n   214→              personaId: dbExec.personaId,\n   215→              prompt: dbExec.inputData || '',\n   216→              projectId,\n   217→              config: { timeoutMs: 300_000 },\n   218→            },\n   219→            receivedAt: Date.now(),\n   220→          });\n   221→          this.processQueue();\n   222→        }\n   223→      }\n   224→    });\n   225→\n   226→    // Handle worker disconnect during execution — re-queue if retries remain\n   227→    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n   228→      if (executionId) {\n   229→        const exec = this.active.get(executionId);\n   230→        const retries = exec?.disconnectRetries ?? 0;\n   231→\n   232→        if (exec?.request && retries < MAX_DISCONNECT_RETRIES) {\n   233→          // Re-queue for retry\n   234→          const nextRetry = retries + 1;\n   235→          this.logger.warn({ executionId, retry: nextRetry, maxRetries: MAX_DISCONNECT_RETRIES }, 'Worker disconnected during execution, re-queuing');\n   236→\n   237→          // Clear the active entry so dispatchToWorker can create a fresh one\n   238→          this.active.delete(executionId);\n   239→\n   240→          // Mark as queued in DB\n   241→          const disconnDb = this.resolveDbForExecution(executionId);\n   242→          if (disconnDb) {\n   243→            try {\n   244→              db.updateExecution(disconnDb, executionId, {\n   245→                status: 'queued',\n   246→                errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n   247→              });\n   248→            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on worker disconnect re-queue'); }\n   249→          }\n   250→\n   251→          // Temporarily store the retry count so dispatchToWorker picks it up\n   252→          const request = exec.request;\n   253→          // Create a placeholder active entry to carry retry count across re-dispatch\n   254→          this.active.set(executionId, {\n   255→            workerId: '',\n   256→            startedAt: 0,\n   257→            output: [],\n   258→            status: 'running',\n   259→            request,\n   260→            disconnectRetries: nextRetry,\n   261→          });\n   262→\n   263→          this.queue.unshift({ request, receivedAt: Date.now() });\n   264→          this.processQueue();\n   265→        } else {\n   266→          // Retries exhausted or no request stored — permanent failure\n   267→          this.logger.error({ executionId, retries }, 'Worker disconnected during execution, retries exhausted');\n   268→          if (exec) {\n   269→            exec.status = 'failed';\n   270→            exec.completedAt = Date.now();\n   271→            setTimeout(() => this.active.delete(executionId), 30_000);\n   272→          }\n   273→\n   274→          const disconnDb = this.resolveDbForExecution(executionId);\n   275→          if (disconnDb) {\n   276→            try {\n   277→              db.updateExecution(disconnDb, executionId, {\n   278→                status: 'failed',\n   279→                errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n   280→                completedAt: new Date().toISOString(),\n   281→              });\n   282→            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:failed' }, 'Failed to persist execution failure on worker disconnect'); }\n   283→          }\n   284→          this.executionTenant.delete(executionId);\n   285→\n   286→          this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   287→            executionId,\n   288→            status: 'failed',\n   289→            error: 'Worker disconnected (retries exhausted)',\n   290→            durationMs: 0,\n   291→          }), executionId).catch(err => { this.logger.warn({ err, executionId, op: 'kafka:exec_lifecycle' }, 'Failed to produce disconnect failure lifecycle to Kafka'); });\n   292→        }\n   293→      }\n   294→    });\n   295→  }\n   296→\n   297→  setTenantDbManager(mgr: TenantDbManager): void {\n   298→    this.tenantDbManager = mgr;\n   299→  }\n   300→\n   301→  async setMasterKey(masterKeyHex: string): Promise<void> {\n   302→    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n   303→  }\n   304→\n   305→  setTenantKeyManager(mgr: TenantKeyManager): void {\n   306→    this.tenantKeyManager = mgr;\n   307→  }\n   308→\n   309→  setAuditLog(log: AuditLog): void {\n   310→    this.auditLog = log;\n   311→  }\n   312→\n   313→  /** Resolve the database for a given projectId via tenant DB manager. */\n   314→  private resolveDb(projectId?: string): Database.Database | null {\n   315→    if (this.tenantDbManager && projectId) {\n   316→      return this.tenantDbManager.getTenantDb(projectId);\n   317→    }\n   318→    return null;\n   319→  }\n   320→\n   321→  /** Resolve the database for an in-flight execution by its ID. */\n   322→  private resolveDbForExecution(executionId: string): Database.Database | null {\n   323→    const projectId = this.executionTenant.get(executionId);\n   324→    return this.resolveDb(projectId);\n   325→  }\n   326→\n   327→  /**\n   328→   * Emit a single structured log entry for every execution state transition.\n   329→   * Creates a queryable timeline: grep for \"Execution state transition\" to see\n   330→   * the full lifecycle of any execution.\n   331→   */\n   332→  private logTransition(opts: {\n   333→    executionId: string;\n   334→    previousState: ExecutionStatus | null;\n   335→    newState: ExecutionStatus;\n   336→    trigger: TransitionTrigger;\n   337→    workerId?: string;\n   338→    personaId?: string;\n   339→    queueWaitMs?: number;\n   340→    disconnectRetries?: number;\n   341→    errorMessage?: string;\n   342→  }): void {\n   343→    this.logger.info({\n   344→      executionId: opts.executionId,\n   345→      previousState: opts.previousState,\n   346→      newState: opts.newState,\n   347→      trigger: opts.trigger,\n   348→      ...(opts.workerId ? { workerId: opts.workerId } : {}),\n   349→      ...(opts.personaId ? { personaId: opts.personaId } : {}),\n   350→      ...(opts.queueWaitMs !== undefined ? { queueWaitMs: opts.queueWaitMs } : {}),\n   351→      ...(opts.disconnectRetries !== undefined ? { disconnectRetries: opts.disconnectRetries } : {}),\n   352→      ...(opts.errorMessage ? { errorMessage: opts.errorMessage } : {}),\n   353→    }, 'Execution state transition');\n   354→  }\n   355→\n   356→  /**\n   357→   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   358→   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   359→   */\n   360→  private async decryptWithAudit(\n   361→    payload: EncryptedPayload,\n   362→    tenantId: string,\n   363→    resourceId: string,\n   364→    logContext: Record<string, unknown>,\n   365→    logMessage: string,\n   366→  ): Promise<string | undefined> {\n   367→    const decryptKey = this.tenantKeyManager\n   368→      ? await this.tenantKeyManager.getKey(tenantId)\n   369→      : this.masterKey;\n   370→    if (!decryptKey) return undefined;\n   371→\n   372→    try {\n   373→      const decrypted = decrypt(payload, decryptKey, { tenantId, credentialId: resourceId, resourceType: 'credential' });\n   374→      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n   375→      return decrypted;\n   376→    } catch (err) {\n   377→      const reason = err instanceof DecryptionError ? err.message : (err instanceof Error ? err.message : String(err));\n   378→      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n   379→      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: { reason } }); } catch { /* logged inside record() */ }\n   380→      return undefined;\n   381→    }\n   382→  }\n   383→\n   384→  submit(request: ExecRequest): void {\n   385→    this.logger.info({\n   386→      executionId: request.executionId,\n   387→      personaId: request.personaId,\n   388→      ...(request.eventId ? { eventId: request.eventId } : {}),\n   389→    }, 'Execution submitted');\n   390→\n   391→    // Track which tenant owns this execution (for callback DB resolution)\n   392→    const projectId = request.projectId || 'default';\n   393→    this.executionTenant.set(request.executionId, projectId);\n   394→\n   395→    // Create DB record immediately\n   396→    const submitDb = this.resolveDb(projectId);\n   397→    if (submitDb) {\n   398→      try {\n   399→        db.createExecution(submitDb, {\n   400→          id: request.executionId,\n   401→          personaId: request.personaId,\n   402→          inputData: request.prompt,\n   403→          projectId,\n   404→          eventId: request.eventId ?? null,\n   405→        });\n   406→      } catch (err) {\n   407→        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n   408→      }\n   409→    }\n   410→\n   411→    this.queue.push({ request, receivedAt: Date.now() });\n   412→    this.processQueue();\n   413→  }\n   414→\n   415→  private async processQueue(): Promise<void> {\n   416→    // Guard: only one processQueue loop runs at a time to prevent concurrent\n   417→    // calls from racing on getIdleWorker()/assign() and double-claiming a worker.\n   418→    if (this.dispatching) return;\n   419→    this.dispatching = true;\n   420→    try {\n   421→      while (this.queue.length > 0) {\n   422→        const workerId = this.pool.getIdleWorker();\n   423→        if (!workerId) {\n   424→          this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n   425→          return;\n   426→        }\n   427→\n   428→        const item = this.queue.shift()!;\n   429→        await this.dispatchToWorker(workerId, item.request);\n   430→      }\n   431→    } finally {\n   432→      this.dispatching = false;\n   433→    }\n   434→  }\n   435→\n   436→  /** Exposes decryptWithAudit as the Decryptor interface for pipeline stages. */\n   437→  private getDecryptor(): Decryptor {\n   438→    return {\n   439→      decrypt: (payload, tenantId, resourceId, logContext, logMessage) =>\n   440→        this.decryptWithAudit(payload, tenantId, resourceId, logContext, logMessage),\n   441→    };\n   442→  }\n   443→\n   444→  /** Lazily initialise the ExecutionPreparer (depends on mutable setter state). */\n   445→  private ensurePreparer(): ExecutionPreparer {\n   446→    if (!this.preparer) {\n   447→      this.preparer = new ExecutionPreparer(\n   448→        (projectId) => this.resolveDb(projectId),\n   449→        this.getDecryptor(),\n   450→        this.logger,\n   451→      );\n   452→    }\n   453→    return this.preparer;\n   454→  }\n   455→\n   456→  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n   457→    // Stage 1: Resolve token (stays in Dispatcher)\n   458→    const token = await resolveToken(this.oauth, this.tokenManager);\n   459→    if (!token) {\n   460→      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n   461→      this.queue.unshift({ request, receivedAt: Date.now() });\n   462→      return;\n   463→    }\n   464→\n   465→    // Stages 2-4: Persona resolution, payload assembly, assignment building\n   466→    const assignment = await this.ensurePreparer().prepare(request, token);\n   467→    const tenantId = request.projectId || 'default';\n   468→    const dispatchDb = this.resolveDb(tenantId);\n   469→\n   470→    // Track in-memory for real-time streaming (preserve retry count across re-dispatches)\n   471→    const prevRetries = this.active.get(request.executionId)?.disconnectRetries ?? 0;\n   472→    this.active.set(request.executionId, {\n   473→      workerId,\n   474→      startedAt: Date.now(),\n   475→      output: [],\n   476→      status: 'running',\n   477→      request,\n   478→      disconnectRetries: prevRetries,\n   479→    });\n   480→\n   481→    // Mark running in DB\n   482→    if (dispatchDb) {\n   483→      try {\n   484→        db.updateExecution(dispatchDb, request.executionId, {\n   485→          status: 'running',\n   486→          startedAt: new Date().toISOString(),\n   487→        });\n   488→      } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:running' }, 'Failed to mark execution as running in DB'); }\n   489→    }\n   490→\n   491→    const sent = this.pool.assign(workerId, assignment);\n   492→    if (!sent) {\n   493→      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n   494→      this.active.delete(request.executionId);\n   495→      if (dispatchDb) {\n   496→        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:queued' }, 'Failed to re-queue execution in DB after assign failure'); }\n   497→      }\n   498→      this.queue.unshift({ request, receivedAt: Date.now() });\n   499→      this.processQueue();\n   500→    } else {\n   501→      this.logger.info({\n   502→        workerId,\n   503→        executionId: request.executionId,\n   504→        personaId: request.personaId,\n   505→        ...(request.eventId ? { eventId: request.eventId } : {}),\n   506→      }, 'Execution dispatched to worker');\n   507→    }\n   508→  }\n   509→\n   510→  cancelExecution(executionId: string): boolean {\n   511→    const exec = this.active.get(executionId);\n   512→    if (!exec || exec.status !== 'running') return false;\n   513→\n   514→    return this.pool.send(exec.workerId, {\n   515→      type: 'cancel',\n   516→      executionId,\n   517→    });\n   518→  }\n   519→\n   520→  getQueueLength(): number {\n   521→    return this.queue.length;\n   522→  }\n   523→\n   524→  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n   525→    return Array.from(this.active.entries())\n   526→      .filter(([, e]) => e.status === 'running')\n   527→      .map(([executionId, e]) => ({\n   528→        executionId,\n   529→        workerId: e.workerId,\n   530→        startedAt: e.startedAt,\n   531→      }));\n   532→  }\n   533→\n   534→  /**\n   535→   * Get execution state. Tries in-memory first (for real-time output),\n   536→   * then falls back to DB for completed/historical executions.\n   537→   */\n   538→  getExecution(executionId: string): ActiveExecution | null {\n   539→    // Check in-memory active executions first\n   540→    const active = this.active.get(executionId);\n   541→    if (active) return active;\n   542→\n   543→    const execDb = this.resolveDbForExecution(executionId);\n   544→    if (execDb) {\n   545→      const dbExec = db.getExecution(execDb, executionId);\n   546→      if (dbExec) {\n   547→        return {\n   548→          workerId: '',\n   549→          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n   550→          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n   551→          status: dbExec.status as ActiveExecution['status'],\n   552→          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n   553→          durationMs: dbExec.durationMs ?? undefined,\n   554→          sessionId: dbExec.claudeSessionId ?? undefined,\n   555→          totalCostUsd: dbExec.costUsd ?? undefined,\n   556→        };\n   557→      }\n   558→    }\n   559→\n   560→    return null;\n   561→  }\n   562→\n   563→  getExecutionOutput(executionId: string): string[] | null {\n   564→    const exec = this.getExecution(executionId);\n   565→    return exec?.output ?? null;\n   566→  }\n   567→\n   568→  /** Shared handler for stdout/stderr output chunks. */\n   569→  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n   570→    const line = prefix ? `${prefix}${chunk}` : chunk;\n   571→\n   572→    const exec = this.active.get(executionId);\n   573→    if (exec) {\n   574→      exec.output.push(line);\n   575→    }\n   576→\n   577→    this.bufferOutput(executionId, line + '\\n');\n   578→\n   579→    // Forward stdout to Kafka (stderr is not forwarded)\n   580→    if (!prefix) {\n   581→      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n   582→        executionId,\n   583→        chunk,\n   584→        timestamp,\n   585→      }), executionId).catch(err => {\n   586→        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n   587→      });\n   588→    }\n   589→  }\n   590→\n   591→  /** Buffer an output chunk for batched DB write. */\n   592→  private bufferOutput(executionId: string, chunk: string): void {\n   593→    let buf = this.outputBuffers.get(executionId);\n   594→    if (!buf) {\n   595→      buf = [];\n   596→      this.outputBuffers.set(executionId, buf);\n   597→    }\n   598→    buf.push(chunk);\n   599→  }\n   600→\n   601→  /** Flush buffered output for a specific execution to DB. */\n   602→  private flushOutputForExecution(executionId: string): void {\n   603→    const buf = this.outputBuffers.get(executionId);\n   604→    if (!buf || buf.length === 0) return;\n   605→\n   606→    const combined = buf.join('');\n   607→    this.outputBuffers.delete(executionId);\n   608→\n   609→    const outputDb = this.resolveDbForExecution(executionId);\n   610→    if (outputDb) {\n   611→      try { db.appendOutput(outputDb, executionId, combined); } catch (err) { this.logger.warn({ err, executionId, op: 'appendOutput' }, 'Failed to flush buffered output to DB'); }\n   612→    }\n   613→  }\n   614→\n   615→  /** Flush all buffered output across all executions to DB. */\n   616→  private flushOutputBuffers(): void {\n   617→    for (const executionId of this.outputBuffers.keys()) {\n   618→      this.flushOutputForExecution(executionId);\n   619→    }\n   620→  }\n   621→\n   622→  shutdown(): void {\n   623→    clearInterval(this.outputFlushTimer);\n   624→    this.flushOutputBuffers();\n   625→  }\n   626→}\n   627→"}]},"parent_tool_use_id":null,"session_id":"d073280e-6082-4db5-95e6-287c162efeec","uuid":"6b4ae21f-78f2-4758-b3a1-466704cfab13","timestamp":"2026-03-18T17:54:00.658Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\dispatcher.ts","content":"import { type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type PhaseTimings, type EncryptedPayload, TOPICS, decrypt, DecryptionError, deriveMasterKeyAsync } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { resolveToken, ExecutionPreparer, type Decryptor } from './dispatchPipeline.js';\n\ninterface QueuedExecution {\n  request: ExecRequest;\n  receivedAt: number;\n}\n\n// Maximum number of times an execution will be re-queued after worker disconnect\nconst MAX_DISCONNECT_RETRIES = 2;\n\n/** All valid execution statuses. */\ntype ExecutionStatus = 'queued' | 'running' | 'completed' | 'failed' | 'cancelled';\n\n/** What triggered a state transition. */\ntype TransitionTrigger =\n  | 'submit'\n  | 'dispatch'\n  | 'complete'\n  | 'busy-nack'\n  | 'disconnect-retry'\n  | 'disconnect-exhausted'\n  | 'assign-failure';\n\n// In-memory tracking for active executions (real-time output streaming)\ninterface ActiveExecution {\n  workerId: string;\n  startedAt: number;\n  output: string[];\n  status: 'running' | 'completed' | 'failed' | 'cancelled';\n  progress?: ProgressInfo;\n  completedAt?: number;\n  exitCode?: number;\n  durationMs?: number;\n  sessionId?: string;\n  totalCostUsd?: number;\n  phaseTimings?: PhaseTimings;\n  /** Original request kept for re-queuing on worker disconnect. Only present for in-flight executions. */\n  request?: ExecRequest;\n  /** How many times this execution has been re-queued after a worker disconnect. */\n  disconnectRetries?: number;\n}\n\nconst OUTPUT_FLUSH_INTERVAL_MS = 500;\n\nexport class Dispatcher {\n  private queue: QueuedExecution[] = [];\n  // In-memory map for real-time output + cancel routing (active executions only)\n  private active = new Map<string, ActiveExecution>();\n  private tenantDbManager: TenantDbManager | null = null;\n  private masterKey: Buffer | null = null;\n  private tenantKeyManager: TenantKeyManager | null = null;\n  private auditLog: AuditLog | null = null;\n  private preparer: ExecutionPreparer | null = null;\n  // Maps executionId → projectId for DB resolution during callbacks\n  private executionTenant = new Map<string, string>();\n  // Batched output buffers: executionId → pending chunks\n  private outputBuffers = new Map<string, string[]>();\n  private outputFlushTimer: NodeJS.Timeout;\n  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n  private dispatching = false;\n\n  constructor(\n    private pool: WorkerPool,\n    private tokenManager: TokenManager,\n    private oauth: OAuthManager | null,\n    private kafka: KafkaClient,\n    private logger: Logger,\n  ) {\n    // Periodic flush of batched output to DB\n    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n\n    // When a worker becomes ready, try to dispatch queued work\n    this.pool.on('worker-ready', () => {\n      this.processQueue();\n    });\n\n    // When a worker connects, try to dispatch\n    this.pool.on('worker-connected', () => {\n      this.processQueue();\n    });\n\n    // Track stdout for execution output\n    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    });\n\n    // Track stderr for debugging failed executions\n    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    });\n\n    // Handle execution completion\n    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n        executionId: msg.executionId,\n        status: msg.status,\n        exitCode: msg.exitCode,\n        durationMs: msg.durationMs,\n        sessionId: msg.sessionId,\n        totalCostUsd: msg.totalCostUsd,\n        ...(msg.phaseTimings ? { phaseTimings: msg.phaseTimings } : {}),\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n      });\n\n      // Flush any remaining buffered output before persisting completion\n      this.flushOutputForExecution(msg.executionId);\n\n      // Update in-memory\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.status = msg.status;\n        exec.completedAt = Date.now();\n        exec.exitCode = msg.exitCode;\n        exec.durationMs = msg.durationMs;\n        exec.sessionId = msg.sessionId;\n        exec.totalCostUsd = msg.totalCostUsd;\n        exec.phaseTimings = msg.phaseTimings;\n        // Remove from active after a short delay (allow polling to pick up final state)\n        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n      }\n\n      // Persist to DB\n      const completeDb = this.resolveDbForExecution(msg.executionId);\n      if (completeDb) {\n        try {\n          db.updateExecution(completeDb, msg.executionId, {\n            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n            completedAt: new Date().toISOString(),\n            durationMs: msg.durationMs,\n            claudeSessionId: msg.sessionId,\n            costUsd: msg.totalCostUsd ?? 0,\n          });\n        } catch (err) {\n          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n        }\n      }\n\n      // Clean up tenant mapping after completion delay\n      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n\n      // Process next queued item\n      this.processQueue();\n    });\n\n    // Track execution progress\n    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n      }\n      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n        executionId: msg.executionId,\n        phase: msg.phase,\n        percent: msg.percent,\n        detail: msg.detail,\n        timestamp: msg.timestamp,\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n      });\n    });\n\n    // Forward persona events to Kafka\n    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n        executionId: msg.executionId,\n        eventType: msg.eventType,\n        payload: msg.payload,\n        timestamp: Date.now(),\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n      });\n    });\n\n    // Handle worker busy nack — re-queue the rejected execution\n    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n      const exec = this.active.get(msg.executionId);\n      if (exec?.request) {\n        const request = exec.request;\n        this.active.delete(msg.executionId);\n        // Mark as queued in DB\n        const reqDb = this.resolveDbForExecution(msg.executionId);\n        if (reqDb) {\n          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack'); }\n        }\n        this.queue.unshift({ request, receivedAt: Date.now() });\n        this.processQueue();\n      } else {\n        // Fallback: reconstruct from DB if request was not stored (should not happen)\n        this.active.delete(msg.executionId);\n        const projectId = this.executionTenant.get(msg.executionId) || 'default';\n        const reqDb = this.resolveDb(projectId);\n        if (reqDb) {\n          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack fallback'); }\n        }\n        const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n        if (dbExec) {\n          this.queue.unshift({\n            request: {\n              executionId: msg.executionId,\n              personaId: dbExec.personaId,\n              prompt: dbExec.inputData || '',\n              projectId,\n              config: { timeoutMs: 300_000 },\n            },\n            receivedAt: Date.now(),\n          });\n          this.processQueue();\n        }\n      }\n    });\n\n    // Handle worker disconnect during execution — re-queue if retries remain\n    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n      if (executionId) {\n        const exec = this.active.get(executionId);\n        const retries = exec?.disconnectRetries ?? 0;\n\n        if (exec?.request && retries < MAX_DISCONNECT_RETRIES) {\n          // Re-queue for retry\n          const nextRetry = retries + 1;\n          this.logger.warn({ executionId, retry: nextRetry, maxRetries: MAX_DISCONNECT_RETRIES }, 'Worker disconnected during execution, re-queuing');\n\n          // Clear the active entry so dispatchToWorker can create a fresh one\n          this.active.delete(executionId);\n\n          // Mark as queued in DB\n          const disconnDb = this.resolveDbForExecution(executionId);\n          if (disconnDb) {\n            try {\n              db.updateExecution(disconnDb, executionId, {\n                status: 'queued',\n                errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n              });\n            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on worker disconnect re-queue'); }\n          }\n\n          // Temporarily store the retry count so dispatchToWorker picks it up\n          const request = exec.request;\n          // Create a placeholder active entry to carry retry count across re-dispatch\n          this.active.set(executionId, {\n            workerId: '',\n            startedAt: 0,\n            output: [],\n            status: 'running',\n            request,\n            disconnectRetries: nextRetry,\n          });\n\n          this.queue.unshift({ request, receivedAt: Date.now() });\n          this.processQueue();\n        } else {\n          // Retries exhausted or no request stored — permanent failure\n          this.logger.error({ executionId, retries }, 'Worker disconnected during execution, retries exhausted');\n          if (exec) {\n            exec.status = 'failed';\n            exec.completedAt = Date.now();\n            setTimeout(() => this.active.delete(executionId), 30_000);\n          }\n\n          const disconnDb = this.resolveDbForExecution(executionId);\n          if (disconnDb) {\n            try {\n              db.updateExecution(disconnDb, executionId, {\n                status: 'failed',\n                errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n                completedAt: new Date().toISOString(),\n              });\n            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:failed' }, 'Failed to persist execution failure on worker disconnect'); }\n          }\n          this.executionTenant.delete(executionId);\n\n          this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n            executionId,\n            status: 'failed',\n            error: 'Worker disconnected (retries exhausted)',\n            durationMs: 0,\n          }), executionId).catch(err => { this.logger.warn({ err, executionId, op: 'kafka:exec_lifecycle' }, 'Failed to produce disconnect failure lifecycle to Kafka'); });\n        }\n      }\n    });\n  }\n\n  setTenantDbManager(mgr: TenantDbManager): void {\n    this.tenantDbManager = mgr;\n  }\n\n  async setMasterKey(masterKeyHex: string): Promise<void> {\n    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n  }\n\n  setTenantKeyManager(mgr: TenantKeyManager): void {\n    this.tenantKeyManager = mgr;\n  }\n\n  setAuditLog(log: AuditLog): void {\n    this.auditLog = log;\n  }\n\n  /** Resolve the database for a given projectId via tenant DB manager. */\n  private resolveDb(projectId?: string): Database.Database | null {\n    if (this.tenantDbManager && projectId) {\n      return this.tenantDbManager.getTenantDb(projectId);\n    }\n    return null;\n  }\n\n  /** Resolve the database for an in-flight execution by its ID. */\n  private resolveDbForExecution(executionId: string): Database.Database | null {\n    const projectId = this.executionTenant.get(executionId);\n    return this.resolveDb(projectId);\n  }\n\n  /**\n   * Emit a single structured log entry for every execution state transition.\n   * Creates a queryable timeline: grep for \"Execution state transition\" to see\n   * the full lifecycle of any execution.\n   */\n  private logTransition(opts: {\n    executionId: string;\n    previousState: ExecutionStatus | null;\n    newState: ExecutionStatus;\n    trigger: TransitionTrigger;\n    workerId?: string;\n    personaId?: string;\n    queueWaitMs?: number;\n    disconnectRetries?: number;\n    errorMessage?: string;\n  }): void {\n    this.logger.info({\n      executionId: opts.executionId,\n      previousState: opts.previousState,\n      newState: opts.newState,\n      trigger: opts.trigger,\n      ...(opts.workerId ? { workerId: opts.workerId } : {}),\n      ...(opts.personaId ? { personaId: opts.personaId } : {}),\n      ...(opts.queueWaitMs !== undefined ? { queueWaitMs: opts.queueWaitMs } : {}),\n      ...(opts.disconnectRetries !== undefined ? { disconnectRetries: opts.disconnectRetries } : {}),\n      ...(opts.errorMessage ? { errorMessage: opts.errorMessage } : {}),\n    }, 'Execution state transition');\n  }\n\n  /**\n   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   */\n  private async decryptWithAudit(\n    payload: EncryptedPayload,\n    tenantId: string,\n    resourceId: string,\n    logContext: Record<string, unknown>,\n    logMessage: string,\n  ): Promise<string | undefined> {\n    const decryptKey = this.tenantKeyManager\n      ? await this.tenantKeyManager.getKey(tenantId)\n      : this.masterKey;\n    if (!decryptKey) return undefined;\n\n    try {\n      const decrypted = decrypt(payload, decryptKey, { tenantId, credentialId: resourceId, resourceType: 'credential' });\n      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n      return decrypted;\n    } catch (err) {\n      const reason = err instanceof DecryptionError ? err.message : (err instanceof Error ? err.message : String(err));\n      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: { reason } }); } catch { /* logged inside record() */ }\n      return undefined;\n    }\n  }\n\n  submit(request: ExecRequest): void {\n    this.logger.info({\n      executionId: request.executionId,\n      personaId: request.personaId,\n      ...(request.eventId ? { eventId: request.eventId } : {}),\n    }, 'Execution submitted');\n\n    // Track which tenant owns this execution (for callback DB resolution)\n    const projectId = request.projectId || 'default';\n    this.executionTenant.set(request.executionId, projectId);\n\n    // Create DB record immediately\n    const submitDb = this.resolveDb(projectId);\n    if (submitDb) {\n      try {\n        db.createExecution(submitDb, {\n          id: request.executionId,\n          personaId: request.personaId,\n          inputData: request.prompt,\n          projectId,\n          eventId: request.eventId ?? null,\n        });\n      } catch (err) {\n        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n      }\n    }\n\n    this.queue.push({ request, receivedAt: Date.now() });\n    this.processQueue();\n  }\n\n  private async processQueue(): Promise<void> {\n    // Guard: only one processQueue loop runs at a time to prevent concurrent\n    // calls from racing on getIdleWorker()/assign() and double-claiming a worker.\n    if (this.dispatching) return;\n    this.dispatching = true;\n    try {\n      while (this.queue.length > 0) {\n        const workerId = this.pool.getIdleWorker();\n        if (!workerId) {\n          this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n          return;\n        }\n\n        const item = this.queue.shift()!;\n        await this.dispatchToWorker(workerId, item.request);\n      }\n    } finally {\n      this.dispatching = false;\n    }\n  }\n\n  /** Exposes decryptWithAudit as the Decryptor interface for pipeline stages. */\n  private getDecryptor(): Decryptor {\n    return {\n      decrypt: (payload, tenantId, resourceId, logContext, logMessage) =>\n        this.decryptWithAudit(payload, tenantId, resourceId, logContext, logMessage),\n    };\n  }\n\n  /** Lazily initialise the ExecutionPreparer (depends on mutable setter state). */\n  private ensurePreparer(): ExecutionPreparer {\n    if (!this.preparer) {\n      this.preparer = new ExecutionPreparer(\n        (projectId) => this.resolveDb(projectId),\n        this.getDecryptor(),\n        this.logger,\n      );\n    }\n    return this.preparer;\n  }\n\n  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n    // Stage 1: Resolve token (stays in Dispatcher)\n    const token = await resolveToken(this.oauth, this.tokenManager);\n    if (!token) {\n      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      return;\n    }\n\n    // Stages 2-4: Persona resolution, payload assembly, assignment building\n    const assignment = await this.ensurePreparer().prepare(request, token);\n    const tenantId = request.projectId || 'default';\n    const dispatchDb = this.resolveDb(tenantId);\n\n    // Track in-memory for real-time streaming (preserve retry count across re-dispatches)\n    const prevRetries = this.active.get(request.executionId)?.disconnectRetries ?? 0;\n    this.active.set(request.executionId, {\n      workerId,\n      startedAt: Date.now(),\n      output: [],\n      status: 'running',\n      request,\n      disconnectRetries: prevRetries,\n    });\n\n    // Mark running in DB\n    if (dispatchDb) {\n      try {\n        db.updateExecution(dispatchDb, request.executionId, {\n          status: 'running',\n          startedAt: new Date().toISOString(),\n        });\n      } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:running' }, 'Failed to mark execution as running in DB'); }\n    }\n\n    const sent = this.pool.assign(workerId, assignment);\n    if (!sent) {\n      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n      this.active.delete(request.executionId);\n      if (dispatchDb) {\n        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:queued' }, 'Failed to re-queue execution in DB after assign failure'); }\n      }\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      this.processQueue();\n    } else {\n      this.logger.info({\n        workerId,\n        executionId: request.executionId,\n        personaId: request.personaId,\n        ...(request.eventId ? { eventId: request.eventId } : {}),\n      }, 'Execution dispatched to worker');\n    }\n  }\n\n  cancelExecution(executionId: string): boolean {\n    const exec = this.active.get(executionId);\n    if (!exec || exec.status !== 'running') return false;\n\n    return this.pool.send(exec.workerId, {\n      type: 'cancel',\n      executionId,\n    });\n  }\n\n  getQueueLength(): number {\n    return this.queue.length;\n  }\n\n  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n    return Array.from(this.active.entries())\n      .filter(([, e]) => e.status === 'running')\n      .map(([executionId, e]) => ({\n        executionId,\n        workerId: e.workerId,\n        startedAt: e.startedAt,\n      }));\n  }\n\n  /**\n   * Get execution state. Tries in-memory first (for real-time output),\n   * then falls back to DB for completed/historical executions.\n   */\n  getExecution(executionId: string): ActiveExecution | null {\n    // Check in-memory active executions first\n    const active = this.active.get(executionId);\n    if (active) return active;\n\n    const execDb = this.resolveDbForExecution(executionId);\n    if (execDb) {\n      const dbExec = db.getExecution(execDb, executionId);\n      if (dbExec) {\n        return {\n          workerId: '',\n          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n          status: dbExec.status as ActiveExecution['status'],\n          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n          durationMs: dbExec.durationMs ?? undefined,\n          sessionId: dbExec.claudeSessionId ?? undefined,\n          totalCostUsd: dbExec.costUsd ?? undefined,\n        };\n      }\n    }\n\n    return null;\n  }\n\n  getExecutionOutput(executionId: string): string[] | null {\n    const exec = this.getExecution(executionId);\n    return exec?.output ?? null;\n  }\n\n  /** Shared handler for stdout/stderr output chunks. */\n  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n    const line = prefix ? `${prefix}${chunk}` : chunk;\n\n    const exec = this.active.get(executionId);\n    if (exec) {\n      exec.output.push(line);\n    }\n\n    this.bufferOutput(executionId, line + '\\n');\n\n    // Forward stdout to Kafka (stderr is not forwarded)\n    if (!prefix) {\n      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n        executionId,\n        chunk,\n        timestamp,\n      }), executionId).catch(err => {\n        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n      });\n    }\n  }\n\n  /** Buffer an output chunk for batched DB write. */\n  private bufferOutput(executionId: string, chunk: string): void {\n    let buf = this.outputBuffers.get(executionId);\n    if (!buf) {\n      buf = [];\n      this.outputBuffers.set(executionId, buf);\n    }\n    buf.push(chunk);\n  }\n\n  /** Flush buffered output for a specific execution to DB. */\n  private flushOutputForExecution(executionId: string): void {\n    const buf = this.outputBuffers.get(executionId);\n    if (!buf || buf.length === 0) return;\n\n    const combined = buf.join('');\n    this.outputBuffers.delete(executionId);\n\n    const outputDb = this.resolveDbForExecution(executionId);\n    if (outputDb) {\n      try { db.appendOutput(outputDb, executionId, combined); } catch (err) { this.logger.warn({ err, executionId, op: 'appendOutput' }, 'Failed to flush buffered output to DB'); }\n    }\n  }\n\n  /** Flush all buffered output across all executions to DB. */\n  private flushOutputBuffers(): void {\n    for (const executionId of this.outputBuffers.keys()) {\n      this.flushOutputForExecution(executionId);\n    }\n  }\n\n  shutdown(): void {\n    clearInterval(this.outputFlushTimer);\n    this.flushOutputBuffers();\n  }\n}\n","numLines":627,"startLine":1,"totalLines":627}}}
