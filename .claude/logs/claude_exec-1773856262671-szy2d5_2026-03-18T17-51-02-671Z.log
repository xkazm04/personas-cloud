[2026-03-18T17:51:34.965Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015i6p138CYT8Vxs9zpm7VoD","type":"tool_result","content":"     1→import { WebSocketServer, WebSocket } from 'ws';\n     2→import https from 'node:https';\n     3→import crypto from 'node:crypto';\n     4→import fs from 'node:fs';\n     5→import {\n     6→  parseWorkerMessage,\n     7→  serializeMessage,\n     8→  type WorkerMessage,\n     9→  type OrchestratorMessage,\n    10→  type ExecAssign,\n    11→  type ExecStdout,\n    12→  type ExecStderr,\n    13→  type ExecComplete,\n    14→  type ExecProgress,\n    15→  type WorkerEvent,\n    16→  type WorkerBusy,\n    17→  type WorkerInfo,\n    18→} from '@dac-cloud/shared';\n    19→import type { Logger } from 'pino';\n    20→import type { IncomingMessage } from 'node:http';\n    21→import type { TlsConfig } from './tls.js';\n    22→\n    23→/** Typed event map for WorkerPool → Dispatcher communication. */\n    24→export interface WorkerPoolEvents {\n    25→  'worker-connected': (info: WorkerInfo) => void;\n    26→  'worker-disconnected': (workerId: string, executionId: string | undefined) => void;\n    27→  'worker-ready': (workerId: string) => void;\n    28→  'stdout': (workerId: string, msg: ExecStdout) => void;\n    29→  'stderr': (workerId: string, msg: ExecStderr) => void;\n    30→  'complete': (workerId: string, msg: ExecComplete) => void;\n    31→  'persona-event': (workerId: string, msg: WorkerEvent) => void;\n    32→  'progress': (workerId: string, msg: ExecProgress) => void;\n    33→  'busy': (workerId: string, msg: WorkerBusy) => void;\n    34→}\n    35→\n    36→const HEARTBEAT_INTERVAL_MS = 30_000;\n    37→const HEARTBEAT_TIMEOUT_MS = 90_000;\n    38→const HEARTBEAT_NEAR_MISS_THRESHOLD_MS = HEARTBEAT_TIMEOUT_MS * 0.5;\n    39→\n    40→/** In-memory counters for worker pool connection lifecycle. */\n    41→export interface WorkerPoolMetrics {\n    42→  totalConnections: number;\n    43→  totalDisconnections: number;\n    44→  parseFailures: number;\n    45→  heartbeatNearMisses: number;\n    46→  /** Recent connection durations (ms) for the last N disconnects. */\n    47→  recentConnectionDurations: number[];\n    48→}\n    49→\n    50→/** Constant-time string comparison to prevent timing side-channel attacks on token validation. */\n    51→function timingSafeTokenEqual(a: string, b: string): boolean {\n    52→  const bufA = Buffer.from(a, 'utf8');\n    53→  const bufB = Buffer.from(b, 'utf8');\n    54→  if (bufA.length !== bufB.length) {\n    55→    // Compare against self to maintain constant timing, then return false\n    56→    crypto.timingSafeEqual(bufA, bufA);\n    57→    return false;\n    58→  }\n    59→  return crypto.timingSafeEqual(bufA, bufB);\n    60→}\n    61→\n    62→interface WorkerEntry {\n    63→  ws: WebSocket;\n    64→  info: WorkerInfo;\n    65→  heartbeatTimer?: ReturnType<typeof setInterval>;\n    66→}\n    67→\n    68→export class WorkerPool {\n    69→  private workers = new Map<string, WorkerEntry>();\n    70→  private idleWorkers = new Set<string>();\n    71→  private wss: WebSocketServer | null = null;\n    72→  private allowedDigests: string[];\n    73→  private rejectUnverified: boolean;\n    74→\n    75→  // Typed listener storage — one array per event name\n    76→  private listeners: { [K in keyof WorkerPoolEvents]?: WorkerPoolEvents[K][] } = {};\n    77→\n    78→  /** Connection lifecycle metrics. */\n    79→  private metrics: WorkerPoolMetrics = {\n    80→    totalConnections: 0,\n    81→    totalDisconnections: 0,\n    82→    parseFailures: 0,\n    83→    heartbeatNearMisses: 0,\n    84→    recentConnectionDurations: [],\n    85→  };\n    86→  private static readonly MAX_DURATION_HISTORY = 100;\n    87→\n    88→  constructor(\n    89→    private expectedWorkerToken: string,\n    90→    private logger: Logger,\n    91→    opts?: { allowedDigests?: string[]; rejectUnverified?: boolean },\n    92→  ) {\n    93→    this.allowedDigests = opts?.allowedDigests ?? [];\n    94→    this.rejectUnverified = opts?.rejectUnverified ?? false;\n    95→  }\n    96→\n    97→  /** Register a typed event listener. */\n    98→  on<K extends keyof WorkerPoolEvents>(event: K, listener: WorkerPoolEvents[K]): this {\n    99→    if (!this.listeners[event]) {\n   100→      this.listeners[event] = [];\n   101→    }\n   102→    this.listeners[event]!.push(listener);\n   103→    return this;\n   104→  }\n   105→\n   106→  /** Emit a typed event. */\n   107→  private emit<K extends keyof WorkerPoolEvents>(event: K, ...args: Parameters<WorkerPoolEvents[K]>): void {\n   108→    const fns = this.listeners[event];\n   109→    if (fns) {\n   110→      for (const fn of fns) {\n   111→        (fn as (...a: Parameters<WorkerPoolEvents[K]>) => void)(...args);\n   112→      }\n   113→    }\n   114→  }\n   115→\n   116→  listen(port: number, tlsConfig?: TlsConfig): void {\n   117→    if (tlsConfig?.enabled) {\n   118→      const httpsServer = https.createServer({\n   119→        cert: fs.readFileSync(tlsConfig.certPath),\n   120→        key: fs.readFileSync(tlsConfig.keyPath),\n   121→        ca: tlsConfig.caPath ? fs.readFileSync(tlsConfig.caPath) : undefined,\n   122→        requestCert: tlsConfig.requireClientCert,\n   123→        rejectUnauthorized: tlsConfig.requireClientCert,\n   124→      });\n   125→      this.wss = new WebSocketServer({ server: httpsServer });\n   126→      httpsServer.listen(port);\n   127→      this.logger.info({ port, tls: true, mTLS: tlsConfig.requireClientCert }, 'Worker pool listening (WSS)');\n   128→    } else {\n   129→      this.wss = new WebSocketServer({ port });\n   130→      this.logger.info({ port, tls: false }, 'Worker pool listening (WS — plaintext)');\n   131→    }\n   132→\n   133→    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n   134→      this.logger.info({ remoteAddr: req.socket.remoteAddress }, 'Worker connection attempt');\n   135→\n   136→      // Validate worker token from Authorization header (timing-safe comparison)\n   137→      const authHeader = req.headers.authorization;\n   138→      const token = authHeader?.startsWith('Bearer ') ? authHeader.slice(7) : null;\n   139→      if (!token || !timingSafeTokenEqual(token, this.expectedWorkerToken)) {\n   140→        this.logger.warn({ remoteAddr: req.socket.remoteAddress }, 'Worker rejected: invalid token');\n   141→        ws.close(1008, 'Invalid worker token');\n   142→        return;\n   143→      }\n   144→\n   145→      this.handleConnection(ws);\n   146→    });\n   147→\n   148→    this.wss.on('error', (err) => {\n   149→      this.logger.error({ err }, 'WebSocket server error');\n   150→    });\n   151→  }\n   152→\n   153→  private handleConnection(ws: WebSocket): void {\n   154→    let workerId: string | null = null;\n   155→\n   156→    const connectionTimeout = setTimeout(() => {\n   157→      if (!workerId) {\n   158→        this.logger.warn('Worker did not send hello within timeout, closing');\n   159→        ws.close(1008, 'Hello timeout');\n   160→      }\n   161→    }, 10_000);\n   162→\n   163→    ws.on('message', (raw: Buffer) => {\n   164→      const msg = parseWorkerMessage(raw.toString());\n   165→      if (!msg) {\n   166→        this.metrics.parseFailures++;\n   167→        this.logger.warn({ parseFailures: this.metrics.parseFailures }, 'Invalid message from worker');\n   168→        return;\n   169→      }\n   170→\n   171→      if (msg.type === 'hello') {\n   172→        clearTimeout(connectionTimeout);\n   173→        workerId = msg.workerId;\n   174→        this.registerWorker(workerId, ws, msg.version, msg.capabilities, msg.imageDigest, msg.claudeCliVersion);\n   175→        return;\n   176→      }\n   177→\n   178→      if (!workerId) {\n   179→        this.logger.warn({ type: msg.type }, 'Message before hello');\n   180→        return;\n   181→      }\n   182→\n   183→      this.handleWorkerMessage(workerId, msg);\n   184→    });\n   185→\n   186→    ws.on('close', () => {\n   187→      clearTimeout(connectionTimeout);\n   188→      if (workerId) {\n   189→        this.unregisterWorker(workerId);\n   190→      }\n   191→    });\n   192→\n   193→    ws.on('error', (err) => {\n   194→      this.logger.error({ err, workerId }, 'Worker WebSocket error');\n   195→    });\n   196→  }\n   197→\n   198→  private registerWorker(workerId: string, ws: WebSocket, version: string, capabilities: string[], imageDigest?: string, claudeCliVersion?: string): void {\n   199→    // I10: If a worker with this ID already exists, disconnect the old one first\n   200→    const existing = this.workers.get(workerId);\n   201→    if (existing) {\n   202→      this.logger.warn({ workerId }, 'Duplicate worker ID — disconnecting previous connection');\n   203→      if (existing.heartbeatTimer) clearInterval(existing.heartbeatTimer);\n   204→      existing.ws.close(1001, 'Replaced by new connection');\n   205→      this.workers.delete(workerId);\n   206→      this.idleWorkers.delete(workerId);\n   207→    }\n   208→\n   209→    const verified = this.allowedDigests.length === 0 || (!!imageDigest && this.allowedDigests.includes(imageDigest));\n   210→\n   211→    if (this.rejectUnverified && !verified) {\n   212→      this.logger.warn({ workerId, imageDigest }, 'Rejecting unverified worker — digest not in allowlist');\n   213→      ws.close(1008, 'Unverified image digest');\n   214→      return;\n   215→    }\n   216→\n   217→    const info: WorkerInfo = {\n   218→      workerId,\n   219→      status: 'idle',\n   220→      version,\n   221→      capabilities,\n   222→      connectedAt: Date.now(),\n   223→      lastHeartbeat: Date.now(),\n   224→      imageDigest,\n   225→      claudeCliVersion,\n   226→      verified,\n   227→    };\n   228→\n   229→    const heartbeatTimer = setInterval(() => {\n   230→      const entry = this.workers.get(workerId);\n   231→      if (!entry) return;\n   232→\n   233→      const heartbeatAge = Date.now() - entry.info.lastHeartbeat;\n   234→\n   235→      if (heartbeatAge > HEARTBEAT_TIMEOUT_MS) {\n   236→        this.logger.warn({ workerId }, 'Worker heartbeat timeout');\n   237→        entry.ws.close(1001, 'Heartbeat timeout');\n   238→        return;\n   239→      }\n   240→\n   241→      if (heartbeatAge > HEARTBEAT_NEAR_MISS_THRESHOLD_MS) {\n   242→        this.metrics.heartbeatNearMisses++;\n   243→        this.logger.warn({ workerId, heartbeatAge, thresholdMs: HEARTBEAT_NEAR_MISS_THRESHOLD_MS }, 'Heartbeat near-miss');\n   244→      }\n   245→\n   246→      this.send(workerId, { type: 'heartbeat', timestamp: Date.now() });\n   247→    }, HEARTBEAT_INTERVAL_MS);\n   248→\n   249→    this.workers.set(workerId, { ws, info, heartbeatTimer });\n   250→    this.idleWorkers.add(workerId);\n   251→    this.metrics.totalConnections++;\n   252→\n   253→    // Send ack\n   254→    this.send(workerId, {\n   255→      type: 'ack',\n   256→      workerId,\n   257→      sessionToken: `session-${Date.now()}`,\n   258→    });\n   259→\n   260→    this.logger.info({ workerId, version, capabilities, imageDigest, claudeCliVersion, verified }, 'Worker registered');\n   261→    this.emit('worker-connected', info);\n   262→  }\n   263→\n   264→  private unregisterWorker(workerId: string): void {\n   265→    const entry = this.workers.get(workerId);\n   266→    if (!entry) return;\n   267→\n   268→    if (entry.heartbeatTimer) {\n   269→      clearInterval(entry.heartbeatTimer);\n   270→    }\n   271→\n   272→    const hadExecution = entry.info.currentExecutionId;\n   273→    const connectionDurationMs = Date.now() - entry.info.connectedAt;\n   274→\n   275→    this.workers.delete(workerId);\n   276→    this.idleWorkers.delete(workerId);\n   277→    this.metrics.totalDisconnections++;\n   278→\n   279→    // Track recent connection durations (ring buffer)\n   280→    this.metrics.recentConnectionDurations.push(connectionDurationMs);\n   281→    if (this.metrics.recentConnectionDurations.length > WorkerPool.MAX_DURATION_HISTORY) {\n   282→      this.metrics.recentConnectionDurations.shift();\n   283→    }\n   284→\n   285→    this.logger.info({ workerId, hadExecution, connectionDurationMs }, 'Worker disconnected');\n   286→    this.emit('worker-disconnected', workerId, hadExecution);\n   287→  }\n   288→\n   289→  private handleWorkerMessage(workerId: string, msg: WorkerMessage): void {\n   290→    const entry = this.workers.get(workerId);\n   291→    if (!entry) return;\n   292→\n   293→    switch (msg.type) {\n   294→      case 'heartbeat':\n   295→        entry.info.lastHeartbeat = Date.now();\n   296→        break;\n   297→\n   298→      case 'ready':\n   299→        entry.info.status = 'idle';\n   300→        entry.info.currentExecutionId = undefined;\n   301→        this.idleWorkers.add(workerId);\n   302→        this.emit('worker-ready', workerId);\n   303→        break;\n   304→\n   305→      case 'stdout':\n   306→        this.emit('stdout', workerId, msg);\n   307→        break;\n   308→\n   309→      case 'stderr':\n   310→        this.emit('stderr', workerId, msg);\n   311→        break;\n   312→\n   313→      case 'complete':\n   314→        entry.info.status = 'idle';\n   315→        entry.info.currentExecutionId = undefined;\n   316→        this.idleWorkers.add(workerId);\n   317→        this.logger.info({\n   318→          workerId,\n   319→          executionId: msg.executionId,\n   320→          status: msg.status,\n   321→          durationMs: msg.durationMs,\n   322→          ...(msg.phaseTimings ? { phaseTimings: msg.phaseTimings } : {}),\n   323→        }, 'Execution complete');\n   324→        this.emit('complete', workerId, msg);\n   325→        break;\n   326→\n   327→      case 'event':\n   328→        this.emit('persona-event', workerId, msg);\n   329→        break;\n   330→\n   331→      case 'progress':\n   332→        this.emit('progress', workerId, msg);\n   333→        break;\n   334→\n   335→      case 'busy':\n   336→        this.logger.warn({ workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment (busy)');\n   337→        // Mark worker as idle again so it can receive future work once it finishes\n   338→        entry.info.status = 'idle';\n   339→        entry.info.currentExecutionId = undefined;\n   340→        this.idleWorkers.add(workerId);\n   341→        this.emit('busy', workerId, msg);\n   342→        break;\n   343→\n   344→      default:\n   345→        this.logger.warn({ workerId, type: (msg as WorkerMessage).type }, 'Unknown message type');\n   346→    }\n   347→  }\n   348→\n   349→  send(workerId: string, msg: OrchestratorMessage): boolean {\n   350→    const entry = this.workers.get(workerId);\n   351→    if (!entry || entry.ws.readyState !== WebSocket.OPEN) return false;\n   352→\n   353→    entry.ws.send(serializeMessage(msg));\n   354→    return true;\n   355→  }\n   356→\n   357→  assign(workerId: string, assignment: ExecAssign): boolean {\n   358→    const entry = this.workers.get(workerId);\n   359→    if (!entry || entry.info.status !== 'idle') return false;\n   360→\n   361→    entry.info.status = 'executing';\n   362→    entry.info.currentExecutionId = assignment.executionId;\n   363→    this.idleWorkers.delete(workerId);\n   364→    return this.send(workerId, assignment);\n   365→  }\n   366→\n   367→  getIdleWorker(): string | null {\n   368→    const first = this.idleWorkers.values().next();\n   369→    return first.done ? null : first.value;\n   370→  }\n   371→\n   372→  getWorkers(): WorkerInfo[] {\n   373→    return Array.from(this.workers.values()).map(e => ({ ...e.info }));\n   374→  }\n   375→\n   376→  getWorkerCount(): { total: number; idle: number; executing: number } {\n   377→    const idle = this.idleWorkers.size;\n   378→    return { total: this.workers.size, idle, executing: this.workers.size - idle };\n   379→  }\n   380→\n   381→  getMetrics(): WorkerPoolMetrics {\n   382→    return { ...this.metrics, recentConnectionDurations: [...this.metrics.recentConnectionDurations] };\n   383→  }\n   384→\n   385→  /** Return worker IDs whose last heartbeat exceeds the near-miss threshold. */\n   386→  getStaleWorkers(): Array<{ workerId: string; heartbeatAgeMs: number }> {\n   387→    const now = Date.now();\n   388→    const stale: Array<{ workerId: string; heartbeatAgeMs: number }> = [];\n   389→    for (const [workerId, entry] of this.workers) {\n   390→      const age = now - entry.info.lastHeartbeat;\n   391→      if (age > HEARTBEAT_NEAR_MISS_THRESHOLD_MS) {\n   392→        stale.push({ workerId, heartbeatAgeMs: age });\n   393→      }\n   394→    }\n   395→    return stale;\n   396→  }\n   397→\n   398→  shutdown(): void {\n   399→    for (const [workerId] of this.workers) {\n   400→      this.send(workerId, {\n   401→        type: 'shutdown',\n   402→        reason: 'Orchestrator shutting down',\n   403→        gracePeriodMs: 30_000,\n   404→      });\n   405→    }\n   406→    this.wss?.close();\n   407→    for (const entry of this.workers.values()) {\n   408→      if (entry.heartbeatTimer) clearInterval(entry.heartbeatTimer);\n   409→    }\n   410→  }\n   411→}\n   412→"}]},"parent_tool_use_id":"toolu_01WnHBpnvYFko6UL4CMFQnL4","session_id":"d073280e-6082-4db5-95e6-287c162efeec","uuid":"a56b9a90-9ef0-457d-8c7b-180fa0717e5d","timestamp":"2026-03-18T17:51:34.867Z"}
