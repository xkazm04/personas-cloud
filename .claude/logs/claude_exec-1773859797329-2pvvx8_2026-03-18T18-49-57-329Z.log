[2026-03-18T18:50:41.708Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y13tTLBvfEYcZjAZDob4cf","type":"tool_result","content":"     1→import { type ExecAssign, type ExecRequest, TOPICS, assemblePrompt, parseModelProfile, decrypt, deriveMasterKey, type EncryptedPayload } from '@dac-cloud/shared';\n     2→import type Database from 'better-sqlite3';\n     3→import type { WorkerPool } from './workerPool.js';\n     4→import type { TokenManager } from './tokenManager.js';\n     5→import type { OAuthManager } from './oauth.js';\n     6→import type { KafkaClient } from './kafka.js';\n     7→import type { Logger } from 'pino';\n     8→import * as db from './db.js';\n     9→\n    10→interface QueuedExecution {\n    11→  request: ExecRequest;\n    12→  receivedAt: number;\n    13→}\n    14→\n    15→// In-memory tracking for active executions (real-time output streaming)\n    16→interface ActiveExecution {\n    17→  workerId: string;\n    18→  startedAt: number;\n    19→  output: string[];\n    20→  status: 'running' | 'completed' | 'failed' | 'cancelled';\n    21→  completedAt?: number;\n    22→  exitCode?: number;\n    23→  durationMs?: number;\n    24→  sessionId?: string;\n    25→  totalCostUsd?: number;\n    26→}\n    27→\n    28→export class Dispatcher {\n    29→  private queue: QueuedExecution[] = [];\n    30→  // In-memory map for real-time output + cancel routing (active executions only)\n    31→  private active = new Map<string, ActiveExecution>();\n    32→  private database: Database.Database | null = null;\n    33→  private masterKey: Buffer | null = null;\n    34→\n    35→  constructor(\n    36→    private pool: WorkerPool,\n    37→    private tokenManager: TokenManager,\n    38→    private oauth: OAuthManager | null,\n    39→    private kafka: KafkaClient,\n    40→    private logger: Logger,\n    41→  ) {\n    42→    // When a worker becomes ready, try to dispatch queued work\n    43→    this.pool.on('worker-ready', () => {\n    44→      this.processQueue();\n    45→    });\n    46→\n    47→    // When a worker connects, try to dispatch\n    48→    this.pool.on('worker-connected', () => {\n    49→      this.processQueue();\n    50→    });\n    51→\n    52→    // Track stdout for execution output\n    53→    this.pool.on('stdout', (_workerId: string, msg: { executionId: string; chunk: string; timestamp: number }) => {\n    54→      const exec = this.active.get(msg.executionId);\n    55→      if (exec) {\n    56→        exec.output.push(msg.chunk);\n    57→      }\n    58→\n    59→      // Persist to DB\n    60→      if (this.database) {\n    61→        try { db.appendOutput(this.database, msg.executionId, msg.chunk + '\\n'); } catch { /* best effort */ }\n    62→      }\n    63→\n    64→      // Forward to Kafka\n    65→      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n    66→        executionId: msg.executionId,\n    67→        chunk: msg.chunk,\n    68→        timestamp: msg.timestamp,\n    69→      }), msg.executionId).catch(err => {\n    70→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce output to Kafka');\n    71→      });\n    72→    });\n    73→\n    74→    // Track stderr for debugging failed executions\n    75→    this.pool.on('stderr', (_workerId: string, msg: { executionId: string; chunk: string; timestamp: number }) => {\n    76→      const exec = this.active.get(msg.executionId);\n    77→      if (exec) {\n    78→        exec.output.push(`[STDERR] ${msg.chunk}`);\n    79→      }\n    80→\n    81→      if (this.database) {\n    82→        try { db.appendOutput(this.database, msg.executionId, `[STDERR] ${msg.chunk}\\n`); } catch { /* best effort */ }\n    83→      }\n    84→\n    85→      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    86→    });\n    87→\n    88→    // Handle execution completion\n    89→    this.pool.on('complete', (_workerId: string, msg: { executionId: string; status: string; exitCode: number; durationMs: number; sessionId?: string; totalCostUsd?: number }) => {\n    90→      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n    91→        executionId: msg.executionId,\n    92→        status: msg.status,\n    93→        exitCode: msg.exitCode,\n    94→        durationMs: msg.durationMs,\n    95→        sessionId: msg.sessionId,\n    96→        totalCostUsd: msg.totalCostUsd,\n    97→      }), msg.executionId).catch(err => {\n    98→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n    99→      });\n   100→\n   101→      // Update in-memory\n   102→      const exec = this.active.get(msg.executionId);\n   103→      if (exec) {\n   104→        exec.status = msg.status as ActiveExecution['status'];\n   105→        exec.completedAt = Date.now();\n   106→        exec.exitCode = msg.exitCode;\n   107→        exec.durationMs = msg.durationMs;\n   108→        exec.sessionId = msg.sessionId;\n   109→        exec.totalCostUsd = msg.totalCostUsd;\n   110→        // Remove from active after a short delay (allow polling to pick up final state)\n   111→        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n   112→      }\n   113→\n   114→      // Persist to DB\n   115→      if (this.database) {\n   116→        try {\n   117→          db.updateExecution(this.database, msg.executionId, {\n   118→            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n   119→            completedAt: new Date().toISOString(),\n   120→            durationMs: msg.durationMs,\n   121→            claudeSessionId: msg.sessionId,\n   122→            costUsd: msg.totalCostUsd ?? 0,\n   123→          });\n   124→        } catch (err) {\n   125→          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n   126→        }\n   127→      }\n   128→\n   129→      // Process next queued item\n   130→      this.processQueue();\n   131→    });\n   132→\n   133→    // Forward persona events to Kafka\n   134→    this.pool.on('persona-event', (_workerId: string, msg: { executionId: string; eventType: string; payload: unknown }) => {\n   135→      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n   136→        executionId: msg.executionId,\n   137→        eventType: msg.eventType,\n   138→        payload: msg.payload,\n   139→        timestamp: Date.now(),\n   140→      }), msg.executionId).catch(err => {\n   141→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n   142→      });\n   143→    });\n   144→\n   145→    // Handle worker disconnect during execution\n   146→    this.pool.on('worker-disconnected', (_workerId: string, executionId?: string) => {\n   147→      if (executionId) {\n   148→        this.logger.error({ executionId }, 'Worker disconnected during execution');\n   149→        const exec = this.active.get(executionId);\n   150→        if (exec) {\n   151→          exec.status = 'failed';\n   152→          exec.completedAt = Date.now();\n   153→          setTimeout(() => this.active.delete(executionId), 30_000);\n   154→        }\n   155→\n   156→        // Persist failure\n   157→        if (this.database) {\n   158→          try {\n   159→            db.updateExecution(this.database, executionId, {\n   160→              status: 'failed',\n   161→              errorMessage: 'Worker disconnected',\n   162→              completedAt: new Date().toISOString(),\n   163→            });\n   164→          } catch { /* best effort */ }\n   165→        }\n   166→\n   167→        this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   168→          executionId,\n   169→          status: 'failed',\n   170→          error: 'Worker disconnected',\n   171→          durationMs: 0,\n   172→        }), executionId).catch(() => {});\n   173→      }\n   174→    });\n   175→  }\n   176→\n   177→  setDatabase(database: Database.Database): void {\n   178→    this.database = database;\n   179→  }\n   180→\n   181→  setMasterKey(masterKeyHex: string): void {\n   182→    this.masterKey = deriveMasterKey(masterKeyHex);\n   183→  }\n   184→\n   185→  submit(request: ExecRequest): void {\n   186→    this.logger.info({\n   187→      executionId: request.executionId,\n   188→      personaId: request.personaId,\n   189→    }, 'Execution submitted');\n   190→\n   191→    // Create DB record immediately\n   192→    if (this.database) {\n   193→      try {\n   194→        db.createExecution(this.database, {\n   195→          id: request.executionId,\n   196→          personaId: request.personaId,\n   197→          inputData: request.prompt,\n   198→          projectId: request.projectId,\n   199→        });\n   200→      } catch (err) {\n   201→        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n   202→      }\n   203→    }\n   204→\n   205→    this.queue.push({ request, receivedAt: Date.now() });\n   206→    this.processQueue();\n   207→  }\n   208→\n   209→  private async processQueue(): Promise<void> {\n   210→    if (this.queue.length === 0) return;\n   211→\n   212→    const workerId = this.pool.getIdleWorker();\n   213→    if (!workerId) {\n   214→      this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n   215→      return;\n   216→    }\n   217→\n   218→    const item = this.queue.shift()!;\n   219→    await this.dispatchToWorker(workerId, item.request);\n   220→  }\n   221→\n   222→  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n   223→    // Try to get a fresh token via OAuth (auto-refreshes if near expiry)\n   224→    let claudeToken: string | null = null;\n   225→    if (this.oauth?.hasTokens()) {\n   226→      claudeToken = await this.oauth.getValidAccessToken();\n   227→      if (claudeToken) {\n   228→        this.tokenManager.storeClaudeToken(claudeToken);\n   229→      }\n   230→    }\n   231→    // Fallback to stored token\n   232→    if (!claudeToken) {\n   233→      claudeToken = this.tokenManager.getClaudeToken();\n   234→    }\n   235→    if (!claudeToken) {\n   236→      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n   237→      this.queue.unshift({ request, receivedAt: Date.now() });\n   238→      return;\n   239→    }\n   240→\n   241→    // Build environment variables for the worker\n   242→    const env: Record<string, string> = {\n   243→      ANTHROPIC_API_KEY: claudeToken,\n   244→    };\n   245→\n   246→    // If persona exists in DB, assemble prompt from persona config and inject credentials\n   247→    let prompt = request.prompt;\n   248→    if (this.database) {\n   249→      const persona = db.getPersona(this.database, request.personaId);\n   250→      if (persona) {\n   251→        const tools = db.getToolsForPersona(this.database, persona.id);\n   252→        const creds = db.listCredentialsForPersona(this.database, persona.id);\n   253→\n   254→        // Decrypt credentials and inject as env vars\n   255→        const credentialHints: string[] = [];\n   256→        for (const cred of creds) {\n   257→          const envName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   258→          credentialHints.push(envName);\n   259→\n   260→          // Decrypt and inject credential fields as env vars\n   261→          if (this.masterKey) {\n   262→            try {\n   263→              const payload: EncryptedPayload = {\n   264→                encrypted: cred.encryptedData,\n   265→                iv: cred.iv,\n   266→                tag: cred.tag,\n   267→              };\n   268→              const decrypted = decrypt(payload, this.masterKey);\n   269→\n   270→              // Try to parse as JSON with multiple fields\n   271→              try {\n   272→                const fields = JSON.parse(decrypted) as Record<string, string>;\n   273→                for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n   274→                  const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   275→                  env[fieldEnvName] = String(fieldValue);\n   276→                }\n   277→              } catch {\n   278→                // Not JSON — inject as single value\n   279→                env[envName] = decrypted;\n   280→              }\n   281→            } catch (err) {\n   282→              this.logger.error({ err, credentialId: cred.id, credentialName: cred.name }, 'Failed to decrypt credential');\n   283→            }\n   284→          }\n   285→        }\n   286→\n   287→        const inputData = request.inputData ? (request.inputData as Record<string, unknown>) : undefined;\n   288→        prompt = assemblePrompt(persona, tools, inputData, credentialHints.length > 0 ? credentialHints : undefined);\n   289→\n   290→        // Apply model profile env overrides\n   291→        const profile = parseModelProfile(persona.modelProfile);\n   292→        if (profile?.provider) {\n   293→          switch (profile.provider) {\n   294→            case 'ollama':\n   295→              if (profile.baseUrl) env['OLLAMA_BASE_URL'] = profile.baseUrl;\n   296→              if (profile.authToken) env['OLLAMA_API_KEY'] = profile.authToken;\n   297→              delete env['ANTHROPIC_API_KEY'];\n   298→              break;\n   299→            case 'litellm':\n   300→              if (profile.baseUrl) env['ANTHROPIC_BASE_URL'] = profile.baseUrl;\n   301→              if (profile.authToken) env['ANTHROPIC_AUTH_TOKEN'] = profile.authToken;\n   302→              delete env['ANTHROPIC_API_KEY'];\n   303→              break;\n   304→            case 'custom':\n   305→              if (profile.baseUrl) env['OPENAI_BASE_URL'] = profile.baseUrl;\n   306→              if (profile.authToken) env['OPENAI_API_KEY'] = profile.authToken;\n   307→              delete env['ANTHROPIC_API_KEY'];\n   308→              break;\n   309→          }\n   310→        }\n   311→\n   312→        this.logger.info({ personaId: persona.id, toolCount: tools.length, credCount: creds.length }, 'Assembled prompt from DB persona');\n   313→      }\n   314→    }\n   315→\n   316→    const assignment: ExecAssign = {\n   317→      type: 'assign',\n   318→      executionId: request.executionId,\n   319→      personaId: request.personaId,\n   320→      prompt,\n   321→      env,\n   322→      config: {\n   323→        timeoutMs: request.config.timeoutMs || 300_000,\n   324→        maxOutputBytes: 10 * 1024 * 1024, // 10MB\n   325→      },\n   326→    };\n   327→\n   328→    // Track in-memory for real-time streaming\n   329→    this.active.set(request.executionId, {\n   330→      workerId,\n   331→      startedAt: Date.now(),\n   332→      output: [],\n   333→      status: 'running',\n   334→    });\n   335→\n   336→    // Mark running in DB\n   337→    if (this.database) {\n   338→      try {\n   339→        db.updateExecution(this.database, request.executionId, {\n   340→          status: 'running',\n   341→          startedAt: new Date().toISOString(),\n   342→        });\n   343→      } catch { /* best effort */ }\n   344→    }\n   345→\n   346→    const sent = this.pool.assign(workerId, assignment);\n   347→    if (!sent) {\n   348→      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n   349→      this.active.delete(request.executionId);\n   350→      if (this.database) {\n   351→        try { db.updateExecution(this.database, request.executionId, { status: 'queued' }); } catch { /* best effort */ }\n   352→      }\n   353→      // Re-queue\n   354→      this.queue.unshift({ request, receivedAt: Date.now() });\n   355→    } else {\n   356→      this.logger.info({\n   357→        workerId,\n   358→        executionId: request.executionId,\n   359→        personaId: request.personaId,\n   360→      }, 'Execution dispatched to worker');\n   361→    }\n   362→  }\n   363→\n   364→  cancelExecution(executionId: string): boolean {\n   365→    const exec = this.active.get(executionId);\n   366→    if (!exec || exec.status !== 'running') return false;\n   367→\n   368→    return this.pool.send(exec.workerId, {\n   369→      type: 'cancel',\n   370→      executionId,\n   371→    });\n   372→  }\n   373→\n   374→  getQueueLength(): number {\n   375→    return this.queue.length;\n   376→  }\n   377→\n   378→  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n   379→    return Array.from(this.active.entries())\n   380→      .filter(([, e]) => e.status === 'running')\n   381→      .map(([executionId, e]) => ({\n   382→        executionId,\n   383→        workerId: e.workerId,\n   384→        startedAt: e.startedAt,\n   385→      }));\n   386→  }\n   387→\n   388→  /**\n   389→   * Get execution state. Tries in-memory first (for real-time output),\n   390→   * then falls back to DB for completed/historical executions.\n   391→   */\n   392→  getExecution(executionId: string): ActiveExecution | null {\n   393→    // Check in-memory active executions first\n   394→    const active = this.active.get(executionId);\n   395→    if (active) return active;\n   396→\n   397→    // Fall back to DB\n   398→    if (this.database) {\n   399→      const dbExec = db.getExecution(this.database, executionId);\n   400→      if (dbExec) {\n   401→        // Convert DB execution to ActiveExecution shape for backward compat\n   402→        return {\n   403→          workerId: '',\n   404→          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n   405→          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n   406→          status: dbExec.status as ActiveExecution['status'],\n   407→          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n   408→          durationMs: dbExec.durationMs ?? undefined,\n   409→          sessionId: dbExec.claudeSessionId ?? undefined,\n   410→          totalCostUsd: dbExec.costUsd ?? undefined,\n   411→        };\n   412→      }\n   413→    }\n   414→\n   415→    return null;\n   416→  }\n   417→\n   418→  getExecutionOutput(executionId: string): string[] | null {\n   419→    const exec = this.getExecution(executionId);\n   420→    return exec?.output ?? null;\n   421→  }\n   422→\n   423→  shutdown(): void {\n   424→    // No cleanup timer needed — DB persists naturally\n   425→  }\n   426→}\n   427→"}]},"parent_tool_use_id":"toolu_01G392R7jPGR2USL7R4bPHor","session_id":"15915e67-0f08-45e6-a989-69b2c8df5088","uuid":"d59016d9-10ca-47e5-ab72-7ebb8e111fe3","timestamp":"2026-03-18T18:50:41.522Z"}
