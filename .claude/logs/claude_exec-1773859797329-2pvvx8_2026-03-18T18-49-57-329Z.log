ype: 'ack';\n    67→  workerId: string;\n    68→  sessionToken: string;\n    69→}\n    70→\n    71→export interface ExecAssign {\n    72→  type: 'assign';\n    73→  executionId: string;\n    74→  personaId: string;\n    75→  prompt: string;\n    76→  env: Record<string, string>;\n    77→  config: {\n    78→    timeoutMs: number;\n    79→    maxOutputBytes: number;\n    80→  };\n    81→}\n    82→\n    83→export interface ExecCancel {\n    84→  type: 'cancel';\n    85→  executionId: string;\n    86→}\n    87→\n    88→export interface OrchestratorShutdown {\n    89→  type: 'shutdown';\n    90→  reason: string;\n    91→  gracePeriodMs: number;\n    92→}\n    93→\n    94→export interface OrchestratorHeartbeat {\n    95→  type: 'heartbeat';\n    96→  timestamp: number;\n    97→}\n    98→\n    99→export type OrchestratorMessage =\n   100→  | OrchestratorAck\n   101→  | ExecAssign\n   102→  | ExecCancel\n   103→  | OrchestratorShutdown\n   104→  | OrchestratorHeartbeat;\n   105→\n   106→// --- Helpers ---\n   107→\n   108→export function parseMessage<T>(raw: string): T | null {\n   109→  try {\n   110→    return JSON.parse(raw) as T;\n   111→  } catch {\n   112→    return null;\n   113→  }\n   114→}\n   115→\n   116→export function serializeMessage(msg: WorkerMessage | OrchestratorMessage): string {\n   117→  return JSON.stringify(msg);\n   118→}\n   119→"}]},"parent_tool_use_id":"toolu_01G392R7jPGR2USL7R4bPHor","session_id":"15915e67-0f08-45e6-a989-69b2c8df5088","uuid":"c47523d4-1bf4-4c96-b1c8-d4a28f124925","timestamp":"2026-03-18T18:50:37.452Z"}
