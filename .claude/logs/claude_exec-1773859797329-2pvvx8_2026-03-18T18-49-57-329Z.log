dateAndExtractContext(req);\n    45→    if (!ctx) {\n    46→      res.writeHead(401, { 'Content-Type': 'application/json' });\n    47→      res.end(JSON.stringify({ error: 'Unauthorized' }));\n    48→      return;\n    49→    }\n    50→\n    51→    // Helper: project scoping (admin sees all, user sees own project)\n    52→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n    53→\n    54→    try {\n    55→      // --- OAuth endpoints ---\n    56→      if (pathname === '/api/oauth/authorize' && req.method === 'POST') {\n    57→        handleOAuthAuthorize(res, oauth);\n    58→      } else if (pathname === '/api/oauth/callback' && req.method === 'POST') {\n    59→        await handleOAuthCallback(req, res, oauth, tokenManager, logger);\n    60→      } else if (pathname === '/api/oauth/status' && req.method === 'GET') {\n    61→        handleOAuthStatus(res, oauth);\n    62→      } else if (pathname === '/api/oauth/refresh' && req.method === 'POST') {\n    63→        await handleOAuthRefresh(res, oauth, tokenManager, logger);\n    64→      } else if (pathname === '/api/oauth/disconnect' && req.method === 'DELETE') {\n    65→        handleOAuthDisconnect(res, oauth, tokenManager);\n    66→      }\n    67→      // --- Token injection (fallback for setup-token / direct paste) ---\n    68→      else if (pathname === '/api/token' && req.method === 'POST') {\n    69→        await handleSetToken(req, res, tokenManager, logger);\n    70→      }\n    71→      // --- Persona CRUD ---\n    72→      else if (pathname === '/api/personas' && req.method === 'GET' && database) {\n    73→        json(res, 200, db.listPersonas(database, scopedProjectId));\n    74→      } else if (pathname === '/api/personas' && req.method === 'POST' && database) {\n    75→        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n    76→        const now = new Date().toISOString();\n    77→        const persona: Persona = {\n    78→          id: body.id ??