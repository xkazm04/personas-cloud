s', '');\n   109→        const body = JSON.parse(await readBody(req)) as { toolId: string };\n   110→        db.linkTool(database, id, body.toolId);\n   111→        json(res, 200, { linked: true });\n   112→      } else if (matchRoute(pathname, '/api/personas/') && !pathname!.endsWith('/tools') && !pathname!.endsWith('/credentials') && !pathname!.endsWith('/subscriptions') && !pathname!.endsWith('/triggers') && req.method === 'DELETE' && database) {\n   113→        const id = pathname!.replace('/api/personas/', '');\n   114→        db.deletePersona(database, id, scopedProjectId);\n   115→        json(res, 200, { deleted: true });\n   116→      }\n   117→      // --- Tool Definitions ---\n   118→      else if (pathname === '/api/tool-definitions' && req.method === 'POST' && database) {\n   119→        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   120→        const now = new Date().toISOString();\n   121→        const tool: PersonaToolDefinition = {\n   122→          id: body.id ?? nanoid(),\n   123→          name: body.name ?? 'unnamed',\n   124→          category: body.category ?? 'general',\n   125→          description: body.description ?? '',\n   126→          scriptPath: body.scriptPath ?? '',\n   127→          inputSchema: body.inputSchema ?? null,\n   128→          outputSchema: body.outputSchema ?? null,\n   129→          requiresCredentialType: body.requiresCredentialType ?? null,\n   130→          implementationGuide: body.implementationGuide ?? null,\n   131→          isBuiltin: body.isBuiltin ?? false,\n   132→          createdAt: body.createdAt ?? now,\n   133→          updatedAt: now,\n   134→        };\n   135→        db.upsertToolDefinition(database, tool);\n   136→        json(res, 201, tool);\n   137→      }\n   138→      // --- Credentials ---\n   139→      else if (pathname === '/api/credentials' && req.method === 'POST' && database) {\n   140→        const body = JSON.parse(await readBody(req));\n   141→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   142→        const cred = db.createCredential(database, body);\n   143→        json(res, 201, cred);\n   144→      } else if (matchRoute(pathname, '/api/credentials/') && req.method === 'DELETE' && database) {\n   145→        const id = pathname!.replace('/api/credentials/', '');\n   146→        db.deleteCredential(database, id);\n   147→        json(res, 200, { deleted: true });\n   148→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/credentials') && req.method === 'GET' && database) {\n   149→        const id = pathname!.replace('/api/personas/', '').replace('/credentials', '');\n   150→        const creds = db.listCredentialsForPersona(database, id);\n   151→        // Strip encrypted data from response\n   152→        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   153→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/credentials') && req.method === 'POST' && database) {\n   154→        const id = pathname!.replace('/api/personas/', '').replace('/credentials', '');\n   155→        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   156→        db.linkCredential(database, id, body.credentialId);\n   157→        json(res, 200, { linked: true });\n   158→      }\n   159→      // --- Event Subscriptions ---\n   160→      else if (pathname === '/api/subscriptions' && req.method === 'POST' && database) {\n   161→        const body = JSON.parse(await readBody(req));\n   162→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   163→        const sub = db.createSubscription(database, body);\n   164→        json(res, 201, sub);\n   165→      } else if (matchRoute(pathname, '/api/subscriptions/') && req.method === 'PUT' && database) {\n   166→        const id = pathname!.replace('/api/subscriptions/', '');\n   167→        const body = JSON.parse(await readBody(req));\n   168→        db.updateSubscription(database, id, body);\n   169→        const updated = db.getSubscription(database, id);\n   170→        json(res, 200, updated);\n   171→      } else if (matchRoute(pathname, '/api/subscriptions/') && req.method === 'DELETE' && database) {\n   172→        const id = pathname!.replace('/api/subscriptions/', '');\n   173→        db.deleteSubscription(database, id);\n   174→        json(res, 200, { deleted: true });\n   175→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/subscriptions') && req.method === 'GET' && database) {\n   176→        const id = pathname!.replace('/api/personas/', '').replace('/subscriptions', '');\n   177→        json(res, 200, db.listSubscriptionsForPersona(database, id));\n   178→      }\n   179→      // --- Triggers ---\n   180→      else if (pathname === '/api/triggers' && req.method === 'POST' && database) {\n   181→        const body = JSON.parse(await readBody(req));\n   182→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   183→        const trigger = db.createTrigger(database, body);\n   184→        json(res, 201, trigger);\n   185→      } else if (matchRoute(pathname, '/api/triggers/') && req.method === 'PUT' && database) {\n   186→        const id = pathname!.replace('/api/triggers/', '');\n   187→        const body = JSON.parse(await readBody(req));\n   188→        db.updateTrigger(database, id, body);\n   189→        const updated = db.getTrigger(database, id);\n   190→        json(res, 200, updated);\n   191→      } else if (matchRoute(pathname, '/api/triggers/') && req.method === 'DELETE' && database) {\n   192→        const id = pathname!.replace('/api/triggers/', '');\n   193→        db.deleteTrigger(database, id);\n   194→        json(res, 200, { deleted: true });\n   195→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/triggers') && req.method === 'GET' && database) {\n   196→        const id = pathname!.replace('/api/personas/', '').replace('/triggers', '');\n   197→        json(res, 200, db.listTriggersForPersona(database, id));\n   198→      }\n   199→      // --- Events ---\n   200→      else if (pathname === '/api/events' && req.method === 'GET' && database) {\n   201→        const params = new URLSearchParams(queryString || '');\n   202→        const events = db.listEvents(database, {\n   203→          eventType: params.get('eventType') ?? undefined,\n   204→          status: params.get('status') ?? undefined,\n   205→          limit: params.get('limit') ? parseInt(params.get('limit')!, 10) : 50,\n   206→          offset: params.get('offset') ? parseInt(params.get('offset')!, 10) : undefined,\n   207→          projectId: scopedProjectId,\n   208→        });\n   209→        json(res, 200, events);\n   210→      } else if (pathname === '/api/events' && req.method === 'POST' && database) {\n   211→        const body = JSON.parse(await readBody(req));\n   212→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   213→        const event = db.publishEvent(database, body);\n   214→        json(res, 201, event);\n   215→      } else if (matchRoute(pathname, '/api/events/') && req.method === 'PUT' && database) {\n   216→        const id = pathname!.replace('/api/events/', '');\n   217→        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n   218→        const updated = db.updateEventWithMetadata(database, id, body.status, body.metadata);\n   219→        if (updated) {\n   220→          json(res, 200, updated);\n   221→        } else {\n   222→          res.writeHead(404, { 'Content-Type': 'application/json' });\n   223→          res.end(JSON.stringify({ error: 'Event not found' }));\n   224→        }\n   225→      }\n   226→      // --- Webhooks ---\n   227→      else if (matchRoute(pathname, '/api/webhooks/') && req.method === 'POST' && database) {\n   228→        const personaId = pathname!.replace('/api/webhooks/', '');\n   229→        const body = await readBody(req);\n   230→        const event = db.publishEvent(database, {\n   231→          eventType: 'webhook_received',\n   232→          sourceType: 'webhook',\n   233→          sourceId: personaId,\n   234→          targetPersonaId: personaId,\n   235→          payload: body,\n   236→        });\n   237→        json(res, 201, event);\n   238→      }\n   239→      // --- GitLab Webhook ---\n   240→      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && database) {\n   241→        const body = await readBody(req);\n   242→        let parsed: Record<string, unknown> = {};\n   243→        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   244→        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   245→        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   246→        const event = db.publishEvent(database, {\n   247→          eventType: `gitlab_${objectKind}`,\n   248→          sourceType: 'gitlab',\n   249→          sourceId: projectPath ?? null,\n   250→          payload: body,\n   251→        });\n   252→        json(res, 201, event);\n   253→      }\n   254→      // --- Executions ---\n   255→      else if (pathname === '/api/executions' && req.method === 'GET' && database) {\n   256→        const params = new URLSearchParams(queryString || '');\n   257→        const executions = db.listExecutions(database, {\n   258→          personaId: params.get('personaId') ?? undefined,\n   259→          status: params.get('status') ?? undefined,\n   260→          limit: params.get('limit') ? parseInt(params.get('limit')!, 10) : 50,\n   261→          offset: params.get('offset') ? parseInt(params.get('offset')!, 10) : undefined,\n   262→          projectId: scopedProjectId,\n   263→        });\n   264→        json(res, 200, executions);\n   265→      }\n   266→      // --- Existing execution endpoints ---\n   267→      else if (pathname === '/api/status' && req.method === 'GET') {\n   268→        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   269→      } else if (pathname === '/api/execute' && req.method === 'POST') {\n   270→        await handleExecute(req, res, dispatcher, logger, ctx);\n   271→      } else if (matchRoute(pathname, '/api/executions/') && pathname!.endsWith('/cancel') && req.method === 'POST') {\n   272→        const executionId = pathname!.replace('/api/executions/', '').replace('/cancel', '');\n   273→        handleCancelExecution(res, dispatcher, executionId || '');\n   274→      } else if (matchRoute(pathname, '/api/executions/') && req.method === 'GET') {\n   275→        const executionId = pathname!.replace('/api/executions/', '');\n   276→        const params = new URLSearchParams(queryString || '');\n   277→        const offset = parseInt(params.get('offset') || '0', 10);\n   278→        handleGetExecution(res, dispatcher, executionId, offset);\n   279→      }\n   280→      // --- Admin-only routes ---\n   281→      else if (pathname === '/api/admin/users' && req.method === 'GET' && database) {\n   282→        if (requireAdmin(ctx, res)) return;\n   283→        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   284→      } else if (pathname === '/api/admin/personas' && req.method === 'GET' && database) {\n   285→        if (requireAdmin(ctx, res)) return;\n   286→        json(res, 200, db.listPersonas(database));\n   287→      } else if (pathname === '/api/admin/executions' && req.method === 'GET' && database) {\n   288→        if (requireAdmin(ctx, res)) return;\n   289→        const params = new URLSearchParams(queryString || '');\n   290→        json(res, 200, db.listExecutions(database, {\n   291→          limit: params.get('limit') ? parseInt(params.get('limit')!, 10) : 100,\n   292→          offset: params.get('offset') ? parseInt(params.get('offset')!, 10) : undefined,\n   293→        }));\n   294→      } else {\n   295→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   296→        res.end(JSON.stringify({ error: 'Not found' }));\n   297→      }\n   298→    } catch (err) {\n   299→      if (err instanceof Error && err.message === 'Payload too large') {\n   300→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   301→        res.end(JSON.stringify({ error: 'Payload too large' }));\n   302→        return;\n   303→      }\n   304→      logger.error({ err, url }, 'HTTP handler error');\n   305→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   306→      res.end(JSON.stringify({ error: 'Internal server error' }));\n   307→    }\n   308→  });\n   309→\n   310→  return server;\n   311→}\n   312→\n   313→function json(res: http.ServerResponse, status: number, data: unknown): void {\n   314→  res.writeHead(status, { 'Content-Type': 'application/json' });\n   315→  res.end(JSON.stringify(data));\n   316→}\n   317→\n   318→function matchRoute(pathname: string | undefined, prefix: string): boolean {\n   319→  return !!pathname && pathname.startsWith(prefix) && pathname.length > prefix.length;\n   320→}\n   321→\n   322→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   323→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   324→  if (ctx.authType !== 'admin') {\n   325→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   326→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   327→    return true;\n   328→  }\n   329→  return false;\n   330→}\n   331→\n   332→// --- OAuth handlers ---\n   333→\n   334→function handleOAuthAuthorize(res: http.ServerResponse, oauth: OAuthManager): void {\n   335→  const { url, state } = oauth.generateAuthUrl();\n   336→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   337→  res.end(JSON.stringify({\n   338→    authUrl: url,\n   339→    state,\n   340→    instructions: [\n   341→      '1. Open the authUrl in a browser',\n   342→      '2. Log in with your Anthropic account and authorize',\n   343→      '3. You will be redirected to a page showing an authorization code',\n   344→      '4. Copy the code from the URL (the \"code\" query parameter)',\n   345→      '5. POST it to /api/oauth/callback with { \"code\": \"...\", \"state\": \"...\" }',\n   346→    ],\n   347→  }));\n   348→}\n   349→\n   350→async function handleOAuthCallback(\n   351→  req: http.IncomingMessage,\n   352→  res: http.ServerResponse,\n   353→  oauth: OAuthManager,\n   354→  tokenManager: TokenManager,\n   355→  logger: Logger,\n   356→): Promise<void> {\n   357→  const body = await readBody(req);\n   358→  let parsed: { code?: string; state?: string };\n   359→\n   360→  try {\n   361→    parsed = JSON.parse(body);\n   362→  } catch {\n   363→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   364→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   365→    return;\n   366→  }\n   367→\n   368→  if (!parsed.code || !parsed.state) {\n   369→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   370→    res.end(JSON.stringify({ error: 'Missing required fields: code, state' }));\n   371→    return;\n   372→  }\n   373→\n   374→  const tokens = await oauth.exchangeCode(parsed.code, parsed.state);\n   375→  if (!tokens) {\n   376→    res.writeHead(401, { 'Content-Type': 'application/json' });\n   377→    res.end(JSON.stringify({ error: 'OAuth token exchange failed' }));\n   378→    return;\n   379→  }\n   380→\n   381→  // Also store the access token in TokenManager for backward compatibility\n   382→  tokenManager.storeClaudeToken(tokens.accessToken);\n   383→\n   384→  logger.info('OAuth flow completed, subscription connected');\n   385→\n   386→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   387→  res.end(JSON.stringify({\n   388→    status: 'connected',\n   389→    scopes: tokens.scopes,\n   390→    expiresAt: new Date(tokens.expiresAt).toISOString(),\n   391→  }));\n   392→}\n   393→\n   394→function handleOAuthStatus(res: http.ServerResponse, oauth: OAuthManager): void {\n   395→  const tokens = oauth.getTokens();\n   396→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   397→  res.end(JSON.stringify({\n   398→    connected: oauth.hasTokens(),\n   399→    scopes: tokens?.scopes || [],\n   400→    expiresAt: tokens ? new Date(tokens.expiresAt).toISOString() : null,\n   401→    isExpired: tokens ? Date.now() > tokens.expiresAt : null,\n   402→  }));\n   403→}\n   404→\n   405→async function handleOAuthRefresh(\n   406→  res: http.ServerResponse,\n   407→  oauth: OAuthManager,\n   408→  tokenManager: TokenManager,\n   409→  logger: Logger,\n   410→): Promise<void> {\n   411→  const tokens = await oauth.refreshAccessToken();\n   412→  if (!tokens) {\n   413→    res.writeHead(500, { 'Content-Type': 'application/json' });\n   414→    res.end(JSON.stringify({ error: 'Token refresh failed' }));\n   415→    return;\n   416→  }\n   417→\n   418→  tokenManager.storeClaudeToken(tokens.accessToken);\n   419→  logger.info('OAuth token refreshed via API');\n   420→\n   421→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   422→  res.end(JSON.stringify({\n   423→    status: 'refreshed',\n   424→    expiresAt: new Date(tokens.expiresAt).toISOString(),\n   425→  }));\n   426→}\n   427→\n   428→function handleOAuthDisconnect(\n   429→  res: http.ServerResponse,\n   430→  oauth: OAuthManager,\n   431→  tokenManager: TokenManager,\n   432→): void {\n   433→  oauth.clearTokens();\n   434→  tokenManager.clearToken();\n   435→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   436→  res.end(JSON.stringify({ status: 'disconnected' }));\n   437→}\n   438→\n   439→// --- Token injection (for setup-token / manual paste) ---\n   440→\n   441→async function handleSetToken(\n   442→  req: http.IncomingMessage,\n   443→  res: http.ServerResponse,\n   444→  tokenManager: TokenManager,\n   445→  logger: Logger,\n   446→): Promise<void> {\n   447→  const body = await readBody(req);\n   448→  let parsed: { token?: string };\n   449→\n   450→  try {\n   451→    parsed = JSON.parse(body);\n   452→  } catch {\n   453→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   454→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   455→    return;\n   456→  }\n   457→\n   458→  if (!parsed.token) {\n   459→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   460→    res.end(JSON.stringify({ error: 'Missing required field: token' }));\n   461→    return;\n   462→  }\n   463→\n   464→  tokenManager.storeClaudeToken(parsed.token);\n   465→  logger.info('Claude token set via direct injection');\n   466→\n   467→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   468→  res.end(JSON.stringify({ status: 'token_stored' }));\n   469→}\n   470→\n   471→// --- Existing handlers ---\n   472→\n   473→function handleHealth(res: http.ServerResponse, pool: WorkerPool, oauth: OAuthManager): void {\n   474→  const counts = pool.getWorkerCount();\n   475→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   476→  res.end(JSON.stringify({\n   477→    status: 'ok',\n   478→    workers: counts,\n   479→    hasSubscription: oauth.hasTokens(),\n   480→    timestamp: Date.now(),\n   481→  }));\n   482→}\n   483→\n   484→function handleStatus(\n   485→  res: http.ServerResponse,\n   486→  pool: WorkerPool,\n   487→  dispatcher: Dispatcher,\n   488→  tokenManager: TokenManager,\n   489→  oauth: OAuthManager,\n   490→): void {\n   491→  const oauthTokens = oauth.getTokens();\n   492→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   493→  res.end(JSON.stringify({\n   494→    workers: pool.getWorkers(),\n   495→    workerCounts: pool.getWorkerCount(),\n   496→    queueLength: dispatcher.getQueueLength(),\n   497→    activeExecutions: dispatcher.getActiveExecutions(),\n   498→    hasClaudeToken: tokenManager.hasToken(),\n   499→    oauth: {\n   500→      connected: oauth.hasTokens(),\n   501→      scopes: oauthTokens?.scopes || [],\n   502→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   503→    },\n   504→  }));\n   505→}\n   506→\n   507→async function handleExecute(\n   508→  req: http.IncomingMessage,\n   509→  res: http.ServerResponse,\n   510→  dispatcher: Dispatcher,\n   511→  logger: Logger,\n   512→  ctx?: RequestContext,\n   513→): Promise<void> {\n   514→  const body = await readBody(req);\n   515→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   516→\n   517→  try {\n   518→    parsed = JSON.parse(body);\n   519→  } catch {\n   520→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   521→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   522→    return;\n   523→  }\n   524→\n   525→  if (!parsed.prompt) {\n   526→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   527→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   528→    return;\n   529→  }\n   530→\n   531→  const request: ExecRequest = {\n   532→    executionId: nanoid(),\n   533→    personaId: parsed.personaId || 'manual',\n   534→    prompt: parsed.prompt,\n   535→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   536→    config: {\n   537→      timeoutMs: parsed.timeoutMs || 300_000,\n   538→    },\n   539→  };\n   540→\n   541→  dispatcher.submit(request);\n   542→\n   543→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   544→\n   545→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   546→  res.end(JSON.stringify({\n   547→    executionId: request.executionId,\n   548→    status: 'queued',\n   549→  }));\n   550→}\n   551→\n   552→function handleGetExecution(\n   553→  res: http.ServerResponse,\n   554→  dispatcher: Dispatcher,\n   555→  executionId: string,\n   556→  offset: number = 0,\n   557→): void {\n   558→  const exec = dispatcher.getExecution(executionId);\n   559→\n   560→  if (!exec) {\n   561→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   562→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   563→    return;\n   564→  }\n   565→\n   566→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   567→\n   568→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   569→  res.end(JSON.stringify({\n   570→    executionId,\n   571→    status: exec.status,\n   572→    outputLines: exec.output.length,\n   573→    output,\n   574→    durationMs: exec.durationMs,\n   575→    sessionId: exec.sessionId,\n   576→    totalCostUsd: exec.totalCostUsd,\n   577→  }));\n   578→}\n   579→\n   580→function handleCancelExecution(\n   581→  res: http.ServerResponse,\n   582→  dispatcher: Dispatcher,\n   583→  executionId: string,\n   584→): void {\n   585→  const cancelled = dispatcher.cancelExecution(executionId);\n   586→\n   587→  if (!cancelled) {\n   588→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   589→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   590→    return;\n   591→  }\n   592→\n   593→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   594→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   595→}\n   596→\n   597→const MAX_BODY_BYTES = 1024 * 1024; // 1 MB\n   598→\n   599→function readBody(req: http.IncomingMessage): Promise<string> {\n   600→  return new Promise((resolve, reject) => {\n   601→    const chunks: Buffer[] = [];\n   602→    let totalBytes = 0;\n   603→    req.on('data', (chunk: Buffer) => {\n   604→      totalBytes += chunk.length;\n   605→      if (totalBytes > MAX_BODY_BYTES) {\n   606→        req.destroy();\n   607→        reject(new Error('Payload too large'));\n   608→        return;\n   609→      }\n   610→      chunks.push(chunk);\n   611→    });\n   612→    req.on('end', () => resolve(Buffer.concat(chunks).toString()));\n   613→    req.on('error', reject);\n   614→  });\n   615→}\n   616→"}]},"parent_tool_use_id":null,"session_id":"15915e67-0f08-45e6-a989-69b2c8df5088","uuid":"96e93d0d-40a0-478c-8144-1f8b68ae939a","timestamp":"2026-03-18T18:51:19.835Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\.claude\\worktrees\\idempotent-mapping-emerson\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport type { ExecRequest, Persona, PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { Logger } from 'pino';\nimport * as db from './db.js';\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n): http.Server {\n  const server = http.createServer(async (req, res) => {\n    // CORS headers\n    res.setHeader('Access-Control-Allow-Origin', '*');\n    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n\n    if (req.method === 'OPTIONS') {\n      res.writeHead(204);\n      res.end();\n      return;\n    }\n\n    const url = req.url || '/';\n    const [pathname, queryString] = url.split('?');\n\n    // Unauthenticated endpoints\n    if (pathname === '/health' && req.method === 'GET') {\n      handleHealth(res, pool, oauth);\n      return;\n    }\n\n    // Auth check for everything else — dual auth (API key + optional JWT)\n    const ctx = auth.validateAndExtractContext(req);\n    if (!ctx) {\n      res.writeHead(401, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Unauthorized' }));\n      return;\n    }\n\n    // Helper: project scoping (admin sees all, user sees own project)\n    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n\n    try {\n      // --- OAuth endpoints ---\n      if (pathname === '/api/oauth/authorize' && req.method === 'POST') {\n        handleOAuthAuthorize(res, oauth);\n      } else if (pathname === '/api/oauth/callback' && req.method === 'POST') {\n        await handleOAuthCallback(req, res, oauth, tokenManager, logger);\n      } else if (pathname === '/api/oauth/status' && req.method === 'GET') {\n        handleOAuthStatus(res, oauth);\n      } else if (pathname === '/api/oauth/refresh' && req.method === 'POST') {\n        await handleOAuthRefresh(res, oauth, tokenManager, logger);\n      } else if (pathname === '/api/oauth/disconnect' && req.method === 'DELETE') {\n        handleOAuthDisconnect(res, oauth, tokenManager);\n      }\n      // --- Token injection (fallback for setup-token / direct paste) ---\n      else if (pathname === '/api/token' && req.method === 'POST') {\n        await handleSetToken(req, res, tokenManager, logger);\n      }\n      // --- Persona CRUD ---\n      else if (pathname === '/api/personas' && req.method === 'GET' && database) {\n        json(res, 200, db.listPersonas(database, scopedProjectId));\n      } else if (pathname === '/api/personas' && req.method === 'POST' && database) {\n        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n        const now = new Date().toISOString();\n        const persona: Persona = {\n          id: body.id ?? nanoid(),\n          projectId: ctx.authType === 'user' ? ctx.projectId : (body.projectId ?? 'default'),\n          name: body.name ?? 'Untitled',\n          description: body.description ?? null,\n          systemPrompt: body.systemPrompt ?? '',\n          structuredPrompt: body.structuredPrompt ?? null,\n          icon: body.icon ?? null,\n          color: body.color ?? null,\n          enabled: body.enabled ?? true,\n          maxConcurrent: body.maxConcurrent ?? 1,\n          timeoutMs: body.timeoutMs ?? 300_000,\n          modelProfile: body.modelProfile ?? null,\n          maxBudgetUsd: body.maxBudgetUsd ?? null,\n          maxTurns: body.maxTurns ?? null,\n          designContext: body.designContext ?? null,\n          groupId: body.groupId ?? null,\n          createdAt: body.createdAt ?? now,\n          updatedAt: now,\n        };\n        db.upsertPersona(database, persona);\n        json(res, 201, persona);\n      } else if (matchRoute(pathname, '/api/personas/') && req.method === 'GET' && database) {\n        const id = pathname!.replace('/api/personas/', '');\n        const persona = db.getPersona(database, id);\n        if (!persona || (scopedProjectId && persona.projectId !== scopedProjectId)) { json(res, 404, { error: 'Not found' }); return; }\n        json(res, 200, persona);\n      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/tools') && req.method === 'GET' && database) {\n        const id = pathname!.replace('/api/personas/', '').replace('/tools', '');\n        json(res, 200, db.getToolsForPersona(database, id));\n      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/tools') && req.method === 'POST' && database) {\n        const id = pathname!.replace('/api/personas/', '').replace('/tools', '');\n        const body = JSON.parse(await readBody(req)) as { toolId: string };\n        db.linkTool(database, id, body.toolId);\n        json(res, 200, { linked: true });\n      } else if (matchRoute(pathname, '/api/personas/') && !pathname!.endsWith('/tools') && !pathname!.endsWith('/credentials') && !pathname!.endsWith('/subscriptions') && !pathname!.endsWith('/triggers') && req.method === 'DELETE' && database) {\n        const id = pathname!.replace('/api/personas/', '');\n        db.deletePersona(database, id, scopedProjectId);\n        json(res, 200, { deleted: true });\n      }\n      // --- Tool Definitions ---\n      else if (pathname === '/api/tool-definitions' && req.method === 'POST' && database) {\n        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n        const now = new Date().toISOString();\n        const tool: PersonaToolDefinition = {\n          id: body.id ?? nanoid(),\n          name: body.name ?? 'unnamed',\n          category: body.category ?? 'general',\n          description: body.description ?? '',\n          scriptPath: body.scriptPath ?? '',\n          inputSchema: body.inputSchema ?? null,\n          outputSchema: body.outputSchema ?? null,\n          requiresCredentialType: body.requiresCredentialType ?? null,\n          implementationGuide: body.implementationGuide ?? null,\n          isBuiltin: body.isBuiltin ?? false,\n          createdAt: body.createdAt ?? now,\n          updatedAt: now,\n        };\n        db.upsertToolDefinition(database, tool);\n        json(res, 201, tool);\n      }\n      // --- Credentials ---\n      else if (pathname === '/api/credentials' && req.method === 'POST' && database) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const cred = db.createCredential(database, body);\n        json(res, 201, cred);\n      } else if (matchRoute(pathname, '/api/credentials/') && req.method === 'DELETE' && database) {\n        const id = pathname!.replace('/api/credentials/', '');\n        db.deleteCredential(database, id);\n        json(res, 200, { deleted: true });\n      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/credentials') && req.method === 'GET' && database) {\n        const id = pathname!.replace('/api/personas/', '').replace('/credentials', '');\n        const creds = db.listCredentialsForPersona(database, id);\n        // Strip encrypted data from response\n        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/credentials') && req.method === 'POST' && database) {\n        const id = pathname!.replace('/api/personas/', '').replace('/credentials', '');\n        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n        db.linkCredential(database, id, body.credentialId);\n        json(res, 200, { linked: true });\n      }\n      // --- Event Subscriptions ---\n      else if (pathname === '/api/subscriptions' && req.method === 'POST' && database) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const sub = db.createSubscription(database, body);\n        json(res, 201, sub);\n      } else if (matchRoute(pathname, '/api/subscriptions/') && req.method === 'PUT' && database) {\n        const id = pathname!.replace('/api/subscriptions/', '');\n        const body = JSON.parse(await readBody(req));\n        db.updateSubscription(database, id, body);\n        const updated = db.getSubscription(database, id);\n        json(res, 200, updated);\n      } else if (matchRoute(pathname, '/api/subscriptions/') && req.method === 'DELETE' && database) {\n        const id = pathname!.replace('/api/subscriptions/', '');\n        db.deleteSubscription(database, id);\n        json(res, 200, { deleted: true });\n      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/subscriptions') && req.method === 'GET' && database) {\n        const id = pathname!.replace('/api/personas/', '').replace('/subscriptions', '');\n        json(res, 200, db.listSubscriptionsForPersona(database, id));\n      }\n      // --- Triggers ---\n      else if (pathname === '/api/triggers' && req.method === 'POST' && database) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const trigger = db.createTrigger(database, body);\n        json(res, 201, trigger);\n      } else if (matchRoute(pathname, '/api/triggers/') && req.method === 'PUT' && database) {\n        const id = pathname!.replace('/api/triggers/', '');\n        const body = JSON.parse(await readBody(req));\n        db.updateTrigger(database, id, body);\n        const updated = db.getTrigger(database, id);\n        json(res, 200, updated);\n      } else if (matchRoute(pathname, '/api/triggers/') && req.method === 'DELETE' && database) {\n        const id = pathname!.replace('/api/triggers/', '');\n        db.deleteTrigger(database, id);\n        json(res, 200, { deleted: true });\n      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/triggers') && req.method === 'GET' && database) {\n        const id = pathname!.replace('/api/personas/', '').replace('/triggers', '');\n        json(res, 200, db.listTriggersForPersona(database, id));\n      }\n      // --- Events ---\n      else if (pathname === '/api/events' && req.method === 'GET' && database) {\n        const params = new URLSearchParams(queryString || '');\n        const events = db.listEvents(database, {\n          eventType: params.get('eventType') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: params.get('limit') ? parseInt(params.get('limit')!, 10) : 50,\n          offset: params.get('offset') ? parseInt(params.get('offset')!, 10) : undefined,\n          projectId: scopedProjectId,\n        });\n        json(res, 200, events);\n      } else if (pathname === '/api/events' && req.method === 'POST' && database) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const event = db.publishEvent(database, body);\n        json(res, 201, event);\n      } else if (matchRoute(pathname, '/api/events/') && req.method === 'PUT' && database) {\n        const id = pathname!.replace('/api/events/', '');\n        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n        const updated = db.updateEventWithMetadata(database, id, body.status, body.metadata);\n        if (updated) {\n          json(res, 200, updated);\n        } else {\n          res.writeHead(404, { 'Content-Type': 'application/json' });\n          res.end(JSON.stringify({ error: 'Event not found' }));\n        }\n      }\n      // --- Webhooks ---\n      else if (matchRoute(pathname, '/api/webhooks/') && req.method === 'POST' && database) {\n        const personaId = pathname!.replace('/api/webhooks/', '');\n        const body = await readBody(req);\n        const event = db.publishEvent(database, {\n          eventType: 'webhook_received',\n          sourceType: 'webhook',\n          sourceId: personaId,\n          targetPersonaId: personaId,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- GitLab Webhook ---\n      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && database) {\n        const body = await readBody(req);\n        let parsed: Record<string, unknown> = {};\n        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n        const event = db.publishEvent(database, {\n          eventType: `gitlab_${objectKind}`,\n          sourceType: 'gitlab',\n          sourceId: projectPath ?? null,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- Executions ---\n      else if (pathname === '/api/executions' && req.method === 'GET' && database) {\n        const params = new URLSearchParams(queryString || '');\n        const executions = db.listExecutions(database, {\n          personaId: params.get('personaId') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: params.get('limit') ? parseInt(params.get('limit')!, 10) : 50,\n          offset: params.get('offset') ? parseInt(params.get('offset')!, 10) : undefined,\n          projectId: scopedProjectId,\n        });\n        json(res, 200, executions);\n      }\n      // --- Existing execution endpoints ---\n      else if (pathname === '/api/status' && req.method === 'GET') {\n        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n      } else if (pathname === '/api/execute' && req.method === 'POST') {\n        await handleExecute(req, res, dispatcher, logger, ctx);\n      } else if (matchRoute(pathname, '/api/executions/') && pathname!.endsWith('/cancel') && req.method === 'POST') {\n        const executionId = pathname!.replace('/api/executions/', '').replace('/cancel', '');\n        handleCancelExecution(res, dispatcher, executionId || '');\n      } else if (matchRoute(pathname, '/api/executions/') && req.method === 'GET') {\n        const executionId = pathname!.replace('/api/executions/', '');\n        const params = new URLSearchParams(queryString || '');\n        const offset = parseInt(params.get('offset') || '0', 10);\n        handleGetExecution(res, dispatcher, executionId, offset);\n      }\n      // --- Admin-only routes ---\n      else if (pathname === '/api/admin/users' && req.method === 'GET' && database) {\n        if (requireAdmin(ctx, res)) return;\n        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n      } else if (pathname === '/api/admin/personas' && req.method === 'GET' && database) {\n        if (requireAdmin(ctx, res)) return;\n        json(res, 200, db.listPersonas(database));\n      } else if (pathname === '/api/admin/executions' && req.method === 'GET' && database) {\n        if (requireAdmin(ctx, res)) return;\n        const params = new URLSearchParams(queryString || '');\n        json(res, 200, db.listExecutions(database, {\n          limit: params.get('limit') ? parseInt(params.get('limit')!, 10) : 100,\n          offset: params.get('offset') ? parseInt(params.get('offset')!, 10) : undefined,\n        }));\n      } else {\n        res.writeHead(404, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Not found' }));\n      }\n    } catch (err) {\n      if (err instanceof Error && err.message === 'Payload too large') {\n        res.writeHead(413, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Payload too large' }));\n        return;\n      }\n      logger.error({ err, url }, 'HTTP handler error');\n      res.writeHead(500, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Internal server error' }));\n    }\n  });\n\n  return server;\n}\n\nfunction json(res: http.ServerResponse, status: number, data: unknown): void {\n  res.writeHead(status, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify(data));\n}\n\nfunction matchRoute(pathname: string | undefined, prefix: string): boolean {\n  return !!pathname && pathname.startsWith(prefix) && pathname.length > prefix.length;\n}\n\n/** Returns true (and sends 403) if the caller is NOT an admin. */\nfunction requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n  if (ctx.authType !== 'admin') {\n    res.writeHead(403, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Admin access required' }));\n    return true;\n  }\n  return false;\n}\n\n// --- OAuth handlers ---\n\nfunction handleOAuthAuthorize(res: http.ServerResponse, oauth: OAuthManager): void {\n  const { url, state } = oauth.generateAuthUrl();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    authUrl: url,\n    state,\n    instructions: [\n      '1. Open the authUrl in a browser',\n      '2. Log in with your Anthropic account and authorize',\n      '3. You will be redirected to a page showing an authorization code',\n      '4. Copy the code from the URL (the \"code\" query parameter)',\n      '5. POST it to /api/oauth/callback with { \"code\": \"...\", \"state\": \"...\" }',\n    ],\n  }));\n}\n\nasync function handleOAuthCallback(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  oauth: OAuthManager,\n  tokenManager: TokenManager,\n  logger: Logger,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { code?: string; state?: string };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.code || !parsed.state) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required fields: code, state' }));\n    return;\n  }\n\n  const tokens = await oauth.exchangeCode(parsed.code, parsed.state);\n  if (!tokens) {\n    res.writeHead(401, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'OAuth token exchange failed' }));\n    return;\n  }\n\n  // Also store the access token in TokenManager for backward compatibility\n  tokenManager.storeClaudeToken(tokens.accessToken);\n\n  logger.info('OAuth flow completed, subscription connected');\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    status: 'connected',\n    scopes: tokens.scopes,\n    expiresAt: new Date(tokens.expiresAt).toISOString(),\n  }));\n}\n\nfunction handleOAuthStatus(res: http.ServerResponse, oauth: OAuthManager): void {\n  const tokens = oauth.getTokens();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    connected: oauth.hasTokens(),\n    scopes: tokens?.scopes || [],\n    expiresAt: tokens ? new Date(tokens.expiresAt).toISOString() : null,\n    isExpired: tokens ? Date.now() > tokens.expiresAt : null,\n  }));\n}\n\nasync function handleOAuthRefresh(\n  res: http.ServerResponse,\n  oauth: OAuthManager,\n  tokenManager: TokenManager,\n  logger: Logger,\n): Promise<void> {\n  const tokens = await oauth.refreshAccessToken();\n  if (!tokens) {\n    res.writeHead(500, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Token refresh failed' }));\n    return;\n  }\n\n  tokenManager.storeClaudeToken(tokens.accessToken);\n  logger.info('OAuth token refreshed via API');\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    status: 'refreshed',\n    expiresAt: new Date(tokens.expiresAt).toISOString(),\n  }));\n}\n\nfunction handleOAuthDisconnect(\n  res: http.ServerResponse,\n  oauth: OAuthManager,\n  tokenManager: TokenManager,\n): void {\n  oauth.clearTokens();\n  tokenManager.clearToken();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ status: 'disconnected' }));\n}\n\n// --- Token injection (for setup-token / manual paste) ---\n\nasync function handleSetToken(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  tokenManager: TokenManager,\n  logger: Logger,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { token?: string };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.token) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required field: token' }));\n    return;\n  }\n\n  tokenManager.storeClaudeToken(parsed.token);\n  logger.info('Claude token set via direct injection');\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ status: 'token_stored' }));\n}\n\n// --- Existing handlers ---\n\nfunction handleHealth(res: http.ServerResponse, pool: WorkerPool, oauth: OAuthManager): void {\n  const counts = pool.getWorkerCount();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    status: 'ok',\n    workers: counts,\n    hasSubscription: oauth.hasTokens(),\n    timestamp: Date.now(),\n  }));\n}\n\nfunction handleStatus(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n): void {\n  const oauthTokens = oauth.getTokens();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    workers: pool.getWorkers(),\n    workerCounts: pool.getWorkerCount(),\n    queueLength: dispatcher.getQueueLength(),\n    activeExecutions: dispatcher.getActiveExecutions(),\n    hasClaudeToken: tokenManager.hasToken(),\n    oauth: {\n      connected: oauth.hasTokens(),\n      scopes: oauthTokens?.scopes || [],\n      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n    },\n  }));\n}\n\nasync function handleExecute(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  ctx?: RequestContext,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.prompt) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n    return;\n  }\n\n  const request: ExecRequest = {\n    executionId: nanoid(),\n    personaId: parsed.personaId || 'manual',\n    prompt: parsed.prompt,\n    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n    config: {\n      timeoutMs: parsed.timeoutMs || 300_000,\n    },\n  };\n\n  dispatcher.submit(request);\n\n  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n\n  res.writeHead(202, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId: request.executionId,\n    status: 'queued',\n  }));\n}\n\nfunction handleGetExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n  offset: number = 0,\n): void {\n  const exec = dispatcher.getExecution(executionId);\n\n  if (!exec) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found' }));\n    return;\n  }\n\n  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId,\n    status: exec.status,\n    outputLines: exec.output.length,\n    output,\n    durationMs: exec.durationMs,\n    sessionId: exec.sessionId,\n    totalCostUsd: exec.totalCostUsd,\n  }));\n}\n\nfunction handleCancelExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n): void {\n  const cancelled = dispatcher.cancelExecution(executionId);\n\n  if (!cancelled) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n    return;\n  }\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n}\n\nconst MAX_BODY_BYTES = 1024 * 1024; // 1 MB\n\nfunction readBody(req: http.IncomingMessage): Promise<string> {\n  return new Promise((resolve, reject) => {\n    const chunks: Buffer[] = [];\n    let totalBytes = 0;\n    req.on('data', (chunk: Buffer) => {\n      totalBytes += chunk.length;\n      if (totalBytes > MAX_BODY_BYTES) {\n        req.destroy();\n        reject(new Error('Payload too large'));\n        return;\n      }\n      chunks.push(chunk);\n    });\n    req.on('end', () => resolve(Buffer.concat(chunks).toString()));\n    req.on('error', reject);\n  });\n}\n","numLines":616,"startLine":1,"totalLines":616}}}
