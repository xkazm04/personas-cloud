   const proxyUrl = `http://127.0.0.1:${proxy.port}`;\n    78→        sandbox.env['HTTP_PROXY'] = proxyUrl;\n    79→        sandbox.env['HTTPS_PROXY'] = proxyUrl;\n    80→        sandbox.env['http_proxy'] = proxyUrl;\n    81→        sandbox.env['https_proxy'] = proxyUrl;\n    82→        sandbox.env['NO_PROXY'] = '';\n    83→      }\n    84→\n    85→      // Inject credentials via async file write (unblocks event loop)\n    86→      injectedCreds = await injectCredentialsViaFile(sandbox.env, assignment.executionId, this.logger);\n    87→      sandbox.env[injectedCreds.envPointerKey] = injectedCreds.credentialFilePath;\n    88→\n    89→      this.childProcess = spawn(sandbox.command, sandbox.args, {\n    90→        cwd: sandbox.cwd,\n    91→        stdio: ['pipe', 'pipe', 'pipe'],\n    92→        env: sandbox.env,\n    93→      });\n    94→\n    95→      // Pipe prompt to stdin\n    96→      this.childProcess.stdin!.write(assignment.prompt);\n    97→      this.childProcess.stdin!.end();\n    98→\n    99→      // Set up timeout\n   100→      const timeoutHandle = setTimeout(() => {\n   101→        this.logger.warn({\n   102→          executionId: assignment.executionId,\n   103→          timeoutMs: assignment.config.timeoutMs,\n   104→        }, 'Execution timeout, killing process');\n   105→        this.kill();\n   106→      }, assignment.config.timeoutMs);\n   107→\n   108→      // Parse stdout\n   109→      const stdoutBuffer = new LineBuffer();\n   110→      this.childProcess.stdout!.on('data', (data: Buffer) => {\n   111→        const lines = stdoutBuffer.push(data.toString());\n   112→        for (const line of lines) {\n   113→          this.processStdoutLine(line, callbacks);\n   114→        }\n   115→      });\n   116→\n   117→      // Parse stderr\n   118→      const stderrBuffer = new LineBuffer();\n   119→      this.childProcess.stderr!.on('data', (data: Buffer) => {\n   120→        const lines = stderrBuffer.push(data.toString());\n   121→        for (cons