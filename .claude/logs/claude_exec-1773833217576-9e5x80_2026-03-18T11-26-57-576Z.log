 k: string): boolean {\n   139→  return typeof o[k] === 'number';\n   140→}\n   141→\n   142→function hasStrArr(o: Record<string, unknown>, k: string): boolean {\n   143→  return Array.isArray(o[k]) && (o[k] as unknown[]).every(v => typeof v === 'string');\n   144→}\n   145→\n   146→export function validateWorkerMessage(msg: unknown): WorkerMessage | null {\n   147→  if (!isObj(msg) || !hasStr(msg, 'type')) return null;\n   148→  const m = msg as Record<string, unknown> & { type: string };\n   149→  switch (m.type) {\n   150→    case 'hello':\n   151→      return hasStr(m, 'workerId') && hasStr(m, 'version') && hasStrArr(m, 'capabilities')\n   152→        ? (m as unknown as WorkerHello) : null;\n   153→    case 'ready':\n   154→      return m as unknown as WorkerReady;\n   155→    case 'stdout':\n   156→    case 'stderr':\n   157→      return hasStr(m, 'executionId') && hasStr(m, 'chunk') && hasNum(m, 'timestamp')\n   158→        ? (m as unknown as ExecStdout & ExecStderr) : null;\n   159→    case 'complete':\n   160→      return hasStr(m, 'executionId') && hasStr(m, 'status') && hasNum(m, 'exitCode') && hasNum(m, 'durationMs')\n   161→        ? (m as unknown as ExecComplete) : null;\n   162→    case 'event':\n   163→      return hasStr(m, 'executionId') && hasStr(m, 'eventType') && 'payload' in m\n   164→        ? (m as unknown as WorkerEvent) : null;\n   165→    case 'progress':\n   166→      return hasStr(m, 'executionId') && hasStr(m, 'phase') && hasNum(m, 'percent') && hasNum(m, 'timestamp')\n   167→        ? (m as unknown as ExecProgress) : null;\n   168→    case 'heartbeat':\n   169→      return hasNum(m, 'timestamp') ? (m as unknown as WorkerHeartbeat) : null;\n   170→    case 'busy':\n   171→      return hasStr(m, 'executionId') && hasStr(m, 'reason')\n   172→        ? (m as unknown as WorkerBusy) : null;\n   173→    default:\n   174→      return null;\n   175→  }\n   176→}\n   177→\n   178→export function validateOrchestratorMessage(msg: unknown): OrchestratorMessage | null {\n   179→  if (!isObj(msg) || !hasStr(msg, 'type')) return null;\n   180→  const m = msg as Record<string, unknown> & { type: string };\n   181→  switch (m.type) {\n   182→    case 'ack':\n   183→      return hasStr(m, 'workerId') && hasStr(m, 'sessionToken')\n   184→        ? (m as unknown as OrchestratorAck) : null;\n   185→    case 'assign':\n   186→      return hasStr(m, 'executionId') && hasStr(m, 'personaId') && hasStr(m, 'prompt') && isObj(m.env) && isObj(m.config)\n   187→        ? (m as unknown as ExecAssign) : null;\n   188→    case 'cancel':\n   189→      return hasStr(m, 'executionId') ? (m as unknown as ExecCancel) : null;\n   190→    case 'shutdown':\n   191→      return hasStr(m, 'reason') && hasNum(m, 'gracePeriodMs')\n   192→        ? (m as unknown as OrchestratorShutdown) : null;\n   193→    case 'heartbeat':\n   194→      return hasNum(m, 'timestamp') ? (m as unknown as OrchestratorHeartbeat) : null;\n   195→    default:\n   196→      return null;\n   197→  }\n   198→}\n   199→\n   200→// --- Helpers ---\n   201→\n   202→export function parseWorkerMessage(raw: string): WorkerMessage | null {\n   203→  try {\n   204→    return validateWorkerMessage(JSON.parse(raw));\n   205→  } catch {\n   206→    return null;\n   207→  }\n   208→}\n   209→\n   210→export function parseOrchestratorMessage(raw: string): OrchestratorMessage | null {\n   211→  try {\n   212→    return validateOrchestratorMessage(JSON.parse(raw));\n   213→  } catch {\n   214→    return null;\n   215→  }\n   216→}\n   217→\n   218→export function serializeMessage(msg: WorkerMessage | OrchestratorMessage): string {\n   219→  return JSON.stringify(msg);\n   220→}\n   221→"}]},"parent_tool_use_id":null,"session_id":"a8b52b54-f9f8-434c-8e72-6074a57c043f","uuid":"a54ac885-0f52-4381-9c74-2a265125384a","timestamp":"2026-03-18T11:27:09.447Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\shared\\src\\protocol.ts","content":"// ============================================================\n// dac-wire: WebSocket protocol between orchestrator and workers\n// ============================================================\n\n// --- Worker → Orchestrator ---\n\nexport interface WorkerHello {\n  type: 'hello';\n  workerId: string;\n  version: string;\n  capabilities: string[];\n  imageDigest?: string;\n  claudeCliVersion?: string;\n}\n\nexport interface WorkerReady {\n  type: 'ready';\n}\n\nexport interface ExecStdout {\n  type: 'stdout';\n  executionId: string;\n  chunk: string;\n  timestamp: number;\n}\n\nexport interface ExecStderr {\n  type: 'stderr';\n  executionId: string;\n  chunk: string;\n  timestamp: number;\n}\n\nexport interface ExecComplete {\n  type: 'complete';\n  executionId: string;\n  status: 'completed' | 'failed' | 'cancelled';\n  exitCode: number;\n  durationMs: number;\n  sessionId?: string;\n  totalCostUsd?: number;\n}\n\nexport interface WorkerEvent {\n  type: 'event';\n  executionId: string;\n  eventType: 'manual_review' | 'user_message' | 'persona_action' | 'emit_event';\n  payload: unknown;\n}\n\nexport interface ExecProgress {\n  type: 'progress';\n  executionId: string;\n  phase: string;\n  percent: number;\n  detail?: string;\n  timestamp: number;\n}\n\nexport interface WorkerHeartbeat {\n  type: 'heartbeat';\n  timestamp: number;\n}\n\nexport interface WorkerBusy {\n  type: 'busy';\n  executionId: string;\n  reason: string;\n}\n\nexport type WorkerMessage =\n  | WorkerHello\n  | WorkerReady\n  | ExecStdout\n  | ExecStderr\n  | ExecComplete\n  | WorkerEvent\n  | ExecProgress\n  | WorkerHeartbeat\n  | WorkerBusy;\n\n// --- Orchestrator → Worker ---\n\nexport interface OrchestratorAck {\n  type: 'ack';\n  workerId: string;\n  sessionToken: string;\n}\n\nexport interface ExecAssign {\n  type: 'assign';\n  executionId: string;\n  personaId: string;\n  prompt: string;\n  env: Record<string, string>;\n  config: {\n    timeoutMs: number;\n    maxOutputBytes: number;\n    networkPolicy?: import('./networkPolicy.js').NetworkPolicy;\n    maxBudgetUsd?: number;\n    maxTurns?: number;\n  };\n}\n\nexport interface ExecCancel {\n  type: 'cancel';\n  executionId: string;\n}\n\nexport interface OrchestratorShutdown {\n  type: 'shutdown';\n  reason: string;\n  gracePeriodMs: number;\n}\n\nexport interface OrchestratorHeartbeat {\n  type: 'heartbeat';\n  timestamp: number;\n}\n\nexport type OrchestratorMessage =\n  | OrchestratorAck\n  | ExecAssign\n  | ExecCancel\n  | OrchestratorShutdown\n  | OrchestratorHeartbeat;\n\n// --- Runtime validators ---\n\nfunction isObj(v: unknown): v is Record<string, unknown> {\n  return typeof v === 'object' && v !== null && !Array.isArray(v);\n}\n\nfunction hasStr(o: Record<string, unknown>, k: string): boolean {\n  return typeof o[k] === 'string';\n}\n\nfunction hasNum(o: Record<string, unknown>, k: string): boolean {\n  return typeof o[k] === 'number';\n}\n\nfunction hasStrArr(o: Record<string, unknown>, k: string): boolean {\n  return Array.isArray(o[k]) && (o[k] as unknown[]).every(v => typeof v === 'string');\n}\n\nexport function validateWorkerMessage(msg: unknown): WorkerMessage | null {\n  if (!isObj(msg) || !hasStr(msg, 'type')) return null;\n  const m = msg as Record<string, unknown> & { type: string };\n  switch (m.type) {\n    case 'hello':\n      return hasStr(m, 'workerId') && hasStr(m, 'version') && hasStrArr(m, 'capabilities')\n        ? (m as unknown as WorkerHello) : null;\n    case 'ready':\n      return m as unknown as WorkerReady;\n    case 'stdout':\n    case 'stderr':\n      return hasStr(m, 'executionId') && hasStr(m, 'chunk') && hasNum(m, 'timestamp')\n        ? (m as unknown as ExecStdout & ExecStderr) : null;\n    case 'complete':\n      return hasStr(m, 'executionId') && hasStr(m, 'status') && hasNum(m, 'exitCode') && hasNum(m, 'durationMs')\n        ? (m as unknown as ExecComplete) : null;\n    case 'event':\n      return hasStr(m, 'executionId') && hasStr(m, 'eventType') && 'payload' in m\n        ? (m as unknown as WorkerEvent) : null;\n    case 'progress':\n      return hasStr(m, 'executionId') && hasStr(m, 'phase') && hasNum(m, 'percent') && hasNum(m, 'timestamp')\n        ? (m as unknown as ExecProgress) : null;\n    case 'heartbeat':\n      return hasNum(m, 'timestamp') ? (m as unknown as WorkerHeartbeat) : null;\n    case 'busy':\n      return hasStr(m, 'executionId') && hasStr(m, 'reason')\n        ? (m as unknown as WorkerBusy) : null;\n    default:\n      return null;\n  }\n}\n\nexport function validateOrchestratorMessage(msg: unknown): OrchestratorMessage | null {\n  if (!isObj(msg) || !hasStr(msg, 'type')) return null;\n  const m = msg as Record<string, unknown> & { type: string };\n  switch (m.type) {\n    case 'ack':\n      return hasStr(m, 'workerId') && hasStr(m, 'sessionToken')\n        ? (m as unknown as OrchestratorAck) : null;\n    case 'assign':\n      return hasStr(m, 'executionId') && hasStr(m, 'personaId') && hasStr(m, 'prompt') && isObj(m.env) && isObj(m.config)\n        ? (m as unknown as ExecAssign) : null;\n    case 'cancel':\n      return hasStr(m, 'executionId') ? (m as unknown as ExecCancel) : null;\n    case 'shutdown':\n      return hasStr(m, 'reason') && hasNum(m, 'gracePeriodMs')\n        ? (m as unknown as OrchestratorShutdown) : null;\n    case 'heartbeat':\n      return hasNum(m, 'timestamp') ? (m as unknown as OrchestratorHeartbeat) : null;\n    default:\n      return null;\n  }\n}\n\n// --- Helpers ---\n\nexport function parseWorkerMessage(raw: string): WorkerMessage | null {\n  try {\n    return validateWorkerMessage(JSON.parse(raw));\n  } catch {\n    return null;\n  }\n}\n\nexport function parseOrchestratorMessage(raw: string): OrchestratorMessage | null {\n  try {\n    return validateOrchestratorMessage(JSON.parse(raw));\n  } catch {\n    return null;\n  }\n}\n\nexport function serializeMessage(msg: WorkerMessage | OrchestratorMessage): string {\n  return JSON.stringify(msg);\n}\n","numLines":221,"startLine":1,"totalLines":221}}}
