 = createRowMapper<PersonaSummary>({\n    40→  id: { col: 'id' },\n    41→  projectId: { col: 'project_id' },\n    42→  name: { col: 'name' },\n    43→  description: { col: 'description', nullable: true },\n    44→  icon: { col: 'icon', nullable: true },\n    45→  color: { col: 'color', nullable: true },\n    46→  enabled: { col: 'enabled', bool: true },\n    47→  groupId: { col: 'group_id', nullable: true },\n    48→});\n    49→\n    50→// ---------------------------------------------------------------------------\n    51→// CRUD\n    52→// ---------------------------------------------------------------------------\n    53→\n    54→export function getPersona(db: Database.Database, id: string): Persona | undefined {\n    55→  const row = stmt(db,'SELECT * FROM personas WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n    56→  return row ? rowToPersona(row) : undefined;\n    57→}\n    58→\n    59→/** Batch-fetch multiple personas by ID. Returns a Map keyed by persona ID. */\n    60→export function getPersonasByIds(db: Database.Database, ids: string[]): Map<string, Persona> {\n    61→  const map = new Map<string, Persona>();\n    62→  if (ids.length === 0) return map;\n    63→  const placeholders = ids.map(() => '?').join(',');\n    64→  const rows = db.prepare(`SELECT * FROM personas WHERE id IN (${placeholders})`).all(...ids) as Record<string, unknown>[];\n    65→  for (const row of rows) {\n    66→    const persona = rowToPersona(row);\n    67→    map.set(persona.id, persona);\n    68→  }\n    69→  return map;\n    70→}\n    71→\n    72→export function listPersonas(db: Database.Database, projectId?: string): Persona[] {\n    73→  const { sql: where, params } = buildWhereClause({ projectId }, { projectId: 'project_id' });\n    74→  const rows = stmt(db, `SELECT * FROM personas ${where} ORDER BY name`).all(...params) as Record<string, unknown>[];\n    75→  return rows.map(rowToPersona);\n    76→}\n    77→\n    78→const SUMMARY_COLS = 'id, project_id, name, description, icon, color, enabled, group_id';\n    79→\n    80→export function listPersonasSummary(db: Database.Database, projectId?: string): PersonaSummary[] {\n    81→  const { sql: where, params } = buildWhereClause({ projectId }, { projectId: 'project_id' });\n    82→  const rows = stmt(db, `SELECT ${SUMMARY_COLS} FROM personas ${where} ORDER BY name`).all(...params) as Record<string, unknown>[];\n    83→  return rows.map(rowToPersonaSummary);\n    84→}\n    85→\n    86→export function upsertPersona(db: Database.Database, p: Persona): void {\n    87→  stmt(db,`\n    88→    INSERT INTO personas (id, project_id, name, description, system_prompt, structured_prompt, icon, color, enabled, max_concurrent, timeout_ms, inference_profile_id, network_policy, max_budget_usd, max_turns, design_context, group_id, created_at, updated_at)\n    89→    VALUES (@id, @projectId, @name, @description, @systemPrompt, @structuredPrompt, @icon, @color, @enabled, @maxConcurrent, @timeoutMs, @inferenceProfileId, @networkPolicy, @maxBudgetUsd, @maxTurns, @designContext, @groupId, @createdAt, @updatedAt)\n    90→    ON CONFLICT(id) DO UPDATE SET\n    91→      name = excluded.name, description = excluded.description, system_prompt = excluded.system_prompt,\n    92→      structured_prompt = excluded.structured_prompt, icon = excluded.icon, color = excluded.color,\n    93→      enabled = excluded.enabled, max_concurrent = excluded.max_concurrent, timeout_ms = excluded.timeout_ms,\n    94→      inference_profile_id = excluded.inference_profile_id,\n    95→      network_policy = excluded.network_policy, max_budget_usd = excluded.max_budget_usd, max_turns = excluded.max_turns,\n    96→      design_context = excluded.design_context, group_id = excluded.group_id, updated_at = excluded.updated_at\n    97→  `).run({\n    98→    id: p.id,\n    99→    projectId: p.projectId,\n   100→    name: p.name,\n   101→    description: p.description,\n   102→    systemPrompt: p.systemPrompt,\n   103→    structuredPrompt: p.structuredPrompt,\n   104→    icon: p.icon,\n   105→    color: p.color,\n   106→    enabled: p.enabled ? 1 : 0,\n   107→    maxConcurrent: p.maxConcurrent,\n   108→    timeoutMs: p.timeoutMs,\n   109→    inferenceProfileId: p.inferenceProfileId,\n   110→    networkPolicy: p.networkPolicy,\n   111→    maxBudgetUsd: p.maxBudgetUsd,\n   112→    maxTurns: p.maxTurns,\n   113→    designContext: p.designContext,\n   114→    groupId: p.groupId,\n   115→    createdAt: p.createdAt,\n   116→    updatedAt: p.updatedAt,\n   117→  });\n   118→}\n   119→\n   120→export function deletePersona(db: Database.Database, id: string, projectId?: string): void {\n   121→  if (projectId) {\n   122→    stmt(db,'DELETE FROM personas WHERE id = ? AND project_id = ?').run(id, projectId);\n   123→  } else {\n   124→    stmt(db,'DELETE FROM personas WHERE id = ?').run(id);\n   125→  }\n   126→}\n   127→\n   128→/** Fetch persona + tools, credentials (redacted), subscriptions, triggers in one transaction. */\n   129→export function getHydratedPersona(database: Database.Database, id: string): HydratedPersona | undefined {\n   130→  const row = stmt(database,'SELECT * FROM personas WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n   131→  if (!row) return undefined;\n   132→\n   133→  const persona = rowToPersona(row);\n   134→\n   135→  const toolRows = stmt(database,`\n   136→    SELECT t.* FROM persona_tool_definitions t\n   137→    JOIN persona_tools pt ON pt.tool_id = t.id\n   138→    WHERE pt.persona_id = ?\n   139→  `).all(id) as Record<string, unknown>[];\n   140→\n   141→  const credRows = stmt(database,`\n   142→    SELECT c.id, c.project_id, c.name, c.service_type, c.metadata, c.last_used_at, c.created_at, c.updated_at\n   143→    FROM persona_credentials c\n   144→    JOIN persona_credential_links cl ON cl.credential_id = c.id\n   145→    WHERE cl.persona_id = ?\n   146→  `).all(id) as Record<string, unknown>[];\n   147→\n   148→  const subRows = stmt(database,\n   149→    'SELECT * FROM persona_event_subscriptions WHERE persona_id = ?',\n   150→  ).all(id) as Record<string, unknown>[];\n   151→\n   152→  const triggerRows = stmt(database,\n   153→    'SELECT * FROM persona_triggers WHERE persona_id = ?',\n   154→  ).all(id) as Record<string, unknown>[];\n   155→\n   156→  return {\n   157→    ...persona,\n   158→    tools: toolRows.map(rowToTool),\n   159→    credentials: credRows.map(rowToRedactedCredential),\n   160→    subscriptions: subRows.map(rowToSubscription),\n   161→    triggers: triggerRows.map(rowToTrigger),\n   162→  };\n   163→}\n   164→\n   165→// ---------------------------------------------------------------------------\n   166→// Admin queries\n   167→// ---------------------------------------------------------------------------\n   168→\n   169→export function listDistinctProjectIds(db: Database.Database): string[] {\n   170→  const rows = stmt(db,'SELECT DISTINCT project_id FROM personas ORDER BY project_id').all() as Array<{ project_id: string }>;\n   171→  return rows.map(r => r.project_id);\n   172→}\n   173→"}]},"parent_tool_use_id":null,"session_id":"3049258c-b498-4c1e-9f74-b0c3e1c86778","uuid":"aefba7cd-b9cf-44e5-bbd5-948c66476be0","timestamp":"2026-03-18T11:50:49.345Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\db\\personas.ts","content":"import Database from 'better-sqlite3';\nimport type {\n  Persona,\n  PersonaSummary,\n  HydratedPersona,\n} from '@dac-cloud/shared';\nimport { stmt, createRowMapper, buildWhereClause } from './_helpers.js';\nimport { rowToTool } from './tools.js';\nimport { rowToRedactedCredential } from './credentials.js';\nimport { rowToSubscription } from './events.js';\nimport { rowToTrigger } from './triggers.js';\n\n// ---------------------------------------------------------------------------\n// Row mappers\n// ---------------------------------------------------------------------------\n\nconst rowToPersona = createRowMapper<Persona>({\n  id: { col: 'id' },\n  projectId: { col: 'project_id' },\n  name: { col: 'name' },\n  description: { col: 'description', nullable: true },\n  systemPrompt: { col: 'system_prompt' },\n  structuredPrompt: { col: 'structured_prompt', nullable: true },\n  icon: { col: 'icon', nullable: true },\n  color: { col: 'color', nullable: true },\n  enabled: { col: 'enabled', bool: true },\n  maxConcurrent: { col: 'max_concurrent' },\n  timeoutMs: { col: 'timeout_ms' },\n  inferenceProfileId: { col: 'inference_profile_id', nullable: true },\n  networkPolicy: { col: 'network_policy', nullable: true },\n  maxBudgetUsd: { col: 'max_budget_usd', nullable: true },\n  maxTurns: { col: 'max_turns', nullable: true },\n  designContext: { col: 'design_context', nullable: true },\n  groupId: { col: 'group_id', nullable: true },\n  createdAt: { col: 'created_at' },\n  updatedAt: { col: 'updated_at' },\n});\n\nconst rowToPersonaSummary = createRowMapper<PersonaSummary>({\n  id: { col: 'id' },\n  projectId: { col: 'project_id' },\n  name: { col: 'name' },\n  description: { col: 'description', nullable: true },\n  icon: { col: 'icon', nullable: true },\n  color: { col: 'color', nullable: true },\n  enabled: { col: 'enabled', bool: true },\n  groupId: { col: 'group_id', nullable: true },\n});\n\n// ---------------------------------------------------------------------------\n// CRUD\n// ---------------------------------------------------------------------------\n\nexport function getPersona(db: Database.Database, id: string): Persona | undefined {\n  const row = stmt(db,'SELECT * FROM personas WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n  return row ? rowToPersona(row) : undefined;\n}\n\n/** Batch-fetch multiple personas by ID. Returns a Map keyed by persona ID. */\nexport function getPersonasByIds(db: Database.Database, ids: string[]): Map<string, Persona> {\n  const map = new Map<string, Persona>();\n  if (ids.length === 0) return map;\n  const placeholders = ids.map(() => '?').join(',');\n  const rows = db.prepare(`SELECT * FROM personas WHERE id IN (${placeholders})`).all(...ids) as Record<string, unknown>[];\n  for (const row of rows) {\n    const persona = rowToPersona(row);\n    map.set(persona.id, persona);\n  }\n  return map;\n}\n\nexport function listPersonas(db: Database.Database, projectId?: string): Persona[] {\n  const { sql: where, params } = buildWhereClause({ projectId }, { projectId: 'project_id' });\n  const rows = stmt(db, `SELECT * FROM personas ${where} ORDER BY name`).all(...params) as Record<string, unknown>[];\n  return rows.map(rowToPersona);\n}\n\nconst SUMMARY_COLS = 'id, project_id, name, description, icon, color, enabled, group_id';\n\nexport function listPersonasSummary(db: Database.Database, projectId?: string): PersonaSummary[] {\n  const { sql: where, params } = buildWhereClause({ projectId }, { projectId: 'project_id' });\n  const rows = stmt(db, `SELECT ${SUMMARY_COLS} FROM personas ${where} ORDER BY name`).all(...params) as Record<string, unknown>[];\n  return rows.map(rowToPersonaSummary);\n}\n\nexport function upsertPersona(db: Database.Database, p: Persona): void {\n  stmt(db,`\n    INSERT INTO personas (id, project_id, name, description, system_prompt, structured_prompt, icon, color, enabled, max_concurrent, timeout_ms, inference_profile_id, network_policy, max_budget_usd, max_turns, design_context, group_id, created_at, updated_at)\n    VALUES (@id, @projectId, @name, @description, @systemPrompt, @structuredPrompt, @icon, @color, @enabled, @maxConcurrent, @timeoutMs, @inferenceProfileId, @networkPolicy, @maxBudgetUsd, @maxTurns, @designContext, @groupId, @createdAt, @updatedAt)\n    ON CONFLICT(id) DO UPDATE SET\n      name = excluded.name, description = excluded.description, system_prompt = excluded.system_prompt,\n      structured_prompt = excluded.structured_prompt, icon = excluded.icon, color = excluded.color,\n      enabled = excluded.enabled, max_concurrent = excluded.max_concurrent, timeout_ms = excluded.timeout_ms,\n      inference_profile_id = excluded.inference_profile_id,\n      network_policy = excluded.network_policy, max_budget_usd = excluded.max_budget_usd, max_turns = excluded.max_turns,\n      design_context = excluded.design_context, group_id = excluded.group_id, updated_at = excluded.updated_at\n  `).run({\n    id: p.id,\n    projectId: p.projectId,\n    name: p.name,\n    description: p.description,\n    systemPrompt: p.systemPrompt,\n    structuredPrompt: p.structuredPrompt,\n    icon: p.icon,\n    color: p.color,\n    enabled: p.enabled ? 1 : 0,\n    maxConcurrent: p.maxConcurrent,\n    timeoutMs: p.timeoutMs,\n    inferenceProfileId: p.inferenceProfileId,\n    networkPolicy: p.networkPolicy,\n    maxBudgetUsd: p.maxBudgetUsd,\n    maxTurns: p.maxTurns,\n    designContext: p.designContext,\n    groupId: p.groupId,\n    createdAt: p.createdAt,\n    updatedAt: p.updatedAt,\n  });\n}\n\nexport function deletePersona(db: Database.Database, id: string, projectId?: string): void {\n  if (projectId) {\n    stmt(db,'DELETE FROM personas WHERE id = ? AND project_id = ?').run(id, projectId);\n  } else {\n    stmt(db,'DELETE FROM personas WHERE id = ?').run(id);\n  }\n}\n\n/** Fetch persona + tools, credentials (redacted), subscriptions, triggers in one transaction. */\nexport function getHydratedPersona(database: Database.Database, id: string): HydratedPersona | undefined {\n  const row = stmt(database,'SELECT * FROM personas WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n  if (!row) return undefined;\n\n  const persona = rowToPersona(row);\n\n  const toolRows = stmt(database,`\n    SELECT t.* FROM persona_tool_definitions t\n    JOIN persona_tools pt ON pt.tool_id = t.id\n    WHERE pt.persona_id = ?\n  `).all(id) as Record<string, unknown>[];\n\n  const credRows = stmt(database,`\n    SELECT c.id, c.project_id, c.name, c.service_type, c.metadata, c.last_used_at, c.created_at, c.updated_at\n    FROM persona_credentials c\n    JOIN persona_credential_links cl ON cl.credential_id = c.id\n    WHERE cl.persona_id = ?\n  `).all(id) as Record<string, unknown>[];\n\n  const subRows = stmt(database,\n    'SELECT * FROM persona_event_subscriptions WHERE persona_id = ?',\n  ).all(id) as Record<string, unknown>[];\n\n  const triggerRows = stmt(database,\n    'SELECT * FROM persona_triggers WHERE persona_id = ?',\n  ).all(id) as Record<string, unknown>[];\n\n  return {\n    ...persona,\n    tools: toolRows.map(rowToTool),\n    credentials: credRows.map(rowToRedactedCredential),\n    subscriptions: subRows.map(rowToSubscription),\n    triggers: triggerRows.map(rowToTrigger),\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Admin queries\n// ---------------------------------------------------------------------------\n\nexport function listDistinctProjectIds(db: Database.Database): string[] {\n  const rows = stmt(db,'SELECT DISTINCT project_id FROM personas ORDER BY project_id').all() as Array<{ project_id: string }>;\n  return rows.map(r => r.project_id);\n}\n","numLines":173,"startLine":1,"totalLines":173}}}
