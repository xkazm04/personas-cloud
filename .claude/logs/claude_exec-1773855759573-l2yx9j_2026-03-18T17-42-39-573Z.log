[2026-03-18T17:42:48.981Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QfA13pGNe8SSjDWHSRvWnA","type":"tool_result","content":"     1→import { EventEmitter } from 'node:events';\n     2→import { deriveTenantKeyAsync } from '@dac-cloud/shared';\n     3→import type { Logger } from 'pino';\n     4→\n     5→interface CachedKey {\n     6→  key: Buffer;\n     7→  createdAt: number;\n     8→}\n     9→\n    10→export interface TenantKeyMetrics {\n    11→  hits: number;\n    12→  misses: number;\n    13→  cacheSize: number;\n    14→  derivations: number;\n    15→  avgDerivationMs: number;\n    16→}\n    17→\n    18→const DEFAULT_TTL_MS = 30 * 60 * 1000; // 30 minutes\n    19→const DEFAULT_RENEW_AHEAD_MS = 5 * 60 * 1000; // renew 5 min before expiry\n    20→\n    21→export type TenantIdSource = () => string[];\n    22→\n    23→export interface KeyDerivedEvent { tenantId: string; timestamp: number }\n    24→export interface TenantKeyEvents {\n    25→  'key:derived': [KeyDerivedEvent];\n    26→}\n    27→\n    28→/**\n    29→ * Manages per-tenant encryption keys with caching.\n    30→ *\n    31→ * Keys are derived from the master secret + tenant ID via PBKDF2 (shared/crypto.ts).\n    32→ * A single maintenance timer handles both renewal and eviction in a fixed order\n    33→ * (renew first, then evict) to prevent races between independent timers.\n    34→ *\n    35→ * Emits `key:derived` so audit concerns can subscribe externally.\n    36→ */\n    37→export class TenantKeyManager extends EventEmitter<TenantKeyEvents> {\n    38→  private cache = new Map<string, CachedKey>();\n    39→  private maintenanceTimer: NodeJS.Timeout;\n    40→  private tenantIdSource: TenantIdSource | null = null;\n    41→  private _hits = 0;\n    42→  private _misses = 0;\n    43→  private _derivations = 0;\n    44→  private _totalDerivationMs = 0;\n    45→\n    46→  constructor(\n    47→    private masterSecret: string,\n    48→    private logger: Logger,\n    49→    private ttlMs: number = DEFAULT_TTL_MS,\n    50→    private renewAheadMs: number = DEFAULT_RENEW_AHEAD_MS,\n    51→  ) {\n    52→    super();\n    53→    // Single timer for cache maintenance: renewal before eviction\n    54→    this.maintenanceTimer = setInterval(() => this.maintainCache(), 60_000);\n    55→  }\n    56→\n    57→  /**\n    58→   * Set a source function that returns all known tenant IDs.\n    59→   * Once set, pre-warms the cache. Proactive renewal runs automatically\n    60→   * via the unified maintenance timer when a tenant source is available.\n    61→   */\n    62→  async setTenantIdSource(source: TenantIdSource): Promise<void> {\n    63→    this.tenantIdSource = source;\n    64→    await this.warmAll();\n    65→  }\n    66→\n    67→  /**\n    68→   * Pre-derive and cache keys for all known tenants.\n    69→   */\n    70→  async warmAll(): Promise<void> {\n    71→    if (!this.tenantIdSource) return;\n    72→\n    73→    const tenantIds = this.tenantIdSource();\n    74→    let warmed = 0;\n    75→    const promises: Promise<void>[] = [];\n    76→    for (const tenantId of tenantIds) {\n    77→      const cached = this.cache.get(tenantId);\n    78→      if (!cached || Date.now() - cached.createdAt >= this.ttlMs) {\n    79→        promises.push(this.deriveAndCache(tenantId).then(() => { warmed++; }));\n    80→      }\n    81→    }\n    82→    await Promise.all(promises);\n    83→    if (warmed > 0) {\n    84→      this.logger.info({ warmed, total: tenantIds.length }, 'Pre-warmed tenant key cache');\n    85→    }\n    86→  }\n    87→\n    88→  /**\n    89→   * Eagerly warm the key cache for a single tenant (e.g., on tenant creation).\n    90→   */\n    91→  async warmTenant(tenantId: string): Promise<void> {\n    92→    await this.deriveAndCache(tenantId);\n    93→    this.logger.debug({ tenantId }, 'Eagerly warmed tenant key');\n    94→  }\n    95→\n    96→  /**\n    97→   * Get the encryption key for a tenant. Derives on first access, caches thereafter.\n    98→   */\n    99→  async getKey(tenantId: string): Promise<Buffer> {\n   100→    const cached = this.cache.get(tenantId);\n   101→    if (cached && Date.now() - cached.createdAt < this.ttlMs) {\n   102→      this._hits++;\n   103→      return cached.key;\n   104→    }\n   105→\n   106→    this._misses++;\n   107→    return this.deriveAndCache(tenantId);\n   108→  }\n   109→\n   110→  /**\n   111→   * Returns cache hit/miss metrics and derivation performance stats.\n   112→   */\n   113→  getMetrics(): TenantKeyMetrics {\n   114→    return {\n   115→      hits: this._hits,\n   116→      misses: this._misses,\n   117→      cacheSize: this.cache.size,\n   118→      derivations: this._derivations,\n   119→      avgDerivationMs: this._derivations > 0\n   120→        ? this._totalDerivationMs / this._derivations\n   121→        : 0,\n   122→    };\n   123→  }\n   124→\n   125→  /**\n   126→   * Invalidate all cached keys (e.g., after master key rotation).\n   127→   */\n   128→  invalidateAll(): void {\n   129→    this.zeroAllKeys();\n   130→    this.cache.clear();\n   131→    this.logger.info('All cached tenant keys invalidated');\n   132→  }\n   133→\n   134→  close(): void {\n   135→    clearInterval(this.maintenanceTimer);\n   136→    this.zeroAllKeys();\n   137→    this.cache.clear();\n   138→    this.removeAllListeners();\n   139→  }\n   140→\n   141→  private async deriveAndCache(tenantId: string): Promise<Buffer> {\n   142→    const existing = this.cache.get(tenantId);\n   143→    if (existing) existing.key.fill(0);\n   144→\n   145→    const { key, elapsedMs } = await deriveTenantKeyAsync(this.masterSecret, tenantId);\n   146→\n   147→    this._derivations++;\n   148→    this._totalDerivationMs += elapsedMs;\n   149→\n   150→    this.cache.set(tenantId, { key, createdAt: Date.now() });\n   151→\n   152→    this.emit('key:derived', { tenantId, timestamp: Date.now() });\n   153→\n   154→    this.logger.debug({ tenantId, derivationMs: Math.round(elapsedMs) }, 'Tenant key derived');\n   155→    return key;\n   156→  }\n   157→\n   158→  /** Zero all cached key buffers. */\n   159→  private zeroAllKeys(): void {\n   160→    for (const cached of this.cache.values()) {\n   161→      cached.key.fill(0);\n   162→    }\n   163→  }\n   164→\n   165→  /**\n   166→   * Unified cache maintenance: renew near-expiry keys first, then evict expired ones.\n   167→   * Running both phases in a single callback with fixed ordering prevents the race\n   168→   * where independent timers could evict a key before renewal refreshes it, or\n   169→   * renewal re-derives a key that eviction immediately deletes.\n   170→   */\n   171→  private async maintainCache(): Promise<void> {\n   172→    try {\n   173→      const now = Date.now();\n   174→\n   175→      // Phase 1: Renew keys approaching expiry (only when a tenant source is set)\n   176→      if (this.tenantIdSource) {\n   177→        const renewThreshold = this.ttlMs - this.renewAheadMs;\n   178→        const toRenew: { tenantId: string; promise: Promise<void> }[] = [];\n   179→\n   180→        for (const [tenantId, cached] of this.cache) {\n   181→          const age = now - cached.createdAt;\n   182→          if (age >= renewThreshold) {\n   183→            toRenew.push({ tenantId, promise: this.deriveAndCache(tenantId).then(() => {}) });\n   184→          }\n   185→        }\n   186→\n   187→        // Pick up any new tenants not yet in cache\n   188→        for (const tenantId of this.tenantIdSource()) {\n   189→          if (!this.cache.has(tenantId)) {\n   190→            toRenew.push({ tenantId, promise: this.deriveAndCache(tenantId).then(() => {}) });\n   191→          }\n   192→        }\n   193→\n   194→        const results = await Promise.allSettled(toRenew.map(r => r.promise));\n   195→        const failed = results\n   196→          .map((r, i) => r.status === 'rejected' ? { tenantId: toRenew[i].tenantId, reason: r.reason } : null)\n   197→          .filter(Boolean) as { tenantId: string; reason: unknown }[];\n   198→\n   199→        if (failed.length > 0) {\n   200→          for (const { tenantId, reason } of failed) {\n   201→            this.logger.error({ tenantId, err: reason }, 'Failed to renew tenant key during maintenance');\n   202→          }\n   203→        }\n   204→\n   205→        const succeeded = toRenew.length - failed.length;\n   206→        if (toRenew.length > 0) {\n   207→          this.logger.debug({ renewed: succeeded, failed: failed.length }, 'Proactively renewed tenant keys');\n   208→        }\n   209→      }\n   210→\n   211→      // Phase 2: Evict keys still past TTL (those not renewed above)\n   212→      for (const [tenantId, cached] of this.cache) {\n   213→        if (now - cached.createdAt >= this.ttlMs) {\n   214→          cached.key.fill(0);\n   215→          this.cache.delete(tenantId);\n   216→          this.logger.debug({ tenantId }, 'Evicted expired tenant key');\n   217→        }\n   218→      }\n   219→\n   220→      // Phase 3: Log cache metrics summary\n   221→      const metrics = this.getMetrics();\n   222→      const total = metrics.hits + metrics.misses;\n   223→      this.logger.info({\n   224→        hits: metrics.hits,\n   225→        misses: metrics.misses,\n   226→        hitRate: total > 0 ? `${((metrics.hits / total) * 100).toFixed(1)}%` : 'N/A',\n   227→        cacheSize: metrics.cacheSize,\n   228→        derivations: metrics.derivations,\n   229→        avgDerivationMs: Math.round(metrics.avgDerivationMs),\n   230→      }, 'Tenant key cache metrics');\n   231→    } catch (err) {\n   232→      this.logger.error({ err, cacheSize: this.cache.size }, 'Unexpected error during tenant key cache maintenance');\n   233→    }\n   234→  }\n   235→}\n   236→"}]},"parent_tool_use_id":null,"session_id":"1624ba40-4f68-417c-a7ea-09469f0f5381","uuid":"078fad67-d5f7-41b4-8293-d9573597d8df","timestamp":"2026-03-18T17:42:48.724Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\tenantKeyManager.ts","content":"import { EventEmitter } from 'node:events';\nimport { deriveTenantKeyAsync } from '@dac-cloud/shared';\nimport type { Logger } from 'pino';\n\ninterface CachedKey {\n  key: Buffer;\n  createdAt: number;\n}\n\nexport interface TenantKeyMetrics {\n  hits: number;\n  misses: number;\n  cacheSize: number;\n  derivations: number;\n  avgDerivationMs: number;\n}\n\nconst DEFAULT_TTL_MS = 30 * 60 * 1000; // 30 minutes\nconst DEFAULT_RENEW_AHEAD_MS = 5 * 60 * 1000; // renew 5 min before expiry\n\nexport type TenantIdSource = () => string[];\n\nexport interface KeyDerivedEvent { tenantId: string; timestamp: number }\nexport interface TenantKeyEvents {\n  'key:derived': [KeyDerivedEvent];\n}\n\n/**\n * Manages per-tenant encryption keys with caching.\n *\n * Keys are derived from the master secret + tenant ID via PBKDF2 (shared/crypto.ts).\n * A single maintenance timer handles both renewal and eviction in a fixed order\n * (renew first, then evict) to prevent races between independent timers.\n *\n * Emits `key:derived` so audit concerns can subscribe externally.\n */\nexport class TenantKeyManager extends EventEmitter<TenantKeyEvents> {\n  private cache = new Map<string, CachedKey>();\n  private maintenanceTimer: NodeJS.Timeout;\n  private tenantIdSource: TenantIdSource | null = null;\n  private _hits = 0;\n  private _misses = 0;\n  private _derivations = 0;\n  private _totalDerivationMs = 0;\n\n  constructor(\n    private masterSecret: string,\n    private logger: Logger,\n    private ttlMs: number = DEFAULT_TTL_MS,\n    private renewAheadMs: number = DEFAULT_RENEW_AHEAD_MS,\n  ) {\n    super();\n    // Single timer for cache maintenance: renewal before eviction\n    this.maintenanceTimer = setInterval(() => this.maintainCache(), 60_000);\n  }\n\n  /**\n   * Set a source function that returns all known tenant IDs.\n   * Once set, pre-warms the cache. Proactive renewal runs automatically\n   * via the unified maintenance timer when a tenant source is available.\n   */\n  async setTenantIdSource(source: TenantIdSource): Promise<void> {\n    this.tenantIdSource = source;\n    await this.warmAll();\n  }\n\n  /**\n   * Pre-derive and cache keys for all known tenants.\n   */\n  async warmAll(): Promise<void> {\n    if (!this.tenantIdSource) return;\n\n    const tenantIds = this.tenantIdSource();\n    let warmed = 0;\n    const promises: Promise<void>[] = [];\n    for (const tenantId of tenantIds) {\n      const cached = this.cache.get(tenantId);\n      if (!cached || Date.now() - cached.createdAt >= this.ttlMs) {\n        promises.push(this.deriveAndCache(tenantId).then(() => { warmed++; }));\n      }\n    }\n    await Promise.all(promises);\n    if (warmed > 0) {\n      this.logger.info({ warmed, total: tenantIds.length }, 'Pre-warmed tenant key cache');\n    }\n  }\n\n  /**\n   * Eagerly warm the key cache for a single tenant (e.g., on tenant creation).\n   */\n  async warmTenant(tenantId: string): Promise<void> {\n    await this.deriveAndCache(tenantId);\n    this.logger.debug({ tenantId }, 'Eagerly warmed tenant key');\n  }\n\n  /**\n   * Get the encryption key for a tenant. Derives on first access, caches thereafter.\n   */\n  async getKey(tenantId: string): Promise<Buffer> {\n    const cached = this.cache.get(tenantId);\n    if (cached && Date.now() - cached.createdAt < this.ttlMs) {\n      this._hits++;\n      return cached.key;\n    }\n\n    this._misses++;\n    return this.deriveAndCache(tenantId);\n  }\n\n  /**\n   * Returns cache hit/miss metrics and derivation performance stats.\n   */\n  getMetrics(): TenantKeyMetrics {\n    return {\n      hits: this._hits,\n      misses: this._misses,\n      cacheSize: this.cache.size,\n      derivations: this._derivations,\n      avgDerivationMs: this._derivations > 0\n        ? this._totalDerivationMs / this._derivations\n        : 0,\n    };\n  }\n\n  /**\n   * Invalidate all cached keys (e.g., after master key rotation).\n   */\n  invalidateAll(): void {\n    this.zeroAllKeys();\n    this.cache.clear();\n    this.logger.info('All cached tenant keys invalidated');\n  }\n\n  close(): void {\n    clearInterval(this.maintenanceTimer);\n    this.zeroAllKeys();\n    this.cache.clear();\n    this.removeAllListeners();\n  }\n\n  private async deriveAndCache(tenantId: string): Promise<Buffer> {\n    const existing = this.cache.get(tenantId);\n    if (existing) existing.key.fill(0);\n\n    const { key, elapsedMs } = await deriveTenantKeyAsync(this.masterSecret, tenantId);\n\n    this._derivations++;\n    this._totalDerivationMs += elapsedMs;\n\n    this.cache.set(tenantId, { key, createdAt: Date.now() });\n\n    this.emit('key:derived', { tenantId, timestamp: Date.now() });\n\n    this.logger.debug({ tenantId, derivationMs: Math.round(elapsedMs) }, 'Tenant key derived');\n    return key;\n  }\n\n  /** Zero all cached key buffers. */\n  private zeroAllKeys(): void {\n    for (const cached of this.cache.values()) {\n      cached.key.fill(0);\n    }\n  }\n\n  /**\n   * Unified cache maintenance: renew near-expiry keys first, then evict expired ones.\n   * Running both phases in a single callback with fixed ordering prevents the race\n   * where independent timers could evict a key before renewal refreshes it, or\n   * renewal re-derives a key that eviction immediately deletes.\n   */\n  private async maintainCache(): Promise<void> {\n    try {\n      const now = Date.now();\n\n      // Phase 1: Renew keys approaching expiry (only when a tenant source is set)\n      if (this.tenantIdSource) {\n        const renewThreshold = this.ttlMs - this.renewAheadMs;\n        const toRenew: { tenantId: string; promise: Promise<void> }[] = [];\n\n        for (const [tenantId, cached] of this.cache) {\n          const age = now - cached.createdAt;\n          if (age >= renewThreshold) {\n            toRenew.push({ tenantId, promise: this.deriveAndCache(tenantId).then(() => {}) });\n          }\n        }\n\n        // Pick up any new tenants not yet in cache\n        for (const tenantId of this.tenantIdSource()) {\n          if (!this.cache.has(tenantId)) {\n            toRenew.push({ tenantId, promise: this.deriveAndCache(tenantId).then(() => {}) });\n          }\n        }\n\n        const results = await Promise.allSettled(toRenew.map(r => r.promise));\n        const failed = results\n          .map((r, i) => r.status === 'rejected' ? { tenantId: toRenew[i].tenantId, reason: r.reason } : null)\n          .filter(Boolean) as { tenantId: string; reason: unknown }[];\n\n        if (failed.length > 0) {\n          for (const { tenantId, reason } of failed) {\n            this.logger.error({ tenantId, err: reason }, 'Failed to renew tenant key during maintenance');\n          }\n        }\n\n        const succeeded = toRenew.length - failed.length;\n        if (toRenew.length > 0) {\n          this.logger.debug({ renewed: succeeded, failed: failed.length }, 'Proactively renewed tenant keys');\n        }\n      }\n\n      // Phase 2: Evict keys still past TTL (those not renewed above)\n      for (const [tenantId, cached] of this.cache) {\n        if (now - cached.createdAt >= this.ttlMs) {\n          cached.key.fill(0);\n          this.cache.delete(tenantId);\n          this.logger.debug({ tenantId }, 'Evicted expired tenant key');\n        }\n      }\n\n      // Phase 3: Log cache metrics summary\n      const metrics = this.getMetrics();\n      const total = metrics.hits + metrics.misses;\n      this.logger.info({\n        hits: metrics.hits,\n        misses: metrics.misses,\n        hitRate: total > 0 ? `${((metrics.hits / total) * 100).toFixed(1)}%` : 'N/A',\n        cacheSize: metrics.cacheSize,\n        derivations: metrics.derivations,\n        avgDerivationMs: Math.round(metrics.avgDerivationMs),\n      }, 'Tenant key cache metrics');\n    } catch (err) {\n      this.logger.error({ err, cacheSize: this.cache.size }, 'Unexpected error during tenant key cache maintenance');\n    }\n  }\n}\n","numLines":236,"startLine":1,"totalLines":236}}}
