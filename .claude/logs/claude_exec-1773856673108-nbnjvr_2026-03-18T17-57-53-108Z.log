[2026-03-18T17:58:22.006Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P1oCn6oJCMvYaaFL835TWc","type":"tool_result","content":"     1→import type { ChildProcess } from 'node:child_process';\n     2→import { spawn } from 'node:child_process';\n     3→import type { ExecAssign, PhaseTimings } from '@dac-cloud/shared';\n     4→import { LineBuffer, extractStreamEvents } from './parser.js';\n     5→import { prepareSandbox, cleanupSandbox, type SandboxConfig } from './sandbox.js';\n     6→import { startFilterProxy, type ProxyHandle } from './networkProxy.js';\n     7→import { injectCredentialsViaFile, type InjectedCredentials } from './credentialInjector.js';\n     8→import { parseNetworkPolicy } from '@dac-cloud/shared';\n     9→import type { Logger } from 'pino';\n    10→\n    11→export interface ExecutorCallbacks {\n    12→  onStdout(chunk: string, timestamp: number): void;\n    13→  onStderr(chunk: string, timestamp: number): void;\n    14→  onEvent(eventType: 'manual_review' | 'user_message' | 'persona_action' | 'emit_event', payload: unknown): void;\n    15→  onProgress(phase: string, percent: number, detail?: string): void;\n    16→  onComplete(status: 'completed' | 'failed' | 'cancelled', exitCode: number, durationMs: number, sessionId?: string, totalCostUsd?: number, phaseTimings?: PhaseTimings): void;\n    17→}\n    18→\n    19→export interface ExecutorStatus {\n    20→  state: 'idle' | 'busy';\n    21→  executionId?: string;\n    22→  durationMs?: number;\n    23→}\n    24→\n    25→export class Executor {\n    26→  private childProcess: ChildProcess | null = null;\n    27→  private killed = false;\n    28→  private sessionId: string | undefined;\n    29→  private totalCostUsd: number | undefined;\n    30→  private currentExecutionId: string | null = null;\n    31→  private executionStartTime: number | null = null;\n    32→\n    33→  /**\n    34→   * Resolves when the current execution (including its finally-block cleanup)\