[2026-03-18T17:57:06.847Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NZpBGW3nYdptwDCpRJV2Am","type":"tool_result","content":"     1→import crypto from 'node:crypto';\n     2→import Database from 'better-sqlite3';\n     3→import type { Logger } from 'pino';\n     4→\n     5→/** SHA-256 hash chain genesis value (64 hex zeros). */\n     6→const GENESIS_HASH = '0'.repeat(64);\n     7→\n     8→/**\n     9→ * Compute a chain hash: SHA-256(previousHash + deterministic JSON of entry fields).\n    10→ * Each entry's hash commits to the entire chain history before it.\n    11→ */\n    12→function computeChainHash(prevHash: string, entry: BufferedEntry): string {\n    13→  const payload = prevHash + JSON.stringify([\n    14→    entry.timestamp,\n    15→    entry.action,\n    16→    entry.tenantId,\n    17→    entry.actor,\n    18→    entry.resourceType,\n    19→    entry.resourceId,\n    20→    entry.detail,\n    21→    entry.ipAddress,\n    22→  ]);\n    23→  return crypto.createHash('sha256').update(payload).digest('hex');\n    24→}\n    25→\n    26→const AUDIT_SCHEMA = `\n    27→CREATE TABLE IF NOT EXISTS audit_events (\n    28→  id INTEGER PRIMARY KEY AUTOINCREMENT,\n    29→  timestamp TEXT NOT NULL,\n    30→  action TEXT NOT NULL,\n    31→  tenant_id TEXT,\n    32→  actor TEXT,\n    33→  resource_type TEXT,\n    34→  resource_id TEXT,\n    35→  detail TEXT,\n    36→  ip_address TEXT,\n    37→  prev_hash TEXT\n    38→);\n    39→CREATE INDEX IF NOT EXISTS idx_audit_ts ON audit_events(timestamp);\n    40→CREATE INDEX IF NOT EXISTS idx_audit_tenant_action_ts ON audit_events(tenant_id, action, timestamp);\n    41→DROP INDEX IF EXISTS idx_audit_tenant_ts;\n    42→DROP INDEX IF EXISTS idx_audit_action;\n    43→`;\n    44→\n    45→/** Thrown when an audit event fails to persist — signals an audit trail gap. */\n    46→export class AuditWriteError extends Error {\n    47→  constructor(\n    48→    public readonly entry: AuditEntry,\n    49→    cause: unknown,\n    50→  ) {\n    51→    super(`Audit write failed for action \"${entry.action}\"`);\n    52→    this.name = 'AuditWriteError';\n    53→    this.cause = cause;\n    54→  }\n    55→}\n    56→\n    57→// ---------------------------------------------------------------------------\n    58→// Discriminated-union audit entries — each action carries its own typed payload\n    59→// ---------------------------------------------------------------------------\n    60→\n    61→/** Fields common to every audit entry. */\n    62→interface AuditEntryBase {\n    63→  tenantId?: string;\n    64→  actor?: string;\n    65→  ipAddress?: string;\n    66→}\n    67→\n    68→// --- Key management ---\n    69→interface KeyEncryptEntry extends AuditEntryBase {\n    70→  action: 'key:encrypt';\n    71→  resourceType: 'credential';\n    72→  resourceId: string;\n    73→}\n    74→\n    75→interface KeyDecryptEntry extends AuditEntryBase {\n    76→  action: 'key:decrypt';\n    77→  resourceType: 'credential';\n    78→  resourceId: string;\n    79→}\n    80→\n    81→interface KeyDecryptFailedEntry extends AuditEntryBase {\n    82→  action: 'key:decrypt_failed';\n    83→  resourceType: 'credential';\n    84→  resourceId: string;\n    85→  detail: { reason: string };\n    86→}\n    87→\n    88→interface KeyDeleteEntry extends AuditEntryBase {\n    89→  action: 'key:delete';\n    90→  resourceType: 'credential';\n    91→  resourceId: string;\n    92→}\n    93→\n    94→interface KeyAccessEntry extends AuditEntryBase {\n    95→  action: 'key:access';\n    96→  resourceType: 'credential';\n    97→  resourceId: string;\n    98→}\n    99→\n   100→interface KeyDeriveEntry extends AuditEntryBase {\n   101→  action: 'key:derive';\n   102→}\n   103→\n   104→// --- Persona management ---\n   105→interface PersonaCreateEntry extends AuditEntryBase {\n   106→  action: 'persona:create';\n   107→  resourceType: 'persona';\n   108→  resourceId: string;\n   109→}\n   110→\n   111→interface PersonaDeleteEntry extends AuditEntryBase {\n   112→  action: 'persona:delete';\n   113→  resourceType: 'persona';\n   114→  resourceId: string;\n   115→}\n   116→\n   117→// --- Tool management ---\n   118→interface ToolLinkEntry extends AuditEntryBase {\n   119→  action: 'tool:link';\n   120→  resourceType: 'persona';\n   121→  resourceId: string;\n   122→  detail: { toolId: string };\n   123→}\n   124→\n   125→interface ToolDefinitionCreateEntry extends AuditEntryBase {\n   126→  action: 'tool-definition:create';\n   127→  resourceType: 'toolDefinition';\n   128→  resourceId: string;\n   129→}\n   130→\n   131→// --- Credential linking ---\n   132→interface CredentialLinkEntry extends AuditEntryBase {\n   133→  action: 'credential:link';\n   134→  resourceType: 'persona';\n   135→  resourceId: string;\n   136→  detail: { credentialId: string };\n   137→}\n   138→\n   139→// --- Subscriptions ---\n   140→interface SubscriptionCreateEntry extends AuditEntryBase {\n   141→  action: 'subscription:create';\n   142→  resourceType: 'subscription';\n   143→  resourceId: string;\n   144→  detail: { personaId: string; eventType: string };\n   145→}\n   146→\n   147→interface SubscriptionUpdateEntry extends AuditEntryBase {\n   148→  action: 'subscription:update';\n   149→  resourceType: 'subscription';\n   150→  resourceId: string;\n   151→}\n   152→\n   153→interface SubscriptionDeleteEntry extends AuditEntryBase {\n   154→  action: 'subscription:delete';\n   155→  resourceType: 'subscription';\n   156→  resourceId: string;\n   157→}\n   158→\n   159→// --- Worker pool ---\n   160→interface WorkerConnectedEntry extends AuditEntryBase {\n   161→  action: 'worker:connected';\n   162→  detail: { workerId: string };\n   163→}\n   164→\n   165→interface WorkerDisconnectedEntry extends AuditEntryBase {\n   166→  action: 'worker:disconnected';\n   167→  detail: { workerId: string };\n   168→  resourceId?: string;\n   169→}\n   170→\n   171→/** Discriminated union of all audit event types. */\n   172→export type AuditEntry =\n   173→  | KeyEncryptEntry\n   174→  | KeyDecryptEntry\n   175→  | KeyDecryptFailedEntry\n   176→  | KeyDeleteEntry\n   177→  | KeyAccessEntry\n   178→  | KeyDeriveEntry\n   179→  | PersonaCreateEntry\n   180→  | PersonaDeleteEntry\n   181→  | ToolLinkEntry\n   182→  | ToolDefinitionCreateEntry\n   183→  | CredentialLinkEntry\n   184→  | SubscriptionCreateEntry\n   185→  | SubscriptionUpdateEntry\n   186→  | SubscriptionDeleteEntry\n   187→  | WorkerConnectedEntry\n   188→  | WorkerDisconnectedEntry;\n   189→\n   190→/** String-literal union of all valid audit actions. */\n   191→export type AuditAction = AuditEntry['action'];\n   192→\n   193→/** Row shape returned by audit_events queries. */\n   194→export interface AuditEvent {\n   195→  id: number;\n   196→  timestamp: string;\n   197→  action: string;\n   198→  tenant_id: string | null;\n   199→  actor: string | null;\n   200→  resource_type: string | null;\n   201→  resource_id: string | null;\n   202→  detail: string | null;\n   203→  ip_address: string | null;\n   204→  prev_hash: string | null;\n   205→}\n   206→\n   207→/** Result of verifying the audit hash chain. */\n   208→export interface ChainVerifyResult {\n   209→  valid: boolean;\n   210→  verifiedCount: number;\n   211→  brokenAtId?: number;\n   212→}\n   213→\n   214→/** Max entries buffered before an automatic flush. */\n   215→const BUFFER_FLUSH_SIZE = 50;\n   216→/** Interval (ms) between timer-based flushes. */\n   217→const BUFFER_FLUSH_INTERVAL_MS = 100;\n   218→\n   219→interface BufferedEntry {\n   220→  timestamp: string;\n   221→  action: string;\n   222→  tenantId: string | null;\n   223→  actor: string | null;\n   224→  resourceType: string | null;\n   225→  resourceId: string | null;\n   226→  detail: string | null;\n   227→  ipAddress: string | null;\n   228→}\n   229→\n   230→export class AuditLog {\n   231→  private db: Database.Database;\n   232→  private insertStmt: Database.Statement;\n   233→  private queryStmtCache = new Map<string, Database.Statement>();\n   234→  private buffer: BufferedEntry[] = [];\n   235→  private flushTimer: NodeJS.Timeout | null = null;\n   236→  private batchInsert: (entries: BufferedEntry[], hashes: string[]) => void;\n   237→  private lastHash: string;\n   238→\n   239→  constructor(\n   240→    dbPath: string,\n   241→    private logger: Logger,\n   242→  ) {\n   243→    this.db = new Database(dbPath);\n   244→    this.db.pragma('journal_mode = WAL');\n   245→    this.db.exec(AUDIT_SCHEMA);\n   246→\n   247→    // Migration: add prev_hash column to existing databases that lack it\n   248→    const cols = this.db.pragma('table_info(audit_events)') as { name: string }[];\n   249→    if (!cols.some((c) => c.name === 'prev_hash')) {\n   250→      this.db.exec('ALTER TABLE audit_events ADD COLUMN prev_hash TEXT');\n   251→    }\n   252→\n   253→    this.insertStmt = this.db.prepare(\n   254→      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address, prev_hash) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',\n   255→    );\n   256→\n   257→    // Initialize chain from last stored hash (or genesis for empty / pre-chain DBs)\n   258→    const lastRow = this.db.prepare(\n   259→      'SELECT prev_hash FROM audit_events WHERE prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n   260→    ).get() as { prev_hash: string } | undefined;\n   261→    this.lastHash = lastRow?.prev_hash ?? GENESIS_HASH;\n   262→\n   263→    // Wrap N inserts in a single transaction — one fsync instead of N\n   264→    const stmt = this.insertStmt;\n   265→    this.batchInsert = this.db.transaction((entries: BufferedEntry[], hashes: string[]) => {\n   266→      for (let i = 0; i < entries.length; i++) {\n   267→        const e = entries[i];\n   268→        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress, hashes[i]);\n   269→      }\n   270→    });\n   271→\n   272→    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n   273→\n   274→    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled, hash-chain active)');\n   275→  }\n   276→\n   277→  /** Expose the underlying database for use by RetentionPolicy. */\n   278→  getDb(): Database.Database {\n   279→    return this.db;\n   280→  }\n   281→\n   282→  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n   283→  countEvents(before?: string): number {\n   284→    const stmt = before\n   285→      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n   286→      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n   287→    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n   288→    return row.cnt;\n   289→  }\n   290→\n   291→  /**\n   292→   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   293→   * yielding the event loop between batches so concurrent DB operations\n   294→   * are not starved during large purges.\n   295→   */\n   296→  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n   297→    const deleteChunk = this.db.prepare(\n   298→      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n   299→    );\n   300→    let totalDeleted = 0;\n   301→    while (true) {\n   302→      const result = deleteChunk.run(cutoff, chunkSize);\n   303→      totalDeleted += result.changes;\n   304→      if (result.changes < chunkSize) break;\n   305→      await new Promise<void>((resolve) => setImmediate(resolve));\n   306→    }\n   307→    return totalDeleted;\n   308→  }\n   309→\n   310→  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n   311→  record(entry: AuditEntry): void {\n   312→    this.buffer.push({\n   313→      timestamp: new Date().toISOString(),\n   314→    