[2026-03-18T17:11:29.560Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E9NMQqThJBtW82tVCTioXz","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    11→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    12→import type { TenantDbManager } from './tenantDbManager.js';\n    13→import type { TenantKeyManager } from './tenantKeyManager.js';\n    14→import type { AuditLog } from './auditLog.js';\n    15→import type { Logger } from 'pino';\n    16→import * as db from './db/index.js';\n    17→import { readBody, json } from './httpUtils.js';\n    18→\n    19→export function createHttpApi(\n    20→  auth: Auth,\n    21→  dispatcher: Dispatcher,\n    22→  pool: WorkerPool,\n    23→  tokenManager: TokenManager,\n    24→  oauth: OAuthManager,\n    25→  logger: Logger,\n    26→  database?: Database.Database,\n    27→  tenantDbManager?: TenantDbManager,\n    28→  tenantKeyManager?: TenantKeyManager,\n    29→  auditLog?: AuditLog,\n    30→): http.Server {\n    31→  const server = http.createServer(async (req, res) => {\n    32→    // Security headers\n    33→    res.setHeader('X-Content-Type-Options', 'nosniff');\n    34→\n    35→    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    36→    const origin = req.headers.origin ?? '';\n    37→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    38→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    39→    if (isAdminRoute) {\n    40→      // Admin routes: only allow same-origin requests (no CORS wildcard)\n    41→      if (origin && origin === allowedOrigin) {\n    42→        res.setHeader('Access-Control-Allow-Origin', origin);\n    43→      }\n    44→      // If no match, omit the header entirely — browser blocks the request\n    45→    } else {\n    46→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    47→    }\n    48→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    49→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n    50→\n    51→    if (req.method === 'OPTIONS') {\n    52→      res.writeHead(204);\n    53→      res.end();\n    54→      return;\n    55→    }\n    56→\n    57→    const url = req.url || '/';\n    58→    const [pathname, queryString] = url.split('?');\n    59→    const route = parseRoute(pathname ?? '');\n    60→\n    61→    // Unauthenticated endpoints\n    62→    if (pathname === '/health' && req.method === 'GET') {\n    63→      handleHealth(res, pool, oauth);\n    64→      return;\n    65→    }\n    66→\n    67→    // Auth check for everything else — dual auth (API key + optional JWT)\n    68→    const ctx = auth.validateAndExtractContext(req);\n    69→    if (!ctx) {\n    70→      res.writeHead(401, { 'Content-Type': 'application/json' });\n    71→      res.end(JSON.stringify({ error: 'Unauthorized' }));\n    72→      return;\n    73→    }\n    74→\n    75→    // Helper: project scoping (admin sees all, user sees own project)\n    76→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n    77→\n    78→    // Resolve tenant-specific database when available\n    79→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n    80→      if (tenantDbManager && projectId) {\n    81→        return tenantDbManager.getTenantDb(projectId);\n    82→      }\n    83→      return database;\n    84→    };\n    85→    const tenantDb = resolveDatabase(ctx.projectId);\n    86→\n    87→    try {\n    88→      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n    89→      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n    90→        if (requireAdmin(ctx, res)) return;\n    91→        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n    92→        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n    93→        return;\n    94→      }\n    95→      // --- Persona CRUD ---\n    96→      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n    97→        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n    98→      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n    99→        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   100→        const persona = createPersonaWithDefaults({\n   101→          ...body,\n   102→          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   103→        });\n   104→        db.upsertPersona(tenantDb, persona);\n   105→        logger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   106→        json(res, 201, persona);\n   107→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n   108→        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n   109→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n   110→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   111→        if (!persona) return;\n   112→        const body = JSON.parse(await readBody(req)) as { toolId: string };\n   113→        db.linkTool(tenantDb, route.id, body.toolId);\n   114→        logger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   115→        json(res, 200, { linked: true });\n   116→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n   117→        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, logger), scopedProjectId, res);\n   118→        if (!hydrated) return;\n   119→        json(res, 200, hydrated);\n   120→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n   121→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   122→        if (!persona) return;\n   123→        json(res, 200, persona);\n   124→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   125→        db.deletePersona(tenantDb, route.id, scopedProjectId);\n   126→        logger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   127→        json(res, 200, { deleted: true });\n   128→      }\n   129→      // --- Tool Definitions ---\n   130→      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n   131→        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   132→        const tool = createToolDefinitionWithDefaults(body);\n   133→        db.upsertToolDefinition(tenantDb, tool);\n   134→        logger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   135→        json(res, 201, tool);\n   136→      }\n   137→      // --- Credentials ---\n   138→      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n   139→        const body = JSON.parse(await readBody(req));\n   140→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   141→\n   142→        // Require plaintext — clients must never supply pre-encrypted data\n   143→        if (!body.plaintext || typeof body.plaintext !== 'string') {\n   144→          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   145→          return;\n   146→        }\n   147→\n   148→        // Reject oversized plaintext before synchronous encryption blocks the event loop\n   149→        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   150→          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   151→          return;\n   152→        }\n   153→\n   154→        // Encryption is mandatory — reject if the key manager is unavailable\n   155→        if (!tenantKeyManager) {\n   156→          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   157→          return;\n   158→        }\n   159→\n   160→        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n   161→        delete body.encryptedData;\n   162→        delete body.iv;\n   163→        delete body.tag;\n   164→\n   165→        // Server-side encryption with per-tenant key\n   166→        const tenantId = body.projectId || ctx.projectId || 'default';\n   167→        const key = await tenantKeyManager.getKey(tenantId);\n   168→        const encrypted = encrypt(body.plaintext, key);\n   169→        body.encryptedData = encrypted.encrypted;\n   170→        body.iv = encrypted.iv;\n   171→        body.tag = encrypted.tag;\n   172→        delete body.plaintext;\n   173→\n   174→        const cred = db.createCredential(tenantDb, body);\n   175→        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n   176→        logger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   177→        json(res, 201, cred);\n   178→      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   179→        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n   180→        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   181→        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   182→        logger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   183→        json(res, 200, { deleted: true });\n   184→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n   185→        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n   186→        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   187→        // Strip encrypted data from response\n   188→        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   189→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n   190→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   191→        if (!persona) return;\n   192→        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   193→        db.linkCredential(tenantDb, route.id, body.credentialId);\n   194→        logger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route.id, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   195→        json(res, 200, { linked: true });\n   196→      }\n   197→      // --- Event Subscriptions ---\n   198→      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n   199→        const body = JSON.parse(await readBody(req));\n   200→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   201→        const missing: string[] = [];\n   202→        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   203→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   204→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   205→        const sub = db.createSubscription(tenantDb, body);\n   206→        json(res, 201, sub);\n   207→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   208→        const body = JSON.parse(await readBody(req));\n   209→        db.updateSubscription(tenantDb, route.id, body);\n   210→        const updated = db.getSubscription(tenantDb, route.id);\n   211→        json(res, 200, updated);\n   212→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   213→        db.deleteSubscription(tenantDb, route.id);\n   214→        json(res, 200, { deleted: true });\n   215→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n   216→        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n   217→      }\n   218→      // --- Triggers (delegated to triggerHttpHandlers) ---\n   219→      else if (route && tenantDb && (\n   220→        route.resource === 'triggers' ||\n   221→        (route.resource === 'personas' && route.subResource === 'triggers')\n   222→      )) {\n   223→        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n   224→        return;\n   225→      }\n   226→      // --- Events ---\n   227→      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n   228→        const params = new URLSearchParams(queryString || '');\n   229→        const events = db.listEvents(tenantDb, {\n   230→          eventType: params.get('eventType') ?? undefined,\n   231→          status: params.get('status') ?? undefined,\n   232→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   233→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   234→          projectId: scopedProjectId,\n   235→        });\n   236→        json(res, 200, events);\n   237→      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n   238→        const body = JSON.parse(await readBody(req));\n   239→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   240→        const missing: string[] = [];\n   241→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   242→        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   243→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   244→        const event = db.publishEvent(tenantDb, body);\n   245→        json(res, 201, event);\n   246→      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   247→        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n   248→        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n   249→        if (updated) {\n   250→          json(res, 200, updated);\n   251→        } else {\n   252→          res.writeHead(404, { 'Content-Type': 'application/json' });\n   253→          res.end(JSON.stringify({ error: 'Event not found' }));\n   254→        }\n   255→      }\n   256→      // --- Webhooks ---\n   257→      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n   258→        const personaId = route.id;\n   259→        const body = await readBody(req);\n   260→        const event = db.publishEvent(tenantDb, {\n   261→          eventType: 'webhook_received',\n   262→          sourceType: 'webhook',\n   263→          sourceId: personaId,\n   264→          targetPersonaId: personaId,\n   265→          payload: body,\n   266→        });\n   267→        json(res, 201, event);\n   268→      }\n   269→      // --- GitLab Webhook ---\n   270→      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n   271→        const body = await readBody(req);\n   272→        let parsed: Record<string, unknown> = {};\n   273→        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   274→        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   275→        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   276→        const event = db.publishEvent(tenantDb, {\n   277→          eventType: `gitlab_${objectKind}`,\n   278→          sourceType: 'gitlab',\n   279→          sourceId: projectPath ?? null,\n   280→          payload: body,\n   281→        });\n   282→        json(res, 201, event);\n   283→      }\n   284→      // --- Executions ---\n   285→      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n   286→        const params = new URLSearchParams(queryString || '');\n   287→        const executions = db.listExecutions(tenantDb, {\n   288→          personaId: params.get('personaId') ?? undefined,\n   289→          status: params.get('status') ?? undefined,\n   290→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   291→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   292→          projectId: scopedProjectId,\n   293→        });\n   294→        json(res, 200, executions);\n   295→      }\n   296→      // --- Existing execution endpoints ---\n   297→      else if (pathname === '/api/status' && req.method === 'GET') {\n   298→        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   299→      } else if (pathname === '/api/execute' && req.method === 'POST') {\n   300→        await handleExecute(req, res, dispatcher, logger, ctx);\n   301→      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n   302→        handleCancelExecution(res, dispatcher, route.id);\n   303→      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n   304→        const executionId = route.id;\n   305→        const params = new URLSearchParams(queryString || '');\n   306→        const offset = parseInt(params.get('offset') || '0', 10);\n   307→        handleGetExecution(res, dispatcher, executionId, offset);\n   308→      }\n   309→      // --- Admin-only routes ---\n   310→      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n   311→        if (requireAdmin(ctx, res)) return;\n   312→        if (tenantDbManager) {\n   313→          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   314→        } else if (database) {\n   315→          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   316→        } else {\n   317→          json(res, 200, { projectIds: [] });\n   318→        }\n   319→      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n   320→        if (requireAdmin(ctx, res)) return;\n   321→        if (tenantDbManager) {\n   322→          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   323→          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   324→          json(res, 200, allPersonas);\n   325→        } else if (database) {\n   326→          json(res, 200, db.listPersonasSummary(database));\n   327→        } else {\n   328→          json(res, 200, []);\n   329→        }\n   330→      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n   331→        if (requireAdmin(ctx, res)) return;\n   332→        const params = new URLSearchParams(queryString || '');\n   333→        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   334→        if (tenantDbManager) {\n   335→          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   336→          tenantDbManager.forEachTenant((tDb) => {\n   337→            allExecs.push(...db.listExecutions(tDb, { limit }));\n   338→          });\n   339→          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   340→          json(res, 200, allExecs.slice(0, limit));\n   341→        } else if (database) {\n   342→          json(res, 200, db.listExecutions(database, {\n   343→            limit,\n   344→            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   345→          }));\n   346→        } else {\n   347→          json(res, 200, []);\n   348→        }\n   349→      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n   350→        if (requireAdmin(ctx, res)) return;\n   351→        if (!auditLog) { json(res, 200, []); return; }\n   352→        const params = new URLSearchParams(queryString || '');\n   353→        json(res, 200, auditLog.query({\n   354→          tenantId: params.get('tenantId') ?? undefined,\n   355→          action: params.get('action') ?? undefined,\n   356→          since: params.get('since') ?? undefined,\n   357→          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   358→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   359→        }));\n   360→      } else {\n   361→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   362→        res.end(JSON.stringify({ error: 'Not found' }));\n   363→      }\n   364→    } catch (err) {\n   365→      if (err instanceof Error && err.message === 'Payload too large') {\n   366→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   367→        res.end(JSON.stringify({ error: 'Payload too large' }));\n   368→        return;\n   369→      }\n   370→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   371→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   372→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n   373→        return;\n   374→      }\n   375→      logger.error({ err, url }, 'HTTP handler error');\n   376→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   377→      res.end(JSON.stringify({ error: 'Internal server error' }));\n   378→    }\n   379→  });\n   380→\n   381→  return server;\n   382→}\n   383→\n   384→interface ParsedRoute {\n   385→  resource: string;\n   386→  id?: string;\n   387→  subResource?: string;\n   388→}\n   389→\n   390→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n   391→function parseRoute(pathname: string): ParsedRoute | null {\n   392→  if (!pathname.startsWith('/api/')) return null;\n   393→  const segments = pathname.slice(5).split('/').filter(Boolean);\n   394→  if (segments.length === 0) return null;\n   395→  return {\n   396→    resource: segments[0]!,\n   397→    id: segments[1],\n   398→    subResource: segments[2],\n   399→  };\n   400→}\n   401→\n   402→/**\n   403→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   404→ * Returns the entity on success, or null after sending a 404 response.\n   405→ */\n   406→function withScopedEntity<T extends { projectId?: string | null }>(\n   407→  entity: T | undefined,\n   408→  scopedProjectId: string | undefined,\n   409→  res: http.ServerResponse,\n   410→): T | null {\n   411→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   412→    json(res, 404, { error: 'Not found' });\n   413→    return null;\n   414→  }\n   415→  return entity;\n   416→}\n   417→\n   418→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   419→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   420→  if (ctx.authType !== 'admin') {\n   421→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   422→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   423→    return true;\n   424→  }\n   425→  return false;\n   426→}\n   427→\n   428→// --- Existing handlers ---\n   429→\n   430→function handleHealth(res: http.ServerResponse, pool: WorkerPool, oauth: OAuthManager): void {\n   431→  const counts = pool.getWorkerCount();\n   432→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   433→  res.end(JSON.stringify({\n   434→    status: 'ok',\n   435→    workers: counts,\n   436→    hasSubscription: oauth.hasTokens(),\n   437→    timestamp: Date.now(),\n   438→  }));\n   439→}\n   440→\n   441→function handleStatus(\n   442→  res: http.ServerResponse,\n   443→  pool: WorkerPool,\n   444→  dispatcher: Dispatcher,\n   445→  tokenManager: TokenManager,\n   446→  oauth: OAuthManager,\n   447→): void {\n   448→  const oauthTokens = oauth.getTokens();\n   449→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   450→  res.end(JSON.stringify({\n   451→    workers: pool.getWorkers(),\n   452→    workerCounts: pool.getWorkerCount(),\n   453→    workerPoolMetrics: pool.getMetrics(),\n   454→    queueLength: dispatcher.getQueueLength(),\n   455→    activeExecutions: dispatcher.getActiveExecutions(),\n   456→    hasClaudeToken: tokenManager.hasToken(),\n   457→    oauth: {\n   458→      connected: oauth.hasTokens(),\n   459→      scopes: oauthTokens?.scopes || [],\n   460→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   461→    },\n   462→  }));\n   463→}\n   464→\n   465→async function handleExecute(\n   466→  req: http.IncomingMessage,\n   467→  res: http.ServerResponse,\n   468→  dispatcher: Dispatcher,\n   469→  logger: Logger,\n   470→  ctx?: RequestContext,\n   471→): Promise<void> {\n   472→  const body = await readBody(req);\n   473→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   474→\n   475→  try {\n   476→    parsed = JSON.parse(body);\n   477→  } catch {\n   478→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   479→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   480→    return;\n   481→  }\n   482→\n   483→  if (!parsed.prompt) {\n   484→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   485→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   486→    return;\n   487→  }\n   488→\n   489→  const request: ExecRequest = {\n   490→    executionId: nanoid(),\n   491→    personaId: parsed.personaId || 'manual',\n   492→    prompt: parsed.prompt,\n   493→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   494→    config: {\n   495→      timeoutMs: parsed.timeoutMs || 300_000,\n   496→    },\n   497→  };\n   498→\n   499→  dispatcher.submit(request);\n   500→\n   501→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   502→\n   503→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   504→  res.end(JSON.stringify({\n   505→    executionId: request.executionId,\n   506→    status: 'queued',\n   507→  }));\n   508→}\n   509→\n   510→function handleGetExecution(\n   511→  res: http.ServerResponse,\n   512→  dispatcher: Dispatcher,\n   513→  executionId: string,\n   514→  offset: number = 0,\n   515→): void {\n   516→  const exec = dispatcher.getExecution(executionId);\n   517→\n   518→  if (!exec) {\n   519→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   520→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   521→    return;\n   522→  }\n   523→\n   524→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   525→\n   526→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   527→  res.end(JSON.stringify({\n   528→    executionId,\n   529→    status: exec.status,\n   530→    outputLines: exec.output.length,\n   531→    output,\n   532→    durationMs: exec.durationMs,\n   533→    sessionId: exec.sessionId,\n   534→    totalCostUsd: exec.totalCostUsd,\n   535→  }));\n   536→}\n   537→\n   538→function handleCancelExecution(\n   539→  res: http.ServerResponse,\n   540→  dispatcher: Dispatcher,\n   541→  executionId: string,\n   542→): void {\n   543→  const cancelled = dispatcher.cancelExecution(executionId);\n   544→\n   545→  if (!cancelled) {\n   546→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   547→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   548→    return;\n   549→  }\n   550→\n   551→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   552→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   553→}\n   554→\n   555→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\n   556→const MAX_QUERY_LIMIT = 500;\n   557→const MAX_QUERY_OFFSET = 100_000;\n   558→\n   559→/** Parse an integer query param and clamp it to safe bounds. */\n   560→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   561→  if (!value) return defaultValue;\n   562→  const parsed = parseInt(value, 10);\n   563→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   564→  return Math.min(parsed, max);\n   565→}\n   566→"}]},"parent_tool_use_id":null,"session_id":"8ecff3da-49df-4238-aff9-1324c7a2c38b","uuid":"42ab1a96-a4b4-48a7-a525-7a0fb36a8d9e","timestamp":"2026-03-18T17:11:29.480Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n): http.Server {\n  const server = http.createServer(async (req, res) => {\n    // Security headers\n    res.setHeader('X-Content-Type-Options', 'nosniff');\n\n    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    const origin = req.headers.origin ?? '';\n    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    if (isAdminRoute) {\n      // Admin routes: only allow same-origin requests (no CORS wildcard)\n      if (origin && origin === allowedOrigin) {\n        res.setHeader('Access-Control-Allow-Origin', origin);\n      }\n      // If no match, omit the header entirely — browser blocks the request\n    } else {\n      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    }\n    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n\n    if (req.method === 'OPTIONS') {\n      res.writeHead(204);\n      res.end();\n      return;\n    }\n\n    const url = req.url || '/';\n    const [pathname, queryString] = url.split('?');\n    const route = parseRoute(pathname ?? '');\n\n    // Unauthenticated endpoints\n    if (pathname === '/health' && req.method === 'GET') {\n      handleHealth(res, pool, oauth);\n      return;\n    }\n\n    // Auth check for everything else — dual auth (API key + optional JWT)\n    const ctx = auth.validateAndExtractContext(req);\n    if (!ctx) {\n      res.writeHead(401, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Unauthorized' }));\n      return;\n    }\n\n    // Helper: project scoping (admin sees all, user sees own project)\n    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n\n    // Resolve tenant-specific database when available\n    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n      if (tenantDbManager && projectId) {\n        return tenantDbManager.getTenantDb(projectId);\n      }\n      return database;\n    };\n    const tenantDb = resolveDatabase(ctx.projectId);\n\n    try {\n      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n        if (requireAdmin(ctx, res)) return;\n        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n        return;\n      }\n      // --- Persona CRUD ---\n      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n        const persona = createPersonaWithDefaults({\n          ...body,\n          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n        });\n        db.upsertPersona(tenantDb, persona);\n        logger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n        json(res, 201, persona);\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { toolId: string };\n        db.linkTool(tenantDb, route.id, body.toolId);\n        logger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n        json(res, 200, { linked: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, logger), scopedProjectId, res);\n        if (!hydrated) return;\n        json(res, 200, hydrated);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        json(res, 200, persona);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deletePersona(tenantDb, route.id, scopedProjectId);\n        logger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n        json(res, 200, { deleted: true });\n      }\n      // --- Tool Definitions ---\n      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n        const tool = createToolDefinitionWithDefaults(body);\n        db.upsertToolDefinition(tenantDb, tool);\n        logger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n        json(res, 201, tool);\n      }\n      // --- Credentials ---\n      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n\n        // Require plaintext — clients must never supply pre-encrypted data\n        if (!body.plaintext || typeof body.plaintext !== 'string') {\n          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n          return;\n        }\n\n        // Reject oversized plaintext before synchronous encryption blocks the event loop\n        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n          return;\n        }\n\n        // Encryption is mandatory — reject if the key manager is unavailable\n        if (!tenantKeyManager) {\n          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n          return;\n        }\n\n        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n        delete body.encryptedData;\n        delete body.iv;\n        delete body.tag;\n\n        // Server-side encryption with per-tenant key\n        const tenantId = body.projectId || ctx.projectId || 'default';\n        const key = await tenantKeyManager.getKey(tenantId);\n        const encrypted = encrypt(body.plaintext, key);\n        body.encryptedData = encrypted.encrypted;\n        body.iv = encrypted.iv;\n        body.tag = encrypted.tag;\n        delete body.plaintext;\n\n        const cred = db.createCredential(tenantDb, body);\n        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n        json(res, 201, cred);\n      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n        // Strip encrypted data from response\n        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n        db.linkCredential(tenantDb, route.id, body.credentialId);\n        logger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route.id, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n        json(res, 200, { linked: true });\n      }\n      // --- Event Subscriptions ---\n      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const sub = db.createSubscription(tenantDb, body);\n        json(res, 201, sub);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        db.updateSubscription(tenantDb, route.id, body);\n        const updated = db.getSubscription(tenantDb, route.id);\n        json(res, 200, updated);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deleteSubscription(tenantDb, route.id);\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n      }\n      // --- Triggers (delegated to triggerHttpHandlers) ---\n      else if (route && tenantDb && (\n        route.resource === 'triggers' ||\n        (route.resource === 'personas' && route.subResource === 'triggers')\n      )) {\n        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n        return;\n      }\n      // --- Events ---\n      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const events = db.listEvents(tenantDb, {\n          eventType: params.get('eventType') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, events);\n      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const event = db.publishEvent(tenantDb, body);\n        json(res, 201, event);\n      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n        if (updated) {\n          json(res, 200, updated);\n        } else {\n          res.writeHead(404, { 'Content-Type': 'application/json' });\n          res.end(JSON.stringify({ error: 'Event not found' }));\n        }\n      }\n      // --- Webhooks ---\n      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n        const personaId = route.id;\n        const body = await readBody(req);\n        const event = db.publishEvent(tenantDb, {\n          eventType: 'webhook_received',\n          sourceType: 'webhook',\n          sourceId: personaId,\n          targetPersonaId: personaId,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- GitLab Webhook ---\n      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n        const body = await readBody(req);\n        let parsed: Record<string, unknown> = {};\n        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n        const event = db.publishEvent(tenantDb, {\n          eventType: `gitlab_${objectKind}`,\n          sourceType: 'gitlab',\n          sourceId: projectPath ?? null,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- Executions ---\n      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const executions = db.listExecutions(tenantDb, {\n          personaId: params.get('personaId') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, executions);\n      }\n      // --- Existing execution endpoints ---\n      else if (pathname === '/api/status' && req.method === 'GET') {\n        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n      } else if (pathname === '/api/execute' && req.method === 'POST') {\n        await handleExecute(req, res, dispatcher, logger, ctx);\n      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n        handleCancelExecution(res, dispatcher, route.id);\n      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n        const executionId = route.id;\n        const params = new URLSearchParams(queryString || '');\n        const offset = parseInt(params.get('offset') || '0', 10);\n        handleGetExecution(res, dispatcher, executionId, offset);\n      }\n      // --- Admin-only routes ---\n      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n        } else if (database) {\n          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n        } else {\n          json(res, 200, { projectIds: [] });\n        }\n      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n          json(res, 200, allPersonas);\n        } else if (database) {\n          json(res, 200, db.listPersonasSummary(database));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        const params = new URLSearchParams(queryString || '');\n        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n        if (tenantDbManager) {\n          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n          tenantDbManager.forEachTenant((tDb) => {\n            allExecs.push(...db.listExecutions(tDb, { limit }));\n          });\n          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n          json(res, 200, allExecs.slice(0, limit));\n        } else if (database) {\n          json(res, 200, db.listExecutions(database, {\n            limit,\n            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          }));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (!auditLog) { json(res, 200, []); return; }\n        const params = new URLSearchParams(queryString || '');\n        json(res, 200, auditLog.query({\n          tenantId: params.get('tenantId') ?? undefined,\n          action: params.get('action') ?? undefined,\n          since: params.get('since') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        }));\n      } else {\n        res.writeHead(404, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Not found' }));\n      }\n    } catch (err) {\n      if (err instanceof Error && err.message === 'Payload too large') {\n        res.writeHead(413, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Payload too large' }));\n        return;\n      }\n      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n        res.writeHead(409, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n        return;\n      }\n      logger.error({ err, url }, 'HTTP handler error');\n      res.writeHead(500, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Internal server error' }));\n    }\n  });\n\n  return server;\n}\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\n/**\n * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n * Returns the entity on success, or null after sending a 404 response.\n */\nfunction withScopedEntity<T extends { projectId?: string | null }>(\n  entity: T | undefined,\n  scopedProjectId: string | undefined,\n  res: http.ServerResponse,\n): T | null {\n  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n    json(res, 404, { error: 'Not found' });\n    return null;\n  }\n  return entity;\n}\n\n/** Returns true (and sends 403) if the caller is NOT an admin. */\nfunction requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n  if (ctx.authType !== 'admin') {\n    res.writeHead(403, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Admin access required' }));\n    return true;\n  }\n  return false;\n}\n\n// --- Existing handlers ---\n\nfunction handleHealth(res: http.ServerResponse, pool: WorkerPool, oauth: OAuthManager): void {\n  const counts = pool.getWorkerCount();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    status: 'ok',\n    workers: counts,\n    hasSubscription: oauth.hasTokens(),\n    timestamp: Date.now(),\n  }));\n}\n\nfunction handleStatus(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n): void {\n  const oauthTokens = oauth.getTokens();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    workers: pool.getWorkers(),\n    workerCounts: pool.getWorkerCount(),\n    workerPoolMetrics: pool.getMetrics(),\n    queueLength: dispatcher.getQueueLength(),\n    activeExecutions: dispatcher.getActiveExecutions(),\n    hasClaudeToken: tokenManager.hasToken(),\n    oauth: {\n      connected: oauth.hasTokens(),\n      scopes: oauthTokens?.scopes || [],\n      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n    },\n  }));\n}\n\nasync function handleExecute(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  ctx?: RequestContext,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.prompt) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n    return;\n  }\n\n  const request: ExecRequest = {\n    executionId: nanoid(),\n    personaId: parsed.personaId || 'manual',\n    prompt: parsed.prompt,\n    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n    config: {\n      timeoutMs: parsed.timeoutMs || 300_000,\n    },\n  };\n\n  dispatcher.submit(request);\n\n  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n\n  res.writeHead(202, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId: request.executionId,\n    status: 'queued',\n  }));\n}\n\nfunction handleGetExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n  offset: number = 0,\n): void {\n  const exec = dispatcher.getExecution(executionId);\n\n  if (!exec) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found' }));\n    return;\n  }\n\n  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId,\n    status: exec.status,\n    outputLines: exec.output.length,\n    output,\n    durationMs: exec.durationMs,\n    sessionId: exec.sessionId,\n    totalCostUsd: exec.totalCostUsd,\n  }));\n}\n\nfunction handleCancelExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n): void {\n  const cancelled = dispatcher.cancelExecution(executionId);\n\n  if (!cancelled) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n    return;\n  }\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n}\n\nconst MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\nconst MAX_QUERY_LIMIT = 500;\nconst MAX_QUERY_OFFSET = 100_000;\n\n/** Parse an integer query param and clamp it to safe bounds. */\nfunction clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n  if (!value) return defaultValue;\n  const parsed = parseInt(value, 10);\n  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n  return Math.min(parsed, max);\n}\n","numLines":566,"startLine":1,"totalLines":566}}}
