[2026-03-18T17:11:29.133Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016tndymC23nDSTVT4xNqkyf","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import { matchEvent, assemblePrompt } from '@dac-cloud/shared';\n     4→import type { ExecRequest, EventMatch, PersonaEvent } from '@dac-cloud/shared';\n     5→import { nanoid } from 'nanoid';\n     6→import * as db from './db/index.js';\n     7→import type { Dispatcher } from './dispatcher.js';\n     8→import type { TenantDbManager } from './tenantDbManager.js';\n     9→\n    10→/** Default threshold (seconds) for the periodic stale-event reaper. */\n    11→const STALE_EVENT_REAPER_SECONDS = 120;\n    12→/** Run the reaper every N ticks (at 2s interval, 30 ticks = ~60s). */\n    13→const REAPER_TICK_INTERVAL = 30;\n    14→\n    15→/**\n    16→ * Recover events orphaned in 'processing' state from a prior crash.\n    17→ * Call once at startup before the tick loop begins.\n    18→ */\n    19→function recoverOrphanedEvents(\n    20→  database: Database.Database | null,\n    21→  logger: Logger,\n    22→  tenantDbManager?: TenantDbManager,\n    23→): void {\n    24→  if (tenantDbManager) {\n    25→    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    26→      const count = db.resetAllProcessingEvents(tenantDb);\n    27→      if (count > 0) {\n    28→        logger.warn({ projectId, count }, 'Reset orphaned processing events to pending at startup');\n    29→      }\n    30→    });\n    31→  } else if (database) {\n    32→    const count = db.resetAllProcessingEvents(database);\n    33→    if (count > 0) {\n    34→      logger.warn({ count }, 'Reset orphaned processing events to pending at startup');\n    35→    }\n    36→  }\n    37→}\n    38→\n    39→/**\n    40→ * Periodic reaper: reset events stuck in 'processing' longer than the threshold.\n    41→ * Guards against edge cases during normal operation.\n    42→ */\n    43→function reapStaleEvents(\n    44→  database: Database.Database | null,\n    45→  logger: Logger,\n    46→  tenantDbManager?: TenantDbManager,\n    47→): void {\n    48→  if (tenantDbManager) {\n    49→    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    50→      const count = db.resetStaleProcessingEvents(tenantDb, STALE_EVENT_REAPER_SECONDS);\n    51→      if (count > 0) {\n    52→        logger.warn({ projectId, count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    53→      }\n    54→    });\n    55→  } else if (database) {\n    56→    const count = db.resetStaleProcessingEvents(database, STALE_EVENT_REAPER_SECONDS);\n    57→    if (count > 0) {\n    58→      logger.warn({ count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    59→    }\n    60→  }\n    61→}\n    62→\n    63→/**\n    64→ * Start the event processing loop.\n    65→ * Supports both tenant-isolated DBs (via TenantDbManager) and legacy single DB.\n    66→ */\n    67→export function startEventProcessor(\n    68→  database: Database.Database | null,\n    69→  dispatcher: Dispatcher,\n    70→  logger: Logger,\n    71→  interval: number = 2000,\n    72→  tenantDbManager?: TenantDbManager,\n    73→): NodeJS.Timeout {\n    74→  // At startup, reset any events orphaned in 'processing' from a prior crash\n    75→  recoverOrphanedEvents(database, logger, tenantDbManager);\n    76→\n    77→  logger.info({ intervalMs: interval, tenantIsolated: !!tenantDbManager }, 'Event processor started');\n    78→\n    79→  let tickCount = 0;\n    80→\n    81→  return setInterval(() => {\n    82→    try {\n    83→      tickCount++;\n    84→\n    85→      // Periodically reap stale processing events as a safety net\n    86→      if (tickCount % REAPER_TICK_INTERVAL === 0) {\n    87→        reapStaleEvents(database, logger, tenantDbManager);\n    88→      }\n    89→\n    90→      if (tenantDbManager) {\n    91→        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    92→          eventBusTick(tenantDb, dispatcher, logger, projectId);\n    93→        });\n    94→      } else if (database) {\n    95→        eventBusTick(database, dispatcher, logger);\n    96→      }\n    97→    } catch (err) {\n    98→      logger.error({ err }, 'Event processor tick failed');\n    99→    }\n   100→  }, interval);\n   101→}\n   102→\n   103→function eventBusTick(\n   104→  database: Database.Database,\n   105→  dispatcher: Dispatcher,\n   106→  logger: Logger,\n   107→  projectId?: string,\n   108→): void {\n   109→  const tickStartMs = performance.now();\n   110→  let eventsFetched = 0;\n   111→  let matchesFound = 0;\n   112→  let delivered = 0;\n   113→  let skipped = 0;\n   114→  let failed = 0;\n   115→\n   116→  try {\n   117→    const events = db.getPendingEvents(database, 50);\n   118→    eventsFetched = events.length;\n   119→    if (eventsFetched === 0) return;\n   120→\n   121→    // Collect dispatch requests to fire *after* the transaction commits so that\n   122→    // the dispatcher never sees stale DB state.\n   123→    const pendingDispatches: ExecRequest[] = [];\n   124→\n   125→    // Wrap all DB reads/writes in a single transaction to avoid per-statement\n   126→    // fsync overhead (up to 100 individual commits per tick otherwise).\n   127→    database.transaction(() => {\n   128→      // Cache subscription lookups per unique (eventType, projectId) to avoid\n   129→      // redundant DB queries when the same event type fires multiple times in a batch.\n   130→      const subsCache = new Map<string, ReturnType<typeof db.getSubscriptionsByEventType>>();\n   131→\n   132→      // Phase 1: Mark events as processing, compute matches, collect unique persona IDs.\n   133→      const eventMatches: Array<{ event: PersonaEvent; matches: EventMatch[] }> = [];\n   134→      const allPersonaIds = new Set<string>();\n   135→\n   136→      for (const event of events) {\n   137→        db.updateEventStatus(database, event.id, 'processing');\n   138→\n   139→        const cacheKey = `${event.eventType}\\0${event.projectId}`;\n   140→        let subs = subsCache.get(cacheKey);\n   141→        if (subs === undefined) {\n   142→          subs = db.getSubscriptionsByEventType(database, event.eventType, event.projectId);\n   143→          subsCache.set(cacheKey, subs);\n   144→        }\n   145→        const matches = matchEvent(event, subs);\n   146→\n   147→        if (matches.length === 0) {\n   148→          db.updateEventStatus(database, event.id, 'skipped');\n   149→          skipped++;\n   150→          continue;\n   151→        }\n   152→\n   153→        matchesFound += matches.length;\n   154→        eventMatches.push({ event, matches });\n   155→        for (const match of matches) {\n   156→          allPersonaIds.add(match.personaId);\n   157→        }\n   158→      }\n   159→\n   160→      if (allPersonaIds.size === 0) return;\n   161→\n   162→      // Phase 2: Batch-fetch personas, tools, and running counts (2-3 queries total).\n   163→      const personaIds = [...allPersonaIds];\n   164→      const personaMap = db.getPersonasByIds(database, personaIds);\n   165→      const toolsMap = db.getToolsForPersonaIds(database, personaIds);\n   166→      const runningMap = db.countRunningExecutionsByPersonaIds(database, personaIds);\n   167→\n   168→      // Phase 3: Dispatch using Map lookups instead of per-match queries.\n   169→      // Track persona slots claimed within this tick to prevent over-dispatch.\n   170→      const claimed = new Map<string, number>();\n   171→\n   172→      for (const { event, matches } of eventMatches) {\n   173→        let eventDelivered = 0;\n   174→        let eventFailed = 0;\n   175→        let throttled = 0;\n   176→\n   177→        for (const match of matches) {\n   178→          try {\n   179→            const persona = personaMap.get(match.personaId);\n   180→            if (!persona) {\n   181→              logger.warn({ personaId: match.personaId, eventId: event.id }, 'Persona not found for event match');\n   182→              eventFailed++;\n   183→              failed++;\n   184→              continue;\n   185→            }\n   186→\n   187→            // Check concurrency (in-tick claims + batched DB count)\n   188→            const tickClaimed = claimed.get(persona.id) ?? 0;\n   189→            const running = runningMap.get(persona.id) ?? 0;\n   190→            if (running + tickClaimed >= persona.maxConcurrent) {\n   191→              logger.info({ personaId: persona.id, running, tickClaimed, max: persona.maxConcurrent }, 'Persona at concurrency limit, deferring');\n   192→              throttled++;\n   193→              continue;\n   194→            }\n   195→\n   196→            // Build input data from event payload\n   197→            let inputData: Record<string, unknown> | undefined;\n   198→            if (match.payload) {\n   199→              try {\n   200→                inputData = JSON.parse(match.payload);\n   201→              } catch (parseError) {\n   202→                logger.warn({ eventId: event.id, personaId: match.personaId, parseError }, 'Event payload JSON parse failed, using raw');\n   203→                inputData = { raw: match.payload };\n   204→              }\n   205→            }\n   206→\n   207→            // Assemble prompt using batched persona + tools\n   208→            const tools = toolsMap.get(persona.id) ?? [];\n   209→            const prompt = assemblePrompt(persona, tools, inputData);\n   210→\n   211→            // Queue dispatch request (fired after transaction commits)\n   212→            const request: ExecRequest = {\n   213→              executionId: nanoid(),\n   214→              personaId: persona.id,\n   215→              prompt,\n   216→              projectId: projectId ?? persona.projectId,\n   217→              config: { timeoutMs: persona.timeoutMs },\n   218→            };\n   219→\n   220→            pendingDispatches.push(request);\n   221→            claimed.set(persona.id, (claimed.get(persona.id) ?? 0) + 1);\n   222→            eventDelivered++;\n   223→            delivered++;\n   224→\n   225→            logger.info({\n   226→              eventId: event.id,\n   227→              personaId: persona.id,\n   228→              executionId: request.executionId,\n   229→              eventType: event.eventType,\n   230→              useCaseId: match.useCaseId,\n   231→            }, 'Event dispatched to persona');\n   232→          } catch (err) {\n   233→            logger.error({ err, personaId: match.personaId, eventId: event.id }, 'Failed to dispatch event match');\n   234→            eventFailed++;\n   235→            failed++;\n   236→          }\n   237→        }\n   238→\n   239→        // Update event status\n   240→        if (eventDelivered > 0 && eventFailed === 0 && throttled === 0) {\n   241→          db.updateEventStatus(database, event.id, 'delivered');\n   242→        } else if (eventDelivered > 0 && throttled > 0) {\n   243→          // Some matches delivered but others were concurrency-limited.\n   244→          // Defer with backoff so throttled matches get retried later.\n   245→          db.deferEventForRetry(database, event.id, event.retryCount);\n   246→          logger.info({ eventId: event.id, delivered: eventDelivered, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event partially delivered, deferring throttled matches for retry');\n   247→        } else if (eventDelivered > 0 && eventFailed > 0) {\n   248→          db.updateEventStatus(database, event.id, 'partial');\n   249→        } else if (throttled > 0) {\n   250→          // All (or remaining) matches were concurrency-limited — defer with backoff.\n   251→          db.deferEventForRetry(database, event.id, event.retryCount);\n   252→          logger.info({ eventId: event.id, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event deferred due to concurrency limits');\n   253→        } else {\n   254→          db.updateEventStatus(database, event.id, 'failed', 'All subscription matches failed');\n   255→        }\n   256→      }\n   257→    })();\n   258→\n   259→    // Fire dispatches after the transaction has committed successfully\n   260→    for (const request of pendingDispatches) {\n   261→      dispatcher.submit(request);\n   262→    }\n   263→  } finally {\n   264→    const tickDurationMs = performance.now() - tickStartMs;\n   265→    logger.info({\n   266→      tickDurationMs,\n   267→      eventsFetched,\n   268→      matchesFound,\n   269→      delivered,\n   270→      skipped,\n   271→      failed\n   272→    }, 'Event processor tick complete');\n   273→  }\n   274→}\n   275→"}]},"parent_tool_use_id":null,"session_id":"8ecff3da-49df-4238-aff9-1324c7a2c38b","uuid":"3eeb3596-ac2b-4a3d-88ca-8b3bbd042476","timestamp":"2026-03-18T17:11:29.042Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\eventProcessor.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport { matchEvent, assemblePrompt } from '@dac-cloud/shared';\nimport type { ExecRequest, EventMatch, PersonaEvent } from '@dac-cloud/shared';\nimport { nanoid } from 'nanoid';\nimport * as db from './db/index.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\n\n/** Default threshold (seconds) for the periodic stale-event reaper. */\nconst STALE_EVENT_REAPER_SECONDS = 120;\n/** Run the reaper every N ticks (at 2s interval, 30 ticks = ~60s). */\nconst REAPER_TICK_INTERVAL = 30;\n\n/**\n * Recover events orphaned in 'processing' state from a prior crash.\n * Call once at startup before the tick loop begins.\n */\nfunction recoverOrphanedEvents(\n  database: Database.Database | null,\n  logger: Logger,\n  tenantDbManager?: TenantDbManager,\n): void {\n  if (tenantDbManager) {\n    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n      const count = db.resetAllProcessingEvents(tenantDb);\n      if (count > 0) {\n        logger.warn({ projectId, count }, 'Reset orphaned processing events to pending at startup');\n      }\n    });\n  } else if (database) {\n    const count = db.resetAllProcessingEvents(database);\n    if (count > 0) {\n      logger.warn({ count }, 'Reset orphaned processing events to pending at startup');\n    }\n  }\n}\n\n/**\n * Periodic reaper: reset events stuck in 'processing' longer than the threshold.\n * Guards against edge cases during normal operation.\n */\nfunction reapStaleEvents(\n  database: Database.Database | null,\n  logger: Logger,\n  tenantDbManager?: TenantDbManager,\n): void {\n  if (tenantDbManager) {\n    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n      const count = db.resetStaleProcessingEvents(tenantDb, STALE_EVENT_REAPER_SECONDS);\n      if (count > 0) {\n        logger.warn({ projectId, count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n      }\n    });\n  } else if (database) {\n    const count = db.resetStaleProcessingEvents(database, STALE_EVENT_REAPER_SECONDS);\n    if (count > 0) {\n      logger.warn({ count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    }\n  }\n}\n\n/**\n * Start the event processing loop.\n * Supports both tenant-isolated DBs (via TenantDbManager) and legacy single DB.\n */\nexport function startEventProcessor(\n  database: Database.Database | null,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  interval: number = 2000,\n  tenantDbManager?: TenantDbManager,\n): NodeJS.Timeout {\n  // At startup, reset any events orphaned in 'processing' from a prior crash\n  recoverOrphanedEvents(database, logger, tenantDbManager);\n\n  logger.info({ intervalMs: interval, tenantIsolated: !!tenantDbManager }, 'Event processor started');\n\n  let tickCount = 0;\n\n  return setInterval(() => {\n    try {\n      tickCount++;\n\n      // Periodically reap stale processing events as a safety net\n      if (tickCount % REAPER_TICK_INTERVAL === 0) {\n        reapStaleEvents(database, logger, tenantDbManager);\n      }\n\n      if (tenantDbManager) {\n        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n          eventBusTick(tenantDb, dispatcher, logger, projectId);\n        });\n      } else if (database) {\n        eventBusTick(database, dispatcher, logger);\n      }\n    } catch (err) {\n      logger.error({ err }, 'Event processor tick failed');\n    }\n  }, interval);\n}\n\nfunction eventBusTick(\n  database: Database.Database,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  projectId?: string,\n): void {\n  const tickStartMs = performance.now();\n  let eventsFetched = 0;\n  let matchesFound = 0;\n  let delivered = 0;\n  let skipped = 0;\n  let failed = 0;\n\n  try {\n    const events = db.getPendingEvents(database, 50);\n    eventsFetched = events.length;\n    if (eventsFetched === 0) return;\n\n    // Collect dispatch requests to fire *after* the transaction commits so that\n    // the dispatcher never sees stale DB state.\n    const pendingDispatches: ExecRequest[] = [];\n\n    // Wrap all DB reads/writes in a single transaction to avoid per-statement\n    // fsync overhead (up to 100 individual commits per tick otherwise).\n    database.transaction(() => {\n      // Cache subscription lookups per unique (eventType, projectId) to avoid\n      // redundant DB queries when the same event type fires multiple times in a batch.\n      const subsCache = new Map<string, ReturnType<typeof db.getSubscriptionsByEventType>>();\n\n      // Phase 1: Mark events as processing, compute matches, collect unique persona IDs.\n      const eventMatches: Array<{ event: PersonaEvent; matches: EventMatch[] }> = [];\n      const allPersonaIds = new Set<string>();\n\n      for (const event of events) {\n        db.updateEventStatus(database, event.id, 'processing');\n\n        const cacheKey = `${event.eventType}\\0${event.projectId}`;\n        let subs = subsCache.get(cacheKey);\n        if (subs === undefined) {\n          subs = db.getSubscriptionsByEventType(database, event.eventType, event.projectId);\n          subsCache.set(cacheKey, subs);\n        }\n        const matches = matchEvent(event, subs);\n\n        if (matches.length === 0) {\n          db.updateEventStatus(database, event.id, 'skipped');\n          skipped++;\n          continue;\n        }\n\n        matchesFound += matches.length;\n        eventMatches.push({ event, matches });\n        for (const match of matches) {\n          allPersonaIds.add(match.personaId);\n        }\n      }\n\n      if (allPersonaIds.size === 0) return;\n\n      // Phase 2: Batch-fetch personas, tools, and running counts (2-3 queries total).\n      const personaIds = [...allPersonaIds];\n      const personaMap = db.getPersonasByIds(database, personaIds);\n      const toolsMap = db.getToolsForPersonaIds(database, personaIds);\n      const runningMap = db.countRunningExecutionsByPersonaIds(database, personaIds);\n\n      // Phase 3: Dispatch using Map lookups instead of per-match queries.\n      // Track persona slots claimed within this tick to prevent over-dispatch.\n      const claimed = new Map<string, number>();\n\n      for (const { event, matches } of eventMatches) {\n        let eventDelivered = 0;\n        let eventFailed = 0;\n        let throttled = 0;\n\n        for (const match of matches) {\n          try {\n            const persona = personaMap.get(match.personaId);\n            if (!persona) {\n              logger.warn({ personaId: match.personaId, eventId: event.id }, 'Persona not found for event match');\n              eventFailed++;\n              failed++;\n              continue;\n            }\n\n            // Check concurrency (in-tick claims + batched DB count)\n            const tickClaimed = claimed.get(persona.id) ?? 0;\n            const running = runningMap.get(persona.id) ?? 0;\n            if (running + tickClaimed >= persona.maxConcurrent) {\n              logger.info({ personaId: persona.id, running, tickClaimed, max: persona.maxConcurrent }, 'Persona at concurrency limit, deferring');\n              throttled++;\n              continue;\n            }\n\n            // Build input data from event payload\n            let inputData: Record<string, unknown> | undefined;\n            if (match.payload) {\n              try {\n                inputData = JSON.parse(match.payload);\n              } catch (parseError) {\n                logger.warn({ eventId: event.id, personaId: match.personaId, parseError }, 'Event payload JSON parse failed, using raw');\n                inputData = { raw: match.payload };\n              }\n            }\n\n            // Assemble prompt using batched persona + tools\n            const tools = toolsMap.get(persona.id) ?? [];\n            const prompt = assemblePrompt(persona, tools, inputData);\n\n            // Queue dispatch request (fired after transaction commits)\n            const request: ExecRequest = {\n              executionId: nanoid(),\n              personaId: persona.id,\n              prompt,\n              projectId: projectId ?? persona.projectId,\n              config: { timeoutMs: persona.timeoutMs },\n            };\n\n            pendingDispatches.push(request);\n            claimed.set(persona.id, (claimed.get(persona.id) ?? 0) + 1);\n            eventDelivered++;\n            delivered++;\n\n            logger.info({\n              eventId: event.id,\n              personaId: persona.id,\n              executionId: request.executionId,\n              eventType: event.eventType,\n              useCaseId: match.useCaseId,\n            }, 'Event dispatched to persona');\n          } catch (err) {\n            logger.error({ err, personaId: match.personaId, eventId: event.id }, 'Failed to dispatch event match');\n            eventFailed++;\n            failed++;\n          }\n        }\n\n        // Update event status\n        if (eventDelivered > 0 && eventFailed === 0 && throttled === 0) {\n          db.updateEventStatus(database, event.id, 'delivered');\n        } else if (eventDelivered > 0 && throttled > 0) {\n          // Some matches delivered but others were concurrency-limited.\n          // Defer with backoff so throttled matches get retried later.\n          db.deferEventForRetry(database, event.id, event.retryCount);\n          logger.info({ eventId: event.id, delivered: eventDelivered, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event partially delivered, deferring throttled matches for retry');\n        } else if (eventDelivered > 0 && eventFailed > 0) {\n          db.updateEventStatus(database, event.id, 'partial');\n        } else if (throttled > 0) {\n          // All (or remaining) matches were concurrency-limited — defer with backoff.\n          db.deferEventForRetry(database, event.id, event.retryCount);\n          logger.info({ eventId: event.id, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event deferred due to concurrency limits');\n        } else {\n          db.updateEventStatus(database, event.id, 'failed', 'All subscription matches failed');\n        }\n      }\n    })();\n\n    // Fire dispatches after the transaction has committed successfully\n    for (const request of pendingDispatches) {\n      dispatcher.submit(request);\n    }\n  } finally {\n    const tickDurationMs = performance.now() - tickStartMs;\n    logger.info({\n      tickDurationMs,\n      eventsFetched,\n      matchesFound,\n      delivered,\n      skipped,\n      failed\n    }, 'Event processor tick complete');\n  }\n}\n","numLines":275,"startLine":1,"totalLines":275}}}
