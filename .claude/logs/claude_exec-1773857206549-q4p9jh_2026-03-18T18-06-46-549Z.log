{\n    41→  handler: RouteHandler;\n    42→  needsDb?: boolean;\n    43→  adminOnly?: boolean;\n    44→}\n    45→\n    46→/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\n    47→function resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n    48→  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n    49→}\n    50→\n    51→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n    52→function parseRoute(pathname: string): ParsedRoute | null {\n    53→  if (!pathname.startsWith('/api/')) return null;\n    54→  const segments = pathname.slice(5).split('/').filter(Boolean);\n    55→  if (segments.length === 0) return null;\n    56→  return {\n    57→    resource: segments[0]!,\n    58→    id: segments[1],\n    59→    subResource: segments[2],\n    60→  };\n    61→}\n    62→\n    63→export function createHttpApi(\n    64→  auth: Auth,\n    65→  dispatcher: Dispatcher,\n    66→  pool: WorkerPool,\n    67→  tokenManager: TokenManager,\n    68→  oauth: OAuthManager,\n    69→  logger: Logger,\n    70→  database?: Database.Database,\n    71→  tenantDbManager?: TenantDbManager,\n    72→  tenantKeyManager?: TenantKeyManager,\n    73→  auditLog?: AuditLog,\n    74→  getEventProcessorHealth?: () => EventProcessorHealth,\n    75→  kafka?: KafkaClient,\n    76→  onEventPublished?: () => void,\n    77→): http.Server {\n    78→\n    79→  /** Wrap a mutation handler to emit an audit event on successful response. */\n    80→  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    81→    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n    82→      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n    83→      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n    84→        try {\n    85→          auditLog.record({\n    86→            action,\n    87→            tenantId: ctx.projectId || 'default',\n    88→            actor: ctx.userEmail || ctx.projectId,\n    89→            resourceType,\n    90→            resourceId: route?.id,\n    91→            ipAddress: req.socket.remoteAddress,\n    92→          } as AuditEntry);\n    93→        } catch { /* logged inside record() */ }\n    94→      }\n    95→    };\n    96→  }\n    97→\n    98→  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n    99→  const exactRoutes = new Map<string, RouteEntry>();\n   100→\n   101→  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n   102→  for (const [path, method] of [\n   103→    ['/api/oauth/authorize', 'POST'],\n   104→    ['/api/oauth/callback', 'POST'],\n   105→    ['/api/oauth/status', 'GET'],\n   106→    ['/api/oauth/refresh', 'POST'],\n   107→    ['/api/oauth/disconnect', 'DELETE'],\n   108→    ['/api/token', 'POST'],\n   109→  ] as const) {\n   110→    exactRoutes.set(`${method}:${path}`, {\n   111→      adminOnly: true,\n   112→      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   113→        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger);\n   114→      },\n   115→    });\n   116→  }\n   117→\n   118→  exactRoutes.set('GET:/api/status', {\n   119→    handler: (_req, res) => {\n   120→      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   121→    },\n   122→  });\n   123→\n   124→  exactRoutes.set('POST:/api/execute', {\n   125→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   126→      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n   127→    }, 'execution:submit', 'execution'),\n   128→  });\n   129→\n   130→  exactRoutes.set('POST:/api/gitlab/webhook', {\n   131→    needsDb: true,\n   132→    handler: withHttpAudit(async (req, res, _ctx, _route, _qs, tenantDb) => {\n   133→      const body = await readBody(req);\n   134→      let parsed: Record<string, unknown> = {};\n   135→      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   136→      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   137→      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   138→      const event = db.publishEvent(tenantDb!, {\n   139→        eventType: `gitlab_${objectKind}`,\n   140→        sourceType: 'gitlab',\n   141→        sourceId: projectPath ?? null,\n   142→        payload: body,\n   143→      });\n   144→      onEventPublished?.();\n   145→      json(res, 201, event);\n   146→    }, 'event:publish', 'event'),\n   147→  });\n   148→\n   149→  // Admin routes\n   150→  exactRoutes.set('GET:/api/admin/users', {\n   151→    adminOnly: true,\n   152→    handler: (_req, res) => {\n   153→      if (tenantDbManager) {\n   154→        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   155→      } else if (database) {\n   156→        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   157→      } else {\n   158→        json(res, 200, { projectIds: [] });\n   159→      }\n   160→    },\n   161→  });\n   162→\n   163→  exactRoutes.set('GET:/api/admin/personas', {\n   164→    adminOnly: true,\n   165→    handler: (_req, res) => {\n   166→      if (tenantDbManager) {\n   167→        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   168→        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   169→        json(res, 200, allPersonas);\n   170→      } else if (database) {\n   171→        json(res, 200, db.listPersonasSummary(database));\n   172→      } else {\n   173→        json(res, 200, []);\n   174→      }\n   175→    },\n   176→  });\n   177→\n   178→  exactRoutes.set('GET:/api/admin/executions', {\n   179→    adminOnly: true,\n   180→    handler: (_req, res, _ctx, _route, queryString) => {\n   181→      const params = new URLSearchParams(queryString || '');\n   182→      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   183→      if (tenantDbManager) {\n   184→        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   185→        tenantDbManager.forEachTenant((tDb) => {\n   186→          allExecs.push(...db.listExecutions(tDb, { limit }));\n   187→        });\n   188→        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   189→        json(res, 200, allExecs.slice(0, limit));\n   190→      } else if (database) {\n   191→        json(res, 200, db.listExecutions(database, {\n   192→          limit,\n   193→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   194→        }));\n   195→      } else {\n   196→        json(res, 200, []);\n   197→      }\n   198→    },\n   199→  });\n   200→\n   201→  exactRoutes.set('GET:/api/admin/audit', {\n   202→    adminOnly: true,\n   203→    handler: (_req, res, _ctx, _route, queryString) => {\n   204→      if (!auditLog) { json(res, 200, []); return; }\n   205→      const params = new URLSearchParams(queryString || '');\n   206→      json(res, 200, auditLog.query({\n   207→        tenantId: params.get('tenantId') ?? undefined,\n   208→        action: (params.get('action') ?? undefined) as AuditAction | undefined,\n   209→        since: params.get('since') ?? undefined,\n   210→        limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   211→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   212→      }));\n   213→    },\n   214→  });\n   215→\n   216→  // ── Resource route table (O(1) lookup by `METHOD:resource[:id][:sub]`) ──\n   217→  const resourceRoutes = new Map<string, RouteEntry>();\n   218→\n   219→  // --- Persona CRUD ---\n   220→  resourceRoutes.set(resourceKey('GET', 'personas', false), {\n   221→    needsDb: true,\n   222→    handler: (_req, res, _ctx, _route, _qs, tenantDb, scopedProjectId) => {\n   223→      json(res, 200, db.listPersonasSummary(tenantDb!, scopedProjectId));\n   224→    },\n   225→  });\n   226→\n   227→  resourceRoutes.set(resourceKey('POST', 'personas', false), {\n   228→    needsDb: true,\n   229→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   230→      const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   231→      const persona = createPersonaWithDefaults({\n   232→        ...body,\n   233→        projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   234→      });\n   235→      db.upsertPersona(tenantDb!, persona);\n   236→      try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: persona.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   237→      reqLogger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   238→      json(res, 201, persona);\n   239→    },\n   240→  });\n   241→\n   242→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'tools'), {\n   243→    needsDb: true,\n   244→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   245→      json(res, 200, db.getToolsForPersona(tenantDb!, route!.id!));\n   246→    },\n   247→  });\n   248→\n   249→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'tools'), {\n   250→    needsDb: true,\n   251→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   252→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   253→      if (!persona) return;\n   254→      const body = JSON.parse(await readBody(req)) as { toolId: string };\n   255→      db.linkTool(tenantDb!, route!.id!, body.toolId);\n   256→      try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { toolId: body.toolId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   257→      reqLogger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route!.id!, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   258→      json(res, 200, { linked: true });\n   259→    },\n   260→  });\n   261→\n   262→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'full'), {\n   263→    needsDb: true,\n   264→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   265→      const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb!, route!.id!, reqLogger), scopedProjectId, res);\n   266→      if (!hydrated) return;\n   267→      json(res, 200, hydrated);\n   268→    },\n   269→  });\n   270→\n   271→  resourceRoutes.set(resourceKey('GET', 'personas', true), {\n   272→    needsDb: true,\n   273→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId) => {\n   274→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   275→      if (!persona) return;\n   276→      json(res, 200, persona);\n   277→    },\n   278→  });\n   279→\n   280→  resourceRoutes.set(resourceKey('DELETE', 'personas', true), {\n   281→    needsDb: true,\n   282→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   283→      db.deletePersona(tenantDb!, route!.id!, scopedProjectId);\n   284→      try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   285→      reqLogger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   286→      json(res, 200, { deleted: true });\n   287→    },\n   288→  });\n   289→\n   290→  // --- Persona sub-resources: credentials ---\n   291→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'credentials'), {\n   292→    needsDb: true,\n   293→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   294→      const creds = db.listCredentialsForPersona(tenantDb!, route!.id!);\n   295→      try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   296→      json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   297→    },\n   298→  });\n   299→\n   300→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'credentials'), {\n   301→    needsDb: true,\n   302→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   303→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   304→      if (!persona) return;\n   305→      const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   306→      db.linkCredential(tenantDb!, route!.id!, body.credentialId);\n   307→      try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { credentialId: body.credentialId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   308→      reqLogger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route!.id!, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   309→      json(res, 200, { linked: true });\n   310→    },\n   311→  });\n   312→\n   313→  // --- Persona sub-resources: subscriptions ---\n   314→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'subscriptions'), {\n   315→    needsDb: true,\n   316→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   317→      json(res, 200, db.listSubscriptionsForPersona(tenantDb!, route!.id!));\n   318→    },\n   319→  });\n   320→\n   321→  // --- Tool Definitions ---\n   322→  resourceRoutes.set(resourceKey('POST', 'tool-definitions', false), {\n   323→    needsDb: true,\n   324→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   325→      const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   326→      const tool = createToolDefinitionWithDefaults(body);\n   327→      db.upsertToolDefinition(tenantDb!, tool);\n   328→      try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'toolDefinition', resourceId: tool.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   329→      reqLogger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   330→      json(res, 201, tool);\n   331→    },\n   332→  });\n   333→\n   334→  // --- Credentials ---\n   335→  resourceRoutes.set(resourceKey('POST', 'credentials', false), {\n   336→    needsDb: true,\n   337→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   338→      const body = JSON.parse(await readBody(req));\n   339→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   340→\n   341→      if (!body.plaintext || typeof body.plaintext !== 'string') {\n   342→        json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   343→        return;\n   344→      }\n   345→      if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   346→        json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   347→        return;\n   348→      }\n   349→      if (!tenantKeyManager) {\n   350→        json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   351→        return;\n   352→      }\n   353→\n   354→      delete body.encryptedData;\n   355→      delete body.iv;\n   356→      delete body.tag;\n   357→\n   358→      const tenantId = body.projectId || ctx.projectId || 'default';\n   359→      const key = await tenantKeyManager.getKey(tenantId);\n   360→      const encrypted = encrypt(body.plaintext, key);\n   361→      body.encryptedData = encrypted.encrypted;\n   362→      body.iv = encrypted.iv;\n   363→      body.tag = encrypted.tag;\n   364→      delete body.plaintext;\n   365→\n   366→      const cred = db.createCredential(tenantDb!, body);\n   367→      try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: cred.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   368→      reqLogger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   369→      json(res, 201, cred);\n   370→    },\n   371→  });\n   372→\n   373→  resourceRoutes.set(resourceKey('DELETE', 'credentials', true), {\n   374→    needsDb: true,\n   375→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   376→      const changes = db.deleteCredential(tenantDb!, route!.id!, scopedProjectId);\n   377→      if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   378→      try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   379→      reqLogger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   380→      json(res, 200, { deleted: true });\n   381→    },\n   382→  });\n   383→\n   384→  // --- Event Subscriptions ---\n   385→  resourceRoutes.set(resourceKey('POST', 'subscriptions', false), {\n   386→    needsDb: true,\n   387→    handler: async (req, res, ctx, _route, _qs, tenantDb) => {\n   388→      const body = JSON.parse(await readBody(req));\n   389→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   390→      const missing: string[] = [];\n   391→      if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   392→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   393→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   394→      const sub = db.createSubscription(tenantDb!, body);\n   395→      try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: sub.id, detail: { personaId: body.personaId, eventType: body.eventType }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   396→      json(res, 201, sub);\n   397→    },\n   398→  });\n   399→\n   400→  resourceRoutes.set(resourceKey('PUT', 'subscriptions', true), {\n   401→    needsDb: true,\n   402→    handler: async (req, res, ctx, route, _qs, tenantDb) => {\n   403→      const body = JSON.parse(await readBody(req));\n   404→      db.updateSubscription(tenantDb!, route!.id!, body);\n   405→      const updated = db.getSubscription(tenantDb!, route!.id!);\n   406→      try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   407→      json(res, 200, updated);\n   408→    },\n   409→  });\n   410→\n   411→  resourceRoutes.set(resourceKey('DELETE', 'subscriptions', true), {\n   412→    needsDb: true,\n   413→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   414→      db.deleteSubscription(tenantDb!, route!.id!);\n   415→      try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   416→      json(res, 200, { deleted: true });\n   417→    },\n   418→  });\n   419→\n   420→  // --- Triggers (delegated to triggerHttpHandlers) ---\n   421→  const triggerHandler: RouteHandler = async (req, res, ctx, route, _qs, tenantDb) => {\n   422→    await handleTriggerRoute(route!, req.method!, req, res, tenantDb!, ctx);\n   423→  };\n   424→  resourceRoutes.set(resourceKey('POST', 'triggers', false), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:create', 'trigger') });\n   425→  resourceRoutes.set(resourceKey('PUT', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:update', 'trigger') });\n   426→  resourceRoutes.set(resourceKey('DELETE', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:delete', 'trigger') });\n   427→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'triggers'), { needsDb: true, handler: triggerHandler });\n   428→\n   429→  // --- Events ---\n   430→  resourceRoutes.set(resourceKey('GET', 'events', false), {\n   431→    needsDb: true,\n   432→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   433→      const params = new URLSearchParams(queryString || '');\n   434→      const events = db.listEvents(tenantDb!, {\n   435→        eventType: params.get('eventType') ?? undefined,\n   436→        status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n   437→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   438→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   439→        projectId: scopedProjectId,\n   440→      });\n   441→      json(res, 200, events);\n   442→    },\n   443→  });\n   444→\n   445→  resourceRoutes.set(resourceKey('POST', 'events', false), {\n   446→    needsDb: true,\n   447→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, tenantDb) => {\n   448→      const body = JSON.parse(await readBody(req));\n   449→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   450→      const missing: string[] = [];\n   451→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   452→      if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   453→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   454→      const event = db.publishEvent(tenantDb!, body);\n   455→      onEventPublished?.();\n   456→      json(res, 201, event);\n   457→    }, 'event:publish', 'event'),\n   458→  });\n   459→\n   460→  resourceRoutes.set(resourceKey('PUT', 'events', true), {\n   461→    needsDb: true,\n   462→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   463→      const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n   464→      const updated = db.updateEventWithMetadata(tenantDb!, route!.id!, body.status, body.metadata);\n   465→      if (updated) {\n   466→        json(res, 200, updated);\n   467→      } else {\n   468→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   469→        res.end(JSON.stringify({ error: 'Event not found' }));\n   470→      }\n   471→    }, 'event:update', 'event'),\n   472→  });\n   473→\n   474→  // --- Webhooks ---\n   475→  resourceRoutes.set(resourceKey('POST', 'webhooks', true), {\n   476→    needsDb: true,\n   477→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   478→      const personaId = route!.id!;\n   479→      const body = await readBody(req);\n   480→      const event = db.publishEvent(tenantDb!, {\n   481→        eventType: 'webhook_received',\n   482→        sourceType: 'webhook',\n   483→        sourceId: personaId,\n   484→        targetPersonaId: personaId,\n   485→        payload: body,\n   486→      });\n   487→      onEventPublished?.();\n   488→      json(res, 201, event);\n   489→    }, 'webhook:receive', 'webhook'),\n   490→  });\n   491→\n   492→  // --- Executions ---\n   493→  resourceRoutes.set(resourceKey('GET', 'executions', false), {\n   494→    needsDb: true,\n   495→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   496→      const params = new URLSearchParams(queryString || '');\n   497→      const executions = db.listExecutions(tenantDb!, {\n   498→        personaId: params.get('personaId') ?? undefined,\n   499→        status: params.get('status') ?? undefined,\n   500→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   501→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   502→        projectId: scopedProjectId,\n   503→      });\n   504→      json(res, 200, executions);\n   505→    },\n   506→  });\n   507→\n   508→  resourceRoutes.set(resourceKey('POST', 'executions', true, 'cancel'), {\n   509→    handler: (_req, res, _ctx, route) => {\n   510→      handleCancelExecution(res, dispatcher, route!.id!);\n   511→    },\n   512→  });\n   513→\n   514→  resourceRoutes.set(resourceKey('GET', 'executions', true), {\n   515→    handler: (_req, res, _ctx, route, queryString) => {\n   516→      const params = new URLSearchParams(queryString || '');\n   517→      const offset = parseInt(params.get('offset') || '0', 10);\n   518→      handleGetExecution(res, dispatcher, route!.id!, offset);\n   519→    },\n   520→  });\n   521→\n   522→  // ── Request handler ──\n   523→  const server = http.createServer(async (req, res) => {\n   524→    // Request correlation ID\n   525→    const reqId = nanoid();\n   526→    const reqLogger = logger.child({ reqId });\n   527→    res.setHeader('X-Request-Id', reqId);\n   528→\n   529→    // Security headers\n   530→    res.setHeader('X-Content-Type-Options', 'nosniff');\n   531→\n   532→    // CORS headers\n   533→    const origin = req.headers.origin ?? '';\n   534→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n   535→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n   536→    if (isAdminRoute) {\n   537→      if (origin && origin === allowedOrigin) {\n   538→        res.setHeader('Access-Control-Allow-Origin', origin);\n   539→      }\n   540→    } else {\n   541→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n   542→    }\n   543→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n   544→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n   545→\n   546→    if (req.method === 'OPTIONS') {\n   547→      res.writeHead(204);\n   548→      res.end();\n   549→      return;\n   550→    }\n   551→\n   552→    const url = req.url || '/';\n   553→    const [pathname, queryString] = url.split('?');\n   554→    const route = parseRoute(pathname ?? '');\n   555→\n   556→    // Unauthenticated endpoint\n   557→    if (pathname === '/health' && req.method === 'GET') {\n   558→      await handleHealth(res, pool, dispatcher, oauth, getEventProcessorHealth, database, tenantDbManager, kafka);\n   559→      return;\n   560→    }\n   561→\n   562→    // Auth check\n   563→    const ctx = auth.validateAndExtractContext(req);\n   564→    if (!ctx) {\n   565→      res.writeHead(401, { 'Content-Type': 'application/json' });\n   566→      res.end(JSON.stringify({ error: 'Unauthorized', reqId }));\n   567→      return;\n   568→    }\n   569→\n   570→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n   571→\n   572→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n   573→      if (tenantDbManager && projectId) {\n   574→        return tenantDbManager.getTenantDb(projectId);\n   575→      }\n   576→      return database;\n   577→    };\n   578→    const tenantDb = resolveDatabase(ctx.projectId);\n   579→\n   580→    try {\n   581→      // O(1) exact-path lookup\n   582→      const exactEntry = exactRoutes.get(`${req.method}:${pathname}`);\n   583→      if (exactEntry) {\n   584→        if (exactEntry.adminOnly && requireAdmin(ctx, res)) return;\n   585→        if (exactEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   586→        await exactEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   587→        return;\n   588→      }\n   589→\n   590→      // O(1) resource-route lookup\n   591→      if (route) {\n   592→        const resKey = resourceKey(req.method!, route.resource, !!route.id, route.subResource);\n   593→        const resEntry = resourceRoutes.get(resKey);\n   594→        if (resEntry) {\n   595→          if (resEntry.adminOnly && requireAdmin(ctx, res)) return;\n   596→          if (resEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   597→          await resEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   598→          return;\n   599→        }\n   600→      }\n   601→\n   602→      // No matching route\n   603→      json(res, 404, { error: 'Not found', reqId });\n   604→    } catch (err) {\n   605→      if (err instanceof Error && err.message === 'Payload too large') {\n   606→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   607→        res.end(JSON.stringify({ error: 'Payload too large', reqId }));\n   608→        return;\n   609→      }\n   610→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   611→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   612→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists', reqId }));\n   613→        return;\n   614→      }\n   615→      reqLogger.error({ err, url }, 'HTTP handler error');\n   616→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   617→      res.end(JSON.stringify({ error: 'Internal server error', reqId }));\n   618→    }\n   619→  });\n   620→\n   621→  return server;\n   622→}\n   623→\n   624→/**\n   625→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   626→ * Returns the entity on success, or null after sending a 404 response.\n   627→ */\n   628→function withScopedEntity<T extends { projectId?: string | null }>(\n   629→  entity: T | undefined,\n   630→  scopedProjectId: string | undefined,\n   631→  res: http.ServerResponse,\n   632→): T | null {\n   633→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   634→    json(res, 404, { error: 'Not found' });\n   635→    return null;\n   636→  }\n   637→  return entity;\n   638→}\n   639→\n   640→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   641→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   642→  if (ctx.authType !== 'admin') {\n   643→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   644→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   645→    return true;\n   646→  }\n   647→  return false;\n   648→}\n   649→\n   650→// --- Existing handlers ---\n   651→\n   652→/** Heartbeat age (ms) beyond which a worker is considered stale. */\n   653→const STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n   654→\n   655→async function handleHealth(\n   656→  res: http.ServerResponse,\n   657→  pool: WorkerPool,\n   658→  dispatcher: Dispatcher,\n   659→  oauth: OAuthManager,\n   660→  getEventProcessorHealth?: () => EventProcessorHealth,\n   661→  database?: Database.Database,\n   662→  tenantDbManager?: TenantDbManager,\n   663→  kafka?: KafkaClient,\n   664→): Promise<void> {\n   665→  const issues: string[] = [];\n   666→\n   667→  const counts = pool.getWorkerCount();\n   668→  const workers = pool.getWorkers();\n   669→  const now = Date.now();\n   670→  const staleWorkers = workers\n   671→    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n   672→    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n   673→\n   674→  if (staleWorkers.length > 0) {\n   675→    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n   676→  }\n   677→\n   678→  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n   679→  if (database) {\n   680→    try {\n   681→      database.prepare('SELECT 1').get();\n   682→      dbHealth.status = 'ok';\n   683→    } catch {\n   684→      dbHealth.status = 'error';\n   685→      issues.push('database unreachable');\n   686→    }\n   687→  }\n   688→  if (tenantDbManager) {\n   689→    try {\n   690→      const tenantIds = tenantDbManager.listTenantIds();\n   691→      dbHealth.tenantCount = tenantIds.length;\n   692→      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n   693→    } catch {\n   694→      dbHealth.tenantCount = -1;\n   695→      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n   696→      issues.push('tenant DB listing failed');\n   697→    }\n   698→  }\n   699→\n   700→  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n   701→  if (kafka) {\n   702→    const kh = await kafka.checkHealth();\n   703→    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n   704→    if (kh.status === 'error') {\n   705→      issues.push(`kafka: ${kh.detail || 'error'}`);\n   706→    }\n   707→  }\n   708→\n   709→  const queueDepth = dispatcher.getQueueLength();\n   710→  const activeExecutions = dispatcher.getActiveExecutions().length;\n   711→\n   712→  let eventProcessorHealth: EventProcessorHealth | undefined;\n   713→  if (getEventProcessorHealth) {\n   714→    eventProcessorHealth = getEventProcessorHealth();\n   715→  }\n   716→\n   717→  let verdict: 'healthy' | 'degraded' | 'unhealthy';\n   718→  if (issues.some(i => i.includes('database unreachable') || i.includes('kafka: '))) {\n   719→    verdict = 'unhealthy';\n   720→  } else if (issues.length > 0) {\n   721→    verdict = 'degraded';\n   722→  } else {\n   723→    verdict = 'healthy';\n   724→  }\n   725→\n   726→  const body: Record<string, unknown> = {\n   727→    status: verdict,\n   728→    timestamp: Date.now(),\n   729→    dependencies: {\n   730→      database: dbHealth,\n   731→      kafka: kafkaHealth,\n   732→      workers: {\n   733→        ...counts,\n   734→        staleWorkers: staleWorkers.length > 0 ? staleWorkers : undefined,\n   735→      },\n   736→    },\n   737→    queue: {\n   738→      depth: queueDepth,\n   739→      activeExecutions,\n   740→    },\n   741→    hasSubscription: oauth.hasTokens(),\n   742→  };\n   743→\n   744→  if (eventProcessorHealth) {\n   745→    (body.dependencies as Record<string, unknown>).eventProcessor = eventProcessorHealth;\n   746→  }\n   747→\n   748→  if (issues.length > 0) {\n   749→    body.issues = issues;\n   750→  }\n   751→\n   752→  const httpStatus = verdict === 'unhealthy' ? 503 : 200;\n   753→  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n   754→  res.end(JSON.stringify(body));\n   755→}\n   756→\n   757→function handleStatus(\n   758→  res: http.ServerResponse,\n   759→  pool: WorkerPool,\n   760→  dispatcher: Dispatcher,\n   761→  tokenManager: TokenManager,\n   762→  oauth: OAuthManager,\n   763→): void {\n   764→  const oauthTokens = oauth.getTokens();\n   765→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   766→  res.end(JSON.stringify({\n   767→    workers: pool.getWorkers(),\n   768→    workerCounts: pool.getWorkerCount(),\n   769→    workerPoolMetrics: pool.getMetrics(),\n   770→    queueLength: dispatcher.getQueueLength(),\n   771→    activeExecutions: dispatcher.getActiveExecutions(),\n   772→    hasClaudeToken: tokenManager.hasToken(),\n   773→    oauth: {\n   774→      connected: oauth.hasTokens(),\n   775→      scopes: oauthTokens?.scopes || [],\n   776→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   777→    },\n   778→  }));\n   779→}\n   780→\n   781→async function handleExecute(\n   782→  req: http.IncomingMessage,\n   783→  res: http.ServerResponse,\n   784→  dispatcher: Dispatcher,\n   785→  logger: Logger,\n   786→  ctx?: RequestContext,\n   787→): Promise<void> {\n   788→  const body = await readBody(req);\n   789→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   790→\n   791→  try {\n   792→    parsed = JSON.parse(body);\n   793→  } catch {\n   794→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   795→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   796→    return;\n   797→  }\n   798→\n   799→  if (!parsed.prompt) {\n   800→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   801→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   802→    return;\n   803→  }\n   804→\n   805→  const request: ExecRequest = {\n   806→    executionId: nanoid(),\n   807→    personaId: parsed.personaId || 'manual',\n   808→    prompt: parsed.prompt,\n   809→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   810→    config: {\n   811→      timeoutMs: parsed.timeoutMs || 300_000,\n   812→    },\n   813→  };\n   814→\n   815→  dispatcher.submit(request);\n   816→\n   817→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   818→\n   819→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   820→  res.end(JSON.stringify({\n   821→    executionId: request.executionId,\n   822→    status: 'queued',\n   823→  }));\n   824→}\n   825→\n   826→function handleGetExecution(\n   827→  res: http.ServerResponse,\n   828→  dispatcher: Dispatcher,\n   829→  executionId: string,\n   830→  offset: number = 0,\n   831→): void {\n   832→  const exec = dispatcher.getExecution(executionId);\n   833→\n   834→  if (!exec) {\n   835→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   836→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   837→    return;\n   838→  }\n   839→\n   840→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   841→\n   842→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   843→  res.end(JSON.stringify({\n   844→    executionId,\n   845→    status: exec.status,\n   846→    outputLines: exec.output.length,\n   847→    output,\n   848→    durationMs: exec.durationMs,\n   849→    sessionId: exec.sessionId,\n   850→    totalCostUsd: exec.totalCostUsd,\n   851→    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n   852→  }));\n   853→}\n   854→\n   855→function handleCancelExecution(\n   856→  res: http.ServerResponse,\n   857→  dispatcher: Dispatcher,\n   858→  executionId: string,\n   859→): void {\n   860→  const cancelled = dispatcher.cancelExecution(executionId);\n   861→\n   862→  if (!cancelled) {\n   863→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   864→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   865→    return;\n   866→  }\n   867→\n   868→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   869→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   870→}\n   871→\n   872→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB\n   873→const MAX_QUERY_LIMIT = 500;\n   874→const MAX_QUERY_OFFSET = 100_000;\n   875→\n   876→/** Parse an integer query param and clamp it to safe bounds. */\n   877→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   878→  if (!value) return defaultValue;\n   879→  const parsed = parseInt(value, 10);\n   880→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   881→  return Math.min(parsed, max);\n   882→}\n   883→"}]},"parent_tool_use_id":null,"session_id":"6d8c3840-8f0a-47b3-9f7a-68415254a6c6","uuid":"cd4dbb2d-1bea-4bd5-9146-e7613da4fe72","timestamp":"2026-03-18T18:07:03.582Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog, AuditEntry, AuditAction } from './auditLog.js';\nimport type { EventProcessorHealth } from './eventProcessor.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\n// --- Route types ---\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\ntype RouteHandler = (\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  ctx: RequestContext,\n  route: ParsedRoute | null,\n  queryString: string | undefined,\n  tenantDb: Database.Database | undefined,\n  scopedProjectId: string | undefined,\n  reqLogger: Logger,\n) => Promise<void> | void;\n\ninterface RouteEntry {\n  handler: RouteHandler;\n  needsDb?: boolean;\n  adminOnly?: boolean;\n}\n\n/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\nfunction resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  kafka?: KafkaClient,\n  onEventPublished?: () => void,\n): http.Server {\n\n  /** Wrap a mutation handler to emit an audit event on successful response. */\n  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n        try {\n          auditLog.record({\n            action,\n            tenantId: ctx.projectId || 'default',\n            actor: ctx.userEmail || ctx.projectId,\n            resourceType,\n            resourceId: route?.id,\n            ipAddress: req.socket.remoteAddress,\n          } as AuditEntry);\n        } catch { /* logged inside record() */ }\n      }\n    };\n  }\n\n  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n  const exactRoutes = new Map<string, RouteEntry>();\n\n  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n  for (const [path, method] of [\n    ['/api/oauth/authorize', 'POST'],\n    ['/api/oauth/callback', 'POST'],\n    ['/api/oauth/status', 'GET'],\n    ['/api/oauth/refresh', 'POST'],\n    ['/api/oauth/disconnect', 'DELETE'],\n    ['/api/token', 'POST'],\n  ] as const) {\n    exactRoutes.set(`${method}:${path}`, {\n      adminOnly: true,\n      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger);\n      },\n    });\n  }\n\n  exactRoutes.set('GET:/api/status', {\n    handler: (_req, res) => {\n      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n    },\n  });\n\n  exactRoutes.set('POST:/api/execute', {\n    handler: withHttpAudit(async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n    }, 'execution:submit', 'execution'),\n  });\n\n  exactRoutes.set('POST:/api/gitlab/webhook', {\n    needsDb: true,\n    handler: withHttpAudit(async (req, res, _ctx, _route, _qs, tenantDb) => {\n      const body = await readBody(req);\n      let parsed: Record<string, unknown> = {};\n      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n      const event = db.publishEvent(tenantDb!, {\n        eventType: `gitlab_${objectKind}`,\n        sourceType: 'gitlab',\n        sourceId: projectPath ?? null,\n        payload: body,\n      });\n      onEventPublished?.();\n      json(res, 201, event);\n    }, 'event:publish', 'event'),\n  });\n\n  // Admin routes\n  exactRoutes.set('GET:/api/admin/users', {\n    adminOnly: true,\n    handler: (_req, res) => {\n      if (tenantDbManager) {\n        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n      } else if (database) {\n        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n      } else {\n        json(res, 200, { projectIds: [] });\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/personas', {\n    adminOnly: true,\n    handler: (_req, res) => {\n      if (tenantDbManager) {\n        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n        json(res, 200, allPersonas);\n      } else if (database) {\n        json(res, 200, db.listPersonasSummary(database));\n      } else {\n        json(res, 200, []);\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/executions', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      const params = new URLSearchParams(queryString || '');\n      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n      if (tenantDbManager) {\n        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n        tenantDbManager.forEachTenant((tDb) => {\n          allExecs.push(...db.listExecutions(tDb, { limit }));\n        });\n        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n        json(res, 200, allExecs.slice(0, limit));\n      } else if (database) {\n        json(res, 200, db.listExecutions(database, {\n          limit,\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        }));\n      } else {\n        json(res, 200, []);\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/audit', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      if (!auditLog) { json(res, 200, []); return; }\n      const params = new URLSearchParams(queryString || '');\n      json(res, 200, auditLog.query({\n        tenantId: params.get('tenantId') ?? undefined,\n        action: (params.get('action') ?? undefined) as AuditAction | undefined,\n        since: params.get('since') ?? undefined,\n        limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n      }));\n    },\n  });\n\n  // ── Resource route table (O(1) lookup by `METHOD:resource[:id][:sub]`) ──\n  const resourceRoutes = new Map<string, RouteEntry>();\n\n  // --- Persona CRUD ---\n  resourceRoutes.set(resourceKey('GET', 'personas', false), {\n    needsDb: true,\n    handler: (_req, res, _ctx, _route, _qs, tenantDb, scopedProjectId) => {\n      json(res, 200, db.listPersonasSummary(tenantDb!, scopedProjectId));\n    },\n  });\n\n  resourceRoutes.set(resourceKey('POST', 'personas', false), {\n    needsDb: true,\n    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n      const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n      const persona = createPersonaWithDefaults({\n        ...body,\n        projectIdOverride: ctx.authTyp