te worker token from Authorization header (timing-safe comparison)\n   137→      const authHeader = req.headers.authorization;\n   138→      const token = authHeader?.startsWith('Bearer ') ? authHeader.slice(7) : null;\n   139→      if (!token || !timingSafeTokenEqual(token, this.expectedWorkerToken)) {\n   140→        this.logger.warn({ remoteAddr: req.socket.remoteAddress }, 'Worker rejected: invalid token');\n   141→        ws.close(1008, 'Invalid worker token');\n   142→        return;\n   143→      }\n   144→\n   145→      this.handleConnection(ws);\n   146→    });\n   147→\n   148→    this.wss.on('error', (err) => {\n   149→      this.logger.error({ err }, 'WebSocket server error');\n   150→    });\n   151→  }\n   152→\n   153→  private handleConnection(ws: WebSocket): void {\n   154→    let workerId: string | null = null;\n   155→\n   156→    const connectionTimeout = setTimeout(() => {\n   157→      if (!workerId) {\n   158→        this.logger.warn('Worker did not send hello within timeout, closing');\n   159→        ws.close(1008, 'Hello timeout');\n   160→      }\n   161→    }, 10_000);\n   162→\n   163→    ws.on('message', (raw: Buffer) => {\n   164→      const msg = parseWorkerMessage(raw.toString());\n   165→      if (!msg) {\n   166→        this.metrics.parseFailures++;\n   167→        this.logger.warn({ parseFailures: this.metrics.parseFailures }, 'Invalid message from worker');\n   168→        return;\n   169→      }\n   170→\n   171→      if (msg.type === 'hello') {\n   172→        clearTimeout(connectionTimeout);\n   173→        workerId = msg.workerId;\n   174→        this.registerWorker(workerId, ws, msg.version, msg.capabilities, msg.imageDigest, msg.claudeCliVersion);\n   175→        return;\n   176→      }\n   177→\n   178→      if (!workerId) {\n   179→        this.logger.warn({ type: msg.type }, 'Message before hello');\n   180→        return;\n   181→      }\n   182→\n   183→      this.handleWorkerMessage(workerId, msg);\n   184→    });\n  