[2026-03-18T18:33:33.535Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K4MDBEBp1nsNN4xFbgnMLa","type":"tool_result","content":"     1Ôćĺimport { EventEmitter } from 'node:events';\n     2Ôćĺimport { deriveTenantKeyAsync } from '@dac-cloud/shared';\n     3Ôćĺimport type { Logger } from 'pino';\n     4Ôćĺ\n     5Ôćĺinterface CachedKey {\n     6Ôćĺ  key: Buffer;\n     7Ôćĺ  createdAt: number;\n     8Ôćĺ}\n     9Ôćĺ\n    10Ôćĺexport interface TenantKeyMetrics {\n    11Ôćĺ  hits: number;\n    12Ôćĺ  misses: number;\n    13Ôćĺ  cacheSize: number;\n    14Ôćĺ  derivations: number;\n    15Ôćĺ  avgDerivationMs: number;\n    16Ôćĺ}\n    17Ôćĺ\n    18Ôćĺconst DEFAULT_TTL_MS = 30 * 60 * 1000; // 30 minutes\n    19Ôćĺconst DEFAULT_RENEW_AHEAD_MS = 5 * 60 * 1000; // renew 5 min before expiry\n    20Ôćĺ\n    21Ôćĺexport type TenantIdSource = () => string[];\n    22Ôćĺ\n    23Ôćĺexport interface KeyDerivedEvent { tenantId: string; timestamp: number }\n    24Ôćĺexport interface TenantKeyEvents {\n    25Ôćĺ  'key:derived': [KeyDerivedEvent];\n    26Ôćĺ}\n    27Ôćĺ\n    28Ôćĺ/**\n    29Ôćĺ * Manages per-tenant encryption keys with caching.\n    30Ôćĺ *\n    31Ôćĺ * Keys are derived from the master secret + tenant ID via PBKDF2 (shared/crypto.ts).\n    32Ôćĺ * A single maintenance timer handles both renewal and eviction in a fixed order\n    33Ôćĺ * (renew first, then evict) to prevent races between independent timers.\n    34Ôćĺ *\n    35Ôćĺ * Emits `key:derived` so audit concerns can subscribe externally.\n    36Ôćĺ */\n    37Ôćĺexport class TenantKeyManager extends EventEmitter<TenantKeyEvents> {\n    38Ôćĺ  private cache = new Map<string, CachedKey>();\n    39Ôćĺ  private maintenanceTimer: NodeJS.Timeout;\n    40Ôćĺ  private tenantIdSource: TenantIdSource | null = null;\n    41Ôćĺ  private _hits = 0;\n    42Ôćĺ  private _misses = 0;\n    43Ôćĺ  private _derivations = 0;\n    44Ôćĺ  private _totalDerivationMs = 0;\n    45Ôćĺ\n    46Ôćĺ  constructor(\n    47Ôćĺ    private masterSecret: string,\n    48Ôćĺ    private logger: Logger,\n    49Ôćĺ    private ttlMs: number = DEFAULT_TTL_MS,\n    50Ôćĺ    private renewAheadMs: number = DEFAULT_RENEW_AHEAD_MS,\n    51Ôćĺ  ) {\n    52Ôćĺ    super();\n    53Ôćĺ    // Single timer for cache maintenance: renewal before eviction\n    54Ôćĺ    this.maintenanceTimer = setInterval(() => this.maintainCache(), 60_000);\n    55Ôćĺ  }\n    56Ôćĺ\n    57Ôćĺ  /**\n    58Ôćĺ   * Set a source function that returns all known tenant IDs.\n    59Ôćĺ   * Once set, pre-warms the cache. Proactive renewal runs automatically\n    60Ôćĺ   * via the unified maintenance timer when a tenant source is available.\n    61Ôćĺ   */\n    62Ôćĺ  async setTenantIdSource(source: TenantIdSource): Promise<void> {\n    63Ôćĺ    this.tenantIdSource = source;\n    64Ôćĺ    await this.warmAll();\n    65Ôćĺ  }\n    66Ôćĺ\n    67Ôćĺ  /**\n    68Ôćĺ   * Pre-derive and cache keys for all known tenants.\n    69Ôćĺ   */\n    70Ôćĺ  async warmAll(): Promise<void> {\n    71Ôćĺ    if (!this.tenantIdSource) return;\n    72Ôćĺ\n    73Ôćĺ    const tenantIds = this.tenantIdSource();\n    74Ôćĺ    let warmed = 0;\n    75Ôćĺ    const promises: Promise<void>[] = [];\n    76Ôćĺ    for (const tenantId of tenantIds) {\n    77Ôćĺ      const cached = this.cache.get(tenantId);\n    78Ôćĺ      if (!cached || Date.now() - cached.createdAt >= this.ttlMs) {\n    79Ôćĺ        promises.push(this.deriveAndCache(tenantId).then(() => { warmed++; }));\n    80Ôćĺ      }\n    81Ôćĺ    }\n    82Ôćĺ    await Promise.all(promises);\n    83Ôćĺ    if (warmed > 0) {\n    84Ôćĺ      this.logger.info({ warmed, total: tenantIds.length }, 'Pre-warmed tenant key cache');\n    85Ôćĺ    }\n    86Ôćĺ  }\n    87Ôćĺ\n    88Ôćĺ  /**\n    89Ôćĺ   * Eagerly warm the key cache for a single tenant (e.g., on tenant creation).\n    90Ôćĺ   */\n    91Ôćĺ  async warmTenant(tenantId: string): Promise<void> {\n    92Ôćĺ    await this.deriveAndCache(tenantId);\n    93