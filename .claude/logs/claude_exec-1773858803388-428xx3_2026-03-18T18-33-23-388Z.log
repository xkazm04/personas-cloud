[2026-03-18T18:33:33.332Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015udGAHyKddPgaP1Pad55fU","type":"tool_result","content":"     1Ôćĺimport crypto from 'node:crypto';\n     2Ôćĺimport Database from 'better-sqlite3';\n     3Ôćĺimport type { Logger } from 'pino';\n     4Ôćĺ\n     5Ôćĺ/** SHA-256 hash chain genesis value (64 hex zeros). */\n     6Ôćĺconst GENESIS_HASH = '0'.repeat(64);\n     7Ôćĺ\n     8Ôćĺ/**\n     9Ôćĺ * Compute a chain hash: SHA-256(previousHash + deterministic JSON of entry fields).\n    10Ôćĺ * Each entry's hash commits to the entire chain history before it.\n    11Ôćĺ */\n    12Ôćĺfunction computeChainHash(prevHash: string, entry: BufferedEntry): string {\n    13Ôćĺ  const payload = prevHash + JSON.stringify([\n    14Ôćĺ    entry.timestamp,\n    15Ôćĺ    entry.action,\n    16Ôćĺ    entry.tenantId,\n    17Ôćĺ    entry.actor,\n    18Ôćĺ    entry.resourceType,\n    19Ôćĺ    entry.resourceId,\n    20Ôćĺ    entry.detail,\n    21Ôćĺ    entry.ipAddress,\n    22Ôćĺ  ]);\n    23Ôćĺ  return crypto.createHash('sha256').update(payload).digest('hex');\n    24Ôćĺ}\n    25Ôćĺ\n    26Ôćĺconst AUDIT_SCHEMA = `\n    27ÔćĺCREATE TABLE IF NOT EXISTS audit_events (\n    28Ôćĺ  id INTEGER PRIMARY KEY AUTOINCREMENT,\n    29Ôćĺ  timestamp TEXT NOT NULL,\n    30Ôćĺ  action TEXT NOT NULL,\n    31Ôćĺ  tenant_id TEXT,\n    32Ôćĺ  actor TEXT,\n    33Ôćĺ  resource_type TEXT,\n    34Ôćĺ  resource_id TEXT,\n    35Ôćĺ  detail TEXT,\n    36Ôćĺ  ip_address TEXT,\n    37Ôćĺ  prev_hash TEXT\n    38Ôćĺ);\n    39ÔćĺCREATE INDEX IF NOT EXISTS idx_audit_ts ON audit_events(timestamp);\n    40ÔćĺCREATE INDEX IF NOT EXISTS idx_audit_tenant_action_ts ON audit_events(tenant_id, action, timestamp);\n    41ÔćĺDROP INDEX IF EXISTS idx_audit_tenant_ts;\n    42ÔćĺDROP INDEX IF EXISTS idx_audit_action;\n    43Ôćĺ`;\n    44Ôćĺ\n    45Ôćĺ/** Thrown when an audit event fails to persist ÔÇö signals an audit trail gap. */\n    46Ôćĺexport class AuditWriteError extends Error {\n    47Ôćĺ  constructor(\n    48Ôćĺ    public readonly entry: AuditEntry,\n    49Ôćĺ    cause: unknown,\n    50Ôćĺ  ) {\n    51Ôćĺ    super(`Audit write failed for action \"${entry.action}\"`);\n    52Ôćĺ    this.name = 'AuditWriteError';\n    53Ôćĺ    this.cause = cause;\n    54Ôćĺ  }\n    55Ôćĺ}\n    56Ôćĺ\n    57Ôćĺ// ---------------------------------------------------------------------------\n    58Ôćĺ// Discriminated-union audit entries ÔÇö each action carries its own typed payload\n    59Ôćĺ// ---------------------------------------------------------------------------\n    60Ôćĺ\n    61Ôćĺ/** Fields common to every audit entry. */\n    62Ôćĺinterface AuditEntryBase {\n    63Ôćĺ  tenantId?: string;\n    64Ôćĺ  actor?: string;\n    65Ôćĺ  ipAddress?: string;\n    66Ôćĺ}\n    67Ôćĺ\n    68Ôćĺ// --- Key management ---\n    69Ôćĺinterface KeyEncryptEntry extends AuditEntryBase {\n    70Ôćĺ  action: 'key:encrypt';\n    71Ôćĺ  resourceType: 'credential';\n    72Ôćĺ  resourceId: string;\n    73Ôćĺ}\n    74Ôćĺ\n    75Ôćĺinterface KeyDecryptEntry extends AuditEntryBase {\n    76Ôćĺ  action: 'key:decrypt';\n    77Ôćĺ  resourceType: 'credential';\n    78Ôćĺ  resourceId: string;\n    79Ôćĺ}\n    80Ôćĺ\n    81Ôćĺinterface KeyDecryptFailedEntry extends AuditEntryBase {\n    82Ôćĺ  action: 'key:decrypt_failed';\n    83Ôćĺ  resourceType: 'credential';\n    84Ôćĺ  resourceId: string;\n    85Ôćĺ  detail: { reason: string };\n    86Ôćĺ}\n    87Ôćĺ\n    88Ôćĺinterface KeyDeleteEntry extends AuditEntryBase {\n    89Ôćĺ  action: 'key:delete';\n    90Ôćĺ  resourceType: 'credential';\n    91Ôćĺ  resourceId: string;\n    92Ôćĺ}\n    93Ôćĺ\n    94Ôćĺinterface KeyAccessEntry extends AuditEntryBase {\n    95Ôćĺ  action: 'key:access';\n    96Ôćĺ  resourceType: 'credential';\n    97Ôćĺ  resourceId: string;\n    98Ôćĺ}\n    99Ôćĺ\n   100Ôćĺinterface KeyDeriveEntry extends AuditEntryBase {\n   101Ôćĺ  action: 'key:derive';\n   102Ôćĺ}\n   103Ôćĺ\n   104Ôćĺ// --- Persona management ---\n   105Ôćĺinterface PersonaCreateEntry extends AuditEntryBase {\n   106Ôćĺ  action: 'persona:create';\n   107Ôćĺ  resourceType: 'persona';\n   108Ôćĺ  resourceId: string;\n   109Ôćĺ}\n   110Ôćĺ\n   111Ôćĺinterface PersonaDeleteEntry extends AuditEntryBase {\n   112Ôćĺ  action: 'persona:delete';\n   113Ôćĺ  resourceType: 'persona';\n   114Ôćĺ  resourceId: string;\n   115Ôćĺ}\n   116Ôćĺ\n   117Ôćĺ// --- Tool management ---\n   118Ôćĺinterface ToolLinkEntry extends AuditEntryBase {\n   119Ôćĺ  action: 'tool:link';\n   120Ôćĺ  resourceType: 'persona';\n   121Ôćĺ  resourceId: string;\n   122Ôćĺ  detail: { toolId: string };\n   123Ôćĺ}\n   124Ôćĺ\n   125Ôćĺinterface ToolDefinitionCreateEntry extends AuditEntryBase {\n   126Ôćĺ  action: 'tool-definition:create';\n   127Ôćĺ  resourceType: 'toolDefinition';\n   128Ôćĺ  resourceId: string;\n   129Ôćĺ}\n   130Ôćĺ\n   131Ôćĺ// --- Credential linking ---\n   132Ôćĺinterface CredentialLinkEntry extends AuditEntryBase {\n   133Ôćĺ  action: 'credential:link';\n   134Ôćĺ  resourceType: 'persona';\n   135Ôćĺ  resourceId: string;\n   136Ôćĺ  detail: { credentialId: string };\n   137Ôćĺ}\n   138Ôćĺ\n   139Ôćĺ// --- Subscriptions ---\n   140Ôćĺinterface SubscriptionCreateEntry extends AuditEntryBase {\n   141Ôćĺ  action: 'subscription:create';\n   142Ôćĺ  resourceType: 'subscription';\n   143Ôćĺ  resourceId: string;\n   144Ôćĺ  detail: { personaId: string; eventType: string };\n   145Ôćĺ}\n   146Ôćĺ\n   147Ôćĺinterface SubscriptionUpdateEntry extends AuditEntryBase {\n   148Ôćĺ  action: 'subscription:update';\n   149Ôćĺ  resourceType: 'subscription';\n   150Ôćĺ  resourceId: string;\n   151Ôćĺ}\n   152Ôćĺ\n   153Ôćĺinterface SubscriptionDeleteEntry extends AuditEntryBase {\n   154Ôćĺ  action: 'subscription:delete';\n   155Ôćĺ  resourceType: 'subscription';\n   156Ôćĺ  resourceId: string;\n   157Ôćĺ}\n   158Ôćĺ\n   159Ôćĺ// --- Worker pool ---\n   160Ôćĺinterface WorkerConnectedEntry extends AuditEntryBase {\n   161Ôćĺ  action: 'worker:connected';\n   162Ôćĺ  detail: { workerId: string };\n   163Ôćĺ}\n   164Ôćĺ\n   165Ôćĺinterface WorkerDisconnectedEntry extends AuditEntryBase {\n   166Ôćĺ  action: 'worker:disconnected';\n   167Ôćĺ  detail: { workerId: string };\n   168Ôćĺ  resourceId?: string;\n   169Ôćĺ}\n   170Ôćĺ\n   171Ôćĺ// --- Triggers ---\n   172Ôćĺinterface TriggerCreateEntry extends AuditEntryBase {\n   173Ôćĺ  action: 'trigger:create';\n   174Ôćĺ  resourceType: 'trigger';\n   175Ôćĺ  resourceId?: string;\n   176Ôćĺ}\n   177Ôćĺ\n   178Ôćĺinterface TriggerUpdateEntry extends AuditEntryBase {\n   179Ôćĺ  action: 'trigger:update';\n   180Ôćĺ  resourceType: 'trigger';\n   181Ôćĺ  resourceId: string;\n   182Ôćĺ}\n   183Ôćĺ\n   184Ôćĺinterface TriggerDeleteEntry extends AuditEntryBase {\n   185Ôćĺ  action: 'trigger:delete';\n   186Ôćĺ  resourceType: 'trigger';\n   187Ôćĺ  resourceId: string;\n   188Ôćĺ}\n   189Ôćĺ\n   190Ôćĺ// --- Events ---\n   191Ôćĺinterface EventPublishEntry extends AuditEntryBase {\n   192Ôćĺ  action: 'event:publish';\n   193Ôćĺ  resourceType: 'event';\n   194Ôćĺ  resourceId?: string;\n   195Ôćĺ}\n   196Ôćĺ\n   197Ôćĺinterface EventUpdateEntry extends AuditEntryBase {\n   198Ôćĺ  action: 'event:update';\n   199Ôćĺ  resourceType: 'event';\n   200Ôćĺ  resourceId: string;\n   201Ôćĺ}\n   202Ôćĺ\n   203Ôćĺ// --- Executions ---\n   204Ôćĺinterface ExecutionSubmitEntry extends AuditEntryBase {\n   205Ôćĺ  action: 'execution:submit';\n   206Ôćĺ  resourceType: 'execution';\n   207Ôćĺ  resourceId?: string;\n   208Ôćĺ}\n   209Ôćĺ\n   210Ôćĺ// --- Webhooks ---\n   211Ôćĺinterface WebhookReceiveEntry extends AuditEntryBase {\n   212Ôćĺ  action: 'webhook:receive';\n   213Ôćĺ  resourceType: 'webhook';\n   214Ôćĺ  resourceId: string;\n   215Ôćĺ}\n   216Ôćĺ\n   217Ôćĺ/** Discriminated union of all audit event types. */\n   218Ôćĺexport type AuditEntry =\n   219Ôćĺ  | KeyEncryptEntry\n   220Ôćĺ  | KeyDecryptEntry\n   221Ôćĺ  | KeyDecryptFailedEntry\n   222Ôćĺ  | KeyDeleteEntry\n   223Ôćĺ  | KeyAccessEntry\n   224Ôćĺ  | KeyDeriveEntry\n   225Ôćĺ  | PersonaCreateEntry\n   226Ôćĺ  | PersonaDeleteEntry\n   227Ôćĺ  | ToolLinkEntry\n   228Ôćĺ  | ToolDefinitionCreateEntry\n   229Ôćĺ  | CredentialLinkEntry\n   230Ôćĺ  | SubscriptionCreateEntry\n   231Ôćĺ  | SubscriptionUpdateEntry\n   232Ôćĺ  | SubscriptionDeleteEntry\n   233Ôćĺ  | WorkerConnectedEntry\n   234Ôćĺ  | WorkerDisconnectedEntry\n   235Ôćĺ  | TriggerCreateEntry\n   236Ôćĺ  | TriggerUpdateEntry\n   237Ôćĺ  | TriggerDeleteEntry\n   238Ôćĺ  | EventPublishEntry\n   239Ôćĺ  | EventUpdateEntry\n   240Ôćĺ  | ExecutionSubmitEntry\n   241Ôćĺ  | WebhookReceiveEntry;\n   242Ôćĺ\n   243Ôćĺ/** String-literal union of all valid audit actions. */\n   244Ôćĺexport type AuditAction = AuditEntry['action'];\n   245Ôćĺ\n   246Ôćĺ/** Row shape returned by audit_events queries. */\n   247Ôćĺexport interface AuditEvent {\n   248Ôćĺ  id: number;\n   249Ôćĺ  timestamp: string;\n   250Ôćĺ  action: string;\n   251Ôćĺ  tenant_id: string | null;\n   252Ôćĺ  actor: string | null;\n   253Ôćĺ  resource_type: string | null;\n   254Ôćĺ  resource_id: string | null;\n   255Ôćĺ  detail: string | null;\n   256Ôćĺ  ip_address: string | null;\n   257Ôćĺ  prev_hash: string | null;\n   258Ôćĺ}\n   259Ôćĺ\n   260Ôćĺ/** Result of verifying the audit hash chain. */\n   261Ôćĺexport interface ChainVerifyResult {\n   262Ôćĺ  valid: boolean;\n   263Ôćĺ  verifiedCount: number;\n   264Ôćĺ  brokenAtId?: number;\n   265Ôćĺ}\n   266Ôćĺ\n   267Ôćĺ/** Max entries buffered before an automatic flush. */\n   268Ôćĺconst BUFFER_FLUSH_SIZE = 50;\n   269Ôćĺ/** Interval (ms) between timer-based flushes. */\n   270Ôćĺconst BUFFER_FLUSH_INTERVAL_MS = 100;\n   271Ôćĺ\n   272Ôćĺinterface BufferedEntry {\n   273Ôćĺ  timestamp: string;\n   274Ôćĺ  action: string;\n   275Ôćĺ  tenantId: string | null;\n   276Ôćĺ  actor: string | null;\n   277Ôćĺ  resourceType: string | null;\n   278Ôćĺ  resourceId: string | null;\n   279Ôćĺ  detail: string | null;\n   280Ôćĺ  ipAddress: string | null;\n   281Ôćĺ}\n   282Ôćĺ\n   283Ôćĺexport class AuditLog {\n   284Ôćĺ  private db: Database.Database;\n   285Ôćĺ  private insertStmt: Database.Statement;\n   286Ôćĺ  private queryStmtCache = new Map<string, Database.Statement>();\n   287Ôćĺ  private buffer: BufferedEntry[] = [];\n   288Ôćĺ  private flushTimer: NodeJS.Timeout | null = null;\n   289Ôćĺ  private batchInsert: (entries: BufferedEntry[], hashes: string[]) => void;\n   290Ôćĺ  private lastHash: string;\n   291Ôćĺ\n   292Ôćĺ  constructor(\n   293Ôćĺ    dbPath: string,\n   294Ôćĺ    private logger: Logger,\n   295Ôćĺ  ) {\n   296Ôćĺ    this.db = new Database(dbPath);\n   297Ôćĺ    this.db.pragma('journal_mode = WAL');\n   298Ôćĺ    this.db.exec(AUDIT_SCHEMA);\n   299Ôćĺ\n   300Ôćĺ    // Migration: add prev_hash column to existing databases that lack it\n   301Ôćĺ    const cols = this.db.pragma('table_info(audit_events)') as { name: string }[];\n   302Ôćĺ    if (!cols.some((c) => c.name === 'prev_hash')) {\n   303Ôćĺ      this.db.exec('ALTER TABLE audit_events ADD COLUMN prev_hash TEXT');\n   304Ôćĺ    }\n   305Ôćĺ\n   306Ôćĺ    this.insertStmt = this.db.prepare(\n   307Ôćĺ      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address, prev_hash) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',\n   308Ôćĺ    );\n   309Ôćĺ\n   310Ôćĺ    // Initialize chain from last stored hash (or genesis for empty / pre-chain DBs)\n   311Ôćĺ    const lastRow = this.db.prepare(\n   312Ôćĺ      'SELECT prev_hash FROM audit_events WHERE prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n   313Ôćĺ    ).get() as { prev_hash: string } | undefined;\n   314Ôćĺ    this.lastHash = lastRow?.prev_hash ?? GENESIS_HASH;\n   315Ôćĺ\n   316Ôćĺ    // Wrap N inserts in a single transaction ÔÇö one fsync instead of N\n   317Ôćĺ    const stmt = this.insertStmt;\n   318Ôćĺ    this.batchInsert = this.db.transaction((entries: BufferedEntry[], hashes: string[]) => {\n   319Ôćĺ      for (let i = 0; i < entries.length; i++) {\n   320Ôćĺ        const e = entries[i];\n   321Ôćĺ        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress, hashes[i]);\n   322Ôćĺ      }\n   323Ôćĺ    });\n   324Ôćĺ\n   325Ôćĺ    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n   326Ôćĺ\n   327Ôćĺ    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled, hash-chain active)');\n   328Ôćĺ  }\n   329Ôćĺ\n   330Ôćĺ  /** Expose the underlying database for use by RetentionPolicy. */\n   331Ôćĺ  getDb(): Database.Database {\n   332Ôćĺ    return this.db;\n   333Ôćĺ  }\n   334Ôćĺ\n   335Ôćĺ  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n   336Ôćĺ  countEvents(before?: string): number {\n   337Ôćĺ    const stmt = before\n   338Ôćĺ      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n   339Ôćĺ      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n   340Ôćĺ    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n   341Ôćĺ    return row.cnt;\n   342Ôćĺ  }\n   343Ôćĺ\n   344Ôćĺ  /**\n   345Ôćĺ   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   346Ôćĺ   * yielding the event loop between batches so concurrent DB operations\n   347Ôćĺ   * are not starved during large purges.\n   348Ôćĺ   */\n   349Ôćĺ  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n   350Ôćĺ    const deleteChunk = this.db.prepare(\n   351Ôćĺ      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n   352Ôćĺ    );\n   353Ôćĺ    let totalDeleted = 0;\n   354Ôćĺ    while (true) {\n   355Ôćĺ      const result = deleteChunk.run(cutoff, chunkSize);\n   356Ôćĺ      totalDeleted += result.changes;\n   357Ôćĺ      if (result.changes < chunkSize) break;\n   358Ôćĺ      await new Promise<void>((resolve) => setImmediate(resolve));\n   359Ôćĺ    }\n   360Ôćĺ    return totalDeleted;\n   361Ôćĺ  }\n   362Ôćĺ\n   363Ôćĺ  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n   364Ôćĺ  record(entry: AuditEntry): void {\n   365Ôćĺ    this.buffer.push({\n   366Ôćĺ      timestamp: new Date().toISOString(),\n   367Ôćĺ      action: entry.action,\n   368Ôćĺ      tenantId: entry.tenantId ?? null,\n   369Ôćĺ      actor: entry.actor ?? null,\n   370Ôćĺ      resourceType: 'resourceType' in entry ? entry.resourceType : null,\n   371Ôćĺ      resourceId: 'resourceId' in entry ? (entry.resourceId ?? null) : null,\n   372Ôćĺ      detail: 'detail' in entry ? JSON.stringify(entry.detail) : null,\n   373Ôćĺ      ipAddress: entry.ipAddress ?? null,\n   374Ôćĺ    });\n   375Ôćĺ    if (this.buffer.length >= BUFFER_FLUSH_SIZE) {\n   376Ôćĺ      this.flush();\n   377Ôćĺ    }\n   378Ôćĺ  }\n   379Ôćĺ\n   380Ôćĺ  /** Flush buffered entries to SQLite in a single transaction, computing chain hashes. */\n   381Ôćĺ  flush(): void {\n   382Ôćĺ    if (this.buffer.length === 0) return;\n   383Ôćĺ    const batch = this.buffer;\n   384Ôćĺ    this.buffer = [];\n   385Ôćĺ\n   386Ôćĺ    // Compute chain hashes for the batch\n   387Ôćĺ    const hashes: string[] = [];\n   388Ôćĺ    let prevHash = this.lastHash;\n   389Ôćĺ    for (const entry of batch) {\n   390Ôćĺ      prevHash = computeChainHash(prevHash, entry);\n   391Ôćĺ      hashes.push(prevHash);\n   392Ôćĺ    }\n   393Ôćĺ\n   394Ôćĺ    try {\n   395Ôćĺ      this.batchInsert(batch, hashes);\n   396Ôćĺ      this.lastHash = prevHash;\n   397Ôćĺ    } catch (err) {\n   398Ôćĺ      this.logger.error({ err, count: batch.length }, 'Audit batch write failed ÔÇö audit trail gap');\n   399Ôćĺ    }\n   400Ôćĺ  }\n   401Ôćĺ\n   402Ôćĺ  /** Aggregated audit event statistics for dashboard consumption. */\n   403Ôćĺ  stats(opts?: {\n   404Ôćĺ    tenantId?: string;\n   405Ôćĺ    since?: string;\n   406Ôćĺ    until?: string;\n   407Ôćĺ    bucket?: 'hour' | 'day';\n   408Ôćĺ  }): {\n   409Ôćĺ    byAction: { action: string; count: number }[];\n   410Ôćĺ    byTenant: { tenant_id: string; count: number }[];\n   411Ôćĺ    topActors: { actor: string; count: number }[];\n   412Ôćĺ    trend: { bucket: string; count: number }[];\n   413Ôćĺ  } {\n   414Ôćĺ    this.flush(); // ensure buffered entries are visible\n   415Ôćĺ\n   416Ôćĺ    const params: unknown[] = [];\n   417Ôćĺ    const clauses: string[] = [];\n   418Ôćĺ    if (opts?.tenantId) { clauses.push('tenant_id = ?'); params.push(opts.tenantId); }\n   419Ôćĺ    if (opts?.since) { clauses.push('timestamp >= ?'); params.push(opts.since); }\n   420Ôćĺ    if (opts?.until) { clauses.push('timestamp < ?'); params.push(opts.until); }\n   421Ôćĺ    const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   422Ôćĺ\n   423Ôćĺ    const bucketExpr = opts?.bucket === 'hour'\n   424Ôćĺ      ? \"substr(timestamp, 1, 13)\"  // YYYY-MM-DDTHH\n   425Ôćĺ      : \"substr(timestamp, 1, 10)\"; // YYYY-MM-DD\n   426Ôćĺ\n   427Ôćĺ    const byAction = this.db.prepare(\n   428Ôćĺ      `SELECT action, COUNT(*) as count FROM audit_events ${where} GROUP BY action ORDER BY count DESC`,\n   429Ôćĺ    ).all(...params) as { action: string; count: number }[];\n   430Ôćĺ\n   431Ôćĺ    const byTenant = this.db.prepare(\n   432Ôćĺ      `SELECT COALESCE(tenant_id, '__none__') as tenant_id, COUNT(*) as count FROM audit_events ${where} GROUP BY tenant_id ORDER BY count DESC LIMIT 50`,\n   433Ôćĺ    ).all(...params) as { tenant_id: string; count: number }[];\n   434Ôćĺ\n   435Ôćĺ    const topActors = this.db.prepare(\n   436Ôćĺ      `SELECT COALESCE(actor, '__none__') as actor, COUNT(*) as count FROM audit_events ${where} GROUP BY actor ORDER BY count DESC LIMIT 20`,\n   437Ôćĺ    ).all(...params) as { actor: string; count: number }[];\n   438Ôćĺ\n   439Ôćĺ    const trend = this.db.prepare(\n   440Ôćĺ      `SELECT ${bucketExpr} as bucket, COUNT(*) as count FROM audit_events ${where} GROUP BY bucket ORDER BY bucket ASC`,\n   441Ôćĺ    ).all(...params) as { bucket: string; count: number }[];\n   442Ôćĺ\n   443Ôćĺ    return { byAction, byTenant, topActors, trend };\n   444Ôćĺ  }\n   445Ôćĺ\n   446Ôćĺ  /** Query audit events with optional filters. */\n   447Ôćĺ  query(opts?: {\n   448Ôćĺ    tenantId?: string;\n   449Ôćĺ    action?: AuditAction;\n   450Ôćĺ    since?: string;\n   451Ôćĺ    limit?: number;\n   452Ôćĺ    offset?: number;\n   453Ôćĺ  }): AuditEvent[] {\n   454Ôćĺ    const params: unknown[] = [];\n   455Ôćĺ    const clauses: string[] = [];\n   456Ôćĺ    const keyParts: string[] = [];\n   457Ôćĺ\n   458Ôćĺ    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n   459Ôćĺ    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n   460Ôćĺ    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n   461Ôćĺ\n   462Ôćĺ    const key = keyParts.join('-') || 'none';\n   463Ôćĺ    let stmt = this.queryStmtCache.get(key);\n   464Ôćĺ    if (!stmt) {\n   465Ôćĺ      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   466Ôćĺ      stmt = this.db.prepare(\n   467Ôćĺ        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n   468Ôćĺ      );\n   469Ôćĺ      this.queryStmtCache.set(key, stmt);\n   470Ôćĺ    }\n   471Ôćĺ\n   472Ôćĺ    const limit = opts?.limit ?? 100;\n   473Ôćĺ    const offset = opts?.offset ?? 0;\n   474Ôćĺ\n   475Ôćĺ    return stmt.all(...params, limit, offset) as AuditEvent[];\n   476Ôćĺ  }\n   477Ôćĺ\n   478Ôćĺ  /**\n   479Ôćĺ   * Verify the integrity of the audit hash chain.\n   480Ôćĺ   * Iterates all chained rows and checks that each hash is consistent with\n   481Ôćĺ   * its predecessor. Pre-chain rows (migrated without prev_hash) are skipped.\n   482Ôćĺ   * If rows were purged, the chain will break at the first remaining row\n   483Ôćĺ   * ÔÇö this is by design (deletions are detectable).\n   484Ôćĺ   *\n   485Ôćĺ   * When `since`/`until` are provided, only rows within that timestamp range\n   486Ôćĺ   * are checked. The initial previous-hash is seeded from the last chained\n   487Ôćĺ   * row before the range (or genesis if none exists).\n   488Ôćĺ   */\n   489Ôćĺ  verify(opts?: { since?: string; until?: string }): ChainVerifyResult {\n   490Ôćĺ    this.flush(); // ensure all buffered entries are persisted\n   491Ôćĺ\n   492Ôćĺ    const hasRange = opts?.since || opts?.until;\n   493Ôćĺ    const clauses: string[] = [];\n   494Ôćĺ    const params: unknown[] = [];\n   495Ôćĺ    if (opts?.since) { clauses.push('timestamp >= ?'); params.push(opts.since); }\n   496Ôćĺ    if (opts?.until) { clauses.push('timestamp < ?'); params.push(opts.until); }\n   497Ôćĺ    const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   498Ôćĺ\n   499Ôćĺ    const iter = this.db.prepare(\n   500Ôćĺ      `SELECT * FROM audit_events ${where} ORDER BY id ASC`,\n   501Ôćĺ    ).iterate(...params);\n   502Ôćĺ\n   503Ôćĺ    // Seed the previous hash: for ranged queries, look up the last chained\n   504Ôćĺ    // row before the first matching row; for full scans use genesis.\n   505Ôćĺ    let prevHash = GENESIS_HASH;\n   506Ôćĺ    let seeded = !hasRange; // full scan is pre-seeded with genesis\n   507Ôćĺ\n   508Ôćĺ    let verifiedCount = 0;\n   509Ôćĺ\n   510Ôćĺ    for (const raw of iter) {\n   511Ôćĺ      const row = raw as AuditEvent;\n   512Ôćĺ      if (row.prev_hash === null) continue; // pre-chain row\n   513Ôćĺ\n   514Ôćĺ      // Lazily seed prevHash on the first chained row of a ranged query\n   515Ôćĺ      if (!seeded) {\n   516Ôćĺ        const prev = this.db.prepare(\n   517Ôćĺ          'SELECT prev_hash FROM audit_events WHERE id < ? AND prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n   518Ôćĺ        ).get(row.id) as { prev_hash: string } | undefined;\n   519Ôćĺ        prevHash = prev?.prev_hash ?? GENESIS_HASH;\n   520Ôćĺ        seeded = true;\n   521Ôćĺ      }\n   522Ôćĺ\n   523Ôćĺ      const expected = computeChainHash(prevHash, {\n   524Ôćĺ        timestamp: row.timestamp,\n   525Ôćĺ        action: row.action,\n   526Ôćĺ        tenantId: row.tenant_id,\n   527Ôćĺ        actor: row.actor,\n   528Ôćĺ        resourceType: row.resource_type,\n   529Ôćĺ        resourceId: row.resource_id,\n   530Ôćĺ        detail: row.detail,\n   531Ôćĺ        ipAddress: row.ip_address,\n   532Ôćĺ      });\n   533Ôćĺ\n   534Ôćĺ      if (row.prev_hash !== expected) {\n   535Ôćĺ        return { valid: false, verifiedCount, brokenAtId: row.id };\n   536Ôćĺ      }\n   537Ôćĺ\n   538Ôćĺ      prevHash = row.prev_hash;\n   539Ôćĺ      verifiedCount++;\n   540Ôćĺ    }\n   541Ôćĺ\n   542Ôćĺ    return { valid: true, verifiedCount };\n   543Ôćĺ  }\n   544Ôćĺ\n   545Ôćĺ  close(): void {\n   546Ôćĺ    if (this.flushTimer) {\n   547Ôćĺ      clearInterval(this.flushTimer);\n   548Ôćĺ      this.flushTimer = null;\n   549Ôćĺ    }\n   550Ôćĺ    this.flush();\n   551Ôćĺ    try { this.db.close(); } catch { /* best effort */ }\n   552Ôćĺ  }\n   553Ôćĺ}\n   554Ôćĺ"}]},"parent_tool_use_id":null,"session_id":"f94dec9b-4588-4b40-8fce-f8fe1b53042f","uuid":"22b954f5-64de-41b5-b81f-7d4c6486e9e6","timestamp":"2026-03-18T18:33:32.828Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\auditLog.ts","content":"import crypto from 'node:crypto';\nimport Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\n\n/** SHA-256 hash chain genesis value (64 hex zeros). */\nconst GENESIS_HASH = '0'.repeat(64);\n\n/**\n * Compute a chain hash: SHA-256(previousHash + deterministic JSON of entry fields).\n * Each entry's hash commits to the entire chain history before it.\n */\nfunction computeChainHash(prevHash: string, entry: BufferedEntry): string {\n  const payload = prevHash + JSON.stringify([\n    entry.timestamp,\n    entry.action,\n    entry.tenantId,\n    entry.actor,\n    entry.resourceType,\n    entry.resourceId,\n    entry.detail,\n    entry.ipAddress,\n  ]);\n  return crypto.createHash('sha256').update(payload).digest('hex');\n}\n\nconst AUDIT_SCHEMA = `\nCREATE TABLE IF NOT EXISTS audit_events (\n  id INTEGER PRIMARY KEY AUTOINCREMENT,\n  timestamp TEXT NOT NULL,\n  action TEXT NOT NULL,\n  tenant_id TEXT,\n  actor TEXT,\n  resource_type TEXT,\n  resource_id TEXT,\n  detail TEXT,\n  ip_address TEXT,\n  prev_hash TEXT\n);\nCREATE INDEX IF NOT EXISTS idx_audit_ts ON audit_events(timestamp);\nCREATE INDEX IF NOT EXISTS idx_audit_tenant_action_ts ON audit_events(tenant_id, action, timestamp);\nDROP INDEX IF EXISTS idx_audit_tenant_ts;\nDROP INDEX IF EXISTS idx_audit_action;\n`;\n\n/** Thrown when an audit event fails to persist ÔÇö signals an audit trail gap. */\nexport class AuditWriteError extends Error {\n  constructor(\n    public readonly entry: AuditEntry,\n    cause: unknown,\n  ) {\n    super(`Audit write failed for action \"${entry.action}\"`);\n    this.name = 'AuditWriteError';\n    this.cause = cause;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Discriminated-union audit entries ÔÇö each action carries its own typed payload\n// ---------------------------------------------------------------------------\n\n/** Fields common to every audit entry. */\ninterface AuditEntryBase {\n  tenantId?: string;\n  actor?: string;\n  ipAddress?: string;\n}\n\n// --- Key management ---\ninterface KeyEncryptEntry extends AuditEntryBase {\n  action: 'key:encrypt';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyDecryptEntry extends AuditEntryBase {\n  action: 'key:decrypt';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyDecryptFailedEntry extends AuditEntryBase {\n  action: 'key:decrypt_failed';\n  resourceType: 'credential';\n  resourceId: string;\n  detail: { reason: string };\n}\n\ninterface KeyDeleteEntry extends AuditEntryBase {\n  action: 'key:delete';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyAccessEntry extends AuditEntryBase {\n  action: 'key:access';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyDeriveEntry extends AuditEntryBase {\n  action: 'key:derive';\n}\n\n// --- Persona management ---\ninterface PersonaCreateEntry extends AuditEntryBase {\n  action: 'persona:create';\n  resourceType: 'persona';\n  resourceId: string;\n}\n\ninterface PersonaDeleteEntry extends AuditEntryBase {\n  action: 'persona:delete';\n  resourceType: 'persona';\n  resourceId: string;\n}\n\n// --- Tool management ---\ninterface ToolLinkEntry extends AuditEntryBase {\n  action: 'tool:link';\n  resourceType: 'persona';\n  resourceId: string;\n  detail: { toolId: string };\n}\n\ninterface ToolDefinitionCreateEntry extends AuditEntryBase {\n  action: 'tool-definition:create';\n  resourceType: 'toolDefinition';\n  resourceId: string;\n}\n\n// --- Credential linking ---\ninterface CredentialLinkEntry extends AuditEntryBase {\n  action: 'credential:link';\n  resourceType: 'persona';\n  resourceId: string;\n  detail: { credentialId: string };\n}\n\n// --- Subscriptions ---\ninterface SubscriptionCreateEntry extends AuditEntryBase {\n  action: 'subscription:create';\n  resourceType: 'subscription';\n  resourceId: string;\n  detail: { personaId: string; eventType: string };\n}\n\ninterface SubscriptionUpdateEntry extends AuditEntryBase {\n  action: 'subscription:update';\n  resourceType: 'subscription';\n  resourceId: string;\n}\n\ninterface SubscriptionDeleteEntry extends AuditEntryBase {\n  action: 'subscription:delete';\n  resourceType: 'subscription';\n  resourceId: string;\n}\n\n// --- Worker pool ---\ninterface WorkerConnectedEntry extends AuditEntryBase {\n  action: 'worker:connected';\n  detail: { workerId: string };\n}\n\ninterface WorkerDisconnectedEntry extends AuditEntryBase {\n  action: 'worker:disconnected';\n  detail: { workerId: string };\n  resourceId?: string;\n}\n\n// --- Triggers ---\ninterface TriggerCreateEntry extends AuditEntryBase {\n  action: 'trigger:create';\n  resourceType: 'trigger';\n  resourceId?: string;\n}\n\ninterface TriggerUpdateEntry extends AuditEntryBase {\n  action: 'trigger:update';\n  resourceType: 'trigger';\n  resourceId: string;\n}\n\ninterface TriggerDeleteEntry extends AuditEntryBase {\n  action: 'trigger:delete';\n  resourceType: 'trigger';\n  resourceId: string;\n}\n\n// --- Events ---\ninterface EventPublishEntry extends AuditEntryBase {\n  action: 'event:publish';\n  resourceType: 'event';\n  resourceId?: string;\n}\n\ninterface EventUpdateEntry extends AuditEntryBase {\n  action: 'event:update';\n  resourceType: 'event';\n  resourceId: string;\n}\n\n// --- Executions ---\ninterface ExecutionSubmitEntry extends AuditEntryBase {\n  action: 'execution:submit';\n  resourceType: 'execution';\n  resourceId?: string;\n}\n\n// --- Webhooks ---\ninterface WebhookReceiveEntry extends AuditEntryBase {\n  action: 'webhook:receive';\n  resourceType: 'webhook';\n  resourceId: string;\n}\n\n/** Discriminated union of all audit event types. */\nexport type AuditEntry =\n  | KeyEncryptEntry\n  | KeyDecryptEntry\n  | KeyDecryptFailedEntry\n  | KeyDeleteEntry\n  | KeyAccessEntry\n  | KeyDeriveEntry\n  | PersonaCreateEntry\n  | PersonaDeleteEntry\n  | ToolLinkEntry\n  | ToolDefinitionCreateEntry\n  | CredentialLinkEntry\n  | SubscriptionCreateEntry\n  | SubscriptionUpdateEntry\n  | SubscriptionDeleteEntry\n  | WorkerConnectedEntry\n  | WorkerDisconnectedEntry\n  | TriggerCreateEntry\n  | TriggerUpdateEntry\n  | TriggerDeleteEntry\n  | EventPublishEntry\n  | EventUpdateEntry\n  | ExecutionSubmitEntry\n  | WebhookReceiveEntry;\n\n/** String-literal union of all valid audit actions. */\nexport type AuditAction = AuditEntry['action'];\n\n/** Row shape returned by audit_events queries. */\nexport interface AuditEvent {\n  id: number;\n  timestamp: string;\n  action: string;\n  tenant_id: string | null;\n  actor: string | null;\n  resource_type: string | null;\n  resource_id: string | null;\n  detail: string | null;\n  ip_address: string | null;\n  prev_hash: string | null;\n}\n\n/** Result of verifying the audit hash chain. */\nexport interface ChainVerifyResult {\n  valid: boolean;\n  verifiedCount: number;\n  brokenAtId?: number;\n}\n\n/** Max entries buffered before an automatic flush. */\nconst BUFFER_FLUSH_SIZE = 50;\n/** Interval (ms) between timer-based flushes. */\nconst BUFFER_FLUSH_INTERVAL_MS = 100;\n\ninterface BufferedEntry {\n  timestamp: string;\n  action: string;\n  tenantId: string | null;\n  actor: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  detail: string | null;\n  ipAddress: string | null;\n}\n\nexport class AuditLog {\n  private db: Database.Database;\n  private insertStmt: Database.Statement;\n  private queryStmtCache = new Map<string, Database.Statement>();\n  private buffer: BufferedEntry[] = [];\n  private flushTimer: NodeJS.Timeout | null = null;\n  private batchInsert: (entries: BufferedEntry[], hashes: string[]) => void;\n  private lastHash: string;\n\n  constructor(\n    dbPath: string,\n    private logger: Logger,\n  ) {\n    this.db = new Database(dbPath);\n    this.db.pragma('journal_mode = WAL');\n    this.db.exec(AUDIT_SCHEMA);\n\n    // Migration: add prev_hash column to existing databases that lack it\n    const cols = this.db.pragma('table_info(audit_events)') as { name: string }[];\n    if (!cols.some((c) => c.name === 'prev_hash')) {\n      this.db.exec('ALTER TABLE audit_events ADD COLUMN prev_hash TEXT');\n    }\n\n    this.insertStmt = this.db.prepare(\n      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address, prev_hash) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',\n    );\n\n    // Initialize chain from last stored hash (or genesis for empty / pre-chain DBs)\n    const lastRow = this.db.prepare(\n      'SELECT prev_hash FROM audit_events WHERE prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n    ).get() as { prev_hash: string } | undefined;\n    this.lastHash = lastRow?.prev_hash ?? GENESIS_HASH;\n\n    // Wrap N inserts in a single transaction ÔÇö one fsync instead of N\n    const stmt = this.insertStmt;\n    this.batchInsert = this.db.transaction((entries: BufferedEntry[], hashes: string[]) => {\n      for (let i = 0; i < entries.length; i++) {\n        const e = entries[i];\n        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress, hashes[i]);\n      }\n    });\n\n    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n\n    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled, hash-chain active)');\n  }\n\n  /** Expose the underlying database for use by RetentionPolicy. */\n  getDb(): Database.Database {\n    return this.db;\n  }\n\n  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n  countEvents(before?: string): number {\n    const stmt = before\n      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n    return row.cnt;\n  }\n\n  /**\n   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   * yielding the event loop between batches so concurrent DB operations\n   * are not starved during large purges.\n   */\n  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n    const deleteChunk = this.db.prepare(\n      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n    );\n    let totalDeleted = 0;\n    while (true) {\n      const result = deleteChunk.run(cutoff, chunkSize);\n      totalDeleted += result.changes;\n      if (result.changes < chunkSize) break;\n      await new Promise<void>((resolve) => setImmediate(resolve));\n    }\n    return totalDeleted;\n  }\n\n  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n  record(entry: AuditEntry): void {\n    this.buffer.push({\n      timestamp: new Date().toISOString(),\n      action: entry.action,\n      tenantId: entry.tenantId ?? null,\n      actor: entry.actor ?? null,\n      resourceType: 'resourceType' in entry ? entry.resourceType : null,\n      resourceId: 'resourceId' in entry ? (entry.resourceId ?? null) : null,\n      detail: 'detail' in entry ? JSON.stringify(entry.detail) : null,\n      ipAddress: entry.ipAddress ?? null,\n    });\n    if (this.buffer.length >= BUFFER_FLUSH_SIZE) {\n      this.flush();\n    }\n  }\n\n  /** Flush buffered entries to SQLite in a single transaction, computing chain hashes. */\n  flush(): void {\n    if (this.buffer.length === 0) return;\n    const batch = this.buffer;\n    this.buffer = [];\n\n    // Compute chain hashes for the batch\n    const hashes: string[] = [];\n    let prevHash = this.lastHash;\n    for (const entry of batch) {\n      prevHash = computeChainHash(prevHash, entry);\n      hashes.push(prevHash);\n    }\n\n    try {\n      this.batchInsert(batch, hashes);\n      this.lastHash = prevHash;\n    } catch (err) {\n      this.logger.error({ err, count: batch.length }, 'Audit batch write failed ÔÇö audit trail gap');\n    }\n  }\n\n  /** Aggregated audit event statistics for dashboard consumption. */\n  stats(opts?: {\n    tenantId?: string;\n    since?: string;\n    until?: string;\n    bucket?: 'hour' | 'day';\n  }): {\n    byAction: { action: string; count: number }[];\n    byTenant: { tenant_id: string; count: number }[];\n    topActors: { actor: string; count: number }[];\n    trend: { bucket: string; count: number }[];\n  } {\n    this.flush(); // ensure buffered entries are visible\n\n    const params: unknown[] = [];\n    const clauses: string[] = [];\n    if (opts?.tenantId) { clauses.push('tenant_id = ?'); params.push(opts.tenantId); }\n    if (opts?.since) { clauses.push('timestamp >= ?'); params.push(opts.since); }\n    if (opts?.until) { clauses.push('timestamp < ?'); params.push(opts.until); }\n    const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n\n    const bucketExpr = opts?.bucket === 'hour'\n      ? \"substr(timestamp, 1, 13)\"  // YYYY-MM-DDTHH\n      : \"substr(timestamp, 1, 10)\"; // YYYY-MM-DD\n\n    const byAction = this.db.prepare(\n      `SELECT action, COUNT(*) as count FROM audit_events ${where} GROUP BY action ORDER BY count DESC`,\n    ).all(...params) as { action: string; count: number }[];\n\n    const byTenant = this.db.prepare(\n      `SELECT COALESCE(tenant_id, '__none__') as tenant_id, COUNT(*) as count FROM audit_events ${where} GROUP BY tenant_id ORDER BY count DESC LIMIT 50`,\n    ).all(...params) as { tenant_id: string; count: number }[];\n\n    const topActors = this.db.prepare(\n      `SELECT COALESCE(actor, '__none__') as actor, COUNT(*) as count FROM audit_events ${where} GROUP BY actor ORDER BY count DESC LIMIT 20`,\n    ).all(...params) as { actor: string; count: number }[];\n\n    const trend = this.db.prepare(\n      `SELECT ${bucketExpr} as bucket, COUNT(*) as count FROM audit_events ${where} GROUP BY bucket ORDER BY bucket ASC`,\n    ).all(...params) as { bucket: string; count: number }[];\n\n    return { byAction, byTenant, topActors, trend };\n  }\n\n  /** Query audit events with optional filters. */\n  query(opts?: {\n    tenantId?: string;\n    action?: AuditAction;\n    since?: string;\n    limit?: number;\n    offset?: number;\n  }): AuditEvent[] {\n    const params: unknown[] = [];\n    const clauses: string[] = [];\n    const keyParts: string[] = [];\n\n    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n\n    const key = keyParts.join('-') || 'none';\n    let stmt = this.queryStmtCache.get(key);\n    if (!stmt) {\n      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n      stmt = this.db.prepare(\n        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n      );\n      this.queryStmtCache.set(key, stmt);\n    }\n\n    const limit = opts?.limit ?? 100;\n    const offset = opts?.offset ?? 0;\n\n    return stmt.all(...params, limit, offset) as AuditEvent[];\n  }\n\n  /**\n   * Verify the integrity of the audit hash chain.\n   * Iterates all chained rows and checks that each hash is consistent with\n   * its predecessor. Pre-chain rows (migrated without prev_hash) are skipped.\n   * If rows were purged, the chain will break at the first remaining row\n   * ÔÇö this is by design (deletions are detectable).\n   *\n   * When `since`/`until` are provided, only rows within that timestamp range\n   * are checked. The initial previous-hash is seeded from the last chained\n   * row before the range (or genesis if none exists).\n   */\n  verify(opts?: { since?: string; until?: string }): ChainVerifyResult {\n    this.flush(); // ensure all buffered entries are persisted\n\n    const hasRange = opts?.since || opts?.until;\n    const clauses: string[] = [];\n    const params: unknown[] = [];\n    if (opts?.since) { clauses.push('timestamp >= ?'); params.push(opts.since); }\n    if (opts?.until) { clauses.push('timestamp < ?'); params.push(opts.until); }\n    const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n\n    const iter = this.db.prepare(\n      `SELECT * FROM audit_events ${where} ORDER BY id ASC`,\n    ).iterate(...params);\n\n    // Seed the previous hash: for ranged queries, look up the last chained\n    // row before the first matching row; for full scans use genesis.\n    let prevHash = GENESIS_HASH;\n    let seeded = !hasRange; // full scan is pre-seeded with genesis\n\n    let verifiedCount = 0;\n\n    for (const raw of iter) {\n      const row = raw as AuditEvent;\n      if (row.prev_hash === null) continue; // pre-chain row\n\n      // Lazily seed prevHash on the first chained row of a ranged query\n      if (!seeded) {\n        const prev = this.db.prepare(\n          'SELECT prev_hash FROM audit_events WHERE id < ? AND prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n        ).get(row.id) as { prev_hash: string } | undefined;\n        prevHash = prev?.prev_hash ?? GENESIS_HASH;\n        seeded = true;\n      }\n\n      const expected = computeChainHash(prevHash, {\n        timestamp: row.timestamp,\n        action: row.action,\n        tenantId: row.tenant_id,\n        actor: row.actor,\n        resourceType: row.resource_type,\n        resourceId: row.resource_id,\n        detail: row.detail,\n        ipAddress: row.ip_address,\n      });\n\n      if (row.prev_hash !== expected) {\n        return { valid: false, verifiedCount, brokenAtId: row.id };\n      }\n\n      prevHash = row.prev_hash;\n      verifiedCount++;\n    }\n\n    return { valid: true, verifiedCount };\n  }\n\n  close(): void {\n    if (this.flushTimer) {\n      clearInterval(this.flushTimer);\n      this.flushTimer = null;\n    }\n    this.flush();\n    try { this.db.close(); } catch { /* best effort */ }\n  }\n}\n","numLines":554,"startLine":1,"totalLines":554}}}
