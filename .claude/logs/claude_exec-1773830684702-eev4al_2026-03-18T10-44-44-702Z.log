[2026-03-18T10:44:54.569Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DqAuuwDBux1d74F1GkLMFm","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    11→import type { TenantDbManager } from './tenantDbManager.js';\n    12→import type { TenantKeyManager } from './tenantKeyManager.js';\n    13→import type { AuditLog } from './auditLog.js';\n    14→import type { Logger } from 'pino';\n    15→import * as db from './db/index.js';\n    16→import { readBody, json } from './httpUtils.js';\n    17→\n    18→export function createHttpApi(\n    19→  auth: Auth,\n    20→  dispatcher: Dispatcher,\n    21→  pool: WorkerPool,\n    22→  tokenManager: TokenManager,\n    23→  oauth: OAuthManager,\n    24→  logger: Logger,\n    25→  database?: Database.Database,\n    26→  tenantDbManager?: TenantDbManager,\n    27→  tenantKeyManager?: TenantKeyManager,\n    28→  auditLog?: AuditLog,\n    29→): http.Server {\n    30→  const server = http.createServer(async (req, res) => {\n    31→    // Security headers\n    32→    res.setHeader('X-Content-Type-Options', 'nosniff');\n    33→\n    34→    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    35→    const origin = req.headers.origin ?? '';\n    36→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    37→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    38→    if (isAdminRoute) {\n    39→      // Admin routes: only allow same-origin requests (no CORS wildcard)\n    40→      if (origin && origin === allowedOrigin) {\n    41→        res.setHeader('Access-Control-Allow-Origin', origin);\n    42→      }\n    43→      // If no match, omit the header entirely — browser blocks the request\n    44→    } else {\n    45→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    46→    }\n    47→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    48→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n    49→\n    50→    if (req.method === 'OPTIONS') {\n    51→      res.writeHead(204);\n    52→      res.end();\n    53→      return;\n    54→    }\n    55→\n    56→    const url = req.url || '/';\n    57→    const [pathname, queryString] = url.split('?');\n    58→    const route = parseRoute(pathname ?? '');\n    59→\n    60→    // Unauthenticated endpoints\n    61→    if (pathname === '/health' && req.method === 'GET') {\n    62→      handleHealth(res, pool, oauth);\n    63→      return;\n    64→    }\n    65→\n    66→    // Auth check for everything else — dual auth (API key + optional JWT)\n    67→    const ctx = auth.validateAndExtractContext(req);\n    68→    if (!ctx) {\n    69→      res.writeHead(401, { 'Content-Type': 'application/json' });\n    70→      res.end(JSON.stringify({ error: 'Unauthorized' }));\n    71→      return;\n    72→    }\n    73→\n    74→    // Helper: project scoping (admin sees all, user sees own project)\n    75→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n    76→\n    77→    // Resolve tenant-specific database when available\n    78→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n    79→      if (tenantDbManager && projectId) {\n    80→        return tenantDbManager.getTenantDb(projectId);\n    81→      }\n    82→      return database;\n    83→    };\n    84→    const tenantDb = resolveDatabase(ctx.projectId);\n    85→\n    86→    try {\n    87→      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n    88→      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n    89→        if (requireAdmin(ctx, res)) return;\n    90→        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n    91→        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n    92→        return;\n    93→      }\n    94→      // --- Persona CRUD ---\n    95→      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n    96→        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n    97→      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n    98→        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n    99→        const persona = createPersonaWithDefaults({\n   100→          ...body,\n   101→          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   102→        });\n   103→        db.upsertPersona(tenantDb, persona);\n   104→        json(res, 201, persona);\n   105→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n   106→        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n   107→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n   108→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   109→        if (!persona) return;\n   110→        const body = JSON.parse(await readBody(req)) as { toolId: string };\n   111→        db.linkTool(tenantDb, route.id, body.toolId);\n   112→        json(res, 200, { linked: true });\n   113→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n   114→        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id), scopedProjectId, res);\n   115→        if (!hydrated) return;\n   116→        json(res, 200, hydrated);\n   117→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n   118→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   119→        if (!persona) return;\n   120→        json(res, 200, persona);\n   121→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   122→        db.deletePersona(tenantDb, route.id, scopedProjectId);\n   123→        json(res, 200, { deleted: true });\n   124→      }\n   125→      // --- Tool Definitions ---\n   126→      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n   127→        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   128→        const tool = createToolDefinitionWithDefaults(body);\n   129→        db.upsertToolDefinition(tenantDb, tool);\n   130→        json(res, 201, tool);\n   131→      }\n   132→      // --- Credentials ---\n   133→      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n   134→        const body = JSON.parse(await readBody(req));\n   135→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   136→        // Reject oversized plaintext before synchronous encryption blocks the event loop\n   137→        if (body.plaintext && typeof body.plaintext === 'string' && body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   138→          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   139→          return;\n   140→        }\n   141→        // Server-side encryption with per-tenant key when plaintext secret is provided\n   142→        if (body.plaintext && tenantKeyManager) {\n   143→          const tenantId = body.projectId || ctx.projectId || 'default';\n   144→          const key = await tenantKeyManager.getKey(tenantId);\n   145→          const encrypted = encrypt(body.plaintext, key);\n   146→          body.encryptedData = encrypted.encrypted;\n   147→          body.iv = encrypted.iv;\n   148→          body.tag = encrypted.tag;\n   149→          delete body.plaintext;\n   150→          // Audit after creation below\n   151→        }\n   152→        const cred = db.createCredential(tenantDb, body);\n   153→        auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id });\n   154→        json(res, 201, cred);\n   155→      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   156→        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n   157→        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   158→        json(res, 200, { deleted: true });\n   159→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n   160→        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n   161→        // Strip encrypted data from response\n   162→        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   163→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n   164→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   165→        if (!persona) return;\n   166→        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   167→        db.linkCredential(tenantDb, route.id, body.credentialId);\n   168→        json(res, 200, { linked: true });\n   169→      }\n   170→      // --- Event Subscriptions ---\n   171→      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n   172→        const body = JSON.parse(await readBody(req));\n   173→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   174→        const missing: string[] = [];\n   175→        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   176→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   177→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   178→        const sub = db.createSubscription(tenantDb, body);\n   179→        json(res, 201, sub);\n   180→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   181→        const body = JSON.parse(await readBody(req));\n   182→        db.updateSubscription(tenantDb, route.id, body);\n   183→        const updated = db.getSubscription(tenantDb, route.id);\n   184→        json(res, 200, updated);\n   185→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   186→        db.deleteSubscription(tenantDb, route.id);\n   187→        json(res, 200, { deleted: true });\n   188→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n   189→        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n   190→      }\n   191→      // --- Triggers ---\n   192→      else if (route?.resource === 'triggers' && !route.id && req.method === 'POST' && tenantDb) {\n   193→        const body = JSON.parse(await readBody(req));\n   194→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   195→        const trigger = db.createTrigger(tenantDb, body);\n   196→        json(res, 201, trigger);\n   197→      } else if (route?.resource === 'triggers' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   198→        const body = JSON.parse(await readBody(req));\n   199→        db.updateTrigger(tenantDb, route.id, body);\n   200→        const updated = db.getTrigger(tenantDb, route.id);\n   201→        json(res, 200, updated);\n   202→      } else if (route?.resource === 'triggers' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   203→        db.deleteTrigger(tenantDb, route.id);\n   204→        json(res, 200, { deleted: true });\n   205→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'triggers' && req.method === 'GET' && tenantDb) {\n   206→        json(res, 200, db.listTriggersForPersona(tenantDb, route.id));\n   207→      }\n   208→      // --- Events ---\n   209→      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n   210→        const params = new URLSearchParams(queryString || '');\n   211→        const events = db.listEvents(tenantDb, {\n   212→          eventType: params.get('eventType') ?? undefined,\n   213→          status: params.get('status') ?? undefined,\n   214→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   215→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   216→          projectId: scopedProjectId,\n   217→        });\n   218→        json(res, 200, events);\n   219→      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n   220→        const body = JSON.parse(await readBody(req));\n   221→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   222→        const missing: string[] = [];\n   223→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   224→        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   225→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   226→        const event = db.publishEvent(tenantDb, body);\n   227→        json(res, 201, event);\n   228→      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   229→        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n   230→        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n   231→        if (updated) {\n   232→          json(res, 200, updated);\n   233→        } else {\n   234→          res.writeHead(404, { 'Content-Type': 'application/json' });\n   235→          res.end(JSON.stringify({ error: 'Event not found' }));\n   236→        }\n   237→      }\n   238→      // --- Webhooks ---\n   239→      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n   240→        const personaId = route.id;\n   241→        const body = await readBody(req);\n   242→        const event = db.publishEvent(tenantDb, {\n   243→          eventType: 'webhook_received',\n   244→          sourceType: 'webhook',\n   245→          sourceId: personaId,\n   246→          targetPersonaId: personaId,\n   247→          payload: body,\n   248→        });\n   249→        json(res, 201, event);\n   250→      }\n   251→      // --- GitLab Webhook ---\n   252→      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n   253→        const body = await readBody(req);\n   254→        let parsed: Record<string, unknown> = {};\n   255→        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   256→        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   257→        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   258→        const event = db.publishEvent(tenantDb, {\n   259→          eventType: `gitlab_${objectKind}`,\n   260→          sourceType: 'gitlab',\n   261→          sourceId: projectPath ?? null,\n   262→          payload: body,\n   263→        });\n   264→        json(res, 201, event);\n   265→      }\n   266→      // --- Executions ---\n   267→      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n   268→        const params = new URLSearchParams(queryString || '');\n   269→        const executions = db.listExecutions(tenantDb, {\n   270→          personaId: params.get('personaId') ?? undefined,\n   271→          status: params.get('status') ?? undefined,\n   272→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   273→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   274→          projectId: scopedProjectId,\n   275→        });\n   276→        json(res, 200, executions);\n   277→      }\n   278→      // --- Existing execution endpoints ---\n   279→      else if (pathname === '/api/status' && req.method === 'GET') {\n   280→        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   281→      } else if (pathname === '/api/execute' && req.method === 'POST') {\n   282→        await handleExecute(req, res, dispatcher, logger, ctx);\n   283→      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n   284→        handleCancelExecution(res, dispatcher, route.id);\n   285→      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n   286→        const executionId = route.id;\n   287→        const params = new URLSearchParams(queryString || '');\n   288→        const offset = parseInt(params.get('offset') || '0', 10);\n   289→        handleGetExecution(res, dispatcher, executionId, offset);\n   290→      }\n   291→      // --- Admin-only routes ---\n   292→      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n   293→        if (requireAdmin(ctx, res)) return;\n   294→        if (tenantDbManager) {\n   295→          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   296→        } else if (database) {\n   297→          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   298→        } else {\n   299→          json(res, 200, { projectIds: [] });\n   300→        }\n   301→      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n   302→        if (requireAdmin(ctx, res)) return;\n   303→        if (tenantDbManager) {\n   304→          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   305→          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   306→          json(res, 200, allPersonas);\n   307→        } else if (database) {\n   308→          json(res, 200, db.listPersonasSummary(database));\n   309→        } else {\n   310→          json(res, 200, []);\n   311→        }\n   312→      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n   313→        if (requireAdmin(ctx, res)) return;\n   314→        const params = new URLSearchParams(queryString || '');\n   315→        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   316→        if (tenantDbManager) {\n   317→          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   318→          tenantDbManager.forEachTenant((tDb) => {\n   319→            allExecs.push(...db.listExecutions(tDb, { limit }));\n   320→          });\n   321→          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   322→          json(res, 200, allExecs.slice(0, limit));\n   323→        } else if (database) {\n   324→          json(res, 200, db.listExecutions(database, {\n   325→            limit,\n   326→            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   327→          }));\n   328→        } else {\n   329→          json(res, 200, []);\n   330→        }\n   331→      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n   332→        if (requireAdmin(ctx, res)) return;\n   333→        if (!auditLog) { json(res, 200, []); return; }\n   334→        const params = new URLSearchParams(queryString || '');\n   335→        json(res, 200, auditLog.query({\n   336→          tenantId: params.get('tenantId') ?? undefined,\n   337→          action: params.get('action') ?? undefined,\n   338→          since: params.get('since') ?? undefined,\n   339→          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   340→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   341→        }));\n   342→      } else {\n   343→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   344→        res.end(JSON.stringify({ error: 'Not found' }));\n   345→      }\n   346→    } catch (err) {\n   347→      if (err instanceof Error && err.message === 'Payload too large') {\n   348→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   349→        res.end(JSON.stringify({ error: 'Payload too large' }));\n   350→        return;\n   351→      }\n   352→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   353→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   354→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n   355→        return;\n   356→      }\n   357→      logger.error({ err, url }, 'HTTP handler error');\n   358→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   359→      res.end(JSON.stringify({ error: 'Internal server error' }));\n   360→    }\n   361→  });\n   362→\n   363→  return server;\n   364→}\n   365→\n   366→interface ParsedRoute {\n   367→  resource: string;\n   368→  id?: string;\n   369→  subResource?: string;\n   370→}\n   371→\n   372→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n   373→function parseRoute(pathname: string): ParsedRoute | null {\n   374→  if (!pathname.startsWith('/api/')) return null;\n   375→  const segments = pathname.slice(5).split('/').filter(Boolean);\n   376→  if (segments.length === 0) return null;\n   377→  return {\n   378→    resource: segments[0]!,\n   379→    id: segments[1],\n   380→    subResource: segments[2],\n   381→  };\n   382→}\n   383→\n   384→/**\n   385→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   386→ * Returns the entity on success, or null after sending a 404 response.\n   387→ */\n   388→function withScopedEntity<T extends { projectId?: string | null }>(\n   389→  entity: T | undefined,\n   390→  scopedProjectId: string | undefined,\n   391→  res: http.ServerResponse,\n   392→): T | null {\n   393→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   394→    json(res, 404, { error: 'Not found' });\n   395→    return null;\n   396→  }\n   397→  return entity;\n   398→}\n   399→\n   400→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   401→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   402→  if (ctx.authType !== 'admin') {\n   403→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   404→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   405→    return true;\n   406→  }\n   407→  return false;\n   408→}\n   409→\n   410→// --- Existing handlers ---\n   411→\n   412→function handleHealth(res: http.ServerResponse, pool: WorkerPool, oauth: OAuthManager): void {\n   413→  const counts = pool.getWorkerCount();\n   414→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   415→  res.end(JSON.stringify({\n   416→    status: 'ok',\n   417→    workers: counts,\n   418→    hasSubscription: oauth.hasTokens(),\n   419→    timestamp: Date.now(),\n   420→  }));\n   421→}\n   422→\n   423→function handleStatus(\n   424→  res: http.ServerResponse,\n   425→  pool: WorkerPool,\n   426→  dispatcher: Dispatcher,\n   427→  tokenManager: TokenManager,\n   428→  oauth: OAuthManager,\n   429→): void {\n   430→  const oauthTokens = oauth.getTokens();\n   431→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   432→  res.end(JSON.stringify({\n   433→    workers: pool.getWorkers(),\n   434→    workerCounts: pool.getWorkerCount(),\n   435→    queueLength: dispatcher.getQueueLength(),\n   436→    activeExecutions: dispatcher.getActiveExecutions(),\n   437→    hasClaudeToken: tokenManager.hasToken(),\n   438→    oauth: {\n   439→      connected: oauth.hasTokens(),\n   440→      scopes: oauthTokens?.scopes || [],\n   441→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   442→    },\n   443→  }));\n   444→}\n   445→\n   446→async function handleExecute(\n   447→  req: http.IncomingMessage,\n   448→  res: http.ServerResponse,\n   449→  dispatcher: Dispatcher,\n   450→  logger: Logger,\n   451→  ctx?: RequestContext,\n   452→): Promise<void> {\n   453→  const body = await readBody(req);\n   454→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   455→\n   456→  try {\n   457→    parsed = JSON.parse(body);\n   458→  } catch {\n   459→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   460→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   461→    return;\n   462→  }\n   463→\n   464→  if (!parsed.prompt) {\n   465→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   466→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   467→    return;\n   468→  }\n   469→\n   470→  const request: ExecRequest = {\n   471→    executionId: nanoid(),\n   472→    personaId: parsed.personaId || 'manual',\n   473→    prompt: parsed.prompt,\n   474→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   475→    config: {\n   476→      timeoutMs: parsed.timeoutMs || 300_000,\n   477→    },\n   478→  };\n   479→\n   480→  dispatcher.submit(request);\n   481→\n   482→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   483→\n   484→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   485→  res.end(JSON.stringify({\n   486→    executionId: request.executionId,\n   487→    status: 'queued',\n   488→  }));\n   489→}\n   490→\n   491→function handleGetExecution(\n   492→  res: http.ServerResponse,\n   493→  dispatcher: Dispatcher,\n   494→  executionId: string,\n   495→  offset: number = 0,\n   496→): void {\n   497→  const exec = dispatcher.getExecution(executionId);\n   498→\n   499→  if (!exec) {\n   500→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   501→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   502→    return;\n   503→  }\n   504→\n   505→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   506→\n   507→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   508→  res.end(JSON.stringify({\n   509→    executionId,\n   510→    status: exec.status,\n   511→    outputLines: exec.output.length,\n   512→    output,\n   513→    durationMs: exec.durationMs,\n   514→    sessionId: exec.sessionId,\n   515→    totalCostUsd: exec.totalCostUsd,\n   516→  }));\n   517→}\n   518→\n   519→function handleCancelExecution(\n   520→  res: http.ServerResponse,\n   521→  dispatcher: Dispatcher,\n   522→  executionId: string,\n   523→): void {\n   524→  const cancelled = dispatcher.cancelExecution(executionId);\n   525→\n   526→  if (!cancelled) {\n   527→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   528→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   529→    return;\n   530→  }\n   531→\n   532→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   533→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   534→}\n   535→\n   536→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\n   537→const MAX_QUERY_LIMIT = 500;\n   538→const MAX_QUERY_OFFSET = 100_000;\n   539→\n   540→/** Parse an integer query param and clamp it to safe bounds. */\n   541→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   542→  if (!value) return defaultValue;\n   543→  const parsed = parseInt(value, 10);\n   544→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   545→  return Math.min(parsed, max);\n   546→}\n   547→"}]},"parent_tool_use_id":null,"session_id":"45612b36-7747-42ff-8f65-ed62dd610bb3","uuid":"d7a7f485-0db0-43dc-82a3-ac49378e9e11","timestamp":"2026-03-18T10:44:54.122Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n): http.Server {\n  const server = http.createServer(async (req, res) => {\n    // Security headers\n    res.setHeader('X-Content-Type-Options', 'nosniff');\n\n    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    const origin = req.headers.origin ?? '';\n    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    if (isAdminRoute) {\n      // Admin routes: only allow same-origin requests (no CORS wildcard)\n      if (origin && origin === allowedOrigin) {\n        res.setHeader('Access-Control-Allow-Origin', origin);\n      }\n      // If no match, omit the header entirely — browser blocks the request\n    } else {\n      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    }\n    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n\n    if (req.method === 'OPTIONS') {\n      res.writeHead(204);\n      res.end();\n      return;\n    }\n\n    const url = req.url || '/';\n    const [pathname, queryString] = url.split('?');\n    const route = parseRoute(pathname ?? '');\n\n    // Unauthenticated endpoints\n    if (pathname === '/health' && req.method === 'GET') {\n      handleHealth(res, pool, oauth);\n      return;\n    }\n\n    // Auth check for everything else — dual auth (API key + optional JWT)\n    const ctx = auth.validateAndExtractContext(req);\n    if (!ctx) {\n      res.writeHead(401, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Unauthorized' }));\n      return;\n    }\n\n    // Helper: project scoping (admin sees all, user sees own project)\n    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n\n    // Resolve tenant-specific database when available\n    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n      if (tenantDbManager && projectId) {\n        return tenantDbManager.getTenantDb(projectId);\n      }\n      return database;\n    };\n    const tenantDb = resolveDatabase(ctx.projectId);\n\n    try {\n      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n        if (requireAdmin(ctx, res)) return;\n        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n        return;\n      }\n      // --- Persona CRUD ---\n      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n        const persona = createPersonaWithDefaults({\n          ...body,\n          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n        });\n        db.upsertPersona(tenantDb, persona);\n        json(res, 201, persona);\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { toolId: string };\n        db.linkTool(tenantDb, route.id, body.toolId);\n        json(res, 200, { linked: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!hydrated) return;\n        json(res, 200, hydrated);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        json(res, 200, persona);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deletePersona(tenantDb, route.id, scopedProjectId);\n        json(res, 200, { deleted: true });\n      }\n      // --- Tool Definitions ---\n      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n        const tool = createToolDefinitionWithDefaults(body);\n        db.upsertToolDefinition(tenantDb, tool);\n        json(res, 201, tool);\n      }\n      // --- Credentials ---\n      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        // Reject oversized plaintext before synchronous encryption blocks the event loop\n        if (body.plaintext && typeof body.plaintext === 'string' && body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n          return;\n        }\n        // Server-side encryption with per-tenant key when plaintext secret is provided\n        if (body.plaintext && tenantKeyManager) {\n          const tenantId = body.projectId || ctx.projectId || 'default';\n          const key = await tenantKeyManager.getKey(tenantId);\n          const encrypted = encrypt(body.plaintext, key);\n          body.encryptedData = encrypted.encrypted;\n          body.iv = encrypted.iv;\n          body.tag = encrypted.tag;\n          delete body.plaintext;\n          // Audit after creation below\n        }\n        const cred = db.createCredential(tenantDb, body);\n        auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id });\n        json(res, 201, cred);\n      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n        // Strip encrypted data from response\n        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n        db.linkCredential(tenantDb, route.id, body.credentialId);\n        json(res, 200, { linked: true });\n      }\n      // --- Event Subscriptions ---\n      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const sub = db.createSubscription(tenantDb, body);\n        json(res, 201, sub);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        db.updateSubscription(tenantDb, route.id, body);\n        const updated = db.getSubscription(tenantDb, route.id);\n        json(res, 200, updated);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deleteSubscription(tenantDb, route.id);\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n      }\n      // --- Triggers ---\n      else if (route?.resource === 'triggers' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const trigger = db.createTrigger(tenantDb, body);\n        json(res, 201, trigger);\n      } else if (route?.resource === 'triggers' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        db.updateTrigger(tenantDb, route.id, body);\n        const updated = db.getTrigger(tenantDb, route.id);\n        json(res, 200, updated);\n      } else if (route?.resource === 'triggers' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deleteTrigger(tenantDb, route.id);\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'triggers' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listTriggersForPersona(tenantDb, route.id));\n      }\n      // --- Events ---\n      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const events = db.listEvents(tenantDb, {\n          eventType: params.get('eventType') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, events);\n      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const event = db.publishEvent(tenantDb, body);\n        json(res, 201, event);\n      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n        if (updated) {\n          json(res, 200, updated);\n        } else {\n          res.writeHead(404, { 'Content-Type': 'application/json' });\n          res.end(JSON.stringify({ error: 'Event not found' }));\n        }\n      }\n      // --- Webhooks ---\n      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n        const personaId = route.id;\n        const body = await readBody(req);\n        const event = db.publishEvent(tenantDb, {\n          eventType: 'webhook_received',\n          sourceType: 'webhook',\n          sourceId: personaId,\n          targetPersonaId: personaId,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- GitLab Webhook ---\n      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n        const body = await readBody(req);\n        let parsed: Record<string, unknown> = {};\n        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n        const event = db.publishEvent(tenantDb, {\n          eventType: `gitlab_${objectKind}`,\n          sourceType: 'gitlab',\n          sourceId: projectPath ?? null,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- Executions ---\n      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const executions = db.listExecutions(tenantDb, {\n          personaId: params.get('personaId') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, executions);\n      }\n      // --- Existing execution endpoints ---\n      else if (pathname === '/api/status' && req.method === 'GET') {\n        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n      } else if (pathname === '/api/execute' && req.method === 'POST') {\n        await handleExecute(req, res, dispatcher, logger, ctx);\n      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n        handleCancelExecution(res, dispatcher, route.id);\n      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n        const executionId = route.id;\n        const params = new URLSearchParams(queryString || '');\n        const offset = parseInt(params.get('offset') || '0', 10);\n        handleGetExecution(res, dispatcher, executionId, offset);\n      }\n      // --- Admin-only routes ---\n      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n        } else if (database) {\n          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n        } else {\n          json(res, 200, { projectIds: [] });\n        }\n      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n          json(res, 200, allPersonas);\n        } else if (database) {\n          json(res, 200, db.listPersonasSummary(database));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        const params = new URLSearchParams(queryString || '');\n        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n        if (tenantDbManager) {\n          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n          tenantDbManager.forEachTenant((tDb) => {\n            allExecs.push(...db.listExecutions(tDb, { limit }));\n          });\n          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n          json(res, 200, allExecs.slice(0, limit));\n        } else if (database) {\n          json(res, 200, db.listExecutions(database, {\n            limit,\n            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          }));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (!auditLog) { json(res, 200, []); return; }\n        const params = new URLSearchParams(queryString || '');\n        json(res, 200, auditLog.query({\n          tenantId: params.get('tenantId') ?? undefined,\n          action: params.get('action') ?? undefined,\n          since: params.get('since') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        }));\n      } else {\n        res.writeHead(404, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Not found' }));\n      }\n    } catch (err) {\n      if (err instanceof Error && err.message === 'Payload too large') {\n        res.writeHead(413, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Payload too large' }));\n        return;\n      }\n      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n        res.writeHead(409, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n        return;\n      }\n      logger.error({ err, url }, 'HTTP handler error');\n      res.writeHead(500, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Internal server error' }));\n    }\n  });\n\n  return server;\n}\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\n/**\n * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n * Returns the entity on success, or null after sending a 404 response.\n */\nfunction withScopedEntity<T extends { projectId?: string | null }>(\n  entity: T | undefined,\n  scopedProjectId: string | undefined,\n  res: http.ServerResponse,\n): T | null {\n  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n    json(res, 404, { error: 'Not found' });\n    return null;\n  }\n  return entity;\n}\n\n/** Returns true (and sends 403) if the caller is NOT an admin. */\nfunction requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n  if (ctx.authType !== 'admin') {\n    res.writeHead(403, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Admin access required' }));\n    return true;\n  }\n  return false;\n}\n\n// --- Existing handlers ---\n\nfunction handleHealth(res: http.ServerResponse, pool: WorkerPool, oauth: OAuthManager): void {\n  const counts = pool.getWorkerCount();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    status: 'ok',\n    workers: counts,\n    hasSubscription: oauth.hasTokens(),\n    timestamp: Date.now(),\n  }));\n}\n\nfunction handleStatus(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n): void {\n  const oauthTokens = oauth.getTokens();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    workers: pool.getWorkers(),\n    workerCounts: pool.getWorkerCount(),\n    queueLength: dispatcher.getQueueLength(),\n    activeExecutions: dispatcher.getActiveExecutions(),\n    hasClaudeToken: tokenManager.hasToken(),\n    oauth: {\n      connected: oauth.hasTokens(),\n      scopes: oauthTokens?.scopes || [],\n      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n    },\n  }));\n}\n\nasync function handleExecute(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  ctx?: RequestContext,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.prompt) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n    return;\n  }\n\n  const request: ExecRequest = {\n    executionId: nanoid(),\n    personaId: parsed.personaId || 'manual',\n    prompt: parsed.prompt,\n    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n    config: {\n      timeoutMs: parsed.timeoutMs || 300_000,\n    },\n  };\n\n  dispatcher.submit(request);\n\n  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n\n  res.writeHead(202, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId: request.executionId,\n    status: 'queued',\n  }));\n}\n\nfunction handleGetExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n  offset: number = 0,\n): void {\n  const exec = dispatcher.getExecution(executionId);\n\n  if (!exec) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found' }));\n    return;\n  }\n\n  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId,\n    status: exec.status,\n    outputLines: exec.output.length,\n    output,\n    durationMs: exec.durationMs,\n    sessionId: exec.sessionId,\n    totalCostUsd: exec.totalCostUsd,\n  }));\n}\n\nfunction handleCancelExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n): void {\n  const cancelled = dispatcher.cancelExecution(executionId);\n\n  if (!cancelled) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n    return;\n  }\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n}\n\nconst MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\nconst MAX_QUERY_LIMIT = 500;\nconst MAX_QUERY_OFFSET = 100_000;\n\n/** Parse an integer query param and clamp it to safe bounds. */\nfunction clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n  if (!value) return defaultValue;\n  const parsed = parseInt(value, 10);\n  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n  return Math.min(parsed, max);\n}\n","numLines":547,"startLine":1,"totalLines":547}}}
