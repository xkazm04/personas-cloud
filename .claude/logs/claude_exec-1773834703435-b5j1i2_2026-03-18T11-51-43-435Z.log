ing; serviceType: string; encryptedData: string; iv: string; tag: string; metadata?: string | null; projectId?: string;\n    41→}): PersonaCredential {\n    42→  const now = new Date().toISOString();\n    43→  const id = nanoid();\n    44→  const projectId = input.projectId ?? 'default';\n    45→  const metadata = input.metadata ?? null;\n    46→  stmt(db,`\n    47→    INSERT INTO persona_credentials (id, project_id, name, service_type, encrypted_data, iv, tag, metadata, created_at, updated_at)\n    48→    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n    49→  `).run(id, projectId, input.name, input.serviceType, input.encryptedData, input.iv, input.tag, metadata, now, now);\n    50→  return {\n    51→    id,\n    52→    projectId,\n    53→    name: input.name,\n    54→    serviceType: input.serviceType,\n    55→    encryptedData: input.encryptedData,\n    56→    iv: input.iv,\n    57→    tag: input.tag,\n    58→    metadata,\n    59→    lastUsedAt: null,\n    60→    createdAt: now,\n    61→    updatedAt: now,\n    62→  };\n    63→}\n    64→\n    65→export function getCredential(db: Database.Database, id: string): PersonaCredential | undefined {\n    66→  const row = stmt(db,'SELECT * FROM persona_credentials WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n    67→  return row ? rowToCredential(row) : undefined;\n    68→}\n    69→\n    70→export function listCredentialsForPersona(db: Database.Database, personaId: string): PersonaCredential[] {\n    71→  const rows = stmt(db,`\n    72→    SELECT c.* FROM persona_credentials c\n    73→    JOIN persona_credential_links cl ON cl.credential_id = c.id\n    74→    WHERE cl.persona_id = ?\n    75→  `).all(personaId) as Record<string, unknown>[];\n    76→  return rows.map(rowToCredential);\n    77→}\n    78→\n    79→export function linkCredential(db: Database.Database, personaId: string, credentialId: string): void {\n    80→  stmt(db,'INSERT OR IGNORE INTO persona_credential_links (persona_id, credential_id) VALUES (?, ?)').run(personaId, credentialId);\n    81→}\n    82→\n    83→export function deleteCredential(db: Database.Database, id: string, projectId?: string): number {\n    84→  if (projectId) {\n    85→    const result = stmt(db,'DELETE FROM persona_credentials WHERE id = ? AND project_id = ?').run(id, projectId);\n    86→    return result.changes;\n    87→  }\n    88→  const result = stmt(db,'DELETE FROM persona_credentials WHERE id = ?').run(id);\n    89→  return result.changes;\n    90→}\n    91→"}]},"parent_tool_use_id":null,"session_id":"6b375ece-41c0-48fe-9151-de360e723e96","uuid":"c2caa635-a22f-4506-ac0e-2fd189cc5612","timestamp":"2026-03-18T11:52:08.724Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\db\\credentials.ts","content":"import Database from 'better-sqlite3';\nimport { nanoid } from 'nanoid';\nimport type { PersonaCredential } from '@dac-cloud/shared';\nimport { stmt, createRowMapper } from './_helpers.js';\n\n// ---------------------------------------------------------------------------\n// Row mappers\n// ---------------------------------------------------------------------------\n\nconst rowToCredential = createRowMapper<PersonaCredential>({\n  id: { col: 'id' },\n  projectId: { col: 'project_id', default: 'default' },\n  name: { col: 'name' },\n  serviceType: { col: 'service_type' },\n  encryptedData: { col: 'encrypted_data' },\n  iv: { col: 'iv' },\n  tag: { col: 'tag' },\n  metadata: { col: 'metadata', nullable: true },\n  lastUsedAt: { col: 'last_used_at', nullable: true },\n  createdAt: { col: 'created_at' },\n  updatedAt: { col: 'updated_at' },\n});\n\nexport const rowToRedactedCredential = createRowMapper<Omit<PersonaCredential, 'encryptedData' | 'iv' | 'tag'>>({\n  id: { col: 'id' },\n  projectId: { col: 'project_id', default: 'default' },\n  name: { col: 'name' },\n  serviceType: { col: 'service_type' },\n  metadata: { col: 'metadata', nullable: true },\n  lastUsedAt: { col: 'last_used_at', nullable: true },\n  createdAt: { col: 'created_at' },\n  updatedAt: { col: 'updated_at' },\n});\n\n// ---------------------------------------------------------------------------\n// CRUD\n// ---------------------------------------------------------------------------\n\nexport function createCredential(db: Database.Database, input: {\n  name: string; serviceType: string; encryptedData: string; iv: string; tag: string; metadata?: string | null; projectId?: string;\n}): PersonaCredential {\n  const now = new Date().toISOString();\n  const id = nanoid();\n  const projectId = input.projectId ?? 'default';\n  const metadata = input.metadata ?? null;\n  stmt(db,`\n    INSERT INTO persona_credentials (id, project_id, name, service_type, encrypted_data, iv, tag, metadata, created_at, updated_at)\n    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n  `).run(id, projectId, input.name, input.serviceType, input.encryptedData, input.iv, input.tag, metadata, now, now);\n  return {\n    id,\n    projectId,\n    name: input.name,\n    serviceType: input.serviceType,\n    encryptedData: input.encryptedData,\n    iv: input.iv,\n    tag: input.tag,\n    metadata,\n    lastUsedAt: null,\n    createdAt: now,\n    updatedAt: now,\n  };\n}\n\nexport function getCredential(db: Database.Database, id: string): PersonaCredential | undefined {\n  const row = stmt(db,'SELECT * FROM persona_credentials WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n  return row ? rowToCredential(row) : undefined;\n}\n\nexport function listCredentialsForPersona(db: Database.Database, personaId: string): PersonaCredential[] {\n  const rows = stmt(db,`\n    SELECT c.* FROM persona_credentials c\n    JOIN persona_credential_links cl ON cl.credential_id = c.id\n    WHERE cl.persona_id = ?\n  `).all(personaId) as Record<string, unknown>[];\n  return rows.map(rowToCredential);\n}\n\nexport function linkCredential(db: Database.Database, personaId: string, credentialId: string): void {\n  stmt(db,'INSERT OR IGNORE INTO persona_credential_links (persona_id, credential_id) VALUES (?, ?)').run(personaId, credentialId);\n}\n\nexport function deleteCredential(db: Database.Database, id: string, projectId?: string): number {\n  if (projectId) {\n    const result = stmt(db,'DELETE FROM persona_credentials WHERE id = ? AND project_id = ?').run(id, projectId);\n    return result.changes;\n  }\n  const result = stmt(db,'DELETE FROM persona_credentials WHERE id = ?').run(id);\n  return result.changes;\n}\n","numLines":91,"startLine":1,"totalLines":91}}}
