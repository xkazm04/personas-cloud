    56→    credentials: {\n    57→      activeFileCount: getActiveCredentialFileCount(),\n    58→    },\n    59→  };\n    60→}\n    61→\n    62→export function startHealthProbe(\n    63→  port: number,\n    64→  connection: Connection,\n    65→  executor: Executor,\n    66→  workerId: string,\n    67→  logger: Logger,\n    68→): http.Server {\n    69→  const startTime = Date.now();\n    70→\n    71→  const server = http.createServer((req, res) => {\n    72→    if (req.method !== 'GET') {\n    73→      res.writeHead(405);\n    74→      res.end();\n    75→      return;\n    76→    }\n    77→\n    78→    const payload = buildHealthPayload(connection, executor, workerId, startTime);\n    79→\n    80→    if (req.url === '/healthz') {\n    81→      // Liveness: alive unless WS is permanently disconnected (shutting down)\n    82→      const alive = payload.websocket !== 'disconnected';\n    83→      res.writeHead(alive ? 200 : 503, { 'Content-Type': 'application/json' });\n    84→      res.end(JSON.stringify(payload));\n    85→      return;\n    86→    }\n    87→\n    88→    if (req.url === '/readyz') {\n    89→      // Readiness: ready to accept work when connected and idle\n    90→      const ready = payload.websocket === 'connected' && payload.execution.state === 'idle';\n    91→      res.writeHead(ready ? 200 : 503, { 'Content-Type': 'application/json' });\n    92→      res.end(JSON.stringify(payload));\n    93→      return;\n    94→    }\n    95→\n    96→    res.writeHead(404);\n    97→    res.end();\n    98→  });\n    99→\n   100→  server.listen(port, '0.0.0.0', () => {\n   101→    logger.info({ port }, 'Health probe listening');\n   102→  });\n   103→\n   104→  server.on('error', (err) => {\n   105→    logger.error({ err, port }, 'Health probe server error');\n   106→  });\n   107→\n   108→  return server;\n   109→}\n   110→"}]},"parent_tool_use_id":null,"session_id":"a6611918-5700-489e-b074-66c80e703fff","uuid":"cb452b20-0f9c-4273-9cc9-7b39242ba1cb","timestamp":"2026-03-18T17:41:52.783Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\worker\\src\\healthProbe.ts","content":"import http from 'node:http';\nimport fs from 'node:fs';\nimport os from 'node:os';\nimport type { Logger } from 'pino';\nimport type { Connection } from './connection.js';\nimport type { Executor } from './executor.js';\nimport { isSandboxAvailable } from './sandbox.js';\nimport { getActiveCredentialFileCount } from './credentialInjector.js';\n\ninterface DiskInfo {\n  path: string;\n  availableBytes: number;\n  totalBytes: number;\n}\n\nfunction getDiskInfo(dirPath: string): DiskInfo | null {\n  try {\n    const stats = fs.statfsSync(dirPath);\n    return {\n      path: dirPath,\n      availableBytes: stats.bavail * stats.bsize,\n      totalBytes: stats.blocks * stats.bsize,\n    };\n  } catch {\n    return null;\n  }\n}\n\nfunction buildHealthPayload(\n  connection: Connection,\n  executor: Executor,\n  workerId: string,\n  startTime: number,\n) {\n  const wsState = connection.getConnectionState();\n  const execStatus = executor.getStatus();\n\n  const tmpdir = getDiskInfo(os.tmpdir());\n  const devShm = process.platform === 'linux' && fs.existsSync('/dev/shm')\n    ? getDiskInfo('/dev/shm')\n    : null;\n\n  return {\n    status: wsState === 'connected' ? 'healthy' as const : 'degraded' as const,\n    workerId,\n    uptimeMs: Date.now() - startTime,\n    websocket: wsState,\n    execution: execStatus,\n    sandbox: {\n      bwrapAvailable: isSandboxAvailable(),\n    },\n    disk: {\n      tmpdir,\n      devShm,\n    },\n    credentials: {\n      activeFileCount: getActiveCredentialFileCount(),\n    },\n  };\n}\n\nexport function startHealthProbe(\n  port: number,\n  connection: Connection,\n  executor: Executor,\n  workerId: string,\n  logger: Logger,\n): http.Server {\n  const startTime = Date.now();\n\n  const server = http.createServer((req, res) => {\n    if (req.method !== 'GET') {\n      res.writeHead(405);\n      res.end();\n      return;\n    }\n\n    const payload = buildHealthPayload(connection, executor, workerId, startTime);\n\n    if (req.url === '/healthz') {\n      // Liveness: alive unless WS is permanently disconnected (shutting down)\n      const alive = payload.websocket !== 'disconnected';\n      res.writeHead(alive ? 200 : 503, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify(payload));\n      return;\n    }\n\n    if (req.url === '/readyz') {\n      // Readiness: ready to accept work when connected and idle\n      const ready = payload.websocket === 'connected' && payload.execution.state === 'idle';\n      res.writeHead(ready ? 200 : 503, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify(payload));\n      return;\n    }\n\n    res.writeHead(404);\n    res.end();\n  });\n\n  server.listen(port, '0.0.0.0', () => {\n    logger.info({ port }, 'Health probe listening');\n  });\n\n  server.on('error', (err) => {\n    logger.error({ err, port }, 'Health probe server error');\n  });\n\n  return server;\n}\n","numLines":110,"startLine":1,"totalLines":110}}}
