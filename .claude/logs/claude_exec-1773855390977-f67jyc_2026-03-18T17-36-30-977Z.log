up\n    35→   * (sandbox removal, credential deletion, proxy teardown) has finished.\n    36→   * If no execution is active, resolves immediately.\n    37→   *\n    38→   * An optional `timeoutMs` ensures the caller is never blocked forever\n    39→   * (defaults to 10 s).\n    40→   */\n    41→  waitForCleanup(timeoutMs = 10_000): Promise<void> {\n    42→    if (!this.executionDone) return Promise.resolve();\n    43→\n    44→    return Promise.race([\n    45→      this.executionDone,\n    46→      new Promise<void>((resolve) => setTimeout(resolve, timeoutMs)),\n    47→    ]);\n    48→  }\n    49→\n    50→  private processStdoutLine(line: string, callbacks: ExecutorCallbacks): void {\n    51→    callbacks.onStdout(line, Date.now());\n    52→\n    53→    const streamEvents = extractStreamEvents(line, this.logger);\n    54→    if (streamEvents.sessionId) this.sessionId = streamEvents.sessionId;\n    55→    if (streamEvents.totalCostUsd) this.totalCostUsd = streamEvents.totalCostUsd;\n    56→    for (const event of streamEvents.personaEvents) {\n    57→      callbacks.onEvent(event.eventType, event.payload);\n    58→    }\n    59→    if (streamEvents.progress) {\n    60→      callbacks.onProgress(streamEvents.progress.phase, streamEvents.progress.percent, streamEvents.progress.detail);\n    61→    }\n    62→  }\n    63→\n    64→  /** Returns true if an execution is currently in progress. */\n    65→  isBusy(): boolean {\n    66→    return this.childProcess !== null;\n    67→  }\n    68→\n    69→  async execute(assignment: ExecAssign, callbacks: ExecutorCallbacks): Promise<void> {\n    70→    const run = this.doExecute(assignment, callbacks);\n    71→    this.executionDone = run.catch((err) => {\n    72→      this.logger.warn({ err, executionId: assignment.executionId, operation: 'execute' }, 'Execution promise swallowed');\n    73→    });   // swallow – callers handle errors via callbacks\n    74→    try {\n    75→      await run;\n    76→    } finally {\n    77→      this.executionDone = null;\n    78→    }\n    79→  }\n    80→\n    81→  private async doExecute(assignment: ExecAssign, callbacks: ExecutorCallbacks): Promise<void> {\n    82→    const startTime = Date.now();\n    83→    this.sessionId = undefined;\n    84→    this.totalCostUsd = undefined;\n    85→\n    86→    const netPolicy = assignment.config.networkPolicy ?? undefined;\n    87→    const sandboxConfig: SandboxConfig = {\n    88→      executionId: assignment.executionId,\n    89→      env: { ...assignment.env },\n    90→      networkAccess: !netPolicy, // full access only if no policy set\n    91→      networkPolicy: netPolicy,\n    92→      timeoutMs: assignment.config.timeoutMs,\n    93→      maxBudgetUsd: assignment.config.maxBudgetUsd,\n    94→      maxTurns: assignment.config.maxTurns,\n    95→    };\n    96→\n    97→    let t0 = Date.now();\n    98→    const sandbox = prepareSandbox(sandboxConfig, this.logger);\n    99→    const sandboxSetupMs = Date.now() - t0;\n   100→\n   101→    let proxy: ProxyHandle | null = null;\n   102→    let injectedCreds: InjectedCredentials | null = null;\n   103→    let proxyStartupMs: number | null = null;\n   104→    let credentialInjectionMs = 0;\n   105→    let cliRuntimeMs = 0;\n   106→    let exitCode = 1;\n   107→    let completedNormally = false;\n   108→\n   109→    this.logger.info({\n   110→      executionId: assignment.executionId,\n   111→      personaId: assignment.personaId,\n   112→      sandboxDir: sandbox.sandboxDir,\n   113→      timeoutMs: assignment.config.timeoutMs,\n   114→    }, 'Starting execution');\n   115→\n   116→    try {\n   117→      // Start filtering proxy for allow-list network policies\n   118→      if (sandbox.proxyRequired && netPolicy) {\n   119→        t0 = Date.now();\n   120→        proxy = await startFilterProxy(netPolicy, this.logger, assignment.executionId);\n   121→        proxyStartupMs = Date.now() - t0;\n   122→        const proxyUrl = `http://127.0.0.1:${proxy.port}`;\n   123→        sandbox.env['HTTP_PROXY'] = proxyUrl;\n   124→        sandbox.env['HTTPS_PROXY'] = proxyUrl;\n   125→        sandbox.env['http_proxy'] = proxyUrl;\n   126→        sandbox.env['https_proxy'] = proxyUrl;\n   127→        sandbox.env['NO_PROXY'] = '';\n   128→      }\n   129→\n   130→      // Inject credentials via async file write (unblocks event loop)\n   131→      t0 = Date.now();\n   132→      injectedCreds = await injectCredentialsViaFile(sandbox.env, assignment.executionId, this.logger);\n   133→      credentialInjectionMs = Date.now() - t0;\n   134→      sandbox.env[injectedCreds.envPointerKey] = injectedCreds.credentialFilePath;\n   135→\n   136→      const cliStartTime = Date.now();\n   137→      this.childProcess = spawn(sandbox.command, sandbox.args, {\n   138→        cwd: sandbox.cwd,\n   139→        stdio: ['pipe', 'pipe', 'pipe'],\n   140→        env: sandbox.env,\n   141→      });\n   142→\n   143→      // Pipe prompt to stdin\n   144→      this.childProcess.stdin!.write(assignment.prompt);\n   145→      this.childProcess.stdin!.end();\n   146→\n   147→      // Set up timeout\n   148→      const timeoutHandle = setTimeout(() => {\n   149→        this.logger.warn({\n   150→          executionId: assignment.executionId,\n   151→          timeoutMs: assignment.config.timeoutMs,\n   152→        }, 'Execution timeout, killing process');\n   153→        this.kill();\n   154→      }, assignment.config.timeoutMs);\n   155→\n   156→      // Parse stdout\n   157→      const stdoutBuffer = new LineBuffer();\n   158→      this.childProcess.stdout!.on('data', (data: Buffer) => {\n   159→        const lines = stdoutBuffer.push(data.toString());\n   160→        for (const line of lines) {\n   161→          this.processStdoutLine(line, callbacks);\n   162→        }\n   163→      });\n   164→\n   165→      // Parse stderr\n   166→      const stderrBuffer = new LineBuffer();\n   167→      this.childProcess.stderr!.on('data', (data: Buffer) => {\n   168→        const lines = stderrBuffer.push(data.toString());\n   169→        for (const line of lines) {\n   170→          callbacks.onStderr(line, Date.now());\n   171→        }\n   172→      });\n   173→\n   174→      // Wait for process to exit\n   175→      exitCode = await new Promise<number>((resolve) => {\n   176→        this.childProcess!.on('close', (code: number | null) => {\n   177→          clearTimeout(timeoutHandle);\n   178→          resolve(code ?? 1);\n   179→        });\n   180→\n   181→        this.childProcess!.on('error', (err: Error) => {\n   182→          clearTimeout(timeoutHandle);\n   183→          this.logger.error({ err, executionId: assignment.executionId }, 'Process spawn error');\n   184→          resolve(1);\n   185→        });\n   186→      });\n   187→\n   188→      // Flush remaining buffered data\n   189→      for (const line of stdoutBuffer.flush()) {\n   190→        this.processStdoutLine(line, callbacks);\n   191→      }\n   192→      for (const line of stderrBuffer.flush()) {\n   193→        callbacks.onStderr(line, Date.now());\n   194→      }\n   195→\n   196→      cliRuntimeMs = Date.now() - cliStartTime;\n   197→      completedNormally = true;\n   198→\n   199→    } finally {\n   200→      const wasKilled = this.killed;\n   201→      const cleanupStart = Date.now();\n   202→      if (injectedCreds) await injectedCreds.cleanup().catch(() => {});\n   203→      if (proxy) proxy.cleanup();\n   204→      cleanupSandbox(sandbox.sandboxDir, this.logger);\n   205→      this.childProcess = null;\n   206→      this.killed = false;\n   207→      const cleanupMs = Date.now() - cleanupStart;\n   208→\n   209→      const durationMs = Date.now() - startTime;\n   210→      const status = wasKilled ? 'cancelled' : (exitCode === 0 ? 'completed' : 'failed');\n   211→\n   212→      const phaseTimings: PhaseTimings = {\n   213→        sandboxSetupMs,\n   214→        credentialInjectionMs,\n   215→        proxyStartupMs,\n   216→        cliRuntimeMs,\n   217→        cleanupMs,\n   218→      };\n   219→\n   220→      this.logger.info({\n   221→        executionId: assignment.executionId,\n   222→        exitCode,\n   223→        durationMs,\n   224→        status,\n   225→        sessionId: this.sessionId,\n   226→        totalCostUsd: this.totalCostUsd,\n   227→        phaseTimings,\n   228→      }, 'Execution finished');\n   229→\n   230→      if (completedNormally) {\n   231→        callbacks.onComplete(status, exitCode, durationMs, this.sessionId, this.totalCostUsd, phaseTimings);\n   232→      }\n   233→    }\n   234→  }\n   235→\n   236→  kill(): void {\n   237→    if (this.childProcess && !this.killed) {\n   238→      this.killed = true;\n   239→      this.childProcess.kill('SIGTERM');\n   240→\n   241→      // Force kill after 5 seconds\n   242→      setTimeout(() => {\n   243→        if (this.childProcess) {\n   244→          this.childProcess.kill('SIGKILL');\n   245→        }\n   246→      }, 5_000);\n   247→    }\n   248→  }\n   249→}\n   250→"}]},"parent_tool_use_id":"toolu_01QCDZ6LeM8HYDps8f9rJDrU","session_id":"a6611918-5700-489e-b074-66c80e703fff","uuid":"bf91e5e0-7f89-4efb-8ffd-f9a4319dd96d","timestamp":"2026-03-18T17:36:58.146Z"}
