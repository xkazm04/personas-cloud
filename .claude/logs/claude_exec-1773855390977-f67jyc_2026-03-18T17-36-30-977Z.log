vate logger: Logger,\n    53→    tlsConfig?: WorkerTlsConfig,\n    54→    opts?: { imageDigest?: string; claudeCliVersion?: string },\n    55→  ) {\n    56→    this.tlsConfig = tlsConfig;\n    57→    this.imageDigest = opts?.imageDigest || '';\n    58→    this.claudeCliVersion = opts?.claudeCliVersion || '';\n    59→\n    60→    if (tlsConfig) {\n    61→      this.cachedTlsOptions = {\n    62→        rejectUnauthorized: tlsConfig.rejectUnauthorized,\n    63→      };\n    64→      if (tlsConfig.caPath) {\n    65→        this.cachedTlsOptions.ca = fs.readFileSync(tlsConfig.caPath);\n    66→      }\n    67→      if (tlsConfig.certPath && tlsConfig.keyPath) {\n    68→        this.cachedTlsOptions.cert = fs.readFileSync(tlsConfig.certPath);\n    69→        this.cachedTlsOptions.key = fs.readFileSync(tlsConfig.keyPath);\n    70→      }\n    71→    }\n    72→  }\n    73→\n    74→  connect(): void {\n    75→    if (this.shuttingDown) return;\n    76→\n    77→    this.logger.info({ url: this.orchestratorUrl, workerId: this.workerId }, 'Connecting to orchestrator');\n    78→\n    79→    const wsOptions: WebSocket.ClientOptions = {\n    80→      ...this.cachedTlsOptions,\n    81→      headers: {\n    82→        Authorization: `Bearer ${this.workerToken}`,\n    83→      },\n    84→    };\n    85→\n    86→    this.ws = new WebSocket(this.orchestratorUrl, wsOptions);\n    87→\n    88→    this.ws.on('open', () => {\n    89→      this.connected = true;\n    90→      this.reconnectDelay = INITIAL_RECONNECT_DELAY_MS;\n    91→\n    92→      // Send hello\n    93→      this.send({\n    94→        type: 'hello',\n    95→        workerId: this.workerId,\n    96→        version: PROTOCOL_VERSION,\n    97→        capabilities: ['claude-cli', 'node', 'git', 'network-policy'],\n    98→        ...(this.imageDigest ? { imageDigest: this.imageDigest } : {}),\n    99→        ...(this.claudeCliVersion ? { claudeCliVersion: this.claudeCliVersion } : {}),\n   100→      });\n   101→\n   102→      // Start heartbeat\n   103→      this.heartbeatTimer = setInterval(() => {\n   104→        this.send({ type: 'heartbeat', timestamp: Date.now() });\n   105→      }, HEARTBEAT_INTERVAL_MS);\n   106→\n   107→      this.logger.info('Connected to orchestrator');\n   108→    });\n   109→\n   110→    this.ws.on('message', (raw: Buffer) => {\n   111→      const msg = parseOrchestratorMessage(raw.toString());\n   112→      if (!msg) {\n   113→        this.logger.warn('Invalid message from orchestrator');\n   114→        return;\n   115→      }\n   116→\n   117→      this.handleMessage(msg);\n   118→    });\n   119→\n   120→    this.ws.on('close', (code: number, reason: Buffer) => {\n   121→      this.logger.info({ code, reason: reason.toString() }, 'Disconnected from orchestrator');\n   122→      this.cleanup();\n   123→      this.scheduleReconnect();\n   124→    });\n   125→\n   126→    this.ws.on('error', (err: Error) => {\n   127→      this.logger.error({ err }, 'WebSocket error');\n   128→      // 'close' will follow, which handles reconnection\n   129→    });\n   130→  }\n   131→\n   132→  private handleMessage(msg: OrchestratorMessage): void {\n   133→    switch (msg.type) {\n   134→      case 'ack':\n   135→        this.logger.info({ workerId: msg.workerId }, 'Received ack from orchestrator');\n   136→        // Send ready after ack\n   137→        this.sendReady();\n   138→        break;\n   139→\n   140→      case 'assign':\n   141→        this.logger.info({ executionId: msg.executionId, personaId: msg.personaId }, 'Received execution assignment');\n   142→        this.callbacks.onAssign(msg);\n   143→        break;\n   144→\n   145→      case 'cancel':\n   146→        this.logger.info({ executionId: msg.executionId }, 'Received cancel');\n   147→        this.callbacks.onCancel(msg);\n   148→        break;\n   149→\n   150→      case 'shutdown':\n   151→        this.logger.info({ reason: msg.reason }, 'Received shutdown');\n   152→        this.shuttingDown = true;\n   153→        this.callbacks.onShutdown(msg);\n   154→        break;\n   155→\n   156→      case 'heartbeat':\n   157→        // Orchestrator heartbeat — no action needed\n   158→        break;\n   159→    }\n   160→  }\n   161→\n   162→  send(msg: WorkerMessage): boolean {\n   163→    if (!this.ws || this.ws.readyState !== WebSocket.OPEN) {\n   164→      this.logger.warn({ type: msg.type }, 'Cannot send — not connected');\n   165→      return false;\n   166→    }\n   167→\n   168→    this.ws.send(serializeMessage(msg));\n   169→    return true;\n   170→  }\n   171→\n   172→  sendReady(): void {\n   173→    this.send({ type: 'ready' });\n   174→  }\n   175→\n   176→  sendBusy(executionId: string, reason: string): void {\n   177→    this.send({ type: 'busy', executionId, reason });\n   178→  }\n   179→\n   180→  sendStdout(executionId: string, chunk: string): void {\n   181→    this.send({\n   182→      type: 'stdout',\n   183→      executionId,\n   184→      chunk,\n   185→      timestamp: Date.now(),\n   186→    });\n   187→  }\n   188→\n   189→  sendStderr(executionId: string, chunk: string): void {\n   190→    this.send({\n   191→      type: 'stderr',\n   192→      executionId,\n   193→      chunk,\n   194→      timestamp: Date.now(),\n   195→    });\n   196→  }\n   197→\n   198→  sendComplete(\n   199→    executionId: string,\n   200→    status: 'completed' | 'failed' | 'cancelled',\n   201→    exitCode: number,\n   202→    durationMs: number,\n   203→    sessionId?: string,\n   204→    totalCostUsd?: number,\n   205→    phaseTimings?: PhaseTimings,\n   206→  ): void {\n   207→    this.send({\n   208→      type: 'complete',\n   209→      executionId,\n   210→      status,\n   211→      exitCode,\n   212→      durationMs,\n   213→      sessionId,\n   214→      totalCostUsd,\n   215→      phaseTimings,\n   216→    });\n   217→  }\n   218→\n   219→  sendProgress(executionId: string, phase: string, percent: number, detail?: string): void {\n   220→    this.send({\n   221→      type: 'progress',\n   222→      executionId,\n   223→      phase,\n   224→      percent,\n   225→      detail,\n   226→      timestamp: Date.now(),\n   227→    });\n   228→  }\n   229→\n   230→  sendEvent(executionId: string, eventType: 'manual_review' | 'user_message' | 'persona_action' | 'emit_event', payload: unknown): void {\n   231→    this.send({\n   232→      type: 'event',\n   233→      executionId,\n   234→      eventType,\n   235→      payload,\n   236→    });\n   237→  }\n   238→\n   239→  private cleanup(): void {\n   240→    this.connected = false;\n   241→    if (this.heartbeatTimer) {\n   242→      clearInterval(this.heartbeatTimer);\n   243→      this.heartbeatTimer = undefined;\n   244→    }\n   245→  }\n   246→\n   247→  private scheduleReconnect(): void {\n   248→    if (this.shuttingDown) return;\n   249→\n   250→    this.logger.info({ delayMs: this.reconnectDelay }, 'Scheduling reconnect');\n   251→\n   252→    this.reconnectTimer = setTimeout(() => {\n   253→      this.connect();\n   254→    }, this.reconnectDelay);\n   255→\n   256→    // Exponential backoff\n   257→    this.reconnectDelay = Math.min(this.reconnectDelay * 2, MAX_RECONNECT_DELAY_MS);\n   258→  }\n   259→\n   260→  disconnect(): void {\n   261→    this.shuttingDown = true;\n   262→    this.cleanup();\n   263→    if (this.reconnectTimer) {\n   264→      clearTimeout(this.reconnectTimer);\n   265→    }\n   266→    if (this.ws) {\n   267→      this.ws.close(1000, 'Worker shutting down');\n   268→    }\n   269→  }\n   270→\n   271→  isConnected(): boolean {\n   272→    return this.connected;\n   273→  }\n   274→}\n   275→"}]},"parent_tool_use_id":"toolu_01QCDZ6LeM8HYDps8f9rJDrU","session_id":"a6611918-5700-489e-b074-66c80e703fff","uuid":"3446378a-2bdc-445b-8851-16e5570d91d0","timestamp":"2026-03-18T17:36:58.038Z"}
