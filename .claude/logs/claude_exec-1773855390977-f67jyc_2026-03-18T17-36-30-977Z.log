[2026-03-18T17:41:52.488Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016eTXTLFZk65uvoKzaZq1fp","type":"tool_result","content":"     1→import type { ChildProcess } from 'node:child_process';\n     2→import { spawn } from 'node:child_process';\n     3→import type { ExecAssign, PhaseTimings } from '@dac-cloud/shared';\n     4→import { LineBuffer, extractStreamEvents } from './parser.js';\n     5→import { prepareSandbox, cleanupSandbox, type SandboxConfig } from './sandbox.js';\n     6→import { startFilterProxy, type ProxyHandle } from './networkProxy.js';\n     7→import { injectCredentialsViaFile, type InjectedCredentials } from './credentialInjector.js';\n     8→import { parseNetworkPolicy } from '@dac-cloud/shared';\n     9→import type { Logger } from 'pino';\n    10→\n    11→export interface ExecutorCallbacks {\n    12→  onStdout(chunk: string, timestamp: number): void;\n    13→  onStderr(chunk: string, timestamp: number): void;\n    14→  onEvent(eventType: 'manual_review' | 'user_message' | 'persona_action' | 'emit_event', payload: unknown): void;\n    15→  onProgress(phase: string, percent: number, detail?: string): void;\n    16→  onComplete(status: 'completed' | 'failed' | 'cancelled', exitCode: number, durationMs: number, sessionId?: string, totalCostUsd?: number, phaseTimings?: PhaseTimings): void;\n    17→}\n    18→\n    19→export interface ExecutorStatus {\n    20→  state: 'idle' | 'busy';\n    21→  executionId?: string;\n    22→  durationMs?: number;\n    23→}\n    24→\n    25→export class Executor {\n    26→  private childProcess: ChildProcess | null = null;\n    27→  private killed = false;\n    28→  private sessionId: string | undefined;\n    29→  private totalCostUsd: number | undefined;\n    30→  private currentExecutionId: string | null = null;\n    31→  private executionStartTime: number | null = null;\n    32→\n    33→  /**\n    34→   * Resolves when the current execution (including its finally-block cleanup)\n    35→   * finishes.  Null when idle.\n    36→   */\n    37→  private executionDone: Promise<void> | null = null;\n    38→\n    39→  constructor(private logger: Logger) {}\n    40→\n    41→  getStatus(): ExecutorStatus {\n    42→    if (this.currentExecutionId && this.executionStartTime) {\n    43→      return {\n    44→        state: 'busy',\n    45→        executionId: this.currentExecutionId,\n    46→        durationMs: Date.now() - this.executionStartTime,\n    47→      };\n    48→    }\n    49→    return { state: 'idle' };\n    50→  }\n    51→\n    52→  /**\n    53→   * Returns a promise that resolves once the in-flight execution's cleanup\n    54→   * (sandbox removal, credential deletion, proxy teardown) has finished.\n    55→   * If no execution is active, resolves immediately.\n    56→   *\n    57→   * An optional `timeoutMs` ensures the caller is never blocked forever\n    58→   * (defaults to 10 s).\n    59→   */\n    60→  waitForCleanup(timeoutMs = 10_000): Promise<void> {\n    61→    if (!this.executionDone) return Promise.resolve();\n    62→\n    63→    return Promise.race([\n    64→      this.executionDone,\n    65→      new Promise<void>((resolve) => setTimeout(resolve, timeoutMs)),\n    66→    ]);\n    67→  }\n    68→\n    69→  private processStdoutLine(line: string, callbacks: ExecutorCallbacks): void {\n    70→    callbacks.onStdout(line, Date.now());\n    71→\n    72→    const streamEvents = extractStreamEvents(line, this.logger);\n    73→    if (streamEvents.sessionId) this.sessionId = streamEvents.sessionId;\n    74→    if (streamEvents.totalCostUsd) this.totalCostUsd = streamEvents.totalCostUsd;\n    75→    for (const event of streamEvents.personaEvents) {\n    76→      callbacks.onEvent(event.eventType, event.payload);\n    77→    }\n    78→    if (streamEvents.progress) {\n    79→      callbacks.onProgress(streamEvents.progress.phase, streamEvents.progress.percent, streamEvents.progress.detail);\n    80→    }\n    81→  }\n    82→\n    83→  /** Returns true if an execution is currently in progress. */\n    84→  isBusy(): boolean {\n    85→    return this.childProcess !== null;\n    86→  }\n    87→\n    88→  async execute(assignment: ExecAssign, callbacks: ExecutorCallbacks): Promise<void> {\n    89→    const run = this.doExecute(assignment, callbacks);\n    90→    this.executionDone = run.catch((err) => {\n    91→      this.logger.warn({ err, executionId: assignment.executionId, operation: 'execute' }, 'Execution promise swallowed');\n    92→    });   // swallow – callers handle errors via callbacks\n    93→    try {\n    94→      await run;\n    95→    } finally {\n    96→      this.executionDone = null;\n    97→    }\n    98→  }\n    99→\n   100→  private async doExecute(assignment: ExecAssign, callbacks: ExecutorCallbacks): Promise<void> {\n   101→    const startTime = Date.now();\n   102→    this.currentExecutionId = assignment.executionId;\n   103→    this.executionStartTime = startTime;\n   104→    this.sessionId = undefined;\n   105→    this.totalCostUsd = undefined;\n   106→\n   107→    const netPolicy = assignment.config.networkPolicy ?? undefined;\n   108→    const sandboxConfig: SandboxConfig = {\n   109→      executionId: assignment.executionId,\n   110→      env: { ...assignment.env },\n   111→      networkAccess: !netPolicy, // full access only if no policy set\n   112→      networkPolicy: netPolicy,\n   113→      timeoutMs: assignment.config.timeoutMs,\n   114→      maxBudgetUsd: assignment.config.maxBudgetUsd,\n   115→      maxTurns: assignment.config.maxTurns,\n   116→    };\n   117→\n   118→    let t0 = Date.now();\n   119→    const sandbox = prepareSandbox(sandboxConfig, this.logger);\n   120→    const sandboxSetupMs = Date.now() - t0;\n   121→\n   122→    let proxy: ProxyHandle | null = null;\n   123→    let injectedCreds: InjectedCredentials | null = null;\n   124→    let proxyStartupMs: number | null = null;\n   125→    let credentialInjectionMs = 0;\n   126→    let cliRuntimeMs = 0;\n   127→    let exitCode = 1;\n   128→    let completedNormally = false;\n   129→\n   130→    this.logger.info({\n   131→      executionId: assignment.executionId,\n   132→      personaId: assignment.personaId,\n   133→      sandboxDir: sandbox.sandboxDir,\n   134→      timeoutMs: assignment.config.timeoutMs,\n   135→    }, 'Starting execution');\n   136→\n   137→    try {\n   138→      // Start filtering proxy for allow-list network policies\n   139→      if (sandbox.proxyRequired && netPolicy) {\n   140→        t0 = Date.now();\n   141→        proxy = await startFilterProxy(netPolicy, this.logger, assignment.executionId);\n   142→        proxyStartupMs = Date.now() - t0;\n   143→        const proxyUrl = `http://127.0.0.1:${proxy.port}`;\n   144→        sandbox.env['HTTP_PROXY'] = proxyUrl;\n   145→        sandbox.env['HTTPS_PROXY'] = proxyUrl;\n   146→        sandbox.env['http_proxy'] = proxyUrl;\n   147→        sandbox.env['https_proxy'] = proxyUrl;\n   148→        sandbox.env['NO_PROXY'] = '';\n   149→      }\n   150→\n   151→      // Inject credentials via async file write (unblocks event loop)\n   152→      t0 = Date.now();\n   153→      injectedCreds = await injectCredentialsViaFile(sandbox.env, assignment.executionId, this.logger);\n   154→      credentialInjectionMs = Date.now() - t0;\n   155→      sandbox.env[injectedCreds.envPointerKey] = injectedCreds.credentialFilePath;\n   156→\n   157→      const cliStartTime = Date.now();\n   158→      this.childProcess = spawn(sandbox.command, sandbox.args, {\n   159→        cwd: sandbox.cwd,\n   160→        stdio: ['pipe', 'pipe', 'pipe'],\n   161→        env: sandbox.env,\n   162→      });\n   163→\n   164→      // Pipe prompt to stdin\n   165→      this.childProcess.stdin!.write(assignment.prompt);\n   166→      this.childProcess.stdin!.end();\n   167→\n   168→      // Set up timeout\n   169→      const timeoutHandle = setTimeout(() => {\n   170→        this.logger.warn({\n   171→          executionId: assignment.executionId,\n   172→          timeoutMs: assignment.config.timeoutMs,\n   173→        }, 'Execution timeout, killing process');\n   174→        this.kill();\n   175→      }, assignment.config.timeoutMs);\n   176→\n   177→      // Parse stdout\n   178→      const stdoutBuffer = new LineBuffer();\n   179→      this.childProcess.stdout!.on('data', (data: Buffer) => {\n   180→        const lines = stdoutBuffer.push(data.toString());\n   181→        for (const line of lines) {\n   182→          this.processStdoutLine(line, callbacks);\n   183→        }\n   184→      });\n   185→\n   186→      // Parse stderr\n   187→      const stderrBuffer = new LineBuffer();\n   188→      this.childProcess.stderr!.on('data', (data: Buffer) => {\n   189→        const lines = stderrBuffer.push(data.toString());\n   190→        for (const line of lines) {\n   191→          callbacks.onStderr(line, Date.now());\n   192→        }\n   193→      });\n   194→\n   195→      // Wait for process to exit\n   196→      exitCode = await new Promise<number>((resolve) => {\n   197→        this.childProcess!.on('close', (code: number | null) => {\n   198→          clearTimeout(timeoutHandle);\n   199→          resolve(code ?? 1);\n   200→        });\n   201→\n   202→        this.childProcess!.on('error', (err: Error) => {\n   203→          clearTimeout(timeoutHandle);\n   204→          this.logger.error({ err, executionId: assignment.executionId }, 'Process spawn error');\n   205→          resolve(1);\n   206→        });\n   207→      });\n   208→\n   209→      // Flush remaining buffered data\n   210→      for (const line of stdoutBuffer.flush()) {\n   211→        this.processStdoutLine(line, callbacks);\n   212→      }\n   213→      for (const line of stderrBuffer.flush()) {\n   214→        callbacks.onStderr(line, Date.now());\n   215→      }\n   216→\n   217→      cliRuntimeMs = Date.now() - cliStartTime;\n   218→      completedNormally = true;\n   219→\n   220→    } finally {\n   221→      const wasKilled = this.killed;\n   222→      const cleanupStart = Date.now();\n   223→      if (injectedCreds) await injectedCreds.cleanup().catch(() => {});\n   224→      if (proxy) proxy.cleanup();\n   225→      cleanupSandbox(sandbox.sandboxDir, this.logger);\n   226→      this.childProcess = null;\n   227→      this.killed = false;\n   228→      this.currentExecutionId = null;\n   229→      this.executionStartTime = null;\n   230→      const cleanupMs = Date.now() - cleanupStart;\n   231→\n   232→      const durationMs = Date.now() - startTime;\n   233→      const status = wasKilled ? 'cancelled' : (exitCode === 0 ? 'completed' : 'failed');\n   234→\n   235→      const phaseTimings: PhaseTimings = {\n   236→        sandboxSetupMs,\n   237→        credentialInjectionMs,\n   238→        proxyStartupMs,\n   239→        cliRuntimeMs,\n   240→        cleanupMs,\n   241→      };\n   242→\n   243→      this.logger.info({\n   244→        executionId: assignment.executionId,\n   245→        exitCode,\n   246→        durationMs,\n   247→        status,\n   248→        sessionId: this.sessionId,\n   249→        totalCostUsd: this.totalCostUsd,\n   250→        phaseTimings,\n   251→      }, 'Execution finished');\n   252→\n   253→      if (completedNormally) {\n   254→        callbacks.onComplete(status, exitCode, durationMs, this.sessionId, this.totalCostUsd, phaseTimings);\n   255→      }\n   256→    }\n   257→  }\n   258→\n   259→  kill(): void {\n   260→    if (this.childProcess && !this.killed) {\n   261→      this.killed = true;\n   262→      this.childProcess.kill('SIGTERM');\n   263→\n   264→      // Force kill after 5 seconds\n   265→      setTimeout(() => {\n   266→        if (this.childProcess) {\n   267→          this.childProcess.kill('SIGKILL');\n   268→        }\n   269→      }, 5_000);\n   270→    }\n   271→  }\n   272→}\n   273→"}]},"parent_tool_use_id":null,"session_id":"a6611918-5700-489e-b074-66c80e703fff","uuid":"63c5cd2b-5ebe-49d1-86bb-ebe88c7e13b0","t