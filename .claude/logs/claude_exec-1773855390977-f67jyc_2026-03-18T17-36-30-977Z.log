[2026-03-18T17:39:44.886Z] [STDOUT] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01CdEcQCFRMPYEMJDbWEnQyE","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NrQBc4PMPyEHjJxq3dp5Bz","name":"Write","input":{"file_path":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\worker\\src\\healthProbe.ts","content":"import http from 'node:http';\nimport fs from 'node:fs';\nimport os from 'node:os';\nimport type { Logger } from 'pino';\nimport type { Connection } from './connection.js';\nimport type { Executor } from './executor.js';\nimport { isSandboxAvailable } from './sandbox.js';\nimport { getActiveCredentialFileCount } from './credentialInjector.js';\n\nexport interface HealthDeps {\n  connection: Connection;\n  executor: Executor;\n  workerId: string;\n}\n\ninterface DiskSpace {\n  path: string;\n  availableMb: number;\n  totalMb: number;\n}\n\nfunction getDiskSpace(dir: string): DiskSpace | null {\n  try {\n    const stats = fs.statfsSync(dir);\n    return {\n      path: dir,\n      availableMb: Math.round((stats.bavail * stats.bsize) / (1024 * 1024)),\n      totalMb: Math.round((stats.blocks * stats.bsize) / (1024 * 1024)),\n    };\n  } catch {\n    return null;\n  }\n}\n\nfunction buildHealthPayload(deps: HealthDeps) {\n  const executorStatus = deps.executor.getStatus();\n\n  const tmpdir = os.tmpdir();\n  const disk: Record<string, DiskSpace> = {};\n  const tmpSpace = getDiskSpace(tmpdir);\n  if (tmpSpace) disk['tmpdir'] = tmpSpace;\n\n  if (process.platform === 'linux' && fs.existsSync('/dev/shm')) {\n    const shmSpace = getDiskSpace('/dev/shm');\n    if (shmSpace) disk['devShm'] = shmSpace;\n  }\n\n  return {\n    status: executorStatus.state === 'idle' && deps.connection.getConnectionState() === 'connected' ? 'healthy' : 'degraded',\n    workerId: deps.workerId,\n    uptime: Math.round(process.uptime()),\n    connection: deps.connection.getConnectionState(),\n    execution: executorStatus,\n    sandbox: { bwrapAvailable: isSandboxAvailable() },\n    disk,\n    credentials: { activeFileCount: getActiveCredentialFileCount() },\n  };\n}\n\nexport function startHealthProbe(port: number, deps: HealthDeps, logger: Logger): http.Server {\n  const server = http.createServer((req, res) => {\n    if (req.method !== 'GET') {\n      res.writeHead(405);\n      res.end();\n      return;\n    }\n\n    if (req.url === '/healthz' || req.url === '/health') {\n      const payload = buildHealthPayload(deps);\n      const body = JSON.stringify(payload);\n      res.writeHead(200, { 'Content-Type': 'application/json' });\n      res.end(body);\n      return;\n    }\n\n    if (req.url === '/readyz' || req.url === '/ready') {\n      const connState = deps.connection.getConnectionState();\n      if (connState === 'connected' && !deps.executor.isBusy()) {\n        res.writeHead(200, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ ready: true }));\n      } else {\n        res.writeHead(503, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ ready: false, connection: connState, busy: deps.executor.isBusy() }));\n      }\n      return;\n    }\n\n    if (req.url === '/livez' || req.url === '/live') {\n      res.writeHead(200, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ alive: true }));\n      return;\n    }\n\n    res.writeHead(404);\n    res.end();\n  });\n\n  server.listen(port, '0.0.0.0', () => {\n    logger.info({ port }, 'Health probe listening');\n  });\n\n  server.on('error', (err) => {\n    logger.error({ err, port }, 'Health probe server error');\n  });\n\n  return server;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":266,"cache_read_input_tokens":51782,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":266},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":nu