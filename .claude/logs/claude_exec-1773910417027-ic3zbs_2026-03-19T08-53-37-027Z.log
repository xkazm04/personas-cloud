[2026-03-19T08:54:13.809Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TuDLX8MS1tsFB6RUbhXbx3","type":"tool_result","content":"     1→import path from 'node:path';\n     2→import pino from 'pino';\n     3→import { loadConfig } from './config.js';\n     4→import { createAuth } from './auth.js';\n     5→import { createTokenManager } from './tokenManager.js';\n     6→import { OAuthManager } from './oauth.js';\n     7→import { WorkerPool } from './workerPool.js';\n     8→import { createKafkaClient, createNoopKafkaClient } from './kafka.js';\n     9→import { Dispatcher } from './dispatcher.js';\n    10→import { createHttpApi } from './httpApi.js';\n    11→import { initDb } from './db.js';\n    12→import { startEventProcessor } from './eventProcessor.js';\n    13→import { startTriggerScheduler } from './triggerScheduler.js';\n    14→import { TOPICS, type ExecRequest } from '@dac-cloud/shared';\n    15→\n    16→const logger = pino({ level: process.env['LOG_LEVEL'] || 'info' });\n    17→\n    18→async function main() {\n    19→  logger.info('Starting DAC Cloud Orchestrator...');\n    20→\n    21→  // Load configuration\n    22→  const config = loadConfig();\n    23→  logger.info({\n    24→    kafkaEnabled: config.kafkaEnabled,\n    25→    wsPort: config.wsPort,\n    26→    httpPort: config.httpPort,\n    27→    hasDirectToken: !!config.claudeToken,\n    28→  }, 'Configuration loaded');\n    29→\n    30→  // Initialize components\n    31→  const auth = createAuth(config.teamApiKey, config.supabaseJwtSecret || undefined);\n    32→  const tokenManager = createTokenManager(config.masterKey, logger);\n    33→  const oauth = new OAuthManager(logger);\n    34→\n    35→  // If a direct Claude token is provided (from setup-token), store it\n    36→  if (config.claudeToken) {\n    37→    tokenManager.storeClaudeToken(config.claudeToken);\n    38→    logger.info('Direct Claude token loaded from environment');\n    39→  } else {\n    40→    logger.info('No direct Claude token — use OAuth flow via POST /api/oauth/authorize');\n    41→  }\n    42→\n    43→  // Database\n    44→  const dbPath = process.env['DAC_DB_PATH'] || path.join(process.cwd(), 'data', 'personas.db');\n    45→  const database = initDb(dbPath, logger);\n    46→\n    47→  // Worker pool (WebSocket server)\n    48→  const pool = new WorkerPool(config.workerToken, logger);\n    49→\n    50→  // Kafka client\n    51→  const kafka = config.kafkaEnabled\n    52→    ? createKafkaClient(config.kafkaBrokers, config.kafkaUsername, config.kafkaPassword, logger)\n    53→    : createNoopKafkaClient(logger);\n    54→\n    55→  // Dispatcher — uses OAuth manager for token refresh\n    56→  const dispatcher = new Dispatcher(pool, tokenManager, oauth, kafka, logger);\n    57→  dispatcher.setDatabase(database);\n    58→  dispatcher.setMasterKey(config.masterKey);\n    59→\n    60→  // Connect Kafka\n    61→  if (config.kafkaEnabled) {\n    62→    await kafka.connect();\n    63→\n    64→    // Subscribe to execution requests\n    65→    await kafka.subscribe(async (topic: string, value: string) => {\n    66→      if (topic === TOPICS.EXEC_REQUESTS) {\n    67→        try {\n    68→          const request: ExecRequest = JSON.parse(value);\n    69→          dispatcher.submit(request);\n    70→        } catch (err) {\n    71→          logger.error({ err }, 'Failed to parse execution request from Kafka');\n    72→        }\n    73→      }\n    74→    });\n    75→  }\n    76→\n    77→  // Start WebSocket server for workers\n    78→  pool.listen(config.wsPort);\n    79→\n    80→  // Start HTTP API (now includes OAuth endpoints + persona CRUD)\n    81→  const httpServer = createHttpApi(auth, dispatcher, pool, tokenManager, oauth, logger, database);\n    82→  httpServer.listen(config.httpPort, () => {\n    83→    logger.info({ port: config.httpPort }, 'HTTP API listening');\n    84→  });\n    85→\n    86→  // Start event processor (2s tick) and trigger scheduler (5s tick)\n    87→  const eventProcessorTimer = startEventProcessor(database, dispatcher, logger);\n    88→  const triggerSchedulerTimer = startTriggerScheduler(database, logger);\n    89→\n    90→  // Token refresh loop — refresh OAuth token proactively every 30 minutes\n    91→  setInterval(async () => {\n    92→    if (oauth.hasTokens()) {\n    93→      const token = await oauth.getValidAccessToken();\n    94→      if (token) {\n    95→        tokenManager.storeClaudeToken(token);\n    96→      }\n    97→    }\n    98→  }, 30 * 60 * 1000);\n    99→\n   100→  // Log status periodically\n   101→  setInterval(() => {\n   102→    const counts = pool.getWorkerCount();\n   103→    const queueLen = dispatcher.getQueueLength();\n   104→    if (counts.total > 0 || queueLen > 0) {\n   105→      logger.info({\n   106→        workers: counts,\n   107→        queueLength: queueLen,\n   108→        activeExecutions: dispatcher.getActiveExecutions().length,\n   109→        hasOAuth: oauth.hasTokens(),\n   110→      }, 'Status');\n   111→    }\n   112→  }, 60_000);\n   113→\n   114→  // Graceful shutdown\n   115→  const shutdown = async () => {\n   116→    logger.info('Shutting down...');\n   117→    clearInterval(eventProcessorTimer);\n   118→    clearInterval(triggerSchedulerTimer);\n   119→    dispatcher.shutdown();\n   120→    pool.shutdown();\n   121→    await kafka.disconnect();\n   122→    httpServer.close();\n   123→    database.close();\n   124→    process.exit(0);\n   125→  };\n   126→\n   127→  process.on('SIGINT', shutdown);\n   128→  process.on('SIGTERM', shutdown);\n   129→\n   130→  logger.info('DAC Cloud Orchestrator ready');\n   131→  logger.info(`  HTTP API: http://localhost:${config.httpPort}`);\n   132→  logger.info(`  Worker WS: ws://localhost:${config.wsPort}`);\n   133→  if (!config.claudeToken) {\n   134→    logger.info('  Connect subscription: POST /api/oauth/authorize');\n   135→  }\n   136→}\n   137→\n   138→main().catch((err) => {\n   139→  logger.fatal({ err }, 'Failed to start orchestrator');\n   140→  process.exit(1);\n   141→});\n   142→"}]},"parent_tool_use_id":"toolu_01K91VrZmXpE8J8MvygPBg3v","session_id":"b8c72731-09c7-48ee-b1d6-3b6918a239e2","uuid":"1038a750-acc4-4963-8351-3747b12d7782","timestamp":"2026-03-19T08:54:13.590Z"}
