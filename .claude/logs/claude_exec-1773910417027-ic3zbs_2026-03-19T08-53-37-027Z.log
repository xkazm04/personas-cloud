[2026-03-19T08:56:35.756Z] [STDOUT] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01MsQwtHNWXi8dVsja2vuHBV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01A1tWpNsBWjhaGjV5tiQeZP","name":"Write","input":{"file_path":"C:\\Users\\kazda\\kiro\\personas-cloud\\.claude\\worktrees\\purring-enchanting-quasar\\packages\\orchestrator\\src\\retention.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\n\n// ---------------------------------------------------------------------------\n// Retention policy types\n// ---------------------------------------------------------------------------\n\nexport interface RetentionPolicy {\n  /** Table name in SQLite */\n  table: string;\n  /** Column that holds the date/timestamp to compare against */\n  timestampColumn: string;\n  /** 'ephemeral' tables are purged by retention; 'persistent' are kept */\n  lifecycle: 'ephemeral' | 'persistent';\n}\n\n// ---------------------------------------------------------------------------\n// Table registry — every table that should be subject to retention\n// ---------------------------------------------------------------------------\n\nexport const TABLE_REGISTRY: RetentionPolicy[] = [\n  {\n    table: 'daily_metrics',\n    timestampColumn: 'date',\n    lifecycle: 'ephemeral',\n  },\n  {\n    table: 'system_daily_metrics',\n    timestampColumn: 'date',\n    lifecycle: 'ephemeral',\n  },\n];\n\n// ---------------------------------------------------------------------------\n// runRetention — deletes rows older than the configured retention window\n// ---------------------------------------------------------------------------\n\n/**\n * Purge rows from all ephemeral tables whose timestamp column is older than\n * `retentionDays` days ago.\n *\n * Returns the total number of rows deleted across all tables.\n */\nexport function runRetention(\n  db: Database.Database,\n  retentionDays: number,\n  logger: Logger,\n): number {\n  const cutoff = new Date();\n  cutoff.setDate(cutoff.getDate() - retentionDays);\n  const cutoffIso = cutoff.toISOString().slice(0, 10); // YYYY-MM-DD\n\n  let totalDeleted = 0;\n\n  for (const policy of TABLE_REGISTRY) {\n    if (policy.lifecycle !== 'ephemeral') continue;\n\n    const result = db\n      .prepare(`DELETE FROM ${policy.table} WHERE ${policy.timestampColumn} < ?`)\n      .run(cutoffIso);\n\n    const deleted = result.changes;\n    if (deleted > 0) {\n      logger.info(\n        { table: policy.table, deleted, cutoff: cutoffIso },\n        'Retention: purged old rows',\n      );\n    }\n    totalDeleted += deleted;\n  }\n\n  if (totalDeleted === 0) {\n    logger.debug({ cutoff: cutoffIso }, 'Retention: no rows to purge');\n  }\n\n  return totalDeleted;\n}\n\n// ---------------------------------------------------------------------------\n// startRetentionScheduler — runs retention on a periodic interval\n// ---------------------------------------------------------------------------\n\n/**\n * Starts a repeating timer that runs retention every `intervalMs` milliseconds.\n * Runs once immediately on startup, then repeats.\n *\n * Default interval: 1 hour.\n */\nexport function startRetentionScheduler(\n  db: Database.Database,\n  retentionDays: number,\n  logger: Logger,\n  intervalMs: number = 60 * 60 * 1000,\n): ReturnType<typeof setInterval> {\n  // Run once immediately\n  try {\n    runRetention(db, retentionDays, logger);\n  } catch (err) {\n    logger.error({ err }, 'Retention: initial run failed');\n  }\n\n  // Then repeat on interval\n  return setInterval(() => {\n    try {\n      runRetention(db, retentionDays, logger);\n    } catch (err) {\n      logger.error({ err }, 'Retention: scheduled run failed');\n    }\n  }, intervalMs);\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":189,"cache_read_input_tokens":49329,"cache_creation":{"ephemeral_5m_