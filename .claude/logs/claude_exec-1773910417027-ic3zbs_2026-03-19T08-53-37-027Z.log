[2026-03-19T08:54:14.469Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014e4WefXewdaeFwx9C2y9vu","type":"tool_result","content":"     1→import pino from 'pino';\n     2→import { loadConfig } from './config.js';\n     3→import { Connection } from './connection.js';\n     4→import { Executor } from './executor.js';\n     5→import type { ExecAssign } from '@dac-cloud/shared';\n     6→\n     7→const logger = pino({ level: process.env['LOG_LEVEL'] || 'info' });\n     8→\n     9→async function main() {\n    10→  logger.info('Starting DAC Cloud Worker...');\n    11→\n    12→  const config = loadConfig();\n    13→  logger.info({ workerId: config.workerId, orchestratorUrl: config.orchestratorUrl }, 'Configuration loaded');\n    14→\n    15→  const executor = new Executor(logger);\n    16→  let currentExecutionId: string | null = null;\n    17→\n    18→  const connection = new Connection(\n    19→    config.orchestratorUrl,\n    20→    config.workerId,\n    21→    config.workerToken,\n    22→    {\n    23→      onAssign(msg: ExecAssign) {\n    24→        currentExecutionId = msg.executionId;\n    25→\n    26→        executor.execute(msg, {\n    27→          onStdout(chunk: string, timestamp: number) {\n    28→            connection.sendStdout(msg.executionId, chunk);\n    29→          },\n    30→\n    31→          onStderr(chunk: string, timestamp: number) {\n    32→            logger.warn({ executionId: msg.executionId, stderr: chunk }, 'CLI stderr');\n    33→            connection.sendStderr(msg.executionId, chunk);\n    34→          },\n    35→\n    36→          onEvent(eventType: string, payload: unknown) {\n    37→            connection.sendEvent(msg.executionId, eventType, payload);\n    38→          },\n    39→\n    40→          onComplete(status, exitCode, durationMs, sessionId, totalCostUsd) {\n    41→            connection.sendComplete(msg.executionId, status, exitCode, durationMs, sessionId, totalCostUsd);\n    42→            currentExecutionId = null;\n    43→\n    44→            // Signal ready for next assignment\n    45→            connection.sendReady();\n    46→          },\n    47→        }).catch((err) => {\n    48→          logger.error({ err, executionId: msg.executionId }, 'Execution error');\n    49→          connection.sendComplete(msg.executionId, 'failed', 1, 0);\n    50→          currentExecutionId = null;\n    51→          connection.sendReady();\n    52→        });\n    53→      },\n    54→\n    55→      onCancel(msg) {\n    56→        if (currentExecutionId === msg.executionId) {\n    57→          logger.info({ executionId: msg.executionId }, 'Cancelling execution');\n    58→          executor.kill();\n    59→        }\n    60→      },\n    61→\n    62→      onShutdown(msg) {\n    63→        logger.info({ reason: msg.reason, gracePeriodMs: msg.gracePeriodMs }, 'Shutdown requested');\n    64→\n    65→        if (currentExecutionId) {\n    66→          // Wait for current execution to finish, then exit\n    67→          logger.info('Waiting for current execution to complete before shutdown');\n    68→          const checkInterval = setInterval(() => {\n    69→            if (!currentExecutionId) {\n    70→              clearInterval(checkInterval);\n    71→              shutdown();\n    72→            }\n    73→          }, 1000);\n    74→\n    75→          // Force shutdown after grace period\n    76→          setTimeout(() => {\n    77→            clearInterval(checkInterval);\n    78→            executor.kill();\n    79→            shutdown();\n    80→          }, msg.gracePeriodMs);\n    81→        } else {\n    82→          shutdown();\n    83→        }\n    84→      },\n    85→    },\n    86→    logger,\n    87→  );\n    88→\n    89→  // Connect to orchestrator\n    90→  connection.connect();\n    91→\n    92→  // Graceful shutdown\n    93→  function shutdown() {\n    94→    logger.info('Shutting down worker...');\n    95→    connection.disconnect();\n    96→    process.exit(0);\n    97→  }\n    98→\n    99→  process.on('SIGINT', () => {\n   100→    if (currentExecutionId) {\n   101→      logger.info('SIGINT received, killing current execution');\n   102→      executor.kill();\n   103→    }\n   104→    shutdown();\n   105→  });\n   106→\n   107→  process.on('SIGTERM', () => {\n   108→    if (currentExecutionId) {\n   109→      logger.info('SIGTERM received, killing current execution');\n   110→      executor.kill();\n   111→    }\n   112→    shutdown();\n   113→  });\n   114→\n   115→  logger.info('DAC Cloud Worker started');\n   116→}\n   117→\n   118→main().catch((err) => {\n   119→  logger.fatal({ err }, 'Failed to start worker');\n   120→  process.exit(1);\n   121→});\n   122→"}]},"parent_tool_use_id":"toolu_01K91VrZmXpE8J8MvygPBg3v","session_id":"b8c72731-09c7-48ee-b1d6-3b6918a239e2","uuid":"5affce76-c35a-42da-b8c6-ed675e9cf97d","timestamp":"2026-03-19T08:54:14.059Z"}
