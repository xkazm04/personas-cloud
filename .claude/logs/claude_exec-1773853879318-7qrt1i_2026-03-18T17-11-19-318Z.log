;\n   119→\n   120→  const httpServer = createHttpApi(auth, dispatcher, pool, tokenManager, oauth, logger, undefined, tenantDbManager, tenantKeyManager, auditLog);\n   121→  httpServer.listen(config.httpPort, () => {\n   122→    logger.info({ port: config.httpPort }, 'HTTP API listening');\n   123→  });\n   124→\n   125→  // Start event processor (2s tick) and trigger scheduler (5s tick) — tenant-aware\n   126→  const eventProcessorTimer = startEventProcessor(null, dispatcher, logger, 2000, tenantDbManager);\n   127→  const triggerSchedulerTimer = startTriggerScheduler(null, logger, 5000, tenantDbManager);\n   128→\n   129→  // Start daily retention job (purge old executions/events, aggregate metrics)\n   130→  const retentionTimer = startRetentionJob(tenantDbManager, config.retentionDays, logger);\n   131→\n   132→  // Token refresh loop — refresh OAuth token proactively every 30 minutes\n   133→  setInterval(async () => {\n   134→    if (oauth.hasTokens()) {\n   135→      const token = await oauth.getValidAccessToken();\n   136→      if (token) {\n   137→        tokenManager.storeClaudeToken(token);\n   138→      }\n   139→    }\n   140→  }, 30 * 60 * 1000);\n   141→\n   142→  // Log status periodically\n   143→  setInterval(() => {\n   144→    const counts = pool.getWorkerCount();\n   145→    const queueLen = dispatcher.getQueueLength();\n   146→    if (counts.total > 0 || queueLen > 0) {\n   147→      logger.info({\n   148→        workers: counts,\n   149→        queueLength: queueLen,\n   150→        activeExecutions: dispatcher.getActiveExecutions().length,\n   151→        hasOAuth: oauth.hasTokens(),\n   152→      }, 'Status');\n   153→    }\n   154→  }, 60_000);\n   155→\n   156→  // Graceful shutdown\n   157→  const shutdown = async () => {\n   158→    logger.info('Shutting down...');\n   159→    clearInterval(eventProcessorTimer);\n   160→    clearInterval(triggerSchedulerTimer);\n   161→    clearInterval(retentionTimer);\n   162→    dispatcher.shutdown();