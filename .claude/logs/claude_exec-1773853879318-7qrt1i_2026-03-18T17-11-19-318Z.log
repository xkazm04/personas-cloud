[2026-03-18T17:12:43.939Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013Ucva8Sb7g4LWUZRg5TQzz","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import { getTableSpec, isMetrizable, isEphemeral } from '@dac-cloud/shared';\n     4→import type { MetrizableTableSpec, EphemeralTableSpec } from '@dac-cloud/shared';\n     5→import type { TenantDbManager } from './tenantDbManager.js';\n     6→\n     7→// Validate registry classification at import time — if someone changes the\n     8→// registry without updating this module the build still passes but the runtime\n     9→// assertion catches the mismatch immediately.\n    10→const execSpec = getTableSpec('persona_executions');\n    11→const eventsSpec = getTableSpec('persona_events');\n    12→if (!execSpec || !isMetrizable(execSpec)) {\n    13→  throw new Error('persona_executions must be registered as metrizable in TABLE_REGISTRY');\n    14→}\n    15→if (!eventsSpec || !isEphemeral(eventsSpec)) {\n    16→  throw new Error('persona_events must be registered as ephemeral in TABLE_REGISTRY');\n    17→}\n    18→\n    19→/** Maximum fraction of rows a single purge cycle may delete (safety cap). */\n    20→const EXEC_MAX_PURGE_FRACTION = (execSpec as MetrizableTableSpec).maxPurgeFraction ?? 0.8;\n    21→const EVENTS_MAX_PURGE_FRACTION = (eventsSpec as EphemeralTableSpec).maxPurgeFraction ?? 0.8;\n    22→\n    23→/** Rows deleted per chunk to keep individual lock durations short (~50ms). */\n    24→const PURGE_CHUNK_SIZE = 5000;\n    25→\n    26→/** Yield the event loop so concurrent reads/writes can proceed between batches. */\n    27→function yieldTick(): Promise<void> {\n    28→  return new Promise((resolve) => setImmediate(resolve));\n    29→}\n    30→\n    31→/**\n    32→ * Daily retention job: purge old executions/events and aggregate daily metrics.\n    33→ */\n    34→export function startRetentionJob(\n    35→  tenantDbManager: TenantDbManager,\n    36→  retentionDays: number,\n    37→  logger: Logger,\n    38→): NodeJS.Timeout {\n    39→  logger.info({ retentionDays }, 'Retention job started (daily)');\n    40→\n    41→  // Run once on startup then daily\n    42→  setTimeout(() => runRetention(tenantDbManager, retentionDays, logger), 5000);\n    43→\n    44→  return setInterval(() => {\n    45→    runRetention(tenantDbManager, retentionDays, logger);\n    46→  }, 24 * 60 * 60 * 1000);\n    47→}\n    48→\n    49→/**\n    50→ * Delete rows in chunks of PURGE_CHUNK_SIZE, yielding the event loop between\n    51→ * batches so other DB operations are not starved.\n    52→ */\n    53→async function chunkedDelete(db: Database.Database, sql: string, params: unknown[]): Promise<number> {\n    54→  const stmt = db.prepare(sql);\n    55→  let totalDeleted = 0;\n    56→  while (true) {\n    57→    const result = stmt.run(...params, PURGE_CHUNK_SIZE);\n    58→    totalDeleted += result.changes;\n    59→    if (result.changes < PURGE_CHUNK_SIZE) break;\n    60→    await yieldTick();\n    61→  }\n    62→  return totalDeleted;\n    63→}\n    64→\n    65→async function runRetention(\n    66→  tenantDbManager: TenantDbManager,\n    67→  retentionDays: number,\n    68→  logger: Logger,\n    69→): Promise<void> {\n    70→  const cutoff = new Date(Date.now() - retentionDays * 86_400_000).toISOString();\n    71→\n    72→  const tenantIds = tenantDbManager.listTenantIds();\n    73→  for (const projectId of tenantIds) {\n    74→    try {\n    75→      const db = tenantDbManager.getTenantDb(projectId);\n    76→      await runTenantRetention(db, projectId, cutoff, retentionDays, logger);\n    77→    } catch (err) {\n    78→      logger.error({ err, projectId }, 'Retention cleanup failed for tenant');\n    79→    }\n    80→    // Yield between tenants so the event loop stays responsive\n    81→    await yieldTick();\n    82→  }\n    83→\n    84→  // ── Reduce phase: aggregate all tenant metrics into system.db ──\n    85→  try {\n    86→    aggregateSystemMetrics(tenantDbManager, logger);\n    87→  } catch (err) {\n    88→    logger.error({ err }, 'System-wide metrics aggregation failed');\n    89→  }\n    90→}\n    91→\n    92→/**\n    93→ * Map-reduce step: read daily_metrics from every tenant DB and write\n    94→ * a system-wide summary to the system_daily_metrics table in system.db.\n    95→ * Replaces rows wholesale each run so the system view is always consistent.\n    96→ */\n    97→function aggregateSystemMetrics(\n    98→  tenantDbManager: TenantDbManager,\n    99→  logger: Logger,\n   100→): void {\n   101→  const systemDb = tenantDbManager.getSystemDb();\n   102→  const tenantIds = tenantDbManager.listTenantIds();\n   103→\n   104→  // Accumulate per-day totals across all tenants\n   105→  const dayMap = new Map<string, {\n   106→    total_executions: number;\n   107→    completed: number;\n   108→    failed: number;\n   109→    total_cost_usd: number;\n   110→    total_duration_ms: number;\n   111→    tenant_count: number;\n   112→  }>();\n   113→\n   114→  for (const projectId of tenantIds) {\n   115→    try {\n   116→      const db = tenantDbManager.getTenantDb(projectId);\n   117→      const rows = db.prepare(\n   118→        'SELECT date, total_executions, completed, failed, total_cost_usd, total_duration_ms FROM daily_metrics',\n   119→      ).all() as Array<{\n   120→        date: string;\n   121→        total_executions: number;\n   122→        completed: number;\n   123→        failed: number;\n   124→        total_cost_usd: number;\n   125→        total_duration_ms: number;\n   126→      }>;\n   127→\n   128→      for (const row of rows) {\n   129→        const existing = dayMap.get(row.date);\n   130→        if (existing) {\n   131→          existing.total_executions += row.total_executions;\n   132→          existing.completed += row.completed;\n   133→          existing.failed += row.failed;\n   134→          existing.total_cost_usd += row.total_cost_usd;\n   135→          existing.total_duration_ms += row.total_duration_ms;\n   136→          existing.tenant_count += 1;\n   137→        } else {\n   138→          dayMap.set(row.date, {\n   139→            total_executions: row.total_executions,\n   140→            completed: row.completed,\n   141→            failed: row.failed,\n   142→            total_cost_usd: row.total_cost_usd,\n   143→            total_duration_ms: row.total_duration_ms,\n   144→            tenant_count: 1,\n   145→          });\n   146→        }\n   147→      }\n   148→    } catch (err) {\n   149→      logger.warn({ err, projectId }, 'Failed to read metrics for tenant during aggregation');\n   150→    }\n   151→  }\n   152→\n   153→  if (dayMap.size === 0) return;\n   154→\n   155→  // Write aggregated metrics in a single transaction\n   156→  const now = new Date().toISOString();\n   157→  systemDb.transaction(() => {\n   158→    const upsert = systemDb.prepare(`\n   159→      INSERT INTO system_daily_metrics\n   160→        (date, total_executions, completed, failed, total_cost_usd, total_duration_ms, tenant_count, aggregated_at)\n   161→      VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n   162→      ON CONFLICT(date) DO UPDATE SET\n   163→        total_executions = excluded.total_executions,\n   164→        completed = excluded.completed,\n   165→        failed = excluded.failed,\n   166→        total_cost_usd = excluded.total_cost_usd,\n   167→        total_duration_ms = excluded.total_duration_ms,\n   168→        tenant_count = excluded.tenant_count,\n   169→        aggregated_at = excluded.aggregated_at\n   170→    `);\n   171→    for (const [date, m] of dayMap) {\n   172→      upsert.run(date, m.total_executions, m.completed, m.failed, m.total_cost_usd, m.total_duration_ms, m.tenant_count, now);\n   173→    }\n   174→  })();\n   175→\n   176→  logger.info({ days: dayMap.size, tenants: tenantIds.length }, 'System-wide metrics aggregation complete');\n   177→}\n   178→\n   179→async function runTenantRetention(\n   180→  db: Database.Database,\n   181→  projectId: string,\n   182→  cutoff: string,\n   183→  retentionDays: number,\n   184→  logger: Logger,\n   185→): Promise<void> {\n   186→  // ── Batched index scan: collect purgeable execution rowids in chunks ──\n   187→  // Both the aggregation (Step 1) and the delete (Step 2) operate on\n   188→  // this pre-collected set instead of scanning persona_executions twice.\n   189→  // The collection itself is batched to avoid holding a write lock while\n   190→  // inserting millions of rowids after a long retention gap.\n   191→  db.exec('CREATE TEMP TABLE IF NOT EXISTS _ret_ids (id INTEGER PRIMARY KEY)');\n   192→  db.prepare('DELETE FROM _ret_ids').run();\n   193→  {\n   194→    const collectStmt = db.prepare(`\n   195→      INSERT INTO _ret_ids (id)\n   196→      SELECT rowid FROM persona_executions\n   197→      WHERE rowid > ? AND created_at < ? AND status IN ('completed', 'failed', 'cancelled')\n   198→      ORDER BY rowid\n   199→      LIMIT ?\n   200→    `);\n   201→    let cursor = 0;\n   202→    while (true) {\n   203→      const result = collectStmt.run(cursor, cutoff, PURGE_CHUNK_SIZE);\n   204→      if (result.changes === 0) break;\n   205→      const maxRow = db.prepare('SELECT MAX(id) as m FROM _ret_ids').get() as { m: number };\n   206→      cursor = maxRow.m;\n   207→      if (result.changes < PURGE_CHUNK_SIZE) break;\n   208→      await yieldTick();\n   209→    }\n   210→  }\n   211→\n   212→  // ── Step 1: Aggregate metrics in a short transaction ──────────────\n   213→  // Watermark-based: each source row is counted exactly once, so the\n   214→  // additive upsert is safe even if a previous run crashed mid-delete.\n   215→  // No heavy deletes here — lock duration is brief.\n   216→  const aggregatedDays = db.transaction(() => {\n   217→    const watermarkRow = db.prepare(\n   218→      \"SELECT last_rowid FROM retention_watermark WHERE key = 'executions'\",\n   219→    ).get() as { last_rowid: number } | undefined;\n   220→    const lastRowid = watermarkRow?.last_rowid ?? 0;\n   221→\n   222→    // Max rowid above the watermark (reads temp table only, no main-table scan)\n   223→    const maxRow = db.prepare(\n   224→      'SELECT MAX(id) as max_rowid FROM _ret_ids WHERE id > ?',\n   225→    ).get(lastRowid) as { max_rowid: number | null } | undefined;\n   226→    const newWatermark = maxRow?.max_rowid ?? lastRowid;\n   227→\n   228→    // Aggregate only never-before-counted rows. The JOIN fetches data columns\n   229→    // via direct rowid B-tree lookups rather than a redundant index range scan.\n   230→    const rows = db.prepare(`\n   231→      SELECT\n   232→        date(pe.created_at) as day,\n   233→        COUNT(*) as total,\n   234→        SUM(CASE WHEN pe.status = 'completed' THEN 1 ELSE 0 END) as completed,\n   235→        SUM(CASE WHEN pe.status = 'failed' THEN 1 ELSE 0 END) as failed,\n   236→        COALESCE(SUM(pe.cost_usd), 0) as cost,\n   237→        COALESCE(SUM(pe.duration_ms), 0) as duration\n   238→      FROM _ret_ids r\n   239→      JOIN persona_executions pe ON pe.rowid = r.id\n   240→      WHERE r.id > ?\n   241→      GROUP BY date(pe.created_at)\n   242→    `).all(lastRowid) as Array<{ day: string; total: number; completed: number; failed: number; cost: number; duration: number }>;\n   243→\n   244→    const upsertStmt = db.prepare(`\n   245→      INSERT INTO daily_metrics (date, total_executions, completed, failed, total_cost_usd, total_duration_ms)\n   246→      VALUES (?, ?, ?, ?, ?, ?)\n   247→      ON CONFLICT(date) DO UPDATE SET\n   248→        total_executions = total_executions + excluded.total_executions,\n   249→        completed = completed + excluded.completed,\n   250→        failed = failed + excluded.failed,\n   251→        total_cost_usd = total_cost_usd + excluded.total_cost_usd,\n   252→        total_duration_ms = total_duration_ms + excluded.total_duration_ms\n   253→    `);\n   254→    for (const row of rows) {\n   255→      upsertStmt.run(row.day, row.total, row.completed, row.failed, row.cost, row.duration);\n   256→    }\n   257→\n   258→    db.prepare(`\n   259→      INSERT INTO retention_watermark (key, last_rowid) VALUES ('executions', ?)\n   260→      ON CONFLICT(key) DO UPDATE SET last_rowid = excluded.last_rowid\n   261→    `).run(newWatermark);\n   262→\n   263→    return rows.length;\n   264→  })();\n   265→\n   266→  // ── Step 2: Delete execution rows using pre-collected rowids ──────\n   267→  // Pre-purge sanity check: refuse to delete more than EXEC_MAX_PURGE_FRACTION of all rows\n   268→  const execTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_executions').get() as { cnt: number };\n   269→  const execCandidateRow = db.prepare('SELECT COUNT(*) as cnt FROM _ret_ids').get() as { cnt: number };\n   270→\n   271→  let purgedExecutions = 0;\n   272→  if (execTotalRow.cnt > 0 && execCandidateRow.cnt / execTotalRow.cnt > EXEC_MAX_PURGE_FRACTION) {\n   273→    logger.error(\n   274→      { projectId, total: execTotalRow.cnt, candidates: execCandidateRow.cnt, cutoff, maxFraction: EXEC_MAX_PURGE_FRACTION },\n   275→      'Execution purge aborted: deletion would exceed safety cap',\n   276→    );\n   277→  } else {\n   278→    // Each chunk is its own implicit transaction (~50ms lock), with event-loop\n   279→    // yields between chunks so concurrent operations can proceed.\n   280→    const deleteStmt = db.prepare(\n   281→      'DELETE FROM persona_executions WHERE rowid IN (SELECT id FROM _ret_ids LIMIT ?)',\n   282→    );\n   283→    const trimStmt = db.prepare(\n   284→      'DELETE FROM _ret_ids WHERE id IN (SELECT id FROM _ret_ids LIMIT ?)',\n   285→    );\n   286→    while (true) {\n   287→      const result = deleteStmt.run(PURGE_CHUNK_SIZE);\n   288→      purgedExecutions += result.changes;\n   289→      trimStmt.run(PURGE_CHUNK_SIZE);\n   290→      if (result.changes < PURGE_CHUNK_SIZE) break;\n   291→      await yieldTick();\n   292→    }\n   293→  }\n   294→\n   295→  // ── Step 3: Purge old events in batched chunks ────────────────────\n   296→  // Pre-purge sanity check for events\n   297→  const eventsTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_events').get() as { cnt: number };\n   298→  const eventsCandidateRow = db.prepare(\n   299→    \"SELECT COUNT(*) as cnt FROM persona_events WHERE created_at < ?\",\n   300→  ).get(cutoff) as { cnt: number };\n   301→\n   302→  let purgedEvents = 0;\n   303→  let purgedStuckEvents = 0;\n   304→  if (eventsTotalRow.cnt > 0 && eventsCandidateRow.cnt / eventsTotalRow.cnt > EVENTS_MAX_PURGE_FRACTION) {\n   305→    logger.error(\n   306→      { projectId, total: eventsTotalRow.cnt, candidates: eventsCandidateRow.cnt, cutoff, maxFraction: EVENTS_MAX_PURGE_FRACTION },\n   307→      'Event purge aborted: deletion would exceed safety cap',\n   308→    );\n   309→  } else {\n   310→    purgedEvents = await chunkedDelete(\n   311→      db,\n   312→      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status NOT IN ('pending', 'processing') LIMIT ?)\",\n   313→      [cutoff],\n   314→    );\n   315→\n   316→    // Safety net: purge stuck pending/processing events older than 7x retentionDays.\n   317→    const stuckCutoff = new Date(Date.now() - retentionDays * 7 * 86_400_000).toISOString();\n   318→    purgedStuckEvents = await chunkedDelete(\n   319→      db,\n   320→      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status IN ('pending', 'processing') LIMIT ?)\",\n   321→      [stuckCutoff],\n   322→    );\n   323→  }\n   324→\n   325→  if (purgedExecutions > 0 || purgedEvents > 0 || purgedStuckEvents > 0) {\n   326→    logger.info({\n   327→      projectId,\n   328→      purgedExecutions,\n   329→      purgedEvents,\n   330→      purgedStuckEvents,\n   331→      aggregatedDays,\n   332→    }, 'Retention cleanup complete');\n   333→  }\n   334→}\n   335→"}]},"parent_tool_use_id":null,"session_id":"bcae0c8d-0b02-4ad9-b283-350ffa4e6b87","uuid":"eed56d9b-0eea-4553-9cfc-d6ee00e01742","timestamp":"2026-03-18T17:12:43.845Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\retention.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport { getTableSpec, isMetrizable, isEphemeral } from '@dac-cloud/shared';\nimport type { MetrizableTableSpec, EphemeralTableSpec } from '@dac-cloud/shared';\nimport type { TenantDbManager } from './tenantDbManager.js';\n\n// Validate registry classification at import time — if someone changes the\n// registry without updating this module the build still passes but the runtime\n// assertion catches the mismatch immediately.\nconst execSpec = getTableSpec('persona_executions');\nconst eventsSpec = getTableSpec('persona_events');\nif (!execSpec || !isMetrizable(execSpec)) {\n  throw new Error('persona_executions must be registered as metrizable in TABLE_REGISTRY');\n}\nif (!eventsSpec || !isEphemeral(eventsSpec)) {\n  throw new Error('persona_events must be registered as ephemeral in TABLE_REGISTRY');\n}\n\n/** Maximum fraction of rows a single purge cycle may delete (safety cap). */\nconst EXEC_MAX_PURGE_FRACTION = (execSpec as MetrizableTableSpec).maxPurgeFraction ?? 0.8;\nconst EVENTS_MAX_PURGE_FRACTION = (eventsSpec as EphemeralTableSpec).maxPurgeFraction ?? 0.8;\n\n/** Rows deleted per chunk to keep individual lock durations short (~50ms). */\nconst PURGE_CHUNK_SIZE = 5000;\n\n/** Yield the event loop so concurrent reads/writes can proceed between batches. */\nfunction yieldTick(): Promise<void> {\n  return new Promise((resolve) => setImmediate(resolve));\n}\n\n/**\n * Daily retention job: purge old executions/events and aggregate daily metrics.\n */\nexport function startRetentionJob(\n  tenantDbManager: TenantDbManager,\n  retentionDays: number,\n  logger: Logger,\n): NodeJS.Timeout {\n  logger.info({ retentionDays }, 'Retention job started (daily)');\n\n  // Run once on startup then daily\n  setTimeout(() => runRetention(tenantDbManager, retentionDays, logger), 5000);\n\n  return setInterval(() => {\n    runRetention(tenantDbManager, retentionDays, logger);\n  }, 24 * 60 * 60 * 1000);\n}\n\n/**\n * Delete rows in chunks of PURGE_CHUNK_SIZE, yielding the event loop between\n * batches so other DB operations are not starved.\n */\nasync function chunkedDelete(db: Database.Database, sql: string, params: unknown[]): Promise<number> {\n  const stmt = db.prepare(sql);\n  let totalDeleted = 0;\n  while (true) {\n    const result = stmt.run(...params, PURGE_CHUNK_SIZE);\n    totalDeleted += result.changes;\n    if (result.changes < PURGE_CHUNK_SIZE) break;\n    await yieldTick();\n  }\n  return totalDeleted;\n}\n\nasync function runRetention(\n  tenantDbManager: TenantDbManager,\n  retentionDays: number,\n  logger: Logger,\n): Promise<void> {\n  const cutoff = new Date(Date.now() - retentionDays * 86_400_000).toISOString();\n\n  const tenantIds = tenantDbManager.listTenantIds();\n  for (const projectId of tenantIds) {\n    try {\n      const db = tenantDbManager.getTenantDb(projectId);\n      await runTenantRetention(db, projectId, cutoff, retentionDays, logger);\n    } catch (err) {\n      logger.error({ err, projectId }, 'Retention cleanup failed for tenant');\n    }\n    // Yield between tenants so the event loop stays responsive\n    await yieldTick();\n  }\n\n  // ── Reduce phase: aggregate all tenant metrics into system.db ──\n  try {\n    aggregateSystemMetrics(tenantDbManager, logger);\n  } catch (err) {\n    logger.error({ err }, 'System-wide metrics aggregation failed');\n  }\n}\n\n/**\n * Map-reduce step: read daily_metrics from every tenant DB and write\n * a system-wide summary to the system_daily_metrics table in system.db.\n * Replaces rows wholesale each run so the system view is always consistent.\n */\nfunction aggregateSystemMetrics(\n  tenantDbManager: TenantDbManager,\n  logger: Logger,\n): void {\n  const systemDb = tenantDbManager.getSystemDb();\n  const tenantIds = tenantDbManager.listTenantIds();\n\n  // Accumulate per-day totals across all tenants\n  const dayMap = new Map<string, {\n    total_executions: number;\n    completed: number;\n    failed: number;\n    total_cost_usd: number;\n    total_duration_ms: number;\n    tenant_count: number;\n  }>();\n\n  for (const projectId of tenantIds) {\n    try {\n      const db = tenantDbManager.getTenantDb(projectId);\n      const rows = db.prepare(\n        'SELECT date, total_executions, completed, failed, total_cost_usd, total_duration_ms FROM daily_metrics',\n      ).all() as Array<{\n        date: string;\n        total_executions: number;\n        completed: number;\n        failed: number;\n        total_cost_usd: number;\n        total_duration_ms: number;\n      }>;\n\n      for (const row of rows) {\n        const existing = dayMap.get(row.date);\n        if (existing) {\n          existing.total_executions += row.total_executions;\n          existing.completed += row.completed;\n          existing.failed += row.failed;\n          existing.total_cost_usd += row.total_cost_usd;\n          existing.total_duration_ms += row.total_duration_ms;\n          existing.tenant_count += 1;\n        } else {\n          dayMap.set(row.date, {\n            total_executions: row.total_executions,\n            completed: row.completed,\n            failed: row.failed,\n            total_cost_usd: row.total_cost_usd,\n            total_duration_ms: row.total_duration_ms,\n            tenant_count: 1,\n          });\n        }\n      }\n    } catch (err) {\n      logger.warn({ err, projectId }, 'Failed to read metrics for tenant during aggregation');\n    }\n  }\n\n  if (dayMap.size === 0) return;\n\n  // Write aggregated metrics in a single transaction\n  const now = new Date().toISOString();\n  systemDb.transaction(() => {\n    const upsert = systemDb.prepare(`\n      INSERT INTO system_daily_metrics\n        (date, total_executions, completed, failed, total_cost_usd, total_duration_ms, tenant_count, aggregated_at)\n      VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n      ON CONFLICT(date) DO UPDATE SET\n        total_executions = excluded.total_executions,\n        completed = excluded.completed,\n        failed = excluded.failed,\n        total_cost_usd = excluded.total_cost_usd,\n        total_duration_ms = excluded.total_duration_ms,\n        tenant_count = excluded.tenant_count,\n        aggregated_at = excluded.aggregated_at\n    `);\n    for (const [date, m] of dayMap) {\n      upsert.run(date, m.total_executions, m.completed, m.failed, m.total_cost_usd, m.total_duration_ms, m.tenant_count, now);\n    }\n  })();\n\n  logger.info({ days: dayMap.size, tenants: tenantIds.length }, 'System-wide metrics aggregation complete');\n}\n\nasync function runTenantRetention(\n  db: Database.Database,\n  projectId: string,\n  cutoff: string,\n  retentionDays: number,\n  logger: Logger,\n): Promise<void> {\n  // ── Batched index scan: collect purgeable execution rowids in chunks ──\n  // Both the aggregation (Step 1) and the delete (Step 2) operate on\n  // this pre-collected set instead of scanning persona_executions twice.\n  // The collection itself is batched to avoid holding a write lock while\n  // inserting millions of rowids after a long retention gap.\n  db.exec('CREATE TEMP TABLE IF NOT EXISTS _ret_ids (id INTEGER PRIMARY KEY)');\n  db.prepare('DELETE FROM _ret_ids').run();\n  {\n    const collectStmt = db.prepare(`\n      INSERT INTO _ret_ids (id)\n      SELECT rowid FROM persona_executions\n      WHERE rowid > ? AND created_at < ? AND status IN ('completed', 'failed', 'cancelled')\n      ORDER BY rowid\n      LIMIT ?\n    `);\n    let cursor = 0;\n    while (true) {\n      const result = collectStmt.run(cursor, cutoff, PURGE_CHUNK_SIZE);\n      if (result.changes === 0) break;\n      const maxRow = db.prepare('SELECT MAX(id) as m FROM _ret_ids').get() as { m: number };\n      cursor = maxRow.m;\n      if (result.changes < PURGE_CHUNK_SIZE) break;\n      await yieldTick();\n    }\n  }\n\n  // ── Step 1: Aggregate metrics in a short transaction ──────────────\n  // Watermark-based: each source row is counted exactly once, so the\n  // additive upsert is safe even if a previous run crashed mid-delete.\n  // No heavy deletes here — lock duration is brief.\n  const aggregatedDays = db.transaction(() => {\n    const watermarkRow = db.prepare(\n      \"SELECT last_rowid FROM retention_watermark WHERE key = 'executions'\",\n    ).get() as { last_rowid: number } | undefined;\n    const lastRowid = watermarkRow?.last_rowid ?? 0;\n\n    // Max rowid above the watermark (reads temp table only, no main-table scan)\n    const maxRow = db.prepare(\n      'SELECT MAX(id) as max_rowid FROM _ret_ids WHERE id > ?',\n    ).get(lastRowid) as { max_rowid: number | null } | undefined;\n    const newWatermark = maxRow?.max_rowid ?? lastRowid;\n\n    // Aggregate only never-before-counted rows. The JOIN fetches data columns\n    // via direct rowid B-tree lookups rather than a redundant index range scan.\n    const rows = db.prepare(`\n      SELECT\n        date(pe.created_at) as day,\n        COUNT(*) as total,\n        SUM(CASE WHEN pe.status = 'completed' THEN 1 ELSE 0 END) as completed,\n        SUM(CASE WHEN pe.status = 'failed' THEN 1 ELSE 0 END) as failed,\n        COALESCE(SUM(pe.cost_usd), 0) as cost,\n        COALESCE(SUM(pe.duration_ms), 0) as duration\n      FROM _ret_ids r\n      JOIN persona_executions pe ON pe.rowid = r.id\n      WHERE r.id > ?\n      GROUP BY date(pe.created_at)\n    `).all(lastRowid) as Array<{ day: string; total: number; completed: number; failed: number; cost: number; duration: number }>;\n\n    const upsertStmt = db.prepare(`\n      INSERT INTO daily_metrics (date, total_executions, completed, failed, total_cost_usd, total_duration_ms)\n      VALUES (?, ?, ?, ?, ?, ?)\n      ON CONFLICT(date) DO UPDATE SET\n        total_executions = total_executions + excluded.total_executions,\n        completed = completed + excluded.completed,\n        failed = failed + excluded.failed,\n        total_cost_usd = total_cost_usd + excluded.total_cost_usd,\n        total_duration_ms = total_duration_ms + excluded.total_duration_ms\n    `);\n    for (const row of rows) {\n      upsertStmt.run(row.day, row.total, row.completed, row.failed, row.cost, row.duration);\n    }\n\n    db.prepare(`\n      INSERT INTO retention_watermark (key, last_rowid) VALUES ('executions', ?)\n      ON CONFLICT(key) DO UPDATE SET last_rowid = excluded.last_rowid\n    `).run(newWatermark);\n\n    return rows.length;\n  })();\n\n  // ── Step 2: Delete execution rows using pre-collected rowids ──────\n  // Pre-purge sanity check: refuse to delete more than EXEC_MAX_PURGE_FRACTION of all rows\n  const execTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_executions').get() as { cnt: number };\n  const execCandidateRow = db.prepare('SELECT COUNT(*) as cnt FROM _ret_ids').get() as { cnt: number };\n\n  let purgedExecutions = 0;\n  if (execTotalRow.cnt > 0 && execCandidateRow.cnt / execTotalRow.cnt > EXEC_MAX_PURGE_FRACTION) {\n    logger.error(\n      { projectId, total: execTotalRow.cnt, candidates: execCandidateRow.cnt, cutoff, maxFraction: EXEC_MAX_PURGE_FRACTION },\n      'Execution purge aborted: deletion would exceed safety cap',\n    );\n  } else {\n    // Each chunk is its own implicit transaction (~50ms lock), with event-loop\n    // yields between chunks so concurrent operations can proceed.\n    const deleteStmt = db.prepare(\n      'DELETE FROM persona_executions WHERE rowid IN (SELECT id FROM _ret_ids LIMIT ?)',\n    );\n    const trimStmt = db.prepare(\n      'DELETE FROM _ret_ids WHERE id IN (SELECT id FROM _ret_ids LIMIT ?)',\n    );\n    while (true) {\n      const result = deleteStmt.run(PURGE_CHUNK_SIZE);\n      purgedExecutions += result.changes;\n      trimStmt.run(PURGE_CHUNK_SIZE);\n      if (result.changes < PURGE_CHUNK_SIZE) break;\n      await yieldTick();\n    }\n  }\n\n  // ── Step 3: Purge old events in batched chunks ────────────────────\n  // Pre-purge sanity check for events\n  const eventsTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_events').get() as { cnt: number };\n  const eventsCandidateRow = db.prepare(\n    \"SELECT COUNT(*) as cnt FROM persona_events WHERE created_at < ?\",\n  ).get(cutoff) as { cnt: number };\n\n  let purgedEvents = 0;\n  let purgedStuckEvents = 0;\n  if (eventsTotalRow.cnt > 0 && eventsCandidateRow.cnt / eventsTotalRow.cnt > EVENTS_MAX_PURGE_FRACTION) {\n    logger.error(\n      { projectId, total: eventsTotalRow.cnt, candidates: eventsCandidateRow.cnt, cutoff, maxFraction: EVENTS_MAX_PURGE_FRACTION },\n      'Event purge aborted: deletion would exceed safety cap',\n    );\n  } else {\n    purgedEvents = await chunkedDelete(\n      db,\n      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status NOT IN ('pending', 'processing') LIMIT ?)\",\n      [cutoff],\n    );\n\n    // Safety net: purge stuck pending/processing events older than 7x retentionDays.\n    const stuckCutoff = new Date(Date.now() - retentionDays * 7 * 86_400_000).toISOString();\n    purgedStuckEvents = await chunkedDelete(\n      db,\n      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status IN ('pending', 'processing') LIMIT ?)\",\n      [stuckCutoff],\n    );\n  }\n\n  if (purgedExecutions > 0 || purgedEvents > 0 || purgedStuckEvents > 0) {\n    logger.info({\n      projectId,\n      purgedExecutions,\n      purgedEvents,\n      purgedStuckEvents,\n      aggregatedDays,\n    }, 'Retention cleanup complete');\n  }\n}\n","numLines":335,"startLine":1,"totalLines":335}}}
