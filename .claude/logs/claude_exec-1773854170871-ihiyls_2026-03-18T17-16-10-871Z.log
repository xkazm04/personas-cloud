[2026-03-18T17:16:21.053Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014zyRpX6m8BZ3G4unWWAqBi","type":"tool_result","content":"     1→import fs from 'node:fs';\n     2→import fsp from 'node:fs/promises';\n     3→import path from 'node:path';\n     4→import os from 'node:os';\n     5→import crypto from 'node:crypto';\n     6→import type { Logger } from 'pino';\n     7→\n     8→export interface InjectedCredentials {\n     9→  /** Path to the tmpfs-backed credential file */\n    10→  credentialFilePath: string;\n    11→  /** Environment variable key pointing to the file */\n    12→  envPointerKey: string;\n    13→  /** Call to delete the credential file */\n    14→  cleanup(): Promise<void>;\n    15→}\n    16→\n    17→/** File name prefix used for all credential temp files. */\n    18→const CRED_FILE_PREFIX = 'dac-creds-';\n    19→\n    20→/** Max age (ms) before an orphaned credential file is swept on startup. */\n    21→const ORPHAN_MAX_AGE_MS = 2 * 60 * 1000; // 2 minutes\n    22→\n    23→/**\n    24→ * Registry of credential file paths created by this process.\n    25→ * Used by the exit handler to synchronously remove files on crash.\n    26→ */\n    27→const activeCredentialFiles = new Set<string>();\n    28→\n    29→/** Whether the process exit handler has been installed. */\n    30→let exitHandlerInstalled = false;\n    31→\n    32→/**\n    33→ * Returns the number of credential files currently tracked by this process.\n    34→ * Useful as a gauge metric to detect credential file leaks (monotonically\n    35→ * increasing count indicates cleanup failures).\n    36→ */\n    37→export function getActiveCredentialFileCount(): number {\n    38→  return activeCredentialFiles.size;\n    39→}\n    40→\n    41→/**\n    42→ * Returns the directories where credential files may be written.\n    43→ */\n    44→function credentialDirs(): string[] {\n    45→  const dirs: string[] = [os.tmpdir()];\n    46→  if (process.platform === 'linux' && fs.existsSync('/dev/shm')) {\n    47→    dirs.push('/dev/shm');\n    48→  }\n    49→  return dirs;\n    50→}\n    51→\n    52→/**\n    53→ * Install a synchronous process exit handler that removes any credential\n    54→ * files still tracked in the registry. This covers cases where the process\n    55→ * exits abnormally (uncaughtException, unhandledRejection) but the event\n    56→ * loop is still alive long enough to fire the 'exit' event.\n    57→ *\n    58→ * Call once during worker startup.\n    59→ */\n    60→export function installCredentialExitHandler(logger: Logger): void {\n    61→  if (exitHandlerInstalled) return;\n    62→  exitHandlerInstalled = true;\n    63→\n    64→  process.on('exit', () => {\n    65→    const totalFiles = activeCredentialFiles.size;\n    66→    const results: { path: string; success: boolean }[] = [];\n    67→\n    68→    for (const filePath of activeCredentialFiles) {\n    69→      try {\n    70→        fs.unlinkSync(filePath);\n    71→        results.push({ path: filePath, success: true });\n    72→      } catch {\n    73→        results.push({ path: filePath, success: false });\n    74→      }\n    75→    }\n    76→\n    77→    const succeeded = results.filter((r) => r.success).length;\n    78→    const failed = results.filter((r) => !r.success).length;\n    79→\n    80→    // Logger may not flush during 'exit', but try anyway\n    81→    if (totalFiles > 0) {\n    82→      logger.info(\n    83→        { totalFiles, succeeded, failed, files: results },\n    84→        'Exit handler credential file cleanup',\n    85→      );\n    86→    }\n    87→  });\n    88→}\n    89→\n    90→/**\n    91→ * Scan credential temp directories for orphaned `dac-creds-*` files older\n    92→ * than ORPHAN_MAX_AGE_MS and remove them. Intended to be called once during\n    93→ * worker startup before any executions begin.\n    94→ */\n    95→export async function sweepOrphanedCredentialFiles(logger: Logger): Promise<number> {\n    96→  const now = Date.now();\n    97→  let swept = 0;\n    98→\n    99→  for (const dir of credentialDirs()) {\n   100→    let entries: string[];\n   101→    try {\n   102→      entries = await fsp.readdir(dir);\n   103→    } catch (err) {\n   104→      logger.warn({ err, dir, operation: 'sweep_readdir' }, 'Failed to read credential directory');\n   105→      continue; // directory inaccessible\n   106→    }\n   107→\n   108→    for (const entry of entries) {\n   109→      if (!entry.startsWith(CRED_FILE_PREFIX)) continue;\n   110→\n   111→      const fullPath = path.join(dir, entry);\n   112→      try {\n   113→        const stat = await fsp.stat(fullPath);\n   114→        if (now - stat.mtimeMs > ORPHAN_MAX_AGE_MS) {\n   115→          await fsp.unlink(fullPath);\n   116→          swept++;\n   117→          logger.warn({ credentialFile: fullPath, ageMs: now - stat.mtimeMs }, 'Swept orphaned credential file');\n   118→        }\n   119→      } catch {\n   120→        // File disappeared between readdir and stat/unlink — fine\n   121→      }\n   122→    }\n   123→  }\n   124→\n   125→  logger.info(\n   126→    { swept, activeCredentialFiles: activeCredentialFiles.size },\n   127→    'Credential file sweep complete',\n   128→  );\n   129→\n   130→  return swept;\n   131→}\n   132→\n   133→/**\n   134→ * Write credentials to a temporary file (preferring tmpfs/ramfs) instead of\n   135→ * injecting them as environment variables. This prevents credential exposure\n   136→ * via /proc/pid/environ or `ps auxe`.\n   137→ *\n   138→ * Returns the file path and a cleanup function. The child process receives\n   139→ * the DAC_CREDENTIALS_FILE env var pointing to the file.\n   140→ */\n   141→export async function injectCredentialsViaFile(\n   142→  env: Record<string, string>,\n   143→  executionId: string,\n   144→  logger: Logger,\n   145→): Promise<InjectedCredentials> {\n   146→  // Prefer /dev/shm (tmpfs, never hits disk) on Linux\n   147→  let tmpBase: string;\n   148→  if (process.platform === 'linux' && fs.existsSync('/dev/shm')) {\n   149→    tmpBase = '/dev/shm';\n   150→  } else {\n   151→    tmpBase = os.tmpdir();\n   152→  }\n   153→\n   154→  const randomSuffix = crypto.randomBytes(8).toString('hex');\n   155→  const credFilePath = path.join(tmpBase, `${CRED_FILE_PREFIX}${executionId}-${randomSuffix}.json`);\n   156→\n   157→  // Collect credential env vars into the file\n   158→  const credentials: Record<string, string> = {};\n   159→  const credentialKeys: string[] = [];\n   160→\n   161→  for (const [key, value] of Object.entries(env)) {\n   162→    // Credential env vars follow the CONNECTOR_* pattern or are well-known secret keys\n   163→    if (\n   164→      key.startsWith('CONNECTOR_') ||\n   165→      key === 'ANTHROPIC_API_KEY' ||\n   166→      key.includes('TOKEN') ||\n   167→      key.includes('SECRET') ||\n   168→      key.includes('PASSWORD') ||\n   169→      key.includes('API_KEY')\n   170→    ) {\n   171→      credentials[key] = value;\n   172→      credentialKeys.push(key);\n   173→    }\n   174→  }\n   175→\n   176→  // Write credential file asynchronously\n   177→  await fsp.writeFile(credFilePath, JSON.stringify(credentials), { mode: 0o600 });\n   178→\n   179→  // Track the file so exit handler can clean it up on crash\n   180→  activeCredentialFiles.add(credFilePath);\n   181→\n   182→  // Remove credential keys from the env dict (they'll be read from file instead)\n   183→  for (const key of credentialKeys) {\n   184→    delete env[key];\n   185→  }\n   186→\n   187→  logger.debug({\n   188→    executionId,\n   189→    credentialFile: credFilePath,\n   190→    credentialCount: credentialKeys.length,\n   191→    onTmpfs: tmpBase === '/dev/shm',\n   192→  }, 'Credentials written to temporary file');\n   193→\n   194→  return {\n   195→    credentialFilePath: credFilePath,\n   196→    envPointerKey: 'DAC_CREDENTIALS_FILE',\n   197→    async cleanup() {\n   198→      activeCredentialFiles.delete(credFilePath);\n   199→      try {\n   200→        await fsp.unlink(credFilePath);\n   201→        logger.debug({ credentialFile: credFilePath }, 'Credential file cleaned up');\n   202→      } catch (err) {\n   203→        // File may already be gone (e.g. sandbox cleanup removed it first)\n   204→        if ((err as NodeJS.ErrnoException).code !== 'ENOENT') {\n   205→          logger.warn({ err, credentialFile: credFilePath }, 'Failed to cleanup credential file');\n   206→        }\n   207→      }\n   208→    },\n   209→  };\n   210→}\n   211→"}]},"parent_tool_use_id":null,"session_id":"98c68aba-f2b1-441c-8ac0-0079aea17493","uuid":"4e90bb89-95ea-48de-a488-224f5f53b8df","timestamp":"2026-03-18T17:16:20.944Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\worker\\src\\credentialInjector.ts","content":"import fs from 'node:fs';\nimport fsp from 'node:fs/promises';\nimport path from 'node:path';\nimport os from 'node:os';\nimport crypto from 'node:crypto';\nimport type { Logger } from 'pino';\n\nexport interface InjectedCredentials {\n  /** Path to the tmpfs-backed credential file */\n  credentialFilePath: string;\n  /** Environment variable key pointing to the file */\n  envPointerKey: string;\n  /** Call to delete the credential file */\n  cleanup(): Promise<void>;\n}\n\n/** File name prefix used for all credential temp files. */\nconst CRED_FILE_PREFIX = 'dac-creds-';\n\n/** Max age (ms) before an orphaned credential file is swept on startup. */\nconst ORPHAN_MAX_AGE_MS = 2 * 60 * 1000; // 2 minutes\n\n/**\n * Registry of credential file paths created by this process.\n * Used by the exit handler to synchronously remove files on crash.\n */\nconst activeCredentialFiles = new Set<string>();\n\n/** Whether the process exit handler has been installed. */\nlet exitHandlerInstalled = false;\n\n/**\n * Returns the number of credential files currently tracked by this process.\n * Useful as a gauge metric to detect credential file leaks (monotonically\n * increasing count indicates cleanup failures).\n */\nexport function getActiveCredentialFileCount(): number {\n  return activeCredentialFiles.size;\n}\n\n/**\n * Returns the directories where credential files may be written.\n */\nfunction credentialDirs(): string[] {\n  const dirs: string[] = [os.tmpdir()];\n  if (process.platform === 'linux' && fs.existsSync('/dev/shm')) {\n    dirs.push('/dev/shm');\n  }\n  return dirs;\n}\n\n/**\n * Install a synchronous process exit handler that removes any credential\n * files still tracked in the registry. This covers cases where the process\n * exits abnormally (uncaughtException, unhandledRejection) but the event\n * loop is still alive long enough to fire the 'exit' event.\n *\n * Call once during worker startup.\n */\nexport function installCredentialExitHandler(logger: Logger): void {\n  if (exitHandlerInstalled) return;\n  exitHandlerInstalled = true;\n\n  process.on('exit', () => {\n    const totalFiles = activeCredentialFiles.size;\n    const results: { path: string; success: boolean }[] = [];\n\n    for (const filePath of activeCredentialFiles) {\n      try {\n        fs.unlinkSync(filePath);\n        results.push({ path: filePath, success: true });\n      } catch {\n        results.push({ path: filePath, success: false });\n      }\n    }\n\n    const succeeded = results.filter((r) => r.success).length;\n    const failed = results.filter((r) => !r.success).length;\n\n    // Logger may not flush during 'exit', but try anyway\n    if (totalFiles > 0) {\n      logger.info(\n        { totalFiles, succeeded, failed, files: results },\n        'Exit handler credential file cleanup',\n      );\n    }\n  });\n}\n\n/**\n * Scan credential temp directories for orphaned `dac-creds-*` files older\n * than ORPHAN_MAX_AGE_MS and remove them. Intended to be called once during\n * worker startup before any executions begin.\n */\nexport async function sweepOrphanedCredentialFiles(logger: Logger): Promise<number> {\n  const now = Date.now();\n  let swept = 0;\n\n  for (const dir of credentialDirs()) {\n    let entries: string[];\n    try {\n      entries = await fsp.readdir(dir);\n    } catch (err) {\n      logger.warn({ err, dir, operation: 'sweep_readdir' }, 'Failed to read credential directory');\n      continue; // directory inaccessible\n    }\n\n    for (const entry of entries) {\n      if (!entry.startsWith(CRED_FILE_PREFIX)) continue;\n\n      const fullPath = path.join(dir, entry);\n      try {\n        const stat = await fsp.stat(fullPath);\n        if (now - stat.mtimeMs > ORPHAN_MAX_AGE_MS) {\n          await fsp.unlink(fullPath);\n          swept++;\n          logger.warn({ credentialFile: fullPath, ageMs: now - stat.mtimeMs }, 'Swept orphaned credential file');\n        }\n      } catch {\n        // File disappeared between readdir and stat/unlink — fine\n      }\n    }\n  }\n\n  logger.info(\n    { swept, activeCredentialFiles: activeCredentialFiles.size },\n    'Credential file sweep complete',\n  );\n\n  return swept;\n}\n\n/**\n * Write credentials to a temporary file (preferring tmpfs/ramfs) instead of\n * injecting them as environment variables. This prevents credential exposure\n * via /proc/pid/environ or `ps auxe`.\n *\n * Returns the file path and a cleanup function. The child process receives\n * the DAC_CREDENTIALS_FILE env var pointing to the file.\n */\nexport async function injectCredentialsViaFile(\n  env: Record<string, string>,\n  executionId: string,\n  logger: Logger,\n): Promise<InjectedCredentials> {\n  // Prefer /dev/shm (tmpfs, never hits disk) on Linux\n  let tmpBase: string;\n  if (process.platform === 'linux' && fs.existsSync('/dev/shm')) {\n    tmpBase = '/dev/shm';\n  } else {\n    tmpBase = os.tmpdir();\n  }\n\n  const randomSuffix = crypto.randomBytes(8).toString('hex');\n  const credFilePath = path.join(tmpBase, `${CRED_FILE_PREFIX}${executionId}-${randomSuffix}.json`);\n\n  // Collect credential env vars into the file\n  const credentials: Record<string, string> = {};\n  const credentialKeys: string[] = [];\n\n  for (const [key, value] of Object.entries(env)) {\n    // Credential env vars follow the CONNECTOR_* pattern or are well-known secret keys\n    if (\n      key.startsWith('CONNECTOR_') ||\n      key === 'ANTHROPIC_API_KEY' ||\n      key.includes('TOKEN') ||\n      key.includes('SECRET') ||\n      key.includes('PASSWORD') ||\n      key.includes('API_KEY')\n    ) {\n      credentials[key] = value;\n      credentialKeys.push(key);\n    }\n  }\n\n  // Write credential file asynchronously\n  await fsp.writeFile(credFilePath, JSON.stringify(credentials), { mode: 0o600 });\n\n  // Track the file so exit handler can clean it up on crash\n  activeCredentialFiles.add(credFilePath);\n\n  // Remove credential keys from the env dict (they'll be read from file instead)\n  for (const key of credentialKeys) {\n    delete env[key];\n  }\n\n  logger.debug({\n    executionId,\n    credentialFile: credFilePath,\n    credentialCount: credentialKeys.length,\n    onTmpfs: tmpBase === '/dev/shm',\n  }, 'Credentials written to temporary file');\n\n  return {\n    credentialFilePath: credFilePath,\n    envPointerKey: 'DAC_CREDENTIALS_FILE',\n    async cleanup() {\n      activeCredentialFiles.delete(credFilePath);\n      try {\n        await fsp.unlink(credFilePath);\n        logger.debug({ credentialFile: credFilePath }, 'Credential file cleaned up');\n      } catch (err) {\n        // File may already be gone (e.g. sandbox cleanup removed it first)\n        if ((err as NodeJS.ErrnoException).code !== 'ENOENT') {\n          logger.warn({ err, credentialFile: credFilePath }, 'Failed to cleanup credential file');\n        }\n      }\n    },\n  };\n}\n","numLines":211,"startLine":1,"totalLines":211}}}
