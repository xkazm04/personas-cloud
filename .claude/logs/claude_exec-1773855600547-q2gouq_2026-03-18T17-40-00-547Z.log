[2026-03-18T17:40:14.294Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012CVyu5Yzi9neLqQr2Q88Jc","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import type { KafkaClient } from './kafka.js';\n    11→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    12→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    13→import type { TenantDbManager } from './tenantDbManager.js';\n    14→import type { TenantKeyManager } from './tenantKeyManager.js';\n    15→import type { AuditLog } from './auditLog.js';\n    16→import type { EventProcessorHealth } from './eventProcessor.js';\n    17→import type { Logger } from 'pino';\n    18→import * as db from './db/index.js';\n    19→import { readBody, json } from './httpUtils.js';\n    20→\n    21→export function createHttpApi(\n    22→  auth: Auth,\n    23→  dispatcher: Dispatcher,\n    24→  pool: WorkerPool,\n    25→  tokenManager: TokenManager,\n    26→  oauth: OAuthManager,\n    27→  logger: Logger,\n    28→  database?: Database.Database,\n    29→  tenantDbManager?: TenantDbManager,\n    30→  tenantKeyManager?: TenantKeyManager,\n    31→  auditLog?: AuditLog,\n    32→  getEventProcessorHealth?: () => EventProcessorHealth,\n    33→  kafka?: KafkaClient,\n    34→  onEventPublished?: () => void,\n    35→): http.Server {\n    36→  const server = http.createServer(async (req, res) => {\n    37→    // Security headers\n    38→    res.setHeader('X-Content-Type-Options', 'nosniff');\n    39→\n    40→    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    41→    const origin = req.headers.origin ?? '';\n    42→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    43→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    44→    if (isAdminRoute) {\n    45→      // Admin routes: only allow same-origin requests (no CORS wildcard)\n    46→      if (origin && origin === allowedOrigin) {\n    47→        res.setHeader('Access-Control-Allow-Origin', origin);\n    48→      }\n    49→      // If no match, omit the header entirely — browser blocks the request\n    50→    } else {\n    51→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    52→    }\n    53→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    54→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n    55→\n    56→    if (req.method === 'OPTIONS') {\n    57→      res.writeHead(204);\n    58→      res.end();\n    59→      return;\n    60→    }\n    61→\n    62→    const url = req.url || '/';\n    63→    const [pathname, queryString] = url.split('?');\n    64→    const route = parseRoute(pathname ?? '');\n    65→\n    66→    // Unauthenticated endpoints\n    67→    if (pathname === '/health' && req.method === 'GET') {\n    68→      await handleHealth(res, pool, dispatcher, oauth, getEventProcessorHealth, database, tenantDbManager, kafka);\n    69→      return;\n    70→    }\n    71→\n    72→    // Auth check for everything else — dual auth (API key + optional JWT)\n    73→    const ctx = auth.validateAndExtractContext(req);\n    74→    if (!ctx) {\n    75→      res.writeHead(401, { 'Content-Type': 'application/json' });\n    76→      res.end(JSON.stringify({ error: 'Unauthorized' }));\n    77→      return;\n    78→    }\n    79→\n    80→    // Helper: project scoping (admin sees all, user sees own project)\n    81→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n    82→\n    83→    // Resolve tenant-specific database when available\n    84→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n    85→      if (tenantDbManager && projectId) {\n    86→        return tenantDbManager.getTenantDb(projectId);\n    87→      }\n    88→      return database;\n    89→    };\n    90→    const tenantDb = resolveDatabase(ctx.projectId);\n    91→\n    92→    try {\n    93→      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n    94→      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n    95→        if (requireAdmin(ctx, res)) return;\n    96→        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n    97→        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n    98→        return;\n    99→      }\n   100→      // --- Persona CRUD ---\n   101→      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n   102→        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n   103→      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n   104→        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   105→        const persona = createPersonaWithDefaults({\n   106→          ...body,\n   107→          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   108→        });\n   109→        db.upsertPersona(tenantDb, persona);\n   110→        try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: persona.id }); } catch { /* logged inside record() */ }\n   111→        logger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   112→        json(res, 201, persona);\n   113→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n   114→        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n   115→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n   116→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   117→        if (!persona) return;\n   118→        const body = JSON.parse(await readBody(req)) as { toolId: string };\n   119→        db.linkTool(tenantDb, route.id, body.toolId);\n   120→        try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id, detail: JSON.stringify({ toolId: body.toolId }) }); } catch { /* logged inside record() */ }\n   121→        logger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   122→        json(res, 200, { linked: true });\n   123→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n   124→        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, logger), scopedProjectId, res);\n   125→        if (!hydrated) return;\n   126→        json(res, 200, hydrated);\n   127→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n   128→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   129→        if (!persona) return;\n   130→        json(res, 200, persona);\n   131→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   132→        db.deletePersona(tenantDb, route.id, scopedProjectId);\n   133→        try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id }); } catch { /* logged inside record() */ }\n   134→        logger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   135→        json(res, 200, { deleted: true });\n   136→      }\n   137→      // --- Tool Definitions ---\n   138→      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n   139→        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   140→        const tool = createToolDefinitionWithDefaults(body);\n   141→        db.upsertToolDefinition(tenantDb, tool);\n   142→        try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', resourceType: 'toolDefinition', resourceId: tool.id }); } catch { /* logged inside record() */ }\n   143→        logger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   144→        json(res, 201, tool);\n   145→      }\n   146→      // --- Credentials ---\n   147→      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n   148→        const body = JSON.parse(await readBody(req));\n   149→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   150→\n   151→        // Require plaintext — clients must never supply pre-encrypted data\n   152→        if (!body.plaintext || typeof body.plaintext !== 'string') {\n   153→          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   154→          return;\n   155→        }\n   156→\n   157→        // Reject oversized plaintext before synchronous encryption blocks the event loop\n   158→        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   159→          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   160→          return;\n   161→        }\n   162→\n   163→        // Encryption is mandatory — reject if the key manager is unavailable\n   164→        if (!tenantKeyManager) {\n   165→          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   166→          return;\n   167→        }\n   168→\n   169→        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n   170→        delete body.encryptedData;\n   171→        delete body.iv;\n   172→        delete body.tag;\n   173→\n   174→        // Server-side encryption with per-tenant key\n   175→        const tenantId = body.projectId || ctx.projectId || 'default';\n   176→        const key = await tenantKeyManager.getKey(tenantId);\n   177→        const encrypted = encrypt(body.plaintext, key);\n   178→        body.encryptedData = encrypted.encrypted;\n   179→        body.iv = encrypted.iv;\n   180→        body.tag = encrypted.tag;\n   181→        delete body.plaintext;\n   182→\n   183→        const cred = db.createCredential(tenantDb, body);\n   184→        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n   185→        logger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   186→        json(res, 201, cred);\n   187→      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   188→        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n   189→        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   190→        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   191→        logger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   192→        json(res, 200, { deleted: true });\n   193→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n   194→        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n   195→        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   196→        // Strip encrypted data from response\n   197→        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   198→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n   199→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   200→        if (!persona) return;\n   201→        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   202→        db.linkCredential(tenantDb, route.id, body.credentialId);\n   203→        try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id, detail: JSON.stringify({ credentialId: body.credentialId }) }); } catch { /* logged inside record() */ }\n   204→        logger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route.id, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   205→        json(res, 200, { linked: true });\n   206→      }\n   207→      // --- Event Subscriptions ---\n   208→      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n   209→        const body = JSON.parse(await readBody(req));\n   210→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   211→        const missing: string[] = [];\n   212→        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   213→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   214→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   215→        const sub = db.createSubscription(tenantDb, body);\n   216→        try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: sub.id, detail: JSON.stringify({ personaId: body.personaId, eventType: body.eventType }) }); } catch { /* logged inside record() */ }\n   217→        json(res, 201, sub);\n   218→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   219→        const body = JSON.parse(await readBody(req));\n   220→        db.updateSubscription(tenantDb, route.id, body);\n   221→        const updated = db.getSubscription(tenantDb, route.id);\n   222→        try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: route.id }); } catch { /* logged inside record() */ }\n   223→        json(res, 200, updated);\n   224→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   225→        db.deleteSubscription(tenantDb, route.id);\n   226→        try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: route.id }); } catch { /* logged inside record() */ }\n   227→        json(res, 200, { deleted: true });\n   228→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n   229→        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n   230→      }\n   231→      // --- Triggers (delegated to triggerHttpHandlers) ---\n   232→      else if (route && tenantDb && (\n   233→        route.resource === 'triggers' ||\n   234→        (route.resource === 'personas' && route.subResource === 'triggers')\n   235→      )) {\n   236→        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n   237→        return;\n   238→      }\n   239→      // --- Events ---\n   240→      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n   241→        const params = new URLSearchParams(queryString || '');\n   242→        const events = db.listEvents(tenantDb, {\n   243→          eventType: params.get('eventType') ?? undefined,\n   244→          status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n   245→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   246→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   247→          projectId: scopedProjectId,\n   248→        });\n   249→        json(res, 200, events);\n   250→      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n   251→        const body = JSON.parse(await readBody(req));\n   252→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   253→        const missing: string[] = [];\n   254→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   255→        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   256→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   257→        const event = db.publishEvent(tenantDb, body);\n   258→        onEventPublished?.();\n   259→        json(res, 201, event);\n   260→      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   261→        const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n   262→        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n   263→        if (updated) {\n   264→          json(res, 200, updated);\n   265→        } else {\n   266→          res.writeHead(404, { 'Content-Type': 'application/json' });\n   267→          res.end(JSON.stringify({ error: 'Event not found' }));\n   268→        }\n   269→      }\n   270→      // --- Webhooks ---\n   271→      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n   272→        const personaId = route.id;\n   273→        const body = await readBody(req);\n   274→        const event = db.publishEvent(tenantDb, {\n   275→          eventType: 'webhook_received',\n   276→          sourceType: 'webhook',\n   277→          sourceId: personaId,\n   278→          targetPersonaId: personaId,\n   279→          payload: body,\n   280→        });\n   281→        onEventPublished?.();\n   282→        json(res, 201, event);\n   283→      }\n   284→      // --- GitLab Webhook ---\n   285→      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n   286→        const body = await readBody(req);\n   287→        let parsed: Record<string, unknown> = {};\n   288→        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   289→        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   290→        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   291→        const event = db.publishEvent(tenantDb, {\n   292→          eventType: `gitlab_${objectKind}`,\n   293→          sourceType: 'gitlab',\n   294→          sourceId: projectPath ?? null,\n   295→          payload: body,\n   296→        });\n   297→        onEventPublished?.();\n   298→        json(res, 201, event);\n   299→      }\n   300→      // --- Executions ---\n   301→      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n   302→        const params = new URLSearchParams(queryString || '');\n   303→        const executions = db.listExecutions(tenantDb, {\n   304→          personaId: params.get('personaId') ?? undefined,\n   305→          status: params.get('status') ?? undefined,\n   306→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   307→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   308→          projectId: scopedProjectId,\n   309→        });\n   310→        json(res, 200, executions);\n   311→      }\n   312→      // --- Existing execution endpoints ---\n   313→      else if (pathname === '/api/status' && req.method === 'GET') {\n   314→        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   315→      } else if (pathname === '/api/execute' && req.method === 'POST') {\n   316→        await handleExecute(req, res, dispatcher, logger, ctx);\n   317→      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n   318→        handleCancelExecution(res, dispatcher, route.id);\n   319→      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n   320→        const executionId = route.id;\n   321→        const params = new URLSearchParams(queryString || '');\n   322→        const offset = parseInt(params.get('offset') || '0', 10);\n   323→        handleGetExecution(res, dispatcher, executionId, offset);\n   324→      }\n   325→      // --- Admin-only routes ---\n   326→      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n   327→        if (requireAdmin(ctx, res)) return;\n   328→        if (tenantDbManager) {\n   329→          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   330→        } else if (database) {\n   331→          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   332→        } else {\n   333→          json(res, 200, { projectIds: [] });\n   334→        }\n   335→      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n   336→        if (requireAdmin(ctx, res)) return;\n   337→        if (tenantDbManager) {\n   338→          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   339→          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   340→          json(res, 200, allPersonas);\n   341→        } else if (database) {\n   342→          json(res, 200, db.listPersonasSummary(database));\n   343→        } else {\n   344→          json(res, 200, []);\n   345→        }\n   346→      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n   347→        if (requireAdmin(ctx, res)) return;\n   348→        const params = new URLSearchParams(queryString || '');\n   349→        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   350→        if (tenantDbManager) {\n   351→          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   352→          tenantDbManager.forEachTenant((tDb) => {\n   353→            allExecs.push(...db.listExecutions(tDb, { limit }));\n   354→          });\n   355→          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   356→          json(res, 200, allExecs.slice(0, limit));\n   357→        } else if (database) {\n   358→          json(res, 200, db.listExecutions(database, {\n   359→            limit,\n   360→            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   361→          }));\n   362→        } else {\n   363→          json(res, 200, []);\n   364→        }\n   365→      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n   366→        if (requireAdmin(ctx, res)) return;\n   367→        if (!auditLog) { json(res, 200, []); return; }\n   368→        const params = new URLSearchParams(queryString || '');\n   369→        json(res, 200, auditLog.query({\n   370→          tenantId: params.get('tenantId') ?? undefined,\n   371→          action: params.get('action') ?? undefined,\n   372→          since: params.get('since') ?? undefined,\n   373→          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   374→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   375→        }));\n   376→      } else {\n   377→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   378→        res.end(JSON.stringify({ error: 'Not found' }));\n   379→      }\n   380→    } catch (err) {\n   381→      if (err instanceof Error && err.message === 'Payload too large') {\n   382→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   383→        res.end(JSON.stringify({ error: 'Payload too large' }));\n   384→        return;\n   385→      }\n   386→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   387→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   388→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n   389→        return;\n   390→      }\n   391→      logger.error({ err, url }, 'HTTP handler error');\n   392→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   393→      res.end(JSON.stringify({ error: 'Internal server error' }));\n   394→    }\n   395→  });\n   396→\n   397→  return server;\n   398→}\n   399→\n   400→interface ParsedRoute {\n   401→  resource: string;\n   402→  id?: string;\n   403→  subResource?: string;\n   404→}\n   405→\n   406→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n   407→function parseRoute(pathname: string): ParsedRoute | null {\n   408→  if (!pathname.startsWith('/api/')) return null;\n   409→  const segments = pathname.slice(5).split('/').filter(Boolean);\n   410→  if (segments.length === 0) return null;\n   411→  return {\n   412→    resource: segments[0]!,\n   413→    id: segments[1],\n   414→    subResource: segments[2],\n   415→  };\n   416→}\n   417→\n   418→/**\n   419→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   420→ * Returns the entity on success, or null after sending a 404 response.\n   421→ */\n   422→function withScopedEntity<T extends { projectId?: string | null }>(\n   423→  entity: T | undefined,\n   424→  scopedProjectId: string | undefined,\n   425→  res: http.ServerResponse,\n   426→): T | null {\n   427→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   428→    json(res, 404, { error: 'Not found' });\n   429→    return null;\n   430→  }\n   431→  return entity;\n   432→}\n   433→\n   434→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   435→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   436→  if (ctx.authType !== 'admin') {\n   437→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   438→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   439→    return true;\n   440→  }\n   441→  return false;\n   442→}\n   443→\n   444→// --- Existing handlers ---\n   445→\n   446→/** Heartbeat age (ms) beyond which a worker is considered stale. */\n   447→const STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n   448→\n   449→async function handleHealth(\n   450→  res: http.ServerResponse,\n   451→  pool: WorkerPool,\n   452→  dispatcher: Dispatcher,\n   453→  oauth: OAuthManager,\n   454→  getEventProcessorHealth?: () => EventProcessorHealth,\n   455→  database?: Database.Database,\n   456→  tenantDbManager?: TenantDbManager,\n   457→  kafka?: KafkaClient,\n   458→): Promise<void> {\n   459→  // Track per-dependency status for overall verdict\n   460→  const issues: string[] = [];\n   461→\n   462→  // --- Workers ---\n   463→  const counts = pool.getWorkerCount();\n   464→  const workers = pool.getWorkers();\n   465→  const now = Date.now();\n   466→  const staleWorkers = workers\n   467→    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n   468→    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n   469→\n   470→  if (staleWorkers.length > 0) {\n   471→    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n   472→  }\n   473→\n   474→  // --- Database ---\n   475→  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n   476→  if (database) {\n   477→    try {\n   478→      database.prepare('SELECT 1').get();\n   479→      dbHealth.status = 'ok';\n   480→    } catch {\n   481→      dbHealth.status = 'error';\n   482→      issues.push('database unreachable');\n   483→    }\n   484→  }\n   485→  if (tenantDbManager) {\n   486→    try {\n   487→      const tenantIds = tenantDbManager.listTenantIds();\n   488→      dbHealth.tenantCount = tenantIds.length;\n   489→      // If no shared database, tenant DB manager is the primary DB layer\n   490→      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n   491→    } catch {\n   492→      dbHealth.tenantCount = -1;\n   493→      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n   494→      issues.push('tenant DB listing failed');\n   495→    }\n   496→  }\n   497→\n   498→  // --- Kafka ---\n   499→  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n   500→  if (kafka) {\n   501→    const kh = await kafka.checkHealth();\n   502→    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n   503→    if (kh.status === 'error') {\n   504→      issues.push(`kafka: ${kh.detail || 'error'}`);\n   505→    }\n   506→  }\n   507→\n   508→  // --- Queue ---\n   509→  const queueDepth = dispatcher.getQueueLength();\n   510→  const activeExecutions = dispatcher.getActiveExecutions().length;\n   511→\n   512→  // --- Event processor ---\n   513→  let eventProcessorHealth: EventProcessorHealth | undefined;\n   514→  if (getEventProcessorHealth) {\n   515→    eventProcessorHealth = getEventProcessorHealth();\n   516→  }\n   517→\n   518→  // --- Overall verdict ---\n   519→  let verdict: 'healthy' | 'degraded' | 'unhealthy';\n   520→  if (issues.some(i => i.includes('database unreachable') || i.includes('kafka: '))) {\n   521→    verdict = 'unhealthy';\n   522→  } else if (issues.length > 0) {\n   523→    verdict = 'degraded';\n   524→  } else {\n   525→    verdict = 'healthy';\n   526→  }\n   527→\n   528→  const body: Record<string, unknown> = {\n   529→    status: verdict,\n   530→    timestamp: Date.now(),\n   531→    dependencies: {\n   532→      database: dbHealth,\n   533→      kafka: kafkaHealth,\n   534→      workers: {\n   535→        ...counts,\n   536→        staleWorkers: staleWorkers.length > 0 ? staleWorkers : undefined,\n   537→      },\n   538→    },\n   539→    queue: {\n   540→      depth: queueDepth,\n   541→      activeExecutions,\n   542→    },\n   543→    hasSubscription: oauth.hasTokens(),\n   544→  };\n   545→\n   546→  if (eventProcessorHealth) {\n   547→    (body.dependencies as Record<string, unknown>).eventProcessor = eventProcessorHealth;\n   548→  }\n   549→\n   550→  if (issues.length > 0) {\n   551→    body.issues = issues;\n   552→  }\n   553→\n   554→  const httpStatus = verdict === 'unhealthy' ? 503 : 200;\n   555→  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n   556→  res.end(JSON.stringify(body));\n   557→}\n   558→\n   559→function handleStatus(\n   560→  res: http.ServerResponse,\n   561→  pool: WorkerPool,\n   562→  dispatcher: Dispatcher,\n   563→  tokenManager: TokenManager,\n   564→  oauth: OAuthManager,\n   565→): void {\n   566→  const oauthTokens = oauth.getTokens();\n   567→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   568→  res.end(JSON.stringify({\n   569→    workers: pool.getWorkers(),\n   570→    workerCounts: pool.getWorkerCount(),\n   571→    workerPoolMetrics: pool.getMetrics(),\n   572→    queueLength: dispatcher.getQueueLength(),\n   573→    activeExecutions: dispatcher.getActiveExecutions(),\n   574→    hasClaudeToken: tokenManager.hasToken(),\n   575→    oauth: {\n   576→      connected: oauth.hasTokens(),\n   577→      scopes: oauthTokens?.scopes || [],\n   578→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   579→    },\n   580→  }));\n   581→}\n   582→\n   583→async function handleExecute(\n   584→  req: http.IncomingMessage,\n   585→  res: http.ServerResponse,\n   586→  dispatcher: Dispatcher,\n   587→  logger: Logger,\n   588→  ctx?: RequestContext,\n   589→): Promise<void> {\n   590→  const body = await readBody(req);\n   591→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   592→\n   593→  try {\n   594→    parsed = JSON.parse(body);\n   595→  } catch {\n   596→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   597→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   598→    return;\n   599→  }\n   600→\n   601→  if (!parsed.prompt) {\n   602→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   603→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   604→    return;\n   605→  }\n   606→\n   607→  const request: ExecRequest = {\n   608→    executionId: nanoid(),\n   609→    personaId: parsed.personaId || 'manual',\n   610→    prompt: parsed.prompt,\n   611→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   612→    config: {\n   613→      timeoutMs: parsed.timeoutMs || 300_000,\n   614→    },\n   615→  };\n   616→\n   617→  dispatcher.submit(request);\n   618→\n   619→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   620→\n   621→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   622→  res.end(JSON.stringify({\n   623→    executionId: request.executionId,\n   624→    status: 'queued',\n   625→  }));\n   626→}\n   627→\n   628→function handleGetExecution(\n   629→  res: http.ServerResponse,\n   630→  dispatcher: Dispatcher,\n   631→  executionId: string,\n   632→  offset: number = 0,\n   633→): void {\n   634→  const exec = dispatcher.getExecution(executionId);\n   635→\n   636→  if (!exec) {\n   637→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   638→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   639→    return;\n   640→  }\n   641→\n   642→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   643→\n   644→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   645→  res.end(JSON.stringify({\n   646→    executionId,\n   647→    status: exec.status,\n   648→    outputLines: exec.output.length,\n   649→    output,\n   650→    durationMs: exec.durationMs,\n   651→    sessionId: exec.sessionId,\n   652→    totalCostUsd: exec.totalCostUsd,\n   653→    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n   654→  }));\n   655→}\n   656→\n   657→function handleCancelExecution(\n   658→  res: http.ServerResponse,\n   659→  dispatcher: Dispatcher,\n   660→  executionId: string,\n   661→): void {\n   662→  const cancelled = dispatcher.cancelExecution(executionId);\n   663→\n   664→  if (!cancelled) {\n   665→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   666→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   667→    return;\n   668→  }\n   669→\n   670→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   671→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   672→}\n   673→\n   674→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\n   675→const MAX_QUERY_LIMIT = 500;\n   676→const MAX_QUERY_OFFSET = 100_000;\n   677→\n   678→/** Parse an integer query param and clamp it to safe bounds. */\n   679→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   680→  if (!value) return defaultValue;\n   681→  const parsed = parseInt(value, 10);\n   682→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   683→  return Math.min(parsed, max);\n   684→}\n   685→"}]},"parent_tool_use_id":null,"session_id":"a58aed6d-7f81-4d21-b6c3-66f17e053333","uuid":"ebc221cd-3bff-4d50-961d-2aefba462451","timestamp":"2026-03-18T17:40:13.863Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { EventProcessorHealth } from './eventProcessor.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  kafka?: KafkaClient,\n  onEventPublished?: () => void,\n): http.Server {\n  const server = http.createServer(async (req, res) => {\n    // Security headers\n    res.setHeader('X-Content-Type-Options', 'nosniff');\n\n    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    const origin = req.headers.origin ?? '';\n    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    if (isAdminRoute) {\n      // Admin routes: only allow same-origin requests (no CORS wildcard)\n      if (origin && origin === allowedOrigin) {\n        res.setHeader('Access-Control-Allow-Origin', origin);\n      }\n      // If no match, omit the header entirely — browser blocks the request\n    } else {\n      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    }\n    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n\n    if (req.method === 'OPTIONS') {\n      res.writeHead(204);\n      res.end();\n      return;\n    }\n\n    const url = req.url || '/';\n    const [pathname, queryString] = url.split('?');\n    const route = parseRoute(pathname ?? '');\n\n    // Unauthenticated endpoints\n    if (pathname === '/health' && req.method === 'GET') {\n      await handleHealth(res, pool, dispatcher, oauth, getEventProcessorHealth, database, tenantDbManager, kafka);\n      return;\n    }\n\n    // Auth check for everything else — dual auth (API key + optional JWT)\n    const ctx = auth.validateAndExtractContext(req);\n    if (!ctx) {\n      res.writeHead(401, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Unauthorized' }));\n      return;\n    }\n\n    // Helper: project scoping (admin sees all, user sees own project)\n    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n\n    // Resolve tenant-specific database when available\n    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n      if (tenantDbManager && projectId) {\n        return tenantDbManager.getTenantDb(projectId);\n      }\n      return database;\n    };\n    const tenantDb = resolveDatabase(ctx.projectId);\n\n    try {\n      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n        if (requireAdmin(ctx, res)) return;\n        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n        return;\n      }\n      // --- Persona CRUD ---\n      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n        const persona = createPersonaWithDefaults({\n          ...body,\n          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n        });\n        db.upsertPersona(tenantDb, persona);\n        try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: persona.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n        json(res, 201, persona);\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { toolId: string };\n        db.linkTool(tenantDb, route.id, body.toolId);\n        try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id, detail: JSON.stringify({ toolId: body.toolId }) }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n        json(res, 200, { linked: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, logger), scopedProjectId, res);\n        if (!hydrated) return;\n        json(res, 200, hydrated);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        json(res, 200, persona);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deletePersona(tenantDb, route.id, scopedProjectId);\n        try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n        json(res, 200, { deleted: true });\n      }\n      // --- Tool Definitions ---\n      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n        const tool = createToolDefinitionWithDefaults(body);\n        db.upsertToolDefinition(tenantDb, tool);\n        try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', resourceType: 'toolDefinition', resourceId: tool.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n        json(res, 201, tool);\n      }\n      // --- Credentials ---\n      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n\n        // Require plaintext — clients must never supply pre-encrypted data\n        if (!body.plaintext || typeof body.plaintext !== 'string') {\n          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n          return;\n        }\n\n        // Reject oversized plaintext before synchronous encryption blocks the event loop\n        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n          return;\n        }\n\n        // Encryption is mandatory — reject if the key manager is unavailable\n        if (!tenantKeyManager) {\n          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n          return;\n        }\n\n        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n        delete body.encryptedData;\n        delete body.iv;\n        delete body.tag;\n\n        // Server-side encryption with per-tenant key\n        const tenantId = body.projectId || ctx.projectId || 'default';\n        const key = await tenantKeyManager.getKey(tenantId);\n        const encrypted = encrypt(body.plaintext, key);\n        body.encryptedData = encrypted.encrypted;\n        body.iv = encrypted.iv;\n        body.tag = encrypted.tag;\n        delete body.plaintext;\n\n        const cred = db.createCredential(tenantDb, body);\n        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n        json(res, 201, cred);\n      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n        // Strip encrypted data from response\n        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n        db.linkCredential(tenantDb, route.id, body.credentialId);\n        try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id, detail: JSON.stringify({ credentialId: body.credentialId }) }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route.id, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n        json(res, 200, { linked: true });\n      }\n      // --- Event Subscriptions ---\n      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const sub = db.createSubscription(tenantDb, body);\n        try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: sub.id, detail: JSON.stringify({ personaId: body.personaId, eventType: body.eventType }) }); } catch { /* logged inside record() */ }\n        json(res, 201, sub);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        db.updateSubscription(tenantDb, route.id, body);\n        const updated = db.getSubscription(tenantDb, route.id);\n        try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: route.id }); } catch { /* logged inside record() */ }\n        json(res, 200, updated);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deleteSubscription(tenantDb, route.id);\n        try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: route.id }); } catch { /* logged inside record() */ }\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n      }\n      // --- Triggers (delegated to triggerHttpHandlers) ---\n      else if (route && tenantDb && (\n        route.resource === 'triggers' ||\n        (route.resource === 'personas' && route.subResource === 'triggers')\n      )) {\n        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n        return;\n      }\n      // --- Events ---\n      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const events = db.listEvents(tenantDb, {\n          eventType: params.get('eventType') ?? undefined,\n          status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, events);\n      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const event = db.publishEvent(tenantDb, body);\n        onEventPublished?.();\n        json(res, 201, event);\n      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n        if (updated) {\n          json(res, 200, updated);\n        } else {\n          res.writeHead(404, { 'Content-Type': 'application/json' });\n          res.end(JSON.stringify({ error: 'Event not found' }));\n        }\n      }\n      // --- Webhooks ---\n      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n        const personaId = route.id;\n        const body = await readBody(req);\n        const event = db.publishEvent(tenantDb, {\n          eventType: 'webhook_received',\n          sourceType: 'webhook',\n          sourceId: personaId,\n          targetPersonaId: personaId,\n          payload: body,\n        });\n        onEventPublished?.();\n        json(res, 201, event);\n      }\n      // --- GitLab Webhook ---\n      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n        const body = await readBody(req);\n        let parsed: Record<string, unknown> = {};\n        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n        const event = db.publishEvent(tenantDb, {\n          eventType: `gitlab_${objectKind}`,\n          sourceType: 'gitlab',\n          sourceId: projectPath ?? null,\n          payload: body,\n        });\n        onEventPublished?.();\n        json(res, 201, event);\n      }\n      // --- Executions ---\n      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const executions = db.listExecutions(tenantDb, {\n          personaId: params.get('personaId') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, executions);\n      }\n      // --- Existing execution endpoints ---\n      else if (pathname === '/api/status' && req.method === 'GET') {\n        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n      } else if (pathname === '/api/execute' && req.method === 'POST') {\n        await handleExecute(req, res, dispatcher, logger, ctx);\n      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n        handleCancelExecution(res, dispatcher, route.id);\n      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n        const executionId = route.id;\n        const params = new URLSearchParams(queryString || '');\n        const offset = parseInt(params.get('offset') || '0', 10);\n        handleGetExecution(res, dispatcher, executionId, offset);\n      }\n      // --- Admin-only routes ---\n      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n        } else if (database) {\n          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n        } else {\n          json(res, 200, { projectIds: [] });\n        }\n      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n          json(res, 200, allPersonas);\n        } else if (database) {\n          json(res, 200, db.listPersonasSummary(database));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        const params = new URLSearchParams(queryString || '');\n        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n        if (tenantDbManager) {\n          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n          tenantDbManager.forEachTenant((tDb) => {\n            allExecs.push(...db.listExecutions(tDb, { limit }));\n          });\n          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n          json(res, 200, allExecs.slice(0, limit));\n        } else if (database) {\n          json(res, 200, db.listExecutions(database, {\n            limit,\n            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          }));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (!auditLog) { json(res, 200, []); return; }\n        const params = new URLSearchParams(queryString || '');\n        json(res, 200, auditLog.query({\n          tenantId: params.get('tenantId') ?? undefined,\n          action: params.get('action') ?? undefined,\n          since: params.get('since') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        }));\n      } else {\n        res.writeHead(404, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Not found' }));\n      }\n    } catch (err) {\n      if (err instanceof Error && err.message === 'Payload too large') {\n        res.writeHead(413, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Payload too large' }));\n        return;\n      }\n      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n        res.writeHead(409, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n        return;\n      }\n      logger.error({ err, url }, 'HTTP handler error');\n      res.writeHead(500, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Internal server error' }));\n    }\n  });\n\n  return server;\n}\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\n/**\n * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n * Returns the entity on success, or null after sending a 404 response.\n */\nfunction withScopedEntity<T extends { projectId?: string | null }>(\n  entity: T | undefined,\n  scopedProjectId: string | undefined,\n  res: http.ServerResponse,\n): T | null {\n  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n    json(res, 404, { error: 'Not found' });\n    return null;\n  }\n  return entity;\n}\n\n/** Returns true (and sends 403) if the caller is NOT an admin. */\nfunction requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n  if (ctx.authType !== 'admin') {\n    res.writeHead(403, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Admin access required' }));\n    return true;\n  }\n  return false;\n}\n\n// --- Existing handlers ---\n\n/** Heartbeat age (ms) beyond which a worker is considered stale. */\nconst STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n\nasync function handleHealth(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  oauth: OAuthManager,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  kafka?: KafkaClient,\n): Promise<void> {\n  // Track per-dependency status for overall verdict\n  const issues: string[] = [];\n\n  // --- Workers ---\n  const counts = pool.getWorkerCount();\n  const workers = pool.getWorkers();\n  const now = Date.now();\n  const staleWorkers = workers\n    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n\n  if (staleWorkers.length > 0) {\n    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n  }\n\n  // --- Database ---\n  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n  if (database) {\n    try {\n      database.prepare('SELECT 1').get();\n      dbHealth.status = 'ok';\n    } catch {\n      dbHealth.status = 'error';\n      issues.push('database unreachable');\n    }\n  }\n  if (tenantDbManager) {\n    try {\n      const tenantIds = tenantDbManager.listTenantIds();\n      dbHealth.tenantCount = tenantIds.length;\n      // If no shared database, tenant DB manager is the primary DB layer\n      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n    } catch {\n      dbHealth.tenantCount = -1;\n      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n      issues.push('tenant DB listing failed');\n    }\n  }\n\n  // --- Kafka ---\n  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n  if (kafka) {\n    const kh = await kafka.checkHealth();\n    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n    if (kh.status === 'error') {\n      issues.push(`kafka: ${kh.detail || 'error'}`);\n    }\n  }\n\n  // --- Queue ---\n  const queueDepth = dispatcher.getQueueLength();\n  const activeExecutions = dispatcher.getActiveExecutions().length;\n\n  // --- Event processor ---\n  let eventProcessorHealth: Ev
[2026-03-18T17:40:14.294Z] [STDOUT] entProcessorHealth | undefined;\n  if (getEventProcessorHealth) {\n    eventProcessorHealth = getEventProcessorHealth();\n  }\n\n  // --- Overall verdict ---\n  let verdict: 'healthy' | 'degraded' | 'unhealthy';\n  if (issues.some(i => i.includes('database unreachable') || i.includes('kafka: '))) {\n    verdict = 'unhealthy';\n  } else if (issues.length > 0) {\n    verdict = 'degraded';\n  } else {\n    verdict = 'healthy';\n  }\n\n  const body: Record<string, unknown> = {\n    status: verdict,\n    timestamp: Date.now(),\n    dependencies: {\n      database: dbHealth,\n      kafka: kafkaHealth,\n      workers: {\n        ...counts,\n        staleWorkers: staleWorkers.length > 0 ? staleWorkers : undefined,\n      },\n    },\n    queue: {\n      depth: queueDepth,\n      activeExecutions,\n    },\n    hasSubscription: oauth.hasTokens(),\n  };\n\n  if (eventProcessorHealth) {\n    (body.dependencies as Record<string, unknown>).eventProcessor = eventProcessorHealth;\n  }\n\n  if (issues.length > 0) {\n    body.issues = issues;\n  }\n\n  const httpStatus = verdict === 'unhealthy' ? 503 : 200;\n  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify(body));\n}\n\nfunction handleStatus(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n): void {\n  const oauthTokens = oauth.getTokens();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    workers: pool.getWorkers(),\n    workerCounts: pool.getWorkerCount(),\n    workerPoolMetrics: pool.getMetrics(),\n    queueLength: dispatcher.getQueueLength(),\n    activeExecutions: dispatcher.getActiveExecutions(),\n    hasClaudeToken: tokenManager.hasToken(),\n    oauth: {\n      connected: oauth.hasTokens(),\n      scopes: oauthTokens?.scopes || [],\n      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n    },\n  }));\n}\n\nasync function handleExecute(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  ctx?: RequestContext,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.prompt) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n    return;\n  }\n\n  const request: ExecRequest = {\n    executionId: nanoid(),\n    personaId: parsed.personaId || 'manual',\n    prompt: parsed.prompt,\n    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n    config: {\n      timeoutMs: parsed.timeoutMs || 300_000,\n    },\n  };\n\n  dispatcher.submit(request);\n\n  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n\n  res.writeHead(202, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId: request.executionId,\n    status: 'queued',\n  }));\n}\n\nfunction handleGetExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n  offset: number = 0,\n): void {\n  const exec = dispatcher.getExecution(executionId);\n\n  if (!exec) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found' }));\n    return;\n  }\n\n  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId,\n    status: exec.status,\n    outputLines: exec.output.length,\n    output,\n    durationMs: exec.durationMs,\n    sessionId: exec.sessionId,\n    totalCostUsd: exec.totalCostUsd,\n    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n  }));\n}\n\nfunction handleCancelExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n): void {\n  const cancelled = dispatcher.cancelExecution(executionId);\n\n  if (!cancelled) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n    return;\n  }\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n}\n\nconst MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\nconst MAX_QUERY_LIMIT = 500;\nconst MAX_QUERY_OFFSET = 100_000;\n\n/** Parse an integer query param and clamp it to safe bounds. */\nfunction clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n  if (!value) return defaultValue;\n  const parsed = parseInt(value, 10);\n  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n  return Math.min(parsed, max);\n}\n","numLines":685,"startLine":1,"totalLines":685}}}
