ust never supply pre-encrypted data\n   157→        if (!body.plaintext || typeof body.plaintext !== 'string') {\n   158→          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   159→          return;\n   160→        }\n   161→\n   162→        // Reject oversized plaintext before synchronous encryption blocks the event loop\n   163→        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   164→          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   165→          return;\n   166→        }\n   167→\n   168→        // Encryption is mandatory — reject if the key manager is unavailable\n   169→        if (!tenantKeyManager) {\n   170→          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   171→          return;\n   172→        }\n   173→\n   174→        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n   175→        delete body.encryptedData;\n   176→        delete body.iv;\n   177→        delete body.tag;\n   178→\n   179→        // Server-side encryption with per-tenant key\n   180→        const tenantId = body.projectId || ctx.projectId || 'default';\n   181→        const key = await tenantKeyManager.getKey(tenantId);\n   182→        const encrypted = encrypt(body.plaintext, key);\n   183→        body.encryptedData = encrypted.encrypted;\n   184→        body.iv = encrypted.iv;\n   185→        body.tag = encrypted.tag;\n   186→        delete body.plaintext;\n   187→\n   188→        const cred = db.createCredential(tenantDb, body);\n   189→        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n   190→        logger.info({ op: 'credential.create', resourceType: 'credenti