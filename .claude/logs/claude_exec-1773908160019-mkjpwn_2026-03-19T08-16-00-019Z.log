[2026-03-19T08:16:09.181Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NSisirxWnF85k6MUPW5naj","type":"tool_result","content":"     1→import crypto from 'node:crypto';\n     2→import Database from 'better-sqlite3';\n     3→import type { Logger } from 'pino';\n     4→\n     5→/** SHA-256 hash chain genesis value (64 hex zeros). */\n     6→const GENESIS_HASH = '0'.repeat(64);\n     7→\n     8→/**\n     9→ * Compute a chain hash: SHA-256(previousHash + deterministic JSON of entry fields).\n    10→ * Each entry's hash commits to the entire chain history before it.\n    11→ */\n    12→function computeChainHash(prevHash: string, entry: BufferedEntry): string {\n    13→  const payload = prevHash + JSON.stringify([\n    14→    entry.timestamp,\n    15→    entry.action,\n    16→    entry.tenantId,\n    17→    entry.actor,\n    18→    entry.resourceType,\n    19→    entry.resourceId,\n    20→    entry.detail,\n    21→    entry.ipAddress,\n    22→  ]);\n    23→  return crypto.createHash('sha256').update(payload).digest('hex');\n    24→}\n    25→\n    26→const AUDIT_SCHEMA = `\n    27→CREATE TABLE IF NOT EXISTS audit_events (\n    28→  id INTEGER PRIMARY KEY AUTOINCREMENT,\n    29→  timestamp TEXT NOT NULL,\n    30→  action TEXT NOT NULL,\n    31→  tenant_id TEXT,\n    32→  actor TEXT,\n    33→  resource_type TEXT,\n    34→  resource_id TEXT,\n    35→  detail TEXT,\n    36→  ip_address TEXT,\n    37→  prev_hash TEXT\n    38→);\n    39→CREATE INDEX IF NOT EXISTS idx_audit_ts ON audit_events(timestamp);\n    40→CREATE INDEX IF NOT EXISTS idx_audit_tenant_action_ts ON audit_events(tenant_id, action, timestamp);\n    41→CREATE INDEX IF NOT EXISTS idx_audit_actor ON audit_events(actor);\n    42→CREATE INDEX IF NOT EXISTS idx_audit_resource_type ON audit_events(resource_type);\n    43→DROP INDEX IF EXISTS idx_audit_tenant_ts;\n    44→DROP INDEX IF EXISTS idx_audit_action;\n    45→`;\n    46→\n    47→/** Thrown when an audit event fails to persist — signals an audit trail gap. */\n    48→export class AuditWriteError extends Error {\n    49→  constructor(\n    50→    public readonly entry: AuditEntry,\n    51→    cause: unknown,\n    52→  ) {\n    53→    super(`Audit write failed for action \"${entry.action}\"`);\n    54→    this.name = 'AuditWriteError';\n    55→    this.cause = cause;\n    56→  }\n    57→}\n    58→\n    59→// ---------------------------------------------------------------------------\n    60→// Discriminated-union audit entries — each action carries its own typed payload\n    61→// ---------------------------------------------------------------------------\n    62→\n    63→/** Fields common to every audit entry. */\n    64→interface AuditEntryBase {\n    65→  tenantId?: string;\n    66→  actor?: string;\n    67→  ipAddress?: string;\n    68→}\n    69→\n    70→// --- Key management ---\n    71→interface KeyEncryptEntry extends AuditEntryBase {\n    72→  action: 'key:encrypt';\n    73→  resourceType: 'credential';\n    74→  resourceId: string;\n    75→}\n    76→\n    77→interface KeyDecryptEntry extends AuditEntryBase {\n    78→  action: 'key:decrypt';\n    79→  resourceType: 'credential';\n    80→  resourceId: string;\n    81→}\n    82→\n    83→interface KeyDecryptFailedEntry extends AuditEntryBase {\n    84→  action: 'key:decrypt_failed';\n    85→  resourceType: 'credential';\n    86→  resourceId: string;\n    87→  detail: { reason: string };\n    88→}\n    89→\n    90→interface KeyDeleteEntry extends AuditEntryBase {\n    91→  action: 'key:delete';\n    92→  resourceType: 'credential';\n    93→  resourceId: string;\n    94→}\n    95→\n    96→interface KeyAccessEntry extends AuditEntryBase {\n    97→  action: 'key:access';\n    98→  resourceType: 'credential';\n    99→  resourceId: string;\n   100→}\n   101→\n   102→interface KeyDeriveEntry extends AuditEntryBase {\n   103→  action: 'key:derive';\n   104→}\n   105→\n   106→// --- Persona management ---\n   107→interface PersonaCreateEntry extends AuditEntryBase {\n   108→  action: 'persona:create';\n   109→  resourceType: 'persona';\n   110→  resourceId: string;\n   111→}\n   112→\n   113→interface PersonaDeleteEntry extends AuditEntryBase {\n   114→  action: 'persona:delete';\n   115→  resourceType: 'persona';\n   116→  resourceId: string;\n   117→}\n   118→\n   119→// --- Tool management ---\n   120→interface ToolLinkEntry extends AuditEntryBase {\n   121→  action: 'tool:link';\n   122→  resourceType: 'persona';\n   123→  resourceId: string;\n   124→  detail: { toolId: string };\n   125→}\n   126→\n   127→interface ToolDefinitionCreateEntry extends AuditEntryBase {\n   128→  action: 'tool-definition:create';\n   129→  resourceType: 'toolDefinition';\n   130→  resourceId: string;\n   131→}\n   132→\n   133→// --- Credential linking ---\n   134→interface CredentialLinkEntry extends AuditEntryBase {\n   135→  action: 'credential:link';\n   136→  resourceType: 'persona';\n   137→  resourceId: string;\n   138→  detail: { credentialId: string };\n   139→}\n   140→\n   141→// --- Subscriptions ---\n   142→interface SubscriptionCreateEntry extends AuditEntryBase {\n   143→  action: 'subscription:create';\n   144→  resourceType: 'subscription';\n   145→  resourceId: string;\n   146→  detail: { personaId: string; eventType: string };\n   147→}\n   148→\n   149→interface SubscriptionUpdateEntry extends AuditEntryBase {\n   150→  action: 'subscription:update';\n   151→  resourceType: 'subscription';\n   152→  resourceId: string;\n   153→}\n   154→\n   155→interface SubscriptionDeleteEntry extends AuditEntryBase {\n   156→  action: 'subscription:delete';\n   157→  resourceType: 'subscription';\n   158→  resourceId: string;\n   159→}\n   160→\n   161→// --- Worker pool ---\n   162→interface WorkerConnectedEntry extends AuditEntryBase {\n   163→  action: 'worker:connected';\n   164→  detail: { workerId: string };\n   165→}\n   166→\n   167→interface WorkerDisconnectedEntry extends AuditEntryBase {\n   168→  action: 'worker:disconnected';\n   169→  detail: { workerId: string };\n   170→  resourceId?: string;\n   171→}\n   172→\n   173→// --- Triggers ---\n   174→interface TriggerCreateEntry extends AuditEntryBase {\n   175→  action: 'trigger:create';\n   176→  resourceType: 'trigger';\n   177→  resourceId?: string;\n   178→}\n   179→\n   180→interface TriggerUpdateEntry extends AuditEntryBase {\n   181→  action: 'trigger:update';\n   182→  resourceType: 'trigger';\n   183→  resourceId: string;\n   184→}\n   185→\n   186→interface TriggerDeleteEntry extends AuditEntryBase {\n   187→  action: 'trigger:delete';\n   188→  resourceType: 'trigger';\n   189→  resourceId: string;\n   190→}\n   191→\n   192→// --- Events ---\n   193→interface EventPublishEntry extends AuditEntryBase {\n   194→  action: 'event:publish';\n   195→  resourceType: 'event';\n   196→  resourceId?: string;\n   197→}\n   198→\n   199→interface EventUpdateEntry extends AuditEntryBase {\n   200→  action: 'event:update';\n   201→  resourceType: 'event';\n   202→  resourceId: string;\n   203→}\n   204→\n   205→// --- Executions ---\n   206→interface ExecutionSubmitEntry extends AuditEntryBase {\n   207→  action: 'execution:submit';\n   208→  resourceType: 'execution';\n   209→  resourceId?: string;\n   210→}\n   211→\n   212→// --- Webhooks ---\n   213→interface WebhookReceiveEntry extends AuditEntryBase {\n   214→  action: 'webhook:receive';\n   215→  resourceType: 'webhook';\n   216→  resourceId: string;\n   217→}\n   218→\n   219→// --- OAuth lifecycle ---\n   220→interface OAuthAuthorizeEntry extends AuditEntryBase {\n   221→  action: 'oauth:authorize';\n   222→  resourceType: 'oauth';\n   223→  resourceId: string; // state parameter\n   224→}\n   225→\n   226→interface OAuthExchangeEntry extends AuditEntryBase {\n   227→  action: 'oauth:exchange';\n   228→  resourceType: 'oauth';\n   229→  detail: { scopes: string[]; expiresAt: string };\n   230→}\n   231→\n   232→interface OAuthRefreshEntry extends AuditEntryBase {\n   233→  action: 'oauth:refresh';\n   234→  resourceType: 'oauth';\n   235→  detail: { expiresAt: string };\n   236→}\n   237→\n   238→interface OAuthRefreshFailedEntry extends AuditEntryBase {\n   239→  action: 'oauth:refresh_failed';\n   240→  resourceType: 'oauth';\n   241→  detail: { reason: string; errorType?: string };\n   242→}\n   243→\n   244→interface OAuthTokenErrorEntry extends AuditEntryBase {\n   245→  action: 'oauth:token_error';\n   246→  resourceType: 'oauth';\n   247→  detail: { errorType: string; status?: number; transient: boolean; context: string };\n   248→}\n   249→\n   250→interface OAuthDisconnectEntry extends AuditEntryBase {\n   251→  action: 'oauth:disconnect';\n   252→  resourceType: 'oauth';\n   253→  detail: { serverRevoked: boolean };\n   254→}\n   255→\n   256→// --- Token lifecycle ---\n   257→interface TokenInjectEntry extends AuditEntryBase {\n   258→  action: 'token:inject';\n   259→  resourceType: 'token';\n   260→}\n   261→\n   262→interface TokenExpiringSoonEntry extends AuditEntryBase {\n   263→  action: 'token:expiring_soon';\n   264→  resourceType: 'oauth';\n   265→  detail: { expiresAt: string; remainingMinutes: number };\n   266→}\n   267→\n   268→/** Discriminated union of all audit event types. */\n   269→export type AuditEntry =\n   270→  | KeyEncryptEntry\n   271→  | KeyDecryptEntry\n   272→  | KeyDecryptFailedEntry\n   273→  | KeyDeleteEntry\n   274→  | KeyAccessEntry\n   275→  | KeyDeriveEntry\n   276→  | PersonaCreateEntry\n   277→  | PersonaDeleteEntry\n   278→  | ToolLinkEntry\n   279→  | ToolDefinitionCreateEntry\n   280→  | CredentialLinkEntry\n   281→  | SubscriptionCreateEntry\n   282→  | SubscriptionUpdateEntry\n   283→  | SubscriptionDeleteEntry\n   284→  | WorkerConnectedEntry\n   285→  | WorkerDisconnectedEntry\n   286→  | TriggerCreateEntry\n   287→  | TriggerUpdateEntry\n   288→  | TriggerDeleteEntry\n   289→  | EventPublishEntry\n   290→  | EventUpdateEntry\n   291→  | ExecutionSubmitEntry\n   292→  | WebhookReceiveEntry\n   293→  | OAuthAuthorizeEntry\n   294→  | OAuthExchangeEntry\n   295→  | OAuthRefreshEntry\n   296→  | OAuthRefreshFailedEntry\n   297→  | OAuthTokenErrorEntry\n   298→  | OAuthDisconnectEntry\n   299→  | TokenInjectEntry\n   300→  | TokenExpiringSoonEntry;\n   301→\n   302→/** String-literal union of all valid audit actions. */\n   303→export type AuditAction = AuditEntry['action'];\n   304→\n   305→/** Row shape returned by audit_events queries. */\n   306→export interface AuditEvent {\n   307→  id: number;\n   308→  timestamp: string;\n   309→  action: string;\n   310→  tenant_id: string | null;\n   311→  actor: string | null;\n   312→  resource_type: string | null;\n   313→  resource_id: string | null;\n   314→  detail: string | null;\n   315→  ip_address: string | null;\n   316→  prev_hash: string | null;\n   317→}\n   318→\n   319→/** Result of verifying the audit hash chain. */\n   320→export interface ChainVerifyResult {\n   321→  valid: boolean;\n   322→  verifiedCount: number;\n   323→  brokenAtId?: number;\n   324→}\n   325→\n   326→/** Max entries buffered before an automatic flush. */\n   327→const BUFFER_FLUSH_SIZE = 50;\n   328→/** Interval (ms) between timer-based flushes. */\n   329→const BUFFER_FLUSH_INTERVAL_MS = 100;\n   330→\n   331→interface BufferedEntry {\n   332→  timestamp: string;\n   333→  action: string;\n   334→  tenantId: string | null;\n   335→  actor: string | null;\n   336→  resourceType: string | null;\n   337→  resourceId: string | null;\n   338→  detail: string | null;\n   339→  ipAddress: string | null;\n   340→}\n   341→\n   342→export class AuditLog {\n   343→  private db: Database.Database;\n   344→  private insertStmt: Database.Statement;\n   345→  private queryStmtCache = new Map<string, Database.Statement>();\n   346→  private buffer: BufferedEntry[] = [];\n   347→  private flushTimer: NodeJS.Timeout | null = null;\n   348→  private batchInsert: (entries: BufferedEntry[], hashes: string[]) => void;\n   349→  private lastHash: string;\n   350→\n   351→  constructor(\n   352→    dbPath: string,\n   353→    private logger: Logger,\n   354→  ) {\n   355→    this.db = new Database(dbPath);\n   356→    this.db.pragma('journal_mode = WAL');\n   357→    this.db.exec(AUDIT_SCHEMA);\n   358→\n   359→    // Migration: add prev_hash column to existing databases that lack it\n   360→    const cols = this.db.pragma('table_info(audit_events)') as { name: string }[];\n   361→    if (!cols.some((c) => c.name === 'prev_hash')) {\n   362→      this.db.exec('ALTER TABLE audit_events ADD COLUMN prev_hash TEXT');\n   363→    }\n   364→\n   365→    this.insertStmt = this.db.prepare(\n   366→      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address, prev_hash) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',\n   367→    );\n   368→\n   369→    // Initialize chain from last stored hash (or genesis for empty / pre-chain DBs)\n   370→    const lastRow = this.db.prepare(\n   371→      'SELECT prev_hash FROM audit_events WHERE prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n   372→    ).get() as { prev_hash: string } | undefined;\n   373→    this.lastHash = lastRow?.prev_hash ?? GENESIS_HASH;\n   374→\n   375→    // Wrap N inserts in a single transaction — one fsync instead of N\n   376→    const stmt = this.insertStmt;\n   377→    this.batchInsert = this.db.transaction((entries: BufferedEntry[], hashes: string[]) => {\n   378→      for (let i = 0; i < entries.length; i++) {\n   379→        const e = entries[i];\n   380→        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress, hashes[i]);\n   381→      }\n   382→    });\n   383→\n   384→    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n   385→\n   386→    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled, hash-chain active)');\n   387→  }\n   388→\n   389→  /** Expose the underlying database for use by RetentionPolicy. */\n   390→  getDb(): Database.Database {\n   391→    return this.db;\n   392→  }\n   393→\n   394→  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n   395→  countEvents(before?: string): number {\n   396→    const stmt = before\n   397→      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n   398→      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n   399→    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n   400→    return row.cnt;\n   401→  }\n   402→\n   403→  /**\n   404→   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   405→   * yielding the event loop between batches so concurrent DB operations\n   406→   * are not starved during large purges.\n   407→   */\n   408→  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n   409→    const deleteChunk = this.db.prepare(\n   410→      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n   411→    );\n   412→    let totalDeleted = 0;\n   413→    while (true) {\n   414→      const result = deleteChunk.run(cutoff, chunkSize);\n   415→      totalDeleted += result.changes;\n   416→      if (result.changes < chunkSize) break;\n   417→      await new Promise<void>((resolve) => setImmediate(resolve));\n   418→    }\n   419→    return totalDeleted;\n   420→  }\n   421→\n   422→  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n   423→  record(entry: AuditEntry): void {\n   424→    this.buffer.push({\n   425→      timestamp: new Date().toISOString(),\n   426→      action: entry.action,\n   427→      tenantId: entry.tenantId ?? null,\n   428→      actor: entry.actor ?? null,\n   429→      resourceType: 'resourceType' in entry ? entry.resourceType : null,\n   430→      resourceId: 'resourceId' in entry ? (entry.resourceId ?? null) : null,\n   431→      detail: 'detail' in entry ? JSON.stringify(entry.detail) : null,\n   432→      ipAddress: entry.ipAddress ?? null,\n   433→    });\n   434→    if (this.buffer.length >= BUFFER_FLUSH_SIZE) {\n   435→      this.flush();\n   436→    }\n   437→  }\n   438→\n   439→  /** Flush buffered entries to SQLite in a single transaction, computing chain hashes. */\n   440→  flush(): void {\n   441→    if (this.buffer.length === 0) return;\n   442→    const batch = this.buffer;\n   443→    this.buffer = [];\n   444→\n   445→    // Compute chain hashes for the batch\n   446→    const hashes: string[] = [];\n   447→    let prevHash = this.lastHash;\n   448→    for (const entry of batch) {\n   449→      prevHash = computeChainHash(prevHash, entry);\n   450→      hashes.push(prevHash);\n   451→    }\n   452→\n   453→    try {\n   454→      this.batchInsert(batch, hashes);\n   455→      this.lastHash = prevHash;\n   456→    } catch (err) {\n   457→      this.logger.error({ err, count: batch.length }, 'Audit batch write failed — audit trail gap');\n   458→    }\n   459→  }\n   460→\n   461→  /** Aggregated audit event statistics for dashboard consumption. */\n   462→  stats(opts?: {\n   463→    tenantId?: string;\n   464→    since?: string;\n   465→    until?: string;\n   466→    bucket?: 'hour' | 'day';\n   467→  }): {\n   468→    byAction: { action: string; count: number }[];\n   469→    byTenant: { tenant_id: string; count: number }[];\n   470→    topActors: { actor: string; count: number }[];\n   471→    trend: { bucket: string; count: number }[];\n   472→  } {\n   473→    this.flush(); // ensure buffered entries are visible\n   474→\n   475→    const params: unknown[] = [];\n   476→    const clauses: string[] = [];\n   477→    if (opts?.tenantId) { clauses.push('tenant_id = ?'); params.push(opts.tenantId); }\n   478→    if (opts?.since) { clauses.push('timestamp >= ?'); params.push(opts.since); }\n   479→    if (opts?.until) { clauses.push('timestamp < ?'); params.push(opts.until); }\n   480→    const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   481→\n   482→    const bucketExpr = opts?.bucket === 'hour'\n   483→      ? \"substr(timestamp, 1, 13)\"  // YYYY-MM-DDTHH\n   484→      : \"substr(timestamp, 1, 10)\"; // YYYY-MM-DD\n   485→\n   486→    const byAction = this.db.prepare(\n   487→      `SELECT action, COUNT(*) as count FROM audit_events ${where} GROUP BY action ORDER BY count DESC`,\n   488→    ).all(...params) as { action: string; count: number }[];\n   489→\n   490→    const byTenant = this.db.prepare(\n   491→      `SELECT COALESCE(tenant_id, '__none__') as tenant_id, COUNT(*) as count FROM audit_events ${where} GROUP BY tenant_id ORDER BY count DESC LIMIT 50`,\n   492→    ).all(...params) as { tenant_id: string; count: number }[];\n   493→\n   494→    const topActors = this.db.prepare(\n   495→      `SELECT COALESCE(actor, '__none__') as actor, COUNT(*) as count FROM audit_events ${where} GROUP BY actor ORDER BY count DESC LIMIT 20`,\n   496→    ).all(...params) as { actor: string; count: number }[];\n   497→\n   498→    const trend = this.db.prepare(\n   499→      `SELECT ${bucketExpr} as bucket, COUNT(*) as count FROM audit_events ${where} GROUP BY bucket ORDER BY bucket ASC`,\n   500→    ).all(...params) as { bucket: string; count: number }[];\n   501→\n   502→    return { byAction, byTenant, topActors, trend };\n   503→  }\n   504→\n   505→  /** Query audit events with optional filters. */\n   506→  query(opts?: {\n   507→    tenantId?: string;\n   508→    action?: AuditAction;\n   509→    since?: string;\n   510→    until?: string;\n   511→    actor?: string;\n   512→    resourceType?: string;\n   513→    resourceId?: string;\n   514→    limit?: number;\n   515→    offset?: number;\n   516→  }): AuditEvent[] {\n   517→    const params: unknown[] = [];\n   518→    const clauses: string[] = [];\n   519→    const keyParts: string[] = [];\n   520→\n   521→    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n   522→    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n   523→    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n   524→    if (opts?.until) { clauses.push('timestamp <= ?'); keyParts.push('until'); params.push(opts.until); }\n   525→    if (opts?.actor) { clauses.push('actor = ?'); keyParts.push('actor'); params.push(opts.actor); }\n   526→    if (opts?.resourceType) { clauses.push('resource_type = ?'); keyParts.push('rtype'); params.push(opts.resourceType); }\n   527→    if (opts?.resourceId) { clauses.push('resource_id = ?'); keyParts.push('rid'); params.push(opts.resourceId); }\n   528→\n   529→    const key = keyParts.join('-') || 'none';\n   530→    let stmt = this.queryStmtCache.get(key);\n   531→    if (!stmt) {\n   532→      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   533→      stmt = this.db.prepare(\n   534→        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n   535→      );\n   536→      this.queryStmtCache.set(key, stmt);\n   537→    }\n   538→\n   539→    const limit = opts?.limit ?? 100;\n   540→    const offset = opts?.offset ?? 0;\n   541→\n   542→    return stmt.all(...params, limit, offset) as AuditEvent[];\n   543→  }\n   544→\n   545→  /**\n   546→   * Verify the integrity of the audit hash chain.\n   547→   * Iterates all chained rows and checks that each hash is consistent with\n   548→   * its predecessor. Pre-chain rows (migrated without prev_hash) are skipped.\n   549→   * If rows were purged, the chain will break at the first remaining row\n   550→   * — this is by design (deletions are detectable).\n   551→   *\n   552→   * When `since`/`until` are provided, only rows within that timestamp range\n   553→   * are checked. The initial previous-hash is seeded from the last chained\n   554→   * row before the range (or genesis if none exists).\n   555→   */\n   556→  verify(opts?: { since?: string; until?: string }): ChainVerifyResult {\n   557→    this.flush(); // ensure all buffered entries are persisted\n   558→\n   559→    const hasRange = opts?.since || opts?.until;\n   560→    const clauses: string[] = [];\n   561→    const params: unknown[] = [];\n   562→    if (opts?.since) { clauses.push('timestamp >= ?'); params.push(opts.since); }\n   563→    if (opts?.until) { clauses.push('timestamp < ?'); params.push(opts.until); }\n   564→    const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   565→\n   566→    const iter = this.db.prepare(\n   567→      `SELECT * FROM audit_events ${where} ORDER BY id ASC`,\n   568→    ).iterate(...params);\n   569→\n   570→    // Seed the previous hash: for ranged queries, look up the last chained\n   571→    // row before the first matching row; for full scans use genesis.\n   572→    let prevHash = GENESIS_HASH;\n   573→    let seeded = !hasRange; // full scan is pre-seeded with genesis\n   574→\n   575→    let verifiedCount = 0;\n   576→\n   577→    for (const raw of iter) {\n   578→      const row = raw as AuditEvent;\n   579→      if (row.prev_hash === null) continue; // pre-chain row\n   580→\n   581→      // Lazily seed prevHash on the first chained row of a ranged query\n   582→      if (!seeded) {\n   583→        const prev = this.db.prepare(\n   584→          'SELECT prev_hash FROM audit_events WHERE id < ? AND prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n   585→        ).get(row.id) as { prev_hash: string } | undefined;\n   586→        prevHash = prev?.prev_hash ?? GENESIS_HASH;\n   587→        seeded = true;\n   588→      }\n   589→\n   590→      const expected = computeChainHash(prevHash, {\n   591→        timestamp: row.timestamp,\n   592→        action: row.action,\n   593→        tenantId: row.tenant_id,\n   594→        actor: row.actor,\n   595→        resourceType: row.resource_type,\n   596→        resourceId: row.resource_id,\n   597→        detail: row.detail,\n   598→        ipAddress: row.ip_address,\n   599→      });\n   600→\n   601→      if (row.prev_hash !== expected) {\n   602→        return { valid: false, verifiedCount, brokenAtId: row.id };\n   603→      }\n   604→\n   605→      prevHash = row.prev_hash;\n   606→      verifiedCount++;\n   607→    }\n   608→\n   609→    return { valid: true, verifiedCount };\n   610→  }\n   611→\n   612→  close(): void {\n   613→    if (this.flushTimer) {\n   614→      clearInterval(this.flushTimer);\n   615→      this.flushTimer = null;\n   616→    }\n   617→    this.flush();\n   618→    try { this.db.close(); } catch { /* best effort */ }\n   619→  }\n   620→}\n   621→"}]},"parent_tool_use_id":null,"session_id":"2563504b-2e19-4cf6-b3f7-2a4b970d6c3d","uuid":"8186342a-bd0b-4ecc-b851-7e718841f418","timestamp":"2026-03-19T08:16:08.730Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\auditLog.ts","content":"import crypto from 'node:crypto';\nimport Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\n\n/** SHA-256 hash chain genesis value (64 hex zeros). */\nconst GENESIS_HASH = '0'.repeat(64);\n\n/**\n * Compute a chain hash: SHA-256(previousHash + deterministic JSON of entry fields).\n * Each entry's hash commits to the entire chain history before it.\n */\nfunction computeChainHash(prevHash: string, entry: BufferedEntry): string {\n  const payload = prevHash + JSON.stringify([\n    entry.timestamp,\n    entry.action,\n    entry.tenantId,\n    entry.actor,\n    entry.resourceType,\n    entry.resourceId,\n    entry.detail,\n    entry.ipAddress,\n  ]);\n  return crypto.createHash('sha256').update(payload).digest('hex');\n}\n\nconst AUDIT_SCHEMA = `\nCREATE TABLE IF NOT EXISTS audit_events (\n  id INTEGER PRIMARY KEY AUTOINCREMENT,\n  timestamp TEXT NOT NULL,\n  action TEXT NOT NULL,\n  tenant_id TEXT,\n  actor TEXT,\n  resource_type TEXT,\n  resource_id TEXT,\n  detail TEXT,\n  ip_address TEXT,\n  prev_hash TEXT\n);\nCREATE INDEX IF NOT EXISTS idx_audit_ts ON audit_events(timestamp);\nCREATE INDEX IF NOT EXISTS idx_audit_tenant_action_ts ON audit_events(tenant_id, action, timestamp);\nCREATE INDEX IF NOT EXISTS idx_audit_actor ON audit_events(actor);\nCREATE INDEX IF NOT EXISTS idx_audit_resource_type ON audit_events(resource_type);\nDROP INDEX IF EXISTS idx_audit_tenant_ts;\nDROP INDEX IF EXISTS idx_audit_action;\n`;\n\n/** Thrown when an audit event fails to persist — signals an audit trail gap. */\nexport class AuditWriteError extends Error {\n  constructor(\n    public readonly entry: AuditEntry,\n    cause: unknown,\n  ) {\n    super(`Audit write failed for action \"${entry.action}\"`);\n    this.name = 'AuditWriteError';\n    this.cause = cause;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Discriminated-union audit entries — each action carries its own typed payload\n// ---------------------------------------------------------------------------\n\n/** Fields common to every audit entry. */\ninterface AuditEntryBase {\n  tenantId?: string;\n  actor?: string;\n  ipAddress?: string;\n}\n\n// --- Key management ---\ninterface KeyEncryptEntry extends AuditEntryBase {\n  action: 'key:encrypt';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyDecryptEntry extends AuditEntryBase {\n  action: 'key:decrypt';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyDecryptFailedEntry extends AuditEntryBase {\n  action: 'key:decrypt_failed';\n  resourceType: 'credential';\n  resourceId: string;\n  detail: { reason: string };\n}\n\ninterface KeyDeleteEntry extends AuditEntryBase {\n  action: 'key:delete';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyAccessEntry extends AuditEntryBase {\n  action: 'key:access';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyDeriveEntry extends AuditEntryBase {\n  action: 'key:derive';\n}\n\n// --- Persona management ---\ninterface PersonaCreateEntry extends AuditEntryBase {\n  action: 'persona:create';\n  resourceType: 'persona';\n  resourceId: string;\n}\n\ninterface PersonaDeleteEntry extends AuditEntryBase {\n  action: 'persona:delete';\n  resourceType: 'persona';\n  resourceId: string;\n}\n\n// --- Tool management ---\ninterface ToolLinkEntry extends AuditEntryBase {\n  action: 'tool:link';\n  resourceType: 'persona';\n  resourceId: string;\n  detail: { toolId: string };\n}\n\ninterface ToolDefinitionCreateEntry extends AuditEntryBase {\n  action: 'tool-definition:create';\n  resourceType: 'toolDefinition';\n  resourceId: string;\n}\n\n// --- Credential linking ---\ninterface CredentialLinkEntry extends AuditEntryBase {\n  action: 'credential:link';\n  resourceType: 'persona';\n  resourceId: string;\n  detail: { credentialId: string };\n}\n\n// --- Subscriptions ---\ninterface SubscriptionCreateEntry extends AuditEntryBase {\n  action: 'subscription:create';\n  resourceType: 'subscription';\n  resourceId: string;\n  detail: { personaId: string; eventType: string };\n}\n\ninterface SubscriptionUpdateEntry extends AuditEntryBase {\n  action: 'subscription:update';\n  resourceType: 'subscription';\n  resourceId: string;\n}\n\ninterface SubscriptionDeleteEntry extends AuditEntryBase {\n  action: 'subscription:delete';\n  resourceType: 'subscription';\n  resourceId: string;\n}\n\n// --- Worker pool ---\ninterface WorkerConnectedEntry extends AuditEntryBase {\n  action: 'worker:connected';\n  detail: { workerId: string };\n}\n\ninterface WorkerDisconnectedEntry extends AuditEntryBase {\n  action: 'worker:disconnected';\n  detail: { workerId: string };\n  resourceId?: string;\n}\n\n// --- Triggers ---\ninterface TriggerCreateEntry extends AuditEntryBase {\n  action: 'trigger:create';\n  resourceType: 'trigger';\n  resourceId?: string;\n}\n\ninterface TriggerUpdateEntry extends AuditEntryBase {\n  action: 'trigger:update';\n  resourceType: 'trigger';\n  resourceId: string;\n}\n\ninterface TriggerDeleteEntry extends AuditEntryBase {\n  action: 'trigger:delete';\n  resourceType: 'trigger';\n  resourceId: string;\n}\n\n// --- Events ---\ninterface EventPublishEntry extends AuditEntryBase {\n  action: 'event:publish';\n  resourceType: 'event';\n  resourceId?: string;\n}\n\ninterface EventUpdateEntry extends AuditEntryBase {\n  action: 'event:update';\n  resourceType: 'event';\n  resourceId: string;\n}\n\n// --- Executions ---\ninterface ExecutionSubmitEntry extends AuditEntryBase {\n  action: 'execution:submit';\n  resourceType: 'execution';\n  resourceId?: string;\n}\n\n// --- Webhooks ---\ninterface WebhookReceiveEntry extends AuditEntryBase {\n  action: 'webhook:receive';\n  resourceType: 'webhook';\n  resourceId: string;\n}\n\n// --- OAuth lifecycle ---\ninterface OAuthAuthorizeEntry extends AuditEntryBase {\n  action: 'oauth:authorize';\n  resourceType: 'oauth';\n  resourceId: string; // state parameter\n}\n\ninterface OAuthExchangeEntry extends AuditEntryBase {\n  action: 'oauth:exchange';\n  resourceType: 'oauth';\n  detail: { scopes: string[]; expiresAt: string };\n}\n\ninterface OAuthRefreshEntry extends AuditEntryBase {\n  action: 'oauth:refresh';\n  resourceType: 'oauth';\n  detail: { expiresAt: string };\n}\n\ninterface OAuthRefreshFailedEntry extends AuditEntryBase {\n  action: 'oauth:refresh_failed';\n  resourceType: 'oauth';\n  detail: { reason: string; errorType?: string };\n}\n\ninterface OAuthTokenErrorEntry extends AuditEntryBase {\n  action: 'oauth:token_error';\n  resourceType: 'oauth';\n  detail: { errorType: string; status?: number; transient: boolean; context: string };\n}\n\ninterface OAuthDisconnectEntry extends AuditEntryBase {\n  action: 'oauth:disconnect';\n  resourceType: 'oauth';\n  detail: { serverRevoked: boolean };\n}\n\n// --- Token lifecycle ---\ninterface TokenInjectEntry extends AuditEntryBase {\n  action: 'token:inject';\n  resourceType: 'token';\n}\n\ninterface TokenExpiringSoonEntry extends AuditEntryBase {\n  action: 'token:expiring_soon';\n  resourceType: 'oauth';\n  detail: { expiresAt: string; remainingMinutes: number };\n}\n\n/** Discriminated union of all audit event types. */\nexport type AuditEntry =\n  | KeyEncryptEntry\n  | KeyDecryptEntry\n  | KeyDecryptFailedEntry\n  | KeyDeleteEntry\n  | KeyAccessEntry\n  | KeyDeriveEntry\n  | PersonaCreateEntry\n  | PersonaDeleteEntry\n  | ToolLinkEntry\n  | ToolDefinitionCreateEntry\n  | CredentialLinkEntry\n  | SubscriptionCreateEntry\n  | SubscriptionUpdateEntry\n  | SubscriptionDeleteEntry\n  | WorkerConnectedEntry\n  | WorkerDisconnectedEntry\n  | TriggerCreateEntry\n  | TriggerUpdateEntry\n  | TriggerDeleteEntry\n  | EventPublishEntry\n  | EventUpdateEntry\n  | ExecutionSubmitEntry\n  | WebhookReceiveEntry\n  | OAuthAuthorizeEntry\n  | OAuthExchangeEntry\n  | OAuthRefreshEntry\n  | OAuthRefreshFailedEntry\n  | OAuthTokenErrorEntry\n  | OAuthDisconnectEntry\n  | TokenInjectEntry\n  | TokenExpiringSoonEntry;\n\n/** String-literal union of all valid audit actions. */\nexport type AuditAction = AuditEntry['action'];\n\n/** Row shape returned by audit_events queries. */\nexport interface AuditEvent {\n  id: number;\n  timestamp: string;\n  action: string;\n  tenant_id: string | null;\n  actor: string | null;\n  resource_type: string | null;\n  resource_id: string | null;\n  detail: string | null;\n  ip_address: string | null;\n  prev_hash: string | null;\n}\n\n/** Result of verifying the audit hash chain. */\nexport interface ChainVerifyResult {\n  valid: boolean;\n  verifiedCount: number;\n  brokenAtId?: number;\n}\n\n/** Max entries buffered before an automatic flush. */\nconst BUFFER_FLUSH_SIZE = 50;\n/** Interval (ms) between timer-based flushes. */\nconst BUFFER_FLUSH_INTERVAL_MS = 100;\n\ninterface BufferedEntry {\n  timestamp: string;\n  action: string;\n  tenantId: string | null;\n  actor: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  detail: string | null;\n  ipAddress: string | null;\n}\n\nexport class AuditLog {\n  private db: Database.Database;\n  private insertStmt: Database.Statement;\n  private queryStmtCache = new Map<string, Database.Statement>();\n  private buffer: BufferedEntry[] = [];\n  private flushTimer: NodeJS.Timeout | null = null;\n  private batchInsert: (entries: BufferedEntry[], hashes: string[]) => void;\n  private lastHash: string;\n\n  constructor(\n    dbPath: string,\n    private logger: Logger,\n  ) {\n    this.db = new Database(dbPath);\n    this.db.pragma('journal_mode = WAL');\n    this.db.exec(AUDIT_SCHEMA);\n\n    // Migration: add prev_hash column to existing databases that lack it\n    const cols = this.db.pragma('table_info(audit_events)') as { name: string }[];\n    if (!cols.some((c) => c.name === 'prev_hash')) {\n      this.db.exec('ALTER TABLE audit_events ADD COLUMN prev_hash TEXT');\n    }\n\n    this.insertStmt = this.db.prepare(\n      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address, prev_hash) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',\n    );\n\n    // Initialize chain from last stored hash (or genesis for empty / pre-chain DBs)\n    const lastRow = this.db.prepare(\n      'SELECT prev_hash FROM audit_events WHERE prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n    ).get() as { prev_hash: string } | undefined;\n    this.lastHash = lastRow?.prev_hash ?? GENESIS_HASH;\n\n    // Wrap N inserts in a single transaction — one fsync instead of N\n    const stmt = this.insertStmt;\n    this.batchInsert = this.db.transaction((entries: BufferedEntry[], hashes: string[]) => {\n      for (let i = 0; i < entries.length; i++) {\n        const e = entries[i];\n        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress, hashes[i]);\n      }\n    });\n\n    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n\n    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled, hash-chain active)');\n  }\n\n  /** Expose the underlying database for use by RetentionPolicy. */\n  getDb(): Database.Database {\n    return this.db;\n  }\n\n  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n  countEvents(before?: string): number {\n    const stmt = before\n      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n    return row.cnt;\n  }\n\n  /**\n   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   * yielding the event loop between batches so concurrent DB operations\n   * are not starved during large purges.\n   */\n  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n    const deleteChunk = this.db.prepare(\n      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n    );\n    let totalDeleted = 0;\n    while (true) {\n      const result = deleteChunk.run(cutoff, chunkSize);\n      totalDeleted += result.changes;\n      if (result.changes < chunkSize) break;\n      await new Promise<void>((resolve) => setImmediate(resolve));\n    }\n    return totalDeleted;\n  }\n\n  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n  record(entry: AuditEntry): void {\n    this.buffer.push({\n      timestamp: new Date().toISOString(),\n      action: entry.action,\n      tenantId: entry.tenantId ?? null,\n      actor: entry.actor ?? null,\n      resourceType: 'resourceType' in entry ? entry.resourceType : null,\n      resourceId: 'resourceId' in entry ? (entry.resourceId ?? null) : null,\n      detail: 'detail' in entry ? JSON.stringify(entry.detail) : null,\n      ipAddress: entry.ipAddress ?? null,\n    });\n    if (this.buffer.length >= BUFFER_FLUSH_SIZE) {\n      this.flush();\n    }\n  }\n\n  /** Flush buffered entries to SQLite in a single transaction, computing chain hashes. */\n  flush(): void {\n    if (this.buffer.length === 0) return;\n    const batch = this.buffer;\n    this.buffer = [];\n\n    // Compute chain hashes for the batch\n    const hashes: string[] = [];\n    let prevHash = this.lastHash;\n    for (const entry of batch) {\n      prevHash = computeChainHash(prevHash, entry);\n      hashes.push(prevHash);\n    }\n\n    try {\n      this.batchInsert(batch, hashes);\n      this.lastHash = prevHash;\n    } catch (err) {\n      this.logger.error({ err, count: batch.length }, 'Audit batch write failed — audit trail gap');\n    }\n  }\n\n  /** Aggregated audit event statistics for dashboard consumption. */\n  stats(opts?: {\n    tenantId?: string;\n    since?: string;\n    until?: string;\n    bucket?: 'hour' | 'day';\n  }): {\n    byAction: { action: string; count: number }[];\n    byTenant: { tenant_id: string; count: number }[];\n    topActors: { actor: string; count: number }[];\n    trend: { bucket: string; count: number }[];\n  } {\n    this.flush(); // ensure buffered entries are visible\n\n    const params: unknown[] = [];\n    const clauses: string[] = [];\n    if (opts?.tenantId) { clauses.push('tenant_id = ?'); params.push(opts.tenantId); }\n    if (opts?.since) { clauses.push('timestamp >= ?'); params.push(opts.since); }\n    if (opts?.until) { clauses.push('timestamp < ?'); params.push(opts.until); }\n    const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n\n    const bucketExpr = opts?.bucket === 'hour'\n      ? \"substr(timestamp, 1, 13)\"  // YYYY-MM-DDTHH\n      : \"substr(timestamp, 1, 10)\"; // YYYY-MM-DD\n\n    const byAction = this.db.prepare(\n      `SELECT action, COUNT(*) as count FROM audit_events ${where} GROUP BY action ORDER BY count DESC`,\n    ).all(...params) as { action: string; count: number }[];\n\n    const byTenant = this.db.prepare(\n      `SELECT COALESCE(tenant_id, '__none__') as tenant_id, COUNT(*) as count FROM audit_events ${where} GROUP BY tenant_id ORDER BY count DESC LIMIT 50`,\n    ).all(...params) as { tenant_id: string; count: number }[];\n\n    const topActors = this.db.prepare(\n      `SELECT COALESCE(actor, '__none__') as actor, COUNT(*) as count FROM audit_events ${where} GROUP BY actor ORDER BY count DESC LIMIT 20`,\n    ).all(...params) as { actor: string; count: number }[];\n\n    const trend = this.db.prepare(\n      `SELECT ${bucketExpr} as bucket, COUNT(*) as count FROM audit_events ${where} GROUP BY bucket ORDER BY bucket ASC`,\n    ).all(...params) as { bucket: string; count: number }[];\n\n    return { byAction, byTenant, topActors, trend };\n  }\n\n  /** Query audit events with optional filters. */\n  query(opts?: {\n    tenantId?: string;\n    action?: AuditAction;\n    since?: string;\n    until?: string;\n    actor?: string;\n    resourceType?: string;\n    resourceId?: string;\n    limit?: number;\n    offset?: number;\n  }): AuditEvent[] {\n    const params: unknown[] = [];\n    const clauses: string[] = [];\n    const keyParts: string[] = [];\n\n    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n    if (opts?.until) { clauses.push('timestamp <= ?'); keyParts.push('until'); params.push(opts.until); }\n    if (opts?.actor) { clauses.push('actor = ?'); keyParts.push('actor'); params.push(opts.actor); }\n    if (opts?.resourceType) { clauses.push('resource_type = ?'); keyParts.push('rtype'); params.push(opts.resourceType); }\n    if (opts?.resourceId) { clauses.push('resource_id = ?'); keyParts.push('rid'); params.push(opts.resourceId); }\n\n    const key = keyParts.join('-') || 'none';\n    let stmt = this.queryStmtCache.get(key);\n    if (!stmt) {\n      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n      stmt = this.db.prepare(\n        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n      );\n      this.queryStmtCache.set(key, stmt);\n    }\n\n    const limit = opts?.limit ?? 100;\n    const offset = opts?.offset ?? 0;\n\n    return stmt.all(...params, limit, offset) as AuditEvent[];\n  }\n\n  /**\n   * Verify the integrity of the audit hash chain.\n   * Iterates all chained rows and checks that each hash is consistent with\n   * its predecessor. Pre-chain rows (migrated without prev_hash) are skipped.\n   * If rows were purged, the chain will break at the first remaining row\n   * — this is by design (deletions are detectable).\n   *\n   * When `since`/`until` are provided, only rows within that timestamp range\n   * are checked. The initial previous-hash is seeded from the last chained\n   * row before the range (or genesis if none exists).\n   */\n  verify(opts?: { since?: string; until?: string }): ChainVerifyResult {\n    this.flush(); // ensure all buffered entries are persisted\n\n    const hasRange = opts?.since || opts?.until;\n    const clauses: string[] = [];\n    const params: unknown[] = [];\n    if (opts?.since) { clauses.push('timestamp >= ?'); params.push(opts.since); }\n    if (opts?.until) { clauses.push('timestamp < ?'); params.push(opts.until); }\n    const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n\n    const iter = this.db.prepare(\n      `SELECT * FROM audit_events ${where} ORDER BY id ASC`,\n    ).iterate(...params);\n\n    // Seed the previous hash: for ranged queries, look up the last chained\n    // row before the first matching row; for full scans use genesis.\n    let prevHash = GENESIS_HASH;\n    let seeded = !hasRange; // full scan is pre-seeded with genesis\n\n    let verifiedCount = 0;\n\n    for (const raw of iter) {\n      const row = raw as AuditEvent;\n      if (row.prev_hash === null) continue; // pre-chain row\n\n      // Lazily seed prevHash on the first chained row of a ranged query\n      if (!seeded) {\n        const prev = this.db.prepare(\n          'SELECT prev_hash FROM audit_events WHERE id < ? AND prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n        ).get(row.id) as { prev_hash: string } | undefined;\n        prevHash = prev?.prev_hash ?? GENESIS_HASH;\n        seeded = true;\n      }\n\n      const expected = computeChainHash(prevHash, {\n        timestamp: row.timestamp,\n        action: row.action,\n        tenantId: row.tenant_id,\n        actor: row.actor,\n        resourceType: row.resource_type,\n        resourceId: row.resource_id,\n        detail: row.detail,\n        ipAddress: row.ip_address,\n      });\n\n      if (row.prev_hash !== expected) {\n        return { valid: false, verifiedCount, brokenAtId: row.id };\n      }\n\n      prevHash = row.prev_hash;\n      verifiedCount++;\n    }\n\n    return { valid: true, verifiedCount };\n  }\n\n  close(): void {\n    if (this.flushTimer) {\n      clearInterval(this.flushTimer);\n      this.flushTimer = null;\n    }\n    this.flush();\n    try { this.db.close(); } catch { /* best effort */ }\n  }\n}\n","numLines":621,"startLine":1,"totalLines":621}}}
