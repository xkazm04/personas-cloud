tabase.Database, logger: Logger): void {\n   204→  const tablesToMigrate = [\n   205→    'persona_credentials',\n   206→    'persona_event_subscriptions',\n   207→    'persona_triggers',\n   208→    'persona_executions',\n   209→  ];\n   210→\n   211→  for (const table of tablesToMigrate) {\n   212→    const columns = stmt(db,`PRAGMA table_info(${table})`).all() as Array<{ name: string }>;\n   213→    const hasProjectId = columns.some(c => c.name === 'project_id');\n   214→    if (!hasProjectId) {\n   215→      db.exec(`ALTER TABLE ${table} ADD COLUMN project_id TEXT NOT NULL DEFAULT 'default'`);\n   216→      logger.info({ table }, 'Migration: added project_id column');\n   217→    }\n   218→  }\n   219→\n   220→  db.exec(`\n   221→    CREATE INDEX IF NOT EXISTS idx_personas_project ON personas(project_id);\n   222→    CREATE INDEX IF NOT EXISTS idx_pe_project ON persona_events(project_id);\n   223→    CREATE INDEX IF NOT EXISTS idx_pcred_project ON persona_credentials(project_id);\n   224→    CREATE INDEX IF NOT EXISTS idx_pes_project ON persona_event_subscriptions(project_id);\n   225→    CREATE INDEX IF NOT EXISTS idx_pes_event_type ON persona_event_subscriptions(event_type, enabled);\n   226→    CREATE INDEX IF NOT EXISTS idx_pt_project ON persona_triggers(project_id);\n   227→    DROP INDEX IF EXISTS idx_pt_next_trigger;\n   228→    CREATE INDEX IF NOT EXISTS idx_pt_due ON persona_triggers(enabled, next_trigger_at);\n   229→    CREATE INDEX IF NOT EXISTS idx_pex_project ON persona_executions(project_id);\n   230→  `);\n   231→\n   232→  // Add inference_profile_id to personas if missing\n   233→  const personaCols = stmt(db,'PRAGMA table_info(personas)').all() as Array<{ name: string }>;\n   234→  if (!personaCols.some(c => c.name === 'inference_profile_id')) {\n   235→    db.exec('ALTER TABLE personas ADD COLUMN inference_profile_id TEXT');\n   236→    logger.info('Migration: added inference_profile_id to personas');\n   237→  }\n   238→  if (!personaCols.som