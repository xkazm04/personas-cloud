[2026-03-18T17:11:30.774Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HVHS8fX6UGupcPNFgobraG","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import { getTableSpec, isMetrizable, isEphemeral } from '@dac-cloud/shared';\n     4→import type { MetrizableTableSpec, EphemeralTableSpec } from '@dac-cloud/shared';\n     5→import type { TenantDbManager } from './tenantDbManager.js';\n     6→\n     7→// Validate registry classification at import time — if someone changes the\n     8→// registry without updating this module the build still passes but the runtime\n     9→// assertion catches the mismatch immediately.\n    10→const execSpec = getTableSpec('persona_executions');\n    11→const eventsSpec = getTableSpec('persona_events');\n    12→if (!execSpec || !isMetrizable(execSpec)) {\n    13→  throw new Error('persona_executions must be registered as metrizable in TABLE_REGISTRY');\n    14→}\n    15→if (!eventsSpec || !isEphemeral(eventsSpec)) {\n    16→  throw new Error('persona_events must be registered as ephemeral in TABLE_REGISTRY');\n    17→}\n    18→\n    19→/** Maximum fraction of rows a single purge cycle may delete (safety cap). */\n    20→const EXEC_MAX_PURGE_FRACTION = (execSpec as MetrizableTableSpec).maxPurgeFraction ?? 0.8;\n    21→const EVENTS_MAX_PURGE_FRACTION = (eventsSpec as EphemeralTableSpec).maxPurgeFraction ?? 0.8;\n    22→\n    23→/** Rows deleted per chunk to keep individual lock durations short (~50ms). */\n    24→const PURGE_CHUNK_SIZE = 5000;\n    25→\n    26→/** Yield the event loop so concurrent reads/writes can proceed between batches. */\n    27→function yieldTick(): Promise<void> {\n    28→  return new Promise((resolve) => setImmediate(resolve));\n    29→}\n    30→\n    31→/**\n    32→ * Daily retention job: purge old executions/events and aggregate daily metrics.\n    33→ */\n    34→export function startRetentionJob(\n    35→  tenantDbManager: TenantDbManager,\n    36→  retentionDays: number,\n    37→  logger: Logger,\n    38→): NodeJS.Timeout {\n    39→  logger.info({ retentionDays }, 'Retention job started (daily)');\n    40→\n    41→  // Run once on startup then daily\n    42→  setTimeout(() => runRetention(tenantDbManager, retentionDays, logger), 5000);\n    43→\n    44→  return setInterval(() => {\n    45→    runRetention(tenantDbManager, retentionDays, logger);\n    46→  }, 24 * 60 * 60 * 1000);\n    47→}\n    48→\n    49→/**\n    50→ * Delete rows in chunks of PURGE_CHUNK_SIZE, yielding the event loop between\n    51→ * batches so other DB operations are not starved.\n    52→ */\n    53→async function chunkedDelete(db: Database.Database, sql: string, params: unknown[]): Promise<number> {\n    54→  const stmt = db.prepare(sql);\n    55→  let totalDeleted = 0;\n    56→  while (true) {\n    57→    const result = stmt.run(...params, PURGE_CHUNK_SIZE);\n    58→    totalDeleted += result.changes;\n    59→    if (result.changes < PURGE_CHUNK_SIZE) break;\n    60→    await yieldTick();\n    61→  }\n    62→  return totalDeleted;\n    63→}\n    64→\n    65→async function runRetention(\n    66→  tenantDbManager: TenantDbManager,\n    67→  retentionDays: number,\n    68→  logger: Logger,\n    69→): Promise<void> {\n    70→  const cutoff = new Date(Date.now() - retentionDays * 86_400_000).toISOString();\n    71→\n    72→  const tenantIds = tenantDbManager.listTenantIds();\n    73→  for (const projectId of tenantIds) {\n    74→    try {\n    75→      const db = tenantDbManager.getTenantDb(projectId);\n    76→      await runTenantRetention(db, projectId, cutoff, retentionDays, logger);\n    77→    } catch (err) {\n    78→      logger.error({ err, projectId }, 'Retention cleanup failed for tenant');\n    79→    }\n    80→    // Yield between tenants so the event loop stays responsive\n    81→    await yieldTick();\n    82→  }\n    83→}\n    84→\n    85→async function runTenantRetention(\n    86→  db: Database.Database,\n    87→  projectId: string,\n    88→  cutoff: string,\n    89→  retentionDays: number,\n    90→  logger: Logger,\n    91→): Promise<void> {\n    92→  // ── Batched index scan: collect purgeable execution rowids in chunks ──\n    93→  // Both the aggregation (Step 1) and the delete (Step 2) operate on\n    94→  // this pre-collected set instead of scanning persona_executions twice.\n    95→  // The collection itself is batched to avoid holding a write lock while\n    96→  // inserting millions of rowids after a long retention gap.\n    97→  db.exec('CREATE TEMP TABLE IF NOT EXISTS _ret_ids (id INTEGER PRIMARY KEY)');\n    98→  db.prepare('DELETE FROM _ret_ids').run();\n    99→  {\n   100→    const collectStmt = db.prepare(`\n   101→      INSERT INTO _ret_ids (id)\n   102→      SELECT rowid FROM persona_executions\n   103→      WHERE rowid > ? AND created_at < ? AND status IN ('completed', 'failed', 'cancelled')\n   104→      ORDER BY rowid\n   105→      LIMIT ?\n   106→    `);\n   107→    let cursor = 0;\n   108→    while (true) {\n   109→      const result = collectStmt.run(cursor, cutoff, PURGE_CHUNK_SIZE);\n   110→      if (result.changes === 0) break;\n   111→      const maxRow = db.prepare('SELECT MAX(id) as m FROM _ret_ids').get() as { m: number };\n   112→      cursor = maxRow.m;\n   113→      if (result.changes < PURGE_CHUNK_SIZE) break;\n   114→      await yieldTick();\n   115→    }\n   116→  }\n   117→\n   118→  // ── Step 1: Aggregate metrics in a short transaction ──────────────\n   119→  // Watermark-based: each source row is counted exactly once, so the\n   120→  // additive upsert is safe even if a previous run crashed mid-delete.\n   121→  // No heavy deletes here — lock duration is brief.\n   122→  const aggregatedDays = db.transaction(() => {\n   123→    const watermarkRow = db.prepare(\n   124→      \"SELECT last_rowid FROM retention_watermark WHERE key = 'executions'\",\n   125→    ).get() as { last_rowid: number } | undefined;\n   126→    const lastRowid = watermarkRow?.last_rowid ?? 0;\n   127→\n   128→    // Max rowid above the watermark (reads temp table only, no main-table scan)\n   129→    const maxRow = db.prepare(\n   130→      'SELECT MAX(id) as max_rowid FROM _ret_ids WHERE id > ?',\n   131→    ).get(lastRowid) as { max_rowid: number | null } | undefined;\n   132→    const newWatermark = maxRow?.max_rowid ?? lastRowid;\n   133→\n   134→    // Aggregate only never-before-counted rows. The JOIN fetches data columns\n   135→    // via direct rowid B-tree lookups rather than a redundant index range scan.\n   136→    const rows = db.prepare(`\n   137→      SELECT\n   138→        date(pe.created_at) as day,\n   139→        COUNT(*) as total,\n   140→        SUM(CASE WHEN pe.status = 'completed' THEN 1 ELSE 0 END) as completed,\n   141→        SUM(CASE WHEN pe.status = 'failed' THEN 1 ELSE 0 END) as failed,\n   142→        COALESCE(SUM(pe.cost_usd), 0) as cost,\n   143→        COALESCE(SUM(pe.duration_ms), 0) as duration\n   144→      FROM _ret_ids r\n   145→      JOIN persona_executions pe ON pe.rowid = r.id\n   146→      WHERE r.id > ?\n   147→      GROUP BY date(pe.created_at)\n   148→    `).all(lastRowid) as Array<{ day: string; total: number; completed: number; failed: number; cost: number; duration: number }>;\n   149→\n   150→    const upsertStmt = db.prepare(`\n   151→      INSERT INTO daily_metrics (date, total_executions, completed, failed, total_cost_usd, total_duration_ms)\n   152→      VALUES (?, ?, ?, ?, ?, ?)\n   153→      ON CONFLICT(date) DO UPDATE SET\n   154→        total_executions = total_executions + excluded.total_executions,\n   155→        completed = completed + excluded.completed,\n   156→        failed = failed + excluded.failed,\n   157→        total_cost_usd = total_cost_usd + excluded.total_cost_usd,\n   158→        total_duration_ms = total_duration_ms + excluded.total_duration_ms\n   159→    `);\n   160→    for (const row of rows) {\n   161→      upsertStmt.run(row.day, row.total, row.completed, row.failed, row.cost, row.duration);\n   162→    }\n   163→\n   164→    db.prepare(`\n   165→      INSERT INTO retention_watermark (key, last_rowid) VALUES ('executions', ?)\n   166→      ON CONFLICT(key) DO UPDATE SET last_rowid = excluded.last_rowid\n   167→    `).run(newWatermark);\n   168→\n   169→    return rows.length;\n   170→  })();\n   171→\n   172→  // ── Step 2: Delete execution rows using pre-collected rowids ──────\n   173→  // Pre-purge sanity check: refuse to delete more than EXEC_MAX_PURGE_FRACTION of all rows\n   174→  const execTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_executions').get() as { cnt: number };\n   175→  const execCandidateRow = db.prepare('SELECT COUNT(*) as cnt FROM _ret_ids').get() as { cnt: number };\n   176→\n   177→  let purgedExecutions = 0;\n   178→  if (execTotalRow.cnt > 0 && execCandidateRow.cnt / execTotalRow.cnt > EXEC_MAX_PURGE_FRACTION) {\n   179→    logger.error(\n   180→      { projectId, total: execTotalRow.cnt, candidates: execCandidateRow.cnt, cutoff, maxFraction: EXEC_MAX_PURGE_FRACTION },\n   181→      'Execution purge aborted: deletion would exceed safety cap',\n   182→    );\n   183→  } else {\n   184→    // Each chunk is its own implicit transaction (~50ms lock), with event-loop\n   185→    // yields between chunks so concurrent operations can proceed.\n   186→    const deleteStmt = db.prepare(\n   187→      'DELETE FROM persona_executions WHERE rowid IN (SELECT id FROM _ret_ids LIMIT ?)',\n   188→    );\n   189→    const trimStmt = db.prepare(\n   190→      'DELETE FROM _ret_ids WHERE id IN (SELECT id FROM _ret_ids LIMIT ?)',\n   191→    );\n   192→    while (true) {\n   193→      const result = deleteStmt.run(PURGE_CHUNK_SIZE);\n   194→      purgedExecutions += result.changes;\n   195→      trimStmt.run(PURGE_CHUNK_SIZE);\n   196→      if (result.changes < PURGE_CHUNK_SIZE) break;\n   197→      await yieldTick();\n   198→    }\n   199→  }\n   200→\n   201→  // ── Step 3: Purge old events in batched chunks ────────────────────\n   202→  // Pre-purge sanity check for events\n   203→  const eventsTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_events').get() as { cnt: number };\n   204→  const eventsCandidateRow = db.prepare(\n   205→    \"SELECT COUNT(*) as cnt FROM persona_events WHERE created_at < ?\",\n   206→  ).get(cutoff) as { cnt: number };\n   207→\n   208→  let purgedEvents = 0;\n   209→  let purgedStuckEvents = 0;\n   210→  if (eventsTotalRow.cnt > 0 && eventsCandidateRow.cnt / eventsTotalRow.cnt > EVENTS_MAX_PURGE_FRACTION) {\n   211→    logger.error(\n   212→      { projectId, total: eventsTotalRow.cnt, candidates: eventsCandidateRow.cnt, cutoff, maxFraction: EVENTS_MAX_PURGE_FRACTION },\n   213→      'Event purge aborted: deletion would exceed safety cap',\n   214→    );\n   215→  } else {\n   216→    purgedEvents = await chunkedDelete(\n   217→      db,\n   218→      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status NOT IN ('pending', 'processing') LIMIT ?)\",\n   219→      [cutoff],\n   220→    );\n   221→\n   222→    // Safety net: purge stuck pending/processing events older than 7x retentionDays.\n   223→    const stuckCutoff = new Date(Date.now() - retentionDays * 7 * 86_400_000).toISOString();\n   224→    purgedStuckEvents = await chunkedDelete(\n   225→      db,\n   226→      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status IN ('pending', 'processing') LIMIT ?)\",\n   227→      [stuckCutoff],\n   228→    );\n   229→  }\n   230→\n   231→  if (purgedExecutions > 0 || purgedEvents > 0 || purgedStuckEvents > 0) {\n   232→    logger.info({\n   233→      projectId,\n   234→      purgedExecutions,\n   235→      purgedEvents,\n   236→      purgedStuckEvents,\n   237→      aggregatedDays,\n   238→    }, 'Retention cleanup complete');\n   239→  }\n   240→}\n   241→"}]},"parent_tool_use_id":null,"session_id":"4bd4a98a-e1f0-4d70-aa28-4677900721cc","uuid":"0ce77ac3-9adf-4d13-9145-83177da3adf6","timestamp":"2026-03-18T17:11:30.302Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\retention.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport { getTableSpec, isMetrizable, isEphemeral } from '@dac-cloud/shared';\nimport type { MetrizableTableSpec, EphemeralTableSpec } from '@dac-cloud/shared';\nimport type { TenantDbManager } from './tenantDbManager.js';\n\n// Validate registry classification at import time — if someone changes the\n// registry without updating this module the build still passes but the runtime\n// assertion catches the mismatch immediately.\nconst execSpec = getTableSpec('persona_executions');\nconst eventsSpec = getTableSpec('persona_events');\nif (!execSpec || !isMetrizable(execSpec)) {\n  throw new Error('persona_executions must be registered as metrizable in TABLE_REGISTRY');\n}\nif (!eventsSpec || !isEphemeral(eventsSpec)) {\n  throw new Error('persona_events must be registered as ephemeral in TABLE_REGISTRY');\n}\n\n/** Maximum fraction of rows a single purge cycle may delete (safety cap). */\nconst EXEC_MAX_PURGE_FRACTION = (execSpec as MetrizableTableSpec).maxPurgeFraction ?? 0.8;\nconst EVENTS_MAX_PURGE_FRACTION = (eventsSpec as EphemeralTableSpec).maxPurgeFraction ?? 0.8;\n\n/** Rows deleted per chunk to keep individual lock durations short (~50ms). */\nconst PURGE_CHUNK_SIZE = 5000;\n\n/** Yield the event loop so concurrent reads/writes can proceed between batches. */\nfunction yieldTick(): Promise<void> {\n  return new Promise((resolve) => setImmediate(resolve));\n}\n\n/**\n * Daily retention job: purge old executions/events and aggregate daily metrics.\n */\nexport function startRetentionJob(\n  tenantDbManager: TenantDbManager,\n  retentionDays: number,\n  logger: Logger,\n): NodeJS.Timeout {\n  logger.info({ retentionDays }, 'Retention job started (daily)');\n\n  // Run once on startup then daily\n  setTimeout(() => runRetention(tenantDbManager, retentionDays, logger), 5000);\n\n  return setInterval(() => {\n    runRetention(tenantDbManager, retentionDays, logger);\n  }, 24 * 60 * 60 * 1000);\n}\n\n/**\n * Delete rows in chunks of PURGE_CHUNK_SIZE, yielding the event loop between\n * batches so other DB operations are not starved.\n */\nasync function chunkedDelete(db: Database.Database, sql: string, params: unknown[]): Promise<number> {\n  const stmt = db.prepare(sql);\n  let totalDeleted = 0;\n  while (true) {\n    const result = stmt.run(...params, PURGE_CHUNK_SIZE);\n    totalDeleted += result.changes;\n    if (result.changes < PURGE_CHUNK_SIZE) break;\n    await yieldTick();\n  }\n  return totalDeleted;\n}\n\nasync function runRetention(\n  tenantDbManager: TenantDbManager,\n  retentionDays: number,\n  logger: Logger,\n): Promise<void> {\n  const cutoff = new Date(Date.now() - retentionDays * 86_400_000).toISOString();\n\n  const tenantIds = tenantDbManager.listTenantIds();\n  for (const projectId of tenantIds) {\n    try {\n      const db = tenantDbManager.getTenantDb(projectId);\n      await runTenantRetention(db, projectId, cutoff, retentionDays, logger);\n    } catch (err) {\n      logger.error({ err, projectId }, 'Retention cleanup failed for tenant');\n    }\n    // Yield between tenants so the event loop stays responsive\n    await yieldTick();\n  }\n}\n\nasync function runTenantRetention(\n  db: Database.Database,\n  projectId: string,\n  cutoff: string,\n  retentionDays: number,\n  logger: Logger,\n): Promise<void> {\n  // ── Batched index scan: collect purgeable execution rowids in chunks ──\n  // Both the aggregation (Step 1) and the delete (Step 2) operate on\n  // this pre-collected set instead of scanning persona_executions twice.\n  // The collection itself is batched to avoid holding a write lock while\n  // inserting millions of rowids after a long retention gap.\n  db.exec('CREATE TEMP TABLE IF NOT EXISTS _ret_ids (id INTEGER PRIMARY KEY)');\n  db.prepare('DELETE FROM _ret_ids').run();\n  {\n    const collectStmt = db.prepare(`\n      INSERT INTO _ret_ids (id)\n      SELECT rowid FROM persona_executions\n      WHERE rowid > ? AND created_at < ? AND status IN ('completed', 'failed', 'cancelled')\n      ORDER BY rowid\n      LIMIT ?\n    `);\n    let cursor = 0;\n    while (true) {\n      const result = collectStmt.run(cursor, cutoff, PURGE_CHUNK_SIZE);\n      if (result.changes === 0) break;\n      const maxRow = db.prepare('SELECT MAX(id) as m FROM _ret_ids').get() as { m: number };\n      cursor = maxRow.m;\n      if (result.changes < PURGE_CHUNK_SIZE) break;\n      await yieldTick();\n    }\n  }\n\n  // ── Step 1: Aggregate metrics in a short transaction ──────────────\n  // Watermark-based: each source row is counted exactly once, so the\n  // additive upsert is safe even if a previous run crashed mid-delete.\n  // No heavy deletes here — lock duration is brief.\n  const aggregatedDays = db.transaction(() => {\n    const watermarkRow = db.prepare(\n      \"SELECT last_rowid FROM retention_watermark WHERE key = 'executions'\",\n    ).get() as { last_rowid: number } | undefined;\n    const lastRowid = watermarkRow?.last_rowid ?? 0;\n\n    // Max rowid above the watermark (reads temp table only, no main-table scan)\n    const maxRow = db.prepare(\n      'SELECT MAX(id) as max_rowid FROM _ret_ids WHERE id > ?',\n    ).get(lastRowid) as { max_rowid: number | null } | undefined;\n    const newWatermark = maxRow?.max_rowid ?? lastRowid;\n\n    // Aggregate only never-before-counted rows. The JOIN fetches data columns\n    // via direct rowid B-tree lookups rather than a redundant index range scan.\n    const rows = db.prepare(`\n      SELECT\n        date(pe.created_at) as day,\n        COUNT(*) as total,\n        SUM(CASE WHEN pe.status = 'completed' THEN 1 ELSE 0 END) as completed,\n        SUM(CASE WHEN pe.status = 'failed' THEN 1 ELSE 0 END) as failed,\n        COALESCE(SUM(pe.cost_usd), 0) as cost,\n        COALESCE(SUM(pe.duration_ms), 0) as duration\n      FROM _ret_ids r\n      JOIN persona_executions pe ON pe.rowid = r.id\n      WHERE r.id > ?\n      GROUP BY date(pe.created_at)\n    `).all(lastRowid) as Array<{ day: string; total: number; completed: number; failed: number; cost: number; duration: number }>;\n\n    const upsertStmt = db.prepare(`\n      INSERT INTO daily_metrics (date, total_executions, completed, failed, total_cost_usd, total_duration_ms)\n      VALUES (?, ?, ?, ?, ?, ?)\n      ON CONFLICT(date) DO UPDATE SET\n        total_executions = total_executions + excluded.total_executions,\n        completed = completed + excluded.completed,\n        failed = failed + excluded.failed,\n        total_cost_usd = total_cost_usd + excluded.total_cost_usd,\n        total_duration_ms = total_duration_ms + excluded.total_duration_ms\n    `);\n    for (const row of rows) {\n      upsertStmt.run(row.day, row.total, row.completed, row.failed, row.cost, row.duration);\n    }\n\n    db.prepare(`\n      INSERT INTO retention_watermark (key, last_rowid) VALUES ('executions', ?)\n      ON CONFLICT(key) DO UPDATE SET last_rowid = excluded.last_rowid\n    `).run(newWatermark);\n\n    return rows.length;\n  })();\n\n  // ── Step 2: Delete execution rows using pre-collected rowids ──────\n  // Pre-purge sanity check: refuse to delete more than EXEC_MAX_PURGE_FRACTION of all rows\n  const execTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_executions').get() as { cnt: number };\n  const execCandidateRow = db.prepare('SELECT COUNT(*) as cnt FROM _ret_ids').get() as { cnt: number };\n\n  let purgedExecutions = 0;\n  if (execTotalRow.cnt > 0 && execCandidateRow.cnt / execTotalRow.cnt > EXEC_MAX_PURGE_FRACTION) {\n    logger.error(\n      { projectId, total: execTotalRow.cnt, candidates: execCandidateRow.cnt, cutoff, maxFraction: EXEC_MAX_PURGE_FRACTION },\n      'Execution purge aborted: deletion would exceed safety cap',\n    );\n  } else {\n    // Each chunk is its own implicit transaction (~50ms lock), with event-loop\n    // yields between chunks so concurrent operations can proceed.\n    const deleteStmt = db.prepare(\n      'DELETE FROM persona_executions WHERE rowid IN (SELECT id FROM _ret_ids LIMIT ?)',\n    );\n    const trimStmt = db.prepare(\n      'DELETE FROM _ret_ids WHERE id IN (SELECT id FROM _ret_ids LIMIT ?)',\n    );\n    while (true) {\n      const result = deleteStmt.run(PURGE_CHUNK_SIZE);\n      purgedExecutions += result.changes;\n      trimStmt.run(PURGE_CHUNK_SIZE);\n      if (result.changes < PURGE_CHUNK_SIZE) break;\n      await yieldTick();\n    }\n  }\n\n  // ── Step 3: Purge old events in batched chunks ────────────────────\n  // Pre-purge sanity check for events\n  const eventsTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_events').get() as { cnt: number };\n  const eventsCandidateRow = db.prepare(\n    \"SELECT COUNT(*) as cnt FROM persona_events WHERE created_at < ?\",\n  ).get(cutoff) as { cnt: number };\n\n  let purgedEvents = 0;\n  let purgedStuckEvents = 0;\n  if (eventsTotalRow.cnt > 0 && eventsCandidateRow.cnt / eventsTotalRow.cnt > EVENTS_MAX_PURGE_FRACTION) {\n    logger.error(\n      { projectId, total: eventsTotalRow.cnt, candidates: eventsCandidateRow.cnt, cutoff, maxFraction: EVENTS_MAX_PURGE_FRACTION },\n      'Event purge aborted: deletion would exceed safety cap',\n    );\n  } else {\n    purgedEvents = await chunkedDelete(\n      db,\n      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status NOT IN ('pending', 'processing') LIMIT ?)\",\n      [cutoff],\n    );\n\n    // Safety net: purge stuck pending/processing events older than 7x retentionDays.\n    const stuckCutoff = new Date(Date.now() - retentionDays * 7 * 86_400_000).toISOString();\n    purgedStuckEvents = await chunkedDelete(\n      db,\n      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status IN ('pending', 'processing') LIMIT ?)\",\n      [stuckCutoff],\n    );\n  }\n\n  if (purgedExecutions > 0 || purgedEvents > 0 || purgedStuckEvents > 0) {\n    logger.info({\n      projectId,\n      purgedExecutions,\n      purgedEvents,\n      purgedStuckEvents,\n      aggregatedDays,\n    }, 'Retention cleanup complete');\n  }\n}\n","numLines":241,"startLine":1,"totalLines":241}}}
