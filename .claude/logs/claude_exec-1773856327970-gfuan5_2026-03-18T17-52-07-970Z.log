[2026-03-18T17:52:37.376Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A1uv7ndeeC8pjLTwo1h1YN","type":"tool_result","content":"     1→import { WebSocketServer, WebSocket } from 'ws';\n     2→import { EventEmitter } from 'node:events';\n     3→import {\n     4→  parseMessage,\n     5→  serializeMessage,\n     6→  type WorkerMessage,\n     7→  type OrchestratorMessage,\n     8→  type ExecAssign,\n     9→  type WorkerInfo,\n    10→} from '@dac-cloud/shared';\n    11→import type { Logger } from 'pino';\n    12→import type { IncomingMessage } from 'node:http';\n    13→\n    14→const HEARTBEAT_INTERVAL_MS = 30_000;\n    15→const HEARTBEAT_TIMEOUT_MS = 90_000;\n    16→\n    17→interface WorkerEntry {\n    18→  ws: WebSocket;\n    19→  info: WorkerInfo;\n    20→  heartbeatTimer?: ReturnType<typeof setInterval>;\n    21→}\n    22→\n    23→export class WorkerPool extends EventEmitter {\n    24→  private workers = new Map<string, WorkerEntry>();\n    25→  private wss: WebSocketServer | null = null;\n    26→\n    27→  constructor(\n    28→    private expectedWorkerToken: string,\n    29→    private logger: Logger,\n    30→  ) {\n    31→    super();\n    32→  }\n    33→\n    34→  listen(port: number): void {\n    35→    this.wss = new WebSocketServer({ port });\n    36→\n    37→    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n    38→      this.logger.info({ remoteAddr: req.socket.remoteAddress }, 'Worker connection attempt');\n    39→\n    40→      // C3: Validate worker token from query string (?token=...)\n    41→      const url = new URL(req.url || '/', `http://${req.headers.host || 'localhost'}`);\n    42→      const token = url.searchParams.get('token');\n    43→      if (!token || token !== this.expectedWorkerToken) {\n    44→        this.logger.warn({ remoteAddr: req.socket.remoteAddress }, 'Worker rejected: invalid token');\n    45→        ws.close(1008, 'Invalid worker token');\n    46→        return;\n    47→      }\n    48→\n    49→      this.handleConnection(ws);\n    50→    });\n    51→\n    52→    this.wss.on('error', (err) => {\n    53→      this.logger.error({ err }, 'WebSocket server error');\n    54→    });\n    55→\n    56→    this.logger.info({ port }, 'Worker pool listening');\n    57→  }\n    58→\n    59→  private handleConnection(ws: WebSocket): void {\n    60→    let workerId: string | null = null;\n    61→\n    62→    const connectionTimeout = setTimeout(() => {\n    63→      if (!workerId) {\n    64→        this.logger.warn('Worker did not send hello within timeout, closing');\n    65→        ws.close(1008, 'Hello timeout');\n    66→      }\n    67→    }, 10_000);\n    68→\n    69→    ws.on('message', (raw: Buffer) => {\n    70→      const msg = parseMessage<WorkerMessage>(raw.toString());\n    71→      if (!msg) {\n    72→        this.logger.warn('Invalid message from worker');\n    73→        return;\n    74→      }\n    75→\n    76→      if (msg.type === 'hello') {\n    77→        clearTimeout(connectionTimeout);\n    78→        workerId = msg.workerId;\n    79→        this.registerWorker(workerId, ws, msg.version, msg.capabilities);\n    80→        return;\n    81→      }\n    82→\n    83→      if (!workerId) {\n    84→        this.logger.warn({ type: msg.type }, 'Message before hello');\n    85→        return;\n    86→      }\n    87→\n    88→      this.handleWorkerMessage(workerId, msg);\n    89→    });\n    90→\n    91→    ws.on('close', () => {\n    92→      clearTimeout(connectionTimeout);\n    93→      if (workerId) {\n    94→        this.unregisterWorker(workerId);\n    95→      }\n    96→    });\n    97→\n    98→    ws.on('error', (err) => {\n    99→      this.logger.error({ err, workerId }, 'Worker WebSocket error');\n   100→    });\n   101→  }\n   102→\n   103→  private registerWorker(workerId: string, ws: WebSocket, version: string, capabilities: string[]): void {\n   104→    // I10: If a worker with this ID already exists, disconnect the old one first\n   105→    const existing = this.workers.get(workerId);\n   106→    if (existing) {\n   107→      this.logger.warn({ workerId }, 'Duplicate worker ID — disconnecting previous connection');\n   108→      if (existing.heartbeatTimer) clearInterval(existing.heartbeatTimer);\n   109→      existing.ws.close(1001, 'Replaced by new connection');\n   110→      this.workers.delete(workerId);\n   111→    }\n   112→\n   113→    const info: WorkerInfo = {\n   114→      workerId,\n   115→      status: 'idle',\n   116→      version,\n   117→      capabilities,\n   118→      connectedAt: Date.now(),\n   119→      lastHeartbeat: Date.now(),\n   120→    };\n   121→\n   122→    const heartbeatTimer = setInterval(() => {\n   123→      const entry = this.workers.get(workerId);\n   124→      if (!entry) return;\n   125→\n   126→      if (Date.now() - entry.info.lastHeartbeat > HEARTBEAT_TIMEOUT_MS) {\n   127→        this.logger.warn({ workerId }, 'Worker heartbeat timeout');\n   128→        entry.ws.close(1001, 'Heartbeat timeout');\n   129→        return;\n   130→      }\n   131→\n   132→      this.send(workerId, { type: 'heartbeat', timestamp: Date.now() });\n   133→    }, HEARTBEAT_INTERVAL_MS);\n   134→\n   135→    this.workers.set(workerId, { ws, info, heartbeatTimer });\n   136→\n   137→    // Send ack\n   138→    this.send(workerId, {\n   139→      type: 'ack',\n   140→      workerId,\n   141→      sessionToken: `session-${Date.now()}`,\n   142→    });\n   143→\n   144→    this.logger.info({ workerId, version, capabilities }, 'Worker registered');\n   145→    this.emit('worker-connected', info);\n   146→  }\n   147→\n   148→  private unregisterWorker(workerId: string): void {\n   149→    const entry = this.workers.get(workerId);\n   150→    if (!entry) return;\n   151→\n   152→    if (entry.heartbeatTimer) {\n   153→      clearInterval(entry.heartbeatTimer);\n   154→    }\n   155→\n   156→    const hadExecution = entry.info.currentExecutionId;\n   157→    this.workers.delete(workerId);\n   158→\n   159→    this.logger.info({ workerId, hadExecution }, 'Worker disconnected');\n   160→    this.emit('worker-disconnected', workerId, hadExecution);\n   161→  }\n   162→\n   163→  private handleWorkerMessage(workerId: string, msg: WorkerMessage): void {\n   164→    const entry = this.workers.get(workerId);\n   165→    if (!entry) return;\n   166→\n   167→    switch (msg.type) {\n   168→      case 'heartbeat':\n   169→        entry.info.lastHeartbeat = Date.now();\n   170→        break;\n   171→\n   172→      case 'ready':\n   173→        entry.info.status = 'idle';\n   174→        entry.info.currentExecutionId = undefined;\n   175→        this.emit('worker-ready', workerId);\n   176→        break;\n   177→\n   178→      case 'stdout':\n   179→        this.emit('stdout', workerId, msg);\n   180→        break;\n   181→\n   182→      case 'stderr':\n   183→        this.emit('stderr', workerId, msg);\n   184→        break;\n   185→\n   186→      case 'complete':\n   187→        entry.info.status = 'idle';\n   188→        entry.info.currentExecutionId = undefined;\n   189→        this.logger.info({\n   190→          workerId,\n   191→          executionId: msg.executionId,\n   192→          status: msg.status,\n   193→          durationMs: msg.durationMs,\n   194→        }, 'Execution complete');\n   195→        this.emit('complete', workerId, msg);\n   196→        break;\n   197→\n   198→      case 'event':\n   199→        this.emit('persona-event', workerId, msg);\n   200→        break;\n   201→\n   202→      default:\n   203→        this.logger.warn({ workerId, type: (msg as WorkerMessage).type }, 'Unknown message type');\n   204→    }\n   205→  }\n   206→\n   207→  send(workerId: string, msg: OrchestratorMessage): boolean {\n   208→    const entry = this.workers.get(workerId);\n   209→    if (!entry || entry.ws.readyState !== WebSocket.OPEN) return false;\n   210→\n   211→    entry.ws.send(serializeMessage(msg));\n   212→    return true;\n   213→  }\n   214→\n   215→  assign(workerId: string, assignment: ExecAssign): boolean {\n   216→    const entry = this.workers.get(workerId);\n   217→    if (!entry || entry.info.status !== 'idle') return false;\n   218→\n   219→    entry.info.status = 'executing';\n   220→    entry.info.currentExecutionId = assignment.executionId;\n   221→    return this.send(workerId, assignment);\n   222→  }\n   223→\n   224→  getIdleWorker(): string | null {\n   225→    for (const [workerId, entry] of this.workers) {\n   226→      if (entry.info.status === 'idle') {\n   227→        return workerId;\n   228→      }\n   229→    }\n   230→    return null;\n   231→  }\n   232→\n   233→  getWorkers(): WorkerInfo[] {\n   234→    return Array.from(this.workers.values()).map(e => ({ ...e.info }));\n   235→  }\n   236→\n   237→  getWorkerCount(): { total: number; idle: number; executing: number } {\n   238→    let idle = 0;\n   239→    let executing = 0;\n   240→    for (const entry of this.workers.values()) {\n   241→      if (entry.info.status === 'idle') idle++;\n   242→      if (entry.info.status === 'executing') executing++;\n   243→    }\n   244→    return { total: this.workers.size, idle, executing };\n   245→  }\n   246→\n   247→  shutdown(): void {\n   248→    for (const [workerId] of this.workers) {\n   249→      this.send(workerId, {\n   250→        type: 'shutdown',\n   251→        reason: 'Orchestrator shutting down',\n   252→        gracePeriodMs: 30_000,\n   253→      });\n   254→    }\n   255→    this.wss?.close();\n   256→    for (const entry of this.workers.values()) {\n   257→      if (entry.heartbeatTimer) clearInterval(entry.heartbeatTimer);\n   258→    }\n   259→  }\n   260→}\n   261→"}]},"parent_tool_use_id":"toolu_01D1akbrxErL2oW8JXrPq4xP","session_id":"98002355-fe9a-4be2-99b0-443b06e347e4","uuid":"3a9783de-77e7-4ab6-8113-4e278a345f01","timestamp":"2026-03-18T17:52:37.259Z"}
