[2026-03-18T17:53:59.645Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Rw5para4tw5B8T9SY8aDGE","type":"tool_result","content":"     1→import { type ExecAssign, type ExecRequest, TOPICS, assemblePrompt, parseModelProfile, decrypt, deriveMasterKey, type EncryptedPayload } from '@dac-cloud/shared';\n     2→import type Database from 'better-sqlite3';\n     3→import type { WorkerPool } from './workerPool.js';\n     4→import type { TokenManager } from './tokenManager.js';\n     5→import type { OAuthManager } from './oauth.js';\n     6→import type { KafkaClient } from './kafka.js';\n     7→import type { Logger } from 'pino';\n     8→import * as db from './db.js';\n     9→\n    10→interface QueuedExecution {\n    11→  request: ExecRequest;\n    12→  receivedAt: number;\n    13→}\n    14→\n    15→// In-memory tracking for active executions (real-time output streaming)\n    16→interface ActiveExecution {\n    17→  workerId: string;\n    18→  startedAt: number;\n    19→  output: string[];\n    20→  status: 'running' | 'completed' | 'failed' | 'cancelled';\n    21→  completedAt?: number;\n    22→  exitCode?: number;\n    23→  durationMs?: number;\n    24→  sessionId?: string;\n    25→  totalCostUsd?: number;\n    26→}\n    27→\n    28→export class Dispatcher {\n    29→  private queue: QueuedExecution[] = [];\n    30→  // In-memory map for real-time output + cancel routing (active executions only)\n    31→  private active = new Map<string, ActiveExecution>();\n    32→  private database: Database.Database | null = null;\n    33→  private masterKey: Buffer | null = null;\n    34→\n    35→  // Batched output buffer: accumulate chunks and flush periodically instead of per-chunk DB writes\n    36→  private outputBuffer = new Map<string, string[]>();\n    37→  private flushTimer: ReturnType<typeof setInterval> | null = null;\n    38→  private static readonly FLUSH_INTERVAL_MS = 500;\n    39→  private static readonly FLUSH_CHUNK_THRESHOLD = 50;\n    40→\n    41→  constructor(\n    42→    private pool: WorkerPool,\n    43→    private tokenManager: TokenManager,\n    44→    private oauth: OAuthManager | null,\n    45→    private kafka: KafkaClient,\n    46→    private logger: Logger,\n    47→  ) {\n    48→    // When a worker becomes ready, try to dispatch queued work\n    49→    this.pool.on('worker-ready', () => {\n    50→      this.processQueue();\n    51→    });\n    52→\n    53→    // When a worker connects, try to dispatch\n    54→    this.pool.on('worker-connected', () => {\n    55→      this.processQueue();\n    56→    });\n    57→\n    58→    // Track stdout for execution output\n    59→    this.pool.on('stdout', (_workerId: string, msg: { executionId: string; chunk: string; timestamp: number }) => {\n    60→      const exec = this.active.get(msg.executionId);\n    61→      if (exec) {\n    62→        exec.output.push(msg.chunk);\n    63→      }\n    64→\n    65→      // Buffer for batched DB write\n    66→      this.bufferOutput(msg.executionId, msg.chunk + '\\n');\n    67→\n    68→      // Forward to Kafka\n    69→      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n    70→        executionId: msg.executionId,\n    71→        chunk: msg.chunk,\n    72→        timestamp: msg.timestamp,\n    73→      }), msg.executionId).catch(err => {\n    74→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce output to Kafka');\n    75→      });\n    76→    });\n    77→\n    78→    // Track stderr for debugging failed executions\n    79→    this.pool.on('stderr', (_workerId: string, msg: { executionId: string; chunk: string; timestamp: number }) => {\n    80→      const exec = this.active.get(msg.executionId);\n    81→      if (exec) {\n    82→        exec.output.push(`[STDERR] ${msg.chunk}`);\n    83→      }\n    84→\n    85→      // Buffer for batched DB write\n    86→      this.bufferOutput(msg.executionId, `[STDERR] ${msg.chunk}\\n`);\n    87→\n    88→      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    89→    });\n    90→\n    91→    // Handle execution completion\n    92→    this.pool.on('complete', (_workerId: string, msg: { executionId: string; status: string; exitCode: number; durationMs: number; sessionId?: string; totalCostUsd?: number }) => {\n    93→      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n    94→        executionId: msg.executionId,\n    95→        status: msg.status,\n    96→        exitCode: msg.exitCode,\n    97→        durationMs: msg.durationMs,\n    98→        sessionId: msg.sessionId,\n    99→        totalCostUsd: msg.totalCostUsd,\n   100→      }), msg.executionId).catch(err => {\n   101→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n   102→      });\n   103→\n   104→      // Update in-memory\n   105→      const exec = this.active.get(msg.executionId);\n   106→      if (exec) {\n   107→        exec.status = msg.status as ActiveExecution['status'];\n   108→        exec.completedAt = Date.now();\n   109→        exec.exitCode = msg.exitCode;\n   110→        exec.durationMs = msg.durationMs;\n   111→        exec.sessionId = msg.sessionId;\n   112→        exec.totalCostUsd = msg.totalCostUsd;\n   113→        // Remove from active after a short delay (allow polling to pick up final state)\n   114→        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n   115→      }\n   116→\n   117→      // Flush any buffered output before persisting completion\n   118→      this.flushOutputForExecution(msg.executionId);\n   119→\n   120→      // Persist to DB\n   121→      if (this.database) {\n   122→        try {\n   123→          db.updateExecution(this.database, msg.executionId, {\n   124→            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n   125→            completedAt: new Date().toISOString(),\n   126→            durationMs: msg.durationMs,\n   127→            claudeSessionId: msg.sessionId,\n   128→            costUsd: msg.totalCostUsd ?? 0,\n   129→          });\n   130→        } catch (err) {\n   131→          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n   132→        }\n   133→      }\n   134→\n   135→      // Process next queued item\n   136→      this.processQueue();\n   137→    });\n   138→\n   139→    // Forward persona events to Kafka\n   140→    this.pool.on('persona-event', (_workerId: string, msg: { executionId: string; eventType: string; payload: unknown }) => {\n   141→      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n   142→        executionId: msg.executionId,\n   143→        eventType: msg.eventType,\n   144→        payload: msg.payload,\n   145→        timestamp: Date.now(),\n   146→      }), msg.executionId).catch(err => {\n   147→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n   148→      });\n   149→    });\n   150→\n   151→    // Handle worker disconnect during execution\n   152→    this.pool.on('worker-disconnected', (_workerId: string, executionId?: string) => {\n   153→      if (executionId) {\n   154→        this.logger.error({ executionId }, 'Worker disconnected during execution');\n   155→        const exec = this.active.get(executionId);\n   156→        if (exec) {\n   157→          exec.status = 'failed';\n   158→          exec.completedAt = Date.now();\n   159→          setTimeout(() => this.active.delete(executionId), 30_000);\n   160→        }\n   161→\n   162→        // Flush any buffered output before persisting failure\n   163→        this.flushOutputForExecution(executionId);\n   164→\n   165→        // Persist failure\n   166→        if (this.database) {\n   167→          try {\n   168→            db.updateExecution(this.database, executionId, {\n   169→              status: 'failed',\n   170→              errorMessage: 'Worker disconnected',\n   171→              completedAt: new Date().toISOString(),\n   172→            });\n   173→          } catch { /* best effort */ }\n   174→        }\n   175→\n   176→        this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   177→          executionId,\n   178→          status: 'failed',\n   179→          error: 'Worker disconnected',\n   180→          durationMs: 0,\n   181→        }), executionId).catch(() => {});\n   182→      }\n   183→    });\n   184→  }\n   185→\n   186→  setDatabase(database: Database.Database): void {\n   187→    this.database = database;\n   188→    // Start the periodic flush timer when DB is available\n   189→    if (!this.flushTimer) {\n   190→      this.flushTimer = setInterval(() => this.flushAllOutputBuffers(), Dispatcher.FLUSH_INTERVAL_MS);\n   191→      this.flushTimer.unref(); // Don't prevent process exit\n   192→    }\n   193→  }\n   194→\n   195→  setMasterKey(masterKeyHex: string): void {\n   196→    this.masterKey = deriveMasterKey(masterKeyHex);\n   197→  }\n   198→\n   199→  submit(request: ExecRequest): void {\n   200→    this.logger.info({\n   201→      executionId: request.executionId,\n   202→      personaId: request.personaId,\n   203→    }, 'Execution submitted');\n   204→\n   205→    // Create DB record immediately\n   206→    if (this.database) {\n   207→      try {\n   208→        db.createExecution(this.database, {\n   209→          id: request.executionId,\n   210→          personaId: request.personaId,\n   211→          inputData: request.prompt,\n   212→          projectId: request.projectId,\n   213→        });\n   214→      } catch (err) {\n   215→        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n   216→      }\n   217→    }\n   218→\n   219→    this.queue.push({ request, receivedAt: Date.now() });\n   220→    this.processQueue();\n   221→  }\n   222→\n   223→  private async processQueue(): Promise<void> {\n   224→    if (this.queue.length === 0) return;\n   225→\n   226→    const workerId = this.pool.getIdleWorker();\n   227→    if (!workerId) {\n   228→      this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n   229→      return;\n   230→    }\n   231→\n   232→    const item = this.queue.shift()!;\n   233→    await this.dispatchToWorker(workerId, item.request);\n   234→  }\n   235→\n   236→  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n   237→    // Try to get a fresh token via OAuth (auto-refreshes if near expiry)\n   238→    let claudeToken: string | null = null;\n   239→    if (this.oauth?.hasTokens()) {\n   240→      claudeToken = await this.oauth.getValidAccessToken();\n   241→      if (claudeToken) {\n   242→        this.tokenManager.storeClaudeToken(claudeToken);\n   243→      }\n   244→    }\n   245→    // Fallback to stored token\n   246→    if (!claudeToken) {\n   247→      claudeToken = this.tokenManager.getClaudeToken();\n   248→    }\n   249→    if (!claudeToken) {\n   250→      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n   251→      this.queue.unshift({ request, receivedAt: Date.now() });\n   252→      return;\n   253→    }\n   254→\n   255→    // Build environment variables for the worker\n   256→    const env: Record<string, string> = {\n   257→      ANTHROPIC_API_KEY: claudeToken,\n   258→    };\n   259→\n   260→    // If persona exists in DB, assemble prompt from persona config and inject credentials\n   261→    let prompt = request.prompt;\n   262→    if (this.database) {\n   263→      const persona = db.getPersona(this.database, request.personaId);\n   264→      if (persona) {\n   265→        const tools = db.getToolsForPersona(this.database, persona.id);\n   266→        const creds = db.listCredentialsForPersona(this.database, persona.id);\n   267→\n   268→        // Decrypt credentials and inject as env vars\n   269→        const credentialHints: string[] = [];\n   270→        for (const cred of creds) {\n   271→          const envName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   272→          credentialHints.push(envName);\n   273→\n   274→          // Decrypt and inject credential fields as env vars\n   275→          if (this.masterKey) {\n   276→            try {\n   277→              const payload: EncryptedPayload = {\n   278→                encrypted: cred.encryptedData,\n   279→                iv: cred.iv,\n   280→                tag: cred.tag,\n   281→              };\n   282→              const decrypted = decrypt(payload, this.masterKey);\n   283→\n   284→              // Try to parse as JSON with multiple fields\n   285→              try {\n   286→                const fields = JSON.parse(decrypted) as Record<string, string>;\n   287→                for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n   288→                  const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   289→                  env[fieldEnvName] = String(fieldValue);\n   290→                }\n   291→              } catch {\n   292→                // Not JSON — inject as single value\n   293→                env[envName] = decrypted;\n   294→              }\n   295→            } catch (err) {\n   296→              this.logger.error({ err, credentialId: cred.id, credentialName: cred.name }, 'Failed to decrypt credential');\n   297→            }\n   298→          }\n   299→        }\n   300→\n   301→        const inputData = request.inputData ? (request.inputData as Record<string, unknown>) : undefined;\n   302→        prompt = assemblePrompt(persona, tools, inputData, credentialHints.length > 0 ? credentialHints : undefined);\n   303→\n   304→        // Apply model profile env overrides\n   305→        const profile = parseModelProfile(persona.modelProfile);\n   306→        if (profile?.provider) {\n   307→          switch (profile.provider) {\n   308→            case 'ollama':\n   309→              if (profile.baseUrl) env['OLLAMA_BASE_URL'] = profile.baseUrl;\n   310→              if (profile.authToken) env['OLLAMA_API_KEY'] = profile.authToken;\n   311→              delete env['ANTHROPIC_API_KEY'];\n   312→              break;\n   313→            case 'litellm':\n   314→              if (profile.baseUrl) env['ANTHROPIC_BASE_URL'] = profile.baseUrl;\n   315→              if (profile.authToken) env['ANTHROPIC_AUTH_TOKEN'] = profile.authToken;\n   316→              delete env['ANTHROPIC_API_KEY'];\n   317→              break;\n   318→            case 'custom':\n   319→              if (profile.baseUrl) env['OPENAI_BASE_URL'] = profile.baseUrl;\n   320→              if (profile.authToken) env['OPENAI_API_KEY'] = profile.authToken;\n   321→              delete env['ANTHROPIC_API_KEY'];\n   322→              break;\n   323→          }\n   324→        }\n   325→\n   326→        this.logger.info({ personaId: persona.id, toolCount: tools.length, credCount: creds.length }, 'Assembled prompt from DB persona');\n   327→      }\n   328→    }\n   329→\n   330→    const assignment: ExecAssign = {\n   331→      type: 'assign',\n   332→      executionId: request.executionId,\n   333→      personaId: request.personaId,\n   334→      prompt,\n   335→      env,\n   336→      config: {\n   337→        timeoutMs: request.config.timeoutMs || 300_000,\n   338→        maxOutputBytes: 10 * 1024 * 1024, // 10MB\n   339→      },\n   340→    };\n   341→\n   342→    // Track in-memory for real-time streaming\n   343→    this.active.set(request.executionId, {\n   344→      workerId,\n   345→      startedAt: Date.now(),\n   346→      output: [],\n   347→      status: 'running',\n   348→    });\n   349→\n   350→    // Mark running in DB\n   351→    if (this.database) {\n   352→      try {\n   353→        db.updateExecution(this.database, request.executionId, {\n   354→          status: 'running',\n   355→          startedAt: new Date().toISOString(),\n   356→        });\n   357→      } catch { /* best effort */ }\n   358→    }\n   359→\n   360→    const sent = this.pool.assign(workerId, assignment);\n   361→    if (!sent) {\n   362→      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n   363→      this.active.delete(request.executionId);\n   364→      if (this.database) {\n   365→        try { db.updateExecution(this.database, request.executionId, { status: 'queued' }); } catch { /* best effort */ }\n   366→      }\n   367→      // Re-queue\n   368→      this.queue.unshift({ request, receivedAt: Date.now() });\n   369→    } else {\n   370→      this.logger.info({\n   371→        workerId,\n   372→        executionId: request.executionId,\n   373→        personaId: request.personaId,\n   374→      }, 'Execution dispatched to worker');\n   375→    }\n   376→  }\n   377→\n   378→  cancelExecution(executionId: string): boolean {\n   379→    const exec = this.active.get(executionId);\n   380→    if (!exec || exec.status !== 'running') return false;\n   381→\n   382→    return this.pool.send(exec.workerId, {\n   383→      type: 'cancel',\n   384→      executionId,\n   385→    });\n   386→  }\n   387→\n   388→  getQueueLength(): number {\n   389→    return this.queue.length;\n   390→  }\n   391→\n   392→  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n   393→    return Array.from(this.active.entries())\n   394→      .filter(([, e]) => e.status === 'running')\n   395→      .map(([executionId, e]) => ({\n   396→        executionId,\n   397→        workerId: e.workerId,\n   398→        startedAt: e.startedAt,\n   399→      }));\n   400→  }\n   401→\n   402→  /**\n   403→   * Get execution state. Tries in-memory first (for real-time output),\n   404→   * then falls back to DB for completed/historical executions.\n   405→   */\n   406→  getExecution(executionId: string): ActiveExecution | null {\n   407→    // Check in-memory active executions first\n   408→    const active = this.active.get(executionId);\n   409→    if (active) return active;\n   410→\n   411→    // Fall back to DB\n   412→    if (this.database) {\n   413→      const dbExec = db.getExecution(this.database, executionId);\n   414→      if (dbExec) {\n   415→        // Convert DB execution to ActiveExecution shape for backward compat\n   416→        return {\n   417→          workerId: '',\n   418→          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n   419→          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n   420→          status: dbExec.status as ActiveExecution['status'],\n   421→          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n   422→          durationMs: dbExec.durationMs ?? undefined,\n   423→          sessionId: dbExec.claudeSessionId ?? undefined,\n   424→          totalCostUsd: dbExec.costUsd ?? undefined,\n   425→        };\n   426→      }\n   427→    }\n   428→\n   429→    return null;\n   430→  }\n   431→\n   432→  getExecutionOutput(executionId: string): string[] | null {\n   433→    const exec = this.getExecution(executionId);\n   434→    return exec?.output ?? null;\n   435→  }\n   436→\n   437→  shutdown(): void {\n   438→    // Flush remaining buffered output and stop the timer\n   439→    if (this.flushTimer) {\n   440→      clearInterval(this.flushTimer);\n   441→      this.flushTimer = null;\n   442→    }\n   443→    this.flushAllOutputBuffers();\n   444→  }\n   445→\n   446→  /** Buffer a chunk for batched DB write. Flushes immediately if threshold exceeded. */\n   447→  private bufferOutput(executionId: string, chunk: string): void {\n   448→    if (!this.database) return;\n   449→\n   450→    let chunks = this.outputBuffer.get(executionId);\n   451→    if (!chunks) {\n   452→      chunks = [];\n   453→      this.outputBuffer.set(executionId, chunks);\n   454→    }\n   455→    chunks.push(chunk);\n   456→\n   457→    if (chunks.length >= Dispatcher.FLUSH_CHUNK_THRESHOLD) {\n   458→      this.flushOutputForExecution(executionId);\n   459→    }\n   460→  }\n   461→\n   462→  /** Flush buffered output for a single execution to the DB. */\n   463→  private flushOutputForExecution(executionId: string): void {\n   464→    const chunks = this.outputBuffer.get(executionId);\n   465→    if (!chunks || chunks.length === 0) return;\n   466→    this.outputBuffer.delete(executionId);\n   467→\n   468→    if (this.database) {\n   469→      try {\n   470→        db.appendOutput(this.database, executionId, chunks.join(''));\n   471→      } catch { /* best effort */ }\n   472→    }\n   473→  }\n   474→\n   475→  /** Flush all buffered output across all executions. */\n   476→  private flushAllOutputBuffers(): void {\n   477→    for (const executionId of this.outputBuffer.keys()) {\n   478→      this.flushOutputForExecution(executionId);\n   479→    }\n   480→  }\n   481→}\n   482→"}]},"parent_tool_use_id":null,"session_id":"98002355-fe9a-4be2-99b0-443b06e347e4","uuid":"437c6508-7326-4772-a700-9f7feddd6727","timestamp":"2026-03-18T17:53:59.549Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\.claude\\worktrees\\flickering-exploring-toucan\\packages\\orchestrator\\src\\dispatcher.ts","content":"import { type ExecAssign, type ExecRequest, TOPICS, assemblePrompt, parseModelProfile, decrypt, deriveMasterKey, type EncryptedPayload } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport type { Logger } from 'pino';\nimport * as db from './db.js';\n\ninterface QueuedExecution {\n  request: ExecRequest;\n  receivedAt: number;\n}\n\n// In-memory tracking for active executions (real-time output streaming)\ninterface ActiveExecution {\n  workerId: string;\n  startedAt: number;\n  output: string[];\n  status: 'running' | 'completed' | 'failed' | 'cancelled';\n  completedAt?: number;\n  exitCode?: number;\n  durationMs?: number;\n  sessionId?: string;\n  totalCostUsd?: number;\n}\n\nexport class Dispatcher {\n  private queue: QueuedExecution[] = [];\n  // In-memory map for real-time output + cancel routing (active executions only)\n  private active = new Map<string, ActiveExecution>();\n  private database: Database.Database | null = null;\n  private masterKey: Buffer | null = null;\n\n  // Batched output buffer: accumulate chunks and flush periodically instead of per-chunk DB writes\n  private outputBuffer = new Map<string, string[]>();\n  private flushTimer: ReturnType<typeof setInterval> | null = null;\n  private static readonly FLUSH_INTERVAL_MS = 500;\n  private static readonly FLUSH_CHUNK_THRESHOLD = 50;\n\n  constructor(\n    private pool: WorkerPool,\n    private tokenManager: TokenManager,\n    private oauth: OAuthManager | null,\n    private kafka: KafkaClient,\n    private logger: Logger,\n  ) {\n    // When a worker becomes ready, try to dispatch queued work\n    this.pool.on('worker-ready', () => {\n      this.processQueue();\n    });\n\n    // When a worker connects, try to dispatch\n    this.pool.on('worker-connected', () => {\n      this.processQueue();\n    });\n\n    // Track stdout for execution output\n    this.pool.on('stdout', (_workerId: string, msg: { executionId: string; chunk: string; timestamp: number }) => {\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.output.push(msg.chunk);\n      }\n\n      // Buffer for batched DB write\n      this.bufferOutput(msg.executionId, msg.chunk + '\\n');\n\n      // Forward to Kafka\n      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n        executionId: msg.executionId,\n        chunk: msg.chunk,\n        timestamp: msg.timestamp,\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce output to Kafka');\n      });\n    });\n\n    // Track stderr for debugging failed executions\n    this.pool.on('stderr', (_workerId: string, msg: { executionId: string; chunk: string; timestamp: number }) => {\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.output.push(`[STDERR] ${msg.chunk}`);\n      }\n\n      // Buffer for batched DB write\n      this.bufferOutput(msg.executionId, `[STDERR] ${msg.chunk}\\n`);\n\n      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    });\n\n    // Handle execution completion\n    this.pool.on('complete', (_workerId: string, msg: { executionId: string; status: string; exitCode: number; durationMs: number; sessionId?: string; totalCostUsd?: number }) => {\n      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n        executionId: msg.executionId,\n        status: msg.status,\n        exitCode: msg.exitCode,\n        durationMs: msg.durationMs,\n        sessionId: msg.sessionId,\n        totalCostUsd: msg.totalCostUsd,\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n      });\n\n      // Update in-memory\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.status = msg.status as ActiveExecution['status'];\n        exec.completedAt = Date.now();\n        exec.exitCode = msg.exitCode;\n        exec.durationMs = msg.durationMs;\n        exec.sessionId = msg.sessionId;\n        exec.totalCostUsd = msg.totalCostUsd;\n        // Remove from active after a short delay (allow polling to pick up final state)\n        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n      }\n\n      // Flush any buffered output before persisting completion\n      this.flushOutputForExecution(msg.executionId);\n\n      // Persist to DB\n      if (this.database) {\n        try {\n          db.updateExecution(this.database, msg.executionId, {\n            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n            completedAt: new Date().toISOString(),\n            durationMs: msg.durationMs,\n            claudeSessionId: msg.sessionId,\n            costUsd: msg.totalCostUsd ?? 0,\n          });\n        } catch (err) {\n          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n        }\n      }\n\n      // Process next queued item\n      this.processQueue();\n    });\n\n    // Forward persona events to Kafka\n    this.pool.on('persona-event', (_workerId: string, msg: { executionId: string; eventType: string; payload: unknown }) => {\n      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n        executionId: msg.executionId,\n        eventType: msg.eventType,\n        payload: msg.payload,\n        timestamp: Date.now(),\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n      });\n    });\n\n    // Handle worker disconnect during execution\n    this.pool.on('worker-disconnected', (_workerId: string, executionId?: string) => {\n      if (executionId) {\n        this.logger.error({ executionId }, 'Worker disconnected during execution');\n        const exec = this.active.get(executionId);\n        if (exec) {\n          exec.status = 'failed';\n          exec.completedAt = Date.now();\n          setTimeout(() => this.active.delete(executionId), 30_000);\n        }\n\n        // Flush any buffered output before persisting failure\n        this.flushOutputForExecution(executionId);\n\n        // Persist failure\n        if (this.database) {\n          try {\n            db.updateExecution(this.database, executionId, {\n              status: 'failed',\n              errorMessage: 'Worker disconnected',\n              completedAt: new Date().toISOString(),\n            });\n          } catch { /* best effort */ }\n        }\n\n        this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n          executionId,\n          status: 'failed',\n          error: 'Worker disconnected',\n          durationMs: 0,\n        }), executionId).catch(() => {});\n      }\n    });\n  }\n\n  setDatabase(database: Database.Database): void {\n    this.database = database;\n    // Start the periodic flush timer when DB is available\n    if (!this.flushTimer) {\n      this.flushTimer = setInterval(() => this.flushAllOutputBuffers(), Dispatcher.FLUSH_INTERVAL_MS);\n      this.flushTimer.unref(); // Don't prevent process exit\n    }\n  }\n\n  setMasterKey(masterKeyHex: string): void {\n    this.masterKey = deriveMasterKey(masterKeyHex);\n  }\n\n  submit(request: ExecRequest): void {\n    this.logger.info({\n      executionId: request.executionId,\n      personaId: request.personaId,\n    }, 'Execution submitted');\n\n    // Create DB record immediately\n    if (this.database) {\n      try {\n        db.createExecution(this.database, {\n          id: request.executionId,\n          personaId: request.personaId,\n          inputData: request.prompt,\n          projectId: request.projectId,\n        });\n      } catch (err) {\n        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n      }\n    }\n\n    this.queue.push({ request, receivedAt: Date.now() });\n    this.processQueue();\n  }\n\n  private async processQueue(): Promise<void> {\n    if (this.queue.length === 0) return;\n\n    const workerId = this.pool.getIdleWorker();\n    if (!workerId) {\n      this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n      return;\n    }\n\n    const item = this.queue.shift()!;\n    await this.dispatchToWorker(workerId, item.request);\n  }\n\n  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n    // Try to get a fresh token via OAuth (auto-refreshes if near expiry)\n    let claudeToken: string | null = null;\n    if (this.oauth?.hasTokens()) {\n      claudeToken = await this.oauth.getValidAccessToken();\n      if (claudeToken) {\n        this.tokenManager.storeClaudeToken(claudeToken);\n      }\n    }\n    // Fallback to stored token\n    if (!claudeToken) {\n      claudeToken = this.tokenManager.getClaudeToken();\n    }\n    if (!claudeToken) {\n      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      return;\n    }\n\n    // Build environment variables for the worker\n    const env: Record<string, string> = {\n      ANTHROPIC_API_KEY: claudeToken,\n    };\n\n    // If persona exists in DB, assemble prompt from persona config and inject credentials\n    let prompt = request.prompt;\n    if (this.database) {\n      const persona = db.getPersona(this.database, request.personaId);\n      if (persona) {\n        const tools = db.getToolsForPersona(this.database, persona.id);\n        const creds = db.listCredentialsForPersona(this.database, persona.id);\n\n        // Decrypt credentials and inject as env vars\n        const credentialHints: string[] = [];\n        for (const cred of creds) {\n          const envName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n          credentialHints.push(envName);\n\n          // Decrypt and inject credential fields as env vars\n          if (this.masterKey) {\n            try {\n              const payload: EncryptedPayload = {\n                encrypted: cred.encryptedData,\n                iv: cred.iv,\n                tag: cred.tag,\n              };\n              const decrypted = decrypt(payload, this.masterKey);\n\n              // Try to parse as JSON with multiple fields\n              try {\n                const fields = JSON.parse(decrypted) as Record<string, string>;\n                for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n                  const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n                  env[fieldEnvName] = String(fieldValue);\n                }\n              } catch {\n                // Not JSON — inject as single value\n                env[envName] = decrypted;\n              }\n            } catch (err) {\n              this.logger.error({ err, credentialId: cred.id, credentialName: cred.name }, 'Failed to decrypt credential');\n            }\n          }\n        }\n\n        const inputData = request.inputData ? (request.inputData as Record<string, unknown>) : undefined;\n        prompt = assemblePrompt(persona, tools, inputData, credentialHints.length > 0 ? credentialHints : undefined);\n\n        // Apply model profile env overrides\n        const profile = parseModelProfile(persona.modelProfile);\n        if (profile?.provider) {\n          switch (profile.provider) {\n            case 'ollama':\n              if (profile.baseUrl) env['OLLAMA_BASE_URL'] = profile.baseUrl;\n              if (profile.authToken) env['OLLAMA_API_KEY'] = profile.authToken;\n              delete env['ANTHROPIC_API_KEY'];\n              break;\n            case 'litellm':\n              if (profile.baseUrl) env['ANTHROPIC_BASE_URL'] = profile.baseUrl;\n              if (profile.authToken) env['ANTHROPIC_AUTH_TOKEN'] = profile.authToken;\n              delete env['ANTHROPIC_API_KEY'];\n              break;\n            case 'custom':\n              if (profile.baseUrl) env['OPENAI_BASE_URL'] = profile.baseUrl;\n              if (profile.authToken) env['OPENAI_API_KEY'] = profile.authToken;\n              delete env['ANTHROPIC_API_KEY'];\n              break;\n          }\n        }\n\n        this.logger.info({ personaId: persona.id, toolCount: tools.length, credCount: creds.length }, 'Assembled prompt from DB persona');\n      }\n    }\n\n    const assignment: ExecAssign = {\n      type: 'assign',\n      executionId: request.executionId,\n      personaId: request.personaId,\n      prompt,\n      env,\n      config: {\n        timeoutMs: request.config.timeoutMs || 300_000,\n        maxOutputBytes: 10 * 1024 * 1024, // 10MB\n      },\n    };\n\n    // Track in-memory for real-time streaming\n    this.active.set(request.executionId, {\n      workerId,\n      startedAt: Date.now(),\n      output: [],\n      status: 'running',\n    });\n\n    // Mark running in DB\n    if (this.database) {\n      try {\n        db.updateExecution(this.database, request.executionId, {\n          status: 'running',\n          startedAt: new Date().toISOString(),\n        });\n      } catch { /* best effort */ }\n    }\n\n    const sent = this.pool.assign(workerId, assignment);\n    if (!sent) {\n      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n      this.active.delete(request.executionId);\n      if (this.database) {\n        try { db.updateExecution(this.database, request.executionId, { status: 'queued' }); } catch { /* best effort */ }\n      }\n      // Re-queue\n      this.queue.unshift({ request, receivedAt: Date.now() });\n    } else {\n      this.logger.info({\n        workerId,\n        executionId: request.executionId,\n        personaId: request.personaId,\n      }, 'Execution dispatched to worker');\n    }\n  }\n\n  cancelExecution(executionId: string): boolean {\n    const exec = this.active.get(executionId);\n    if (!exec || exec.status !== 'running') return false;\n\n    return this.pool.send(exec.workerId, {\n      type: 'cancel',\n      executionId,\n    });\n  }\n\n  getQueueLength(): number {\n    return this.queue.length;\n  }\n\n  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n    return Array.from(this.active.entries())\n      .filter(([, e]) => e.status === 'running')\n      .map(([executionId, e]) => ({\n        executionId,\n        workerId: e.workerId,\n        startedAt: e.startedAt,\n      }));\n  }\n\n  /**\n   * Get execution state. Tries in-memory first (for real-time output),\n   * then falls back to DB for completed/historical executions.\n   */\n  getExecution(executionId: string): ActiveExecution | null {\n    // Check in-memory active executions first\n    const active = this.active.get(executionId);\n    if (active) return active;\n\n    // Fall back to DB\n    if (this.database) {\n      const dbExec = db.getExecution(this.database, executionId);\n      if (dbExec) {\n        // Convert DB execution to ActiveExecution shape for backward compat\n        return {\n          workerId: '',\n          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n          status: dbExec.status as ActiveExecution['status'],\n          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n          durationMs: dbExec.durationMs ?? undefined,\n          sessionId: dbExec.claudeSessionId ?? undefined,\n          totalCostUsd: dbExec.costUsd ?? undefined,\n        };\n      }\n    }\n\n    return null;\n  }\n\n  getExecutionOutput(executionId: string): string[] | null {\n    const exec = this.getExecution(executionId);\n    return exec?.output ?? null;\n  }\n\n  shutdown(): void {\n    // Flush remaining buffered output and stop the timer\n    if (this.flushTimer) {\n      clearInterval(this.flushTimer);\n      this.flushTimer = null;\n    }\n    this.flushAllOutputBuffers();\n  }\n\n  /** Buffer a chunk for batched DB write. Flushes immediately if threshold exceeded. */\n  private bufferOutput(executionId: string, chunk: string): void {\n    if (!this.database) return;\n\n    let chunks = this.outputBuffer.get(executionId);\n    if (!chunks) {\n      chunks = [];\n      this.outputBuffer.set(executionId, chunks);\n    }\n    chunks.push(chunk);\n\n    if (chunks.length >= Dispatcher.FLUSH_CHUNK_THRESHOLD) {\n      this.flushOutputForExecution(executionId);\n    }\n  }\n\n  /** Flush buffered output for a single execution to the DB. */\n  private flushOutputForExecution(executionId: string): void {\n    const chunks = this.outputBuffer.get(executionId);\n    if (!chunks || chunks.length === 0) return;\n    this.outputBuffer.delete(executionId);\n\n    if (this.database) {\n      try {\n        db.appendOutput(this.database, executionId, chunks.join(''));\n      } catch { /* best effort */ }\n    }\n  }\n\n  /** Flush all buffered output across all executions. */\n  private flushAllOutputBuffers(): void {\n    for (const executionId of this.outputBuffer.keys()) {\n      this.flushOutputForExecution(executionId);\n    }\n  }\n}\n","numLines":482,"startLine":1,"totalLines":482}}}
