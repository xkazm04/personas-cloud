[2026-03-18T17:52:32.173Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MTSiTdMUhVb3y7HohdMp7J","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import { nanoid } from 'nanoid';\n     3→import type { Logger } from 'pino';\n     4→import type {\n     5→  Persona,\n     6→  PersonaToolDefinition,\n     7→  PersonaCredential,\n     8→  PersonaEvent,\n     9→  PersonaEventSubscription,\n    10→  PersonaTrigger,\n    11→  PersonaExecution,\n    12→} from '@dac-cloud/shared';\n    13→\n    14→// ---------------------------------------------------------------------------\n    15→// Initialization\n    16→// ---------------------------------------------------------------------------\n    17→\n    18→export function initDb(dbPath: string, logger: Logger): Database.Database {\n    19→  const db = new Database(dbPath);\n    20→  db.pragma('journal_mode = WAL');\n    21→  db.pragma('foreign_keys = ON');\n    22→\n    23→  db.exec(SCHEMA);\n    24→  runMigrations(db, logger);\n    25→  logger.info({ dbPath }, 'Database initialized');\n    26→  return db;\n    27→}\n    28→\n    29→// ---------------------------------------------------------------------------\n    30→// Migrations\n    31→// ---------------------------------------------------------------------------\n    32→\n    33→function runMigrations(db: Database.Database, logger: Logger): void {\n    34→  // Migration: add project_id column to tables that need per-user isolation\n    35→  const tablesToMigrate = [\n    36→    'persona_credentials',\n    37→    'persona_event_subscriptions',\n    38→    'persona_triggers',\n    39→    'persona_executions',\n    40→  ];\n    41→\n    42→  for (const table of tablesToMigrate) {\n    43→    const columns = db.prepare(`PRAGMA table_info(${table})`).all() as Array<{ name: string }>;\n    44→    const hasProjectId = columns.some(c => c.name === 'project_id');\n    45→    if (!hasProjectId) {\n    46→      db.exec(`ALTER TABLE ${table} ADD COLUMN project_id TEXT NOT NULL DEFAULT 'default'`);\n    47→      logger.info({ table }, 'Migration: added project_id column');\n    48→    }\n    49→  }\n    50→\n    51→  // Indexes for project_id\n    52→  db.exec(`\n    53→    CREATE INDEX IF NOT EXISTS idx_personas_project ON personas(project_id);\n    54→    CREATE INDEX IF NOT EXISTS idx_pe_project ON persona_events(project_id);\n    55→    CREATE INDEX IF NOT EXISTS idx_pcred_project ON persona_credentials(project_id);\n    56→    CREATE INDEX IF NOT EXISTS idx_pes_project ON persona_event_subscriptions(project_id);\n    57→    CREATE INDEX IF NOT EXISTS idx_pt_project ON persona_triggers(project_id);\n    58→    CREATE INDEX IF NOT EXISTS idx_pex_project ON persona_executions(project_id);\n    59→  `);\n    60→}\n    61→\n    62→// ---------------------------------------------------------------------------\n    63→// Schema\n    64→// ---------------------------------------------------------------------------\n    65→\n    66→const SCHEMA = `\n    67→CREATE TABLE IF NOT EXISTS personas (\n    68→  id TEXT PRIMARY KEY,\n    69→  project_id TEXT NOT NULL DEFAULT 'default',\n    70→  name TEXT NOT NULL,\n    71→  description TEXT,\n    72→  system_prompt TEXT NOT NULL DEFAULT '',\n    73→  structured_prompt TEXT,\n    74→  icon TEXT,\n    75→  color TEXT,\n    76→  enabled INTEGER NOT NULL DEFAULT 1,\n    77→  max_concurrent INTEGER NOT NULL DEFAULT 1,\n    78→  timeout_ms INTEGER NOT NULL DEFAULT 300000,\n    79→  model_profile TEXT,\n    80→  max_budget_usd REAL,\n    81→  max_turns INTEGER,\n    82→  design_context TEXT,\n    83→  group_id TEXT,\n    84→  created_at TEXT NOT NULL,\n    85→  updated_at TEXT NOT NULL\n    86→);\n    87→\n    88→CREATE TABLE IF NOT EXISTS persona_tool_definitions (\n    89→  id TEXT PRIMARY KEY,\n    90→  name TEXT NOT NULL UNIQUE,\n    91→  category TEXT NOT NULL,\n    92→  description TEXT NOT NULL,\n    93→  script_path TEXT NOT NULL DEFAULT '',\n    94→  input_schema TEXT,\n    95→  output_schema TEXT,\n    96→  requires_credential_type TEXT,\n    97→  implementation_guide TEXT,\n    98→  is_builtin INTEGER NOT NULL DEFAULT 0,\n    99→  created_at TEXT NOT NULL,\n   100→  updated_at TEXT NOT NULL\n   101→);\n   102→\n   103→CREATE TABLE IF NOT EXISTS persona_tools (\n   104→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   105→  tool_id TEXT NOT NULL REFERENCES persona_tool_definitions(id) ON DELETE CASCADE,\n   106→  PRIMARY KEY (persona_id, tool_id)\n   107→);\n   108→\n   109→CREATE TABLE IF NOT EXISTS persona_credentials (\n   110→  id TEXT PRIMARY KEY,\n   111→  project_id TEXT NOT NULL DEFAULT 'default',\n   112→  name TEXT NOT NULL,\n   113→  service_type TEXT NOT NULL,\n   114→  encrypted_data TEXT NOT NULL,\n   115→  iv TEXT NOT NULL,\n   116→  tag TEXT NOT NULL,\n   117→  metadata TEXT,\n   118→  last_used_at TEXT,\n   119→  created_at TEXT NOT NULL,\n   120→  updated_at TEXT NOT NULL\n   121→);\n   122→\n   123→CREATE TABLE IF NOT EXISTS persona_credential_links (\n   124→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   125→  credential_id TEXT NOT NULL REFERENCES persona_credentials(id) ON DELETE CASCADE,\n   126→  PRIMARY KEY (persona_id, credential_id)\n   127→);\n   128→\n   129→CREATE TABLE IF NOT EXISTS persona_events (\n   130→  id TEXT PRIMARY KEY,\n   131→  project_id TEXT NOT NULL DEFAULT 'default',\n   132→  event_type TEXT NOT NULL,\n   133→  source_type TEXT NOT NULL,\n   134→  source_id TEXT,\n   135→  target_persona_id TEXT,\n   136→  payload TEXT,\n   137→  status TEXT NOT NULL DEFAULT 'pending',\n   138→  error_message TEXT,\n   139→  processed_at TEXT,\n   140→  use_case_id TEXT,\n   141→  created_at TEXT NOT NULL\n   142→);\n   143→CREATE INDEX IF NOT EXISTS idx_pe_status ON persona_events(status);\n   144→\n   145→CREATE TABLE IF NOT EXISTS persona_event_subscriptions (\n   146→  id TEXT PRIMARY KEY,\n   147→  project_id TEXT NOT NULL DEFAULT 'default',\n   148→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   149→  event_type TEXT NOT NULL,\n   150→  source_filter TEXT,\n   151→  enabled INTEGER NOT NULL DEFAULT 1,\n   152→  use_case_id TEXT,\n   153→  created_at TEXT NOT NULL,\n   154→  updated_at TEXT NOT NULL\n   155→);\n   156→\n   157→CREATE TABLE IF NOT EXISTS persona_triggers (\n   158→  id TEXT PRIMARY KEY,\n   159→  project_id TEXT NOT NULL DEFAULT 'default',\n   160→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   161→  trigger_type TEXT NOT NULL CHECK(trigger_type IN ('manual','schedule','polling','webhook','chain')),\n   162→  config TEXT,\n   163→  enabled INTEGER NOT NULL DEFAULT 1,\n   164→  last_triggered_at TEXT,\n   165→  next_trigger_at TEXT,\n   166→  use_case_id TEXT,\n   167→  created_at TEXT NOT NULL,\n   168→  updated_at TEXT NOT NULL\n   169→);\n   170→\n   171→CREATE TABLE IF NOT EXISTS persona_executions (\n   172→  id TEXT PRIMARY KEY,\n   173→  project_id TEXT NOT NULL DEFAULT 'default',\n   174→  persona_id TEXT NOT NULL,\n   175→  trigger_id TEXT,\n   176→  use_case_id TEXT,\n   177→  status TEXT NOT NULL DEFAULT 'queued' CHECK(status IN ('queued','running','completed','failed','cancelled')),\n   178→  input_data TEXT,\n   179→  output_data TEXT,\n   180→  claude_session_id TEXT,\n   181→  model_used TEXT,\n   182→  input_tokens INTEGER DEFAULT 0,\n   183→  output_tokens INTEGER DEFAULT 0,\n   184→  cost_usd REAL DEFAULT 0,\n   185→  error_message TEXT,\n   186→  duration_ms INTEGER,\n   187→  retry_of_execution_id TEXT,\n   188→  retry_count INTEGER DEFAULT 0,\n   189→  started_at TEXT,\n   190→  completed_at TEXT,\n   191→  created_at TEXT NOT NULL\n   192→);\n   193→CREATE INDEX IF NOT EXISTS idx_pex_persona ON persona_executions(persona_id);\n   194→CREATE INDEX IF NOT EXISTS idx_pex_status ON persona_executions(status);\n   195→`;\n   196→\n   197→// ---------------------------------------------------------------------------\n   198→// Row → domain type mappers\n   199→// ---------------------------------------------------------------------------\n   200→\n   201→function rowToPersona(row: Record<string, unknown>): Persona {\n   202→  return {\n   203→    id: row['id'] as string,\n   204→    projectId: row['project_id'] as string,\n   205→    name: row['name'] as string,\n   206→    description: (row['description'] as string) ?? null,\n   207→    systemPrompt: row['system_prompt'] as string,\n   208→    structuredPrompt: (row['structured_prompt'] as string) ?? null,\n   209→    icon: (row['icon'] as string) ?? null,\n   210→    color: (row['color'] as string) ?? null,\n   211→    enabled: row['enabled'] === 1,\n   212→    maxConcurrent: row['max_concurrent'] as number,\n   213→    timeoutMs: row['timeout_ms'] as number,\n   214→    modelProfile: (row['model_profile'] as string) ?? null,\n   215→    maxBudgetUsd: (row['max_budget_usd'] as number) ?? null,\n   216→    maxTurns: (row['max_turns'] as number) ?? null,\n   217→    designContext: (row['design_context'] as string) ?? null,\n   218→    groupId: (row['group_id'] as string) ?? null,\n   219→    createdAt: row['created_at'] as string,\n   220→    updatedAt: row['updated_at'] as string,\n   221→  };\n   222→}\n   223→\n   224→function rowToTool(row: Record<string, unknown>): PersonaToolDefinition {\n   225→  return {\n   226→    id: row['id'] as string,\n   227→    name: row['name'] as string,\n   228→    category: row['category'] as string,\n   229→    description: row['description'] as string,\n   230→    scriptPath: row['script_path'] as string,\n   231→    inputSchema: (row['input_schema'] as string) ?? null,\n   232→    outputSchema: (row['output_schema'] as string) ?? null,\n   233→    requiresCredentialType: (row['requires_credential_type'] as string) ?? null,\n   234→    implementationGuide: (row['implementation_guide'] as string) ?? null,\n   235→    isBuiltin: row['is_builtin'] === 1,\n   236→    createdAt: row['created_at'] as string,\n   237→    updatedAt: row['updated_at'] as string,\n   238→  };\n   239→}\n   240→\n   241→function rowToCredential(row: Record<string, unknown>): PersonaCredential {\n   242→  return {\n   243→    id: row['id'] as string,\n   244→    projectId: (row['project_id'] as string) ?? 'default',\n   245→    name: row['name'] as string,\n   246→    serviceType: row['service_type'] as string,\n   247→    encryptedData: row['encrypted_data'] as string,\n   248→    iv: row['iv'] as string,\n   249→    tag: row['tag'] as string,\n   250→    metadata: (row['metadata'] as string) ?? null,\n   251→    lastUsedAt: (row['last_used_at'] as string) ?? null,\n   252→    createdAt: row['created_at'] as string,\n   253→    updatedAt: row['updated_at'] as string,\n   254→  };\n   255→}\n   256→\n   257→function rowToEvent(row: Record<string, unknown>): PersonaEvent {\n   258→  return {\n   259→    id: row['id'] as string,\n   260→    projectId: row['project_id'] as string,\n   261→    eventType: row['event_type'] as string,\n   262→    sourceType: row['source_type'] as string,\n   263→    sourceId: (row['source_id'] as string) ?? null,\n   264→    targetPersonaId: (row['target_persona_id'] as string) ?? null,\n   265→    payload: (row['payload'] as string) ?? null,\n   266→    status: row['status'] as string,\n   267→    errorMessage: (row['error_message'] as string) ?? null,\n   268→    processedAt: (row['processed_at'] as string) ?? null,\n   269→    useCaseId: (row['use_case_id'] as string) ?? null,\n   270→    createdAt: row['created_at'] as string,\n   271→  };\n   272→}\n   273→\n   274→function rowToSubscription(row: Record<string, unknown>): PersonaEventSubscription {\n   275→  return {\n   276→    id: row['id'] as string,\n   277→    personaId: row['persona_id'] as string,\n   278→    eventType: row['event_type'] as string,\n   279→    sourceFilter: (row['source_filter'] as string) ?? null,\n   280→    enabled: row['enabled'] === 1,\n   281→    useCaseId: (row['use_case_id'] as string) ?? null,\n   282→    createdAt: row['created_at'] as string,\n   283→    updatedAt: row['updated_at'] as string,\n   284→  };\n   285→}\n   286→\n   287→function rowToTrigger(row: Record<string, unknown>): PersonaTrigger {\n   288→  return {\n   289→    id: row['id'] as string,\n   290→    personaId: row['persona_id'] as string,\n   291→    triggerType: row['trigger_type'] as string,\n   292→    config: (row['config'] as string) ?? null,\n   293→    enabled: row['enabled'] === 1,\n   294→    lastTriggeredAt: (row['last_triggered_at'] as string) ?? null,\n   295→    nextTriggerAt: (row['next_trigger_at'] as string) ?? null,\n   296→    useCaseId: (row['use_case_id'] as string) ?? null,\n   297→    createdAt: row['created_at'] as string,\n   298→    updatedAt: row['updated_at'] as string,\n   299→  };\n   300→}\n   301→\n   302→function rowToExecution(row: Record<string, unknown>): PersonaExecution {\n   303→  return {\n   304→    id: row['id'] as string,\n   305→    projectId: (row['project_id'] as string) ?? 'default',\n   306→    personaId: row['persona_id'] as string,\n   307→    triggerId: (row['trigger_id'] as string) ?? null,\n   308→    useCaseId: (row['use_case_id'] as string) ?? null,\n   309→    status: row['status'] as string,\n   310→    inputData: (row['input_data'] as string) ?? null,\n   311→    outputData: (row['output_data'] as string) ?? null,\n   312→    claudeSessionId: (row['claude_session_id'] as string) ?? null,\n   313→    modelUsed: (row['model_used'] as string) ?? null,\n   314→    inputTokens: (row['input_tokens'] as number) ?? 0,\n   315→    outputTokens: (row['output_tokens'] as number) ?? 0,\n   316→    costUsd: (row['cost_usd'] as number) ?? 0,\n   317→    errorMessage: (row['error_message'] as string) ?? null,\n   318→    durationMs: (row['duration_ms'] as number) ?? null,\n   319→    retryOfExecutionId: (row['retry_of_execution_id'] as string) ?? null,\n   320→    retryCount: (row['retry_count'] as number) ?? 0,\n   321→    startedAt: (row['started_at'] as string) ?? null,\n   322→    completedAt: (row['completed_at'] as string) ?? null,\n   323→    createdAt: row['created_at'] as string,\n   324→  };\n   325→}\n   326→\n   327→// ---------------------------------------------------------------------------\n   328→// Persona CRUD\n   329→// ---------------------------------------------------------------------------\n   330→\n   331→export function getPersona(db: Database.Database, id: string): Persona | undefined {\n   332→  const row = db.prepare('SELECT * FROM personas WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n   333→  return row ? rowToPersona(row) : undefined;\n   334→}\n   335→\n   336→export function listPersonas(db: Database.Database, projectId?: string): Persona[] {\n   337→  if (projectId) {\n   338→    const rows = db.prepare('SELECT * FROM personas WHERE project_id = ? ORDER BY name').all(projectId) as Record<string, unknown>[];\n   339→    return rows.map(rowToPersona);\n   340→  }\n   341→  const rows = db.prepare('SELECT * FROM personas ORDER BY name').all() as Record<string, unknown>[];\n   342→  return rows.map(rowToPersona);\n   343→}\n   344→\n   345→export function upsertPersona(db: Database.Database, p: Persona): void {\n   346→  db.prepare(`\n   347→    INSERT INTO personas (id, project_id, name, description, system_prompt, structured_prompt, icon, color, enabled, max_concurrent, timeout_ms, model_profile, max_budget_usd, max_turns, design_context, group_id, created_at, updated_at)\n   348→    VALUES (@id, @projectId, @name, @description, @systemPrompt, @structuredPrompt, @icon, @color, @enabled, @maxConcurrent, @timeoutMs, @modelProfile, @maxBudgetUsd, @maxTurns, @designContext, @groupId, @createdAt, @updatedAt)\n   349→    ON CONFLICT(id) DO UPDATE SET\n   350→      name = excluded.name, description = excluded.description, system_prompt = excluded.system_prompt,\n   351→      structured_prompt = excluded.structured_prompt, icon = excluded.icon, color = excluded.color,\n   352→      enabled = excluded.enabled, max_concurrent = excluded.max_concurrent, timeout_ms = excluded.timeout_ms,\n   353→      model_profile = excluded.model_profile, max_budget_usd = excluded.max_budget_usd, max_turns = excluded.max_turns,\n   354→      design_context = excluded.design_context, group_id = excluded.group_id, updated_at = excluded.updated_at\n   355→  `).run({\n   356→    id: p.id,\n   357→    projectId: p.projectId,\n   358→    name: p.name,\n   359→    description: p.description,\n   360→    systemPrompt: p.systemPrompt,\n   361→    structuredPrompt: p.structuredPrompt,\n   362→    icon: p.icon,\n   363→    color: p.color,\n   364→    enabled: p.enabled ? 1 : 0,\n   365→    maxConcurrent: p.maxConcurrent,\n   366→    timeoutMs: p.timeoutMs,\n   367→    modelProfile: p.modelProfile,\n   368→    maxBudgetUsd: p.maxBudgetUsd,\n   369→    maxTurns: p.maxTurns,\n   370→    designContext: p.designContext,\n   371→    groupId: p.groupId,\n   372→    createdAt: p.createdAt,\n   373→    updatedAt: p.updatedAt,\n   374→  });\n   375→}\n   376→\n   377→export function deletePersona(db: Database.Database, id: string, projectId?: string): void {\n   378→  if (projectId) {\n   379→    db.prepare('DELETE FROM personas WHERE id = ? AND project_id = ?').run(id, projectId);\n   380→  } else {\n   381→    db.prepare('DELETE FROM personas WHERE id = ?').run(id);\n   382→  }\n   383→}\n   384→\n   385→// ---------------------------------------------------------------------------\n   386→// Tool Definitions\n   387→// ---------------------------------------------------------------------------\n   388→\n   389→export function getToolsForPersona(db: Database.Database, personaId: string): PersonaToolDefinition[] {\n   390→  const rows = db.prepare(`\n   391→    SELECT t.* FROM persona_tool_definitions t\n   392→    JOIN persona_tools pt ON pt.tool_id = t.id\n   393→    WHERE pt.persona_id = ?\n   394→  `).all(personaId) as Record<string, unknown>[];\n   395→  return rows.map(rowToTool);\n   396→}\n   397→\n   398→export function upsertToolDefinition(db: Database.Database, t: PersonaToolDefinition): void {\n   399→  db.prepare(`\n   400→    INSERT INTO persona_tool_definitions (id, name, category, description, script_path, input_schema, output_schema, requires_credential_type, implementation_guide, is_builtin, created_at, updated_at)\n   401→    VALUES (@id, @name, @category, @description, @scriptPath, @inputSchema, @outputSchema, @requiresCredentialType, @implementationGuide, @isBuiltin, @createdAt, @updatedAt)\n   402→    ON CONFLICT(id) DO UPDATE SET\n   403→      name = excluded.name, category = excluded.category, description = excluded.description,\n   404→      script_path = excluded.script_path, input_schema = excluded.input_schema, output_schema = excluded.output_schema,\n   405→      requires_credential_type = excluded.requires_credential_type, implementation_guide = excluded.implementation_guide,\n   406→      is_builtin = excluded.is_builtin, updated_at = excluded.updated_at\n   407→  `).run({\n   408→    id: t.id,\n   409→    name: t.name,\n   410→    category: t.category,\n   411→    description: t.description,\n   412→    scriptPath: t.scriptPath,\n   413→    inputSchema: t.inputSchema,\n   414→    outputSchema: t.outputSchema,\n   415→    requiresCredentialType: t.requiresCredentialType,\n   416→    implementationGuide: t.implementationGuide,\n   417→    isBuiltin: t.isBuiltin ? 1 : 0,\n   418→    createdAt: t.createdAt,\n   419→    updatedAt: t.updatedAt,\n   420→  });\n   421→}\n   422→\n   423→export function linkTool(db: Database.Database, personaId: string, toolId: string): void {\n   424→  db.prepare('INSERT OR IGNORE INTO persona_tools (persona_id, tool_id) VALUES (?, ?)').run(personaId, toolId);\n   425→}\n   426→\n   427→export function unlinkTool(db: Database.Database, personaId: string, toolId: string): void {\n   428→  db.prepare('DELETE FROM persona_tools WHERE persona_id = ? AND tool_id = ?').run(personaId, toolId);\n   429→}\n   430→\n   431→// ---------------------------------------------------------------------------\n   432→// Credentials\n   433→// ---------------------------------------------------------------------------\n   434→\n   435→export function createCredential(db: Database.Database, input: {\n   436→  name: string; serviceType: string; encryptedData: string; iv: string; tag: string; metadata?: string | null; projectId?: string;\n   437→}): PersonaCredential {\n   438→  const now = new Date().toISOString();\n   439→  const id = nanoid();\n   440→  db.prepare(`\n   441→    INSERT INTO persona_credentials (id, project_id, name, service_type, encrypted_data, iv, tag, metadata, created_at, updated_at)\n   442→    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n   443→  `).run(id, input.projectId ?? 'default', input.name, input.serviceType, input.encryptedData, input.iv, input.tag, input.metadata ?? null, now, now);\n   444→  return getCredential(db, id)!;\n   445→}\n   446→\n   447→export function getCredential(db: Database.Database, id: string): PersonaCredential | undefined {\n   448→  const row = db.prepare('SELECT * FROM persona_credentials WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n   449→  return row ? rowToCredential(row) : undefined;\n   450→}\n   451→\n   452→export function listCredentialsForPersona(db: Database.Database, personaId: string): PersonaCredential[] {\n   453→  const rows = db.prepare(`\n   454→    SELECT c.* FROM persona_credentials c\n   455→    JOIN persona_credential_links cl ON cl.credential_id = c.id\n   456→    WHERE cl.persona_id = ?\n   457→  `).all(personaId) as Record<string, unknown>[];\n   458→  return rows.map(rowToCredential);\n   459→}\n   460→\n   461→export function linkCredential(db: Database.Database, personaId: string, credentialId: string): void {\n   462→  db.prepare('INSERT OR IGNORE INTO persona_credential_links (persona_id, credential_id) VALUES (?, ?)').run(personaId, credentialId);\n   463→}\n   464→\n   465→export function deleteCredential(db: Database.Database, id: string): void {\n   466→  db.prepare('DELETE FROM persona_credentials WHERE id = ?').run(id);\n   467→}\n   468→\n   469→// ---------------------------------------------------------------------------\n   470→// Events\n   471→// ---------------------------------------------------------------------------\n   472→\n   473→export function publishEvent(db: Database.Database, input: {\n   474→  eventType: string; sourceType: string; sourceId?: string | null; targetPersonaId?: string | null;\n   475→  projectId?: string; payload?: string | null; useCaseId?: string | null;\n   476→}): PersonaEvent {\n   477→  const now = new Date().toISOString();\n   478→  const id = nanoid();\n   479→  db.prepare(`\n   480→    INSERT INTO persona_events (id, project_id, event_type, source_type, source_id, target_persona_id, payload, use_case_id, status, created_at)\n   481→    VALUES (?, ?, ?, ?, ?, ?, ?, ?, 'pending', ?)\n   482→  `).run(id, input.projectId ?? 'default', input.eventType, input.sourceType, input.sourceId ?? null, input.targetPersonaId ?? null, input.payload ?? null, input.useCaseId ?? null, now);\n   483→  return getEvent(db, id)!;\n   484→}\n   485→\n   486→export function getEvent(db: Database.Database, id: string): PersonaEvent | undefined {\n   487→  const row = db.prepare('SELECT * FROM persona_events WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n   488→  return row ? rowToEvent(row) : undefined;\n   489→}\n   490→\n   491→export function getPendingEvents(db: Database.Database, limit: number = 50): PersonaEvent[] {\n   492→  const rows = db.prepare(\"SELECT * FROM persona_events WHERE status = 'pending' ORDER BY created_at LIMIT ?\").all(limit) as Record<string, unknown>[];\n   493→  return rows.map(rowToEvent);\n   494→}\n   495→\n   496→export function listEvents(db: Database.Database, opts?: {\n   497