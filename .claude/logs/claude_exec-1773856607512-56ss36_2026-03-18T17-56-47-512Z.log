[2026-03-18T17:56:57.984Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ECpMH5hksoEQX1XWXojUGG","type":"tool_result","content":"     1→// ---------------------------------------------------------------------------\n     2→// Dispatch pipeline — composable stages for worker dispatch\n     3→//\n     4→// Each stage is a standalone async function with typed inputs/outputs,\n     5→// independently testable without mocking the entire Dispatcher.\n     6→//\n     7→// Pipeline: ResolveToken → ResolvePersona → AssemblePayload → BuildAssignment\n     8→// ---------------------------------------------------------------------------\n     9→\n    10→import type { ExecAssign, ExecRequest, NetworkPolicy, Persona, PersonaToolDefinition, EncryptedPayload } from '@dac-cloud/shared';\n    11→import { assemblePrompt, resolveEnvOverrides, toEncryptedPayload, parseNetworkPolicy } from '@dac-cloud/shared';\n    12→import type Database from 'better-sqlite3';\n    13→import type { TokenManager } from './tokenManager.js';\n    14→import type { OAuthManager } from './oauth.js';\n    15→import type { Logger } from 'pino';\n    16→import * as db from './db/index.js';\n    17→\n    18→// ========================== Stage result types =============================\n    19→\n    20→export interface TokenResult {\n    21→  claudeToken: string;\n    22→}\n    23→\n    24→export interface PersonaResolution {\n    25→  persona: Persona | null;\n    26→  tools: PersonaToolDefinition[];\n    27→  credentialHints: string[];\n    28→  credentialEnv: Record<string, string>;\n    29→  inferenceEnvSet: Record<string, string>;\n    30→  inferenceEnvRemove: string[];\n    31→}\n    32→\n    33→export interface AssembledPayload {\n    34→  prompt: string;\n    35→  env: Record<string, string>;\n    36→  networkPolicy: NetworkPolicy | undefined;\n    37→  maxBudgetUsd: number | null;\n    38→  maxTurns: number | null;\n    39→}\n    40→\n    41→// ========================= Dependency interfaces ===========================\n    42→\n    43→/** Minimal decryption capability — abstracts master/tenant key resolution. */\n    44→export interface Decryptor {\n    45→  decrypt(\n    46→    payload: EncryptedPayload,\n    47→    tenantId: string,\n    48→    resourceId: string,\n    49→    logContext: Record<string, unknown>,\n    50→    logMessage: string,\n    51→  ): Promise<string | undefined>;\n    52→}\n    53→\n    54→// =========================== Stage 1: Token ================================\n    55→\n    56→export async function resolveToken(\n    57→  oauth: OAuthManager | null,\n    58→  tokenManager: TokenManager,\n    59→): Promise<TokenResult | null> {\n    60→  let claudeToken: string | null = null;\n    61→\n    62→  if (oauth?.hasTokens()) {\n    63→    claudeToken = await oauth.getValidAccessToken();\n    64→    if (claudeToken) {\n    65→      tokenManager.storeClaudeToken(claudeToken);\n    66→    }\n    67→  }\n    68→\n    69→  if (!claudeToken) {\n    70→    claudeToken = tokenManager.getClaudeToken();\n    71→  }\n    72→\n    73→  return claudeToken ? { claudeToken } : null;\n    74→}\n    75→\n    76→// ========================== Stage 2: Persona ===============================\n    77→\n    78→export async function resolvePersona(\n    79→  dispatchDb: Database.Database | null,\n    80→  personaId: string,\n    81→  tenantId: string,\n    82→  decryptor: Decryptor,\n    83→  logger: Logger,\n    84→): Promise<PersonaResolution> {\n    85→  const empty: PersonaResolution = {\n    86→    persona: null,\n    87→    tools: [],\n    88→    credentialHints: [],\n    89→    credentialEnv: {},\n    90→    inferenceEnvSet: {},\n    91→    inferenceEnvRemove: [],\n    92→  };\n    93→\n    94→  if (!dispatchDb) return empty;\n    95→\n    96→  const persona = db.getPersona(dispatchDb, personaId);\n    97→  if (!persona) return empty;\n    98→\n    99→  const tools = db.getToolsForPersona(dispatchDb, persona.id);\n   100→  const creds = db.listCredentialsForPersona(dispatchDb, persona.id);\n   101→\n   102→  // Decrypt credentials\n   103→  const credentialHints: string[] = [];\n   104→  const credentialEnv: Record<string, string> = {};\n   105→\n   106→  for (const cred of creds) {\n   107→    const envName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   108→    credentialHints.push(envName);\n   109→\n   110→    const decrypted = await decryptor.decrypt(\n   111→      toEncryptedPayload(cred),\n   112→      tenantId,\n   113→      cred.id,\n   114→      { credentialId: cred.id, credentialName: cred.name },\n   115→      'Failed to decrypt credential',\n   116→    );\n   117→\n   118→    if (decrypted !== undefined) {\n   119→      try {\n   120→        const fields = JSON.parse(decrypted) as Record<string, string>;\n   121→        for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n   122→          const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   123→          credentialEnv[fieldEnvName] = String(fieldValue);\n   124→        }\n   125→      } catch {\n   126→        credentialEnv[envName] = decrypted;\n   127→      }\n   128→    }\n   129→  }\n   130→\n   131→  // Resolve inference profile env overrides\n   132→  let inferenceEnvSet: Record<string, string> = {};\n   133→  let inferenceEnvRemove: string[] = [];\n   134→\n   135→  if (persona.inferenceProfileId) {\n   136→    const inferenceProfile = db.getInferenceProfile(dispatchDb, persona.inferenceProfileId);\n   137→    if (inferenceProfile) {\n   138→      let decryptedAuthToken: string | undefined;\n   139→      if (inferenceProfile.authTokenEncrypted && inferenceProfile.authTokenIv && inferenceProfile.authTokenTag) {\n   140→        decryptedAuthToken = await decryptor.decrypt(\n   141→          { encrypted: inferenceProfile.authTokenEncrypted, iv: inferenceProfile.authTokenIv, tag: inferenceProfile.authTokenTag },\n   142→          tenantId,\n   143→          `inference-profile:${inferenceProfile.id}`,\n   144→          { profileId: inferenceProfile.id },\n   145→          'Failed to decrypt inference profile auth token',\n   146→        );\n   147→        decryptedAuthToken = decryptedAuthToken ?? undefined;\n   148→      }\n   149→      const overrides = resolveEnvOverrides(inferenceProfile, decryptedAuthToken);\n   150→      inferenceEnvSet = overrides.set;\n   151→      inferenceEnvRemove = overrides.remove;\n   152→    }\n   153→  }\n   154→\n   155→  logger.info({ personaId: persona.id, toolCount: tools.length, credCount: creds.length }, 'Assembled prompt from DB persona');\n   156→\n   157→  return { persona, tools, credentialHints, credentialEnv, inferenceEnvSet, inferenceEnvRemove };\n   158→}\n   159→\n   160→// ======================== Stage 3: Assemble ================================\n   161→\n   162→export function assemblePayload(\n   163→  request: ExecRequest,\n   164→  token: TokenResult,\n   165→  resolution: PersonaResolution,\n   166→): AssembledPayload {\n   167→  // Build env map: API key + credential env + inference overrides\n   168→  const env: Record<string, string> = {\n   169→    ANTHROPIC_API_KEY: token.claudeToken,\n   170→    ...resolution.credentialEnv,\n   171→    ...resolution.inferenceEnvSet,\n   172→  };\n   173→\n   174→  // Remove inference-specified keys\n   175→  for (const k of resolution.inferenceEnvRemove) {\n   176→    delete env[k];\n   177→  }\n   178→\n   179→  // Build prompt\n   180→  let prompt: string;\n   181→  if (resolution.persona) {\n   182→    const inputData = request.inputData ? (request.inputData as Record<string, unknown>) : undefined;\n   183→    prompt = assemblePrompt(\n   184→      resolution.persona,\n   185→      resolution.tools,\n   186→      inputData,\n   187→      resolution.credentialHints.length > 0 ? resolution.credentialHints : undefined,\n   188→    );\n   189→  } else {\n   190→    prompt = request.prompt;\n   191→  }\n   192→\n   193→  // Resolve network policy\n   194→  let networkPolicy: NetworkPolicy | undefined;\n   195→  if (resolution.persona?.networkPolicy) {\n   196→    networkPolicy = parseNetworkPolicy(resolution.persona.networkPolicy) ?? undefined;\n   197→  }\n   198→\n   199→  return {\n   200→    prompt,\n   201→    env,\n   202→    networkPolicy,\n   203→    maxBudgetUsd: resolution.persona?.maxBudgetUsd ?? null,\n   204→    maxTurns: resolution.persona?.maxTurns ?? null,\n   205→  };\n   206→}\n   207→\n   208→// =================== Stage 4: Build assignment =============================\n   209→\n   210→export function buildAssignment(\n   211→  request: ExecRequest,\n   212→  payload: AssembledPayload,\n   213→): ExecAssign {\n   214→  return {\n   215→    type: 'assign',\n   216→    executionId: request.executionId,\n   217→    personaId: request.personaId,\n   218→    prompt: payload.prompt,\n   219→    env: payload.env,\n   220→    config: {\n   221→      timeoutMs: request.config.timeoutMs || 300_000,\n   222→      maxOutputBytes: 10 * 1024 * 1024,\n   223→      ...(payload.networkPolicy ? { networkPolicy: payload.networkPolicy } : {}),\n   224→      ...(payload.maxBudgetUsd ? { maxBudgetUsd: payload.maxBudgetUsd } : {}),\n   225→      ...(payload.maxTurns ? { maxTurns: payload.maxTurns } : {}),\n   226→    },\n   227→  };\n   228→}\n   229→\n   230→// ============== ExecutionPreparer — stages 2-4 composed ====================\n   231→\n   232→/** Resolves a DB handle for a given project/tenant ID. */\n   233→export type DbResolver = (projectId?: string) => Database.Database | null;\n   234→\n   235→/**\n   236→ * Composes persona resolution, payload assembly, and assignment building\n   237→ * into a single prepare() call. Token acquisition and the actual send\n   238→ * remain in the Dispatcher.\n   239→ */\n   240→export class ExecutionPreparer {\n   241→  constructor(\n   242→    private resolveDb: DbResolver,\n   243→    private decryptor: Decryptor,\n   244→    private logger: Logger,\n   245→  ) {}\n   246→\n   247→  /**\n   248→   * Prepare an ExecAssign from a request and a pre-resolved token.\n   249→   * Pure enrichment — no side effects beyond DB reads and decryption.\n   250→   */\n   251→  async prepare(request: ExecRequest, token: TokenResult): Promise<ExecAssign> {\n   252→    const tenantId = request.projectId || 'default';\n   253→    const dispatchDb = this.resolveDb(tenantId);\n   254→\n   255→    const resolution = await resolvePersona(\n   256→      dispatchDb,\n   257→      request.personaId,\n   258→      tenantId,\n   259→      this.decryptor,\n   260→      this.logger,\n   261→    );\n   262→\n   263→    const payload = assemblePayload(request, token, resolution);\n   264→    return buildAssignment(request, payload);\n   265→  }\n   266→}\n   267→"}]},"parent_tool_use_id":null,"session_id":"22e752af-3acf-42d7-8b18-b18301d6aa7c","uuid":"d0d89896-d669-4e74-bd9c-aaf43ac485ec","timestamp":"2026-03-18T17:56:57.875Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\dispatchPipeline.ts","content":"// ---------------------------------------------------------------------------\n// Dispatch pipeline — composable stages for worker dispatch\n//\n// Each stage is a standalone async function with typed inputs/outputs,\n// independently testable without mocking the entire Dispatcher.\n//\n// Pipeline: ResolveToken → ResolvePersona → AssemblePayload → BuildAssignment\n// ---------------------------------------------------------------------------\n\nimport type { ExecAssign, ExecRequest, NetworkPolicy, Persona, PersonaToolDefinition, EncryptedPayload } from '@dac-cloud/shared';\nimport { assemblePrompt, resolveEnvOverrides, toEncryptedPayload, parseNetworkPolicy } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\n\n// ========================== Stage result types =============================\n\nexport interface TokenResult {\n  claudeToken: string;\n}\n\nexport interface PersonaResolution {\n  persona: Persona | null;\n  tools: PersonaToolDefinition[];\n  credentialHints: string[];\n  credentialEnv: Record<string, string>;\n  inferenceEnvSet: Record<string, string>;\n  inferenceEnvRemove: string[];\n}\n\nexport interface AssembledPayload {\n  prompt: string;\n  env: Record<string, string>;\n  networkPolicy: NetworkPolicy | undefined;\n  maxBudgetUsd: number | null;\n  maxTurns: number | null;\n}\n\n// ========================= Dependency interfaces ===========================\n\n/** Minimal decryption capability — abstracts master/tenant key resolution. */\nexport interface Decryptor {\n  decrypt(\n    payload: EncryptedPayload,\n    tenantId: string,\n    resourceId: string,\n    logContext: Record<string, unknown>,\n    logMessage: string,\n  ): Promise<string | undefined>;\n}\n\n// =========================== Stage 1: Token ================================\n\nexport async function resolveToken(\n  oauth: OAuthManager | null,\n  tokenManager: TokenManager,\n): Promise<TokenResult | null> {\n  let claudeToken: string | null = null;\n\n  if (oauth?.hasTokens()) {\n    claudeToken = await oauth.getValidAccessToken();\n    if (claudeToken) {\n      tokenManager.storeClaudeToken(claudeToken);\n    }\n  }\n\n  if (!claudeToken) {\n    claudeToken = tokenManager.getClaudeToken();\n  }\n\n  return claudeToken ? { claudeToken } : null;\n}\n\n// ========================== Stage 2: Persona ===============================\n\nexport async function resolvePersona(\n  dispatchDb: Database.Database | null,\n  personaId: string,\n  tenantId: string,\n  decryptor: Decryptor,\n  logger: Logger,\n): Promise<PersonaResolution> {\n  const empty: PersonaResolution = {\n    persona: null,\n    tools: [],\n    credentialHints: [],\n    credentialEnv: {},\n    inferenceEnvSet: {},\n    inferenceEnvRemove: [],\n  };\n\n  if (!dispatchDb) return empty;\n\n  const persona = db.getPersona(dispatchDb, personaId);\n  if (!persona) return empty;\n\n  const tools = db.getToolsForPersona(dispatchDb, persona.id);\n  const creds = db.listCredentialsForPersona(dispatchDb, persona.id);\n\n  // Decrypt credentials\n  const credentialHints: string[] = [];\n  const credentialEnv: Record<string, string> = {};\n\n  for (const cred of creds) {\n    const envName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n    credentialHints.push(envName);\n\n    const decrypted = await decryptor.decrypt(\n      toEncryptedPayload(cred),\n      tenantId,\n      cred.id,\n      { credentialId: cred.id, credentialName: cred.name },\n      'Failed to decrypt credential',\n    );\n\n    if (decrypted !== undefined) {\n      try {\n        const fields = JSON.parse(decrypted) as Record<string, string>;\n        for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n          const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n          credentialEnv[fieldEnvName] = String(fieldValue);\n        }\n      } catch {\n        credentialEnv[envName] = decrypted;\n      }\n    }\n  }\n\n  // Resolve inference profile env overrides\n  let inferenceEnvSet: Record<string, string> = {};\n  let inferenceEnvRemove: string[] = [];\n\n  if (persona.inferenceProfileId) {\n    const inferenceProfile = db.getInferenceProfile(dispatchDb, persona.inferenceProfileId);\n    if (inferenceProfile) {\n      let decryptedAuthToken: string | undefined;\n      if (inferenceProfile.authTokenEncrypted && inferenceProfile.authTokenIv && inferenceProfile.authTokenTag) {\n        decryptedAuthToken = await decryptor.decrypt(\n          { encrypted: inferenceProfile.authTokenEncrypted, iv: inferenceProfile.authTokenIv, tag: inferenceProfile.authTokenTag },\n          tenantId,\n          `inference-profile:${inferenceProfile.id}`,\n          { profileId: inferenceProfile.id },\n          'Failed to decrypt inference profile auth token',\n        );\n        decryptedAuthToken = decryptedAuthToken ?? undefined;\n      }\n      const overrides = resolveEnvOverrides(inferenceProfile, decryptedAuthToken);\n      inferenceEnvSet = overrides.set;\n      inferenceEnvRemove = overrides.remove;\n    }\n  }\n\n  logger.info({ personaId: persona.id, toolCount: tools.length, credCount: creds.length }, 'Assembled prompt from DB persona');\n\n  return { persona, tools, credentialHints, credentialEnv, inferenceEnvSet, inferenceEnvRemove };\n}\n\n// ======================== Stage 3: Assemble ================================\n\nexport function assemblePayload(\n  request: ExecRequest,\n  token: TokenResult,\n  resolution: PersonaResolution,\n): AssembledPayload {\n  // Build env map: API key + credential env + inference overrides\n  const env: Record<string, string> = {\n    ANTHROPIC_API_KEY: token.claudeToken,\n    ...resolution.credentialEnv,\n    ...resolution.inferenceEnvSet,\n  };\n\n  // Remove inference-specified keys\n  for (const k of resolution.inferenceEnvRemove) {\n    delete env[k];\n  }\n\n  // Build prompt\n  let prompt: string;\n  if (resolution.persona) {\n    const inputData = request.inputData ? (request.inputData as Record<string, unknown>) : undefined;\n    prompt = assemblePrompt(\n      resolution.persona,\n      resolution.tools,\n      inputData,\n      resolution.credentialHints.length > 0 ? resolution.credentialHints : undefined,\n    );\n  } else {\n    prompt = request.prompt;\n  }\n\n  // Resolve network policy\n  let networkPolicy: NetworkPolicy | undefined;\n  if (resolution.persona?.networkPolicy) {\n    networkPolicy = parseNetworkPolicy(resolution.persona.networkPolicy) ?? undefined;\n  }\n\n  return {\n    prompt,\n    env,\n    networkPolicy,\n    maxBudgetUsd: resolution.persona?.maxBudgetUsd ?? null,\n    maxTurns: resolution.persona?.maxTurns ?? null,\n  };\n}\n\n// =================== Stage 4: Build assignment =============================\n\nexport function buildAssignment(\n  request: ExecRequest,\n  payload: AssembledPayload,\n): ExecAssign {\n  return {\n    type: 'assign',\n    executionId: request.executionId,\n    personaId: request.personaId,\n    prompt: payload.prompt,\n    env: payload.env,\n    config: {\n      timeoutMs: request.config.timeoutMs || 300_000,\n      maxOutputBytes: 10 * 1024 * 1024,\n      ...(payload.networkPolicy ? { networkPolicy: payload.networkPolicy } : {}),\n      ...(payload.maxBudgetUsd ? { maxBudgetUsd: payload.maxBudgetUsd } : {}),\n      ...(payload.maxTurns ? { maxTurns: payload.maxTurns } : {}),\n    },\n  };\n}\n\n// ============== ExecutionPreparer — stages 2-4 composed ====================\n\n/** Resolves a DB handle for a given project/tenant ID. */\nexport type DbResolver = (projectId?: string) => Database.Database | null;\n\n/**\n * Composes persona resolution, payload assembly, and assignment building\n * into a single prepare() call. Token acquisition and the actual send\n * remain in the Dispatcher.\n */\nexport class ExecutionPreparer {\n  constructor(\n    private resolveDb: DbResolver,\n    private decryptor: Decryptor,\n    private logger: Logger,\n  ) {}\n\n  /**\n   * Prepare an ExecAssign from a request and a pre-resolved token.\n   * Pure enrichment — no side effects beyond DB reads and decryption.\n   */\n  async prepare(request: ExecRequest, token: TokenResult): Promise<ExecAssign> {\n    const tenantId = request.projectId || 'default';\n    const dispatchDb = this.resolveDb(tenantId);\n\n    const resolution = await resolvePersona(\n      dispatchDb,\n      request.personaId,\n      tenantId,\n      this.decryptor,\n      this.logger,\n    );\n\n    const payload = assemblePayload(request, token, resolution);\n    return buildAssignment(request, payload);\n  }\n}\n","numLines":267,"startLine":1,"totalLines":267}}}
[2026-03-18T17:56:58.043Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AMXpgNdpZgdLW9JUcMs9xK","type":"tool_result","content":"     1→import { type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type PhaseTimings, type EncryptedPayload, TOPICS, decrypt, DecryptionError, deriveMasterKeyAsync } from '@dac-cloud/shared';\n     2→import type Database from 'better-sqlite3';\n     3→import type { WorkerPool } from './workerPool.js';\n     4→import type { TokenManager } from './tokenManager.js';\n     5→import type { OAuthManager } from './oauth.js';\n     6→import type { KafkaClient } from './kafka.js';\n     7→import type { TenantDbManager } from './tenantDbManager.js';\n     8→import type { TenantKeyManager } from './tenantKeyManager.js';\n     9→import type { AuditLog } from './auditLog.js';\n    10→import type { Logger } from 'pino';\n    11→import * as db from './db/index.js';\n    12→import { resolveToken, ExecutionPreparer, type Decryptor } from './dispatchPipeline.js';\n    13→\n    14→interface QueuedExecution {\n    15→  request: ExecRequest;\n    16→  receivedAt: number;\n    17→}\n    18→\n    19→// Maximum number of times an execution will be re-queued after worker disconnect\n    20→const MAX_DISCONNECT_RETRIES = 2;\n    21→\n    22→/** All valid execution statuses. */\n    23→type ExecutionStatus = 'queued' | 'running' | 'completed' | 'failed' | 'cancelled';\n    24→\n    25→/** What triggered a state transition. */\n    26→type TransitionTrigger =\n    27→  | 'submit'\n    28→  | 'dispatch'\n    29→  | 'complete'\n    30→  | 'busy-nack'\n    31→  | 'disconnect-retry'\n    32→  | 'disconnect-exhausted'\n    33→  | 'assign-failure';\n    34→\n    35→// In-memory tracking for active executions (real-time output streaming)\n    36→interface ActiveExecution {\n    37→  workerId: string;\n    38→  startedAt: number;\n    39→  output: string[];\n    40→  status: 'running' | 'completed' | 'failed' | 'cancelled';\n    41→  progress?: ProgressInfo;\n    42→  completedAt?: number;\n    43→  exitCode?: number;\n    44→  durationMs?: number;\n    45→  sessionId?: string;\n    46→  totalCostUsd?: number;\n    47→  phaseTimings?: PhaseTimings;\n    48→  /** Original request kept for re-queuing on worker disconnect. Only present for in-flight executions. */\n    49→  request?: ExecRequest;\n    50→  /** How many times this execution has been re-queued after a worker disconnect. */\n    51→  disconnectRetries?: number;\n    52→}\n    53→\n    54→const OUTPUT_FLUSH_INTERVAL_MS = 500;\n    55→\n    56→export class Dispatcher {\n    57→  private queue: QueuedExecution[] = [];\n    58→  // In-memory map for real-time output + cancel routing (active executions only)\n    59→  private active = new Map<string, ActiveExecution>();\n    60→  private tenantDbManager: TenantDbManager | null = null;\n    61→  private masterKey: Buffer | null = null;\n    62→  private tenantKeyManager: TenantKeyManager | null = null;\n    63→  private auditLog: AuditLog | null = null;\n    64→  private preparer: ExecutionPreparer | null = null;\n    65→  // Maps executionId → projectId for DB resolution during callbacks\n    66→  private executionTenant = new Map<string, string>();\n    67→  // Batched output buffers: executionId → pending chunks\n    68→  private outputBuffers = new Map<string, string[]>();\n    69→  private outputFlushTimer: NodeJS.Timeout;\n    70→  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n    71→  private dispatching = false;\n    72→\n    73→  constructor(\n    74→    private pool: WorkerPool,\n    75→    private tokenManager: TokenManager,\n    76→    private oauth: OAuthManager | null,\n    77→    private kafka: KafkaClient,\n    78→    private logger: Logger,\n    79→  ) {\n    80→    // Periodic flush of batched output to DB\n    81→    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n    82→\n    83→    // When a worker becomes ready, try to dispatch queued work\n    84→    this.pool.on('worker-ready', () => {\n    85→      this.processQueue();\n    86→    });\n    87→\n    88→    // When a worker connects, try to dispatch\n    89→    this.pool.on('worker-connected', () => {\n    90→      this.processQueue();\n    91→    });\n    92→\n    93→    // Track stdout for execution output\n    94→    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n    95→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    96→    });\n    97→\n    98→    // Track stderr for debugging failed executions\n    99→    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n   100→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n   101→      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n   102→    });\n   103→\n   104→    // Handle execution completion\n   105→    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n   106→      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   107→        executionId: msg.executionId,\n   108→        status: msg.status,\n   109→        exitCode: msg.exitCode,\n   110→        durationMs: msg.durationMs,\n   111→        sessionId: msg.sessionId,\n   112→        totalCostUsd: msg.totalCostUsd,\n   113→        ...(msg.phaseTimings ? { phaseTimings: msg.phaseTimings } : {}),\n   114→      }), msg.executionId).catch(err => {\n   115→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n   116→      });\n   117→\n   118→      // Flush any remaining buffered output before persisting completion\n   119→      this.flushOutputForExecution(msg.executionId);\n   120→\n   121→      // Update in-memory\n   122→      const exec = this.active.get(msg.executionId);\n   123→      const terminalStatus: ExecutionStatus = msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed';\n   124→      this.logTransition({\n   125→        executionId: msg.executionId,\n   126→        previousState: 'running',\n   127→        newState: terminalStatus,\n   128→        trigger: 'complete',\n   129→        workerId: exec?.workerId,\n   130→        disconnectRetries: exec?.disconnectRetries ?? 0,\n   131→      });\n   132→      if (exec) {\n   133→        exec.status = msg.status;\n   134→        exec.completedAt = Date.now();\n   135→        exec.exitCode = msg.exitCode;\n   136→        exec.durationMs = msg.durationMs;\n   137→        exec.sessionId = msg.sessionId;\n   138→        exec.totalCostUsd = msg.totalCostUsd;\n   139→        exec.phaseTimings = msg.phaseTimings;\n   140→        // Remove from active after a short delay (allow polling to pick up final state)\n   141→        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n   142→      }\n   143→\n   144→      // Persist to DB\n   145→      const completeDb = this.resolveDbForExecution(msg.executionId);\n   146→      if (completeDb) {\n   147→        try {\n   148→          db.updateExecution(completeDb, msg.executionId, {\n   149→            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n   150→            completedAt: new Date().toISOString(),\n   151→            durationMs: msg.durationMs,\n   152→            claudeSessionId: msg.sessionId,\n   153→            costUsd: msg.totalCostUsd ?? 0,\n   154→          });\n   155→        } catch (err) {\n   156→          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n   157→        }\n   158→      }\n   159→\n   160→      // Clean up tenant mapping after completion delay\n   161→      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n   162→\n   163→      // Process next queued item\n   164→      this.processQueue();\n   165→    });\n   166→\n   167→    // Track execution progress\n   168→    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n   169→      const exec = this.active.get(msg.executionId);\n   170→      if (exec) {\n   171→        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n   172→      }\n   173→      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n   174→        executionId: msg.executionId,\n   175→        phase: msg.phase,\n   176→        percent: msg.percent,\n   177→        detail: msg.detail,\n   178→        timestamp: msg.timestamp,\n   179→      }), msg.executionId).catch(err => {\n   180→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n   181→      });\n   182→    });\n   183→\n   184→    // Forward persona events to Kafka\n   185→    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n   186→      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n   187→        executionId: msg.executionId,\n   188→        eventType: msg.eventType,\n   189→        payload: msg.payload,\n   190→        timestamp: Date.now(),\n   191→      }), msg.executionId).catch(err => {\n   192→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n   193→      });\n   194→    });\n   195→\n   196→    // Handle worker busy nack — re-queue the rejected execution\n   197→    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n   198→      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n   199→      const exec = this.active.get(msg.executionId);\n   200→      if (exec?.request) {\n   201→        const request = exec.request;\n   202→        this.logTransition({\n   203→          executionId: msg.executionId,\n   204→          previousState: 'running',\n   205→          newState: 'queued',\n   206→          trigger: 'busy-nack',\n   207→          workerId: _workerId,\n   208→          personaId: request.personaId,\n   209→          disconnectRetries: exec.disconnectRetries ?? 0,\n   210→        });\n   211→        this.active.delete(msg.executionId);\n   212→        // Mark as queued in DB\n   213→        const reqDb = this.resolveDbForExecution(msg.executionId);\n   214→        if (reqDb) {\n   215→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack'); }\n   216→        }\n   217→        this.queue.unshift({ request, receivedAt: Date.now() });\n   218→        this.processQueue();\n   219→      } else {\n   220→        // Fallback: reconstruct from DB if request was not stored (should not happen)\n   221→        this.logTransition({\n   222→          executionId: msg.executionId,\n   223→          previousState: 'running',\n   224→          newState: 'queued',\n   225→          trigger: 'busy-nack',\n   226→          workerId: _workerId,\n   227→        });\n   228→        this.active.delete(msg.executionId);\n   229→        const projectId = this.executionTenant.get(msg.executionId) || 'default';\n   230→        const reqDb = this.resolveDb(projectId);\n   231→        if (reqDb) {\n   232→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack fallback'); }\n   233→        }\n   234→        const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n   235→        if (dbExec) {\n   236→          this.queue.unshift({\n   237→            request: {\n   238→              executionId: msg.executionId,\n   239→              personaId: dbExec.personaId,\n   240→              prompt: dbExec.inputData || '',\n   241→              projectId,\n   242→              config: { timeoutMs: 300_000 },\n   243→            },\n   244→            receivedAt: Date.now(),\n   245→          });\n   246→          this.processQueue();\n   247→        }\n   248→      }\n   249→    });\n   250→\n   251→    // Handle worker disconnect during execution — re-queue if retries remain\n   252→    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n   253→      if (executionId) {\n   254→        const exec = this.active.get(executionId);\n   255→        const retries = exec?.disconnectRetries ?? 0;\n   256→\n   257→        if (exec?.request && retries < MAX_DISCONNECT_RETRIES) {\n   258→          // Re-queue for retry\n   259→          const nextRetry = retries + 1;\n   260→          this.logTransition({\n   261→            executionId,\n   262→            previousState: 'running',\n   263→            newState: 'queued',\n   264→            trigger: 'disconnect-retry',\n   265→            workerId: _workerId,\n   266→            personaId: exec.request.personaId,\n   267→            disconnectRetries: nextRetry,\n   268→            errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n   269→          });\n   270→\n   271→          // Clear the active entry so dispatchToWorker can create a fresh one\n   272→          this.active.delete(executionId);\n   273→\n   274→          // Mark as queued in DB\n   275→          const disconnDb = this.resolveDbForExecution(executionId);\n   276→          if (disconnDb) {\n   277→            try {\n   278→              db.updateExecution(disconnDb, executionId, {\n   279→                status: 'queued',\n   280→                errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n   281→              });\n   282→            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on worker disconnect re-queue'); }\n   283→          }\n   284→\n   285→          // Temporarily store the retry count so dispatchToWorker picks it up\n   286→          const request = exec.request;\n   287→          // Create a placeholder active entry to carry retry count across re-dispatch\n   288→          this.active.set(executionId, {\n   289→            workerId: '',\n   290→            startedAt: 0,\n   291→            output: [],\n   292→            status: 'running',\n   293→            request,\n   294→            disconnectRetries: nextRetry,\n   295→          });\n   296→\n   297→          this.queue.unshift({ request, receivedAt: Date.now() });\n   298→          this.processQueue();\n   299→        } else {\n   300→          // Retries exhausted or no request stored — permanent failure\n   301→          this.logTransition({\n   302→            executionId,\n   303→            previousState: 'running',\n   304→            newState: 'failed',\n   305→            trigger: 'disconnect-exhausted',\n   306→            workerId: _workerId,\n   307→            disconnectRetries: retries,\n   308→            errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n   309→          });\n   310→          if (exec) {\n   311→            exec.status = 'failed';\n   312→            exec.completedAt = Date.now();\n   313→            setTimeout(() => this.active.delete(executionId), 30_000);\n   314→          }\n   315→\n   316→          const disconnDb = this.resolveDbForExecution(executionId);\n   317→          if (disconnDb) {\n   318→            try {\n   319→              db.updateExecution(disconnDb, executionId, {\n   320→                status: 'failed',\n   321→                errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n   322→                completedAt: new Date().toISOString(),\n   323→              });\n   324→            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:failed' }, 'Failed to persist execution failure on worker disconnect'); }\n   325→          }\n   326→          this.executionTenant.delete(executionId);\n   327→\n   328→          this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   329→            executionId,\n   330→            status: 'failed',\n   331→            error: 'Worker disconnected (retries exhausted)',\n   332→            durationMs: 0,\n   333→          }), executionId).catch(err => { this.logger.warn({ err, executionId, op: 'kafka:exec_lifecycle' }, 'Failed to produce disconnect failure lifecycle to Kafka'); });\n   334→        }\n   335→      }\n   336→    });\n   337→  }\n   338→\n   339→  setTenantDbManager(mgr: TenantDbManager): void {\n   340→    this.tenantDbManager = mgr;\n   341→  }\n   342→\n   343→  async setMasterKey(masterKeyHex: string): Promise<void> {\n   344→    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n   345→  }\n   346→\n   347→  setTenantKeyManager(mgr: TenantKeyManager): void {\n   348→    this.tenantKeyManager = mgr;\n   349→  }\n   350→\n   351→  setAuditLog(log: AuditLog): void {\n   352→    this.auditLog = log;\n   353→  }\n   354→\n   355→  /** Resolve the database for a given projectId via tenant DB manager. */\n   356→  private resolveDb(projectId?: string): Database.Database | null {\n   357→    if (this.tenantDbManager && projectId) {\n   358→      return this.tenantDbManager.getTenantDb(projectId);\n   359→    }\n   360→    return null;\n   361→  }\n   362→\n   363→  /** Resolve the database for an in-flight execution by its ID. */\n   364→  private resolveDbForExecution(executionId: string): Database.Database | null {\n   365→    const projectId = this.executionTenant.get(executionId);\n   366→    return this.resolveDb(projectId);\n   367→  }\n   368→\n   369→  /**\n   370→   * Emit a single structured log entry for every execution state transition.\n   371→   * Creates a queryable timeline: grep for \"Execution state transition\" to see\n   372→   * the full lifecycle of any execution.\n   373→   */\n   374→  private logTransition(opts: {\n   375→    executionId: string;\n   376→    previousState: ExecutionStatus | null;\n   377→    newState: ExecutionStatus;\n   378→    trigger: TransitionTrigger;\n   379→    workerId?: string;\n   380→    personaId?: string;\n   381→    queueWaitMs?: number;\n   382→    disconnectRetries?: number;\n   383→    errorMessage?: string;\n   384→  }): void {\n   385→    this.logger.info({\n   386→      executionId: opts.executionId,\n   387→      previousState: opts.previousState,\n   388→      newState: opts.newState,\n   389→      trigger: opts.trigger,\n   390→      ...(opts.workerId ? { workerId: opts.workerId } : {}),\n   391→      ...(opts.personaId ? { personaId: opts.personaId } : {}),\n   392→      ...(opts.queueWaitMs !== undefined ? { queueWaitMs: opts.queueWaitMs } : {}),\n   393→      ...(opts.disconnectRetries !== undefined ? { disconnectRetries: opts.disconnectRetries } : {}),\n   394→      ...(opts.errorMessage ? { errorMessage: opts.errorMessage } : {}),\n   395→    }, 'Execution state transition');\n   396→  }\n   397→\n   398→  /**\n   399→   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   400→   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   401→   */\n   402→  private async decryptWithAudit(\n   403→    payload: EncryptedPayload,\n   404→    tenantId: string,\n   405→    resourceId: string,\n   406→    logContext: Record<string, unknown>,\n   407→    logMessage: string,\n   408→  ): Promise<string | undefined> {\n   409→    const decryptKey = this.tenantKeyManager\n   410→      ? await this.tenantKeyManager.getKey(tenantId)\n   411→      : this.masterKey;\n   412→    if (!decryptKey) return undefined;\n   413→\n   414→    try {\n   415→      const decrypted = decrypt(payload, decryptKey, { tenantId, credentialId: resourceId, resourceType: 'credential' });\n   416→      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n   417→      return decrypted;\n   418→    } catch (err) {\n   419→      const reason = err instanceof DecryptionError ? err.message : (err instanceof Error ? err.message : String(err));\n   420→      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n   421→      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: { reason } }); } catch { /* logged inside record() */ }\n   422→      return undefined;\n   423→    }\n   424→  }\n   425→\n   426→  submit(request: ExecRequest): void {\n   427→    this.logger.info({\n   428→      executionId: request.executionId,\n   429→      personaId: request.personaId,\n   430→      ...(request.eventId ? { eventId: request.eventId } : {}),\n   431→    }, 'Execution submitted');\n   432→\n   433→    // Track which tenant owns this execution (for callback DB resolution)\n   434→    const projectId = request.projectId || 'default';\n   435→    this.executionTenant.set(request.executionId, projectId);\n   436→\n   437→    // Create DB record immediately\n   438→    const submitDb = this.resolveDb(projectId);\n   439→    if (submitDb) {\n   440→      try {\n   441→        db.createExecution(submitDb, {\n   442→          id: request.executionId,\n   443→          personaId: request.personaId,\n   444→          inputData: request.prompt,\n   445→          projectId,\n   446→          eventId: request.eventId ?? null,\n   447→        });\n   448→      } catch (err) {\n   449→        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n   450→      }\n   451→    }\n   452→\n   453→    this.logTransition({\n   454→      executionId: request.executionId,\n   455→      previousState: null,\n   456→      newState: 'queued',\n   457→      trigger: 'submit',\n   458→      personaId: request.personaId,\n   459→      disconnectRetries: 0,\n   460→    });\n   461→\n   462→    this.queue.push({ request, receivedAt: Date.now() });\n   463→    this.processQueue();\n   464→  }\n   465→\n   466→  private async processQueue(): Promise<void> {\n   467→    // Guard: only one processQueue loop runs at a time to prevent concurrent\n   468→    // calls from racing on getIdleWorker()/assign() and double-claiming a worker.\n   469→    if (this.dispatching) return;\n   470→    this.dispatching = true;\n   471→    try {\n   472→      while (this.queue.length > 0) {\n   473→        const workerId = this.pool.getIdleWorker();\n   474→        if (!workerId) {\n   475→          this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n   476→          return;\n   477→        }\n   478→\n   479→        const item = this.queue.shift()!;\n   480→        await this.dispatchToWorker(workerId, item.request, item.receivedAt);\n   481→      }\n   482→    } finally {\n   483→      this.dispatching = false;\n   484→    }\n   485→  }\n   486→\n   487→  /** Exposes decryptWithAudit as the Decryptor interface for pipeline stages. */\n   488→  private getDecryptor(): Decryptor {\n   489→    return {\n   490→      decrypt: (payload, tenantId, resourceId, logContext, logMessage) =>\n   491→        this.decryptWithAudit(payload, tenantId, resourceId, logContext, logMessage),\n   492→    };\n   493→  }\n   494→\n   495→  /** Lazily initialise the ExecutionPreparer (depends on mutable setter state). */\n   496→  private ensurePreparer(): ExecutionPreparer {\n   497→    if (!this.preparer) {\n   498→      this.preparer = new ExecutionPreparer(\n   499→        (projectId) => this.resolveDb(projectId),\n   500→        this.getDecryptor(),\n   501→        this.logger,\n   502→      );\n   503→    }\n   504→    return this.preparer;\n   505→  }\n   506→\n   507→  private async dispatchToWorker(workerId: string, request: ExecRequest, queuedAt?: number): Promise<void> {\n   508→    // Stage 1: Resolve token (stays in Dispatcher)\n   509→    const token = await resolveToken(this.oauth, this.tokenManager);\n   510→    if (!token) {\n   511→      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n   512→      this.queue.unshift({ request, receivedAt: Date.now() });\n   513→      return;\n   514→    }\n   515→\n   516→    // Stages 2-4: Persona resolution, payload assembly, assignment building\n   517→    const assignment = await this.ensurePreparer().prepare(request, token);\n   518→    const tenantId = request.projectId || 'default';\n   519→    const dispatchDb = this.resolveDb(tenantId);\n   520→\n   521→    // Track in-memory for real-time streaming (preserve retry count across re-dispatches)\n   522→    const prevRetries = this.active.get(request.executionId)?.disconnectRetries ?? 0;\n   523→    this.active.set(request.executionId, {\n   524→      workerId,\n   525→      startedAt: Date.now(),\n   526→      output: [],\n   527→      status: 'running',\n   528→      request,\n   529→      disconnectRetries: prevRetries,\n   530→    });\n   531→\n   532→    // Mark running in DB\n   533→    if (dispatchDb) {\n   534→      try {\n   535→        db.updateExecution(dispatchDb, request.executionId, {\n   536→          status: 'running',\n   537→          startedAt: new Date().toISOString(),\n   538→        });\n   539→      } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:running' }, 'Failed to mark execution as running in DB'); }\n   540→    }\n   541→\n   542→    const sent = this.pool.assign(workerId, assignment);\n   543→    if (!sent) {\n   544→      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n   545→      this.active.delete(request.executionId);\n   546→      if (dispatchDb) {\n   547→        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:queued' }, 'Failed to re-queue execution in DB after assign failure'); }\n   548→      }\n   549→      this.logTransition({\n   550→        executionId: request.executionId,\n   551→        previousState: 'running',\n   552→        newState: 'queued',\n   553→        trigger: 'assign-failure',\n   554→        workerId,\n   555→        personaId: request.personaId,\n   556→        disconnectRetries: prevRetries,\n   557→      });\n   558→      this.queue.unshift({ request, receivedAt: Date.now() });\n   559→      this.processQueue();\n   560→    } else {\n   561→      const queueWaitMs = queuedAt !== undefined ? Date.now() - queuedAt : undefined;\n   562→      this.logTransition({\n   563→        executionId: request.executionId,\n   564→        previousState: 'queued',\n   565→        newState: 'running',\n   566→        trigger: 'dispatch',\n   567→        workerId,\n   568→        personaId: request.personaId,\n   569→        queueWaitMs,\n   570→        disconnectRetries: prevRetries,\n   571→      });\n   572→    }\n   573→  }\n   574→\n   575→  cancelExecution(executionId: string): boolean {\n   576→    const exec = this.active.get(executionId);\n   577→    if (!exec || exec.status !== 'running') return false;\n   578→\n   579→    return this.pool.send(exec.workerId, {\n   580→      type: 'cancel',\n   581→      executionId,\n   582→    });\n   583→  }\n   584→\n   585→  getQueueLength(): number {\n   586→    return this.queue.length;\n   587→  }\n   588→\n   589→  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n   590→    return Array.from(this.active.entries())\n   591→      .filter(([, e]) => e.status === 'running')\n   592→      .map(([executionId, e]) => ({\n   593→        executionId,\n   594→        workerId: e.workerId,\n   595→        startedAt: e.startedAt,\n   596→      }));\n   597→  }\n   598→\n   599→  /**\n   600→   * Get execution state. Tries in-memory first (for real-time output),\n   601→   * then falls back to DB for completed/historical executions.\n   602→   */\n   603→  getExecution(executionId: string): ActiveExecution | null {\n   604→    // Check in-memory active executions first\n   605→    const active = this.active.get(executionId);\n   606→    if (active) return active;\n   607→\n   608→    const execDb = this.resolveDbForExecution(executionId);\n   609→    if (execDb) {\n   610→      const dbExec = db.getExecution(execDb, executionId);\n   611→      if (dbExec) {\n   612→        return {\n   613→          workerId: '',\n   614→          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n   615→          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n   616→          status: dbExec.status as ActiveExecution['status'],\n   617→          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n   618→          durationMs: dbExec.durationMs ?? undefined,\n   619→          sessionId: dbExec.claudeSessionId ?? undefined,\n   620→          totalCostUsd: dbExec.costUsd ?? undefined,\n   621→        };\n   622→      }\n   623→    }\n   624→\n   625→    return null;\n   626→  }\n   627→\n   628→  getExecutionOutput(executionId: string): string[] | null {\n   629→    const exec = this.getExecution(executionId);\n   630→    return exec?.output ?? null;\n   631→  }\n   632→\n   633→  /** Shared handler for stdout/stderr output chunks. */\n   634→  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n   635→    const line = prefix ? `${prefix}${chunk}` : chunk;\n   636→\n   637→    const exec = this.active.get(executionId);\n   638→    if (exec) {\n   639→      exec.output.push(line);\n   640→    }\n   641→\n   642→    this.bufferOutput(executionId, line + '\\n');\n   643→\n   644→    // Forward stdout to Kafka (stderr is not forwarded)\n   645→    if (!prefix) {\n   646→      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n   647→        executionId,\n   648→        chunk,\n   649→        timestamp,\n   650→      }), executionId).catch(err => {\n   651→        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n   652→      });\n   653→    }\n   654→  }\n   655→\n   656→  /** Buffer an output chunk for batched DB write. */\n   657→  private bufferOutput(executionId: string, chunk: string): void {\n   658→    let buf = this.outputBuffers.get(executionId);\n   659→    if (!buf) {\n   660→      buf = [];\n   661→      this.outputBuffers.set(executionId, buf);\n   662→    }\n   663→    buf.push(chunk);\n   664→  }\n   665→\n   666→  /** Flush buffered output for a specific execution to DB. */\n   667→  private flushOutputForExecution(executionId: string): void {\n   668→    const buf = this.outputBuffers.get(executionId);\n   669→    if (!buf || buf.length === 0) return;\n   670→\n   671→    const combined = buf.join('');\n   672→    this.outputBuffers.delete(executionId);\n   673→\n   674→    const outputDb = this.resolveDbForExecution(executionId);\n   675→    if (outputDb) {\n   676→      try { db.appendOutput(outputDb, executionId, combined); } catch (err) { this.logger.warn({ err, executionId, op: 'appendOutput' }, 'Failed to flush buffered output to DB'); }\n   677→    }\n   678→  }\n   679→\n   680→  /** Flush all buffered output across all executions to DB. */\n   681→  private flushOutputBuffers(): void {\n   682→    for (const executionId of this.outputBuffers.keys()) {\n   683→      this.flushOutputForExecution(executionId);\n   684→    }\n   685→  }\n   686→\n   687→  shutdown(): void {\n   688→    clearInterval(this.outputFlushTimer);\n   689→    this.flushOutputBuffers();\n   690→  }\n   691→}\n   692→"}]},"parent_tool_use_id":null,"session_id":"22e752af-3acf-42d7-8b18-b18301d6aa7c","uuid":"60e9d290-81b6-4bb5-8668-ada46cb3ab11","timestamp":"2026-03-18T17:56:57.957Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\dispatcher.ts","content":"import { type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type PhaseTimings, type EncryptedPayload, TOPICS, decrypt, DecryptionError, deriveMasterKeyAsync } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { resolveToken, ExecutionPreparer, type Decryptor } from './dispatchPipeline.js';\n\ninterface QueuedExecution {\n  request: ExecRequest;\n  receivedAt: number;\n}\n\n// Maximum number of times an execution will be re-queued after worker disconnect\nconst MAX_DISCONNECT_RETRIES = 2;\n\n/** All valid execution statuses. */\ntype ExecutionStatus = 'queued' | 'running' | 'completed' | 'failed' | 'cancelled';\n\n/** What triggered a state transition. */\ntype TransitionTrigger =\n  | 'submit'\n  | 'dispatch'\n  | 'complete'\n  | 'busy-nack'\n  | 'disconnect-retry'\n  | 'disconnect-exhausted'\n  | 'assign-failure';\n\n// In-memory tracking for active executions (real-time output streaming)\ninterface ActiveExecution {\n  workerId: string;\n  startedAt: number;\n  output: string[];\n  status: 'running' | 'completed' | 'failed' | 'cancelled';\n  progress?: ProgressInfo;\n  completedAt?: number;\n  exitCode?: number;\n  durationMs?: number;\n  sessionId?: string;\n  totalCostUsd?: number;\n  phaseTimings?: PhaseTimings;\n  /** Original request kept for re-queuing on worker disconnect. Only present for in-flight executions. */\n  request?: ExecRequest;\n  /** How many times this execution has been re-queued after a worker disconnect. */\n  disconnectRetries?: number;\n}\n\nconst OUTPUT_FLUSH_INTERVAL_MS = 500;\n\nexport class Dispatcher {\n  private queue: QueuedExecution[] = [];\n  // In-memory map for real-time output + cancel routing (active executions only)\n  private active = new Map<string, ActiveExecution>();\n  private tenantDbManager: TenantDbManager | null = null;\n  private masterKey: Buffer | null = null;\n  private tenantKeyManager: TenantKeyManager | null = null;\n  private auditLog: AuditLog | null = null;\n  private preparer: ExecutionPreparer | null = null;\n  // Maps executionId → projectId for DB resolution during callbacks\n  private executionTenant = new Map<string, string>();\n  // Batched output buffers: executionId → pending chunks\n  private outputBuffers = new Map<string, string[]>();\n  private outputFlushTimer: NodeJS.Timeout;\n  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n  private dispatching = false;\n\n  constructor(\n    private pool: WorkerPool,\n    private tokenManager: TokenManager,\n    private oauth: OAuthManager | null,\n    private kafka: KafkaClient,\n    private logger: Logger,\n  ) {\n    // Periodic flush of batched output to DB\n    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n\n    // When a worker becomes ready, try to dispatch queued work\n    this.pool.on('worker-ready', () => {\n      this.processQueue();\n    });\n\n    // When a worker connects, try to dispatch\n    this.pool.on('worker-connected', () => {\n      this.processQueue();\n    });\n\n    // Track stdout for execution output\n    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    });\n\n    // Track stderr for debugging failed executions\n    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    });\n\n    // Handle execution completion\n    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n        executionId: msg.executionId,\n        status: msg.status,\n        exitCode: msg.exitCode,\n        durationMs: msg.durationMs,\n        sessionId: msg.sessionId,\n        totalCostUsd: msg.totalCostUsd,\n        ...(msg.phaseTimings ? { phaseTimings: msg.phaseTimings } : {}),\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n      });\n\n      // Flush any remaining buffered output before persisting completion\n      this.flushOutputForExecution(msg.executionId);\n\n      // Update in-memory\n      const exec = this.active.get(msg.executionId);\n      const terminalStatus: ExecutionStatus = msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed';\n      this.logTransition({\n        executionId: msg.executionId,\n        previousState: 'running',\n        newState: terminalStatus,\n        trigger: 'complete',\n        workerId: exec?.workerId,\n        disconnectRetries: exec?.disconnectRetries ?? 0,\n      });\n      if (exec) {\n        exec.status = msg.status;\n        exec.completedAt = Date.now();\n        exec.exitCode = msg.exitCode;\n        exec.durationMs = msg.durationMs;\n        exec.sessionId = msg.sessionId;\n        exec.totalCostUsd = msg.totalCostUsd;\n        exec.phaseTimings = msg.phaseTimings;\n        // Remove from active after a short delay (allow polling to pick up final state)\n        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n      }\n\n      // Persist to DB\n      const completeDb = this.resolveDbForExecution(msg.executionId);\n      if (completeDb) {\n        try {\n          db.updateExecution(completeDb, msg.executionId, {\n            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n            completedAt: new Date().toISOString(),\n            durationMs: msg.durationMs,\n            claudeSessionId: msg.sessionId,\n            costUsd: msg.totalCostUsd ?? 0,\n          });\n        } catch (err) {\n          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n        }\n      }\n\n      // Clean up tenant mapping after completion delay\n      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n\n      // Process next queued item\n      this.processQueue();\n    });\n\n    // Track execution progress\n    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n      }\n      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n        executionId: msg.executionId,\n        phase: msg.phase,\n        percent: msg.percent,\n        detail: msg.detail,\n        timestamp: msg.timestamp,\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n      });\n    });\n\n    // Forward persona events to Kafka\n    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n        executionId: msg.executionId,\n        eventType: msg.eventType,\n        payload: msg.payload,\n        timestamp: Date.now(),\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n      });\n    });\n\n    // Handle worker busy nack — re-queue the rejected execution\n    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n      const exec = this.active.get(msg.executionId);\n      if (exec?.request) {\n        const request = exec.request;\n        this.logTransition({\n          executionId: msg.executionId,\n          previousState: 'running',\n          newState: 'queued',\n          trigger: 'busy-nack',\n          workerId: _workerId,\n          personaId: request.personaId,\n          disconnectRetries: exec.disconnectRetries ?? 0,\n        });\n        this.active.delete(msg.executionId);\n        // Mark as queued in DB\n        const reqDb = this.resolveDbForExecution(msg.executionId);\n        if (reqDb) {\n          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack'); }\n        }\n        this.queue.unshift({ request, receivedAt: Date.now() });\n        this.processQueue();\n      } else {\n        // Fallback: reconstruct from DB if request was not stored (should not happen)\n        this.logTransition({\n          executionId: msg.executionId,\n          previousState: 'running',\n          newState: 'queued',\n          trigger: 'busy-nack',\n          workerId: _workerId,\n        });\n        this.active.delete(msg.executionId);\n        const projectId = this.executionTenant.get(msg.executionId) || 'default';\n        const reqDb = this.resolveDb(projectId);\n        if (reqDb) {\n          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack fallback'); }\n        }\n        const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n        if (dbExec) {\n          this.queue.unshift({\n            request: {\n              executionId: msg.executionId,\n              personaId: dbExec.personaId,\n              prompt: dbExec.inputData || '',\n              projectId,\n              config: { timeoutMs: 300_000 },\n            },\n            receivedAt: Date.now(),\n          });\n          this.processQueue();\n        }\n      }\n    });\n\n    // Handle worker disconnect during execution — re-queue if retries remain\n    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n      if (executionId) {\n        const exec = this.active.get(executionId);\n        const retries = exec?.disconnectRetries ?? 0;\n\n        if (exec?.request && retries < MAX_DISCONNECT_RETRIES) {\n          // Re-queue for retry\n          const nextRetry = retries + 1;\n          this.logTransition({\n            executionId,\n            previousState: 'running',\n            newState: 'queued',\n            trigger: 'disconnect-retry',\n            workerId: _workerId,\n            personaId: exec.request.personaId,\n            disconnectRetries: nextRetry,\n            errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n          });\n\n          // Clear the active entry so dispatchToWorker can create a fresh one\n          this.active.delete(executionId);\n\n          // Mark as queued in DB\n          const disconnDb = this.resolveDbForExecution(executionId);\n          if (disconnDb) {\n            try {\n              db.updateExecution(disconnDb, executionId, {\n                status: 'queued',\n                errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n              });\n            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on worker disconnect re-queue'); }\n          }\n\n          // Temporarily store the retry count so dispatchToWorker picks it up\n          const request = exec.request;\n          // Create a placeholder active entry to carry retry count across re-dispatch\n          this.active.set(executionId, {\n            workerId: '',\n            startedAt: 0,\n            output: [],\n            status: 'running',\n            request,\n            disconnectRetries: nextRetry,\n          });\n\n          this.queue.unshift({ request, receivedAt: Date.now() });\n          this.processQueue();\n        } else {\n          // Retries exhausted or no request stored — permanent failure\n          this.logTransition({\n            executionId,\n            previousState: 'running',\n            newState: 'failed',\n            trigger: 'disconnect-exhausted',\n            workerId: _workerId,\n            disconnectRetries: retries,\n            errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n          });\n          if (exec) {\n            exec.status = 'failed';\n            exec.completedAt = Date.now();\n            setTimeout(() => this.active.delete(executionId), 30_000);\n          }\n\n          const disconnDb = this.resolveDbForExecution(executionId);\n          if (disconnDb) {\n            try {\n              db.updateExecution(disconnDb, executionId, {\n                status: 'failed',\n                errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n                completedAt: new Date().toISOString(),\n              });\n            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:failed' }, 'Failed to persist execution failure on worker disconnect'); }\n          }\n          this.executionTenant.delete(executionId);\n\n          this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n            executionId,\n            status: 'failed',\n            error: 'Worker disconnected (retries exhausted)',\n            durationMs: 0,\n          }), executionId).catch(err => { this.logger.warn({ err, executionId, op: 'kafka:exec_lifecycle' }, 'Failed to produce disconnect failure lifecycle to Kafka'); });\n        }\n      }\n    });\n  }\n\n  setTenantDbManager(mgr: TenantDbManager): void {\n    this.tenantDbManager = mgr;\n  }\n\n  async setMasterKey(masterKeyHex: string): Promise<void> {\n    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n  }\n\n  setTenantKeyManager(mgr: TenantKeyManager): void {\n    this.tenantKeyManager = mgr;\n  }\n\n  setAuditLog(log: AuditLog): void {\n    this.auditLog = log;\n  }\n\n  /** Resolve the database for a given projectId via tenant DB manager. */\n  private resolveDb(projectId?: string): Database.Database | null {\n    if (this.tenantDbManager && projectId) {\n      return this.tenantDbManager.getTenantDb(projectId);\n    }\n    return null;\n  }\n\n  /** Resolve the database for an in-flight execution by its ID. */\n  private resolveDbForExecution(executionId: string): Database.Database | null {\n    const projectId = this.executionTenant.get(executionId);\n    return this.resolveDb(projectId);\n  }\n\n  /**\n   * Emit a single structured log entry for every execution state transition.\n   * Creates a queryable timeline: grep for \"Execution state transition\" to see\n   * the full lifecycle of any execution.\n   */\n  private logTransition(opts: {\n    executionId: string;\n    previousState: ExecutionStatus | null;\n    newState: ExecutionStatus;\n    trigger: TransitionTrigger;\n    workerId?: string;\n    personaId?: string;\n    queueWaitMs?: number;\n    disconnectRetries?: number;\n    errorMessage?: string;\n  }): void {\n    this.logger.info({\n      executionId: opts.executionId,\n      previousState: opts.previousState,\n      newState: opts.newState,\n      trigger: opts.trigger,\n      ...(opts.workerId ? { workerId: opts.workerId } : {}),\n      ...(opts.personaId ? { personaId: opts.personaId } : {}),\n      ...(opts.queueWaitMs !== undefined ? { queueWaitMs: opts.queueWaitMs } : {}),\n      ...(opts.disconnectRetries !== undefined ? { disconnectRetries: opts.disconnectRetries } : {}),\n      ...(opts.errorMessage ? { errorMessage: opts.errorMessage } : {}),\n    }, 'Execution state transition');\n  }\n\n  /**\n   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   */\n  private async decryptWithAudit(\n    payload: EncryptedPayload,\n    tenantId: string,\n    resourceId: string,\n    logContext: Record<string, unknown>,\n    logMessage: string,\n  ): Promise<string | undefined> {\n    const decryptKey = this.tenantKeyManager\n      ? await this.tenantKeyManager.getKey(tenantId)\n      : this.masterKey;\n    if (!decryptKey) return undefined;\n\n    try {\n      const decrypted = decrypt(payload, decryptKey, { tenantId, credentialId: resourceId, resourceType: 'credential' });\n      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n      return decrypted;\n    } catch (err) {\n      const reason = err instanceof DecryptionError ? err.message : (err instanceof Error ? err.message : String(err));\n      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: { reason } }); } catch { /* logged inside record() */ }\n      return undefined;\n    }\n  }\n\n  submit(request: ExecRequest): void {\n    this.logger.info({\n      executionId: request.executionId,\n      personaId: request.personaId,\n      ...(request.eventId ? { eventId: request.eventId } : {}),\n    }, 'Execution submitted');\n\n    // Track which tenant owns this execution (for callback DB resolution)\n    const projectId = request.projectId || 'default';\n    this.executionTenant.set(request.executionId, projectId);\n\n    // Create DB record immediately\n    const submitDb = this.resolveDb(projectId);\n    if (submitDb) {\n      try {\n        db.createExecution(submitDb, {\n          id: request.executionId,\n          personaId: request.personaId,\n          inputData: request.prompt,\n          projectId,\n          eventId: request.eventId ?? null,\n        });\n      } catch (err) {\n        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n      }\n    }\n\n    this.logTransition({\n      executionId: request.executionId,\n      previousState: null,\n      newState: 'queued',\n      trigger: 'submit',\n      personaId: request.personaId,\n      disconnectRetries: 0,\n    });\n\n    this.queue.push({ request, receivedAt: Date.now() });\n    this.processQueue();\n  }\n\n  private async processQueue(): Promise<void> {\n    // Guard: only one processQueue loop runs at a time to prevent concurrent\n    // calls from racing on getIdleWorker()/assign() and double-claiming a worker.\n    if (this.dispatching) return;\n    this.dispatching = true;\n    try {\n      while (this.queue.length > 0) {\n        const workerId = this.pool.getIdleWorker();\n        if (!workerId) {\n          this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n          return;\n        }\n\n        const item = this.queue.shift()!;\n        await this.dispatchToWorker(workerId, item.request, item.receivedAt);\n      }\n    } finally {\n      this.dispatching = false;\n    }\n  }\n\n  /** Exposes decryptWithAudit as the Decryptor interface for pipeline stages. */\n  private getDecryptor(): Decryptor {\n    return {\n      decrypt: (payload, tenantId, resourceId, logContext, logMessage) =>\n        this.decryptWithAudit(payload, tenantId, resourceId, logContext, logMessage),\n    };\n  }\n\n  /** Lazily initialise the ExecutionPreparer (depends on mutable setter state). */\n  private ensurePreparer(): ExecutionPreparer {\n    if (!this.preparer) {\n      this.preparer = new ExecutionPreparer(\n        (projectId) => this.resolveDb(projectId),\n        this.getDecryptor(),\n        this.logger,\n      );\n    }\n    return this.preparer;\n  }\n\n  private async dispatchToWorker(workerId: string, request: ExecRequest, queuedAt?: number): Promise<void> {\n    // Stage 1: Resolve token (stays in Dispatcher)\n    const token = await resolveToken(this.oauth, this.tokenManager);\n    if (!token) {\n      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      return;\n    }\n\n    // Stages 2-4: Persona resolution, payload assembly, assignment building\n    const assignment = await this.ensurePreparer().prepare(request, token);\n    const tenantId = request.projectId || 'default';\n    const dispatchDb = this.resolveDb(tenantId);\n\n    // Track in-memory for real-time streaming (preserve retry count across re-dispatches)\n    const prevRetries = this.active.get(request.executionId)?.disconnectRetries ?? 0;\n    this.active.set(request.executionId, {\n      workerId,\n      startedAt: Date.now(),\n      output: [],\n      status: 'running',\n      request,\n      disconnectRetries: prevRetries,\n    });\n\n    // Mark running in DB\n    if (dispatchDb) {\n      try {\n        db.updateExecution(dispatchDb, request.executionId, {\n          status: 'running',\n          startedAt: new Date().toISOString(),\n        });\n      } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:running' }, 'Failed to mark execution as running in DB'); }\n    }\n\n    const sent = this.pool.assign(workerId, assignment);\n    if (!sent) {\n      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n      this.active.delete(request.executionId);\n      if (dispatchDb) {\n        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:queued' }, 'Failed to re-queue execution in DB after assign failure'); }\n      }\n      this.logTransition({\n        executionId: request.executionId,\n        previousState: 'running',\n        newState: 'queued',\n        trigger: 'assign-failure',\n        workerId,\n        personaId: request.personaId,\n        disconnectRetries: prevRetries,\n      });\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      this.processQueue();\n    } else {\n      const queueWaitMs = queuedAt !== undefined ? Date.now() - queuedAt : undefined;\n      this.logTransition({\n        executionId: request.executionId,\n        previousState: 'queued',\n        newState: 'running',\n        trigger: 'dispatch',\n        workerId,\n        personaId: request.personaId,\n        queueWaitMs,\n        disconnectRetries: prevRetries,\n      });\n    }\n  }\n\n  cancelExecution(executionId: string): boolean {\n    const exec = this.active.get(executionId);\n    if (!exec || exec.status !== 'running') return false;\n\n    return this.pool.send(exec.workerId, {\n      type: 'cancel',\n      executionId,\n    });\n  }\n\n  getQueueLength(): number {\n    return this.queue.length;\n  }\n\n  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n    return Array.from(this.active.entries())\n      .filter(([, e]) => e.status === 'running')\n      .map(([executionId, e]) => ({\n        executionId,\n        workerId: e.workerId,\n        startedAt: e.startedAt,\n      }));\n  }\n\n  /**\n   * Get execution state. Tries in-memory first (for real-time output),\n   * then falls back to DB for completed/historical executions.\n   */\n  getExecution(executionId: string): ActiveExecution | null {\n    // Check in-memory active executions first\n    const active = this.active.get(executionId);\n    if (active) return active;\n\n    const execDb = this.resolveDbForExecution(executionId);\n    if (execDb) {\n      const dbExec = db.getExecution(execDb, executionId);\n      if (dbExec) {\n        return {\n          workerId: '',\n          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n          status: dbExec.status as ActiveExecution['status'],\n          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n          durationMs: dbExec.durationMs ?? undefined,\n          sessionId: dbExec.claudeSessionId ?? undefined,\n          totalCostUsd: dbExec.costUsd ?? undefined,\n        };\n      }\n    }\n\n    return null;\n  }\n\n  getExecutionOutput(executionId: string): string[] | null {\n    const exec = this.getExecution(executionId);\n    return exec?.output ?? null;\n  }\n\n  /** Shared handler for stdout/stderr output chunks. */\n  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n    const line = prefix ? `${prefix}${chunk}` : chunk;\n\n    const exec = this.active.get(executionId);\n    if (exec) {\n      exec.output.push(line);\n    }\n\n    this.bufferOutput(executionId, line + '\\n');\n\n    // Forward stdout to Kafka (stderr is not forwarded)\n    if (!prefix) {\n      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n        executionId,\n        chunk,\n        timestamp,\n      }), executionId).catch(err => {\n        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n      });\n    }\n  }\n\n  /** Buffer an output chunk for batched DB write. */\n  private bufferOutput(executionId: string, chunk: string): void {\n    let buf = this.outputBuffers.get(executionId);\n    if (!buf) {\n      buf = [];\n      this.outputBuffers.set(executionId, buf);\n    }\n    buf.push(chunk);\n  }\n\n  /** Flush buffered output for a specific execution to DB. */\n  private flushOutputForExecution(executionId: string): void {\n    const buf = this.outputBuffers.get(executionId);\n    if (!buf || buf.length === 0) return;\n\n    const combined = buf.join('');\n    this.outputBuffers.delete(executionId);\n\n    const outputDb = this.resolveDbForExecution(executionId);\n    if (outputDb) {\n      try { db.appendOutput(outputDb, executionId, combined); } catch (err) { this.logger.warn({ err, executionId, op: 'appendOutput' }, 'Failed to flush buffered output to DB'); }\n    }\n  }\n\n  /** Flush all buffered output across all executions to DB. */\n  private flushOutputBuffers(): void {\n    for (const executionId of this.outputBuffers.keys()) {\n      this.flushOutputForExecution(executionId);\n    }\n  }\n\n  shutdown(): void {\n    clearInterval(this.outputFlushTimer);\n    this.flushOutputBuffers();\n  }\n}\n","numLines":692,"startLine":1,"totalLines":692}}}
