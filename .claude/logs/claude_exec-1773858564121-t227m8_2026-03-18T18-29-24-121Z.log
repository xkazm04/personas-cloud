→    cause: unknown,\n    50→  ) {\n    51→    super(`Audit write failed for action \"${entry.action}\"`);\n    52→    this.name = 'AuditWriteError';\n    53→    this.cause = cause;\n    54→  }\n    55→}\n    56→\n    57→// ---------------------------------------------------------------------------\n    58→// Discriminated-union audit entries — each action carries its own typed payload\n    59→// ---------------------------------------------------------------------------\n    60→\n    61→/** Fields common to every audit entry. */\n    62→interface AuditEntryBase {\n    63→  tenantId?: string;\n    64→  actor?: string;\n    65→  ipAddress?: string;\n    66→}\n    67→\n    68→// --- Key management ---\n    69→interface KeyEncryptEntry extends AuditEntryBase {\n    70→  action: 'key:encrypt';\n    71→  resourceType: 'credential';\n    72→  resourceId: string;\n    73→}\n    74→\n    75→interface KeyDecryptEntry extends AuditEntryBase {\n    76→  action: 'key:decrypt';\n    77→  resourceType: 'credential';\n    78→  resourceId: string;\n    79→}\n    80→\n    81→interface KeyDecryptFailedEntry extends AuditEntryBase {\n    82→  action: 'key:decrypt_failed';\n    83→  resourceType: 'credential';\n    84→  resourceId: string;\n    85→  detail: { reason: string };\n    86→}\n    87→\n    88→interface KeyDeleteEntry extends AuditEntryBase {\n    89→  action: 'key:delete';\n    90→  resourceType: 'credential';\n    91→  resourceId: string;\n    92→}\n    93→\n    94→interface KeyAccessEntry extends AuditEntryBase {\n    95→  action: 'key:access';\n    96→  resourceType: 'credential';\n    97→  resourceId: string;\n    98→}\n    99→\n   100→interface KeyDeriveEntry extends AuditEntryBase {\n   101→  action: 'key:derive';\n   102→}\n   103→\n   104→// --- Persona management ---\n   105→interface PersonaCreateEntry extends AuditEntryBase {\n   106→  action: 'persona:create';\n   107→  resourceType: 'persona';\n   108→  resourceId: string;\n   109→}\n   110→\n   111→interface PersonaDeleteEntry extends AuditEntryBase {\n   112→  action: 'persona:delete';\n   113→  resourceType: 'persona';\n   114→  resourceId: string;\n   115→}\n   116→\n   117→// --- Tool management ---\n   118→interface ToolLinkEntry extends AuditEntryBase {\n   119→  action: 'tool:link';\n   120→  resourceType: 'persona';\n   121→  resourceId: string;\n   122→  detail: { toolId: string };\n   123→}\n   124→\n   125→interface ToolDefinitionCreateEntry extends AuditEntryBase {\n   126→  action: 'tool-definition:create';\n   127→  resourceType: 'toolDefinition';\n   128→  resourceId: string;\n   129→}\n   130→\n   131→// --- Credential linking ---\n   132→interface CredentialLinkEntry extends AuditEntryBase {\n   133→  action: 'credential:link';\n   134→  resourceType: 'persona';\n   135→  resourceId: string;\n   136→  detail: { credentialId: string };\n   137→}\n   138→\n   139→// --- Subscriptions ---\n   140→interface SubscriptionCreateEntry extends AuditEntryBase {\n   141→  action: 'subscription:create';\n   142→  resourceType: 'subscription';\n   143→  resourceId: string;\n   144→  detail: { personaId: string; eventType: string };\n   145→}\n   146→\n   147→interface SubscriptionUpdateEntry extends AuditEntryBase {\n   148→  action: 'subscription:update';\n   149→  resourceType: 'subscription';\n   150→  resourceId: string;\n   151→}\n   152→\n   153→interface SubscriptionDeleteEntry extends AuditEntryBase {\n   154→  action: 'subscription:delete';\n   155→  resourceType: 'subscription';\n   156→  resourceId: string;\n   157→}\n   158→\n   159→// --- Worker pool ---\n   160→interface WorkerConnectedEntry extends AuditEntryBase {\n   161→  action: 'worker:connected';\n   162→  detail: { workerId: string };\n   163→}\n   164→\n   165→interface WorkerDisconnectedEntry extends AuditEntryBase {\n   166→  action: 'worker:disconnected';\n   167→  detail: { workerId: string };\n   168→  resourceId?: string;\n   169→}\n   170→\n   171→// --- Triggers ---\n   172→interface TriggerCreateEntry extends AuditEntryBase {\n   173→  action: 'trigger:create';\n   174→  resourceType: 'trigger';\n   175→  resourceId?: string;\n   176→}\n   177→\n   178→interface TriggerUpdateEntry extends AuditEntryBase {\n   179→  action: 'trigger:update';\n   180→  resourceType: 'trigger';\n   181→  resourceId: string;\n   182→}\n   183→\n   184→interface TriggerDeleteEntry extends AuditEntryBase {\n   185→  action: 'trigger:delete';\n   186→  resourceType: 'trigger';\n   187→  resourceId: string;\n   188→}\n   189→\n   190→// --- Events ---\n   191→interface EventPublishEntry extends AuditEntryBase {\n   192→  action: 'event:publish';\n   193→  resourceType: 'event';\n   194→  resourceId?: string;\n   195→}\n   196→\n   197→interface EventUpdateEntry extends AuditEntryBase {\n   198→  action: 'event:update';\n   199→  resourceType: 'event';\n   200→  resourceId: string;\n   201→}\n   202→\n   203→// --- Executions ---\n   204→interface ExecutionSubmitEntry extends AuditEntryBase {\n   205→  action: 'execution:submit';\n   206→  resourceType: 'execution';\n   207→  resourceId?: string;\n   208→}\n   209→\n   210→// --- Webhooks ---\n   211→interface WebhookReceiveEntry extends AuditEntryBase {\n   212→  action: 'webhook:receive';\n   213→  resourceType: 'webhook';\n   214→  resourceId: string;\n   215→}\n   216→\n   217→/** Discriminated union of all audit event types. */\n   218→export type AuditEntry =\n   219→  | KeyEncryptEntry\n   220→  | KeyDecryptEntry\n   221→  | KeyDecryptFailedEntry\n   222→  | KeyDeleteEntry\n   223→  | KeyAccessEntry\n   224→  | KeyDeriveEntry\n   225→  | PersonaCreateEntry\n   226→  | PersonaDeleteEntry\n   227→  | ToolLinkEntry\n   228→  | ToolDefinitionCreateEntry\n   229→  | CredentialLinkEntry\n   230→  | SubscriptionCreateEntry\n   231→  | SubscriptionUpdateEntry\n   232→  | SubscriptionDeleteEntry\n   233→  | WorkerConnectedEntry\n   234→  | WorkerDisconnectedEntry\n   235→  | TriggerCreateEntry\n   236→  | TriggerUpdateEntry\n   237→  | TriggerDeleteEntry\n   238→  | EventPublishEntry\n   239→  | EventUpdateEntry\n   240→  | ExecutionSubmitEntry\n   241→  | WebhookReceiveEntry;\n   242→\n   243→/** String-literal union of all valid audit actions. */\n   244→export type AuditAction = AuditEntry['action'];\n   245→\n   246→/** Row shape returned by audit_events queries. */\n   247→export interface AuditEvent {\n   248→  id: number;\n   249→  timestamp: string;\n   250→  action: string;\n   251→  tenant_id: string | null;\n   252→  actor: string | null;\n   253→  resource_type: string | null;\n   254→  resource_id: string | null;\n   255→  detail: string | null;\n   256→  ip_address: string | null;\n   257→  prev_hash: string | null;\n   258→}\n   259→\n   260→/** Result of verifying the audit hash chain. */\n   261→export interface ChainVerifyResult {\n   262→  valid: boolean;\n   263→  verifiedCount: number;\n   264→  brokenAtId?: number;\n   265→}\n   266→\n   267→/** Max entries buffered before an automatic flush. */\n   268→const BUFFER_FLUSH_SIZE = 50;\n   269→/** Interval (ms) between timer-based flushes. */\n   270→const BUFFER_FLUSH_INTERVAL_MS = 100;\n   271→\n   272→interface BufferedEntry {\n   273→  timestamp: string;\n   274→  action: string;\n   275→  tenantId: string | null;\n   276→  actor: string | null;\n   277→  resourceType: string | null;\n   278→  resourceId: string | null;\n   279→  detail: string | null;\n   280→  ipAddress: string | null;\n   281→}\n   282→\n   283→export class AuditLog {\n   284→  private db: Database.Database;\n   285→  private insertStmt: Database.Statement;\n   286→  private queryStmtCache = new Map<string, Database.Statement>();\n   287→  private buffer: BufferedEntry[] = [];\n   288→  private flushTimer: NodeJS.Timeout | null = null;\n   289→  private batchInsert: (entries: BufferedEntry[], hashes: string[]) => void;\n   290→  private lastHash: string;\n   291→\n   292→  constructor(\n   293→    dbPath: string,\n   294→    private logger: Logger,\n   295→  ) {\n   296→    this.db = new Database(dbPath);\n   297→    this.db.pragma('journal_mode = WAL');\n   298→    this.db.exec(AUDIT_SCHEMA);\n   299→\n   300→    // Migration: add prev_hash column to existing databases that lack it\n   301→    const cols = this.db.pragma('table_info(audit_events)') as { name: string }[];\n   302→    if (!cols.some((c) => c.name === 'prev_hash')) {\n   303→      this.db.exec('ALTER TABLE audit_events ADD COLUMN prev_hash TEXT');\n   304→    }\n   305→\n   306→    this.insertStmt = this.db.prepare(\n   307→      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address, prev_hash) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',\n   308→    );\n   309→\n   310→    // Initialize chain from last stored hash (or genesis for empty / pre-chain DBs)\n   311→    const lastRow = this.db.prepare(\n   312→      'SELECT prev_hash FROM audit_events WHERE prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n   313→    ).get() as { prev_hash: string } | undefined;\n   314→    this.lastHash = lastRow?.prev_hash ?? GENESIS_HASH;\n   315→\n   316→    // Wrap N inserts in a single transaction — one fsync instead of N\n   317→    const stmt = this.insertStmt;\n   318→    this.batchInsert = this.db.transaction((entries: BufferedEntry[], hashes: string[]) => {\n   319→      for (let i = 0; i < entries.length; i++) {\n   320→        const e = entries[i];\n   321→        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress, hashes[i]);\n   322→      }\n   323→    });\n   324→\n   325→    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n   326→\n   327→    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled, hash-chain active)');\n   328→  }\n   329→\n   330→  /** Expose the underlying database for use by RetentionPolicy. */\n   331→  getDb(): Database.Database {\n   332→    return this.db;\n   333→  }\n   334→\n   335→  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n   336→  countEvents(before?: string): number {\n   337→    const stmt = before\n   338→      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n   339→      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n   340→    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n   341→    return row.cnt;\n   342→  }\n   343→\n   344→  /**\n   345→   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   346→   * yielding the event loop between batches so concurrent DB operations\n   347→   * are not starved during large purges.\n   348→   */\n   349→  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n   350→    const deleteChunk = this.db.prepare(\n   351→      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n   352→    );\n   353→    let totalDeleted = 0;\n   354→    while (true) {\n   355→      const result = deleteChunk.run(cutoff, chunkSize);\n   356→      totalDeleted += result.changes;\n   357→      if (result.changes < chunkSize) break;\n   358→      await new Promise<void>((resolve) => setImmediate(resolve));\n   359→    }\n   360→    return totalDeleted;\n   361→  }\n   362→\n   363→  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n   364→  record(entry: AuditEntry): void {\n   365→    this.buffer.push({\n   366→      timestamp: new Date().toISOString(),\n   367→      action: entry.action,\n   368→      tenantId: entry.tenantId ?? null,\n   369→      actor: entry.actor ?? null,\n   370→      resourceType: 'resourceType' in entry ? entry.resourceType : null,\n   371→      resourceId: 'resourceId' in entry ? (entry.resourceId ?? null) : null,\n   372→      detail: 'detail' in entry ? JSON.stringify(entry.detail) : null,\n   373→      ipAddress: entry.ipAddress ?? null,\n   374→    });\n   375→    if (this.buffer.length >= BUFFER_FLUSH_SIZE) {\n   376→      this.flush();\n   377→    }\n   378→  }\n   379→\n   380→  /** Flush buffered entries to SQLite in a single transaction, computing chain hashes. */\n   381→  flush(): void {\n   382→    if (this.buffer.length === 0) return;\n   383→    const batch = this.buffer;\n   384→    this.buffer = [];\n   385→\n   386→    // Compute chain hashes for the batch\n   387→    const hashes: string[] = [];\n   388→    let prevHash = this.lastHash;\n   389→    for (const entry of batch) {\n   390→      prevHash = computeChainHash(prevHash, entry);\n   391→      hashes.push(prevHash);\n   392→    }\n   393→\n   394→    try {\n   395→      this.batchInsert(batch, hashes);\n   396→      this.lastHash = prevHash;\n   397→    } catch (err) {\n   398→      this.logger.error({ err, count: batch.length }, 'Audit batch write failed — audit trail gap');\n   399→    }\n   400→  }\n   401→\n   402→  /** Query audit events with optional filters. */\n   403→  query(opts?: {\n   404→    tenantId?: string;\n   405→    action?: AuditAction;\n   406→    since?: string;\n   407→    limit?: number;\n   408→    offset?: number;\n   409→  }): AuditEvent[] {\n   410→    const params: unknown[] = [];\n   411→    const clauses: string[] = [];\n   412→    const keyParts: string[] = [];\n   413→\n   414→    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n   415→    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n   416→    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n   417→\n   418→    const key = keyParts.join('-') || 'none';\n   419→    let stmt = this.queryStmtCache.get(key);\n   420→    if (!stmt) {\n   421→      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   422→      stmt = this.db.prepare(\n   423→        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n   424→      );\n   425→      this.queryStmtCache.set(key, stmt);\n   426→    }\n   427→\n   428→    const limit = opts?.limit ?? 100;\n   429→    const offset = opts?.offset ?? 0;\n   430→\n   431→    return stmt.all(...params, limit, offset) as AuditEvent[];\n   432→  }\n   433→\n   434→  /**\n   435→   * Verify the integrity of the audit hash chain.\n   436→   * Iterates all chained rows and checks that each hash is consistent with\n   437→   * its predecessor. Pre-chain rows (migrated without prev_hash) are skipped.\n   438→   * If rows were purged, the chain will break at the first remaining row\n   439→   * — this is by design (deletions are detectable).\n   440→   */\n   441→  verify(): ChainVerifyResult {\n   442→    this.flush(); // ensure all buffered entries are persisted\n   443→    const iter = this.db.prepare('SELECT * FROM audit_events ORDER BY id ASC').iterate();\n   444→\n   445→    let prevHash = GENESIS_HASH;\n   446→    let verifiedCount = 0;\n   447→\n   448→    for (const raw of iter) {\n   449→      const row = raw as AuditEvent;\n   450→      if (row.prev_hash === null) continue; // pre-chain row\n   451→\n   452→      const expected = computeChainHash(prevHash, {\n   453→        timestamp: row.timestamp,\n   454→        action: row.action,\n   455→        tenantId: row.tenant_id,\n   456→        actor: row.actor,\n   457→        resourceType: row.resource_type,\n   458→        resourceId: row.resource_id,\n   459→        detail: row.detail,\n   460→        ipAddress: row.ip_address,\n   461→      });\n   462→\n   463→      if (row.prev_hash !== expected) {\n   464→        return { valid: false, verifiedCount, brokenAtId: row.id };\n   465→      }\n   466→\n   467→      prevHash = row.prev_hash;\n   468→      verifiedCount++;\n   469→    }\n   470→\n   471→    return { valid: true, verifiedCount };\n   472→  }\n   473→\n   474→  close(): void {\n   475→    if (this.flushTimer) {\n   476→      clearInterval(this.flushTimer);\n   477→      this.flushTimer = null;\n   478→    }\n   479→    this.flush();\n   480→    try { this.db.close(); } catch { /* best effort */ }\n   481→  }\n   482→}\n   483→"}]},"parent_tool_use_id":null,"session_id":"2a8eabc1-ce20-4af0-9b5d-da3936e3656a","uuid":"674a79d7-5f4a-42fe-83e6-60a581c801af","timestamp":"2026-03-18T18:31:12.007Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\auditLog.ts","content":"import crypto from 'node:crypto';\nimport Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\n\n/** SHA-256 hash chain genesis value (64 hex zeros). */\nconst GENESIS_HASH = '0'.repeat(64);\n\n/**\n * Compute a chain hash: SHA-256(previousHash + deterministic JSON of entry fields).\n * Each entry's hash commits to the entire chain history before it.\n */\nfunction computeChainHash(prevHash: string, entry: BufferedEntry): string {\n  const payload = prevHash + JSON.stringify([\n    entry.timestamp,\n    entry.action,\n    entry.tenantId,\n    entry.actor,\n    entry.resourceType,\n    entry.resourceId,\n    entry.detail,\n    entry.ipAddress,\n  ]);\n  return crypto.createHash('sha256').update(payload).digest('hex');\n}\n\nconst AUDIT_SCHEMA = `\nCREATE TABLE IF NOT EXISTS audit_events (\n  id INTEGER PRIMARY KEY AUTOINCREMENT,\n  timestamp TEXT NOT NULL,\n  action TEXT NOT NULL,\n  tenant_id TEXT,\n  actor TEXT,\n  resource_type TEXT,\n  resource_id TEXT,\n  detail TEXT,\n  ip_address TEXT,\n  prev_hash TEXT\n);\nCREATE INDEX IF NOT EXISTS idx_audit_ts ON audit_events(timestamp);\nCREATE INDEX IF NOT EXISTS idx_audit_tenant_action_ts ON audit_events(tenant_id, action, timestamp);\nDROP INDEX IF EXISTS idx_audit_tenant_ts;\nDROP INDEX IF EXISTS idx_audit_action;\n`;\n\n/** Thrown when an audit event fails to persist — signals an audit trail gap. */\nexport class AuditWriteError extends Error {\n  constructor(\n    public readonly entry: AuditEntry,\n    cause: unknown,\n  ) {\n    super(`Audit write failed for action \"${entry.action}\"`);\n    this.name = 'AuditWriteError';\n    this.cause = cause;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Discriminated-union audit entries — each action carries its own typed payload\n// ---------------------------------------------------------------------------\n\n/** Fields common to every audit entry. */\ninterface AuditEntryBase {\n  tenantId?: string;\n  actor?: string;\n  ipAddress?: string;\n}\n\n// --- Key management ---\ninterface KeyEncryptEntry extends AuditEntryBase {\n  action: 'key:encrypt';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyDecryptEntry extends AuditEntryBase {\n  action: 'key:decrypt';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyDecryptFailedEntry extends AuditEntryBase {\n  action: 'key:decrypt_failed';\n  resourceType: 'credential';\n  resourceId: string;\n  detail: { reason: string };\n}\n\ninterface KeyDeleteEntry extends AuditEntryBase {\n  action: 'key:delete';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyAccessEntry extends AuditEntryBase {\n  action: 'key:access';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyDeriveEntry extends AuditEntryBase {\n  action: 'key:derive';\n}\n\n// --- Persona management ---\ninterface PersonaCreateEntry extends AuditEntryBase {\n  action: 'persona:create';\n  resourceType: 'persona';\n  resourceId: string;\n}\n\ninterface PersonaDeleteEntry extends AuditEntryBase {\n  action: 'persona:delete';\n  resourceType: 'persona';\n  resourceId: string;\n}\n\n// --- Tool management ---\ninterface ToolLinkEntry extends AuditEntryBase {\n  action: 'tool:link';\n  resourceType: 'persona';\n  resourceId: string;\n  detail: { toolId: string };\n}\n\ninterface ToolDefinitionCreateEntry extends AuditEntryBase {\n  action: 'tool-definition:create';\n  resourceType: 'toolDefinition';\n  resourceId: string;\n}\n\n// --- Credential linking ---\ninterface CredentialLinkEntry extends AuditEntryBase {\n  action: 'credential:link';\n  resourceType: 'persona';\n  resourceId: string;\n  detail: { credentialId: string };\n}\n\n// --- Subscriptions ---\ninterface SubscriptionCreateEntry extends AuditEntryBase {\n  action: 'subscription:create';\n  resourceType: 'subscription';\n  resourceId: string;\n  detail: { personaId: string; eventType: string };\n}\n\ninterface SubscriptionUpdateEntry extends AuditEntryBase {\n  action: 'subscription:update';\n  resourceType: 'subscription';\n  resourceId: string;\n}\n\ninterface SubscriptionDeleteEntry extends AuditEntryBase {\n  action: 'subscription:delete';\n  resourceType: 'subscription';\n  resourceId: string;\n}\n\n// --- Worker pool ---\ninterface WorkerConnectedEntry extends AuditEntryBase {\n  action: 'worker:connected';\n  detail: { workerId: string };\n}\n\ninterface WorkerDisconnectedEntry extends AuditEntryBase {\n  action: 'worker:disconnected';\n  detail: { workerId: string };\n  resourceId?: string;\n}\n\n// --- Triggers ---\ninterface TriggerCreateEntry extends AuditEntryBase {\n  action: 'trigger:create';\n  resourceType: 'trigger';\n  resourceId?: string;\n}\n\ninterface TriggerUpdateEntry extends AuditEntryBase {\n  action: 'trigger:update';\n  resourceType: 'trigger';\n  resourceId: string;\n}\n\ninterface TriggerDeleteEntry extends AuditEntryBase {\n  action: 'trigger:delete';\n  resourceType: 'trigger';\n  resourceId: string;\n}\n\n// --- Events ---\ninterface EventPublishEntry extends AuditEntryBase {\n  action: 'event:publish';\n  resourceType: 'event';\n  resourceId?: string;\n}\n\ninterface EventUpdateEntry extends AuditEntryBase {\n  action: 'event:update';\n  resourceType: 'event';\n  resourceId: string;\n}\n\n// --- Executions ---\ninterface ExecutionSubmitEntry extends AuditEntryBase {\n  action: 'execution:submit';\n  resourceType: 'execution';\n  resourceId?: string;\n}\n\n// --- Webhooks ---\ninterface WebhookReceiveEntry extends AuditEntryBase {\n  action: 'webhook:receive';\n  resourceType: 'webhook';\n  resourceId: string;\n}\n\n/** Discriminated union of all audit event types. */\nexport type AuditEntry =\n  | KeyEncryptEntry\n  | KeyDecryptEntry\n  | KeyDecryptFailedEntry\n  | KeyDeleteEntry\n  | KeyAccessEntry\n  | KeyDeriveEntry\n  | PersonaCreateEntry\n  | PersonaDeleteEntry\n  | ToolLinkEntry\n  | ToolDefinitionCreateEntry\n  | CredentialLinkEntry\n  | SubscriptionCreateEntry\n  | SubscriptionUpdateEntry\n  | SubscriptionDeleteEntry\n  | WorkerConnectedEntry\n  | WorkerDisconnectedEntry\n  | TriggerCreateEntry\n  | TriggerUpdateEntry\n  | TriggerDeleteEntry\n  | EventPublishEntry\n  | EventUpdateEntry\n  | ExecutionSubmitEntry\n  | WebhookReceiveEntry;\n\n/** String-literal union of all valid audit actions. */\nexport type AuditAction = AuditEntry['action'];\n\n/** Row shape returned by audit_events queries. */\nexport interface AuditEvent {\n  id: number;\n  timestamp: string;\n  action: string;\n  tenant_id: string | null;\n  actor: string | null;\n  resource_type: string | null;\n  resource_id: string | null;\n  detail: string | null;\n  ip_address: string | null;\n  prev_hash: string | null;\n}\n\n/** Result of verifying the audit hash chain. */\nexport interface ChainVerifyResult {\n  valid: boolean;\n  verifiedCount: number;\n  brokenAtId?: number;\n}\n\n/** Max entries buffered before an automatic flush. */\nconst BUFFER_FLUSH_SIZE = 50;\n/** Interval (ms) between timer-based flushes. */\nconst BUFFER_FLUSH_INTERVAL_MS = 100;\n\ninterface BufferedEntry {\n  timestamp: string;\n  action: string;\n  tenantId: string | null;\n  actor: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  detail: string | null;\n  ipAddress: string | null;\n}\n\nexport class AuditLog {\n  private db: Database.Database;\n  private insertStmt: Database.Statement;\n  private queryStmtCache = new Map<string, Database.Statement>();\n  private buffer: BufferedEntry[] = [];\n  private flushTimer: NodeJS.Timeout | null = null;\n  private batchInsert: (entries: BufferedEntry[], hashes: string[]) => void;\n  private lastHash: string;\n\n  constructor(\n    dbPath: string,\n    private logger: Logger,\n  ) {\n    this.db = new Database(dbPath);\n    this.db.pragma('journal_mode = WAL');\n    this.db.exec(AUDIT_SCHEMA);\n\n    // Migration: add prev_hash column to existing databases that lack it\n    const cols = this.db.pragma('table_info(audit_events)') as { name: string }[];\n    if (!cols.some((c) => c.name === 'prev_hash')) {\n      this.db.exec('ALTER TABLE audit_events ADD COLUMN prev_hash TEXT');\n    }\n\n    this.insertStmt = this.db.prepare(\n      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address, prev_hash) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',\n    );\n\n    // Initialize chain from last stored hash (or genesis for empty / pre-chain DBs)\n    const lastRow = this.db.prepare(\n      'SELECT prev_hash FROM audit_events WHERE prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n    ).get() as { prev_hash: string } | undefined;\n    this.lastHash = lastRow?.prev_hash ?? GENESIS_HASH;\n\n    // Wrap N inserts in a single transaction — one fsync instead of N\n    const stmt = this.insertStmt;\n    this.batchInsert = this.db.transaction((entries: BufferedEntry[], hashes: string[]) => {\n      for (let i = 0; i < entries.length; i++) {\n        const e = entries[i];\n        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress, hashes[i]);\n      }\n    });\n\n    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n\n    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled, hash-chain active)');\n  }\n\n  /** Expose the underlying database for use by RetentionPolicy. */\n  getDb(): Database.Database {\n    return this.db;\n  }\n\n  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n  countEvents(before?: string): number {\n    const stmt = before\n      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n    return row.cnt;\n  }\n\n  /**\n   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   * yielding the event loop between batches so concurrent DB operations\n   * are not starved during large purges.\n   */\n  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n    const deleteChunk = this.db.prepare(\n      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n    );\n    let totalDeleted = 0;\n    while (true) {\n      const result = deleteChunk.run(cutoff, chunkSize);\n      totalDeleted += result.changes;\n      if (result.changes < chunkSize) break;\n      await new Promise<void>((resolve) => setImmediate(resolve));\n    }\n    return totalDeleted;\n  }\n\n  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n  record(entry: AuditEntry): void {\n    this.buffer.push({\n      timestamp: new Date().toISOString(),\n      action: entry.action,\n      tenantId: entry.tenantId ?? null,\n      actor: entry.actor ?? null,\n      resourceType: 'resourceType' in entry ? entry.resourceType : null,\n      resourceId: 'resourceId' in entry ? (entry.resourceId ?? null) : null,\n      detail: 'detail' in entry ? JSON.stringify(entry.detail) : null,\n      ipAddress: entry.ipAddress ?? null,\n    });\n    if (this.buffer.length >= BUFFER_FLUSH_SIZE) {\n      this.flush();\n    }\n  }\n\n  /** Flush buffered entries to SQLite in a single transaction, computing chain hashes. */\n  flush(): void {\n    if (this.buffer.length === 0) return;\n    const batch = this.buffer;\n    this.buffer = [];\n\n    // Compute chain hashes for the batch\n    const hashes: string[] = [];\n    let prevHash = this.lastHash;\n    for (const entry of batch) {\n      prevHash = computeChainHash(prevHash, entry);\n      hashes.push(prevHash);\n    }\n\n    try {\n      this.batchInsert(batch, hashes);\n      this.lastHash = prevHash;\n    } catch (err) {\n      this.logger.error({ err, count: batch.length }, 'Audit batch write failed — audit trail gap');\n    }\n  }\n\n  /** Query audit events with optional filters. */\n  query(opts?: {\n    tenantId?: string;\n    action?: AuditAction;\n    since?: string;\n    limit?: number;\n    offset?: number;\n  }): AuditEvent[] {\n    const params: unknown[] = [];\n    const clauses: string[] = [];\n    const keyParts: string[] = [];\n\n    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n\n    const key = keyParts.join('-') || 'none';\n    let stmt = this.queryStmtCache.get(key);\n    if (!stmt) {\n      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n      stmt = this.db.prepare(\n        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n      );\n      this.queryStmtCache.set(key, stmt);\n    }\n\n    const limit = opts?.limit ?? 100;\n    const offset = opts?.offset ?? 0;\n\n    return stmt.all(...params, limit, offset) as AuditEvent[];\n  }\n\n  /**\n   * Verify the integrity of the audit hash chain.\n   * Iterates all chained rows and checks that each hash is consistent with\n   * its predecessor. Pre-chain rows (migrated without prev_hash) are skipped.\n   * If rows were purged, the chain will break at the first remaining row\n   * — this is by design (deletions are detectable).\n   */\n  verify(): ChainVerifyResult {\n    this.flush(); // ensure all buffered entries are persisted\n    const iter = this.db.prepare('SELECT * FROM audit_events ORDER BY id ASC').iterate();\n\n    let prevHash = GENESIS_HASH;\n    let verifiedCount = 0;\n\n    for (const raw of iter) {\n      const row = raw as AuditEvent;\n      if (row.prev_hash === null) continue; // pre-chain row\n\n      const expected = computeChainHash(prevHash, {\n        timestamp: row.timestamp,\n        action: row.action,\n        tenantId: row.tenant_id,\n        actor: row.actor,\n        resourceType: row.resource_type,\n        resourceId: row.resource_id,\n        detail: row.detail,\n        ipAddress: row.ip_address,\n      });\n\n      if (row.prev_hash !== expected) {\n        return { valid: false, verifiedCount, brokenAtId: row.id };\n      }\n\n      prevHash = row.prev_hash;\n      verifiedCount++;\n    }\n\n    return { valid: true, verifiedCount };\n  }\n\n  close(): void {\n    if (this.flushTimer) {\n      clearInterval(this.flushTimer);\n      this.flushTimer = null;\n    }\n    this.flush();\n    try { this.db.close(); } catch { /* best effort */ }\n  }\n}\n","numLines":483,"startLine":1,"totalLines":483}}}
