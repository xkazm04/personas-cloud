[2026-03-18T18:29:53.922Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GS8cKSPQchRagEEUJ4qbYC","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import { nanoid } from 'nanoid';\n     3→import type { PersonaExecution } from '@dac-cloud/shared';\n     4→import { stmt, createRowMapper, buildWhereClause } from './_helpers.js';\n     5→\n     6→// ---------------------------------------------------------------------------\n     7→// Row mapper\n     8→// ---------------------------------------------------------------------------\n     9→\n    10→const rowToExecution = createRowMapper<PersonaExecution>({\n    11→  id: { col: 'id' },\n    12→  projectId: { col: 'project_id', default: 'default' },\n    13→  personaId: { col: 'persona_id' },\n    14→  triggerId: { col: 'trigger_id', nullable: true },\n    15→  useCaseId: { col: 'use_case_id', nullable: true },\n    16→  eventId: { col: 'event_id', nullable: true },\n    17→  status: { col: 'status' },\n    18→  inputData: { col: 'input_data', nullable: true },\n    19→  outputData: { col: 'output_data', nullable: true },\n    20→  claudeSessionId: { col: 'claude_session_id', nullable: true },\n    21→  modelUsed: { col: 'model_used', nullable: true },\n    22→  inputTokens: { col: 'input_tokens', default: 0 },\n    23→  outputTokens: { col: 'output_tokens', default: 0 },\n    24→  costUsd: { col: 'cost_usd', default: 0 },\n    25→  errorMessage: { col: 'error_message', nullable: true },\n    26→  durationMs: { col: 'duration_ms', nullable: true },\n    27→  retryOfExecutionId: { col: 'retry_of_execution_id', nullable: true },\n    28→  retryCount: { col: 'retry_count', default: 0 },\n    29→  startedAt: { col: 'started_at', nullable: true },\n    30→  completedAt: { col: 'completed_at', nullable: true },\n    31→  createdAt: { col: 'created_at' },\n    32→});\n    33→\n    34→// ---------------------------------------------------------------------------\n    35→// CRUD\n    36→// ---------------------------------------------------------------------------\n    37→\n    38→export function createExecution(db: Database.Database, input: {\n    39→  id?: string; personaId: string; triggerId?: string | null; useCaseId?: string | null; eventId?: string | null; inputData?: string | null; projectId?: string;\n    40→}): PersonaExecution {\n    41→  const now = new Date().toISOString();\n    42→  const id = input.id ?? nanoid();\n    43→  const projectId = input.projectId ?? 'default';\n    44→  const triggerId = input.triggerId ?? null;\n    45→  const useCaseId = input.useCaseId ?? null;\n    46→  const eventId = input.eventId ?? null;\n    47→  const inputData = input.inputData ?? null;\n    48→  stmt(db,`\n    49→    INSERT INTO persona_executions (id, project_id, persona_id, trigger_id, use_case_id, event_id, status, input_data, created_at)\n    50→    VALUES (?, ?, ?, ?, ?, ?, 'queued', ?, ?)\n    51→  `).run(id, projectId, input.personaId, triggerId, useCaseId, eventId, inputData, now);\n    52→  return {\n    53→    id,\n    54→    projectId,\n    55→    personaId: input.personaId,\n    56→    triggerId,\n    57→    useCaseId,\n    58→    eventId,\n    59→    status: 'queued',\n    60→    inputData,\n    61→    outputData: null,\n    62→    claudeSessionId: null,\n    63→    modelUsed: null,\n    64→    inputTokens: 0,\n    65→    outputTokens: 0,\n    66→    costUsd: 0,\n    67→    errorMessage: null,\n    68→    durationMs: null,\n    69→    retryOfExecutionId: null,\n    70→    retryCount: 0,\n    71→    startedAt: null,\n    72→    completedAt: null,\n    73→    createdAt: now,\n    74→  };\n    75→}\n    76→\n    77→export function getExecution(db: Database.Database, id: string): PersonaExecution | undefined {\n    78→  const row = stmt(db,'SELECT * FROM persona_executions WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n    79→  return row ? rowToExecution(row) : undefined;\n    80→}\n    81→\n    82→export function listExecutions(db: Database.Database, opts?: {\n    83→  personaId?: string; status?: string; limit?: number; offset?: number; projectId?: string;\n    84→}): PersonaExecution[] {\n    85→  const { sql: where, params } = buildWhereClause(\n    86→    { projectId: opts?.projectId, personaId: opts?.personaId, status: opts?.status },\n    87→    { projectId: 'project_id', personaId: 'persona_id', status: 'status' },\n    88→  );\n    89→  const limit = opts?.limit ?? 50;\n    90→  const offset = opts?.offset ?? 0;\n    91→  const rows = stmt(db,`SELECT * FROM persona_executions ${where} ORDER BY created_at DESC LIMIT ? OFFSET ?`).all(...params, limit, offset) as Record<string, unknown>[];\n    92→  return rows.map(rowToExecution);\n    93→}\n    94→\n    95→const TERMINAL_STATUSES = new Set(['completed', 'failed', 'cancelled']);\n    96→\n    97→export function updateExecution(db: Database.Database, id: string, updates: Record<string, unknown>): void {\n    98→  const fields: string[] = [];\n    99→  const values: unknown[] = [];\n   100→\n   101→  const columnMap: Record<string, string> = {\n   102→    status: 'status',\n   103→    outputData: 'output_data',\n   104→    claudeSessionId: 'claude_session_id',\n   105→    modelUsed: 'model_used',\n   106→    inputTokens: 'input_tokens',\n   107→    outputTokens: 'output_tokens',\n   108→    costUsd: 'cost_usd',\n   109→    errorMessage: 'error_message',\n   110→    durationMs: 'duration_ms',\n   111→    startedAt: 'started_at',\n   112→    completedAt: 'completed_at',\n   113→  };\n   114→\n   115→  for (const [key, col] of Object.entries(columnMap)) {\n   116→    if (key in updates) {\n   117→      fields.push(`${col} = ?`);\n   118→      values.push(updates[key]);\n   119→    }\n   120→  }\n   121→\n   122→  if (fields.length === 0) return;\n   123→\n   124→  const newStatus = updates.status as string | undefined;\n   125→  let shouldRecordMetrics = false;\n   126→  let createdAt: string | undefined;\n   127→\n   128→  // Check if transitioning to a terminal status to avoid double-counting\n   129→  if (newStatus && TERMINAL_STATUSES.has(newStatus)) {\n   130→    const current = stmt(db, 'SELECT status, created_at FROM persona_executions WHERE id = ?').get(id) as\n   131→      { status: string; created_at: string } | undefined;\n   132→    if (current && !TERMINAL_STATUSES.has(current.status)) {\n   133→      shouldRecordMetrics = true;\n   134→      createdAt = current.created_at;\n   135→    }\n   136→  }\n   137→\n   138→  values.push(id);\n   139→  stmt(db,`UPDATE persona_executions SET ${fields.join(', ')} WHERE id = ?`).run(...values);\n   140→\n   141→  // Incrementally update daily_metrics on terminal status transition\n   142→  if (shouldRecordMetrics && createdAt) {\n   143→    const date = createdAt.slice(0, 10); // YYYY-MM-DD\n   144→    const costUsd = (updates.costUsd as number) ?? 0;\n   145→    const durationMs = (updates.durationMs as number) ?? 0;\n   146→    stmt(db, `\n   147→      INSERT INTO daily_metrics (date, total_executions, completed, failed, total_cost_usd, total_duration_ms)\n   148→      VALUES (?, 1, ?, ?, ?, ?)\n   149→      ON CONFLICT(date) DO UPDATE SET\n   150→        total_executions = total_executions + 1,\n   151→        completed = completed + excluded.completed,\n   152→        failed = failed + excluded.failed,\n   153→        total_cost_usd = total_cost_usd + excluded.total_cost_usd,\n   154→        total_duration_ms = total_duration_ms + excluded.total_duration_ms\n   155→    `).run(date, newStatus === 'completed' ? 1 : 0, newStatus === 'failed' ? 1 : 0, costUsd, durationMs);\n   156→  }\n   157→}\n   158→\n   159→export function appendOutput(db: Database.Database, id: string, chunk: string): void {\n   160→  stmt(db,`\n   161→    UPDATE persona_executions SET output_data = COALESCE(output_data, '') || ? WHERE id = ?\n   162→  `).run(chunk, id);\n   163→}\n   164→\n   165→export function countRunningExecutions(db: Database.Database, personaId: string): number {\n   166→  const row = stmt(db,\"SELECT COUNT(*) as cnt FROM persona_executions WHERE persona_id = ? AND status = 'running'\").get(personaId) as { cnt: number };\n   167→  return row.cnt;\n   168→}\n   169→\n   170→/** Batch-count running executions for multiple personas. Returns a Map keyed by persona ID. */\n   171→export function countRunningExecutionsByPersonaIds(db: Database.Database, personaIds: string[]): Map<string, number> {\n   172→  const map = new Map<string, number>();\n   173→  if (personaIds.length === 0) return map;\n   174→  const placeholders = personaIds.map(() => '?').join(',');\n   175→  const rows = db.prepare(\n   176→    `SELECT persona_id, COUNT(*) as cnt FROM persona_executions WHERE persona_id IN (${placeholders}) AND status = 'running' GROUP BY persona_id`\n   177→  ).all(...personaIds) as Array<{ persona_id: string; cnt: number }>;\n   178→  for (const row of rows) {\n   179→    map.set(row.persona_id, row.cnt);\n   180→  }\n   181→  return map;\n   182→}\n   183→"}]},"parent_tool_use_id":"toolu_01CxroRcNq3gPEPrZ489cQLJ","session_id":"2a8eabc1-ce20-4af0-9b5d-da3936e3656a","uuid":"23764652-5c27-414f-9b63-ae5be45c3a43","timestamp":"2026-03-18T18:29:53.843Z"}
