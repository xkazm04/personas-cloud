[2026-03-18T18:30:07.943Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CX9oPZivCQtGbYUpoBjVvk","type":"tool_result","content":"     1→import pino from 'pino';\n     2→import { loadConfig } from './config.js';\n     3→import { createAuth } from './auth.js';\n     4→import { createTokenManager } from './tokenManager.js';\n     5→import { OAuthManager } from './oauth.js';\n     6→import { WorkerPool, type WorkerPoolEvents } from './workerPool.js';\n     7→import { createKafkaClient, createNoopKafkaClient } from './kafka.js';\n     8→import { Dispatcher } from './dispatcher.js';\n     9→import { createHttpApi } from './httpApi.js';\n    10→import { TenantDbManager } from './tenantDbManager.js';\n    11→import { TenantKeyManager, type TenantKeyEvents } from './tenantKeyManager.js';\n    12→import { AuditLog } from './auditLog.js';\n    13→import { AuditPolicy } from './auditPolicy.js';\n    14→import { AuditRetentionPolicy } from './auditRetentionPolicy.js';\n    15→import { startRetentionJob } from './retention.js';\n    16→import { startEventProcessor } from './eventProcessor.js';\n    17→import { startTriggerScheduler } from './triggerScheduler.js';\n    18→import { loadTlsConfig } from './tls.js';\n    19→import { TOPICS, type ExecRequest } from '@dac-cloud/shared';\n    20→\n    21→const logger = pino({ level: process.env['LOG_LEVEL'] || 'info' });\n    22→\n    23→async function main() {\n    24→  logger.info('Starting DAC Cloud Orchestrator...');\n    25→\n    26→  // Load configuration\n    27→  const config = loadConfig();\n    28→  logger.info({\n    29→    kafkaEnabled: config.kafkaEnabled,\n    30→    wsPort: config.wsPort,\n    31→    httpPort: config.httpPort,\n    32→    hasDirectToken: !!config.claudeToken,\n    33→  }, 'Configuration loaded');\n    34→\n    35→  // Initialize components\n    36→  const auth = createAuth(config.teamApiKey, config.supabaseJwtSecret || undefined);\n    37→  const tokenManager = await createTokenManager(config.masterKey, logger);\n    38→  const oauth = new OAuthManager(logger);\n    39→\n    40→  // If a direct Claude token is provided (from setup-token), store it\n    41→  if (config.claudeToken) {\n    42→    tokenManager.storeClaudeToken(config.claudeToken);\n    43→    logger.info('Direct Claude token loaded from environment');\n    44→  } else {\n    45→    logger.info('No direct Claude token — use OAuth flow via POST /api/oauth/authorize');\n    46→  }\n    47→\n    48→  // Tenant-isolated database manager\n    49→  const tenantDbManager = new TenantDbManager(config.dataDir, logger);\n    50→  logger.info({ dataDir: config.dataDir }, 'Tenant DB manager initialized');\n    51→\n    52→  // Worker pool (WebSocket server)\n    53→  const pool = new WorkerPool(config.workerToken, logger, {\n    54→    allowedDigests: config.allowedImageDigests,\n    55→    rejectUnverified: config.rejectUnverifiedWorkers,\n    56→  });\n    57→\n    58→  // Kafka client\n    59→  const kafka = config.kafkaEnabled\n    60→    ? createKafkaClient(config.kafkaBrokers, config.kafkaUsername, config.kafkaPassword, logger)\n    61→    : createNoopKafkaClient(logger);\n    62→\n    63→  // Audit log (separate append-only DB)\n    64→  const auditLog = new AuditLog(config.auditDbPath, logger);\n    65→  const auditRetention = new AuditRetentionPolicy(auditLog, config.auditRetentionDays, logger);\n    66→  auditRetention.startDailyPurge();\n    67→\n    68→  // Per-tenant key manager (cached key derivation with TTL)\n    69→  const tenantKeyManager = new TenantKeyManager(config.masterKey, logger);\n    70→\n    71→  // Declarative audit policy — maps emitter events to audit entries\n    72→  const auditPolicy = new AuditPolicy(auditLog);\n    73→\n    74→  auditPolicy.attach<TenantKeyEvents>(tenantKeyManager, {\n    75→    'key:derived': (e) => ({ action: 'key:derive', tenantId: e.tenantId }),\n    76→  });\n    77→\n    78→  auditPolicy.attach<WorkerPoolEvents>(pool, {\n    79→    'worker-connected': (info) => ({ action: 'worker:connected', detail: { workerId: info.workerId } }),\n    80→    'worker-disconnected': (workerId, executionId) => ({ action: 'worker:disconnected', detail: { workerId }, resourceId: executionId }),\n    81→  });\n    82→\n    83→  // Wire tenant ID source for key pre-warming and proactive renewal\n    84→  await tenantKeyManager.setTenantIdSource(() => tenantDbManager.listTenantIds());\n    85→  // Eagerly warm key cache when a new tenant is registered\n    86→  tenantDbManager.setTenantCreatedCallback((tenantId) => tenantKeyManager.warmTenant(tenantId));\n    87→\n    88→  // Dispatcher — uses OAuth manager for token refresh\n    89→  const dispatcher = new Dispatcher(pool, tokenManager, oauth, kafka, logger);\n    90→  dispatcher.setTenantDbManager(tenantDbManager);\n    91→  await dispatcher.setMasterKey(config.masterKey);\n    92→  dispatcher.setTenantKeyManager(tenantKeyManager);\n    93→  dispatcher.setAuditLog(auditLog);\n    94→\n    95→  // Connect Kafka\n    96→  if (config.kafkaEnabled) {\n    97→    await kafka.connect();\n    98→\n    99→    // Subscribe to execution requests\n   100→    await kafka.subscribe(async (topic: string, value: string) => {\n   101→      if (topic === TOPICS.EXEC_REQUESTS) {\n   102→        try {\n   103→          const request: ExecRequest = JSON.parse(value);\n   104→          dispatcher.submit(request);\n   105→        } catch (err) {\n   106→          logger.error({ err }, 'Failed to parse execution request from Kafka');\n   107→        }\n   108→      }\n   109→    });\n   110→  }\n   111→\n   112→  // Load TLS config and start WebSocket server for workers\n   113→  const tlsConfig = loadTlsConfig(logger);\n   114→  pool.listen(config.wsPort, tlsConfig.enabled ? tlsConfig : undefined);\n   115→\n   116→  // Start HTTP API (now includes OAuth endpoints + persona CRUD)\n   117→  // Set master key on Kafka for envelope encryption\n   118→  await kafka.setMasterKey(config.masterKey);\n   119→\n   120→  // Start event processor (demand-driven with 30s backstop) — tenant-aware\n   121→  const eventProcessor = startEventProcessor(null, dispatcher, logger, 30_000, tenantDbManager);\n   122→\n   123→  // Start heap-driven trigger scheduler — builds in-memory min-heap from DB on startup\n   124→  const triggerScheduler = startTriggerScheduler(null, logger, undefined, tenantDbManager, eventProcessor.nudge);\n   125→\n   126→  const httpServer = createHttpApi(auth, dispatcher, pool, tokenManager, oauth, logger, undefined, tenantDbManager, tenantKeyManager, auditLog, eventProcessor.getHealth, kafka, eventProcessor.nudge, triggerScheduler);\n   127→  httpServer.listen(config.httpPort, () => {\n   128→    logger.info({ port: config.httpPort }, 'HTTP API listening');\n   129→  });\n   130→\n   131→  // Start daily retention job (purge old executions/events, aggregate metrics)\n   132→  const retentionTimer = startRetentionJob(tenantDbManager, config.retentionDays, logger);\n   133→\n   134→  // Token refresh loop — refresh OAuth token proactively every 30 minutes\n   135→  setInterval(async () => {\n   136→    if (oauth.hasTokens()) {\n   137→      const token = await oauth.getValidAccessToken();\n   138→      if (token) {\n   139→        tokenManager.storeClaudeToken(token);\n   140→      }\n   141→    }\n   142→  }, 30 * 60 * 1000);\n   143→\n   144→  // Log status periodically\n   145→  setInterval(() => {\n   146→    const counts = pool.getWorkerCount();\n   147→    const queueLen = dispatcher.getQueueLength();\n   148→    if (counts.total > 0 || queueLen > 0) {\n   149→      logger.info({\n   150→        workers: counts,\n   151→        queueLength: queueLen,\n   152→        activeExecutions: dispatcher.getActiveExecutions().length,\n   153→        hasOAuth: oauth.hasTokens(),\n   154→      }, 'Status');\n   155→    }\n   156→  }, 60_000);\n   157→\n   158→  // Graceful shutdown\n   159→  const shutdown = async () => {\n   160→    logger.info('Shutting down...');\n   161→    clearInterval(eventProcessor.timer);\n   162→    triggerScheduler.close();\n   163→    clearInterval(retentionTimer);\n   164→    dispatcher.shutdown();\n   165→    pool.shutdown();\n   166→    await kafka.disconnect();\n   167→    httpServer.close();\n   168→    tenantKeyManager.close();\n   169→    auditRetention.close();\n   170→    auditLog.close();\n   171→    tenantDbManager.close();\n   172→    oauth.dispose();\n   173→    process.exit(0);\n   174→  };\n   175→\n   176→  process.on('SIGINT', shutdown);\n   177→  process.on('SIGTERM', shutdown);\n   178→\n   179→  logger.info('DAC Cloud Orchestrator ready');\n   180→  logger.info(`  HTTP API: http://localhost:${config.httpPort}`);\n   181→  logger.info(`  Worker WS: ${tlsConfig.enabled ? 'wss' : 'ws'}://localhost:${config.wsPort}`);\n   182→  if (!config.claudeToken) {\n   183→    logger.info('  Connect subscription: POST /api/oauth/authorize');\n   184→  }\n   185→}\n   186→\n   187→main().catch((err) => {\n   188→  logger.fatal({ err }, 'Failed to start orchestrator');\n   189→  process.exit(1);\n   190→});\n   191→"}]},"parent_tool_use_id":"toolu_01CxroRcNq3gPEPrZ489cQLJ","session_id":"2a8eabc1-ce20-4af0-9b5d-da3936e3656a","uuid":"6d9883e7-ffba-46c2-a492-1bc05c6a81ac","timestamp":"2026-03-18T18:30:07.851Z"}
