ff = new Date(Date.now() - retentionDays * 86_400_000).toISOString();","+  const stuckCutoff = new Date(Date.now() - retentionDays * 7 * 86_400_000).toISOString();"," ","   const tenantIds = tenantDbManager.listTenantIds();","   for (const projectId of tenantIds) {","     try {","       const db = tenantDbManager.getTenantDb(projectId);","-      await runTenantRetention(db, projectId, cutoff, retentionDays, logger);","+      const ctx = { projectId };","+","+      const purgedExecutions = await execPolicy.purge(db, cutoff, logger, ctx);","+      const purgedEvents = await eventsPolicy.purge(db, cutoff, logger, ctx);","+      const purgedStuckEvents = await stuckEventsPolicy.purge(db, stuckCutoff, logger, ctx);","+","+      if (purgedExecutions > 0 || purgedEvents > 0 || purgedStuckEvents > 0) {","+        logger.info({ projectId, purgedExecutions, purgedEvents, purgedStuckEvents }, 'Retention cleanup complete');","+      }","     } catch (err) {","       logger.error({ err, projectId }, 'Retention cleanup failed for tenant');","     }"]},{"oldStart":228,"oldLines":104,"newStart":220,"newLines":3,"lines":[" ","   logger.info({ days: dayMap.size, tenants: tenantIds.length }, 'System-wide metrics aggregation complete');"," }","-","-async function runTenantRetention(","-  db: Database.Database,","-  projectId: string,","-  cutoff: string,","-  retentionDays: number,","-  logger: Logger,","-): Promise<void> {","-  // ── Batched index scan: collect purgeable execution rowids in chunks ──","-  // The delete step operates on this pre-collected set.  Metrics are","-  // recorded incrementally in updateExecution() on terminal status","-  // transitions, so no aggregation is needed here.","-  db.exec('CREATE TEMP TABLE IF NOT EXISTS _ret_ids (id INTEGER PRIMARY KEY)');","-  db.prepare('DELETE FROM _ret_ids').run();","-  {","-    const collectStmt = db.prepare(`","-      INSERT INTO _ret_ids (id)","-      SELECT rowid FROM persona_executions","-      WHERE rowid > ? AND created