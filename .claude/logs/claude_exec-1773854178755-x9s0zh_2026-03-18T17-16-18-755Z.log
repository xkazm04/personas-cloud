  this.heartbeatTimer = setInterval(() => {\n   103→        this.send({ type: 'heartbeat', timestamp: Date.now() });\n   104→      }, HEARTBEAT_INTERVAL_MS);\n   105→\n   106→      this.logger.info('Connected to orchestrator');\n   107→    });\n   108→\n   109→    this.ws.on('message', (raw: Buffer) => {\n   110→      const msg = parseOrchestratorMessage(raw.toString());\n   111→      if (!msg) {\n   112→        this.logger.warn('Invalid message from orchestrator');\n   113→        return;\n   114→      }\n   115→\n   116→      this.handleMessage(msg);\n   117→    });\n   118→\n   119→    this.ws.on('close', (code: number, reason: Buffer) => {\n   120→      this.logger.info({ code, reason: reason.toString() }, 'Disconnected from orchestrator');\n   121→      this.cleanup();\n   122→      this.scheduleReconnect();\n   123→    });\n   124→\n   125→    this.ws.on('error', (err: Error) => {\n   126→      this.logger.error({ err }, 'WebSocket error');\n   127→      // 'close' will follow, which handles reconnection\n   128→    });\n   129→  }\n   130→\n   131→  private handleMessage(msg: OrchestratorMessage): void {\n   132→    switch (msg.type) {\n   133→      case 'ack':\n   134→        this.logger.info({ workerId: msg.workerId }, 'Received ack from orchestrator');\n   135→        // Send ready after ack\n   136→        this.sendReady();\n   137→        break;\n   138→\n   139→      case 'assign':\n   140→        this.logger.info({ executionId: msg.executionId, personaId: msg.personaId }, 'Received execution assignment');\n   141→        this.callbacks.onAssign(msg);\n   142→        break;\n   143→\n   144→      case 'cancel':\n   145→        this.logger.info({ executionId: msg.executionId }, 'Received cancel');\n   146→        this.callbacks.onCancel(msg);\n   147→        break;\n   148→\n   149→      case 'shutdown':\n   150→        this.logger.info({ reason: msg.reason }, 'Received shutdown');\n   151→        this.shuttingDown = true;\n   152→        this.callbacks.