orkerBusy {\n    66→  type: 'busy';\n    67→  executionId: string;\n    68→  reason: string;\n    69→}\n    70→\n    71→export type WorkerMessage =\n    72→  | WorkerHello\n    73→  | WorkerReady\n    74→  | ExecStdout\n    75→  | ExecStderr\n    76→  | ExecComplete\n    77→  | WorkerEvent\n    78→  | ExecProgress\n    79→  | WorkerHeartbeat\n    80→  | WorkerBusy;\n    81→\n    82→// --- Orchestrator → Worker ---\n    83→\n    84→export interface OrchestratorAck {\n    85→  type: 'ack';\n    86→  workerId: string;\n    87→  sessionToken: string;\n    88→}\n    89→\n    90→export interface ExecAssign {\n    91→  type: 'assign';\n    92→  executionId: string;\n    93→  personaId: string;\n    94→  prompt: string;\n    95→  env: Record<string, string>;\n    96→  config: {\n    97→    timeoutMs: number;\n    98→    maxOutputBytes: number;\n    99→    networkPolicy?: import('./networkPolicy.js').NetworkPolicy;\n   100→    maxBudgetUsd?: number;\n   101→    maxTurns?: number;\n   102→  };\n   103→}\n   104→\n   105→export interface ExecCancel {\n   106→  type: 'cancel';\n   107→  executionId: string;\n   108→}\n   109→\n   110→export interface OrchestratorShutdown {\n   111→  type: 'shutdown';\n   112→  reason: string;\n   113→  gracePeriodMs: number;\n   114→}\n   115→\n   116→export interface OrchestratorHeartbeat {\n   117→  type: 'heartbeat';\n   118→  timestamp: number;\n   119→}\n   120→\n   121→export type OrchestratorMessage =\n   122→  | OrchestratorAck\n   123→  | ExecAssign\n   124→  | ExecCancel\n   125→  | OrchestratorShutdown\n   126→  | OrchestratorHeartbeat;\n   127→\n   128→// --- Runtime validators ---\n   129→\n   130→function isObj(v: unknown): v is Record<string, unknown> {\n   131→  return typeof v === 'object' && v !== null && !Array.isArray(v);\n   132→}\n   133→\n   134→function hasStr(o: Record<string, unknown>, k: string): boolean {\n   135→  return typeof o[k] === 'string';\n   136→}\n   137→\n   138→function hasNum(o: Record<string, unknown>,