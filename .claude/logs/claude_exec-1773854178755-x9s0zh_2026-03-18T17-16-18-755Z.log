[2026-03-18T17:16:28.718Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0132hNAct2D8qjrCHPMEKQXc","type":"tool_result","content":"     1→import fs from 'node:fs';\n     2→import path from 'node:path';\n     3→import os from 'node:os';\n     4→import { execSync } from 'node:child_process';\n     5→import type { Logger } from 'pino';\n     6→\n     7→import { buildCliArgs, type NetworkPolicy } from '@dac-cloud/shared';\n     8→\n     9→export interface SandboxConfig {\n    10→  executionId: string;\n    11→  env: Record<string, string>;\n    12→  accessToken?: string;\n    13→  networkAccess: boolean;\n    14→  networkPolicy?: NetworkPolicy;\n    15→  timeoutMs: number;\n    16→  maxBudgetUsd?: number;\n    17→  maxTurns?: number;\n    18→}\n    19→\n    20→export interface SandboxResult {\n    21→  command: string;\n    22→  args: string[];\n    23→  env: Record<string, string>;\n    24→  cwd: string;\n    25→  sandboxDir: string;\n    26→  proxyRequired?: boolean;\n    27→}\n    28→\n    29→let _bwrapAvailable: boolean | null = null;\n    30→\n    31→/**\n    32→ * Cached bwrap args for static system paths that never change between executions.\n    33→ * Computed once at module load time to avoid 6 synchronous fs.existsSync calls per execution.\n    34→ */\n    35→const _cachedStaticBwrapArgs: string[] = (() => {\n    36→  if (process.platform !== 'linux') return [];\n    37→\n    38→  const args: string[] = [];\n    39→  const conditionalPaths: Array<{ path: string; args: string[] }> = [\n    40→    { path: '/lib', args: ['--ro-bind', '/lib', '/lib'] },\n    41→    { path: '/lib64', args: ['--ro-bind', '/lib64', '/lib64'] },\n    42→    { path: '/etc/ssl', args: ['--ro-bind', '/etc/ssl', '/etc/ssl'] },\n    43→    { path: '/etc/ca-certificates', args: ['--ro-bind', '/etc/ca-certificates', '/etc/ca-certificates'] },\n    44→    { path: '/usr/local/lib/node_modules', args: ['--ro-bind', '/usr/local/lib/node_modules', '/usr/local/lib/node_modules'] },\n    45→    { path: '/usr/local/bin/claude', args: ['--ro-bind', '/usr/local/bin/claude', '/usr/local/bin/claude'] },\n    46→  ];\n    47→\n    48→  for (const entry of conditionalPaths) {\n    49→    if (fs.existsSync(entry.path)) {\n    50→      args.push(...entry.args);\n    51→    }\n    52→  }\n    53→\n    54→  return args;\n    55→})();\n    56→\n    57→/**\n    58→ * Check if bubblewrap (bwrap) is available on this system.\n    59→ * Cached after first call.\n    60→ */\n    61→export function isSandboxAvailable(): boolean {\n    62→  if (_bwrapAvailable !== null) return _bwrapAvailable;\n    63→\n    64→  if (process.platform !== 'linux') {\n    65→    _bwrapAvailable = false;\n    66→    return false;\n    67→  }\n    68→\n    69→  try {\n    70→    execSync('which bwrap', { stdio: 'ignore' });\n    71→    _bwrapAvailable = true;\n    72→  } catch {\n    73→    _bwrapAvailable = false;\n    74→  }\n    75→  return _bwrapAvailable;\n    76→}\n    77→\n    78→/**\n    79→ * Resolve the claude CLI command path.\n    80→ */\n    81→function resolveClaudeCommand(): string {\n    82→  if (process.platform === 'win32') {\n    83→    try {\n    84→      return execSync('where claude', { encoding: 'utf8' }).trim().split('\\n')[0]!;\n    85→    } catch { /* fall through */ }\n    86→  }\n    87→  return 'claude';\n    88→}\n    89→\n    90→/**\n    91→ * Build a clean environment dict for the child process.\n    92→ * Never inherits from process.env — only explicit values.\n    93→ */\n    94→function buildCleanEnv(assignmentEnv: Record<string, string>): Record<string, string> {\n    95→  const clean: Record<string, string> = {\n    96→    PATH: '/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin',\n    97→    NODE_ENV: 'production',\n    98→    LANG: 'en_US.UTF-8',\n    99→  };\n   100→\n   101→  // Copy assignment env vars (credentials, config)\n   102→  for (const [key, value] of Object.entries(assignmentEnv)) {\n   103→    if (key === 'ANTHROPIC_API_KEY') continue; // handled via credentials file\n   104→    clean[key] = value;\n   105→  }\n   106→\n   107→  // Explicitly unset CLAUDECODE to prevent nested session guard\n   108→  delete clean['CLAUDECODE'];\n   109→\n   110→  return clean;\n   111→}\n   112→\n   113→/**\n   114→ * Create the per-execution sandbox directory structure and write\n   115→ * Claude config + credentials files.\n   116→ */\n   117→function createSandboxDir(\n   118→  executionId: string,\n   119→  accessToken: string | undefined,\n   120→  logger: Logger,\n   121→): string {\n   122→  const sandboxDir = path.join(os.tmpdir(), `dac-sandbox-${executionId}`);\n   123→  const homeDir = path.join(sandboxDir, 'home');\n   124→  const claudeDir = path.join(homeDir, '.claude');\n   125→  const workDir = path.join(sandboxDir, 'work');\n   126→  const tmpDir = path.join(sandboxDir, 'tmp');\n   127→\n   128→  fs.mkdirSync(claudeDir, { recursive: true });\n   129→  fs.mkdirSync(workDir, { recursive: true });\n   130→  fs.mkdirSync(tmpDir, { recursive: true });\n   131→\n   132→  // Claude onboarding config\n   133→  fs.writeFileSync(\n   134→    path.join(homeDir, '.claude.json'),\n   135→    JSON.stringify({ hasCompletedOnboarding: true }),\n   136→  );\n   137→\n   138→  // OAuth credentials (per-execution, no race condition)\n   139→  if (accessToken) {\n   140→    const credPayload = {\n   141→      claudeAiOauth: {\n   142→        token_type: 'Bearer',\n   143→        access_token: accessToken,\n   144→        expires_at: Math.floor(Date.now() / 1000) + 3600,\n   145→      },\n   146→    };\n   147→    fs.writeFileSync(\n   148→      path.join(claudeDir, '.credentials.json'),\n   149→      JSON.stringify(credPayload, null, 2),\n   150→    );\n   151→    // Restrict permissions on Linux\n   152→    if (process.platform === 'linux') {\n   153→      try { fs.chmodSync(path.join(claudeDir, '.credentials.json'), 0o600); } catch (err) { logger.warn({ err, executionId, operation: 'chmod_credentials' }, 'Failed to restrict credentials file permissions'); }\n   154→    }\n   155→  }\n   156→\n   157→  logger.debug({ sandboxDir, executionId }, 'Sandbox directory created');\n   158→  return sandboxDir;\n   159→}\n   160→\n   161→/**\n   162→ * Prepare a sandboxed execution environment.\n   163→ * When bwrap is available: full namespace isolation.\n   164→ * Fallback: per-execution HOME without namespace isolation.\n   165→ */\n   166→export function prepareSandbox(config: SandboxConfig, logger: Logger): SandboxResult {\n   167→  const oauthToken = config.env['ANTHROPIC_API_KEY'];\n   168→  const accessToken = config.accessToken ??\n   169→    (oauthToken?.startsWith('sk-ant-oat') ? oauthToken : undefined);\n   170→\n   171→  const sandboxDir = createSandboxDir(config.executionId, accessToken, logger);\n   172→  const homeDir = path.join(sandboxDir, 'home');\n   173→  const workDir = path.join(sandboxDir, 'work');\n   174→\n   175→  const cleanEnv = buildCleanEnv(config.env);\n   176→\n   177→  // Non-OAuth API keys (e.g. sk-ant-api*) must be passed via environment.\n   178→  // buildCleanEnv strips ANTHROPIC_API_KEY assuming it's handled via credentials\n   179→  // file, but only OAuth tokens (sk-ant-oat*) are written there. Re-inject\n   180→  // non-OAuth keys so the Claude CLI can authenticate.\n   181→  const apiKey = config.env['ANTHROPIC_API_KEY'];\n   182→  if (apiKey && !accessToken) {\n   183→    cleanEnv['ANTHROPIC_API_KEY'] = apiKey;\n   184→  }\n   185→\n   186→  if (isSandboxAvailable()) {\n   187→    // Full bwrap sandbox\n   188→    const bwrapArgs: string[] = [\n   189→      '--unshare-pid',\n   190→      '--unshare-uts',\n   191→      '--die-with-parent',\n   192→      // Read-only system mounts\n   193→      '--ro-bind', '/usr', '/usr',\n   194→      '--ro-bind', '/bin', '/bin',\n   195→      '--ro-bind', '/sbin', '/sbin',\n   196→      '--ro-bind', '/etc/resolv.conf', '/etc/resolv.conf',\n   197→      // Conditional system paths (cached at