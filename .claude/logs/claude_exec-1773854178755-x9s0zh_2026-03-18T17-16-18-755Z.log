[2026-03-18T17:16:35.517Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GFvZjtztEmpH1qSHu1wZmZ","type":"tool_result","content":"     1→import WebSocket from 'ws';\n     2→import fs from 'node:fs';\n     3→import {\n     4→  parseOrchestratorMessage,\n     5→  serializeMessage,\n     6→  PROTOCOL_VERSION,\n     7→  type OrchestratorMessage,\n     8→  type ExecAssign,\n     9→  type ExecCancel,\n    10→  type OrchestratorShutdown,\n    11→  type WorkerMessage,\n    12→} from '@dac-cloud/shared';\n    13→import type { Logger } from 'pino';\n    14→\n    15→export interface WorkerTlsConfig {\n    16→  caPath: string;\n    17→  certPath: string;\n    18→  keyPath: string;\n    19→  rejectUnauthorized: boolean;\n    20→}\n    21→\n    22→const HEARTBEAT_INTERVAL_MS = 30_000;\n    23→const MAX_RECONNECT_DELAY_MS = 30_000;\n    24→const INITIAL_RECONNECT_DELAY_MS = 1_000;\n    25→\n    26→export interface ConnectionCallbacks {\n    27→  onAssign(msg: ExecAssign): void;\n    28→  onCancel(msg: ExecCancel): void;\n    29→  onShutdown(msg: OrchestratorShutdown): void;\n    30→}\n    31→\n    32→export class Connection {\n    33→  private ws: WebSocket | null = null;\n    34→  private connected = false;\n    35→  private reconnectDelay = INITIAL_RECONNECT_DELAY_MS;\n    36→  private heartbeatTimer?: ReturnType<typeof setInterval>;\n    37→  private reconnectTimer?: ReturnType<typeof setTimeout>;\n    38→  private shuttingDown = false;\n    39→\n    40→  private tlsConfig?: WorkerTlsConfig;\n    41→  private cachedTlsOptions?: Pick<WebSocket.ClientOptions, 'ca' | 'cert' | 'key' | 'rejectUnauthorized'>;\n    42→\n    43→  private imageDigest: string;\n    44→  private claudeCliVersion: string;\n    45→\n    46→  constructor(\n    47→    private orchestratorUrl: string,\n    48→    private workerId: string,\n    49→    private workerToken: string,\n    50→    private callbacks: ConnectionCallbacks,\n    51→    private logger: Logger,\n    52→