79→  id: string;\n   180→  personaId: string;\n   181→  triggerType: TriggerType;\n   182→  config: string | null;\n   183→  enabled: boolean;\n   184→  lastTriggeredAt: string | null;\n   185→  nextTriggerAt: string | null;\n   186→  useCaseId: string | null;\n   187→  createdAt: string;\n   188→  updatedAt: string;\n   189→}\n   190→\n   191→/** Fully hydrated persona with all related entities. */\n   192→export interface HydratedPersona extends Persona {\n   193→  tools: PersonaToolDefinition[];\n   194→  credentials: Omit<PersonaCredential, 'encryptedData' | 'iv' | 'tag'>[];\n   195→  subscriptions: PersonaEventSubscription[];\n   196→  triggers: PersonaTrigger[];\n   197→}\n   198→\n   199→export interface PersonaExecution {\n   200→  id: string;\n   201→  projectId?: string;\n   202→  personaId: string;\n   203→  triggerId: string | null;\n   204→  useCaseId: string | null;\n   205→  status: string;\n   206→  inputData: string | null;\n   207→  outputData: string | null;\n   208→  claudeSessionId: string | null;\n   209→  modelUsed: string | null;\n   210→  inputTokens: number;\n   211→  outputTokens: number;\n   212→  costUsd: number;\n   213→  errorMessage: string | null;\n   214→  durationMs: number | null;\n   215→  retryOfExecutionId: string | null;\n   216→  retryCount: number;\n   217→  startedAt: string | null;\n   218→  completedAt: string | null;\n   219→  createdAt: string;\n   220→}\n   221→\n   222→// ---------------------------------------------------------------------------\n   223→// Execution request — produced to Kafka by Vibeman, consumed by orchestrator\n   224→// ---------------------------------------------------------------------------\n   225→\n   226→export interface ExecRequest {\n   227→  executionId: string;\n   228→  personaId: string;\n   229→  prompt: string;\n   230→  projectId?: string;\n   231→  credentialIds?: string[];\n   232→  inputData?: unknown;\n   233→  config: {\n   234→    timeoutMs: number;\n   235→    maxConcurrent