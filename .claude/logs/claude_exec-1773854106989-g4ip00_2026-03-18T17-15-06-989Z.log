[2026-03-18T17:15:16.625Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xwe18BE5nzHQCcfq3CpCug","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import { matchEvent, assemblePrompt } from '@dac-cloud/shared';\n     4→import type { ExecRequest, EventMatch, PersonaEvent } from '@dac-cloud/shared';\n     5→import { nanoid } from 'nanoid';\n     6→import * as db from './db/index.js';\n     7→import type { Dispatcher } from './dispatcher.js';\n     8→import type { TenantDbManager } from './tenantDbManager.js';\n     9→\n    10→/** Default threshold (seconds) for the periodic stale-event reaper. */\n    11→const STALE_EVENT_REAPER_SECONDS = 120;\n    12→/** Run the reaper every N ticks (at 2s interval, 30 ticks = ~60s). */\n    13→const REAPER_TICK_INTERVAL = 30;\n    14→\n    15→export interface EventProcessorHealth {\n    16→  lastTickAt: number | null;\n    17→  pendingEvents: number;\n    18→  backlogAgeMs: number | null;\n    19→}\n    20→\n    21→export interface EventProcessorHandle {\n    22→  timer: NodeJS.Timeout;\n    23→  getHealth: () => EventProcessorHealth;\n    24→}\n    25→\n    26→/**\n    27→ * Recover events orphaned in 'processing' state from a prior crash.\n    28→ * Call once at startup before the tick loop begins.\n    29→ */\n    30→function recoverOrphanedEvents(\n    31→  database: Database.Database | null,\n    32→  logger: Logger,\n    33→  tenantDbManager?: TenantDbManager,\n    34→): void {\n    35→  if (tenantDbManager) {\n    36→    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    37→      const count = db.resetAllProcessingEvents(tenantDb);\n    38→      if (count > 0) {\n    39→        logger.warn({ projectId, count }, 'Reset orphaned processing events to pending at startup');\n    40→      }\n    41→    });\n    42→  } else if (database) {\n    43→    const count = db.resetAllProcessingEvents(database);\n    44→    if (count > 0) {\n    45→      logger.warn({ count }, 'Reset orphaned processing events to pending at startup');\n    46→    }\n    47→  }\n    48→}\n    49→\n    50→/**\n    51→ * Periodic reaper: reset events stuck in 'processing' longer than the threshold.\n    52→ * Guards against edge cases during normal operation.\n    53→ */\n    54→function reapStaleEvents(\n    55→  database: Database.Database | null,\n    56→  logger: Logger,\n    57→  tenantDbManager?: TenantDbManager,\n    58→): void {\n    59→  if (tenantDbManager) {\n    60→    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    61→      const count = db.resetStaleProcessingEvents(tenantDb, STALE_EVENT_REAPER_SECONDS);\n    62→      if (count > 0) {\n    63→        logger.warn({ projectId, count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    64→      }\n    65→    });\n    66→  } else if (database) {\n    67→    const count = db.resetStaleProcessingEvents(database, STALE_EVENT_REAPER_SECONDS);\n    68→    if (count > 0) {\n    69→      logger.warn({ count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    70→    }\n    71→  }\n    72→}\n    73→\n    74→/**\n    75→ * Start the event processing loop.\n    76→ * Supports both tenant-isolated DBs (via TenantDbManager) and legacy single DB.\n    77→ */\n    78→export function startEventProcessor(\n    79→  database: Database.Database | null,\n    80→  dispatcher: Dispatcher,\n    81→  logger: Logger,\n    82→  interval: number = 2000,\n    83→  tenantDbManager?: TenantDbManager,\n    84→): EventProcessorHandle {\n    85→  // At startup, reset any events orphaned in 'processing' from a prior crash\n    86→  recoverOrphanedEvents(database, logger, tenantDbManager);\n    87→\n    88→  logger.info({ intervalMs: interval, tenantIsolated: !!tenantDbManager }, 'Event processor started');\n    89→\n    90→  let tickCount = 0;\n    91→\n    92→  // Shared health state updated on every tick\n    93→  const health: EventProcessorHealth = {\n    94→    lastTickAt: null,\n    95→    pendingEvents: 0,\n    96→    backlogAgeMs: null,\n    97→  };\n    98→\n    99→  const timer = setInterval(() => {\n   100→    try {\n   101→      tickCount++;\n   102→      health.lastTickAt = Date.now();\n   103→\n   104→      // Periodically reap stale processing events as a safety net\n   105→      if (tickCount % REAPER_TICK_INTERVAL === 0) {\n   106→        reapStaleEvents(database, logger, tenantDbManager);\n   107→      }\n   108→\n   109→      // Collect pending event stats for health reporting\n   110→      let totalPending = 0;\n   111→      let oldestCreatedAt: string | null = null;\n   112→\n   113→      if (tenantDbManager) {\n   114→        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n   115→          totalPending += db.countPendingEvents(tenantDb);\n   116→          const oldest = db.getOldestPendingEventCreatedAt(tenantDb);\n   117→          if (oldest && (!oldestCreatedAt || oldest < oldestCreatedAt)) {\n   118→            oldestCreatedAt = oldest;\n   119→          }\n   120→          eventBusTick(tenantDb, dispatcher, logger, projectId);\n   121→        });\n   122→      } else if (database) {\n   123→        totalPending = db.countPendingEvents(database);\n   124→        oldestCreatedAt = db.getOldestPendingEventCreatedAt(database);\n   125→        eventBusTick(database, dispatcher, logger);\n   126→      }\n   127→\n   128→      health.pendingEvents = totalPending;\n   129→      health.backlogAgeMs = oldestCreatedAt\n   130→        ? Math.max(0, Date.now() - new Date(oldestCreatedAt + 'Z').getTime())\n   131→        : null;\n   132→    } catch (err) {\n   133→      logger.error({ err }, 'Event processor tick failed');\n   134→    }\n   135→  }, interval);\n   136→\n   137→  return {\n   138→    timer,\n   139→    getHealth: () => ({ ...health }),\n   140→  };\n   141→}\n   142→\n   143→function eventBusTick(\n   144→  database: Database.Database,\n   145→  dispatcher: Dispatcher,\n   146→  logger: Logger,\n   147→  projectId?: string,\n   148→): void {\n   149→  const tickStartMs = performance.now();\n   150→  let eventsFetched = 0;\n   151→  let matchesFound = 0;\n   152→  let delivered = 0;\n   153→  let skipped = 0;\n   154→  let failed = 0;\n   155→\n   156→  try {\n   157→    const events = db.getPendingEvents(database, 50);\n   158→    eventsFetched = events.length;\n   159→    if (eventsFetched === 0) return;\n   160→\n   161→    // Collect dispatch requests to fire *after* the transaction commits so that\n   162→    // the dispatcher never sees stale DB state.\n   163→    const pendingDispatches: ExecRequest[] = [];\n   164→\n   165→    // Wrap all DB reads/writes in a single transaction to avoid per-statement\n   166→    // fsync overhead (up to 100 individual commits per tick otherwise).\n   167→    database.transaction(() => {\n   168→      // Cache subscription lookups per unique (eventType, projectId) to avoid\n   169→      // redundant DB queries when the same event type fires multiple times in a batch.\n   170→      const subsCache = new Map<string, ReturnType<typeof db.getSubscriptionsByEventType>>();\n   171→\n   172→      // Phase 1: Mark events as processing, compute matches, collect unique persona IDs.\n   173→      const eventMatches: Array<{ event: PersonaEvent; matches: EventMatch[] }> = [];\n   174→      const allPersonaIds = new Set<string>();\n   175→\n   176→      for (const event of events) {\n   177→        db.updateEventStatus(database, event.id, 'processing');\n   178→\n   179→        const cacheKey = `${event.eventType}\\0${event.projectId}`;\n   180→        let subs = subsCache.get(cacheKey);\n   181→        if (subs === undefined) {\n   182→          subs = db.getSubscriptionsByEventType(database, event.eventType, event.projectId);\n   183→          subsCache.set(cacheKey, subs);\n   184→        }\n   185→        const matches = matchEvent(event, subs);\n   186→\n   187→        if (matches.length === 0) {\n   188→          db.updateEventStatus(database, event.id, 'skipped');\n   189→          skipped++;\n   190→          continue;\n   191→        }\n   192→\n   193→        matchesFound += matches.length;\n   194→        eventMatches.push({ event, matches });\n   195→        for (const match of matches) {\n   196→          allPersonaIds.add(match.personaId);\n   197→        }\n   198→      }\n   199→\n   200→      if (allPersonaIds.size === 0) return;\n   201→\n   202→      // Phase 2: Batch-fetch personas, tools, and running counts (2-3 queries total).\n   203→      const personaIds = [...allPersonaIds];\n   204→      const personaMap = db.getPersonasByIds(database, personaIds);\n   205→      const toolsMap = db.getToolsForPersonaIds(database, personaIds);\n   206→      const runningMap = db.countRunningExecutionsByPersonaIds(database, personaIds);\n   207→\n   208→      // Phase 3: Dispatch using Map lookups instead of per-match queries.\n   209→      // Track persona slots claimed within this tick to prevent over-dispatch.\n   210→      const claimed = new Map<string, number>();\n   211→\n   212→      for (const { event, matches } of eventMatches) {\n   213→        let eventDelivered = 0;\n   214→        let eventFailed = 0;\n   215→        let throttled = 0;\n   216→\n   217→        for (const match of matches) {\n   218→          try {\n   219→            const persona = personaMap.get(match.personaId);\n   220→            if (!persona) {\n   221→              logger.warn({ personaId: match.personaId, eventId: event.id }, 'Persona not found for event match');\n   222→              eventFailed++;\n   223→              failed++;\n   224→              continue;\n   225→            }\n   226→\n   227→            // Check concurrency (in-tick claims + batched DB count)\n   228→            const tickClaimed = claimed.get(persona.id) ?? 0;\n   229→            const running = runningMap.get(persona.id) ?? 0;\n   230→            if (running + tickClaimed >= persona.maxConcurrent) {\n   231→              logger.info({ personaId: persona.id, running, tickClaimed, max: persona.maxConcurrent }, 'Persona at concurrency limit, deferring');\n   232→              throttled++;\n   233→              continue;\n   234→            }\n   235→\n   236→            // Build input data from event payload\n   237→            let inputData: Record<string, unknown> | undefined;\n   238→            if (match.payload) {\n   239→              try {\n   240→                inputData = JSON.parse(match.payload);\n   241→              } catch (parseError) {\n   242→                logger.warn({ eventId: event.id, personaId: match.personaId, parseError }, 'Event payload JSON parse failed, using raw');\n   243→                inputData = { raw: match.payload };\n   244→              }\n   245→            }\n   246→\n   247→            // Assemble prompt using batched persona + tools\n   248→            const tools = toolsMap.get(persona.id) ?? [];\n   249→            const prompt = assemblePrompt(persona, tools, inputData);\n   250→\n   251→            // Queue dispatch request (fired after transaction commits)\n   252→            const request: ExecRequest = {\n   253→              executionId: nanoid(),\n   254→              personaId: persona.id,\n   255→              prompt,\n   256→              projectId: projectId ?? persona.projectId,\n   257→              config: { timeoutMs: persona.timeoutMs },\n   258→            };\n   259→\n   260→            pendingDispatches.push(request);\n   261→            claimed.set(persona.id, (claimed.get(persona.id) ?? 0) + 1);\n   262→            eventDelivered++;\n   263→            delivered++;\n   264→\n   265→            logger.info({\n   266→              eventId: event.id,\n   267→              personaId: persona.id,\n   268→              executionId: request.executionId,\n   269→              eventType: event.eventType,\n   270→              useCaseId: match.useCaseId,\n   271→            }, 'Event dispatched to persona');\n   272→          } catch (err) {\n   273→            logger.error({ err, personaId: match.personaId, eventId: event.id }, 'Failed to dispatch event match');\n   274→            eventFailed++;\n   275→            failed++;\n   276→          }\n   277→        }\n   278→\n   279→        // Update event status\n   280→        if (eventDelivered > 0 && eventFailed === 0 && throttled === 0) {\n   281→          db.updateEventStatus(database, event.id, 'delivered');\n   282→        } else if (eventDelivered > 0 && throttled > 0) {\n   283→          // Some matches delivered but others were concurrency-limited.\n   284→          // Defer with backoff so throttled matches get retried later.\n   285→          db.deferEventForRetry(database, event.id, event.retryCount);\n   286→          logger.info({ eventId: event.id, delivered: eventDelivered, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event partially delivered, deferring throttled matches for retry');\n   287→        } else if (eventDelivered > 0 && eventFailed > 0) {\n   288→          // Some matches delivered but others failed — mark as partial-retry\n   289→          // so the event can be re-processed for the failed matches.\n   290→          db.updateEventStatus(database, event.id, 'partial-retry');\n   291→          logger.info({ eventId: event.id, delivered: eventDelivered, failed: eventFailed }, 'Event partially delivered with failures, marked for retry');\n   292→        } else if (throttled > 0) {\n   293→          // All (or remaining) matches were concurrency-limited — defer with backoff.\n   294→          db.deferEventForRetry(database, event.id, event.retryCount);\n   295→          logger.info({ eventId: event.id, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event deferred due to concurrency limits');\n   296→        } else {\n   297→          db.updateEventStatus(database, event.id, 'failed', 'All subscription matches failed');\n   298→        }\n   299→      }\n   300→    })();\n   301→\n   302→    // Fire dispatches after the transaction has committed successfully\n   303→    for (const request of pendingDispatches) {\n   304→      dispatcher.submit(request);\n   305→    }\n   306→  } finally {\n   307→    const tickDurationMs = performance.now() - tickStartMs;\n   308→    logger.info({\n   309→      tickDurationMs,\n   310→      eventsFetched,\n   311→      matchesFound,\n   312→      delivered,\n   313→      skipped,\n   314→      failed\n   315→    }, 'Event processor tick complete');\n   316→  }\n   317→}\n   318→"}]},"parent_tool_use_id":null,"session_id":"6fad3684-b1dc-4c4e-a994-9ff8f2949463","uuid":"e9b121f0-66e5-40a2-8d29-7cfc654b03ac","timestamp":"2026-03-18T17:15:16.545Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\eventProcessor.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport { matchEvent, assemblePrompt } from '@dac-cloud/shared';\nimport type { ExecRequest, EventMatch, PersonaEvent } from '@dac-cloud/shared';\nimport { nanoid } from 'nanoid';\nimport * as db from './db/index.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\n\n/** Default threshold (seconds) for the periodic stale-event reaper. */\nconst STALE_EVENT_REAPER_SECONDS = 120;\n/** Run the reaper every N ticks (at 2s interval, 30 ticks = ~60s). */\nconst REAPER_TICK_INTERVAL = 30;\n\nexport interface EventProcessorHealth {\n  lastTickAt: number | null;\n  pendingEvents: number;\n  backlogAgeMs: number | null;\n}\n\nexport interface EventProcessorHandle {\n  timer: NodeJS.Timeout;\n  getHealth: () => EventProcessorHealth;\n}\n\n/**\n * Recover events orphaned in 'processing' state from a prior crash.\n * Call once at startup before the tick loop begins.\n */\nfunction recoverOrphanedEvents(\n  database: Database.Database | null,\n  logger: Logger,\n  tenantDbManager?: TenantDbManager,\n): void {\n  if (tenantDbManager) {\n    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n      const count = db.resetAllProcessingEvents(tenantDb);\n      if (count > 0) {\n        logger.warn({ projectId, count }, 'Reset orphaned processing events to pending at startup');\n      }\n    });\n  } else if (database) {\n    const count = db.resetAllProcessingEvents(database);\n    if (count > 0) {\n      logger.warn({ count }, 'Reset orphaned processing events to pending at startup');\n    }\n  }\n}\n\n/**\n * Periodic reaper: reset events stuck in 'processing' longer than the threshold.\n * Guards against edge cases during normal operation.\n */\nfunction reapStaleEvents(\n  database: Database.Database | null,\n  logger: Logger,\n  tenantDbManager?: TenantDbManager,\n): void {\n  if (tenantDbManager) {\n    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n      const count = db.resetStaleProcessingEvents(tenantDb, STALE_EVENT_REAPER_SECONDS);\n      if (count > 0) {\n        logger.warn({ projectId, count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n      }\n    });\n  } else if (database) {\n    const count = db.resetStaleProcessingEvents(database, STALE_EVENT_REAPER_SECONDS);\n    if (count > 0) {\n      logger.warn({ count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    }\n  }\n}\n\n/**\n * Start the event processing loop.\n * Supports both tenant-isolated DBs (via TenantDbManager) and legacy single DB.\n */\nexport function startEventProcessor(\n  database: Database.Database | null,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  interval: number = 2000,\n  tenantDbManager?: TenantDbManager,\n): EventProcessorHandle {\n  // At startup, reset any events orphaned in 'processing' from a prior crash\n  recoverOrphanedEvents(database, logger, tenantDbManager);\n\n  logger.info({ intervalMs: interval, tenantIsolated: !!tenantDbManager }, 'Event processor started');\n\n  let tickCount = 0;\n\n  // Shared health state updated on every tick\n  const health: EventProcessorHealth = {\n    lastTickAt: null,\n    pendingEvents: 0,\n    backlogAgeMs: null,\n  };\n\n  const timer = setInterval(() => {\n    try {\n      tickCount++;\n      health.lastTickAt = Date.now();\n\n      // Periodically reap stale processing events as a safety net\n      if (tickCount % REAPER_TICK_INTERVAL === 0) {\n        reapStaleEvents(database, logger, tenantDbManager);\n      }\n\n      // Collect pending event stats for health reporting\n      let totalPending = 0;\n      let oldestCreatedAt: string | null = null;\n\n      if (tenantDbManager) {\n        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n          totalPending += db.countPendingEvents(tenantDb);\n          const oldest = db.getOldestPendingEventCreatedAt(tenantDb);\n          if (oldest && (!oldestCreatedAt || oldest < oldestCreatedAt)) {\n            oldestCreatedAt = oldest;\n          }\n          eventBusTick(tenantDb, dispatcher, logger, projectId);\n        });\n      } else if (database) {\n        totalPending = db.countPendingEvents(database);\n        oldestCreatedAt = db.getOldestPendingEventCreatedAt(database);\n        eventBusTick(database, dispatcher, logger);\n      }\n\n      health.pendingEvents = totalPending;\n      health.backlogAgeMs = oldestCreatedAt\n        ? Math.max(0, Date.now() - new Date(oldestCreatedAt + 'Z').getTime())\n        : null;\n    } catch (err) {\n      logger.error({ err }, 'Event processor tick failed');\n    }\n  }, interval);\n\n  return {\n    timer,\n    getHealth: () => ({ ...health }),\n  };\n}\n\nfunction eventBusTick(\n  database: Database.Database,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  projectId?: string,\n): void {\n  const tickStartMs = performance.now();\n  let eventsFetched = 0;\n  let matchesFound = 0;\n  let delivered = 0;\n  let skipped = 0;\n  let failed = 0;\n\n  try {\n    const events = db.getPendingEvents(database, 50);\n    eventsFetched = events.length;\n    if (eventsFetched === 0) return;\n\n    // Collect dispatch requests to fire *after* the transaction commits so that\n    // the dispatcher never sees stale DB state.\n    const pendingDispatches: ExecRequest[] = [];\n\n    // Wrap all DB reads/writes in a single transaction to avoid per-statement\n    // fsync overhead (up to 100 individual commits per tick otherwise).\n    database.transaction(() => {\n      // Cache subscription lookups per unique (eventType, projectId) to avoid\n      // redundant DB queries when the same event type fires multiple times in a batch.\n      const subsCache = new Map<string, ReturnType<typeof db.getSubscriptionsByEventType>>();\n\n      // Phase 1: Mark events as processing, compute matches, collect unique persona IDs.\n      const eventMatches: Array<{ event: PersonaEvent; matches: EventMatch[] }> = [];\n      const allPersonaIds = new Set<string>();\n\n      for (const event of events) {\n        db.updateEventStatus(database, event.id, 'processing');\n\n        const cacheKey = `${event.eventType}\\0${event.projectId}`;\n        let subs = subsCache.get(cacheKey);\n        if (subs === undefined) {\n          subs = db.getSubscriptionsByEventType(database, event.eventType, event.projectId);\n          subsCache.set(cacheKey, subs);\n        }\n        const matches = matchEvent(event, subs);\n\n        if (matches.length === 0) {\n          db.updateEventStatus(database, event.id, 'skipped');\n          skipped++;\n          continue;\n        }\n\n        matchesFound += matches.length;\n        eventMatches.push({ event, matches });\n        for (const match of matches) {\n          allPersonaIds.add(match.personaId);\n        }\n      }\n\n      if (allPersonaIds.size === 0) return;\n\n      // Phase 2: Batch-fetch personas, tools, and running counts (2-3 queries total).\n      const personaIds = [...allPersonaIds];\n      const personaMap = db.getPersonasByIds(database, personaIds);\n      const toolsMap = db.getToolsForPersonaIds(database, personaIds);\n      const runningMap = db.countRunningExecutionsByPersonaIds(database, personaIds);\n\n      // Phase 3: Dispatch using Map lookups instead of per-match queries.\n      // Track persona slots claimed within this tick to prevent over-dispatch.\n      const claimed = new Map<string, number>();\n\n      for (const { event, matches } of eventMatches) {\n        let eventDelivered = 0;\n        let eventFailed = 0;\n        let throttled = 0;\n\n        for (const match of matches) {\n          try {\n            const persona = personaMap.get(match.personaId);\n            if (!persona) {\n              logger.warn({ personaId: match.personaId, eventId: event.id }, 'Persona not found for event match');\n              eventFailed++;\n              failed++;\n              continue;\n            }\n\n            // Check concurrency (in-tick claims + batched DB count)\n            const tickClaimed = claimed.get(persona.id) ?? 0;\n            const running = runningMap.get(persona.id) ?? 0;\n            if (running + tickClaimed >= persona.maxConcurrent) {\n              logger.info({ personaId: persona.id, running, tickClaimed, max: persona.maxConcurrent }, 'Persona at concurrency limit, deferring');\n              throttled++;\n              continue;\n            }\n\n            // Build input data from event payload\n            let inputData: Record<string, unknown> | undefined;\n            if (match.payload) {\n              try {\n                inputData = JSON.parse(match.payload);\n              } catch (parseError) {\n                logger.warn({ eventId: event.id, personaId: match.personaId, parseError }, 'Event payload JSON parse failed, using raw');\n                inputData = { raw: match.payload };\n              }\n            }\n\n            // Assemble prompt using batched persona + tools\n            const tools = toolsMap.get(persona.id) ?? [];\n            const prompt = assemblePrompt(persona, tools, inputData);\n\n            // Queue dispatch request (fired after transaction commits)\n            const request: ExecRequest = {\n              executionId: nanoid(),\n              personaId: persona.id,\n              prompt,\n              projectId: projectId ?? persona.projectId,\n              config: { timeoutMs: persona.timeoutMs },\n            };\n\n            pendingDispatches.push(request);\n            claimed.set(persona.id, (claimed.get(persona.id) ?? 0) + 1);\n            eventDelivered++;\n            delivered++;\n\n            logger.info({\n              eventId: event.id,\n              personaId: persona.id,\n              executionId: request.executionId,\n              eventType: event.eventType,\n              useCaseId: match.useCaseId,\n            }, 'Event dispatched to persona');\n          } catch (err) {\n            logger.error({ err, personaId: match.personaId, eventId: event.id }, 'Failed to dispatch event match');\n            eventFailed++;\n            failed++;\n          }\n        }\n\n        // Update event status\n        if (eventDelivered > 0 && eventFailed === 0 && throttled === 0) {\n          db.updateEventStatus(database, event.id, 'delivered');\n        } else if (eventDelivered > 0 && throttled > 0) {\n          // Some matches delivered but others were concurrency-limited.\n          // Defer with backoff so throttled matches get retried later.\n          db.deferEventForRetry(database, event.id, event.retryCount);\n          logger.info({ eventId: event.id, delivered: eventDelivered, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event partially delivered, deferring throttled matches for retry');\n        } else if (eventDelivered > 0 && eventFailed > 0) {\n          // Some matches delivered but others failed — mark as partial-retry\n          // so the event can be re-processed for the failed matches.\n          db.updateEventStatus(database, event.id, 'partial-retry');\n          logger.info({ eventId: event.id, delivered: eventDelivered, failed: eventFailed }, 'Event partially delivered with failures, marked for retry');\n        } else if (throttled > 0) {\n          // All (or remaining) matches were concurrency-limited — defer with backoff.\n          db.deferEventForRetry(database, event.id, event.retryCount);\n          logger.info({ eventId: event.id, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event deferred due to concurrency limits');\n        } else {\n          db.updateEventStatus(database, event.id, 'failed', 'All subscription matches failed');\n        }\n      }\n    })();\n\n    // Fire dispatches after the transaction has committed successfully\n    for (const request of pendingDispatches) {\n      dispatcher.submit(request);\n    }\n  } finally {\n    const tickDurationMs = performance.now() - tickStartMs;\n    logger.info({\n      tickDurationMs,\n      eventsFetched,\n      matchesFound,\n      delivered,\n      skipped,\n      failed\n    }, 'Event processor tick complete');\n  }\n}\n","numLines":318,"startLine":1,"totalLines":318}}}
[2026-03-18T17:15:17.011Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GL3jyjeQ8SYv1zzEsnDrdT","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    11→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    12→import type { TenantDbManager } from './tenantDbManager.js';\n    13→import type { TenantKeyManager } from './tenantKeyManager.js';\n    14→import type { AuditLog } from './auditLog.js';\n    15→import type { EventProcessorHealth } from './eventProcessor.js';\n    16→import type { Logger } from 'pino';\n    17→import * as db from './db/index.js';\n    18→import { readBody, json } from './httpUtils.js';\n    19→\n    20→export function createHttpApi(\n    21→  auth: Auth,\n    22→  dispatcher: Dispatcher,\n    23→  pool: WorkerPool,\n    24→  tokenManager: TokenManager,\n    25→  oauth: OAuthManager,\n    26→  logger: Logger,\n    27→  database?: Database.Database,\n    28→  tenantDbManager?: TenantDbManager,\n    29→  tenantKeyManager?: TenantKeyManager,\n    30→  auditLog?: AuditLog,\n    31→  getEventProcessorHealth?: () => EventProcessorHealth,\n    32→): http.Server {\n    33→  const server = http.createServer(async (req, res) => {\n    34→    // Security headers\n    35→    res.setHeader('X-Content-Type-Options', 'nosniff');\n    36→\n    37→    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    38→    const origin = req.headers.origin ?? '';\n    39→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    40→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    41→    if (isAdminRoute) {\n    42→      // Admin routes: only allow same-origin requests (no CORS wildcard)\n    43→      if (origin && origin === allowedOrigin) {\n    44→        res.setHeader('Access-Control-Allow-Origin', origin);\n    45→      }\n    46→      // If no match, omit the header entirely — browser blocks the request\n    47→    } else {\n    48→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    49→    }\n    50→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    51→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n    52→\n    53→    if (req.method === 'OPTIONS') {\n    54→      res.writeHead(204);\n    55→      res.end();\n    56→      return;\n    57→    }\n    58→\n    59→    const url = req.url || '/';\n    60→    const [pathname, queryString] = url.split('?');\n    61→    const route = parseRoute(pathname ?? '');\n    62→\n    63→    // Unauthenticated endpoints\n    64→    if (pathname === '/health' && req.method === 'GET') {\n    65→      handleHealth(res, pool, oauth, getEventProcessorHealth, database, tenantDbManager);\n    66→      return;\n    67→    }\n    68→\n    69→    // Auth check for everything else — dual auth (API key + optional JWT)\n    70→    const ctx = auth.validateAndExtractContext(req);\n    71→    if (!ctx) {\n    72→      res.writeHead(401, { 'Content-Type': 'application/json' });\n    73→      res.end(JSON.stringify({ error: 'Unauthorized' }));\n    74→      return;\n    75→    }\n    76→\n    77→    // Helper: project scoping (admin sees all, user sees own project)\n    78→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n    79→\n    80→    // Resolve tenant-specific database when available\n    81→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n    82→      if (tenantDbManager && projectId) {\n    83→        return tenantDbManager.getTenantDb(projectId);\n    84→      }\n    85→      return database;\n    86→    };\n    87→    const tenantDb = resolveDatabase(ctx.projectId);\n    88→\n    89→    try {\n    90→      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n    91→      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n    92→        if (requireAdmin(ctx, res)) return;\n    93→        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n    94→        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n    95→        return;\n    96→      }\n    97→      // --- Persona CRUD ---\n    98→      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n    99→        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n   100→      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n   101→        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   102→        const persona = createPersonaWithDefaults({\n   103→          ...body,\n   104→          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   105→        });\n   106→        db.upsertPersona(tenantDb, persona);\n   107→        logger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   108→        json(res, 201, persona);\n   109→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n   110→        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n   111→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n   112→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   113→        if (!persona) return;\n   114→        const body = JSON.parse(await readBody(req)) as { toolId: string };\n   115→        db.linkTool(tenantDb, route.id, body.toolId);\n   116→        logger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   117→        json(res, 200, { linked: true });\n   118→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n   119→        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, logger), scopedProjectId, res);\n   120→        if (!hydrated) return;\n   121→        json(res, 200, hydrated);\n   122→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n   123→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   124→        if (!persona) return;\n   125→        json(res, 200, persona);\n   126→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   127→        db.deletePersona(tenantDb, route.id, scopedProjectId);\n   128→        logger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   129→        json(res, 200, { deleted: true });\n   130→      }\n   131→      // --- Tool Definitions ---\n   132→      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n   133→        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   134→        const tool = createToolDefinitionWithDefaults(body);\n   135→        db.upsertToolDefinition(tenantDb, tool);\n   136→        logger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   137→        json(res, 201, tool);\n   138→      }\n   139→      // --- Credentials ---\n   140→      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n   141→        const body = JSON.parse(await readBody(req));\n   142→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   143→\n   144→        // Require plaintext — clients must never supply pre-encrypted data\n   145→        if (!body.plaintext || typeof body.plaintext !== 'string') {\n   146→          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   147→          return;\n   148→        }\n   149→\n   150→        // Reject oversized plaintext before synchronous encryption blocks the event loop\n   151→        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   152→          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   153→          return;\n   154→        }\n   155→\n   156→        // Encryption is mandatory — reject if the key manager is unavailable\n   157→        if (!tenantKeyManager) {\n   158→          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   159→          return;\n   160→        }\n   161→\n   162→        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n   163→        delete body.encryptedData;\n   164→        delete body.iv;\n   165→        delete body.tag;\n   166→\n   167→        // Server-side encryption with per-tenant key\n   168→        const tenantId = body.projectId || ctx.projectId || 'default';\n   169→        const key = await tenantKeyManager.getKey(tenantId);\n   170→        const encrypted = encrypt(body.plaintext, key);\n   171→        body.encryptedData = encrypted.encrypted;\n   172→        body.iv = encrypted.iv;\n   173→        body.tag = encrypted.tag;\n   174→        delete body.plaintext;\n   175→\n   176→        const cred = db.createCredential(tenantDb, body);\n   177→        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n   178→        logger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   179→        json(res, 201, cred);\n   180→      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   181→        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n   182→        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   183→        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   184→        logger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   185→        json(res, 200, { deleted: true });\n   186→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n   187→        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n   188→        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   189→        // Strip encrypted data from response\n   190→        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   191→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n   192→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   193→        if (!persona) return;\n   194→        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   195→        db.linkCredential(tenantDb, route.id, body.credentialId);\n   196→        logger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route.id, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   197→        json(res, 200, { linked: true });\n   198→      }\n   199→      // --- Event Subscriptions ---\n   200→      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n   201→        const body = JSON.parse(await readBody(req));\n   202→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   203→        const missing: string[] = [];\n   204→        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   205→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   206→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   207→        const sub = db.createSubscription(tenantDb, body);\n   208→        json(res, 201, sub);\n   209→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   210→        const body = JSON.parse(await readBody(req));\n   211→        db.updateSubscription(tenantDb, route.id, body);\n   212→        const updated = db.getSubscription(tenantDb, route.id);\n   213→        json(res, 200, updated);\n   214→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   215→        db.deleteSubscription(tenantDb, route.id);\n   216→        json(res, 200, { deleted: true });\n   217→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n   218→        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n   219→      }\n   220→      // --- Triggers (delegated to triggerHttpHandlers) ---\n   221→      else if (route && tenantDb && (\n   222→        route.resource === 'triggers' ||\n   223→        (route.resource === 'personas' && route.subResource === 'triggers')\n   224→      )) {\n   225→        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n   226→        return;\n   227→      }\n   228→      // --- Events ---\n   229→      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n   230→        const params = new URLSearchParams(queryString || '');\n   231→        const events = db.listEvents(tenantDb, {\n   232→          eventType: params.get('eventType') ?? undefined,\n   233→          status: params.get('status') ?? undefined,\n   234→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   235→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   236→          projectId: scopedProjectId,\n   237→        });\n   238→        json(res, 200, events);\n   239→      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n   240→        const body = JSON.parse(await readBody(req));\n   241→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   242→        const missing: string[] = [];\n   243→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   244→        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   245→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   246→        const event = db.publishEvent(tenantDb, body);\n   247→        json(res, 201, event);\n   248→      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   249→        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n   250→        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n   251→        if (updated) {\n   252→          json(res, 200, updated);\n   253→        } else {\n   254→          res.writeHead(404, { 'Content-Type': 'application/json' });\n   255→          res.end(JSON.stringify({ error: 'Event not found' }));\n   256→        }\n   257→      }\n   258→      // --- Webhooks ---\n   259→      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n   260→        const personaId = route.id;\n   261→        const body = await readBody(req);\n   262→        const event = db.publishEvent(tenantDb, {\n   263→          eventType: 'webhook_received',\n   264→          sourceType: 'webhook',\n   265→          sourceId: personaId,\n   266→          targetPersonaId: personaId,\n   267→          payload: body,\n   268→        });\n   269→        json(res, 201, event);\n   270→      }\n   271→      // --- GitLab Webhook ---\n   272→      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n   273→        const body = await readBody(req);\n   274→        let parsed: Record<string, unknown> = {};\n   275→        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   276→        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   277→        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   278→        const event = db.publishEvent(tenantDb, {\n   279→          eventType: `gitlab_${objectKind}`,\n   280→          sourceType: 'gitlab',\n   281→          sourceId: projectPath ?? null,\n   282→          payload: body,\n   283→        });\n   284→        json(res, 201, event);\n   285→      }\n   286→      // --- Executions ---\n   287→      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n   288→        const params = new URLSearchParams(queryString || '');\n   289→        const executions = db.listExecutions(tenantDb, {\n   290→          personaId: params.get('personaId') ?? undefined,\n   291→          status: params.get('status') ?? undefined,\n   292→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   293→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   294→          projectId: scopedProjectId,\n   295→        });\n   296→        json(res, 200, executions);\n   297→      }\n   298→      // --- Existing execution endpoints ---\n   299→      else if (pathname === '/api/status' && req.method === 'GET') {\n   300→        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   301→      } else if (pathname === '/api/execute' && req.method === 'POST') {\n   302→        await handleExecute(req, res, dispatcher, logger, ctx);\n   303→      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n   304→        handleCancelExecution(res, dispatcher, route.id);\n   305→      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n   306→        const executionId = route.id;\n   307→        const params = new URLSearchParams(queryString || '');\n   308→        const offset = parseInt(params.get('offset') || '0', 10);\n   309→        handleGetExecution(res, dispatcher, executionId, offset);\n   310→      }\n   311→      // --- Admin-only routes ---\n   312→      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n   313→        if (requireAdmin(ctx, res)) return;\n   314→        if (tenantDbManager) {\n   315→          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   316→        } else if (database) {\n   317→          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   318→        } else {\n   319→          json(res, 200, { projectIds: [] });\n   320→        }\n   321→      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n   322→        if (requireAdmin(ctx, res)) return;\n   323→        if (tenantDbManager) {\n   324→          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   325→          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   326→          json(res, 200, allPersonas);\n   327→        } else if (database) {\n   328→          json(res, 200, db.listPersonasSummary(database));\n   329→        } else {\n   330→          json(res, 200, []);\n   331→        }\n   332→      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n   333→        if (requireAdmin(ctx, res)) return;\n   334→        const params = new URLSearchParams(queryString || '');\n   335→        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   336→        if (tenantDbManager) {\n   337→          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   338→          tenantDbManager.forEachTenant((tDb) => {\n   339→            allExecs.push(...db.listExecutions(tDb, { limit }));\n   340→          });\n   341→          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   342→          json(res, 200, allExecs.slice(0, limit));\n   343→        } else if (database) {\n   344→          json(res, 200, db.listExecutions(database, {\n   345→            limit,\n   346→            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   347→          }));\n   348→        } else {\n   349→          json(res, 200, []);\n   350→        }\n   351→      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n   352→        if (requireAdmin(ctx, res)) return;\n   353→        if (!auditLog) { json(res, 200, []); return; }\n   354→        const params = new URLSearchParams(queryString || '');\n   355→        json(res, 200, auditLog.query({\n   356→          tenantId: params.get('tenantId') ?? undefined,\n   357→          action: params.get('action') ?? undefined,\n   358→          since: params.get('since') ?? undefined,\n   359→          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   360→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   361→        }));\n   362→      } else {\n   363→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   364→        res.end(JSON.stringify({ error: 'Not found' }));\n   365→      }\n   366→    } catch (err) {\n   367→      if (err instanceof Error && err.message === 'Payload too large') {\n   368→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   369→        res.end(JSON.stringify({ error: 'Payload too large' }));\n   370→        return;\n   371→      }\n   372→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   373→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   374→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n   375→        return;\n   376→      }\n   377→      logger.error({ err, url }, 'HTTP handler error');\n   378→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   379→      res.end(JSON.stringify({ error: 'Internal server error' }));\n   380→    }\n   381→  });\n   382→\n   383→  return server;\n   384→}\n   385→\n   386→interface ParsedRoute {\n   387→  resource: string;\n   388→  id?: string;\n   389→  subResource?: string;\n   390→}\n   391→\n   392→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n   393→function parseRoute(pathname: string): ParsedRoute | null {\n   394→  if (!pathname.startsWith('/api/')) return null;\n   395→  const segments = pathname.slice(5).split('/').filter(Boolean);\n   396→  if (segments.length === 0) return null;\n   397→  return {\n   398→    resource: segments[0]!,\n   399→    id: segments[1],\n   400→    subResource: segments[2],\n   401→  };\n   402→}\n   403→\n   404→/**\n   405→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   406→ * Returns the entity on success, or null after sending a 404 response.\n   407→ */\n   408→function withScopedEntity<T extends { projectId?: string | null }>(\n   409→  entity: T | undefined,\n   410→  scopedProjectId: string | undefined,\n   411→  res: http.ServerResponse,\n   412→): T | null {\n   413→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   414→    json(res, 404, { error: 'Not found' });\n   415→    return null;\n   416→  }\n   417→  return entity;\n   418→}\n   419→\n   420→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   421→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   422→  if (ctx.authType !== 'admin') {\n   423→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   424→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   425→    return true;\n   426→  }\n   427→  return false;\n   428→}\n   429→\n   430→// --- Existing handlers ---\n   431→\n   432→function handleHealth(\n   433→  res: http.ServerResponse,\n   434→  pool: WorkerPool,\n   435→  oauth: OAuthManager,\n   436→  getEventProcessorHealth?: () => EventProcessorHealth,\n   437→  database?: Database.Database,\n   438→  tenantDbManager?: TenantDbManager,\n   439→): void {\n   440→  const counts = pool.getWorkerCount();\n   441→\n   442→  // Lightweight database connectivity check\n   443→  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n   444→  if (database) {\n   445→    try {\n   446→      database.prepare('SELECT 1').get();\n   447→      dbHealth.status = 'ok';\n   448→    } catch {\n   449→      dbHealth.status = 'error';\n   450→    }\n   451→  }\n   452→  if (tenantDbManager) {\n   453→    try {\n   454→      const tenantIds = tenantDbManager.listTenantIds();\n   455→      dbHealth.tenantCount = tenantIds.length;\n   456→    } catch {\n   457→      dbHealth.tenantCount = -1;\n   458→    }\n   459→  }\n   460→\n   461→  const body: Record<string, unknown> = {\n   462→    status: 'ok',\n   463→    workers: counts,\n   464→    hasSubscription: oauth.hasTokens(),\n   465→    database: dbHealth,\n   466→    timestamp: Date.now(),\n   467→  };\n   468→  if (getEventProcessorHealth) {\n   469→    body.eventProcessor = getEventProcessorHealth();\n   470→  }\n   471→\n   472→  // Degrade overall status if database is unhealthy\n   473→  if (dbHealth.status === 'error') {\n   474→    body.status = 'degraded';\n   475→  }\n   476→\n   477→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   478→  res.end(JSON.stringify(body));\n   479→}\n   480→\n   481→function handleStatus(\n   482→  res: http.ServerResponse,\n   483→  pool: WorkerPool,\n   484→  dispatcher: Dispatcher,\n   485→  tokenManager: TokenManager,\n   486→  oauth: OAuthManager,\n   487→): void {\n   488→  const oauthTokens = oauth.getTokens();\n   489→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   490→  res.end(JSON.stringify({\n   491→    workers: pool.getWorkers(),\n   492→    workerCounts: pool.getWorkerCount(),\n   493→    workerPoolMetrics: pool.getMetrics(),\n   494→    queueLength: dispatcher.getQueueLength(),\n   495→    activeExecutions: dispatcher.getActiveExecutions(),\n   496→    hasClaudeToken: tokenManager.hasToken(),\n   497→    oauth: {\n   498→      connected: oauth.hasTokens(),\n   499→      scopes: oauthTokens?.scopes || [],\n   500→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   501→    },\n   502→  }));\n   503→}\n   504→\n   505→async function handleExecute(\n   506→  req: http.IncomingMessage,\n   507→  res: http.ServerResponse,\n   508→  dispatcher: Dispatcher,\n   509→  logger: Logger,\n   510→  ctx?: RequestContext,\n   511→): Promise<void> {\n   512→  const body = await readBody(req);\n   513→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   514→\n   515→  try {\n   516→    parsed = JSON.parse(body);\n   517→  } catch {\n   518→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   519→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   520→    return;\n   521→  }\n   522→\n   523→  if (!parsed.prompt) {\n   524→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   525→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   526→    return;\n   527→  }\n   528→\n   529→  const request: ExecRequest = {\n   530→    executionId: nanoid(),\n   531→    personaId: parsed.personaId || 'manual',\n   532→    prompt: parsed.prompt,\n   533→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   534→    config: {\n   535→      timeoutMs: parsed.timeoutMs || 300_000,\n   536→    },\n   537→  };\n   538→\n   539→  dispatcher.submit(request);\n   540→\n   541→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   542→\n   543→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   544→  res.end(JSON.stringify({\n   545→    executionId: request.executionId,\n   546→    status: 'queued',\n   547→  }));\n   548→}\n   549→\n   550→function handleGetExecution(\n   551→  res: http.ServerResponse,\n   552→  dispatcher: Dispatcher,\n   553→  executionId: string,\n   554→  offset: number = 0,\n   555→): void {\n   556→  const exec = dispatcher.getExecution(executionId);\n   557→\n   558→  if (!exec) {\n   559→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   560→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   561→    return;\n   562→  }\n   563→\n   564→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   565→\n   566→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   567→  res.end(JSON.stringify({\n   568→    executionId,\n   569→    status: exec.status,\n   570→    outputLines: exec.output.length,\n   571→    output,\n   572→    durationMs: exec.durationMs,\n   573→    sessionId: exec.sessionId,\n   574→    totalCostUsd: exec.totalCostUsd,\n   575→  }));\n   576→}\n   577→\n   578→function handleCancelExecution(\n   579→  res: http.ServerResponse,\n   580→  dispatcher: Dispatcher,\n   581→  executionId: string,\n   582→): void {\n   583→  const cancelled = dispatcher.cancelExecution(executionId);\n   584→\n   585→  if (!cancelled) {\n   586→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   587→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   588→    return;\n   589→  }\n   590→\n   591→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   592→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   593→}\n   594→\n   595→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\n   596→const MAX_QUERY_LIMIT = 500;\n   597→const MAX_QUERY_OFFSET = 100_000;\n   598→\n   599→/** Parse an integer query param and clamp it to safe bounds. */\n   600→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   601→  if (!value) return defaultValue;\n   602→  const parsed = parseInt(value, 10);\n   603→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   604→  return Math.min(parsed, max);\n   605→}\n   606→"}]},"parent_tool_use_id":null,"session_id":"6fad3684-b1dc-4c4e-a994-9ff8f2949463","uuid":"2cecf891-ce92-4005-9ff1-7c1187044506","timestamp":"2026-03-18T17:15:16.917Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { EventProcessorHealth } from './eventProcessor.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n): http.Server {\n  const server = http.createServer(async (req, res) => {\n    // Security headers\n    res.setHeader('X-Content-Type-Options', 'nosniff');\n\n    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    const origin = req.headers.origin ?? '';\n    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    if (isAdminRoute) {\n      // Admin routes: only allow same-origin requests (no CORS wildcard)\n      if (origin && origin === allowedOrigin) {\n        res.setHeader('Access-Control-Allow-Origin', origin);\n      }\n      // If no match, omit the header entirely — browser blocks the request\n    } else {\n      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    }\n    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n\n    if (req.method === 'OPTIONS') {\n      res.writeHead(204);\n      res.end();\n      return;\n    }\n\n    const url = req.url || '/';\n    const [pathname, queryString] = url.split('?');\n    const route = parseRoute(pathname ?? '');\n\n    // Unauthenticated endpoints\n    if (pathname === '/health' && req.method === 'GET') {\n      handleHealth(res, pool, oauth, getEventProcessorHealth, database, tenantDbManager);\n      return;\n    }\n\n    // Auth check for everything else — dual auth (API key + optional JWT)\n    const ctx = auth.validateAndExtractContext(req);\n    if (!ctx) {\n      res.writeHead(401, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Unauthorized' }));\n      return;\n    }\n\n    // Helper: project scoping (admin sees all, user sees own project)\n    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n\n    // Resolve tenant-specific database when available\n    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n      if (tenantDbManager && projectId) {\n        return tenantDbManager.getTenantDb(projectId);\n      }\n      return database;\n    };\n    const tenantDb = resolveDatabase(ctx.projectId);\n\n    try {\n      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n        if (requireAdmin(ctx, res)) return;\n        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n        return;\n      }\n      // --- Persona CRUD ---\n      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n        const persona = createPersonaWithDefaults({\n          ...body,\n          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n        });\n        db.upsertPersona(tenantDb, persona);\n        logger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n        json(res, 201, persona);\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { toolId: string };\n        db.linkTool(tenantDb, route.id, body.toolId);\n        logger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n        json(res, 200, { linked: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, logger), scopedProjectId, res);\n        if (!hydrated) return;\n        json(res, 200, hydrated);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        json(res, 200, persona);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deletePersona(tenantDb, route.id, scopedProjectId);\n        logger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n        json(res, 200, { deleted: true });\n      }\n      // --- Tool Definitions ---\n      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n        const tool = createToolDefinitionWithDefaults(body);\n        db.upsertToolDefinition(tenantDb, tool);\n        logger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n        json(res, 201, tool);\n      }\n      // --- Credentials ---\n      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n\n        // Require plaintext — clients must never supply pre-encrypted data\n        if (!body.plaintext || typeof body.plaintext !== 'string') {\n          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n          return;\n        }\n\n        // Reject oversized plaintext before synchronous encryption blocks the event loop\n        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n          return;\n        }\n\n        // Encryption is mandatory — reject if the key manager is unavailable\n        if (!tenantKeyManager) {\n          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n          return;\n        }\n\n        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n        delete body.encryptedData;\n        delete body.iv;\n        delete body.tag;\n\n        // Server-side encryption with per-tenant key\n        const tenantId = body.projectId || ctx.projectId || 'default';\n        const key = await tenantKeyManager.getKey(tenantId);\n        const encrypted = encrypt(body.plaintext, key);\n        body.encryptedData = encrypted.encrypted;\n        body.iv = encrypted.iv;\n        body.tag = encrypted.tag;\n        delete body.plaintext;\n\n        const cred = db.createCredential(tenantDb, body);\n        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n        json(res, 201, cred);\n      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n        // Strip encrypted data from response\n        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n        db.linkCredential(tenantDb, route.id, body.credentialId);\n        logger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route.id, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n        json(res, 200, { linked: true });\n      }\n      // --- Event Subscriptions ---\n      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const sub = db.createSubscription(tenantDb, body);\n        json(res, 201, sub);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        db.updateSubscription(tenantDb, route.id, body);\n        const updated = db.getSubscription(tenantDb, route.id);\n        json(res, 200, updated);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deleteSubscription(tenantDb, route.id);\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n      }\n      // --- Triggers (delegated to triggerHttpHandlers) ---\n      else if (route && tenantDb && (\n        route.resource === 'triggers' ||\n        (route.resource === 'personas' && route.subResource === 'triggers')\n      )) {\n        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n        return;\n      }\n      // --- Events ---\n      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const events = db.listEvents(tenantDb, {\n          eventType: params.get('eventType') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, events);\n      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const event = db.publishEvent(tenantDb, body);\n        json(res, 201, event);\n      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n        if (updated) {\n          json(res, 200, updated);\n        } else {\n          res.writeHead(404, { 'Content-Type': 'application/json' });\n          res.end(JSON.stringify({ error: 'Event not found' }));\n        }\n      }\n      // --- Webhooks ---\n      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n        const personaId = route.id;\n        const body = await readBody(req);\n        const event = db.publishEvent(tenantDb, {\n          eventType: 'webhook_received',\n          sourceType: 'webhook',\n          sourceId: personaId,\n          targetPersonaId: personaId,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- GitLab Webhook ---\n      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n        const body = await readBody(req);\n        let parsed: Record<string, unknown> = {};\n        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n        const event = db.publishEvent(tenantDb, {\n          eventType: `gitlab_${objectKind}`,\n          sourceType: 'gitlab',\n          sourceId: projectPath ?? null,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- Executions ---\n      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const executions = db.listExecutions(tenantDb, {\n          personaId: params.get('personaId') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, executions);\n      }\n      // --- Existing execution endpoints ---\n      else if (pathname === '/api/status' && req.method === 'GET') {\n        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n      } else if (pathname === '/api/execute' && req.method === 'POST') {\n        await handleExecute(req, res, dispatcher, logger, ctx);\n      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n        handleCancelExecution(res, dispatcher, route.id);\n      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n        const executionId = route.id;\n        const params = new URLSearchParams(queryString || '');\n        const of