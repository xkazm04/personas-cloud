[2026-03-18T12:30:45.569Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FsXf7SMRP9hub3EKZtYPtA","type":"tool_result","content":"     1→import { WebSocketServer, WebSocket } from 'ws';\n     2→import https from 'node:https';\n     3→import crypto from 'node:crypto';\n     4→import fs from 'node:fs';\n     5→import {\n     6→  parseWorkerMessage,\n     7→  serializeMessage,\n     8→  type WorkerMessage,\n     9→  type OrchestratorMessage,\n    10→  type ExecAssign,\n    11→  type ExecStdout,\n    12→  type ExecStderr,\n    13→  type ExecComplete,\n    14→  type ExecProgress,\n    15→  type WorkerEvent,\n    16→  type WorkerBusy,\n    17→  type WorkerInfo,\n    18→} from '@dac-cloud/shared';\n    19→import type { Logger } from 'pino';\n    20→import type { IncomingMessage } from 'node:http';\n    21→import type { TlsConfig } from './tls.js';\n    22→\n    23→/** Typed event map for WorkerPool → Dispatcher communication. */\n    24→export interface WorkerPoolEvents {\n    25→  'worker-connected': (info: WorkerInfo) => void;\n    26→  'worker-disconnected': (workerId: string, executionId: string | undefined) => void;\n    27→  'worker-ready': (workerId: string) => void;\n    28→  'stdout': (workerId: string, msg: ExecStdout) => void;\n    29→  'stderr': (workerId: string, msg: ExecStderr) => void;\n    30→  'complete': (workerId: string, msg: ExecComplete) => void;\n    31→  'persona-event': (workerId: string, msg: WorkerEvent) => void;\n    32→  'progress': (workerId: string, msg: ExecProgress) => void;\n    33→  'busy': (workerId: string, msg: WorkerBusy) => void;\n    34→}\n    35→\n    36→const HEARTBEAT_INTERVAL_MS = 30_000;\n    37→const HEARTBEAT_TIMEOUT_MS = 90_000;\n    38→\n    39→/** Constant-time string comparison to prevent timing side-channel attacks on token validation. */\n    40→function timingSafeTokenEqual(a: string, b: string): boolean {\n    41→  const bufA = Buffer.from(a, 'utf8');\n    42→  const bufB = Buffer.from(b, 'utf8');\n    43→  if (bufA.length !== bufB.length) {\n    44→    // Compare against self to maintain constant timing, then return false\n    45→    crypto.timingSafeEqual(bufA, bufA);\n    46→    return false;\n    47→  }\n    48→  return crypto.timingSafeEqual(bufA, bufB);\n    49→}\n    50→\n    51→interface WorkerEntry {\n    52→  ws: WebSocket;\n    53→  info: WorkerInfo;\n    54→  heartbeatTimer?: ReturnType<typeof setInterval>;\n    55→}\n    56→\n    57→export class WorkerPool {\n    58→  private workers = new Map<string, WorkerEntry>();\n    59→  private idleWorkers = new Set<string>();\n    60→  private wss: WebSocketServer | null = null;\n    61→  private allowedDigests: string[];\n    62→  private rejectUnverified: boolean;\n    63→\n    64→  // Typed listener storage — one array per event name\n    65→  private listeners: { [K in keyof WorkerPoolEvents]?: WorkerPoolEvents[K][] } = {};\n    66→\n    67→  constructor(\n    68→    private expectedWorkerToken: string,\n    69→    private logger: Logger,\n    70→    opts?: { allowedDigests?: string[]; rejectUnverified?: boolean },\n    71→  ) {\n    72→    this.allowedDigests = opts?.allowedDigests ?? [];\n    73→    this.rejectUnverified = opts?.rejectUnverified ?? false;\n    74→  }\n    75→\n    76→  /** Register a typed event listener. */\n    77→  on<K extends keyof WorkerPoolEvents>(event: K, listener: WorkerPoolEvents[K]): this {\n    78→    if (!this.listeners[event]) {\n    79→      this.listeners[event] = [];\n    80→    }\n    81→    this.listeners[event]!.push(listener);\n    82→    return this;\n    83→  }\n    84→\n    85→  /** Emit a typed event. */\n    86→  private emit<K extends keyof WorkerPoolEvents>(event: K, ...args: Parameters<WorkerPoolEvents[K]>): void {\n    87→    const fns = this.listeners[event];\n    88→    if (fns) {\n    89→      for (const fn of fns) {\n    90→        (fn as (...a: Parameters<WorkerPoolEvents[K]>) => void)(...args);\n    91→      }\n    92→    }\n    93→  }\n    94→\n    95→  listen(port: number, tlsConfig?: TlsConfig): void {\n    96→    if (tlsConfig?.enabled) {\n    97→      const httpsServer = https.createServer({\n    98→        cert: fs.readFileSync(tlsConfig.certPath),\n    99→        key: fs.readFileSync(tlsConfig.keyPath),\n   100→        ca: tlsConfig.caPath ? fs.readFileSync(tlsConfig.caPath) : undefined,\n   101→        requestCert: tlsConfig.requireClientCert,\n   102→        rejectUnauthorized: tlsConfig.requireClientCert,\n   103→      });\n   104→      this.wss = new WebSocketServer({ server: httpsServer });\n   105→      httpsServer.listen(port);\n   106→      this.logger.info({ port, tls: true, mTLS: tlsConfig.requireClientCert }, 'Worker pool listening (WSS)');\n   107→    } else {\n   108→      this.wss = new WebSocketServer({ port });\n   109→      this.logger.info({ port, tls: false }, 'Worker pool listening (WS — plaintext)');\n   110→    }\n   111→\n   112→    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n   113→      this.logger.info({ remoteAddr: req.socket.remoteAddress }, 'Worker connection attempt');\n   114→\n   115→      // Validate worker token from Authorization header (timing-safe comparison)\n   116→      const authHeader = req.headers.authorization;\n   117→      const token = authHeader?.startsWith('Bearer ') ? authHeader.slice(7) : null;\n   118→      if (!token || !timingSafeTokenEqual(token, this.expectedWorkerToken)) {\n   119→        this.logger.warn({ remoteAddr: req.socket.remoteAddress }, 'Worker rejected: invalid token');\n   120→        ws.close(1008, 'Invalid worker token');\n   121→        return;\n   122→      }\n   123→\n   124→      this.handleConnection(ws);\n   125→    });\n   126→\n   127→    this.wss.on('error', (err) => {\n   128→      this.logger.error({ err }, 'WebSocket server error');\n   129→    });\n   130→  }\n   131→\n   132→  private handleConnection(ws: WebSocket): void {\n   133→    let workerId: string | null = null;\n   134→\n   135→    const connectionTimeout = setTimeout(() => {\n   136→      if (!workerId) {\n   137→        this.logger.warn('Worker did not send hello within timeout, closing');\n   138→        ws.close(1008, 'Hello timeout');\n   139→      }\n   140→    }, 10_000);\n   141→\n   142→    ws.on('message', (raw: Buffer) => {\n   143→      const msg = parseWorkerMessage(raw.toString());\n   144→      if (!msg) {\n   145→        this.logger.warn('Invalid message from worker');\n   146→        return;\n   147→      }\n   148→\n   149→      if (msg.type === 'hello') {\n   150→        clearTimeout(connectionTimeout);"}]},"parent_tool_use_id":"toolu_01AWZyUJpTDFpjUbSSgeFm47","session_id":"4da3f18a-d7fc-4a07-a959-b6a153b41c3f","uuid":"57a7b291-0551-4fb2-8869-6f23b9528ee8","timestamp":"2026-03-18T12:30:45.492Z"}
