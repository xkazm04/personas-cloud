[2026-03-18T12:30:27.609Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014JHK7EtSziT2FpcxyCGj5B","type":"tool_result","content":"     1→import type { Logger } from 'pino';\n     2→import { getTableSpec, isEphemeral } from '@dac-cloud/shared';\n     3→import type { EphemeralTableSpec } from '@dac-cloud/shared';\n     4→import type { AuditLog } from './auditLog.js';\n     5→\n     6→// Derive retention constraints from the table registry — single source of truth\n     7→const auditSpec = getTableSpec('audit_events');\n     8→if (!auditSpec || !isEphemeral(auditSpec)) {\n     9→  throw new Error('audit_events must be registered as ephemeral in TABLE_REGISTRY');\n    10→}\n    11→const _auditSpec = auditSpec as EphemeralTableSpec;\n    12→\n    13→/** Minimum allowed retention to prevent accidental wipe of the compliance trail. */\n    14→export const MIN_AUDIT_RETENTION_DAYS = _auditSpec.minRetentionDays ?? 90;\n    15→\n    16→/** Maximum fraction of rows a single purge cycle may delete (safety cap). */\n    17→const MAX_PURGE_FRACTION = _auditSpec.maxPurgeFraction ?? 0.8;\n    18→\n    19→/** Rows deleted per chunk to keep WAL size bounded during purge. */\n    20→const PURGE_CHUNK_SIZE = 5000;\n    21→\n    22→/**\n    23→ * Manages retention / purge lifecycle for the audit log.\n    24→ *\n    25→ * Separated from AuditLog so that the log itself enforces append-only\n    26→ * semantics structurally — only this class can delete audit rows.\n    27→ */\n    28→export class AuditRetentionPolicy {\n    29→  private purgeTimer: NodeJS.Timeout | null = null;\n    30→\n    31→  constructor(\n    32→    private auditLog: AuditLog,\n    33→    private retentionDays: number,\n    34→    private logger: Logger,\n    35→  ) {\n    36→    if (!Number.isFinite(retentionDays) || retentionDays < MIN_AUDIT_RETENTION_DAYS) {\n    37→      throw new Error(\n    38→        `auditRetentionDays must be >= ${MIN_AUDIT_RETENTION_DAYS}, got ${retentionDays}`,\n    39→      );\n    40→    }\n    41→  }\n    42→\n    43→  /** Delete audit events older than retentionDays with volume safety cap. */\n    44→  async purgeOld(): Promise<number> {\n    45→    const cutoff = new Date(Date.now() - this.retentionDays * 86_400_000).toISOString();\n    46→\n    47→    // Pre-purge sanity check: refuse to delete more than MAX_PURGE_FRACTION of all rows\n    48→    const total = this.auditLog.countEvents();\n    49→    const candidates = this.auditLog.countEvents(cutoff);\n    50→\n    51→    if (total > 0 && candidates / total > MAX_PURGE_FRACTION) {\n    52→      this.logger.error(\n    53→        { total, candidates, cutoff, maxFraction: MAX_PURGE_FRACTION },\n    54→        'Audit purge aborted: deletion would exceed safety cap',\n    55→      );\n    56→      return 0;\n    57→    }\n    58→\n    59→    const totalDeleted = await this.auditLog.purgeOlderThan(cutoff, PURGE_CHUNK_SIZE);\n    60→    if (totalDeleted > 0) {\n    61→      this.logger.info({ purged: totalDeleted, cutoff }, 'Purged old audit events');\n    62→    }\n    63→    return totalDeleted;\n    64→  }\n    65→\n    66→  /** Start daily purge timer. Returns the timer for cleanup. */\n    67→  startDailyPurge(): NodeJS.Timeout {\n    68→    this.purgeTimer = setInterval(() => {\n    69→      this.purgeOld().catch((err) => {\n    70→        this.logger.error({ err }, 'Audit purge failed');\n    71→      });\n    72→    }, 24 * 60 * 60 * 1000);\n    73→    return this.purgeTimer;\n    74→  }\n    75→\n    76→  close(): void {\n    77→    if (this.purgeTimer) clearInterval(this.purgeTimer);\n    78→  }\n    79→}\n    80→"}]},"parent_tool_use_id":"toolu_01AWZyUJpTDFpjUbSSgeFm47","session_id":"4da3f18a-d7fc-4a07-a959-b6a153b41c3f","uuid":"a2d871c6-edb4-49c2-9df8-54820242803c","timestamp":"2026-03-18T12:30:27.339Z"}
