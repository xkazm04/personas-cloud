xTurns } : {}),\n   496→      },\n   497→    };\n   498→\n   499→    // Track in-memory for real-time streaming (preserve retry count across re-dispatches)\n   500→    const prevRetries = this.active.get(request.executionId)?.disconnectRetries ?? 0;\n   501→    this.active.set(request.executionId, {\n   502→      workerId,\n   503→      startedAt: Date.now(),\n   504→      output: [],\n   505→      status: 'running',\n   506→      request,\n   507→      disconnectRetries: prevRetries,\n   508→    });\n   509→\n   510→    // Mark running in DB\n   511→    if (dispatchDb) {\n   512→      try {\n   513→        db.updateExecution(dispatchDb, request.executionId, {\n   514→          status: 'running',\n   515→          startedAt: new Date().toISOString(),\n   516→        });\n   517→      } catch { /* best effort */ }\n   518→    }\n   519→\n   520→    const sent = this.pool.assign(workerId, assignment);\n   521→    if (!sent) {\n   522→      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n   523→      this.active.delete(request.executionId);\n   524→      if (dispatchDb) {\n   525→        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch { /* best effort */ }\n   526→      }\n   527→      // Re-queue and retry dispatch — another idle worker may be available\n   528→      this.queue.unshift({ request, receivedAt: Date.now() });\n   529→      this.processQueue();\n   530→    } else {\n   531→      this.logger.info({\n   532→        workerId,\n   533→        executionId: request.executionId,\n   534→        personaId: request.personaId,\n   535→      }, 'Execution dispatched to worker');\n   536→    }\n   537→  }\n   538→\n   539→  cancelExecution(executionId: string): boolean {\n   540→    const exec = this.active.get(executionId);\n   541→    if (!exec || exec.status !== 'running') return false;\n   542→\n   543→    return this.pool.send(exec.workerId, {\n   544→      type: 'cancel',\n   545→      executionId,\n   546→    });\n   547→  }\n   548→\n   549→  getQueueLength(): number {\n   550→    return this.queue.length;\n   551→  }\n   552→\n   553→  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n   554→    return Array.from(this.active.entries())\n   555→      .filter(([, e]) => e.status === 'running')\n   556→      .map(([executionId, e]) => ({\n   557→        executionId,\n   558→        workerId: e.workerId,\n   559→        startedAt: e.startedAt,\n   560→      }));\n   561→  }\n   562→\n   563→  /**\n   564→   * Get execution state. Tries in-memory first (for real-time output),\n   565→   * then falls back to DB for completed/historical executions.\n   566→   */\n   567→  getExecution(executionId: string): ActiveExecution | null {\n   568→    // Check in-memory active executions first\n   569→    const active = this.active.get(executionId);\n   570→    if (active) return active;\n   571→\n   572→    const execDb = this.resolveDbForExecution(executionId);\n   573→    if (execDb) {\n   574→      const dbExec = db.getExecution(execDb, executionId);\n   575→      if (dbExec) {\n   576→        return {\n   577→          workerId: '',\n   578→          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n   579→          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n   580→          status: dbExec.status as ActiveExecution['status'],\n   581→          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n   582→          durationMs: dbExec.durationMs ?? undefined,\n   583→          sessionId: dbExec.claudeSessionId ?? undefined,\n   584→          totalCostUsd: dbExec.costUsd ?? undefined,\n   585→        };\n   586→      }\n   587→    }\n   588→\n   589→    return null;\n   590→  }\n   591→\n   592→  getExecutionOutput(executionId: string): string[] | null {\n   593→    const exec = this.getExecution(executionId);\n   594→    return exec?.output ?? null;\n   595→  }\n   596→\n   597→  /** Shared handler for stdout/stderr output chunks. */\n   598→  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n   599→    const line = prefix ? `${prefix}${chunk}` : chunk;\n   600→\n   601→    const exec = this.active.get(executionId);\n   602→    if (exec) {\n   603→      exec.output.push(line);\n   604→    }\n   605→\n   606→    this.bufferOutput(executionId, line + '\\n');\n   607→\n   608→    // Forward stdout to Kafka (stderr is not forwarded)\n   609→    if (!prefix) {\n   610→      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n   611→        executionId,\n   612→        chunk,\n   613→        timestamp,\n   614→      }), executionId).catch(err => {\n   615→        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n   616→      });\n   617→    }\n   618→  }\n   619→\n   620→  /** Buffer an output chunk for batched DB write. */\n   621→  private bufferOutput(executionId: string, chunk: string): void {\n   622→    let buf = this.outputBuffers.get(executionId);\n   623→    if (!buf) {\n   624→      buf = [];\n   625→      this.outputBuffers.set(executionId, buf);\n   626→    }\n   627→    buf.push(chunk);\n   628→  }\n   629→\n   630→  /** Flush buffered output for a specific execution to DB. */\n   631→  private flushOutputForExecution(executionId: string): void {\n   632→    const buf = this.outputBuffers.get(executionId);\n   633→    if (!buf || buf.length === 0) return;\n   634→\n   635→    const combined = buf.join('');\n   636→    this.outputBuffers.delete(executionId);\n   637→\n   638→    const outputDb = this.resolveDbForExecution(executionId);\n   639→    if (outputDb) {\n   640→      try { db.appendOutput(outputDb, executionId, combined); } catch { /* best effort */ }\n   641→    }\n   642→  }\n   643→\n   644→  /** Flush all buffered output across all executions to DB. */\n   645→  private flushOutputBuffers(): void {\n   646→    for (const executionId of this.outputBuffers.keys()) {\n   647→      this.flushOutputForExecution(executionId);\n   648→    }\n   649→  }\n   650→\n   651→  shutdown(): void {\n   652→    clearInterval(this.outputFlushTimer);\n   653→    this.flushOutputBuffers();\n   654→  }\n   655→}\n   656→"}]},"parent_tool_use_id":"toolu_01AWZyUJpTDFpjUbSSgeFm47","session_id":"4da3f18a-d7fc-4a07-a959-b6a153b41c3f","uuid":"2b252435-3a65-4a45-9340-f87ed752e072","timestamp":"2026-03-18T12:30:29.489Z"}
