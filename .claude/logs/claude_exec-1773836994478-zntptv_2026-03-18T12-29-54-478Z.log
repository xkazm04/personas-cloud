[2026-03-18T12:30:32.620Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01292KZFq6Vs72mTRNL8Lmb9","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    11→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    12→import type { TenantDbManager } from './tenantDbManager.js';\n    13→import type { TenantKeyManager } from './tenantKeyManager.js';\n    14→import type { AuditLog } from './auditLog.js';\n    15→import type { Logger } from 'pino';\n    16→import * as db from './db/index.js';\n    17→import { readBody, json } from './httpUtils.js';\n    18→\n    19→export function createHttpApi(\n    20→  auth: Auth,\n    21→  dispatcher: Dispatcher,\n    22→  pool: WorkerPool,\n    23→  tokenManager: TokenManager,\n    24→  oauth: OAuthManager,\n    25→  logger: Logger,\n    26→  database?: Database.Database,\n    27→  tenantDbManager?: TenantDbManager,\n    28→  tenantKeyManager?: TenantKeyManager,\n    29→  auditLog?: AuditLog,\n    30→): http.Server {\n    31→  const server = http.createServer(async (req, res) => {\n    32→    // Security headers\n    33→    res.setHeader('X-Content-Type-Options', 'nosniff');\n    34→\n    35→    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    36→    const origin = req.headers.origin ?? '';\n    37→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    38→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    39→    if (isAdminRoute) {\n    40→      // Admin routes: only allow same-origin requests (no CORS wildcard)\n    41→      if (origin && origin === allowedOrigin) {\n    42→        res.setHeader('Access-Control-Allow-Origin', origin);\n    43→      }\n    44→      // If no match, omit the header entirely — browser blocks the request\n    45→    } else {\n    46→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    47→    }\n    48→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    49→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n    50→\n    51→    if (req.method === 'OPTIONS') {\n    52→      res.writeHead(204);\n    53→      res.end();\n    54→      return;\n    55→    }\n    56→\n    57→    const url = req.url || '/';\n    58→    const [pathname, queryString] = url.split('?');\n    59→    const route = parseRoute(pathname ?? '');\n    60→\n    61→    // Unauthenticated endpoints\n    62→    if (pathname === '/health' && req.method === 'GET') {\n    63→      handleHealth(res, pool, oauth);\n    64→      return;\n    65→    }\n    66→\n    67→    // Auth check for everything else — dual auth (API key + optional JWT)\n    68→    const ctx = auth.validateAndExtractContext(req);\n    69→    if (!ctx) {\n    70→      res.writeHead(401, { 'Content-Type': 'application/json' });\n    71→      res.end(JSON.stringify({ error: 'Unauthorized' }));\n    72→      return;\n    73→    }\n    74→\n    75→    // Helper: project scoping (admin sees all, user sees own project)\n    76→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n    77→\n    78→    // Resolve tenant-specific database when available\n    79→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n    80→      if (tenantDbManager && projectId) {\n    81→        return tenantDbManager.getTenantDb(projectId);\n    82→      }\n    83→      return database;\n    84→    };\n    85→    const tenantDb = resolveDatabase(ctx.projectId);\n    86→\n    87→    try {\n    88→      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n    89→      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n    90→        if (requireAdmin(ctx, res)) return;\n    91→        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n    92→        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n    93→        return;\n    94→      }\n    95→      // --- Persona CRUD ---\n    96→      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n    97→        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n    98→      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n    99→        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   100→        const persona = createPersonaWithDefaults({\n   101→          ...body,\n   102→          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   103→        });\n   104→        db.upsertPersona(tenantDb, persona);\n   105→        logger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   106→        json(res, 201, persona);\n   107→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n   108→        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n   109→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n   110→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   111→        if (!persona) return;\n   112→        const body = JSON.parse(await readBody(req)) as { toolId: string };\n   113→        db.linkTool(tenantDb, route.id, body.toolId);\n   114→        logger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   115→        json(res, 200, { linked: true });\n   116→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n   117→        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, logger), scopedProjectId, res);\n   118→        if (!hydrated) return;\n   119→        json(res, 200, hydrated);\n   120→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n   121→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   122→        if (!persona) return;\n   123→        json(res, 200, persona);\n   124→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   125→        db.deletePersona(tenantDb, route.id, scopedProjectId);\n   126→        logger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   127→        json(res, 200, { deleted: true });\n   128→      }\n   129→      // --- Tool Definitions ---\n   130→      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n   131→        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   132→        const tool = createToolDefinitionWithDefaults(body);\n   133→        db.upsertToolDefinition(tenantDb, tool);\n   134→        logger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   135→        json(res, 201, tool);\n   136→      }\n   137→      // --- Credentials ---\n   138→      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n   139→        const body = JSON.parse(await readBody(req));\n   140→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   141→\n   142→        // Require plaintext — clients must never supply pre-encrypted data\n   143→        if (!body.plaintext || typeof body.plaintext !== 'string') {\n   144→          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   145→          return;\n   146→        }\n   147→\n   148→        // Reject oversized plaintext before synchronous encryption blocks the event loop\n   149→        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   150→          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   151→          return;\n   152→        }\n   153→\n   154→        // Encryption is mandatory — reject if the key manager is unavailable\n   155→        if (!tenantKeyManager) {\n   156→          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   157→          return;\n   158→        }\n   159→\n   160→        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n   161→        delete body.encryptedData;\n   162→        delete body.iv;\n   163→        delete body.tag;\n   164→\n   165→        // Server-side encryption with per-tenant key\n   166→        const tenantId = body.projectId || ctx.projectId || 'default';\n   167→        const key = await tenantKeyManager.getKey(tenantId);\n   168→        const encrypted = encrypt(body.plaintext, key);\n   169→        body.encryptedData = encrypted.encrypted;\n   170→        body.iv = encrypted.iv;\n   171→        body.tag = encrypted.tag;\n   172→        delete body.plaintext;\n   173→\n   174→        const cred = db.createCredential(tenantDb, body);\n   175→        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n   176→        logger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   177→        json(res, 201, cred);\n   178→      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   179→        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n   180→        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   181→        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   182→        logger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   183→        json(res, 200, { deleted: true });\n   184→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n   185→        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n   186→        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   187→        // Strip encrypted data from response\n   188→        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   189→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n   190→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   191→        if (!persona) return;\n   192→        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   193→        db.linkCredential(tenantDb, route.id, body.credentialId);\n   194→        json(res, 200, { linked: true });\n   195→      }\n   196→      // --- Event Subscriptions ---\n   197→      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n   198→        const body = JSON.parse(await readBody(req));\n   199→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   200→        const missing: string[] = [];"}]},"parent_tool_use_id":"toolu_01AWZyUJpTDFpjUbSSgeFm47","session_id":"4da3f18a-d7fc-4a07-a959-b6a153b41c3f","uuid":"017e4a95-7160-4d4c-ab82-3616c9bb3d62","timestamp":"2026-03-18T12:30:32.539Z"}
