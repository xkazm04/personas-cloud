  35→  /** How many times this execution has been re-queued after a worker disconnect. */\n    36→  disconnectRetries?: number;\n    37→}\n    38→\n    39→const OUTPUT_FLUSH_INTERVAL_MS = 500;\n    40→\n    41→export class Dispatcher {\n    42→  private queue: QueuedExecution[] = [];\n    43→  // In-memory map for real-time output + cancel routing (active executions only)\n    44→  private active = new Map<string, ActiveExecution>();\n    45→  private tenantDbManager: TenantDbManager | null = null;\n    46→  private masterKey: Buffer | null = null;\n    47→  private tenantKeyManager: TenantKeyManager | null = null;\n    48→  private auditLog: AuditLog | null = null;\n    49→  // Maps executionId → projectId for DB resolution during callbacks\n    50→  private executionTenant = new Map<string, string>();\n    51→  // Batched output buffers: executionId → pending chunks\n    52→  private outputBuffers = new Map<string, string[]>();\n    53→  private outputFlushTimer: NodeJS.Timeout;\n    54→  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n    55→  private dispatching = false;\n    56→\n    57→  constructor(\n    58→    private pool: WorkerPool,\n    59→    private tokenManager: TokenManager,\n    60→    private oauth: OAuthManager | null,\n    61→    private kafka: KafkaClient,\n    62→    private logger: Logger,\n    63→  ) {\n    64→    // Periodic flush of batched output to DB\n    65→    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n    66→\n    67→    // When a worker becomes ready, try to dispatch queued work\n    68→    this.pool.on('worker-ready', () => {\n    69→      this.processQueue();\n    70→    });\n    71→\n    72→    // When a worker connects, try to dispatch\n    73→    this.pool.on('worker-connected', () => {\n    74→      this.processQueue();\n    75→    });\n    76→\n    77→    // Track stdout for execution output\n    78→    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n    79→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    80→    });\n    81→\n    82→    // Track stderr for debugging failed executions\n    83→    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n    84→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n    85→      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    86→    });\n    87→\n    88→    // Handle execution completion\n    89→    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n    90→      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n    91→        executionId: msg.executionId,\n    92→        status: msg.status,\n    93→        exitCode: msg.exitCode,\n    94→        durationMs: msg.durationMs,\n    95→        sessionId: msg.sessionId,\n    96→        totalCostUsd: msg.totalCostUsd,\n    97→      }), msg.executionId).catch(err => {\n    98→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n    99→      });\n   100→\n   101→      // Flush any remaining buffered output before persisting completion\n   102→      this.flushOutputForExecution(msg.executionId);\n   103→\n   104→      // Update in-memory\n   105→      const exec = this.active.get(msg.executionId);\n   106→      if (exec) {\n   107→        exec.status = msg.status;\n   108→        exec.completedAt = Date.now();\n   109→        exec.exitCode = msg.exitCode;\n   110→        exec.durationMs = msg.durationMs;\n   111→        exec.sessionId = msg.sessionId;\n   112→        exec.totalCostUsd = msg.totalCostUsd;\n   113→        // Remove from active after a short delay (allow polling to pick up final state)\n   114→        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n   115→      }\n   116→\n   117→      // Persist to DB\n   118→      const completeDb = this.resolveDbForExecution(msg.executionId);\n   119→      if (completeDb) {\n   120→        try {\n   121→          db.updateExecution(completeDb, msg.executionId, {\n   122→            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n   123→            completedAt: new Date().toISOString(),\n   124→            durationMs: msg.durationMs,\n   125→            claudeSessionId: msg.sessionId,\n   126→            costUsd: msg.totalCostUsd ?? 0,\n   127→          });\n   128→        } catch (err) {\n   129→          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n   130→        }\n   131→      }\n   132→\n   133→      // Clean up tenant mapping after completion delay\n   134→      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n   135→\n   136→      // Process next queued item\n   137→      this.processQueue();\n   138→    });\n   139→\n   140→    // Track execution progress\n   141→    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n   142→      const exec = this.active.get(msg.executionId);\n   143→      if (exec) {\n   144→        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n   145→      }\n   146→      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n   147→        executionId: msg.executionId,\n   148→        phase: msg.phase,\n   149→        percent: msg.percent,\n   150→        detail: msg.detail,\n   151→        timestamp: msg.timestamp,\n   152→      }), msg.executionId).catch(err => {\n   153→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n   154→      });\n   155→    });\n   156→\n   157→    // Forward persona events to Kafka\n   158→    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n   159→      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n   160→        executionId: msg.executionId,\n   161→        eventType: msg.eventType,\n   162→        payload: msg.payload,\n   163→        timestamp: Date.now(),\n   164→      }), msg.executionId).catch(err => {\n   165→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n   166→      });\n   167→    });\n   168→\n   169→    // Handle worker busy nack — re-queue the rejected execution\n   170→    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n   171→      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n   172→      const exec = this.active.get(msg.executionId);\n   173→      if (exec?.request) {\n   174→        const request = exec.request;\n   175→        this.active.delete(msg.executionId);\n   176→        // Mark as queued in DB\n   177→        const reqDb = this.resolveDbForExecution(msg.executionId);\n   178→        if (reqDb) {\n   179→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch { /* best effort */ }\n   180→        }\n   181→        this.queue.unshift({ request, receivedAt: Date.now() });\n   182→        this.processQueue();\n   183→      } else {\n   184→        // Fallback: reconstruct from DB if request was not stored (should not happen)\n   185→        this.active.delete(msg.executionId);\n   186→        const projectId = this.executionTenant.get(msg.executionId) || 'default';\n   187→        const reqDb = this.resolveDb(projectId);\n   188→        if (reqDb) {\n   189→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch { /* best effort */ }\n   190→        }\n   191→        const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n   192→        if (dbExec) {\n   193→          this.queue.unshift({\n   194→            request: {\n   195→              executionId: msg.executionId,\n   196→              personaId: dbExec.personaId,\n   197→              prompt: dbExec.inputData || '',\n   198→              projectId,\n   199→              config: { timeoutMs: 300_000 },\n   200→            },\n   201→            receivedAt: Date.now(),\n   202→          });\n   203→          this.processQueue();\n   204→        }\n   205→      }\n   206→    });\n   207→\n   208→    // Handle worker disconnect during execution — re-queue if retries remain\n   209→    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n   210→      if (executionId) {\n   211→        const exec = this.active.get(executionId);\n   212→        const retries = exec?.disconnectRetries ?? 0;\n   213→\n   214→        if (exec?.request && retries < MAX_DISCONNECT_RETRIES) {\n   215→          // Re-queue for retry\n   216→          const nextRetry = retries + 1;\n   217→          this.logger.warn({ executionId, retry: nextRetry, maxRetries: MAX_DISCONNECT_RETRIES }, 'Worker disconnected during execution, re-queuing');\n   218→\n   219→          // Clear the active entry so dispatchToWorker can create a fresh one\n   220→          this.active.delete(executionId);\n   221→\n   222→          // Mark as queued in DB\n   223→          const disconnDb = this.resolveDbForExecution(executionId);\n   224→          if (disconnDb) {\n   225→            try {\n   226→              db.updateExecution(disconnDb, executionId, {\n   227→                status: 'queued',\n   228→                errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n   229→              });\n   230→            } catch { /* best effort */ }\n   231→          }\n   232→\n   233→          // Temporarily store the retry count so dispatchToWorker picks it up\n   234→          const request = exec.request;\n   235→          // Create a placeholder active entry to carry retry count across re-dispatch\n   236→          this.active.set(executionId, {\n   237→            workerId: '',\n   238→            startedAt: 0,\n   239→            output: [],\n   240→            status: 'running',\n   241→            request,\n   242→            disconnectRetries: nextRetry,\n   243→          });\n   244→\n   245→          this.queue.unshift({ request, receivedAt: Date.now() });\n   246→          this.processQueue();\n   247→        } else {\n   248→          // Retries exhausted or no request stored — permanent failure\n   249→          this.logger.error({ executionId, retries }, 'Worker disconnected during execution, retries exhausted');\n   250→          if (exec) {\n   251→            exec.status = 'failed';\n   252→            exec.completedAt = Date.now();\n   253→            setTimeout(() => this.active.delete(executionId), 30_000);\n   254→          }\n   255→\n   256→          const disconnDb = this.resolveDbForExecution(executionId);\n   257→          if (disconnDb) {\n   258→            try {\n   259→              db.updateExecution(disconnDb, executionId, {\n   260→                status: 'failed',\n   261→                errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n   262→                completedAt: new Date().toISOString(),\n   263→              });\n   264→            } catch { /* best effort */ }\n   265→          }\n   266→          this.executionTenant.delete(executionId);\n   267→\n   268→          this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   269→            executionId,\n   270→            status: 'failed',\n   271→            error: 'Worker disconnected (retries exhausted)',\n   272→            durationMs: 0,\n   273→          }), executionId).catch(() => {});\n   274→        }\n   275→      }\n   276→    });\n   277→  }\n   278→\n   279→  setTenantDbManager(mgr: TenantDbManager): void {\n   280→    this.tenantDbManager = mgr;\n   281→  }\n   282→\n   283→  async setMasterKey(masterKeyHex: string): Promise<void> {\n   284→    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n   285→  }\n   286→\n   287→  setTenantKeyManager(mgr: TenantKeyManager): void {\n   288→    this.tenantKeyManager = mgr;\n   289→  }\n   290→\n   291→  setAuditLog(log: AuditLog): void {\n   292→    this.auditLog = log;\n   293→  }\n   294→\n   295→  /** Resolve the database for a given projectId via tenant DB manager. */\n   296→  private resolveDb(projectId?: string): Database.Database | null {\n   297→    if (this.tenantDbManager && projectId) {\n   298→      return this.tenantDbManager.getTenantDb(projectId);\n   299→    }\n   300→    return null;\n   301→  }\n   302→\n   303→  /** Resolve the database for an in-flight execution by its ID. */\n   304→  private resolveDbForExecution(executionId: string): Database.Database | null {\n   305→    const projectId = this.executionTenant.get(executionId);\n   306→    return this.resolveDb(projectId);\n   307→  }\n   308→\n   309→  /**\n   310→   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   311→   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   312→   */\n   313→  private async decryptWithAudit(\n   314→    payload: EncryptedPayload,\n   315→    tenantId: string,\n   316→    resourceId: string,\n   317→    logContext: Record<string, unknown>,\n   318→    logMessage: string,\n   319→  ): Promise<string | undefined> {\n   320→    const decryptKey = this.tenantKeyManager\n   321→      ? await this.tenantKeyManager.getKey(tenantId)\n   322→      : this.masterKey;\n   323→    if (!decryptKey) return undefined;\n   324→\n   325→    try {\n   326→      const decrypted = decrypt(payload, decryptKey);\n   327→      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n   328→      return decrypted;\n   329→    } catch (err) {\n   330→      const reason = err instanceof Error ? err.message : String(err);\n   331→      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n   332→      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: reason }); } catch { /* logged inside record() */ }\n   333→      return undefined;\n   334→    }\n   335→  }\n   336→\n   337→  submit(request: ExecRequest): void {\n   338→    this.logger.info({\n   339→      executionId: request.executionId,\n   340→      personaId: request.personaId,\n   341→    }, 'Execution submitted');\n   342→\n   343→    // Track which tenant owns this execution (for callback DB resolution)\n   344→    const projectId = request.projectId || 'default';\n   345→    this.executionTenant.set(request.executionId, projectId);\n   346→\n   347→    // Create DB record immediately\n   348→    const submitDb = this.resolveDb(projectId);\n   349→    if (submitDb) {\n   350→      try {\n   351→        db.createExecution(submitDb, {\n   352→          id: request.executionId,\n   353→          personaId: request.personaId,\n   354→          inputData: request.prompt,\n   355→          projectId,\n   356→        });\n   357→      } catch (err) {\n   358→        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n   359→      }\n   360→    }\n   361→\n   362→    this.queue.push({ request, receivedAt: Date.now() });\n   363→    this.processQueue();\n   364→  }\n   365→\n   366→  private async processQueue(): Promise<void> {\n   367→    // Guard: only one processQueue loop runs at a time to prevent concurrent\n   368→    // calls from racing on getIdleWorker()/assign() and double-claiming a worker.\n   369→    if (this.dispatching) return;\n   370→    this.dispatching = true;\n   371→    try {\n   372→      while (this.queue.length > 0) {\n   373→        const workerId = this.pool.getIdleWorker();\n   374→        if (!workerId) {\n   375→          this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n   376→          return;\n   377→        }\n   378→\n   379→        const item = this.queue.shift()!;\n   380→        await this.dispatchToWorker(workerId, item.request);\n   381→      }\n   382→    } finally {\n   383→      this.dispatching = false;\n   384→    }\n   385→  }\n   386→\n   387→  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n   388→    // Try to get a fresh token via OAuth (auto-refreshes if near expiry)\n   389→    let claudeToken: string | null = null;\n   390→    if (this.oauth?.hasTokens()) {\n   391→      claudeToken = await this.oauth.getValidAccessToken();\n   392→      if (claudeToken) {\n   393→        this.tokenManager.storeClaudeToken(claudeToken);\n   394→      }\n   395→    }\n   396→    // Fallback to stored token\n   397→    if (!claudeToken) {\n   398→      claudeToken = this.tokenManager.getClaudeToken();\n   399→    }\n   400→    if (!claudeToken) {\n   401→      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n   402→      this.queue.unshift({ request, receivedAt: Date.now() });\n   403→      return;\n   404→    }\n   405→\n   406→    // Build environment variables for the worker\n   407→    const env: Record<string, string> = {\n   408→      ANTHROPIC_API_KEY: claudeToken,\n   409→    };\n   410→\n   411→    // If persona exists in DB, assemble prompt from persona config and inject credentials\n   412→    let prompt = request.prompt;\n   413→    const dispatchDb = this.resolveDb(request.projectId || 'default');\n   414→    const persona = dispatchDb ? db.getPersona(dispatchDb, request.personaId) : null;\n   415→    if (dispatchDb) {\n   416→      if (persona) {\n   417→        const tools = db.getToolsForPersona(dispatchDb, persona.id);\n   418→        const creds = db.listCredentialsForPersona(dispatchDb, persona.id);\n   419→\n   420→        // Decrypt credentials and inject as env vars\n   421→        const credentialHints: string[] = [];\n   422→        const tenantId = request.projectId || 'default';\n   423→        for (const cred of creds) {\n   424→          const envName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   425→          credentialHints.push(envName);\n   426→\n   427→          const decrypted = await this.decryptWithAudit(\n   428→            toEncryptedPayload(cred),\n   429→            tenantId,\n   430→            cred.id,\n   431→            { credentialId: cred.id, credentialName: cred.name },\n   432→            'Failed to decrypt credential',\n   433→          );\n   434→          if (decrypted !== undefined) {\n   435→            // Try to parse as JSON with multiple fields\n   436→            try {\n   437→              const fields = JSON.parse(decrypted) as Record<string, string>;\n   438→              for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n   439→                const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   440→                env[fieldEnvName] = String(fieldValue);\n   441→              }\n   442→            } catch {\n   443→              // Not JSON — inject as single value\n   444→              env[envName] = decrypted;\n   445→            }\n   446→          }\n   447→        }\n   448→\n   449→        const inputData = request.inputData ? (request.inputData as Record<string, unknown>) : undefined;\n   450→        prompt = assemblePrompt(persona, tools, inputData, credentialHints.length > 0 ? credentialHints : undefined);\n   451→\n   452→        // Apply inference profile or legacy model profile env overrides\n   453→        let inferenceProfile: InferenceProfile | undefined;\n   454→        if (persona.inferenceProfileId) {\n   455→          inferenceProfile = db.getInferenceProfile(dispatchDb, persona.inferenceProfileId);\n   456→        }\n   457→        if (inferenceProfile) {\n   458→          // Decrypt auth token first so resolve