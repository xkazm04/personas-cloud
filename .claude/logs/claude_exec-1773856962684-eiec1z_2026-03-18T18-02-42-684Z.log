  continue;","-      }","-      if (!trigger.personaEnabled) {","-        logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');","-        continue;","-      }","+      for (const trigger of triggers) {","+        // Skip polling triggers","+        if (trigger.triggerType === 'polling') continue;"," ","-      const triggerProjectId = projectId ?? trigger.personaProjectId;","+        try {","+          const parsedConfig = trigger.parsedConfig;","+          let eventType = 'trigger_fired';","+          let payload: string | null = null;","+          if (parsedConfig) {","+            if (parsedConfig.event_type) eventType = parsedConfig.event_type;","+            if (parsedConfig.payload) payload = JSON.stringify(parsedConfig.payload);","+          }"," ","-      // Publish event to bus","-      db.publishEvent(database, {","-        eventType,","-        sourceType: 'trigger',","-        sourceId: trigger.id,","-        targetPersonaId: trigger.personaId,","-        projectId: triggerProjectId,","-        useCaseId: trigger.useCaseId,","-        payload,","-      });","-      onEventPublished?.();","+          // Skip triggers for deleted or disabled personas","+          if (trigger.personaProjectId == null) {","+            logger.warn({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona not found (deleted?)');","+            continue;","+          }","+          if (!trigger.personaEnabled) {","+            logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');","+            continue;","+          }"," ","-      // Compute next trigger time using already-parsed config","-      const now = new Date().toISOString();","-      const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);","+          const triggerProjectId = tenantId !== 'default' ? tenantId : trigger.personaProjectId;"," ","-      db.updateTriggerTimings(database, trigger.id, now, nextTriggerAt);","+          // Publish event","+          db.publishEvent(tenantDb, {","+            eventType,","+            sourceType: 'trigger',","+            sourceId: trigger.id,","+            targetPersonaId: trigger.personaId,","+            projectId: triggerProjectId,","+            useCaseId: trigger.useCaseId,","+            payload,","+          });","+          onEventPublished?.();"," ","-      logger.info({","-        triggerId: trigger.id,","-        personaId: trigger.personaId,","-        eventType,","-        nextTriggerAt,","-      }, 'Trigger fired');","+          // Compute next trigger time and update DB","+          const now = new Date().toISOString();","+          const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);","+          db.updateTriggerTimings(tenantDb, trigger.id, now, nextTriggerAt);","+","+          // Push updated time back into heap","+          if (nextTriggerAt) {","+            heap.push({ triggerId: trigger.id, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });","+          }","+","+          logger.info({","+            triggerId: trigger.id,","+            personaId: trigger.personaId,","+            eventType,","+            nextTriggerAt,","+          }, 'Trigger fired');","+        } catch (err) {","+          logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');","+        }","+      }","     } catch (err) {","-      logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');","+      logger.error({ err, tenantId }, 'Trigger scheduler tick failed for tenant');","     }","   }"," }"]}],"originalFile":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\n\nconst MIN_DELAY_MS = 100;\nconst MAX_DELAY_MS = 60_000;\n\nexport interface TriggerSchedulerHandle {\n  /** Stop the scheduler. */\n  close(): void;\n  /** Nudge the scheduler to re-evaluate immediately (e.g. after trigger create/update). */\n  nudge(): void;\n}\n\n/**\n * Start the adaptive trigger scheduler.\n *\n * Instead of polling on a fixed interval, after each tick the scheduler queries\n * MIN(next_trigger_at) across all tenant DBs and sleeps until that time\n * (clamped to [100ms, 60s]).  This eliminates idle polling while firing\n * triggers with near-zero latency.\n */\nexport function startTriggerScheduler(\n  database: Database.Database | null,\n  logger: Logger,\n  _interval?: number, // kept for signature compat; ignored\n  tenantDbManager?: TenantDbManager,\n  onEventPublished?: () => void,\n): TriggerSchedulerHandle {\n  let timer: ReturnType<typeof setTimeout> | null = null;\n  let stopped = false;\n\n  logger.info({ minDelayMs: MIN_DELAY_MS, maxDelayMs: MAX_DELAY_MS, tenantIsolated: !!tenantDbManager }, 'Adaptive trigger scheduler started');\n\n  function scheduleTick(delayMs: number): void {\n    if (stopped) return;\n    timer = setTimeout(tick, delayMs);\n  }\n\n  function tick(): void {\n    if (stopped) return;\n    try {\n      if (tenantDbManager) {\n        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n          try {\n            triggerSchedulerTick(tenantDb, logger, projectId, onEventPublished);\n          } catch (err) {\n            logger.error({ err, projectId }, 'Trigger scheduler tick failed for tenant');\n          }\n        });\n      } else if (database) {\n        triggerSchedulerTick(database, logger, undefined, onEventPublished);\n      }\n    } catch (err) {\n      logger.error({ err }, 'Trigger scheduler tick failed');\n    }\n\n    // Compute next delay from earliest pending trigger across all DBs\n    const delayMs = computeNextDelay(database, tenantDbManager);\n    scheduleTick(delayMs);\n  }\n\n  // Kick off the first tick immediately\n  scheduleTick(0);\n\n  return {\n    close() {\n      stopped = true;\n      if (timer != null) {\n        clearTimeout(timer);\n        timer = null;\n      }\n    },\n    nudge() {\n      if (stopped) return;\n      // Cancel pending timer and fire immediately\n      if (timer != null) {\n        clearTimeout(timer);\n        timer = null;\n      }\n      scheduleTick(0);\n    },\n  };\n}\n\n/**\n * Compute how long to sleep until the next trigger fires.\n * Looks at MIN(next_trigger_at) across all available DBs.\n */\nfunction computeNextDelay(\n  database: Database.Database | null,\n  tenantDbManager?: TenantDbManager,\n): number {\n  let earliest: string | null = null;\n\n  if (tenantDbManager) {\n    const tenantIds = tenantDbManager.listTenantIds();\n    for (const id of tenantIds) {\n      try {\n        const tenantDb = tenantDbManager.getTenantDb(id);\n        const t = db.getEarliestNextTriggerTime(tenantDb);\n        if (t && (!earliest || t < earliest)) {\n          earliest = t;\n        }\n      } catch { /* skip failed tenants */ }\n    }\n  } else if (database) {\n    earliest = db.getEarliestNextTriggerTime(database);\n  }\n\n  if (!earliest) return MAX_DELAY_MS;\n\n  const deltaMs = new Date(earliest).getTime() - Date.now();\n  return Math.min(MAX_DELAY_MS, Math.max(MIN_DELAY_MS, deltaMs));\n}\n\nfunction triggerSchedulerTick(\n  database: Database.Database,\n  logger: Logger,\n  projectId?: string,\n  onEventPublished?: () => void,\n): void {\n  const triggers = db.getDueTriggersWithPersona(database);\n  if (triggers.length === 0) return;\n\n  for (const trigger of triggers) {\n    // Skip polling triggers (handled separately if needed)\n    if (trigger.triggerType === 'polling') continue;\n\n    try {\n      // Use pre-parsed typed config — no JSON.parse in the hot path\n      const parsedConfig = trigger.parsedConfig;\n\n      let eventType = 'trigger_fired';\n      let payload: string | null = null;\n      if (parsedConfig) {\n        if (parsedConfig.event_type) eventType = parsedConfig.event_type;\n        if (parsedConfig.payload) payload = JSON.stringify(parsedConfig.payload);\n      }\n\n      // Skip triggers for deleted or disabled personas (persona info from JOIN)\n      if (trigger.personaProjectId == null) {\n        logger.warn({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona not found (deleted?)');\n        continue;\n      }\n      if (!trigger.personaEnabled) {\n        logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');\n        continue;\n      }\n\n      const triggerProjectId = projectId ?? trigger.personaProjectId;\n\n      // Publish event to bus\n      db.publishEvent(database, {\n        eventType,\n        sourceType: 'trigger',\n        sourceId: trigger.id,\n        targetPersonaId: trigger.personaId,\n        projectId: triggerProjectId,\n        useCaseId: trigger.useCaseId,\n        payload,\n      });\n      onEventPublished?.();\n\n      // Compute next trigger time using already-parsed config\n      const now = new Date().toISOString();\n      const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);\n\n      db.updateTriggerTimings(database, trigger.id, now, nextTriggerAt);\n\n      logger.info({\n        triggerId: trigger.id,\n        personaId: trigger.personaId,\n        eventType,\n        nextTriggerAt,\n      }, 'Trigger fired');\n    } catch (err) {\n      logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');\n    }\n  }\n}\n"}}
