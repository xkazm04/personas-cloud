ap(a: number, b: number): void {\n    const entryA = this.heap[a]!;\n    const entryB = this.heap[b]!;\n    this.heap[a] = entryB;\n    this.heap[b] = entryA;\n    this.index.set(entryA.triggerId, b);\n    this.index.set(entryB.triggerId, a);\n  }\n}\n","structuredPatch":[],"originalFile":null}}
