t((tenantDb, projectId) => {\n    46→          try {\n    47→            triggerSchedulerTick(tenantDb, logger, projectId, onEventPublished);\n    48→          } catch (err) {\n    49→            logger.error({ err, projectId }, 'Trigger scheduler tick failed for tenant');\n    50→          }\n    51→        });\n    52→      } else if (database) {\n    53→        triggerSchedulerTick(database, logger, undefined, onEventPublished);\n    54→      }\n    55→    } catch (err) {\n    56→      logger.error({ err }, 'Trigger scheduler tick failed');\n    57→    }\n    58→\n    59→    // Compute next delay from earliest pending trigger across all DBs\n    60→    const delayMs = computeNextDelay(database, tenantDbManager);\n    61→    scheduleTick(delayMs);\n    62→  }\n    63→\n    64→  // Kick off the first tick immediately\n    65→  scheduleTick(0);\n    66→\n    67→  return {\n    68→    close() {\n    69→      stopped = true;\n    70→      if (timer != null) {\n    71→        clearTimeout(timer);\n    72→        timer = null;\n    73→      }\n    74→    },\n    75→    nudge() {\n    76→      if (stopped) return;\n    77→      // Cancel pending timer and fire immediately\n    78→      if (timer != null) {\n    79→        clearTimeout(timer);\n    80→        timer = null;\n    81→      }\n    82→      scheduleTick(0);\n    83→    },\n    84→  };\n    85→}\n    86→\n    87→/**\n    88→ * Compute how long to sleep until the next trigger fires.\n    89→ * Looks at MIN(next_trigger_at) across all available DBs.\n    90→ */\n    91→function computeNextDelay(\n    92→  database: Database.Database | null,\n    93→  tenantDbManager?: TenantDbManager,\n    94→): number {\n    95→  let earliest: string | null = null;\n    96→\n    97→  if (tenantDbManager) {\n    98→    const tenantIds = tenantDbManager.listTenantIds();\n    99→    for (const id of tenantIds) {\n   100→      try {\n   101→        const tenantDb = tenantDbManager.getTenantDb(id);\n   102→        const t = db.getEar