` from triggerType when not present in the JSON\n    92→    if (triggerType && !raw.kind) {\n    93→      raw.kind = triggerType;\n    94→    }\n    95→    return triggerConfigSchema.parse(raw);\n    96→  } catch {\n    97→    return null;\n    98→  }\n    99→}\n   100→\n   101→/**\n   102→ * Validate config at write time — throws on invalid config.\n   103→ * Returns the canonical JSON string to persist.\n   104→ */\n   105→export function validateTriggerConfig(\n   106→  triggerType: TriggerType,\n   107→  config: string | null,\n   108→): string | null {\n   109→  if (!config) return null;\n   110→  const parsed = parseTriggerConfig(config, triggerType);\n   111→  if (!parsed) throw new Error(`Invalid trigger config for type \"${triggerType}\"`);\n   112→  // Strip `kind` from persisted JSON — it's redundant with trigger_type column\n   113→  const { kind: _, ...rest } = parsed;\n   114→  return JSON.stringify(rest);\n   115→}\n   116→\n   117→/**\n   118→ * Compute the next fire time from a typed trigger config.\n   119→ * Supports cron expressions, shorthand \"every Xm/h/s/d\", and interval_seconds.\n   120→ */\n   121→export function computeNextTriggerAtFromParsed(\n   122→  triggerType: TriggerType,\n   123→  parsed: TriggerConfig | null,\n   124→): string | null {\n   125→  if (triggerType !== 'schedule' || !parsed || parsed.kind !== 'schedule') return null;\n   126→\n   127→  if (parsed.cron) {\n   128→    // Shorthand patterns: \"every Xm\", \"every Xh\", \"every Xs\", \"every Xd\"\n   129→    const match = parsed.cron.match(/^every\\s+(\\d+)([smhd])$/i);\n   130→    if (match) {\n   131→      const value = parseInt(match[1]!, 10);\n   132→      const unit = match[2]!.toLowerCase();\n   133→      const multipliers: Record<string, number> = { s: 1000, m: 60000, h: 3600000, d: 86400000 };\n   134→      const ms = value * (multipliers[unit] ?? 60000);\n   135→      return new Date(Date.now() + ms).toISOString();\n   136→    }\n   137→\n   138→    // Standard cron expression\n   139→    try {\n   140→      const interval = CronExpressionParser.parse(parsed.cron);\n   141→      return interval.next().toISOString();\n   142→    } catch {\n   143→      return null;\n   144→    }\n   145→  }\n   146→\n   147→  if (parsed.interval_seconds) {\n   148→    return new Date(Date.now() + parsed.interval_seconds * 1000).toISOString();\n   149→  }\n   150→\n   151→  return null;\n   152→}\n   153→\n   154→// ---------------------------------------------------------------------------\n   155→// CRUD\n   156→// ---------------------------------------------------------------------------\n   157→\n   158→export function createTrigger(db: Database.Database, input: {\n   159→  personaId: string; triggerType: string; config?: string | null; enabled?: boolean; useCaseId?: string | null; projectId?: string;\n   160→}): PersonaTrigger {\n   161→  const now = new Date().toISOString();\n   162→  const id = nanoid();\n   163→  const triggerType = coerceTriggerType(input.triggerType);\n   164→  // Validate config at write time — throws on invalid config\n   165→  const config = input.config ? validateTriggerConfig(triggerType, input.config) : null;\n   166→  const enabled = input.enabled !== false;\n   167→  const useCaseId = input.useCaseId ?? null;\n   168→  const nextTriggerAt = enabled ? computeNextTriggerAtFromParsed(triggerType, parseTriggerConfig(config, triggerType)) : null;\n   169→  stmt(db,`\n   170→    INSERT INTO persona_triggers (id, project_id, persona_id, trigger_type, config, enabled, use_case_id, next_trigger_at, created_at, updated_at)\n   171→    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n   172→  `).run(id, input.projectId ?? 'default', input.personaId, triggerType, config, enabled ? 1 : 0, useCaseId, nextTriggerAt, now, now);\n   173→  return {\n   174→    id,\n   175→    personaId: input.personaId,\n   176→    triggerType,\n   177→    config,\n   178→    enabled,\n   179→    lastTriggeredAt: null,\n   180→    nextTriggerAt,\n   181→    useCaseId,\n   182→    createdAt: now,\n   183→    updatedAt: now,\n   184→  };\n   185→}\n   186→\n   187→export function getTrigger(db: Database.Database, id: string): PersonaTrigger | undefined {\n   188→  const row = stmt(db,'SELECT * FROM persona_triggers WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n   189→  return row ? rowToTrigger(row) : undefined;\n   190→}\n   191→\n   192→export function listTriggersForPersona(db: Database.Database, personaId: string): PersonaTrigger[] {\n   193→  const rows = stmt(db,'SELECT * FROM persona_triggers WHERE persona_id = ?').all(personaId) as Record<string, unknown>[];\n   194→  return rows.map(rowToTrigger);\n   195→}\n   196→\n   197→export interface DueTriggerRow extends PersonaTrigger {\n   198→  personaProjectId: string | null;\n   199→  personaEnabled: boolean | null;\n   200→  /** Pre-parsed typed config — parsed once on load, never in the hot loop. */\n   201→  parsedConfig: TriggerConfig | null;\n   202→}\n   203→\n   204→export function getDueTriggersWithPersona(db: Database.Database, batchSize: number = 100): DueTriggerRow[] {\n   205→  const rows = stmt(db, `\n   206→    SELECT t.*, p.project_id AS persona_project_id, p.enabled AS persona_enabled\n   207→    FROM persona_triggers t\n   208→    LEFT JOIN personas p ON p.id = t.persona_id\n   209→    WHERE t.enabled = 1 AND t.next_trigger_at <= strftime('%Y-%m-%dT%H:%M:%fZ', 'now')\n   210→    ORDER BY t.next_trigger_at ASC\n   211→    LIMIT ?\n   212→  `).all(batchSize) as Record<string, unknown>[];\n   213→  return rows.map(row => {\n   214→    const trigger = rowToTrigger(row);\n   215→    return {\n   216→      ...trigger,\n   217→      personaProjectId: (row.persona_project_id as string) ?? null,\n   218→      personaEnabled: row.persona_enabled != null ? row.persona_enabled === 1 : null,\n   219→      parsedConfig: parseTriggerConfig(trigger.config, trigger.triggerType),\n   220→    };\n   221→  });\n   222→}\n   223→\n   224→export function updateTriggerTimings(db: Database.Database, id: string, lastTriggeredAt: string, nextTriggerAt: string | null): void {\n   225→  stmt(db,'UPDATE persona_triggers SET last_triggered_at = ?, next_trigger_at = ?, updated_at = ? WHERE id = ?')\n   226→    .run(lastTriggeredAt, nextTriggerAt, new Date().toISOString(), id);\n   227→}\n   228→\n   229→export function updateTrigger(db: Database.Database, id: string, updates: {\n   230→  triggerType?: string | null; config?: string | null; enabled?: boolean | null;\n   231→}): void {\n   232→  const trigger = getTrigger(db, id);\n   233→  if (!trigger) return;\n   234→  const effectiveType = updates.triggerType ? coerceTriggerType(updates.triggerType) : trigger.triggerType;\n   235→  const effectiveConfig = updates.config !== undefined\n   236→    ? (updates.config ? validateTriggerConfig(effectiveType, updates.config) : updates.config)\n   237→    : trigger.config;\n   238→  const effectiveEnabled = mergeEnabled(updates.enabled, trigger.enabled);\n   239→  mergeUpdate(db, 'persona_triggers', id, {\n   240→    trigger_type: effectiveType,\n   241→    config: effectiveConfig,\n   242→    enabled: effectiveEnabled,\n   243→  });\n   244→  const nextTriggerAt = effectiveEnabled\n   245→    ? computeNextTriggerAtFromParsed(effectiveType, parseTriggerConfig(effectiveConfig, effectiveType))\n   246→    : null;\n   247→  stmt(db, 'UPDATE persona_triggers SET next_trigger_at = ? WHERE id = ?').run(nextTriggerAt, id);\n   248→}\n   249→\n   250→export function deleteTrigger(db: Database.Database, id: string): void {\n   251→  stmt(db,'DELETE FROM persona_triggers WHERE id = ?').run(id);\n   252→}\n   253→\n   254→/**\n   255→ * Return the earliest `next_trigger_at` for enabled triggers, or null if none exist.\n   256→ */\n   257→export function getEarliestNextTriggerTime(db: Database.Database): string | null {\n   258→  const row = stmt(db, `\n   259→    SELECT MIN(next_trigger_at) AS earliest\n   260→    FROM persona_triggers\n   261→    WHERE enabled = 1 AND next_trigger_at IS NOT NULL\n   262→  `).get() as { earliest: string | null } | undefined;\n   263→  return row?.earliest ?? null;\n   264→}\n   265→"}]},"parent_tool_use_id":null,"session_id":"95383bf2-a63e-4e56-a7ca-eddb4aa0e7cc","uuid":"9fc66b38-bf68-495c-ae27-ee3724a36fe1","timestamp":"2026-03-18T18:03:09.236Z","tool_use_result":{"type":"text","file":{"filePath":"C:/Users/kazda/kiro/personas-cloud/packages/orchestrator/src/db/triggers.ts","content":"import Database from 'better-sqlite3';\nimport { nanoid } from 'nanoid';\nimport { CronExpressionParser } from 'cron-parser';\nimport { z } from 'zod';\nimport type { PersonaTrigger, TriggerType, TriggerConfig } from '@dac-cloud/shared';\nimport { stmt, createRowMapper, mergeEnabled, mergeUpdate } from './_helpers.js';\n\n// ---------------------------------------------------------------------------\n// Row mapper\n// ---------------------------------------------------------------------------\n\nexport const rowToTrigger = createRowMapper<PersonaTrigger>({\n  id: { col: 'id' },\n  personaId: { col: 'persona_id' },\n  triggerType: { col: 'trigger_type' },\n  config: { col: 'config', nullable: true },\n  enabled: { col: 'enabled', bool: true },\n  lastTriggeredAt: { col: 'last_triggered_at', nullable: true },\n  nextTriggerAt: { col: 'next_trigger_at', nullable: true },\n  useCaseId: { col: 'use_case_id', nullable: true },\n  createdAt: { col: 'created_at' },\n  updatedAt: { col: 'updated_at' },\n});\n\n// ---------------------------------------------------------------------------\n// Trigger config — Zod schemas & discriminated union\n// ---------------------------------------------------------------------------\n\nconst triggerConfigBase = z.object({\n  event_type: z.string().optional(),\n  payload: z.unknown().optional(),\n});\n\nconst scheduleTriggerConfigSchema = triggerConfigBase.extend({\n  kind: z.literal('schedule'),\n  cron: z.string().optional(),\n  interval_seconds: z.number().positive().optional(),\n});\n\nconst manualTriggerConfigSchema = triggerConfigBase.extend({\n  kind: z.literal('manual'),\n});\n\nconst pollingTriggerConfigSchema = triggerConfigBase.extend({\n  kind: z.literal('polling'),\n  poll_url: z.string().optional(),\n  poll_interval_seconds: z.number().positive().optional(),\n});\n\nconst webhookTriggerConfigSchema = triggerConfigBase.extend({\n  kind: z.literal('webhook'),\n  url: z.string().optional(),\n  secret: z.string().optional(),\n});\n\nconst chainTriggerConfigSchema = triggerConfigBase.extend({\n  kind: z.literal('chain'),\n  source_persona_id: z.string().optional(),\n  source_event_type: z.string().optional(),\n});\n\nconst triggerConfigSchema = z.discriminatedUnion('kind', [\n  scheduleTriggerConfigSchema,\n  manualTriggerConfigSchema,\n  pollingTriggerConfigSchema,\n  webhookTriggerConfigSchema,\n  chainTriggerConfigSchema,\n]);\n\nconst VALID_TRIGGER_TYPES = new Set<TriggerType>(['manual', 'schedule', 'polling', 'webhook', 'chain']);\n\nfunction coerceTriggerType(raw: string): TriggerType {\n  if (!VALID_TRIGGER_TYPES.has(raw as TriggerType)) {\n    throw new Error(`Invalid trigger type: ${raw}`);\n  }\n  return raw as TriggerType;\n}\n\n/**\n * Validate and parse a raw config JSON string into a typed TriggerConfig.\n * If `triggerType` is provided, the `kind` discriminant is injected automatically\n * so callers don't need to include it in the stored JSON.\n */\nexport function parseTriggerConfig(\n  config: string | null,\n  triggerType?: TriggerType,\n): TriggerConfig | null {\n  if (!config) return null;\n  try {\n    const raw = JSON.parse(config) as Record<string, unknown>;\n    // Inject `kind` from triggerType when not present in the JSON\n    if (triggerType && !raw.kind) {\n      raw.kind = triggerType;\n    }\n    return triggerConfigSchema.parse(raw);\n  } catch {\n    return null;\n  }\n}\n\n/**\n * Validate config at write time — throws on invalid config.\n * Returns the canonical JSON string to persist.\n */\nexport function validateTriggerConfig(\n  triggerType: TriggerType,\n  config: string | null,\n): string | null {\n  if (!config) return null;\n  const parsed = parseTriggerConfig(config, triggerType);\n  if (!parsed) throw new Error(`Invalid trigger config for type \"${triggerType}\"`);\n  // Strip `kind` from persisted JSON — it's redundant with trigger_type column\n  const { kind: _, ...rest } = parsed;\n  return JSON.stringify(rest);\n}\n\n/**\n * Compute the next fire time from a typed trigger config.\n * Supports cron expressions, shorthand \"every Xm/h/s/d\", and interval_seconds.\n */\nexport function computeNextTriggerAtFromParsed(\n  triggerType: TriggerType,\n  parsed: TriggerConfig | null,\n): string | null {\n  if (triggerType !== 'schedule' || !parsed || parsed.kind !== 'schedule') return null;\n\n  if (parsed.cron) {\n    // Shorthand patterns: \"every Xm\", \"every Xh\", \"every Xs\", \"every Xd\"\n    const match = parsed.cron.match(/^every\\s+(\\d+)([smhd])$/i);\n    if (match) {\n      const value = parseInt(match[1]!, 10);\n      const unit = match[2]!.toLowerCase();\n      const multipliers: Record<string, number> = { s: 1000, m: 60000, h: 3600000, d: 86400000 };\n      const ms = value * (multipliers[unit] ?? 60000);\n      return new Date(Date.now() + ms).toISOString();\n    }\n\n    // Standard cron expression\n    try {\n      const interval = CronExpressionParser.parse(parsed.cron);\n      return interval.next().toISOString();\n    } catch {\n      return null;\n    }\n  }\n\n  if (parsed.interval_seconds) {\n    return new Date(Date.now() + parsed.interval_seconds * 1000).toISOString();\n  }\n\n  return null;\n}\n\n// ---------------------------------------------------------------------------\n// CRUD\n// ---------------------------------------------------------------------------\n\nexport function createTrigger(db: Database.Database, input: {\n  personaId: string; triggerType: string; config?: string | null; enabled?: boolean; useCaseId?: string | null; projectId?: string;\n}): PersonaTrigger {\n  const now = new Date().toISOString();\n  const id = nanoid();\n  const triggerType = coerceTriggerType(input.triggerType);\n  // Validate config at write time — throws on invalid config\n  const config = input.config ? validateTriggerConfig(triggerType, input.config) : null;\n  const enabled = input.enabled !== false;\n  const useCaseId = input.useCaseId ?? null;\n  const nextTriggerAt = enabled ? computeNextTriggerAtFromParsed(triggerType, parseTriggerConfig(config, triggerType)) : null;\n  stmt(db,`\n    INSERT INTO persona_triggers (id, project_id, persona_id, trigger_type, config, enabled, use_case_id, next_trigger_at, created_at, updated_at)\n    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n  `).run(id, input.projectId ?? 'default', input.personaId, triggerType, config, enabled ? 1 : 0, useCaseId, nextTriggerAt, now, now);\n  return {\n    id,\n    personaId: input.personaId,\n    triggerType,\n    config,\n    enabled,\n    lastTriggeredAt: null,\n    nextTriggerAt,\n    useCaseId,\n    createdAt: now,\n    updatedAt: now,\n  };\n}\n\nexport function getTrigger(db: Database.Database, id: string): PersonaTrigger | undefined {\n  const row = stmt(db,'SELECT * FROM persona_triggers WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n  return row ? rowToTrigger(row) : undefined;\n}\n\nexport function listTriggersForPersona(db: Database.Database, personaId: string): PersonaTrigger[] {\n  const rows = stmt(db,'SELECT * FROM persona_triggers WHERE persona_id = ?').all(personaId) as Record<string, unknown>[];\n  return rows.map(rowToTrigger);\n}\n\nexport interface DueTriggerRow extends PersonaTrigger {\n  personaProjectId: string | null;\n  personaEnabled: boolean | null;\n  /** Pre-parsed typed config — parsed once on load, never in the hot loop. */\n  parsedConfig: TriggerConfig | null;\n}\n\nexport function getDueTriggersWithPersona(db: Database.Database, batchSize: number = 100): DueTriggerRow[] {\n  const rows = stmt(db, `\n    SELECT t.*, p.project_id AS persona_project_id, p.enabled AS persona_enabled\n    FROM persona_triggers t\n    LEFT JOIN personas p ON p.id = t.persona_id\n    WHERE t.enabled = 1 AND t.next_trigger_at <= strftime('%Y-%m-%dT%H:%M:%fZ', 'now')\n    ORDER BY t.next_trigger_at ASC\n    LIMIT ?\n  `).all(batchSize) as Record<string, unknown>[];\n  return rows.map(row => {\n    const trigger = rowToTrigger(row);\n    return {\n      ...trigger,\n      personaProjectId: (row.persona_project_id as string) ?? null,\n      personaEnabled: row.persona_enabled != null ? row.persona_enabled === 1 : null,\n      parsedConfig: parseTriggerConfig(trigger.config, trigger.triggerType),\n    };\n  });\n}\n\nexport function updateTriggerTimings(db: Database.Database, id: string, lastTriggeredAt: string, nextTriggerAt: string | null): void {\n  stmt(db,'UPDATE persona_triggers SET last_triggered_at = ?, next_trigger_at = ?, updated_at = ? WHERE id = ?')\n    .run(lastTriggeredAt, nextTriggerAt, new Date().toISOString(), id);\n}\n\nexport function updateTrigger(db: Database.Database, id: string, updates: {\n  triggerType?: string | null; config?: string | null; enabled?: boolean | null;\n}): void {\n  const trigger = getTrigger(db, id);\n  if (!trigger) return;\n  const effectiveType = updates.triggerType ? coerceTriggerType(updates.triggerType) : trigger.triggerType;\n  const effectiveConfig = updates.config !== undefined\n    ? (updates.config ? validateTriggerConfig(effectiveType, updates.config) : updates.config)\n    : trigger.config;\n  const effectiveEnabled = mergeEnabled(updates.enabled, trigger.enabled);\n  mergeUpdate(db, 'persona_triggers', id, {\n    trigger_type: effectiveType,\n    config: effectiveConfig,\n    enabled: effectiveEnabled,\n  });\n  const nextTriggerAt = effectiveEnabled\n    ? computeNextTriggerAtFromParsed(effectiveType, parseTriggerConfig(effectiveConfig, effectiveType))\n    : null;\n  stmt(db, 'UPDATE persona_triggers SET next_trigger_at = ? WHERE id = ?').run(nextTriggerAt, id);\n}\n\nexport function deleteTrigger(db: Database.Database, id: string): void {\n  stmt(db,'DELETE FROM persona_triggers WHERE id = ?').run(id);\n}\n\n/**\n * Return the earliest `next_trigger_at` for enabled triggers, or null if none exist.\n */\nexport function getEarliestNextTriggerTime(db: Database.Database): string | null {\n  const row = stmt(db, `\n    SELECT MIN(next_trigger_at) AS earliest\n    FROM persona_triggers\n    WHERE enabled = 1 AND next_trigger_at IS NOT NULL\n  `).get() as { earliest: string | null } | undefined;\n  return row?.earliest ?? null;\n}\n","numLines":265,"startLine":1,"totalLines":265}}}
