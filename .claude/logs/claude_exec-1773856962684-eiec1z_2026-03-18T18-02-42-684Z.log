TEXT');\n   279→    logger.info('Migration: added event_id to persona_executions');\n   280→  }\n   281→}\n   282→\n   283→// ---------------------------------------------------------------------------\n   284→// Initialization\n   285→// ---------------------------------------------------------------------------\n   286→\n   287→/** Legacy: initialize a single monolithic database (used by migration script). */\n   288→export function initDb(dbPath: string, logger: Logger): Database.Database {\n   289→  const db = new Database(dbPath);\n   290→  db.pragma('journal_mode = WAL');\n   291→  db.pragma('foreign_keys = ON');\n   292→\n   293→  db.exec(SHARED_TABLES);\n   294→  runLegacyMigrations(db, logger);\n   295→  logger.info({ dbPath }, 'Database initialized (legacy single-db)');\n   296→  return db;\n   297→}\n   298→\n   299→/** Initialize the system-level database (tenant registry). */\n   300→export function initSystemDb(dbPath: string, logger: Logger): Database.Database {\n   301→  const db = new Database(dbPath);\n   302→  db.pragma('journal_mode = WAL');\n   303→  db.pragma('foreign_keys = ON');\n   304→\n   305→  db.exec(SYSTEM_SCHEMA);\n   306→  logger.info({ dbPath }, 'System database initialized');\n   307→  return db;\n   308→}\n   309→\n   310→/** Initialize a per-tenant database. */\n   311→export function initTenantDb(dbPath: string, logger: Logger): Database.Database {\n   312→  const db = new Database(dbPath);\n   313→  db.pragma('journal_mode = WAL');\n   314→  db.pragma('foreign_keys = ON');\n   315→\n   316→  db.exec(SHARED_TABLES);\n   317→  runTenantMigrations(db, logger);\n   318→  logger.info({ dbPath }, 'Tenant database initialized');\n   319→  return db;\n   320→}\n   321→\n   322→/** Migrations applied to per-tenant databases. */\n   323→function runTenantMigrations(db: Database.Database, logger: Logger): void {\n   324→  const eventCols = stmt(db,'PRAGMA table_info(persona_events)').all() as Array<{ name: string }>;\n   325→  if (!eventCo