","+): void {","+  heap.clear();"," ","   if (tenantDbManager) {","     const tenantIds = tenantDbManager.listTenantIds();","-    for (const id of tenantIds) {","+    for (const tenantId of tenantIds) {","       try {","-        const tenantDb = tenantDbManager.getTenantDb(id);","-        const t = db.getEarliestNextTriggerTime(tenantDb);","-        if (t && (!earliest || t < earliest)) {","-          earliest = t;","-        }","-      } catch { /* skip failed tenants */ }","+        const tenantDb = tenantDbManager.getTenantDb(tenantId);","+        loadDbIntoHeap(heap, tenantDb, tenantId);","+      } catch (err) {","+        logger.error({ err, tenantId }, 'Failed to load triggers for tenant into heap');","+      }","     }","   } else if (database) {","-    earliest = db.getEarliestNextTriggerTime(database);","+    loadDbIntoHeap(heap, database, 'default');","   }","+}"," ","-  if (!earliest) return MAX_DELAY_MS;","+function loadDbIntoHeap(heap: TriggerHeap, dbConn: Database.Database, tenantId: string): void {","+  const rows = db.loadEnabledTriggerTimes(dbConn);","+  for (const row of rows) {","+    heap.push({","+      triggerId: row.id,","+      tenantId,","+      nextTriggerAt: new Date(row.nextTriggerAt).getTime(),","+    });","+  }","+}"," ","-  const deltaMs = new Date(earliest).getTime() - Date.now();","+// ---------------------------------------------------------------------------","+// Compute next delay from the heap (O(1) peek)","+// ---------------------------------------------------------------------------","+","+function computeNextDelay(heap: TriggerHeap): number {","+  const top = heap.peek();","+  if (!top) return MAX_DELAY_MS;","+  const deltaMs = top.nextTriggerAt - Date.now();","   return Math.min(MAX_DELAY_MS, Math.max(MIN_DELAY_MS, deltaMs));"," }"," ","-function triggerSchedulerTick(","-  database: Database.Database,","+// ---------------------------------------------------------------------------","+// Fire due triggers — batch-fetch from