[2026-03-19T08:29:06.940Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KhXzM7SmtMQVynxCrV9E5z","type":"tool_result","content":"     1→import type { Logger } from 'pino';\n     2→import { getTableSpec, isEphemeral } from '@dac-cloud/shared';\n     3→import type { EphemeralTableSpec } from '@dac-cloud/shared';\n     4→import type { AuditLog } from './auditLog.js';\n     5→import { RetentionPolicy } from './retentionPolicy.js';\n     6→\n     7→// Derive retention constraints from the table registry — single source of truth\n     8→const auditSpec = getTableSpec('audit_events');\n     9→if (!auditSpec || !isEphemeral(auditSpec)) {\n    10→  throw new Error('audit_events must be registered as ephemeral in TABLE_REGISTRY');\n    11→}\n    12→\n    13→/** Minimum allowed retention to prevent accidental wipe of the compliance trail. */\n    14→export const MIN_AUDIT_RETENTION_DAYS = (auditSpec as EphemeralTableSpec).minRetentionDays ?? 90;\n    15→\n    16→/** Shared RetentionPolicy instance for audit_events. */\n    17→const auditPolicy = new RetentionPolicy({ table: 'audit_events' });\n    18→\n    19→/**\n    20→ * Manages retention / purge lifecycle for the audit log.\n    21→ *\n    22→ * Separated from AuditLog so that the log itself enforces append-only\n    23→ * semantics structurally — only this class can delete audit rows.\n    24→ */\n    25→export class AuditRetentionPolicy {\n    26→  private purgeTimer: NodeJS.Timeout | null = null;\n    27→\n    28→  constructor(\n    29→    private auditLog: AuditLog,\n    30→    private retentionDays: number,\n    31→    private logger: Logger,\n    32→  ) {\n    33→    if (!Number.isFinite(retentionDays) || retentionDays < MIN_AUDIT_RETENTION_DAYS) {\n    34→      throw new Error(\n    35→        `auditRetentionDays must be >= ${MIN_AUDIT_RETENTION_DAYS}, got ${retentionDays}`,\n    36→      );\n    37→    }\n    38→  }\n    39→\n    40→  /** Delete audit events older than retentionDays with volume safety cap. */\n    41→  async purgeOld(): Promise<number> {\n    42→    const cutoff = new Date(Date.now() - this.retentionDays * 86_400_000).toISOString();\n    43→    const totalDeleted = await auditPolicy.purge(this.auditLog.getDb(), cutoff, this.logger);\n    44→    if (totalDeleted > 0) {\n    45→      this.logger.info({ purged: totalDeleted, cutoff }, 'Purged old audit events');\n    46→    }\n    47→    return totalDeleted;\n    48→  }\n    49→\n    50→  /** Start daily purge timer. Returns the timer for cleanup. */\n    51→  startDailyPurge(): NodeJS.Timeout {\n    52→    this.purgeTimer = setInterval(() => {\n    53→      this.purgeOld().catch((err) => {\n    54→        this.logger.error({ err }, 'Audit purge failed');\n    55→      });\n    56→    }, 24 * 60 * 60 * 1000);\n    57→    return this.purgeTimer;\n    58→  }\n    59→\n    60→  close(): void {\n    61→    if (this.purgeTimer) clearInterval(this.purgeTimer);\n    62→  }\n    63→}\n    64→"}]},"parent_tool_use_id":"toolu_017AXpehDUT8ebwRaA6Z6JLX","session_id":"239ea274-e4d5-4daf-b79f-4e16f4e4e93b","uuid":"ec8773da-13f6-48f0-8eaa-cabc734703e1","timestamp":"2026-03-19T08:29:06.717Z"}
