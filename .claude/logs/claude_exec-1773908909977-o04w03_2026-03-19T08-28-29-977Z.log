[2026-03-19T08:29:09.607Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017NGvDcji9aZCBzxm4FxKbr","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import { stmt } from './_helpers.js';\n     4→\n     5→// ---------------------------------------------------------------------------\n     6→// System schema (tenant registry)\n     7→// ---------------------------------------------------------------------------\n     8→\n     9→const SYSTEM_SCHEMA = `\n    10→CREATE TABLE IF NOT EXISTS tenants (\n    11→  id TEXT PRIMARY KEY,\n    12→  name TEXT,\n    13→  created_at TEXT NOT NULL\n    14→);\n    15→\n    16→CREATE TABLE IF NOT EXISTS system_daily_metrics (\n    17→  date TEXT NOT NULL,\n    18→  total_executions INTEGER DEFAULT 0,\n    19→  completed INTEGER DEFAULT 0,\n    20→  failed INTEGER DEFAULT 0,\n    21→  total_cost_usd REAL DEFAULT 0,\n    22→  total_duration_ms INTEGER DEFAULT 0,\n    23→  tenant_count INTEGER DEFAULT 0,\n    24→  aggregated_at TEXT NOT NULL,\n    25→  PRIMARY KEY (date)\n    26→);\n    27→\n    28→CREATE TABLE IF NOT EXISTS system_kv (\n    29→  key TEXT PRIMARY KEY,\n    30→  value TEXT NOT NULL\n    31→);\n    32→`;\n    33→\n    34→const INFERENCE_PROFILES_TABLE = `\n    35→CREATE TABLE IF NOT EXISTS inference_profiles (\n    36→  id TEXT PRIMARY KEY,\n    37→  project_id TEXT NOT NULL DEFAULT 'default',\n    38→  name TEXT NOT NULL,\n    39→  provider TEXT NOT NULL,\n    40→  model TEXT,\n    41→  base_url TEXT,\n    42→  auth_token_encrypted TEXT,\n    43→  auth_token_iv TEXT,\n    44→  auth_token_tag TEXT,\n    45→  env_mappings TEXT NOT NULL DEFAULT '[]',\n    46→  remove_env_keys TEXT NOT NULL DEFAULT '[]',\n    47→  is_preset INTEGER NOT NULL DEFAULT 0,\n    48→  created_at TEXT NOT NULL,\n    49→  updated_at TEXT NOT NULL\n    50→);\n    51→`;\n    52→\n    53→const DAILY_METRICS_TABLE = `\n    54→CREATE TABLE IF NOT EXISTS daily_metrics (\n    55→  date TEXT NOT NULL,\n    56→  total_executions INTEGER DEFAULT 0,\n    57→  completed INTEGER DEFAULT 0,\n    58→  failed INTEGER DEFAULT 0,\n    59→  total_cost_usd REAL DEFAULT 0,\n    60→  total_duration_ms INTEGER DEFAULT 0,\n    61→  PRIMARY KEY (date)\n    62→);\n    63→\n    64→CREATE TABLE IF NOT EXISTS retention_watermark (\n    65→  key TEXT PRIMARY KEY DEFAULT 'executions',\n    66→  last_rowid INTEGER NOT NULL DEFAULT 0\n    67→);\n    68→`;\n    69→\n    70→// ---------------------------------------------------------------------------\n    71→// Shared entity tables (used by both legacy single-db and per-tenant dbs)\n    72→// ---------------------------------------------------------------------------\n    73→\n    74→const SHARED_TABLES = `\n    75→CREATE TABLE IF NOT EXISTS personas (\n    76→  id TEXT PRIMARY KEY,\n    77→  project_id TEXT NOT NULL DEFAULT 'default',\n    78→  name TEXT NOT NULL,\n    79→  description TEXT,\n    80→  system_prompt TEXT NOT NULL DEFAULT '',\n    81→  structured_prompt TEXT,\n    82→  icon TEXT,\n    83→  color TEXT,\n    84→  enabled INTEGER NOT NULL DEFAULT 1,\n    85→  max_concurrent INTEGER NOT NULL DEFAULT 1,\n    86→  timeout_ms INTEGER NOT NULL DEFAULT 300000,\n    87→  inference_profile_id TEXT,\n    88→  network_policy TEXT,\n    89→  max_budget_usd REAL,\n    90→  max_turns INTEGER,\n    91→  design_context TEXT,\n    92→  group_id TEXT,\n    93→  created_at TEXT NOT NULL,\n    94→  updated_at TEXT NOT NULL\n    95→);\n    96→\n    97→CREATE TABLE IF NOT EXISTS persona_tool_definitions (\n    98→  id TEXT PRIMARY KEY,\n    99→  name TEXT NOT NULL UNIQUE,\n   100→  category TEXT NOT NULL,\n   101→  description TEXT NOT NULL,\n   102→  script_path TEXT NOT NULL DEFAULT '',\n   103→  input_schema TEXT,\n   104→  output_schema TEXT,\n   105→  requires_credential_type TEXT,\n   106→  implementation_guide TEXT,\n   107→  is_builtin INTEGER NOT NULL DEFAULT 0,\n   108→  created_at TEXT NOT NULL,\n   109→  updated_at TEXT NOT NULL\n   110→);\n   111→\n   112→CREATE TABLE IF NOT EXISTS persona_tools (\n   113→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   114→  tool_id TEXT NOT NULL REFERENCES persona_tool_definitions(id) ON DELETE CASCADE,\n   115→  PRIMARY KEY (persona_id, tool_id)\n   116→);\n   117→\n   118→CREATE TABLE IF NOT EXISTS persona_credentials (\n   119→  id TEXT PRIMARY KEY,\n   120→  project_id TEXT NOT NULL DEFAULT 'default',\n   121→  name TEXT NOT NULL,\n   122→  service_type TEXT NOT NULL,\n   123→  encrypted_data TEXT NOT NULL,\n   124→  iv TEXT NOT NULL,\n   125→  tag TEXT NOT NULL,\n   126→  metadata TEXT,\n   127→  last_used_at TEXT,\n   128→  created_at TEXT NOT NULL,\n   129→  updated_at TEXT NOT NULL\n   130→);\n   131→\n   132→CREATE TABLE IF NOT EXISTS persona_credential_links (\n   133→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   134→  credential_id TEXT NOT NULL REFERENCES persona_credentials(id) ON DELETE CASCADE,\n   135→  PRIMARY KEY (persona_id, credential_id)\n   136→);\n   137→\n   138→CREATE TABLE IF NOT EXISTS persona_events (\n   139→  id TEXT PRIMARY KEY,\n   140→  project_id TEXT NOT NULL DEFAULT 'default',\n   141→  event_type TEXT NOT NULL,\n   142→  source_type TEXT NOT NULL,\n   143→  source_id TEXT,\n   144→  target_persona_id TEXT,\n   145→  payload TEXT,\n   146→  status TEXT NOT NULL DEFAULT 'pending' CHECK(status IN ('pending','processing','delivered','skipped','failed','partial','partial-retry')),\n   147→  error_message TEXT,\n   148→  processed_at TEXT,\n   149→  use_case_id TEXT,\n   150→  retry_after TEXT,\n   151→  retry_count INTEGER NOT NULL DEFAULT 0,\n   152→  created_at TEXT NOT NULL\n   153→);\n   154→CREATE INDEX IF NOT EXISTS idx_pe_status ON persona_events(status);\n   155→CREATE INDEX IF NOT EXISTS idx_pe_created_status ON persona_events(created_at, status);\n   156→\n   157→CREATE TABLE IF NOT EXISTS persona_event_subscriptions (\n   158→  id TEXT PRIMARY KEY,\n   159→  project_id TEXT NOT NULL DEFAULT 'default',\n   160→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   161→  event_type TEXT NOT NULL,\n   162→  source_filter TEXT,\n   163→  enabled INTEGER NOT NULL DEFAULT 1,\n   164→  use_case_id TEXT,\n   165→  created_at TEXT NOT NULL,\n   166→  updated_at TEXT NOT NULL\n   167→);\n   168→CREATE INDEX IF NOT EXISTS idx_pes_event_type ON persona_event_subscriptions(event_type, enabled);\n   169→\n   170→CREATE TABLE IF NOT EXISTS persona_triggers (\n   171→  id TEXT PRIMARY KEY,\n   172→  project_id TEXT NOT NULL DEFAULT 'default',\n   173→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   174→  trigger_type TEXT NOT NULL CHECK(trigger_type IN ('manual','schedule','polling','webhook','chain')),\n   175→  config TEXT,\n   176→  enabled INTEGER NOT NULL DEFAULT 1,\n   177→  last_triggered_at TEXT,\n   178→  next_trigger_at TEXT,\n   179→  use_case_id TEXT,\n   180→  created_at TEXT NOT NULL,\n   181→  updated_at TEXT NOT NULL\n   182→);\n   183→CREATE INDEX IF NOT EXISTS idx_pt_due ON persona_triggers(enabled, next_trigger_at);\n   184→\n   185→CREATE TABLE IF NOT EXISTS trigger_fires (\n   186→  id TEXT PRIMARY KEY,\n   187→  trigger_id TEXT NOT NULL,\n   188→  event_id TEXT,\n   189→  execution_id TEXT,\n   190→  status TEXT NOT NULL DEFAULT 'fired' CHECK(status IN ('fired','completed','failed')),\n   191→  duration_ms INTEGER,\n   192→  error_message TEXT,\n   193→  fired_at TEXT NOT NULL\n   194→);\n   195→CREATE INDEX IF NOT EXISTS idx_tf_trigger_fired ON trigger_fires(trigger_id, fired_at DESC);\n   196→CREATE INDEX IF NOT EXISTS idx_tf_trigger_status ON trigger_fires(trigger_id, status);\n   197→\n   198→CREATE TABLE IF NOT EXISTS persona_executions (\n   199→  id TEXT PRIMARY KEY,\n   200→  project_id TEXT NOT NULL DEFAULT 'default',\n   201→  persona_id TEXT NOT NULL,\n   202→  trigger_id TEXT,\n   203→  use_case_id TEXT,\n   204→  event_id TEXT,\n   205→  status TEXT NOT NULL DEFAULT 'queued' CHECK(status IN ('queued','running','completed','failed','cancelled')),\n   206→  input_data TEXT,\n   207→  output_data TEXT,\n   208→  claude_session_id TEXT,\n   209→  model_used TEXT,\n   210→  input_tokens INTEGER DEFAULT 0,\n   211→  output_tokens INTEGER DEFAULT 0,\n   212→  cost_usd REAL DEFAULT 0,\n   213→  error_message TEXT,\n   214→  duration_ms INTEGER,\n   215→  retry_of_execution_id TEXT,\n   216→  retry_count INTEGER DEFAULT 0,\n   217→  started_at TEXT,\n   218→  completed_at TEXT,\n   219→  created_at TEXT NOT NULL\n   220→);\n   221→CREATE INDEX IF NOT EXISTS idx_pex_persona ON persona_executions(persona_id);\n   222→CREATE INDEX IF NOT EXISTS idx_pex_status ON persona_executions(status);\n   223→CREATE INDEX IF NOT EXISTS idx_pex_created_status ON persona_executions(created_at, status);\n   224→\n   225→${DAILY_METRICS_TABLE}\n   226→\n   227→${INFERENCE_PROFILES_TABLE}\n   228→`;\n   229→\n   230→// ---------------------------------------------------------------------------\n   231→// Migrations (legacy single-db)\n   232→// ---------------------------------------------------------------------------\n   233→\n   234→function runLegacyMigrations(db: Database.Database, logger: Logger): void {\n   235→  const tablesToMigrate = [\n   236→    'persona_credentials',\n   237→    'persona_event_subscriptions',\n   238→    'persona_triggers',\n   239→    'persona_executions',\n   240→  ];\n   241→\n   242→  for (const table of tablesToMigrate) {\n   243→    const columns = stmt(db,`PRAGMA table_info(${table})`).all() as Array<{ name: string }>;\n   244→    const hasProjectId = columns.some(c => c.name === 'project_id');\n   245→    if (!hasProjectId) {\n   246→      db.exec(`ALTER TABLE ${table} ADD COLUMN project_id TEXT NOT NULL DEFAULT 'default'`);\n   247→      logger.info({ table }, 'Migration: added project_id column');\n   248→    }\n   249→  }\n   250→\n   251→  db.exec(`\n   252→    CREATE INDEX IF NOT EXISTS idx_personas_project ON personas(project_id);\n   253→    CREATE INDEX IF NOT EXISTS idx_pe_project ON persona_events(project_id);\n   254→    CREATE INDEX IF NOT EXISTS idx_pcred_project ON persona_credentials(project_id);\n   255→    CREATE INDEX IF NOT EXISTS idx_pes_project ON persona_event_subscriptions(project_id);\n   256→    CREATE INDEX IF NOT EXISTS idx_pes_event_type ON persona_event_subscriptions(event_type, enabled);\n   257→    CREATE INDEX IF NOT EXISTS idx_pt_project ON persona_triggers(project_id);\n   258→    DROP INDEX IF EXISTS idx_pt_next_trigger;\n   259→    CREATE INDEX IF NOT EXISTS idx_pt_due ON persona_triggers(enabled, next_trigger_at);\n   260→    CREATE INDEX IF NOT EXISTS idx_pex_project ON persona_executions(project_id);\n   261→  `);\n   262→\n   263→  // Add inference_profile_id to personas if missing\n   264→  const personaCols = stmt(db,'PRAGMA table_info(personas)').all() as Array<{ name: string }>;\n   265→  if (!personaCols.some(c => c.name === 'inference_profile_id')) {\n   266→    db.exec('ALTER TABLE personas ADD COLUMN inference_profile_id TEXT');\n   267→    logger.info('Migration: added inference_profile_id to personas');\n   268→  }\n   269→  if (!personaCols.some(c => c.name === 'network_policy')) {\n   270→    db.exec('ALTER TABLE personas ADD COLUMN network_policy TEXT');\n   271→    logger.info('Migration: added network_policy to personas');\n   272→  }\n   273→\n   274→  // Create inference_profiles table if missing\n   275→  db.exec(INFERENCE_PROFILES_TABLE);\n   276→\n   277→  // Add retry_after and retry_count to persona_events if missing\n   278→  const eventCols = stmt(db,'PRAGMA table_info(persona_events)').all() as Array<{ name: string }>;\n   279→  if (!eventCols.some(c => c.name === 'retry_after')) {\n   280→    db.exec('ALTER TABLE persona_events ADD COLUMN retry_after TEXT');\n   281→    logger.info('Migration: added retry_after to persona_events');\n   282→  }\n   283→  if (!eventCols.some(c => c.name === 'retry_count')) {\n   284→    db.exec('ALTER TABLE persona_events ADD COLUMN retry_count INTEGER NOT NULL DEFAULT 0');\n   285→    logger.info('Migration: added retry_count to persona_events');\n   286→  }\n   287→\n   288→  // Add event_id to persona_executions for event↔execution correlation tracing\n   289→  const execCols = stmt(db,'PRAGMA table_info(persona_executions)').all() as Array<{ name: string }>;\n   290→  if (!execCols.some(c => c.name === 'event_id')) {\n   291→    db.exec('ALTER TABLE persona_executions ADD COLUMN event_id TEXT');\n   292→    logger.info('Migration: added event_id to persona_executions');\n   293→  }\n   294→}\n   295→\n   296→// ---------------------------------------------------------------------------\n   297→// Initialization\n   298→// ---------------------------------------------------------------------------\n   299→\n   300→/** Legacy: initialize a single monolithic database (used by migration script). */\n   301→export function initDb(dbPath: string, logger: Logger): Database.Database {\n   302→  const db = new Database(dbPath);\n   303→  db.pragma('journal_mode = WAL');\n   304→  db.pragma('foreign_keys = ON');\n   305→\n   306→  db.exec(SHARED_TABLES);\n   307→  runLegacyMigrations(db, logger);\n   308→  logger.info({ dbPath }, 'Database initialized (legacy single-db)');\n   309→  return db;\n   310→}\n   311→\n   312→/** Initialize the system-level database (tenant registry). */\n   313→export function initSystemDb(dbPath: string, logger: Logger): Database.Database {\n   314→  const db = new Database(dbPath);\n   315→  db.pragma('journal_mode = WAL');\n   316→  db.pragma('foreign_keys = ON');\n   317→\n   318→  db.exec(SYSTEM_SCHEMA);\n   319→  logger.info({ dbPath }, 'System database initialized');\n   320→  return db;\n   321→}\n   322→\n   323→/** Initialize a per-tenant database. */\n   324→export function initTenantDb(dbPath: string, logger: Logger): Database.Database {\n   325→  cons