ocal/lib/node_modules', args: ['--ro-bind', '/usr/local/lib/node_modules', '/usr/local/lib/node_modules'] },\n    45‚Üí    { path: '/usr/local/bin/claude', args: ['--ro-bind', '/usr/local/bin/claude', '/usr/local/bin/claude'] },\n    46‚Üí  ];\n    47‚Üí\n    48‚Üí  for (const entry of conditionalPaths) {\n    49‚Üí    if (fs.existsSync(entry.path)) {\n    50‚Üí      args.push(...entry.args);\n    51‚Üí    }\n    52‚Üí  }\n    53‚Üí\n    54‚Üí  return args;\n    55‚Üí})();\n    56‚Üí\n    57‚Üí/**\n    58‚Üí * Check if bubblewrap (bwrap) is available on this system.\n    59‚Üí * Cached after first call.\n    60‚Üí */\n    61‚Üíexport function isSandboxAvailable(): boolean {\n    62‚Üí  if (_bwrapAvailable !== null) return _bwrapAvailable;\n    63‚Üí\n    64‚Üí  if (process.platform !== 'linux') {\n    65‚Üí    _bwrapAvailable = false;\n    66‚Üí    return false;\n    67‚Üí  }\n    68‚Üí\n    69‚Üí  try {\n    70‚Üí    execSync('which bwrap', { stdio: 'ignore' });\n    71‚Üí    _bwrapAvailable = true;\n    72‚Üí  } catch {\n    73‚Üí    _bwrapAvailable = false;\n    74‚Üí  }\n    75‚Üí  return _bwrapAvailable;\n    76‚Üí}\n    77‚Üí\n    78‚Üí/**\n    79‚Üí * Resolve the claude CLI command path.\n    80‚Üí */\n    81‚Üífunction resolveClaudeCommand(): string {\n    82‚Üí  if (process.platform === 'win32') {\n    83‚Üí    try {\n    84‚Üí      return execSync('where claude', { encoding: 'utf8' }).trim().split('\\n')[0]!;\n    85‚Üí    } catch { /* fall through */ }\n    86‚Üí  }\n    87‚Üí  return 'claude';\n    88‚Üí}\n    89‚Üí\n    90‚Üí/**\n    91‚Üí * Build a clean environment dict for the child process.\n    92‚Üí * Never inherits from process.env ‚Äî only explicit values.\n    93‚Üí */\n    94‚Üífunction buildCleanEnv(assignmentEnv: Record<string, string>): Record<string, string> {\n    95‚Üí  const clean: Record<string, string> = {\n    96‚Üí    PATH: '/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin',\n    97‚Üí    NODE_ENV: 'production',\n    98‚Üí    LANG: 'en_US.UTF-8',\n    99‚Üí  };\n   100‚Üí\n   101‚Üí  // Copy assignment env vars (credentials, config)\n   102‚Üí  for (const [key, value] of Object.entries(assignmentEnv)) {\n   103‚Üí    if (key === 'ANTHROPIC_API_KEY') continue; // handled via credentials file\n   104‚Üí    clean[key] = value;\n   105‚Üí  }\n   106‚Üí\n   107‚Üí  // Explicitly unset CLAUDECODE to prevent nested session guard\n   108‚Üí  delete clean['CLAUDECODE'];\n   109‚Üí\n   110‚Üí  return clean;\n   111‚Üí}\n   112‚Üí\n   113‚Üí/**\n   114‚Üí * Create the per-execution sandbox directory structure and write\n   115‚Üí * Claude config + credentials files.\n   116‚Üí */\n   117‚Üífunction createSandboxDir(\n   118‚Üí  executionId: string,\n   119‚Üí  accessToken: string | undefined,\n   120‚Üí  logger: Logger,\n   121‚Üí): string {\n   122‚Üí  const sandboxDir = path.join(os.tmpdir(), `dac-sandbox-${executionId}`);\n   123‚Üí  const homeDir = path.join(sandboxDir, 'home');\n   124‚Üí  const claudeDir = path.join(homeDir, '.claude');\n   125‚Üí  const workDir = path.join(sandboxDir, 'work');\n   126‚Üí  const tmpDir = path.join(sandboxDir, 'tmp');\n   127‚Üí\n   128‚Üí  fs.mkdirSync(claudeDir, { recursive: true });\n   129‚Üí  fs.mkdirSync(workDir, { recursive: true });\n   130‚Üí  fs.mkdirSync(tmpDir, { recursive: true });\n   131‚Üí\n   132‚Üí  // Claude onboarding config\n   133‚Üí  fs.writeFileSync(\n   134‚Üí    path.join(homeDir, '.claude.json'),\n   135‚Üí    JSON.stringify({ hasCompletedOnboarding: true }),\n   136‚Üí  );\n   137‚Üí\n   138‚Üí  // OAuth credentials (per-execution, no race condition)\n   139‚Üí  if (accessToken) {\n   140‚Üí    const credPayload = {\n   141‚Üí      claudeAiOauth: {\n   142‚Üí        token_type: 'Bearer',\n   143‚Üí        access_token: accessToken,\n   144‚Üí        expires_at: Math.floor(Date.now() / 1000) + 3600,\n   145‚Üí      },\n   146‚Üí    };\n   147‚Üí    fs.writeFileSync(\n   148‚Üí      path.join(claudeDir, '.credentials.json'),\n   149‚Üí      JSON.stringify(credPayload, null, 2),\n   150‚Üí    );\n   151‚Üí    // Restrict permissions on Linux\n   152‚Üí    if (process.platform === 'linux') {\n   153‚Üí      try { fs.chmodSync(path.join(claudeDir, '.credentials.json'), 0o600); } catch { /* ok */ }\n   154‚Üí    }\n   155‚Üí  }\n   156‚Üí\n   157‚Üí  logger.debug({ sandboxDir, executionId }, 'Sandbox directory created');\n   158‚Üí  return sandboxDir;\n   159‚Üí}\n   160‚Üí\n   161‚Üí/**\n   162‚Üí * Prepare a sandboxed execution environment.\n   163‚Üí * When bwrap is available: full namespace isolation.\n   164‚Üí * Fallback: per-execution HOME without namespace isolation.\n   165‚Üí */\n   166‚Üíexport function prepareSandbox(config: SandboxConfig, logger: Logger): SandboxResult {\n   167‚Üí  const oauthToken = config.env['ANTHROPIC_API_KEY'];\n   168‚Üí  const accessToken = config.accessToken ??\n   169‚Üí    (oauthToken?.startsWith('sk-ant-oat') ? oauthToken : undefined);\n   170‚Üí\n   171‚Üí  const sandboxDir = createSandboxDir(config.executionId, accessToken, logger);\n   172‚Üí  const homeDir = path.join(sandboxDir, 'home');\n   173‚Üí  const workDir = path.join(sandboxDir, 'work');\n   174‚Üí\n   175‚Üí  const cleanEnv = buildCleanEnv(config.env);\n   176‚Üí\n   177‚Üí  // Non-OAuth API keys (e.g. sk-ant-api*) must be passed via environment.\n   178‚Üí  // buildCleanEnv strips ANTHROPIC_API_KEY assuming it's handled via credentials\n   179‚Üí  // file, but only OAuth tokens (sk-ant-oat*) are written there. Re-inject\n   180‚Üí  // non-OAuth keys so the Claude CLI can authenticate.\n   181‚Üí  const apiKey = config.env['ANTHROPIC_API_KEY'];\n   182‚Üí  if (apiKey && !accessToken) {\n   183‚Üí    cleanEnv['ANTHROPIC_API_KEY'] = apiKey;\n   184‚Üí  }\n   185‚Üí\n   186‚Üí  if (isSandboxAvailable()) {\n   187‚Üí    // Full bwrap sandbox\n   188‚Üí    const bwrapArgs: string[] = [\n   189‚Üí      '--unshare-pid',\n   190‚Üí      '--unshare-uts',\n   191‚Üí      '--die-with-parent',\n   192‚Üí      // Read-only system mounts\n   193‚Üí      '--ro-bind', '/usr', '/usr',\n   194‚Üí      '--ro-bind', '/bin', '/bin',\n   195‚Üí      '--ro-bind', '/sbin', '/sbin',\n   196‚Üí      '--ro-bind', '/etc/resolv.conf', '/etc/resolv.conf',\n   197‚Üí      // Conditional system paths (cached at module init)\n   198‚Üí      ..._cachedStaticBwrapArgs,\n   199‚Üí      // Proc, dev\n   200‚Üí      '--proc', '/proc',\n   201‚Üí      '--dev', '/dev',\n   202‚Üí      '--tmpfs', '/run',\n   203‚Üí      // Per-execution writable mounts\n   204‚Üí      '--bind', homeDir, '/home/exec',\n   205‚Üí      '--bind', workDir, '/workspace',\n   206‚Üí      '--bind', path.join(sandboxDir, 'tmp'), '/tmp',\n   207‚Üí      // Environment\n   208‚Üí      '--setenv', 'HOME', '/home/exec',\n   209‚Üí      '--setenv', 'TMPDIR', '/tmp',\n   210‚Üí      '--chdir', '/workspace',\n   211‚Üí      '--new-session',\n   212‚Üí    ];\n   213‚Üí\n   214‚Üí    // Network isolation\n   215‚Üí    if (!config.networkAccess && config.networkPolicy?.mode !== 'allow-list') {\n   216‚Üí      bwrapArgs.push('--unshare-net');\n   217‚Üí    }\n   218‚Üí\n   219‚Üí    // Inject credential env vars into bwrap\n   220‚Üí    for (const [key, value] of Object.entries(cleanEnv)) {\n   221‚Üí      if (key !== 'PATH' && key !== 'NODE_ENV' && key !== 'LANG') {\n   222‚Üí        bwrapArgs.push('--setenv', key, value);\n   223‚Üí      }\n   224‚Üí    }\n   225‚Üí    bwrapArgs.push('--setenv', 'PATH', cleanEnv['PATH']!);\n   226‚Üí    bwrapArgs.push('--setenv', 'NODE_ENV', 'production');\n   227‚Üí\n   228‚Üí    // Separator + claude command\n   229‚Üí    const cli = buildCliArgs(\n   230‚Üí      config.maxBudgetUsd || config.maxTurns\n   231‚Üí        ? { maxBudgetUsd: config.maxBudgetUsd ?? null, maxTurns: config.maxTurns ?? null } as Parameters<typeof buildCliArgs>[0]\n   232‚Üí        : undefined,\n   233‚Üí    );\n   234‚Üí    bwrapArgs.push('--');\n   235‚Üí    bwrapArgs.push(cli.command, ...cli.args);\n   236‚Üí\n   237‚Üí    logger.info({ executionId: config.executionId, sandbox: 'bwrap' }, 'Using bwrap sandbox');\n   238‚Üí\n   239‚Üí    return {\n   240‚Üí      command: 'bwrap',\n   241‚Üí      args: bwrapArgs,\n   242‚Üí      env: cleanEnv,\n   243‚Üí      cwd: workDir,\n   244‚Üí      sandboxDir,\n   245‚Üí      proxyRequired: config.networkPolicy?.mode === 'allow-list',\n   246‚Üí    };\n   247‚Üí  }\n   248‚Üí\n   249‚Üí  // Fallback: no namespace isolation ‚Äî refuse if a network policy is present.\n   250‚Üí  // Without bwrap network namespaces, HTTP_PROXY env vars can be bypassed by\n   251‚Üí  // direct TCP connections, so the proxy cannot enforce allow-list policies.\n   252‚Üí  if (config.networkPolicy) {\n   253‚Üí    throw new Error(\n   254‚Üí      `Cannot enforce network policy (mode=\"${config.networkPolicy.mode}\") in fallback mode: ` +\n   255‚Üí      `bwrap is unavailable and namespace isolation is required to restrict network access. ` +\n   256‚Üí      `Install bubblewrap (bwrap) on this host to execute personas with network policies.`,\n   257‚Üí    );\n   258‚Üí  }\n   259‚Üí\n   260‚Üí  cleanEnv['HOME'] = homeDir;\n   261‚Üí  cleanEnv['TMPDIR'] = path.join(sandboxDir, 'tmp');\n   262‚Üí\n   263‚Üí  const cli = buildCliArgs(\n   264‚Üí    config.maxBudgetUsd || config.maxTurns\n   265‚Üí      ? { maxBudgetUsd: config.maxBudgetUsd ?? null, maxTurns: config.maxTurns ?? null } as Parameters<typeof buildCliArgs>[0]\n   266‚Üí      : undefined,\n   267‚Üí  );\n   268‚Üí  const claudeCmd = resolveClaudeCommand();\n   269‚Üí  const claudeArgs = cli.args;\n   270‚Üí\n   271‚Üí  logger.info({ executionId: config.executionId, sandbox: 'fallback' }, 'Using fallback (per-execution HOME, no namespace isolation)');\n   272‚Üí\n   273‚Üí  return {\n   274‚Üí    command: claudeCmd,\n   275‚Üí    args: claudeArgs,\n   276‚Üí    env: cleanEnv,\n   277‚Üí    cwd: workDir,\n   278‚Üí    sandboxDir,\n   279‚Üí  };\n   280‚Üí}\n   281‚Üí\n   282‚Üí/**\n   283‚Üí * Clean up sandbox directory after execution completes.\n   284‚Üí */\n   285‚Üíexport function cleanupSandbox(sandboxDir: string, logger: Logger): void {\n   286‚Üí  try {\n   287‚Üí    fs.rmSync(sandboxDir, { recursive: true, force: true });\n   288‚Üí    logger.debug({ sandboxDir }, 'Sandbox cleaned up');\n   289‚Üí  } catch (err) {\n   290‚Üí    logger.warn({ err, sandboxDir }, 'Failed to cleanup sandbox directory');\n   291‚Üí  }\n   292‚Üí}\n   293‚Üí"}]},"parent_tool_use_id":null,"session_id":"19136761-88a4-45c5-8117-c85f24e21ebe","uuid":"6464c9f5-e296-4cee-bec0-990339bfa035","timestamp":"2026-03-18T11:56:46.269Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\worker\\src\\sandbox.ts","content":"import fs from 'node:fs';\nimport path from 'node:path';\nimport os from 'node:os';\nimport { execSync } from 'node:child_process';\nimport type { Logger } from 'pino';\n\nimport { buildCliArgs, type NetworkPolicy } from '@dac-cloud/shared';\n\nexport interface SandboxConfig {\n  executionId: string;\n  env: Record<string, string>;\n  accessToken?: string;\n  networkAccess: boolean;\n  networkPolicy?: NetworkPolicy;\n  timeoutMs: number;\n  maxBudgetUsd?: number;\n  maxTurns?: number;\n}\n\nexport interface SandboxResult {\n  command: string;\n  args: string[];\n  env: Record<string, string>;\n  cwd: string;\n  sandboxDir: string;\n  proxyRequired?: boolean;\n}\n\nlet _bwrapAvailable: boolean | null = null;\n\n/**\n * Cached bwrap args for static system paths that never change between executions.\n * Computed once at module load time to avoid 6 synchronous fs.existsSync calls per execution.\n */\nconst _cachedStaticBwrapArgs: string[] = (() => {\n  if (process.platform !== 'linux') return [];\n\n  const args: string[] = [];\n  const conditionalPaths: Array<{ path: string; args: string[] }> = [\n    { path: '/lib', args: ['--ro-bind', '/lib', '/lib'] },\n    { path: '/lib64', args: ['--ro-bind', '/lib64', '/lib64'] },\n    { path: '/etc/ssl', args: ['--ro-bind', '/etc/ssl', '/etc/ssl'] },\n    { path: '/etc/ca-certificates', args: ['--ro-bind', '/etc/ca-certificates', '/etc/ca-certificates'] },\n    { path: '/usr/local/lib/node_modules', args: ['--ro-bind', '/usr/local/lib/node_modules', '/usr/local/lib/node_modules'] },\n    { path: '/usr/local/bin/claude', args: ['--ro-bind', '/usr/local/bin/claude', '/usr/local/bin/claude'] },\n  ];\n\n  for (const entry of conditionalPaths) {\n    if (fs.existsSync(entry.path)) {\n      args.push(...entry.args);\n    }\n  }\n\n  return args;\n})();\n\n/**\n * Check if bubblewrap (bwrap) is available on this system.\n * Cached after first call.\n */\nexport function isSandboxAvailable(): boolean {\n  if (_bwrapAvailable !== null) return _bwrapAvailable;\n\n  if (process.platform !== 'linux') {\n    _bwrapAvailable = false;\n    return false;\n  }\n\n  try {\n    execSync('which bwrap', { stdio: 'ignore' });\n    _bwrapAvailable = true;\n  } catch {\n    _bwrapAvailable = false;\n  }\n  return _bwrapAvailable;\n}\n\n/**\n * Resolve the claude CLI command path.\n */\nfunction resolveClaudeCommand(): string {\n  if (process.platform === 'win32') {\n    try {\n      return execSync('where claude', { encoding: 'utf8' }).trim().split('\\n')[0]!;\n    } catch { /* fall through */ }\n  }\n  return 'claude';\n}\n\n/**\n * Build a clean environment dict for the child process.\n * Never inherits from process.env ‚Äî only explicit values.\n */\nfunction buildCleanEnv(assignmentEnv: Record<string, string>): Record<string, string> {\n  const clean: Record<string, string> = {\n    PATH: '/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin',\n    NODE_ENV: 'production',\n    LANG: 'en_US.UTF-8',\n  };\n\n  // Copy assignment env vars (credentials, config)\n  for (const [key, value] of Object.entries(assignmentEnv)) {\n    if (key === 'ANTHROPIC_API_KEY') continue; // handled via credentials file\n    clean[key] = value;\n  }\n\n  // Explicitly unset CLAUDECODE to prevent nested session guard\n  delete clean['CLAUDECODE'];\n\n  return clean;\n}\n\n/**\n * Create the per-execution sandbox directory structure and write\n * Claude config + credentials files.\n */\nfunction createSandboxDir(\n  executionId: string,\n  accessToken: string | undefined,\n  logger: Logger,\n): string {\n  const sandboxDir = path.join(os.tmpdir(), `dac-sandbox-${executionId}`);\n  const homeDir = path.join(sandboxDir, 'home');\n  const claudeDir = path.join(homeDir, '.claude');\n  const workDir = path.join(sandboxDir, 'work');\n  const tmpDir = path.join(sandboxDir, 'tmp');\n\n  fs.mkdirSync(claudeDir, { recursive: true });\n  fs.mkdirSync(workDir, { recursive: true });\n  fs.mkdirSync(tmpDir, { recursive: true });\n\n  // Claude onboarding config\n  fs.writeFileSync(\n    path.join(homeDir, '.claude.json'),\n    JSON.stringify({ hasCompletedOnboarding: true }),\n  );\n\n  // OAuth credentials (per-execution, no race condition)\n  if (accessToken) {\n    const credPayload = {\n      claudeAiOauth: {\n        token_type: 'Bearer',\n        access_token: accessToken,\n        expires_at: Math.floor(Date.now() / 1000) + 3600,\n      },\n    };\n    fs.writeFileSync(\n      path.join(claudeDir, '.credentials.json'),\n      JSON.stringify(credPayload, null, 2),\n    );\n    // Restrict permissions on Linux\n    if (process.platform === 'linux') {\n      try { fs.chmodSync(path.join(claudeDir, '.credentials.json'), 0o600); } catch { /* ok */ }\n    }\n  }\n\n  logger.debug({ sandboxDir, executionId }, 'Sandbox directory created');\n  return sandboxDir;\n}\n\n/**\n * Prepare a sandboxed execution environment.\n * When bwrap is available: full namespace isolation.\n * Fallback: per-execution HOME without namespace isolation.\n */\nexport function prepareSandbox(config: SandboxConfig, logger: Logger): SandboxResult {\n  const oauthToken = config.env['ANTHROPIC_API_KEY'];\n  const accessToken = config.accessToken ??\n    (oauthToken?.startsWith('sk-ant-oat') ? oauthToken : undefined);\n\n  const sandboxDir = createSandboxDir(config.executionId, accessToken, logger);\n  const homeDir = path.join(sandboxDir, 'home');\n  const workDir = path.join(sandboxDir, 'work');\n\n  const cleanEnv = buildCleanEnv(config.env);\n\n  // Non-OAuth API keys (e.g. sk-ant-api*) must be passed via environment.\n  // buildCleanEnv strips ANTHROPIC_API_KEY assuming it's handled via credentials\n  // file, but only OAuth tokens (sk-ant-oat*) are written there. Re-inject\n  // non-OAuth keys so the Claude CLI can authenticate.\n  const apiKey = config.env['ANTHROPIC_API_KEY'];\n  if (apiKey && !accessToken) {\n    cleanEnv['ANTHROPIC_API_KEY'] = apiKey;\n  }\n\n  if (isSandboxAvailable()) {\n    // Full bwrap sandbox\n    const bwrapArgs: string[] = [\n      '--unshare-pid',\n      '--unshare-uts',\n      '--die-with-parent',\n      // Read-only system mounts\n      '--ro-bind', '/usr', '/usr',\n      '--ro-bind', '/bin', '/bin',\n      '--ro-bind', '/sbin', '/sbin',\n      '--ro-bind', '/etc/resolv.conf', '/etc/resolv.conf',\n      // Conditional system paths (cached at module init)\n      ..._cachedStaticBwrapArgs,\n      // Proc, dev\n      '--proc', '/proc',\n      '--dev', '/dev',\n      '--tmpfs', '/run',\n      // Per-execution writable mounts\n      '--bind', homeDir, '/home/exec',\n      '--bind', workDir, '/workspace',\n      '--bind', path.join(sandboxDir, 'tmp'), '/tmp',\n      // Environment\n      '--setenv', 'HOME', '/home/exec',\n      '--setenv', 'TMPDIR', '/tmp',\n      '--chdir', '/workspace',\n      '--new-session',\n    ];\n\n    // Network isolation\n    if (!config.networkAccess && config.networkPolicy?.mode !== 'allow-list') {\n      bwrapArgs.push('--unshare-net');\n    }\n\n    // Inject credential env vars into bwrap\n    for (const [key, value] of Object.entries(cleanEnv)) {\n      if (key !== 'PATH' && key !== 'NODE_ENV' && key !== 'LANG') {\n        bwrapArgs.push('--setenv', key, value);\n      }\n    }\n    bwrapArgs.push('--setenv', 'PATH', cleanEnv['PATH']!);\n    bwrapArgs.push('--setenv', 'NODE_ENV', 'production');\n\n    // Separator + claude command\n    const cli = buildCliArgs(\n      config.maxBudgetUsd || config.maxTurns\n        ? { maxBudgetUsd: config.maxBudgetUsd ?? null, maxTurns: config.maxTurns ?? null } as Parameters<typeof buildCliArgs>[0]\n        : undefined,\n    );\n    bwrapArgs.push('--');\n    bwrapArgs.push(cli.command, ...cli.args);\n\n    logger.info({ executionId: config.executionId, sandbox: 'bwrap' }, 'Using bwrap sandbox');\n\n    return {\n      command: 'bwrap',\n      args: bwrapArgs,\n      env: cleanEnv,\n      cwd: workDir,\n      sandboxDir,\n      proxyRequired: config.networkPolicy?.mode === 'allow-list',\n    };\n  }\n\n  // Fallback: no namespace isolation ‚Äî refuse if a network policy is present.\n  // Without bwrap network namespaces, HTTP_PROXY env vars can be bypassed by\n  // direct TCP connections, so the proxy cannot enforce allow-list policies.\n  if (config.networkPolicy) {\n    throw new Error(\n      `Cannot enforce network policy (mode=\"${config.networkPolicy.mode}\") in fallback mode: ` +\n      `bwrap is unavailable and namespace isolation is required to restrict network access. ` +\n      `Install bubblewrap (bwrap) on this host to execute personas with network policies.`,\n    );\n  }\n\n  cleanEnv['HOME'] = homeDir;\n  cleanEnv['TMPDIR'] = path.join(sandboxDir, 'tmp');\n\n  const cli = buildCliArgs(\n    config.maxBudgetUsd || config.maxTurns\n      ? { maxBudgetUsd: config.maxBudgetUsd ?? null, maxTurns: config.maxTurns ?? null } as Parameters<typeof buildCliArgs>[0]\n      : undefined,\n  );\n  const claudeCmd = resolveClaudeCommand();\n  const claudeArgs = cli.args;\n\n  logger.info({ executionId: config.executionId, sandbox: 'fallback' }, 'Using fallback (per-execution HOME, no namespace isolation)');\n\n  return {\n    command: claudeCmd,\n    args: claudeArgs,\n    env: cleanEnv,\n    cwd: workDir,\n    sandboxDir,\n  };\n}\n\n/**\n * Clean up sandbox directory after execution completes.\n */\nexport function cleanupSandbox(sandboxDir: string, logger: Logger): void {\n  try {\n    fs.rmSync(sandboxDir, { recursive: true, force: true });\n    logger.debug({ sandboxDir }, 'Sandbox cleaned up');\n  } catch (err) {\n    logger.warn({ err, sandboxDir }, 'Failed to cleanup sandbox directory');\n  }\n}\n","numLines":293,"startLine":1,"totalLines":293}}}
