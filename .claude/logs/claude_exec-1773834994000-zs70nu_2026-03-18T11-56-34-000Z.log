[2026-03-18T11:56:48.488Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QPcC3H4Qvb8PGE3WVK96W5","type":"tool_result","content":"     1‚Üíimport type { Persona, PersonaToolDefinition, StructuredPrompt } from './types.js';\n     2‚Üí\n     3‚Üí// ---------------------------------------------------------------------------\n     4‚Üí// Protocol instruction constants (matching desktop engine/prompt.rs)\n     5‚Üí// ---------------------------------------------------------------------------\n     6‚Üí\n     7‚Üíconst PROTOCOL_USER_MESSAGE = `### User Message Protocol\n     8‚ÜíTo send a message to the user, output a JSON object on its own line:\n     9‚Üí\\`\\`\\`json\n    10‚Üí{\"user_message\": {\"title\": \"Optional Title\", \"content\": \"Message content here\", \"content_type\": \"info\", \"priority\": \"normal\"}}\n    11‚Üí\\`\\`\\`\n    12‚ÜíFields:\n    13‚Üí- \\`title\\` (optional): Short title for the message\n    14‚Üí- \\`content\\` (required): The message body\n    15‚Üí- \\`content_type\\` (optional): \"info\", \"warning\", \"error\", \"success\" (default: \"info\")\n    16‚Üí- \\`priority\\` (optional): \"low\", \"normal\", \"high\", \"urgent\" (default: \"normal\")\n    17‚Üí\n    18‚Üí`;\n    19‚Üí\n    20‚Üíconst PROTOCOL_PERSONA_ACTION = `### Persona Action Protocol\n    21‚ÜíTo trigger an action on another persona, output a JSON object on its own line:\n    22‚Üí\\`\\`\\`json\n    23‚Üí{\"persona_action\": {\"target\": \"target-persona-id\", \"action\": \"run\", \"input\": {\"key\": \"value\"}}}\n    24‚Üí\\`\\`\\`\n    25‚ÜíFields:\n    26‚Üí- \\`target\\` (required): The persona ID to target\n    27‚Üí- \\`action\\` (optional): Action to perform (default: \"run\")\n    28‚Üí- \\`input\\` (optional): JSON data to pass to the target persona\n    29‚Üí\n    30‚Üí`;\n    31‚Üí\n    32‚Üíconst PROTOCOL_EMIT_EVENT = `### Emit Event Protocol\n    33‚ÜíTo emit an event to the system event bus, output a JSON object on its own line:\n    34‚Üí\\`\\`\\`json\n    35‚Üí{\"emit_event\": {\"type\": \"task_completed\", \"data\": {\"result\": \"success\", \"details\": \"...\"}}}\n    36‚Üí\\`\\`\\`\n    37‚ÜíFields:\n    38‚Üí- \\`type\\` (required): Event type identifier\n    39‚Üí- \\`data\\` (optional): Arbitrary JSON payload\n    40‚Üí\n    41‚Üí`;\n    42‚Üí\n    43‚Üíconst PROTOCOL_AGENT_MEMORY = `### Agent Memory Protocol\n    44‚ÜíTo store a memory for future reference, output a JSON object on its own line:\n    45‚Üí\\`\\`\\`json\n    46‚Üí{\"agent_memory\": {\"title\": \"Memory Title\", \"content\": \"What to remember\", \"category\": \"learning\", \"importance\": 5, \"tags\": [\"tag1\", \"tag2\"]}}\n    47‚Üí\\`\\`\\`\n    48‚ÜíFields:\n    49‚Üí- \\`title\\` (required): Short title for the memory\n    50‚Üí- \\`content\\` (required): Detailed content to remember\n    51‚Üí- \\`category\\` (optional): \"learning\", \"preference\", \"fact\", \"procedure\" (default: \"general\")\n    52‚Üí- \\`importance\\` (optional): 1-10 importance rating (default: 5)\n    53‚Üí- \\`tags\\` (optional): Array of string tags for categorization\n    54‚Üí\n    55‚Üí`;\n    56‚Üí\n    57‚Üíconst PROTOCOL_MANUAL_REVIEW = `### Manual Review Protocol\n    58‚ÜíTo flag something for human review, output a JSON object on its own line:\n    59‚Üí\\`\\`\\`json\n    60‚Üí{\"manual_review\": {\"title\": \"Review Title\", \"description\": \"What needs review\", \"severity\": \"medium\", \"context_data\": \"relevant context\", \"suggested_actions\": [\"action1\", \"action2\"]}}\n    61‚Üí\\`\\`\\`\n    62‚ÜíFields:\n    63‚Üí- \\`title\\` (required): Short title describing the review item\n    64‚Üí- \\`description\\` (optional): Detailed description\n    65‚Üí- \\`severity\\` (optional): \"low\", \"medium\", \"high\", \"critical\" (default: \"medium\")\n    66‚Üí- \\`context_data\\` (optional): Additional context string\n    67‚Üí- \\`suggested_actions\\` (optional): Array of suggested resolution steps\n    68‚Üí\n    69‚Üí`;\n    70‚Üí\n    71‚Üíconst PROTOCOL_EXECUTION_FLOW = `### Execution Flow Protocol\n    72‚ÜíTo declare execution flow metadata, output a JSON object on its own line:\n    73‚Üí\\`\\`\\`json\n    74‚Üí{\"execution_flow\": {\"flows\": [{\"step\": 1, \"action\": \"analyze\", \"status\": \"completed\"}, {\"step\": 2, \"action\": \"implement\", \"status\": \"pending\"}]}}\n    75‚Üí\\`\\`\\`\n    76‚ÜíFields:\n    77‚Üí- \\`flows\\` (required): JSON value describing the execution flow steps\n    78‚Üí\n    79‚Üí`;\n    80‚Üí\n    81‚Üíconst PROTOCOL_OUTCOME_ASSESSMENT = `### Outcome Assessment Protocol\n    82‚ÜíIMPORTANT: At the very end of your execution, you MUST output an outcome assessment as the last thing before finishing:\n    83‚Üí\\`\\`\\`json\n    84‚Üí{\"outcome_assessment\": {\"accomplished\": true, \"summary\": \"Brief description of what was achieved\"}}\n    85‚Üí\\`\\`\\`\n    86‚ÜíFields:\n    87‚Üí- \\`accomplished\\` (required): true if the task was successfully completed from a business perspective, false if it could not be completed\n    88‚Üí- \\`summary\\` (required): Brief description of the outcome\n    89‚Üí- \\`blockers\\` (optional): List of reasons the task could not be completed (only when accomplished is false)\n    90‚Üí\n    91‚ÜíYou MUST always output this assessment. Set accomplished to false if:\n    92‚Üí- Required data was not available or accessible\n    93‚Üí- External services were unreachable or returned errors that prevented task completion\n    94‚Üí- The task requirements could not be fulfilled with the available tools\n    95‚Üí- You could not verify the task was completed correctly\n    96‚Üí\n    97‚Üí`;\n    98‚Üí\n    99‚Üí// ---------------------------------------------------------------------------\n   100‚Üí// Tool documentation\n   101‚Üí// ---------------------------------------------------------------------------\n   102‚Üí\n   103‚Üíexport function buildToolDocumentation(tool: PersonaToolDefinition): string {\n   104‚Üí  let doc = `### ${tool.name}\\n${tool.description}\\n`;\n   105‚Üí  doc += `**Category**: ${tool.category}\\n`;\n   106‚Üí\n   107‚Üí  if (!tool.scriptPath) {\n   108‚Üí    if (tool.implementationGuide) {\n   109‚Üí      doc += '**Implementation Guide**:\\n';\n   110‚Üí      doc += tool.implementationGuide;\n   111‚Üí      doc += '\\n';\n   112‚Üí    } else {\n   113‚Üí      doc += '**Implementation**: Use the Bash tool with `curl` to call the API. Credentials are available as environment variables (e.g. `$GOOGLE_ACCESS_TOKEN`).\\n';\n   114‚Üí    }\n   115‚Üí  } else {\n   116‚Üí    doc += `**Usage**: npx tsx \"${tool.scriptPath}\" --input '<JSON>'\\n`;\n   117‚Üí  }\n   118‚Üí\n   119‚Üí  if (tool.inputSchema) {\n   120‚Üí    doc += `**Input Schema**: ${tool.inputSchema}\\n`;\n   121‚Üí  }\n   122‚Üí  if (tool.requiresCredentialType) {\n   123‚Üí    doc += `**Requires Credential**: ${tool.requiresCredentialType} (available as env var)\\n`;\n   124‚Üí  }\n   125‚Üí  return doc;\n   126‚Üí}\n   127‚Üí\n   128‚Üí// ---------------------------------------------------------------------------\n   129‚Üí// Prompt assembly (ported from engine/prompt.rs)\n   130‚Üí// ---------------------------------------------------------------------------\n   131‚Üí\n   132‚Üíexport function assemblePrompt(\n   133‚Üí  persona: Persona,\n   134‚Üí  tools: PersonaToolDefinition[],\n   135‚Üí  inputData?: Record<string, unknown>,\n   136‚Üí  credentialHints?: string[],\n   137‚Üí): string {\n   138‚Üí  let prompt = '';\n   139‚Üí\n   140‚Üí  // Header\n   141‚Üí  prompt += `# Persona: ${persona.name}\\n\\n`;\n   142‚Üí\n   143‚Üí  // Description\n   144‚Üí  if (persona.description) {\n   145‚Üí    prompt += '## Description\\n';\n   146‚Üí    prompt += persona.description;\n   147‚Üí    prompt += '\\n\\n';\n   148‚Üí  }\n   149‚Üí\n   150‚Üí  // Identity and Instructions from structured_prompt or system_prompt\n   151‚Üí  let usedStructured = false;\n   152‚Üí  if (persona.structuredPrompt) {\n   153‚Üí    try {\n   154‚Üí      const sp: StructuredPrompt = JSON.parse(persona.structuredPrompt);\n   155‚Üí      usedStructured = true;\n   156‚Üí\n   157‚Üí      if (sp.identity) {\n   158‚Üí        prompt += '## Identity\\n';\n   159‚Üí        prompt += sp.identity;\n   160‚Üí        prompt += '\\n\\n';\n   161‚Üí      }\n   162‚Üí\n   163‚Üí      if (sp.instructions) {\n   164‚Üí        prompt += '## Instructions\\n';\n   165‚Üí        prompt += sp.instructions;\n   166‚Üí        prompt += '\\n\\n';\n   167‚Üí      }\n   168‚Üí\n   169‚Üí      if (sp.toolGuidance) {\n   170‚Üí        prompt += '## Tool Guidance\\n';\n   171‚Üí        prompt += sp.toolGuidance;\n   172‚Üí        prompt += '\\n\\n';\n   173‚Üí      }\n   174‚Üí\n   175‚Üí      if (sp.examples) {\n   176‚Üí        prompt += '## Examples\\n';\n   177‚Üí        prompt += sp.examples;\n   178‚Üí        prompt += '\\n\\n';\n   179‚Üí      }\n   180‚Üí\n   181‚Üí      if (sp.errorHandling) {\n   182‚Üí        prompt += '## Error Handling\\n';\n   183‚Üí        prompt += sp.errorHandling;\n   184‚Üí        prompt += '\\n\\n';\n   185‚Üí      }\n   186‚Üí\n   187‚Üí      if (sp.customSections) {\n   188‚Üí        for (const section of sp.customSections) {\n   189‚Üí          const heading = section.title ?? section.label ?? section.name ?? section.key;\n   190‚Üí          if (heading && section.content) {\n   191‚Üí            prompt += `## ${heading}\\n`;\n   192‚Üí            prompt += section.content;\n   193‚Üí            prompt += '\\n\\n';\n   194‚Üí          }\n   195‚Üí        }\n   196‚Üí      }\n   197‚Üí\n   198‚Üí      if (sp.webSearch) {\n   199‚Üí        prompt += '## Web Search Research Prompt\\n';\n   200‚Üí        prompt += 'When performing web searches during this execution, use the following research guidance:\\n\\n';\n   201‚Üí        prompt += sp.webSearch;\n   202‚Üí        prompt += '\\n\\n';\n   203‚Üí      }\n   204‚Üí    } catch {\n   205‚Üí      usedStructured = false;\n   206‚Üí    }\n   207‚Üí  }\n   208‚Üí\n   209‚Üí  if (!usedStructured) {\n   210‚Üí    prompt += '## Identity\\n';\n   211‚Üí    prompt += persona.systemPrompt;\n   212‚Üí    prompt += '\\n\\n';\n   213‚Üí  }\n   214‚Üí\n   215‚Üí  // Available Tools\n   216‚Üí  if (tools.length > 0) {\n   217‚Üí    prompt += '## Available Tools\\n';\n   218‚Üí    for (const tool of tools) {\n   219‚Üí      prompt += buildToolDocumentation(tool);\n   220‚Üí      prompt += '\\n';\n   221‚Üí    }\n   222‚Üí  }\n   223‚Üí\n   224‚Üí  // Execution Environment (always Linux for cloud)\n   225‚Üí  prompt += '## Execution Environment\\n';\n   226‚Üí  prompt += '- Platform: Linux/macOS\\n';\n   227‚Üí  prompt += '- Available: `curl`, `node`, `npx`, `git`, `bash`\\n';\n   228‚Üí  prompt += '- PREFER `curl` for HTTP API calls ‚Äî avoid writing scripts when a single curl command works\\n';\n   229‚Üí  prompt += '- Credentials are pre-injected as environment variables ‚Äî access them with `$ENV_VAR_NAME` in curl commands\\n\\n';\n   230‚Üí\n   231‚Üí  // Available Credentials\n   232‚Üí  if (credentialHints && credentialHints.length > 0) {\n   233‚Üí    prompt += '## Available Credentials (as environment variables)\\n';\n   234‚Üí    prompt += 'These env vars are ALREADY SET in your shell ‚Äî use them directly in curl commands:\\n';\n   235‚Üí    for (const hint of credentialHints) {\n   236‚Üí      prompt += `- ${hint}\\n`;\n   237‚Üí    }\n   238‚Üí    prompt += '\\nExample: `curl -H \"Authorization: Bearer $GOOGLE_ACCESS_TOKEN\" https://api.example.com`\\n';\n   239‚Üí    prompt += 'IMPORTANT: Do NOT check if env vars exist ‚Äî they are pre-configured. Just use them.\\n\\n';\n   240‚Üí  }\n   241‚Üí\n   242‚Üí  // Communication Protocols\n   243‚Üí  prompt += '## Communication Protocols\\n\\n';\n   244‚Üí  prompt += PROTOCOL_USER_MESSAGE;\n   245‚Üí  prompt += PROTOCOL_PERSONA_ACTION;\n   246‚Üí  prompt += PROTOCOL_EMIT_EVENT;\n   247‚Üí  prompt += PROTOCOL_AGENT_MEMORY;\n   248‚Üí  prompt += PROTOCOL_MANUAL_REVIEW;\n   249‚Üí  prompt += PROTOCOL_EXECUTION_FLOW;\n   250‚Üí  prompt += PROTOCOL_OUTCOME_ASSESSMENT;\n   251‚Üí\n   252‚Üí  // Input Data\n   253‚Üí  if (inputData) {\n   254‚Üí    // Inject use case context if present\n   255‚Üí    const useCase = inputData['_use_case'] as Record<string, unknown> | undefined;\n   256‚Üí    if (useCase) {\n   257‚Üí      prompt += '## Use Case Context\\n';\n   258‚Üí      if (typeof useCase['title'] === 'string') {\n   259‚Üí        prompt += `You are executing the use case: **${useCase['title']}**\\n`;\n   260‚Üí      }\n   261‚Üí      if (typeof useCase['description'] === 'string') {\n   262‚Üí        prompt += `Description: ${useCase['description']}\\n`;\n   263‚Üí      }\n   264‚Üí      prompt += 'Focus on this specific use case.\\n\\n';\n   265‚Üí    }\n   266‚Üí\n   267‚Üí    // Inject time filter constraints\n   268‚Üí    const timeFilter = inputData['_time_filter'] as Record<string, unknown> | undefined;\n   269‚Üí    if (timeFilter) {\n   270‚Üí      prompt += '## Time Filter (IMPORTANT)\\n';\n   271‚Üí      if (typeof timeFilter['description'] === 'string') {\n   272‚Üí        prompt += `${timeFilter['description']}\\n`;\n   273‚Üí      }\n   274‚Üí      if (typeof timeFilter['field'] === 'string' && typeof timeFilter['default_window'] === 'string') {\n   275‚Üí        prompt += `When querying data, use the '${timeFilter['field']}' parameter to limit results to the last ${timeFilter['default_window']}. `;\n   276‚Üí        prompt += 'Do NOT fetch all historical data ‚Äî only process recent items within this time window.\\n';\n   277‚Üí      }\n   278‚Üí      prompt += '\\n';\n   279‚Üí    }\n   280‚Üí\n   281‚Üí    prompt += '## Input Data\\n```json\\n';\n   282‚Üí    prompt += JSON.stringify(inputData, null, 2);\n   283‚Üí    prompt += '\\n```\\n\\n';\n   284‚Üí  }\n   285‚Üí\n   286‚Üí  // Execute Now\n   287‚Üí  prompt += '## EXECUTE NOW\\n';\n   288‚Üí  prompt += `You are ${persona.name}. Execute your task now. Follow your instructions precisely.\\n`;\n   289‚Üí  if (tools.length > 0) {\n   290‚Üí    prompt += 'Use available tools as needed.\\n';\n   291‚Üí  }\n   292‚Üí  prompt += 'Respond naturally and complete the task.\\n';\n   293‚Üí\n   294‚Üí  return prompt;\n   295‚Üí}\n   296‚Üí\n   297‚Üí// ---------------------------------------------------------------------------\n   298‚Üí// CLI args builder (ported from engine/prompt.rs)\n   299‚Üí// ---------------------------------------------------------------------------\n   300‚Üí\n   301‚Üíexport interface CliArgs {\n   302‚Üí  command: string;\n   303‚Üí  args: string[];\n   304‚Üí  envOverrides: Array<[string, string]>;\n   305‚Üí  envRemovals: string[];\n   306‚Üí}\n   307‚Üí\n   308‚Üíexport function buildCliArgs(\n   309‚Üí  persona?: Persona | null,\n   310‚Üí): CliArgs {\n   311‚Üí  const args = [\n   312‚Üí    '-p', '-',\n   313‚Üí    '--output-format', 'stream-json',\n   314‚Üí    '--verbose',\n   315‚Üí    '--dangerously-skip-permissions',\n   316‚Üí  ];\n   317‚Üí\n   318‚Üí  // Persona-specific flags\n   319‚Üí  if (persona) {\n   320‚Üí    if (persona.maxBudgetUsd && persona.maxBudgetUsd > 0) {\n   321‚Üí      args.push('--max-budget-usd', String(persona.maxBudgetUsd));\n   322‚Üí    }\n   323‚Üí    if (persona.maxTurns && persona.maxTurns > 0) {\n   324‚Üí      args.push('--max-turns', String(persona.maxTurns));\n   325‚Üí    }\n   326‚Üí  }\n   327‚Üí\n   328‚Üí  const envOverrides: Array<[string, string]> = [];\n   329‚Üí  const envRemovals: string[] = ['CLAUDECODE', 'CLAUDE_CODE'];\n   330‚Üí\n   331‚Üí  return { command: 'claude', args, envOverrides, envRemovals };\n   332‚Üí}\n   333‚Üí"}]},"parent_tool_use_id":null,"session_id":"19136761-88a4-45c5-8117-c85f24e21ebe","uuid":"59501609-ef25-4af5-a4e0-617aece3dcbe","timestamp":"2026-03-18T11:56:48.163Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\shared\\src\\prompt.ts","content":"import type { Persona, PersonaToolDefinition, StructuredPrompt } from './types.js';\n\n// ---------------------------------------------------------------------------\n// Protocol instruction constants (matching desktop engine/prompt.rs)\n// ---------------------------------------------------------------------------\n\nconst PROTOCOL_USER_MESSAGE = `### User Message Protocol\nTo send a message to the user, output a JSON object on its own line:\n\\`\\`\\`json\n{\"user_message\": {\"title\": \"Optional Title\", \"content\": \"Message content here\", \"content_type\": \"info\", \"priority\": \"normal\"}}\n\\`\\`\\`\nFields:\n- \\`title\\` (optional): Short title for the message\n- \\`content\\` (required): The message body\n- \\`content_type\\` (optional): \"info\", \"warning\", \"error\", \"success\" (default: \"info\")\n- \\`priority\\` (optional): \"low\", \"normal\", \"high\", \"urgent\" (default: \"normal\")\n\n`;\n\nconst PROTOCOL_PERSONA_ACTION = `### Persona Action Protocol\nTo trigger an action on another persona, output a JSON object on its own line:\n\\`\\`\\`json\n{\"persona_action\": {\"target\": \"target-persona-id\", \"action\": \"run\", \"input\": {\"key\": \"value\"}}}\n\\`\\`\\`\nFields:\n- \\`target\\` (required): The persona ID to target\n- \\`action\\` (optional): Action to perform (default: \"run\")\n- \\`input\\` (optional): JSON data to pass to the target persona\n\n`;\n\nconst PROTOCOL_EMIT_EVENT = `### Emit Event Protocol\nTo emit an event to the system event bus, output a JSON object on its own line:\n\\`\\`\\`json\n{\"emit_event\": {\"type\": \"task_completed\", \"data\": {\"result\": \"success\", \"details\": \"...\"}}}\n\\`\\`\\`\nFields:\n- \\`type\\` (required): Event type identifier\n- \\`data\\` (optional): Arbitrary JSON payload\n\n`;\n\nconst PROTOCOL_AGENT_MEMORY = `### Agent Memory Protocol\nTo store a memory for future reference, output a JSON object on its own line:\n\\`\\`\\`json\n{\"agent_memory\": {\"title\": \"Memory Title\", \"content\": \"What to remember\", \"category\": \"learning\", \"importance\": 5, \"tags\": [\"tag1\", \"tag2\"]}}\n\\`\\`\\`\nFields:\n- \\`title\\` (required): Short title for the memory\n- \\`content\\` (required): Detailed content to remember\n- \\`category\\` (optional): \"learning\", \"preference\", \"fact\", \"procedure\" (default: \"general\")\n- \\`importance\\` (optional): 1-10 importance rating (default: 5)\n- \\`tags\\` (optional): Array of string tags for categorization\n\n`;\n\nconst PROTOCOL_MANUAL_REVIEW = `### Manual Review Protocol\nTo flag something for human review, output a JSON object on its own line:\n\\`\\`\\`json\n{\"manual_review\": {\"title\": \"Review Title\", \"description\": \"What needs review\", \"severity\": \"medium\", \"context_data\": \"relevant context\", \"suggested_actions\": [\"action1\", \"action2\"]}}\n\\`\\`\\`\nFields:\n- \\`title\\` (required): Short title describing the review item\n- \\`description\\` (optional): Detailed description\n- \\`severity\\` (optional): \"low\", \"medium\", \"high\", \"critical\" (default: \"medium\")\n- \\`context_data\\` (optional): Additional context string\n- \\`suggested_actions\\` (optional): Array of suggested resolution steps\n\n`;\n\nconst PROTOCOL_EXECUTION_FLOW = `### Execution Flow Protocol\nTo declare execution flow metadata, output a JSON object on its own line:\n\\`\\`\\`json\n{\"execution_flow\": {\"flows\": [{\"step\": 1, \"action\": \"analyze\", \"status\": \"completed\"}, {\"step\": 2, \"action\": \"implement\", \"status\": \"pending\"}]}}\n\\`\\`\\`\nFields:\n- \\`flows\\` (required): JSON value describing the execution flow steps\n\n`;\n\nconst PROTOCOL_OUTCOME_ASSESSMENT = `### Outcome Assessment Protocol\nIMPORTANT: At the very end of your execution, you MUST output an outcome assessment as the last thing before finishing:\n\\`\\`\\`json\n{\"outcome_assessment\": {\"accomplished\": true, \"summary\": \"Brief description of what was achieved\"}}\n\\`\\`\\`\nFields:\n- \\`accomplished\\` (required): true if the task was successfully completed from a business perspective, false if it could not be completed\n- \\`summary\\` (required): Brief description of the outcome\n- \\`blockers\\` (optional): List of reasons the task could not be completed (only when accomplished is false)\n\nYou MUST always output this assessment. Set accomplished to false if:\n- Required data was not available or accessible\n- External services were unreachable or returned errors that prevented task completion\n- The task requirements could not be fulfilled with the available tools\n- You could not verify the task was completed correctly\n\n`;\n\n// ---------------------------------------------------------------------------\n// Tool documentation\n// ---------------------------------------------------------------------------\n\nexport function buildToolDocumentation(tool: PersonaToolDefinition): string {\n  let doc = `### ${tool.name}\\n${tool.description}\\n`;\n  doc += `**Category**: ${tool.category}\\n`;\n\n  if (!tool.scriptPath) {\n    if (tool.implementationGuide) {\n      doc += '**Implementation Guide**:\\n';\n      doc += tool.implementationGuide;\n      doc += '\\n';\n    } else {\n      doc += '**Implementation**: Use the Bash tool with `curl` to call the API. Credentials are available as environment variables (e.g. `$GOOGLE_ACCESS_TOKEN`).\\n';\n    }\n  } else {\n    doc += `**Usage**: npx tsx \"${tool.scriptPath}\" --input '<JSON>'\\n`;\n  }\n\n  if (tool.inputSchema) {\n    doc += `**Input Schema**: ${tool.inputSchema}\\n`;\n  }\n  if (tool.requiresCredentialType) {\n    doc += `**Requires Credential**: ${tool.requiresCredentialType} (available as env var)\\n`;\n  }\n  return doc;\n}\n\n// ---------------------------------------------------------------------------\n// Prompt assembly (ported from engine/prompt.rs)\n// ---------------------------------------------------------------------------\n\nexport function assemblePrompt(\n  persona: Persona,\n  tools: PersonaToolDefinition[],\n  inputData?: Record<string, unknown>,\n  credentialHints?: string[],\n): string {\n  let prompt = '';\n\n  // Header\n  prompt += `# Persona: ${persona.name}\\n\\n`;\n\n  // Description\n  if (persona.description) {\n    prompt += '## Description\\n';\n    prompt += persona.description;\n    prompt += '\\n\\n';\n  }\n\n  // Identity and Instructions from structured_prompt or system_prompt\n  let usedStructured = false;\n  if (persona.structuredPrompt) {\n    try {\n      const sp: StructuredPrompt = JSON.parse(persona.structuredPrompt);\n      usedStructured = true;\n\n      if (sp.identity) {\n        prompt += '## Identity\\n';\n        prompt += sp.identity;\n        prompt += '\\n\\n';\n      }\n\n      if (sp.instructions) {\n        prompt += '## Instructions\\n';\n        prompt += sp.instructions;\n        prompt += '\\n\\n';\n      }\n\n      if (sp.toolGuidance) {\n        prompt += '## Tool Guidance\\n';\n        prompt += sp.toolGuidance;\n        prompt += '\\n\\n';\n      }\n\n      if (sp.examples) {\n        prompt += '## Examples\\n';\n        prompt += sp.examples;\n        prompt += '\\n\\n';\n      }\n\n      if (sp.errorHandling) {\n        prompt += '## Error Handling\\n';\n        prompt += sp.errorHandling;\n        prompt += '\\n\\n';\n      }\n\n      if (sp.customSections) {\n        for (const section of sp.customSections) {\n          const heading = section.title ?? section.label ?? section.name ?? section.key;\n          if (heading && section.content) {\n            prompt += `## ${heading}\\n`;\n            prompt += section.content;\n            prompt += '\\n\\n';\n          }\n        }\n      }\n\n      if (sp.webSearch) {\n        prompt += '## Web Search Research Prompt\\n';\n        prompt += 'When performing web searches during this execution, use the following research guidance:\\n\\n';\n        prompt += sp.webSearch;\n        prompt += '\\n\\n';\n      }\n    } catch {\n      usedStructured = false;\n    }\n  }\n\n  if (!usedStructured) {\n    prompt += '## Identity\\n';\n    prompt += persona.systemPrompt;\n    prompt += '\\n\\n';\n  }\n\n  // Available Tools\n  if (tools.length > 0) {\n    prompt += '## Available Tools\\n';\n    for (const tool of tools) {\n      prompt += buildToolDocumentation(tool);\n      prompt += '\\n';\n    }\n  }\n\n  // Execution Environment (always Linux for cloud)\n  prompt += '## Execution Environment\\n';\n  prompt += '- Platform: Linux/macOS\\n';\n  prompt += '- Available: `curl`, `node`, `npx`, `git`, `bash`\\n';\n  prompt += '- PREFER `curl` for HTTP API calls ‚Äî avoid writing scripts when a single curl command works\\n';\n  prompt += '- Credentials are pre-injected as environment variables ‚Äî access them with `$ENV_VAR_NAME` in curl commands\\n\\n';\n\n  // Available Credentials\n  if (credentialHints && credentialHints.length > 0) {\n    prompt += '## Available Credentials (as environment variables)\\n';\n    prompt += 'These env vars are ALREADY SET in your shell ‚Äî use them directly in curl commands:\\n';\n    for (const hint of credentialHints) {\n      prompt += `- ${hint}\\n`;\n    }\n    prompt += '\\nExample: `curl -H \"Authorization: Bearer $GOOGLE_ACCESS_TOKEN\" https://api.example.com`\\n';\n    prompt += 'IMPORTANT: Do NOT check if env vars exist ‚Äî they are pre-configured. Just use them.\\n\\n';\n  }\n\n  // Communication Protocols\n  prompt += '## Communication Protocols\\n\\n';\n  prompt += PROTOCOL_USER_MESSAGE;\n  prompt += PROTOCOL_PERSONA_ACTION;\n  prompt += PROTOCOL_EMIT_EVENT;\n  prompt += PROTOCOL_AGENT_MEMORY;\n  prompt += PROTOCOL_MANUAL_REVIEW;\n  prompt += PROTOCOL_EXECUTION_FLOW;\n  prompt += PROTOCOL_OUTCOME_ASSESSMENT;\n\n  // Input Data\n  if (inputData) {\n    // Inject use case context if present\n    const useCase = inputData['_use_case'] as Record<string, unknown> | undefined;\n    if (useCase) {\n      prompt += '## Use Case Context\\n';\n      if (typeof useCase['title'] === 'string') {\n        prompt += `You are executing the use case: **${useCase['title']}**\\n`;\n      }\n      if (typeof useCase['description'] === 'string') {\n        prompt += `Description: ${useCase['description']}\\n`;\n      }\n      prompt += 'Focus on this specific use case.\\n\\n';\n    }\n\n    // Inject time filter constraints\n    const timeFilter = inputData['_time_filter'] as Record<string, unknown> | undefined;\n    if (timeFilter) {\n      prompt += '## Time Filter (IMPORTANT)\\n';\n      if (typeof timeFilter['description'] === 'string') {\n        prompt += `${timeFilter['description']}\\n`;\n      }\n      if (typeof timeFilter['field'] === 'string' && typeof timeFilter['default_window'] === 'string') {\n        prompt += `When querying data, use the '${timeFilter['field']}' parameter to limit results to the last ${timeFilter['default_window']}. `;\n        prompt += 'Do NOT fetch all historical data ‚Äî only process recent items within this time window.\\n';\n      }\n      prompt += '\\n';\n    }\n\n    prompt += '## Input Data\\n```json\\n';\n    prompt += JSON.stringify(inputData, null, 2);\n    prompt += '\\n```\\n\\n';\n  }\n\n  // Execute Now\n  prompt += '## EXECUTE NOW\\n';\n  prompt += `You are ${persona.name}. Execute your task now. Follow your instructions precisely.\\n`;\n  if (tools.length > 0) {\n    prompt += 'Use available tools as needed.\\n';\n  }\n  prompt += 'Respond naturally and complete the task.\\n';\n\n  return prompt;\n}\n\n// ---------------------------------------------------------------------------\n// CLI args builder (ported from engine/prompt.rs)\n// ---------------------------------------------------------------------------\n\nexport interface CliArgs {\n  command: string;\n  args: string[];\n  envOverrides: Array<[string, string]>;\n  envRemovals: string[];\n}\n\nexport function buildCliArgs(\n  persona?: Persona | null,\n): CliArgs {\n  const args = [\n    '-p', '-',\n    '--output-format', 'stream-json',\n    '--verbose',\n    '--dangerously-skip-permissions',\n  ];\n\n  // Persona-specific flags\n  if (persona) {\n    if (persona.maxBudgetUsd && persona.maxBudgetUsd > 0) {\n      args.push('--max-budget-usd', String(persona.maxBudgetUsd));\n    }\n    if (persona.maxTurns && persona.maxTurns > 0) {\n      args.push('--max-turns', String(persona.maxTurns));\n    }\n  }\n\n  const envOverrides: Array<[string, string]> = [];\n  const envRemovals: string[] = ['CLAUDECODE', 'CLAUDE_CODE'];\n\n  return { command: 'claude', args, envOverrides, envRemovals };\n}\n","numLines":333,"startLine":1,"totalLines":333}}}
