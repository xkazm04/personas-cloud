39‚Üí    res.writeHead(501).end('Direct proxy not supported, use CONNECT');\n    40‚Üí  });\n    41‚Üí\n    42‚Üí  server.on('connect', (req, clientSocket, head) => {\n    43‚Üí    const target = req.url ?? '';\n    44‚Üí    let host: string;\n    45‚Üí    let port: number;\n    46‚Üí\n    47‚Üí    // Parse CONNECT target, handling both IPv4 \"host:port\" and IPv6 \"[::1]:port\"\n    48‚Üí    if (target.startsWith('[')) {\n    49‚Üí      const closeBracket = target.indexOf(']');\n    50‚Üí      host = closeBracket > 0 ? target.slice(1, closeBracket) : '';\n    51‚Üí      const portStr = closeBracket > 0 ? target.slice(closeBracket + 2) : '';\n    52‚Üí      port = parseInt(portStr, 10) || 443;\n    53‚Üí    } else {\n    54‚Üí      const lastColon = target.lastIndexOf(':');\n    55‚Üí      host = lastColon > 0 ? target.slice(0, lastColon) : target;\n    56‚Üí      port = lastColon > 0 ? parseInt(target.slice(lastColon + 1), 10) || 443 : 443;\n    57‚Üí    }\n    58‚Üí\n    59‚Üí    if (!host || !isAllowed(policy, host, port)) {\n    60‚Üí      logger.warn({ host, port }, 'Proxy: blocked CONNECT');\n    61‚Üí      clientSocket.write('HTTP/1.1 403 Forbidden\\r\\n\\r\\n');\n    62‚Üí      clientSocket.destroy();\n    63‚Üí      return;\n    64‚Üí    }\n    65‚Üí\n    66‚Üí    const serverSocket = net.connect(port, host, () => {\n    67‚Üí      clientSocket.write('HTTP/1.1 200 Connection Established\\r\\n\\r\\n');\n    68‚Üí      serverSocket.write(head);\n    69‚Üí      serverSocket.pipe(clientSocket);\n    70‚Üí      clientSocket.pipe(serverSocket);\n    71‚Üí    });\n    72‚Üí\n    73‚Üí    activeSockets.add(clientSocket);\n    74‚Üí    activeSockets.add(serverSocket);\n    75‚Üí\n    76‚Üí    const removeSocket = (s: net.Socket | Duplex) => { activeSockets.delete(s); };\n    77‚Üí\n    78‚Üí    serverSocket.on('close', () => removeSocket(serverSocket));\n    79‚Üí    clientSocket.on('close', () => removeSocket(clientSocket));\n    80‚Üí\n    81‚Üí    serverSocket.on