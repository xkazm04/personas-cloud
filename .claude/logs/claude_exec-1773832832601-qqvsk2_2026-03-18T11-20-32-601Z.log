[2026-03-18T11:20:44.193Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T1sSv6SvpVH6mqi4r7HD1x","type":"tool_result","content":"     1→import fs from 'node:fs';\n     2→import fsp from 'node:fs/promises';\n     3→import path from 'node:path';\n     4→import os from 'node:os';\n     5→import crypto from 'node:crypto';\n     6→import type { Logger } from 'pino';\n     7→\n     8→export interface InjectedCredentials {\n     9→  /** Path to the tmpfs-backed credential file */\n    10→  credentialFilePath: string;\n    11→  /** Environment variable key pointing to the file */\n    12→  envPointerKey: string;\n    13→  /** Call to delete the credential file */\n    14→  cleanup(): Promise<void>;\n    15→}\n    16→\n    17→/**\n    18→ * Write credentials to a temporary file (preferring tmpfs/ramfs) instead of\n    19→ * injecting them as environment variables. This prevents credential exposure\n    20→ * via /proc/pid/environ or `ps auxe`.\n    21→ *\n    22→ * Returns the file path and a cleanup function. The child process receives\n    23→ * the DAC_CREDENTIALS_FILE env var pointing to the file.\n    24→ */\n    25→export async function injectCredentialsViaFile(\n    26→  env: Record<string, string>,\n    27→  executionId: string,\n    28→  logger: Logger,\n    29→): Promise<InjectedCredentials> {\n    30→  // Prefer /dev/shm (tmpfs, never hits disk) on Linux\n    31→  let tmpBase: string;\n    32→  if (process.platform === 'linux' && fs.existsSync('/dev/shm')) {\n    33→    tmpBase = '/dev/shm';\n    34→  } else {\n    35→    tmpBase = os.tmpdir();\n    36→  }\n    37→\n    38→  const randomSuffix = crypto.randomBytes(8).toString('hex');\n    39→  const credFilePath = path.join(tmpBase, `dac-creds-${executionId}-${randomSuffix}.json`);\n    40→\n    41→  // Collect credential env vars into the file\n    42→  const credentials: Record<string, string> = {};\n    43→  const credentialKeys: string[] = [];\n    44→\n    45→  for (const [key, value] of Object.entries(env)) {\n    46→    // Credential env vars follow the CONNECTOR_* pattern or are well-known secret keys\n    47→    if (\n    48→      key.startsWith('CONNECTOR_') ||\n    49→      key === 'ANTHROPIC_API_KEY' ||\n    50→      key.includes('TOKEN') ||\n    51→      key.includes('SECRET') ||\n    52→      key.includes('PASSWORD') ||\n    53→      key.includes('API_KEY')\n    54→    ) {\n    55→      credentials[key] = value;\n    56→      credentialKeys.push(key);\n    57→    }\n    58→  }\n    59→\n    60→  // Write credential file asynchronously\n    61→  await fsp.writeFile(credFilePath, JSON.stringify(credentials), { mode: 0o600 });\n    62→\n    63→  // Remove credential keys from the env dict (they'll be read from file instead)\n    64→  for (const key of credentialKeys) {\n    65→    delete env[key];\n    66→  }\n    67→\n    68→  logger.debug({\n    69→    executionId,\n    70→    credentialFile: credFilePath,\n    71→    credentialCount: credentialKeys.length,\n    72→    onTmpfs: tmpBase === '/dev/shm',\n    73→  }, 'Credentials written to temporary file');\n    74→\n    75→  return {\n    76→    credentialFilePath: credFilePath,\n    77→    envPointerKey: 'DAC_CREDENTIALS_FILE',\n    78→    async cleanup() {\n    79→      try {\n    80→        await fsp.unlink(credFilePath);\n    81→        logger.debug({ credentialFile: credFilePath }, 'Credential file cleaned up');\n    82→      } catch (err) {\n    83→        // File may already be gone (e.g. sandbox cleanup removed it first)\n    84→        if ((err as NodeJS.ErrnoException).code !== 'ENOENT') {\n    85→          logger.warn({ err, credentialFile: credFilePath }, 'Failed to cleanup credential file');\n    86→        }\n    87→      }\n    88→    },\n    89→  };\n    90→}\n    91→"}]},"parent_tool_use_id":null,"session_id":"7f364aab-fa6d-4cdc-bf55-d5a726d2f565","uuid":"803b55b9-9207-43e1-b1a6-f36372b48e0b","timestamp":"2026-03-18T11:20:44.061Z","tool_use_result":{"type":"text","file":{"filePath":"C:/Users/kazda/kiro/personas-cloud/packages/worker/src/credentialInjector.ts","content":"import fs from 'node:fs';\nimport fsp from 'node:fs/promises';\nimport path from 'node:path';\nimport os from 'node:os';\nimport crypto from 'node:crypto';\nimport type { Logger } from 'pino';\n\nexport interface InjectedCredentials {\n  /** Path to the tmpfs-backed credential file */\n  credentialFilePath: string;\n  /** Environment variable key pointing to the file */\n  envPointerKey: string;\n  /** Call to delete the credential file */\n  cleanup(): Promise<void>;\n}\n\n/**\n * Write credentials to a temporary file (preferring tmpfs/ramfs) instead of\n * injecting them as environment variables. This prevents credential exposure\n * via /proc/pid/environ or `ps auxe`.\n *\n * Returns the file path and a cleanup function. The child process receives\n * the DAC_CREDENTIALS_FILE env var pointing to the file.\n */\nexport async function injectCredentialsViaFile(\n  env: Record<string, string>,\n  executionId: string,\n  logger: Logger,\n): Promise<InjectedCredentials> {\n  // Prefer /dev/shm (tmpfs, never hits disk) on Linux\n  let tmpBase: string;\n  if (process.platform === 'linux' && fs.existsSync('/dev/shm')) {\n    tmpBase = '/dev/shm';\n  } else {\n    tmpBase = os.tmpdir();\n  }\n\n  const randomSuffix = crypto.randomBytes(8).toString('hex');\n  const credFilePath = path.join(tmpBase, `dac-creds-${executionId}-${randomSuffix}.json`);\n\n  // Collect credential env vars into the file\n  const credentials: Record<string, string> = {};\n  const credentialKeys: string[] = [];\n\n  for (const [key, value] of Object.entries(env)) {\n    // Credential env vars follow the CONNECTOR_* pattern or are well-known secret keys\n    if (\n      key.startsWith('CONNECTOR_') ||\n      key === 'ANTHROPIC_API_KEY' ||\n      key.includes('TOKEN') ||\n      key.includes('SECRET') ||\n      key.includes('PASSWORD') ||\n      key.includes('API_KEY')\n    ) {\n      credentials[key] = value;\n      credentialKeys.push(key);\n    }\n  }\n\n  // Write credential file asynchronously\n  await fsp.writeFile(credFilePath, JSON.stringify(credentials), { mode: 0o600 });\n\n  // Remove credential keys from the env dict (they'll be read from file instead)\n  for (const key of credentialKeys) {\n    delete env[key];\n  }\n\n  logger.debug({\n    executionId,\n    credentialFile: credFilePath,\n    credentialCount: credentialKeys.length,\n    onTmpfs: tmpBase === '/dev/shm',\n  }, 'Credentials written to temporary file');\n\n  return {\n    credentialFilePath: credFilePath,\n    envPointerKey: 'DAC_CREDENTIALS_FILE',\n    async cleanup() {\n      try {\n        await fsp.unlink(credFilePath);\n        logger.debug({ credentialFile: credFilePath }, 'Credential file cleaned up');\n      } catch (err) {\n        // File may already be gone (e.g. sandbox cleanup removed it first)\n        if ((err as NodeJS.ErrnoException).code !== 'ENOENT') {\n          logger.warn({ err, credentialFile: credFilePath }, 'Failed to cleanup credential file');\n        }\n      }\n    },\n  };\n}\n","numLines":91,"startLine":1,"totalLines":91}}}
