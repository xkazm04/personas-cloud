[2026-03-18T11:39:48.116Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017mAXwht4rgNpJXMLcN4RVw","type":"tool_result","content":"The file C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\auditLog.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"2d01669d-98df-4d1d-9dc0-f4e88e168536","uuid":"2263a6f1-18ce-4fa5-a4d7-0410af5f0ce2","timestamp":"2026-03-18T11:39:48.025Z","tool_use_result":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\auditLog.ts","oldString":"  /**\n   * Delete audit events older than `cutoff` in chunks of `chunkSize`.\n   * Returns the total number of rows deleted.\n   */\n  purgeOlderThan(cutoff: string, chunkSize: number): number {\n    const deleteChunk = this.db.prepare(\n      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n    );\n    let totalDeleted = 0;\n    while (true) {\n      const result = deleteChunk.run(cutoff, chunkSize);\n      totalDeleted += result.changes;\n      if (result.changes < chunkSize) break;\n    }\n    return totalDeleted;\n  }","newString":"  /**\n   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   * yielding the event loop between batches so concurrent DB operations\n   * are not starved during large purges.\n   */\n  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n    const deleteChunk = this.db.prepare(\n      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n    );\n    let totalDeleted = 0;\n    while (true) {\n      const result = deleteChunk.run(cutoff, chunkSize);\n      totalDeleted += result.changes;\n      if (result.changes < chunkSize) break;\n      await new Promise<void>((resolve) => setImmediate(resolve));\n    }\n    return totalDeleted;\n  }","originalFile":"import Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\n\nconst AUDIT_SCHEMA = `\nCREATE TABLE IF NOT EXISTS audit_events (\n  id INTEGER PRIMARY KEY AUTOINCREMENT,\n  timestamp TEXT NOT NULL,\n  action TEXT NOT NULL,\n  tenant_id TEXT,\n  actor TEXT,\n  resource_type TEXT,\n  resource_id TEXT,\n  detail TEXT,\n  ip_address TEXT\n);\nCREATE INDEX IF NOT EXISTS idx_audit_ts ON audit_events(timestamp);\nCREATE INDEX IF NOT EXISTS idx_audit_tenant_action_ts ON audit_events(tenant_id, action, timestamp);\nDROP INDEX IF EXISTS idx_audit_tenant_ts;\nDROP INDEX IF EXISTS idx_audit_action;\n`;\n\n/** Thrown when an audit event fails to persist — signals an audit trail gap. */\nexport class AuditWriteError extends Error {\n  constructor(\n    public readonly entry: AuditEntry,\n    cause: unknown,\n  ) {\n    super(`Audit write failed for action \"${entry.action}\"`);\n    this.name = 'AuditWriteError';\n    this.cause = cause;\n  }\n}\n\nexport interface AuditEntry {\n  action: string;\n  tenantId?: string;\n  actor?: string;\n  resourceType?: string;\n  resourceId?: string;\n  detail?: string;\n  ipAddress?: string;\n}\n\n/** Row shape returned by audit_events queries. */\nexport interface AuditEvent {\n  id: number;\n  timestamp: string;\n  action: string;\n  tenant_id: string | null;\n  actor: string | null;\n  resource_type: string | null;\n  resource_id: string | null;\n  detail: string | null;\n  ip_address: string | null;\n}\n\n/** Max entries buffered before an automatic flush. */\nconst BUFFER_FLUSH_SIZE = 50;\n/** Interval (ms) between timer-based flushes. */\nconst BUFFER_FLUSH_INTERVAL_MS = 100;\n\ninterface BufferedEntry {\n  timestamp: string;\n  action: string;\n  tenantId: string | null;\n  actor: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  detail: string | null;\n  ipAddress: string | null;\n}\n\nexport class AuditLog {\n  private db: Database.Database;\n  private insertStmt: Database.Statement;\n  private queryStmtCache = new Map<string, Database.Statement>();\n  private buffer: BufferedEntry[] = [];\n  private flushTimer: NodeJS.Timeout | null = null;\n  private batchInsert: (...entries: BufferedEntry[]) => void;\n\n  constructor(\n    dbPath: string,\n    private logger: Logger,\n  ) {\n    this.db = new Database(dbPath);\n    this.db.pragma('journal_mode = WAL');\n    this.db.exec(AUDIT_SCHEMA);\n    this.insertStmt = this.db.prepare(\n      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',\n    );\n\n    // Wrap N inserts in a single transaction — one fsync instead of N\n    const stmt = this.insertStmt;\n    this.batchInsert = this.db.transaction((...entries: BufferedEntry[]) => {\n      for (const e of entries) {\n        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress);\n      }\n    });\n\n    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n\n    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled)');\n  }\n\n  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n  countEvents(before?: string): number {\n    const stmt = before\n      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n    return row.cnt;\n  }\n\n  /**\n   * Delete audit events older than `cutoff` in chunks of `chunkSize`.\n   * Returns the total number of rows deleted.\n   */\n  purgeOlderThan(cutoff: string, chunkSize: number): number {\n    const deleteChunk = this.db.prepare(\n      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n    );\n    let totalDeleted = 0;\n    while (true) {\n      const result = deleteChunk.run(cutoff, chunkSize);\n      totalDeleted += result.changes;\n      if (result.changes < chunkSize) break;\n    }\n    return totalDeleted;\n  }\n\n  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n  record(entry: AuditEntry): void {\n    this.buffer.push({\n      timestamp: new Date().toISOString(),\n      action: entry.action,\n      tenantId: entry.tenantId ?? null,\n      actor: entry.actor ?? null,\n      resourceType: entry.resourceType ?? null,\n      resourceId: entry.resourceId ?? null,\n      detail: entry.detail ?? null,\n      ipAddress: entry.ipAddress ?? null,\n    });\n    if (this.buffer.length >= BUFFER_FLUSH_SIZE) {\n      this.flush();\n    }\n  }\n\n  /** Flush buffered entries to SQLite in a single transaction. */\n  flush(): void {\n    if (this.buffer.length === 0) return;\n    const batch = this.buffer;\n    this.buffer = [];\n    try {\n      this.batchInsert(...batch);\n    } catch (err) {\n      this.logger.error({ err, count: batch.length }, 'Audit batch write failed — audit trail gap');\n    }\n  }\n\n  /** Query audit events with optional filters. */\n  query(opts?: {\n    tenantId?: string;\n    action?: string;\n    since?: string;\n    limit?: number;\n    offset?: number;\n  }): AuditEvent[] {\n    const params: unknown[] = [];\n    const clauses: string[] = [];\n    const keyParts: string[] = [];\n\n    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n\n    const key = keyParts.join('-') || 'none';\n    let stmt = this.queryStmtCache.get(key);\n    if (!stmt) {\n      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n      stmt = this.db.prepare(\n        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n      );\n      this.queryStmtCache.set(key, stmt);\n    }\n\n    const limit = opts?.limit ?? 100;\n    const offset = opts?.offset ?? 0;\n\n    return stmt.all(...params, limit, offset) as AuditEvent[];\n  }\n\n  close(): void {\n    if (this.flushTimer) {\n      clearInterval(this.flushTimer);\n      this.flushTimer = null;\n    }\n    this.flush();\n    try { this.db.close(); } catch { /* best effort */ }\n  }\n}\n","structuredPatch":[{"oldStart":112,"oldLines":10,"newStart":112,"newLines":11,"lines":["   }"," ","   /**","-   * Delete audit events older than `cutoff` in chunks of `chunkSize`.","-   * Returns the total number of rows deleted.","+   * Delete audit events older than `cutoff` in chunks of `chunkSize`,","+   * yielding the event loop between batches so concurrent DB operations","+   * are not starved during large purges.","    */","-  purgeOlderThan(cutoff: string, chunkSize: number): number {","+  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {","     const deleteChunk = this.db.prepare(","       'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',","     );"]},{"oldStart":124,"oldLines":6,"newStart":125,"newLines":7,"lines":["       const result = deleteChunk.run(cutoff, chunkSize);","       totalDeleted += result.changes;","       if (result.changes < chunkSize) break;","+      await new Promise<void>((resolve) => setImmediate(resolve));","     }","     return totalDeleted;","   }"]}],"userModified":false,"replaceAll":false}}
