;\n      await yieldTick();\n    }\n  }"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2775,"cache_read_input_tokens":27667,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2775},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"2d01669d-98df-4d1d-9dc0-f4e88e168536","uuid":"386018e3-c2f4-4e3d-8c46-25e807c3b449"}
