== null;\n   263→  }\n   264→\n   265→  /**\n   266→   * Revoke tokens on the Anthropic server (RFC 7009) then clear local state.\n   267→   * Best-effort: local state is always cleared even if revocation fails.\n   268→   */\n   269→  async revokeAndClearTokens(): Promise<{ revoked: boolean }> {\n   270→    const tokensToRevoke = this.tokens;\n   271→    // Clear local state immediately so the caller never stays \"connected\"\n   272→    this.tokens = null;\n   273→    this.pendingStates.clear();\n   274→\n   275→    if (!tokensToRevoke) {\n   276→      this.logger.info('No tokens to revoke, local state cleared');\n   277→      return { revoked: false };\n   278→    }\n   279→\n   280→    let revoked = false;\n   281→    // Revoke the refresh token first (invalidates the grant); then the access token.\n   282→    for (const { token, hint } of [\n   283→      { token: tokensToRevoke.refreshToken, hint: 'refresh_token' },\n   284→      { token: tokensToRevoke.accessToken, hint: 'access_token' },\n   285→    ] as const) {\n   286→      try {\n   287→        const response = await fetch(OAUTH_REVOKE_URL, {\n   288→          method: 'POST',\n   289→          headers: { 'Content-Type': 'application/json' },\n   290→          body: JSON.stringify({\n   291→            client_id: CLIENT_ID,\n   292→            token,\n   293→            token_type_hint: hint,\n   294→          }),\n   295→        });\n   296→        // RFC 7009 §2.2: the server responds with 200 even if the token was already invalid\n   297→        if (response.ok) {\n   298→          this.logger.info({ hint }, 'OAuth token revoked on server');\n   299→          revoked = true;\n   300→        } else {\n   301→          const errorText = await response.text();\n   302→          this.logger.warn({ hint, status: response.status, error: errorText }, 'OAuth token revocation returned non-OK');\n   303→        }\n   304→      } catch (err) {\n   305→        this.logger.warn({ err, hint }, 'OAuth token revocation