rom './db/index.js';\nimport { resolveToken, resolvePersona, assemblePayload, buildAssignment, type Decryptor } from './dispatchPipeline.js';"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":260,"cache_read_input_tokens":54531,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":260},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c77d786c-a861-49d7-8b43-8b230b08cc6a","uuid":"37283822-b501-4a1e-91c4-0134bea96550"}
