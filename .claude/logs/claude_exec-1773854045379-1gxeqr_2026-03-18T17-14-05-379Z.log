${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n          credentialHints.push(envName);\n\n          const decrypted = await this.decryptWithAudit(\n            toEncryptedPayload(cred),\n            tenantId,\n            cred.id,\n            { credentialId: cred.id, credentialName: cred.name },\n            'Failed to decrypt credential',\n          );\n          if (decrypted !== undefined) {\n            // Try to parse as JSON with multiple fields\n            try {\n              const fields = JSON.parse(decrypted) as Record<string, string>;\n              for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n                const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n                env[fieldEnvName] = String(fieldValue);\n              }\n            } catch {\n              // Not JSON — inject as single value\n              env[envName] = decrypted;\n            }\n          }\n        }\n\n        const inputData = request.inputData ? (request.inputData as Record<string, unknown>) : undefined;\n        prompt = assemblePrompt(persona, tools, inputData, credentialHints.length > 0 ? credentialHints : undefined);\n\n        // Apply inference profile or legacy model profile env overrides\n        let inferenceProfile: InferenceProfile | undefined;\n        if (persona.inferenceProfileId) {\n          inferenceProfile = db.getInferenceProfile(dispatchDb, persona.inferenceProfileId);\n        }\n        if (inferenceProfile) {\n          // Decrypt auth token first so resolveEnvOverrides can map it to env vars\n          let decryptedAuthToken: string | undefined;\n          if (inferenceProfile.authTokenEncrypted && inferenceProfile.authTokenIv && inferenceProfile.authTokenTag) {\n            decryptedAuthToken = await this.decryptWithAudit(\n              { encrypted: inferenceProfile.authTokenEncrypted, iv: inferenceProfile.authTokenIv, tag: inferenceProfile.authTokenTag },\n              tenantId,\n              `inference-profile:${inferenceProfile.id}`,\n              { profileId: inferenceProfile.id },\n              'Failed to decrypt inference profile auth token',\n            );\n          }\n          const overrides = resolveEnvOverrides(inferenceProfile, decryptedAuthToken);\n          for (const [k, v] of Object.entries(overrides.set)) env[k] = v;\n          for (const k of overrides.remove) delete env[k];\n        }\n\n        this.logger.info({ personaId: persona.id, toolCount: tools.length, credCount: creds.length }, 'Assembled prompt from DB persona');\n      }\n    }\n\n    // Resolve network policy from persona config\n    let networkPolicy: NetworkPolicy | undefined;\n    if (persona?.networkPolicy) {\n      networkPolicy = parseNetworkPolicy(persona.networkPolicy) ?? undefined;\n    }\n\n    const assignment: ExecAssign = {\n      type: 'assign',\n      executionId: request.executionId,\n      personaId: request.personaId,\n      prompt,\n      env,\n      config: {\n        timeoutMs: request.config.timeoutMs || 300_000,\n        maxOutputBytes: 10 * 1024 * 1024, // 10MB\n        ...(networkPolicy ? { networkPolicy } : {}),\n        ...(persona?.maxBudgetUsd ? { maxBudgetUsd: persona.maxBudgetUsd } : {}),\n        ...(persona?.maxTurns ? { maxTurns: persona.maxTurns } : {}),\n      },\n    };\n\n    // Track in-memory for real-time streaming (preserve retry count across re-dispatches)\n    const prevRetries = this.active.get(request.executionId)?.disconnectRetries ?? 0;\n    this.active.set(request.executionId, {\n      workerId,\n      startedAt: Date.now(),\n      output: [],\n      status: 'running',\n      request,\n      disconnectRetries: prevRetries,\n    });\n\n    // Mark running in DB\n    if (dispatchDb) {\n      try {\n        db.updateExecution(dispatchDb, request.executionId, {\n          status: 'running',\n          startedAt: new Date().toISOString(),\n        });\n      } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:running' }, 'Failed to mark execution as running in DB'); }\n    }\n\n    const sent = this.pool.assign(workerId, assignment);\n    if (!sent) {\n      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n      this.active.delete(request.executionId);\n      if (dispatchDb) {\n        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:queued' }, 'Failed to re-queue execution in DB after assign failure'); }\n      }\n      // Re-queue and retry dispatch — another idle worker may be available\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      this.processQueue();\n    } else {\n      this.logger.info({\n        workerId,\n        executionId: request.executionId,\n        personaId: request.personaId,\n      }, 'Execution dispatched to worker');\n    }\n  }","new_string":"  /** Exposes decryptWithAudit as the Decryptor interface for pipeline stages. */\n  private getDecryptor(): Decryptor {\n    return {\n      decrypt: (payload, tenantId, resourceId, logContext, logMessage) =>\n        this.decryptWithAudit(payload, tenantId, resourceId, logContext, logMessage),\n    };\n  }\n\n  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n    // Stage 1: Resolve token\n    const token = await resolveToken(this.oauth, this.tokenManager);\n    if (!token) {\n      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      return;\n    }\n\n    // Stage 2: Resolve persona (credentials, inference profile)\n    const tenantId = request.projectId || 'default';\n    const dispatchDb = this.resolveDb(tenantId);\n    const resolution = await resolvePersona(\n      dispatchDb,\n      request.personaId,\n      tenantId,\n      this.getDecryptor(),\n      this.logger,\n    );\n\n    // Stage 3: Assemble payload (prompt, env, network policy)\n    const payload = assemblePayload(request, token, resolution);\n\n    // Stage 4: Build assignment and send\n    const assignment = buildAssignment(request, payload);\n\n    // Track in-memory for real-time streaming (preserve retry count across re-dispatches)\n    const prevRetries = this.active.get(request.executionId)?.disconnectRetries ?? 0;\n    this.active.set(request.executionId, {\n      workerId,\n      startedAt: Date.now(),\n      output: [],\n      status: 'running',\n      request,\n      disconnectRetries: prevRetries,\n    });\n\n    // Mark running in DB\n    if (dispatchDb) {\n      try {\n        db.updateExecution(dispatchDb, request.executionId, {\n          status: 'running',\n          startedAt: new Date().toISOString(),\n        });\n      } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:running' }, 'Failed to mark execution as running in DB'); }\n    }\n\n    const sent = this.pool.assign(workerId, assignment);\n    if (!sent) {\n      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n      this.active.delete(request.executionId);\n      if (dispatchDb) {\n        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:queued' }, 'Failed to re-queue execution in DB after assign failure'); }\n      }\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      this.processQueue();\n    } else {\n      this.logger.info({\n        workerId,\n        executionId: request.executionId,\n        personaId: request.personaId,\n      }, 'Execution dispatched to worker');\n    }\n  }"},"caller":{"type":"direct"}}],"stop_reason":null