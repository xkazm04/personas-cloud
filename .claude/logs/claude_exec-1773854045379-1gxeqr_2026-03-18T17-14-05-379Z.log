donly cause: unknown,\n    51→    public readonly context: { credentialId?: string; tenantId?: string; resourceType?: string },\n    52→  ) {\n    53→    const parts: string[] = ['AES-GCM decryption failed'];\n    54→    if (context.tenantId) parts.push(`tenant=${context.tenantId}`);\n    55→    if (context.credentialId) parts.push(`credential=${context.credentialId}`);\n    56→    if (context.resourceType) parts.push(`resource=${context.resourceType}`);\n    57→    super(parts.join(' '));\n    58→    this.name = 'DecryptionError';\n    59→  }\n    60→}\n    61→\n    62→/**\n    63→ * Convert a credential row (encryptedData/iv/tag) to the EncryptedPayload shape\n    64→ * expected by decrypt(). Bridges the DB column naming and the crypto interface.\n    65→ */\n    66→export function toEncryptedPayload(cred: { encryptedData: string; iv: string; tag: string }): EncryptedPayload {\n    67→  return { encrypted: cred.encryptedData, iv: cred.iv, tag: cred.tag };\n    68→}\n    69→\n    70→export function decrypt(payload: EncryptedPayload, masterKey: Buffer): string {\n    71→  const iv = Buffer.from(payload.iv, 'hex');\n    72→  const tag = Buffer.from(payload.tag, 'hex');\n    73→  const decipher = crypto.createDecipheriv(ALGORITHM, masterKey, iv, {\n    74→    authTagLength: AUTH_TAG_LENGTH,\n    75→  });\n    76→  decipher.setAuthTag(tag);\n    77→\n    78→  let decrypted = decipher.update(payload.encrypted, 'hex', 'utf8');\n    79→  decrypted += decipher.final('utf8');\n    80→  return decrypted;\n    81→}\n    82→\n    83→/**\n    84→ * Derive a per-tenant encryption key from the master secret.\n    85→ * Uses a tenant-specific salt to ensure each tenant gets a unique key.\n    86→ */\n    87→export function deriveTenantKey(masterSecret: string, tenantId: string): Buffer {\n    88→  return crypto.pbkdf2Sync(\n    89→    masterSecret,\n    90→    `dac-tenant-v1:${tenantId}`,\n    91→    PBKDF2_ITERATIONS,\n    92→    KEY_LENGTH,\n    93→    'sha256',\n    94→  );\n    95→}\n    96→\n    97→/**\n    98→ * Async variant of deriveTenantKey — offloads PBKDF2 to libuv thread pool.\n    99→ */\n   100→export function deriveTenantKeyAsync(masterSecret: string, tenantId: string): Promise<Buffer> {\n   101→  return pbkdf2(masterSecret, `dac-tenant-v1:${tenantId}`, PBKDF2_ITERATIONS, KEY_LENGTH, 'sha256');\n   102→}\n   103→\n   104→export function generateApiKey(): string {\n   105→  return `dac_${crypto.randomBytes(24).toString('hex')}`;\n   106→}\n   107→\n   108→export function hashApiKey(key: string): string {\n   109→  return crypto.createHash('sha256').update(key).digest('hex');\n   110→}\n   111→"}]},"parent_tool_use_id":null,"session_id":"c77d786c-a861-49d7-8b43-8b230b08cc6a","uuid":"1f6d3f9c-5dc0-4836-9213-cbf6bc326ff8","timestamp":"2026-03-18T17:14:27.451Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\shared\\src\\crypto.ts","content":"import crypto from 'node:crypto';\nimport { promisify } from 'node:util';\n\nconst pbkdf2 = promisify(crypto.pbkdf2);\n\nconst ALGORITHM = 'aes-256-gcm';\nconst IV_LENGTH = 16;\nconst AUTH_TAG_LENGTH = 16;\nconst KEY_LENGTH = 32;\nconst PBKDF2_ITERATIONS = 100_000;\nconst SALT = 'dac-cloud-credentials-v1';\n\nexport interface EncryptedPayload {\n  encrypted: string; // hex\n  iv: string;        // hex\n  tag: string;       // hex (GCM auth tag)\n}\n\n/**\n * Derive the master encryption key from a secret using PBKDF2.\n * Uses the libuv thread pool so the event loop stays responsive.\n */\nexport function deriveMasterKeyAsync(secret: string): Promise<Buffer> {\n  return pbkdf2(secret, SALT, PBKDF2_ITERATIONS, KEY_LENGTH, 'sha256');\n}\n\nexport function encrypt(plaintext: string, masterKey: Buffer): EncryptedPayload {\n  const iv = crypto.randomBytes(IV_LENGTH);\n  const cipher = crypto.createCipheriv(ALGORITHM, masterKey, iv, {\n    authTagLength: AUTH_TAG_LENGTH,\n  });\n\n  let encrypted = cipher.update(plaintext, 'utf8', 'hex');\n  encrypted += cipher.final('hex');\n  const tag = cipher.getAuthTag().toString('hex');\n\n  return {\n    encrypted,\n    iv: iv.toString('hex'),\n    tag,\n  };\n}\n\n/**\n * Thrown when AES-GCM decryption fails (bad key, tampered ciphertext, or corrupted data).\n * Carries identity context so callers can produce diagnostic logs and audit events.\n */\nexport class DecryptionError extends Error {\n  constructor(\n    public readonly cause: unknown,\n    public readonly context: { credentialId?: string; tenantId?: string; resourceType?: string },\n  ) {\n    const parts: string[] = ['AES-GCM decryption failed'];\n    if (context.tenantId) parts.push(`tenant=${context.tenantId}`);\n    if (context.credentialId) parts.push(`credential=${context.credentialId}`);\n    if (context.resourceType) parts.push(`resource=${context.resourceType}`);\n    super(parts.join(' '));\n    this.name = 'DecryptionError';\n  }\n}\n\n/**\n * Convert a credential row (encryptedData/iv/tag) to the EncryptedPayload shape\n * expected by decrypt(). Bridges the DB column naming and the crypto interface.\n */\nexport function toEncryptedPayload(cred: { encryptedData: string; iv: string; tag: string }): EncryptedPayload {\n  return { encrypted: cred.encryptedData, iv: cred.iv, tag: cred.tag };\n}\n\nexport function decrypt(payload: EncryptedPayload, masterKey: Buffer): string {\n  const iv = Buffer.from(payload.iv, 'hex');\n  const tag = Buffer.from(payload.tag, 'hex');\n  const decipher = crypto.createDecipheriv(ALGORITHM, masterKey, iv, {\n    authTagLength: AUTH_TAG_LENGTH,\n  });\n  decipher.setAuthTag(tag);\n\n  let decrypted = decipher.update(payload.encrypted, 'hex', 'utf8');\n  decrypted += decipher.final('utf8');\n  return decrypted;\n}\n\n/**\n * Derive a per-tenant encryption key from the master secret.\n * Uses a tenant-specific salt to ensure each tenant gets a unique key.\n */\nexport function deriveTenantKey(masterSecret: string, tenantId: string): Buffer {\n  return crypto.pbkdf2Sync(\n    masterSecret,\n    `dac-tenant-v1:${tenantId}`,\n    PBKDF2_ITERATIONS,\n    KEY_LENGTH,\n    'sha256',\n  );\n}\n\n/**\n * Async variant of deriveTenantKey — offloads PBKDF2 to libuv thread pool.\n */\nexport function deriveTenantKeyAsync(masterSecret: string, tenantId: string): Promise<Buffer> {\n  return pbkdf2(masterSecret, `dac-tenant-v1:${tenantId}`, PBKDF2_ITERATIONS, KEY_LENGTH, 'sha256');\n}\n\nexport function generateApiKey(): string {\n  return `dac_${crypto.randomBytes(24).toString('hex')}`;\n}\n\nexport function hashApiKey(key: string): string {\n  return crypto.createHash('sha256').update(key).digest('hex');\n}\n","numLines":111,"startLine":1,"totalLines":111}}}
