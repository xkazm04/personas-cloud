7→    provider: 'openai-compatible',\n    48→    envMappings: [\n    49→      { envVar: 'OPENAI_BASE_URL', source: 'baseUrl' },\n    50→      { envVar: 'OPENAI_API_KEY', source: 'authToken' },\n    51→    ],\n    52→    removeEnvKeys: NON_CLAUDE_REMOVALS,\n    53→    isPreset: true,\n    54→  },\n    55→};\n    56→\n    57→const VALID_PROVIDERS: InferenceProvider[] = ['claude', 'ollama', 'litellm', 'openai-compatible', 'custom'];\n    58→\n    59→export function validateProfile(profile: Partial<InferenceProfile>): string[] {\n    60→  const errors: string[] = [];\n    61→  if (!profile.name) errors.push('name is required');\n    62→  if (!profile.provider) {\n    63→    errors.push('provider is required');\n    64→  } else if (!VALID_PROVIDERS.includes(profile.provider)) {\n    65→    errors.push(`provider must be one of: ${VALID_PROVIDERS.join(', ')}`);\n    66→  }\n    67→  if (profile.provider !== 'claude' && !profile.baseUrl) {\n    68→    errors.push('baseUrl is required for non-claude providers');\n    69→  }\n    70→  return errors;\n    71→}\n    72→\n    73→export function resolveEnvOverrides(profile: InferenceProfile, decryptedAuthToken?: string): EnvOverrides {\n    74→  const set: Record<string, string> = {};\n    75→  const remove = [...(profile.removeEnvKeys ?? [])];\n    76→\n    77→  for (const mapping of profile.envMappings ?? []) {\n    78→    const value = resolveSource(profile, mapping.source, decryptedAuthToken);\n    79→    if (value) {\n    80→      set[mapping.envVar] = value;\n    81→    }\n    82→  }\n    83→\n    84→  return { set, remove };\n    85→}\n    86→\n    87→function resolveSource(profile: InferenceProfile, source: InferenceProviderEnvMapping['source'], decryptedAuthToken?: string): string | undefined {\n    88→  switch (source) {\n    89→    case 'baseUrl': return profile.baseUrl;\n    90→    case 'authToken': return decryptedAuthToken;\n    91→    case 'model': return profile.model;\n    92→  }\n    93→}\n    94→\n    95→"}]},"parent_tool_use_id":null,"session_id":"c77d786c-a861-49d7-8b43-8b230b08cc6a","uuid":"d1cbdabd-6427-40ec-a2c3-8b9068febee7","timestamp":"2026-03-18T17:14:21.914Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\shared\\src\\inferenceProfiles.ts","content":"// ---------------------------------------------------------------------------\n// Inference profile presets, validation, and env resolution\n// ---------------------------------------------------------------------------\n\nimport type { InferenceProfile, InferenceProvider, InferenceProviderEnvMapping } from './types.js';\n\nexport interface EnvOverrides {\n  set: Record<string, string>;\n  remove: string[];\n}\n\nconst CLAUDE_REMOVALS = ['CLAUDECODE', 'CLAUDE_CODE'];\nconst NON_CLAUDE_REMOVALS = ['ANTHROPIC_API_KEY'];\n\ntype PresetDef = Pick<InferenceProfile, 'name' | 'provider' | 'envMappings' | 'removeEnvKeys' | 'isPreset'>;\n\nexport const PRESET_PROFILES: Record<string, PresetDef> = {\n  'claude-default': {\n    name: 'Claude (Default)',\n    provider: 'claude',\n    envMappings: [],\n    removeEnvKeys: CLAUDE_REMOVALS,\n    isPreset: true,\n  },\n  'ollama-local': {\n    name: 'Ollama (Local)',\n    provider: 'ollama',\n    envMappings: [\n      { envVar: 'OLLAMA_BASE_URL', source: 'baseUrl' },\n      { envVar: 'OLLAMA_API_KEY', source: 'authToken' },\n    ],\n    removeEnvKeys: NON_CLAUDE_REMOVALS,\n    isPreset: true,\n  },\n  'litellm-proxy': {\n    name: 'LiteLLM Proxy',\n    provider: 'litellm',\n    envMappings: [\n      { envVar: 'ANTHROPIC_BASE_URL', source: 'baseUrl' },\n      { envVar: 'ANTHROPIC_AUTH_TOKEN', source: 'authToken' },\n    ],\n    removeEnvKeys: NON_CLAUDE_REMOVALS,\n    isPreset: true,\n  },\n  'openai-compatible': {\n    name: 'OpenAI-Compatible',\n    provider: 'openai-compatible',\n    envMappings: [\n      { envVar: 'OPENAI_BASE_URL', source: 'baseUrl' },\n      { envVar: 'OPENAI_API_KEY', source: 'authToken' },\n    ],\n    removeEnvKeys: NON_CLAUDE_REMOVALS,\n    isPreset: true,\n  },\n};\n\nconst VALID_PROVIDERS: InferenceProvider[] = ['claude', 'ollama', 'litellm', 'openai-compatible', 'custom'];\n\nexport function validateProfile(profile: Partial<InferenceProfile>): string[] {\n  const errors: string[] = [];\n  if (!profile.name) errors.push('name is required');\n  if (!profile.provider) {\n    errors.push('provider is required');\n  } else if (!VALID_PROVIDERS.includes(profile.provider)) {\n    errors.push(`provider must be one of: ${VALID_PROVIDERS.join(', ')}`);\n  }\n  if (profile.provider !== 'claude' && !profile.baseUrl) {\n    errors.push('baseUrl is required for non-claude providers');\n  }\n  return errors;\n}\n\nexport function resolveEnvOverrides(profile: InferenceProfile, decryptedAuthToken?: string): EnvOverrides {\n  const set: Record<string, string> = {};\n  const remove = [...(profile.removeEnvKeys ?? [])];\n\n  for (const mapping of profile.envMappings ?? []) {\n    const value = resolveSource(profile, mapping.source, decryptedAuthToken);\n    if (value) {\n      set[mapping.envVar] = value;\n    }\n  }\n\n  return { set, remove };\n}\n\nfunction resolveSource(profile: InferenceProfile, source: InferenceProviderEnvMapping['source'], decryptedAuthToken?: string): string | undefined {\n  switch (source) {\n    case 'baseUrl': return profile.baseUrl;\n    case 'authToken': return decryptedAuthToken;\n    case 'model': return profile.model;\n  }\n}\n\n","numLines":95,"startLine":1,"totalLines":95}}}
