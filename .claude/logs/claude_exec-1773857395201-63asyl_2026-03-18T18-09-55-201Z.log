n    86→          logger.info('Waiting for current execution to complete before shutdown');\n    87→          const checkInterval = setInterval(() => {\n    88→            if (!currentExecutionId) {\n    89→              clearInterval(checkInterval);\n    90→              shutdown();\n    91→            }\n    92→          }, 1000);\n    93→\n    94→          // Force shutdown after grace period\n    95→          setTimeout(() => {\n    96→            clearInterval(checkInterval);\n    97→            executor.kill();\n    98→            shutdown();\n    99→          }, msg.gracePeriodMs);\n   100→        } else {\n   101→          shutdown();\n   102→        }\n   103→      },\n   104→    },\n   105→    logger,\n   106→    // Pass TLS config if CA or client certs are configured\n   107→    (config.tlsCaPath || config.tlsCertPath) ? {\n   108→      caPath: config.tlsCaPath,\n   109→      certPath: config.tlsCertPath,\n   110→      keyPath: config.tlsKeyPath,\n   111→      rejectUnauthorized: config.tlsRejectUnauthorized,\n   112→    } as WorkerTlsConfig : undefined,\n   113→    { imageDigest: config.imageDigest, claudeCliVersion: config.claudeCliVersion },\n   114→  );\n   115→\n   116→  // Connect to orchestrator\n   117→  connection.connect();\n   118→\n   119→  // Start health probe if configured\n   120→  let healthServer: import('node:http').Server | undefined;\n   121→  if (config.healthPort > 0) {\n   122→    healthServer = startHealthProbe(\n   123→      config.healthPort,\n   124→      connection,\n   125→      executor,\n   126→      config.workerId,\n   127→      logger,\n   128→    );\n   129→  }\n   130→\n   131→  // Graceful shutdown — waits for sandbox/credential cleanup before exiting\n   132→  let shuttingDown = false;\n   133→  async function shutdown() {\n   134→    if (shuttingDown) return;   // prevent double-shutdown\n   135→    shuttingDown = true;\n   136→    logger.info('Shutting down worker...');\n   137→    healthServer?.close();\n   138→  