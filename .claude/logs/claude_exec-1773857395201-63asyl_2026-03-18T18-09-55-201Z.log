C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\worker\\src\\config.ts","content":"import 'dotenv/config';\nimport { nanoid } from 'nanoid';\n\nexport interface WorkerConfig {\n  orchestratorUrl: string;\n  workerToken: string;\n  workerId: string;\n  // Image verification\n  imageDigest: string;\n  claudeCliVersion: string;\n  // TLS (for connecting to orchestrator via wss://)\n  tlsCaPath: string;\n  tlsCertPath: string;\n  tlsKeyPath: string;\n  tlsRejectUnauthorized: boolean;\n  // Health probe HTTP port (0 = disabled)\n  healthPort: number;\n}\n\nfunction required(name: string): string {\n  const value = process.env[name];\n  if (!value) {\n    throw new Error(`Missing required environment variable: ${name}`);\n  }\n  return value;\n}\n\nexport function loadConfig(): WorkerConfig {\n  return {\n    orchestratorUrl: required('ORCHESTRATOR_URL'),\n    workerToken: required('WORKER_TOKEN'),\n    workerId: process.env['WORKER_ID'] || `worker-${nanoid(8)}`,\n    imageDigest: process.env['IMAGE_DIGEST'] || '',\n    claudeCliVersion: process.env['CLAUDE_CLI_VERSION'] || '',\n    tlsCaPath: process.env['TLS_CA_PATH'] || '',\n    tlsCertPath: process.env['TLS_CERT_PATH'] || '',\n    tlsKeyPath: process.env['TLS_KEY_PATH'] || '',\n    tlsRejectUnauthorized: process.env['TLS_REJECT_UNAUTHORIZED'] !== 'false',\n    healthPort: parseInt(process.env['HEALTH_PORT'] || '0', 10),\n  };\n}\n","numLines":42,"startLine":1,"totalLines":42}}}
[2026-03-18T18:10:09.349Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q79aPLu4MEQisoq99tcE4S","type":"tool_result","content":"     1→import type { Persona, PersonaToolDefinition, StructuredPrompt } from './types.js';\n     2→import { buildProtocolDocumentation } from './protocolRegistry.js';\n     3→\n     4→// ---------------------------------------------------------------------------\n     5→// Tool documentation\n     6→// ---------------------------------------------------------------------------\n     7→\n     8→export function buildToolDocumentation(tool: PersonaToolDefinition): string {\n     9→  let doc = `### ${tool.name}\\n${tool.description}\\n`;\n    10→  doc += `**Category**: ${tool.category}\\n`;\n    11→\n    12→  if (!tool.scriptPath) {\n    13→    if (tool.implementationGuide) {\n    14→      doc += '**Implementation Guide**:\\n';\n    15→      doc += tool.implementationGuide;\n    16→      doc += '\\n';\n    17→    } else {\n    18→      doc += '**Implementation**: Use the Bash tool with `curl` to call the API. Credentials are available as environment variables (e.g. `$GOOGLE_ACCESS_TOKEN`).\\n';\n    19→    }\n    20→  } else {\n    21→    doc += `**Usage**: npx tsx \"${tool.scriptPath}\" --input '<JSON>'\\n`;\n    22→  }\n    23→\n    24→  if (tool.inputSchema) {\n    25→    doc += `**Input Schema**: ${tool.inputSchema}\\n`;\n    26→  }\n    27→  if (tool.requiresCredentialType) {\n    28→    doc += `**Requires Credential**: ${tool.requiresCredentialType} (available as env var)\\n`;\n    29→  }\n    30→  return doc;\n    31→}\n    32→\n    33→// ---------------------------------------------------------------------------\n    34→// Prompt assembly (ported from engine/prompt.rs)\n    35→// ---------------------------------------------------------------------------\n    36→\n    37→export function assemblePrompt(\n    38→  persona: Persona,\n    39→  tools: PersonaToolDefinition[],\n    40→  inputData?: Record<string, unknown>,\n    41→  credentialHints?: string[],\n    42→): string {\n    43→  let prompt = '';\n    44→\n    45→  // Header\n    46→  prompt += `# Persona: ${persona.name}\\n\\n`;\n    47→\n    48→  // Description\n    49→  if (persona.description) {\n    50→    prompt += '## Description\\n';\n    51→    prompt += persona.description;\n    52→    prompt += '\\n\\n';\n    53→  }\n    54→\n    55→  // Identity and Instructions from structured_prompt or system_prompt\n    56→  let usedStructured = false;\n    57→  if (persona.structuredPrompt) {\n    58→    try {\n    59→      const sp: StructuredPrompt = JSON.parse(persona.structuredPrompt);\n    60→      usedStructured = true;\n    61→\n    62→      if (sp.identity) {\n    63→        prompt += '## Identity\\n';\n    64→        prompt += sp.identity;\n    65→        prompt += '\\n\\n';\n    66→      }\n    67→\n    68→      if (sp.instructions) {\n    69→        prompt += '## Instructions\\n';\n    70→        prompt += sp.instructions;\n    71→        prompt += '\\n\\n';\n    72→      }\n    73→\n    74→      if (sp.toolGuidance) {\n    75→        prompt += '## Tool Guidance\\n';\n    76→        prompt += sp.toolGuidance;\n    77→        prompt += '\\n\\n';\n    78→      }\n    79→\n    80→      if (sp.examples) {\n    81→        prompt += '## Examples\\n';\n    82→        prompt += sp.examples;\n    83→        prompt += '\\n\\n';\n    84→      }\n    85→\n    86→      if (sp.errorHandling) {\n    87→        prompt += '## Error Handling\\n';\n    88→        prompt += sp.errorHandling;\n    89→        prompt += '\\n\\n';\n    90→      }\n    91→\n    92→      if (sp.customSections) {\n    93→        for (const section of sp.customSections) {\n    94→          const heading = section.title ?? section.label ?? section.name ?? section.key;\n    95→          if (heading && section.content) {\n    96→            prompt += `## ${heading}\\n`;\n    97→            prompt += section.content;\n    98→            prompt += '\\n\\n';\n    99→          }\n   100→        }\n   101→      }\n   102→\n   103→      if (sp.webSearch) {\n   104→        prompt += '## Web Search Research Prompt\\n';\n   105→        prompt += 'When performing web searches during this execution, use the following research guidance:\\n\\n';\n   106→        prompt += sp.webSearch;\n   107→        prompt += '\\n\\n';\n   108→      }\n   109→    } catch {\n   110→      usedStructured = false;\n   111→    }\n   112→  }\n   113→\n   114→  if (!usedStructured) {\n   115→    prompt += '## Identity\\n';\n   116→    prompt += persona.systemPrompt;\n   117→    prompt += '\\n\\n';\n   118→  }\n   119→\n   120→  // Available Tools\n   121→  if (tools.length > 0) {\n   122→    prompt += '## Available Tools\\n';\n   123→    for (const tool of tools) {\n   124→      prompt += buildToolDocumentation(tool);\n   125→      prompt += '\\n';\n   126→    }\n   127→  }\n   128→\n   129→  // Execution Environment (always Linux for cloud)\n   130→  prompt += '## Execution Environment\\n';\n   131→  prompt += '- Platform: Linux/macOS\\n';\n   132→  prompt += '- Available: `curl`, `node`, `npx`, `git`, `bash`\\n';\n   133→  prompt += '- PREFER `curl` for HTTP API calls — avoid writing scripts when a single curl command works\\n';\n   134→  prompt += '- Credentials are pre-injected as environment variables — access them with `$ENV_VAR_NAME` in curl commands\\n\\n';\n   135→\n   136→  // Available Credentials\n   137→  if (credentialHints && credentialHints.length > 0) {\n   138→    prompt += '## Available Credentials (as environment variables)\\n';\n   139→    prompt += 'These env vars are ALREADY SET in your shell — use them directly in curl commands:\\n';\n   140→    for (const hint of credentialHints) {\n   141→      prompt += `- ${hint}\\n`;\n   142→    }\n   143→    prompt += '\\nExample: `curl -H \"Authorization: Bearer $GOOGLE_ACCESS_TOKEN\" https://api.example.com`\\n';\n   144→    prompt += 'IMPORTANT: Do NOT check if env vars exist — they are pre-configured. Just use them.\\n\\n';\n   145→  }\n   146→\n   147→  // Communication Protocols (generated from shared ProtocolRegistry)\n   148→  prompt += '## Communication Protocols\\n\\n';\n   149→  prompt += buildProtocolDocumentation();\n   150→\n   151→  // Input Data\n   152→  if (inputData) {\n   153→    // Inject use case context if present\n   154→    const useCase = inputData['_use_case'] as Record<string, unknown> | undefined;\n   155→    if (useCase) {\n   156→      prompt += '## Use Case Context\\n';\n   157→      if (typeof useCase['title'] === 'string') {\n   158→        prompt += `You are executing the use case: **${useCase['title']}**\\n`;\n   159→      }\n   160→      if (typeof useCase['description'] === 'string') {\n   161→        prompt += `Description: ${useCase['description']}\\n`;\n   162→      }\n   163→      prompt += 'Focus on this specific use case.\\n\\n';\n   164→    }\n   165→\n   166→    // Inject time filter constraints\n   167→    const timeFilter = inputData['_time_filter'] as Record<string, unknown> | undefined;\n   168→    if (timeFilter) {\n   169→      prompt += '## Time Filter (IMPORTANT)\\n';\n   170→      if (typeof timeFilter['description'] === 'string') {\n   171→        prompt += `${timeFilter['description']}\\n`;\n   172→      }\n   173→      if (typeof timeFilter['field'] === 'string' && typeof timeFilter['default_window'] === 'string') {\n   174→        prompt += `When querying data, use the '${timeFilter['field']}' parameter to limit results to the last ${timeFilter['default_window']}. `;\n   175→        prompt += 'Do NOT fetch all historical data — only process recent items within this time window.\\n';\n   176→      }\n   177→      prompt += '\\n';\n   178→    }\n   179→\n   180→    prompt += '## Input Data\\n```json\\n';\n   181→    prompt += JSON.stringify(inputData, null, 2);\n   182→    prompt += '\\n```\\n\\n';\n   183→  }\n   184→\n   185→  // Execute Now\n   186→  prompt += '## EXECUTE NOW\\n';\n   187→  prompt += `You are ${persona.name}. Execute your task now. Follow your instructions precisely.\\n`;\n   188→  if (tools.length > 0) {\n   189→    prompt += 'Use available tools as needed.\\n';\n   190→  }\n   191→  prompt += 'Respond naturally and complete the task.\\n';\n   192→\n   193→  return prompt;\n   194→}\n   195→\n   196→// ---------------------------------------------------------------------------\n   197→// CLI args builder (ported from engine/prompt.rs)\n   198→// ---------------------------------------------------------------------------\n   199→\n   200→export interface CliArgs {\n   201→  command: string;\n   202→  args: string[];\n   203→  envOverrides: Array<[string, string]>;\n   204→  envRemovals: string[];\n   205→}\n   206→\n   207→export function buildCliArgs(\n   208→  persona?: Persona | null,\n   209→): CliArgs {\n   210→  const args = [\n   211→    '-p', '-',\n   212→    '--output-format', 'stream-json',\n   213→    '--verbose',\n   214→    '--dangerously-skip-permissions',\n   215→  ];\n   216→\n   217→  // Persona-specific flags\n   218→  if (persona) {\n   219→    if (persona.maxBudgetUsd && persona.maxBudgetUsd > 0) {\n   220→      args.push('--max-budget-usd', String(persona.maxBudgetUsd));\n   221→    }\n   222→    if (persona.maxTurns && persona.maxTurns > 0) {\n   223→      args.push('--max-turns', String(persona.maxTurns));\n   224→    }\n   225→  }\n   226→\n   227→  const envOverrides: Array<[string, string]> = [];\n   228→  const envRemovals: string[] = ['CLAUDECODE', 'CLAUDE_CODE'];\n   229→\n   230→  return { command: 'claude', args, envOverrides, envRemovals };\n   231→}\n   232→"}]},"parent_tool_use_id":null,"session_id":"1e2bac97-fa85-4832-9433-6690ad57beab","uuid":"f9f7f6aa-dfc4-43ba-96c3-9eafc2bb8015","timestamp":"2026-03-18T18:10:09.218Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\shared\\src\\prompt.ts","content":"import type { Persona, PersonaToolDefinition, StructuredPrompt } from './types.js';\nimport { buildProtocolDocumentation } from './protocolRegistry.js';\n\n// ---------------------------------------------------------------------------\n// Tool documentation\n// ---------------------------------------------------------------------------\n\nexport function buildToolDocumentation(tool: PersonaToolDefinition): string {\n  let doc = `### ${tool.name}\\n${tool.description}\\n`;\n  doc += `**Category**: ${tool.category}\\n`;\n\n  if (!tool.scriptPath) {\n    if (tool.implementationGuide) {\n      doc += '**Implementation Guide**:\\n';\n      doc += tool.implementationGuide;\n      doc += '\\n';\n    } else {\n      doc += '**Implementation**: Use the Bash tool with `curl` to call the API. Credentials are available as environment variables (e.g. `$GOOGLE_ACCESS_TOKEN`).\\n';\n    }\n  } else {\n    doc += `**Usage**: npx tsx \"${tool.scriptPath}\" --input '<JSON>'\\n`;\n  }\n\n  if (tool.inputSchema) {\n    doc += `**Input Schema**: ${tool.inputSchema}\\n`;\n  }\n  if (tool.requiresCredentialType) {\n    doc += `**Requires Credential**: ${tool.requiresCredentialType} (available as env var)\\n`;\n  }\n  return doc;\n}\n\n// ---------------------------------------------------------------------------\n// Prompt assembly (ported from engine/prompt.rs)\n// ---------------------------------------------------------------------------\n\nexport function assemblePrompt(\n  persona: Persona,\n  tools: PersonaToolDefinition[],\n  inputData?: Record<string, unknown>,\n  credentialHints?: string[],\n): string {\n  let prompt = '';\n\n  // Header\n  prompt += `# Persona: ${persona.name}\\n\\n`;\n\n  // Description\n  if (persona.description) {\n    prompt += '## Description\\n';\n    prompt += persona.description;\n    prompt += '\\n\\n';\n  }\n\n  // Identity and Instructions from structured_prompt or system_prompt\n  let usedStructured = false;\n  if (persona.structuredPrompt) {\n    try {\n      const sp: StructuredPrompt = JSON.parse(persona.structuredPrompt);\n      usedStructured = true;\n\n      if (sp.identity) {\n        prompt += '## Identity\\n';\n        prompt += sp.identity;\n        prompt += '\\n\\n';\n      }\n\n      if (sp.instructions) {\n        prompt += '## Instructions\\n';\n        prompt += sp.instructions;\n        prompt += '\\n\\n';\n      }\n\n      if (sp.toolGuidance) {\n        prompt += '## Tool Guidance\\n';\n        prompt += sp.toolGuidance;\n        prompt += '\\n\\n';\n      }\n\n      if (sp.examples) {\n        prompt += '## Examples\\n';\n        prompt += sp.examples;\n        prompt += '\\n\\n';\n      }\n\n      if (sp.errorHandling) {\n        prompt += '## Error Handling\\n';\n        prompt += sp.errorHandling;\n        prompt += '\\n\\n';\n      }\n\n      if (sp.customSections) {\n        for (const section of sp.customSections) {\n          const heading = section.title ?? section.label ?? section.name ?? section.key;\n          if (heading && section.content) {\n            prompt += `## ${heading}\\n`;\n            prompt += section.content;\n            prompt += '\\n\\n';\n          }\n        }\n      }\n\n      if (sp.webSearch) {\n        prompt += '## Web Search Research Prompt\\n';\n        prompt += 'When performing web searches during this execution, use the following research guidance:\\n\\n';\n        prompt += sp.webSearch;\n        prompt += '\\n\\n';\n      }\n    } catch {\n      usedStructured = false;\n    }\n  }\n\n  if (!usedStructured) {\n    prompt += '## Identity\\n';\n    prompt += persona.systemPrompt;\n    prompt += '\\n\\n';\n  }\n\n  // Available Tools\n  if (tools.length > 0) {\n    prompt += '## Available Tools\\n';\n    for (const tool of tools) {\n      prompt += buildToolDocumentation(tool);\n      prompt += '\\n';\n    }\n  }\n\n  // Execution Environment (always Linux for cloud)\n  prompt += '## Execution Environment\\n';\n  prompt += '- Platform: Linux/macOS\\n';\n  prompt += '- Available: `curl`, `node`, `npx`, `git`, `bash`\\n';\n  prompt += '- PREFER `curl` for HTTP API calls — avoid writing scripts when a single curl command works\\n';\n  prompt += '- Credentials are pre-injected as environment variables — access them with `$ENV_VAR_NAME` in curl commands\\n\\n';\n\n  // Available Credentials\n  if (credentialHints && credentialHints.length > 0) {\n    prompt += '## Available Credentials (as environment variables)\\n';\n    prompt += 'These env vars are ALREADY SET in your shell — use them directly in curl commands:\\n';\n    for (const hint of credentialHints) {\n      prompt += `- ${hint}\\n`;\n    }\n    prompt += '\\nExample: `curl -H \"Authorization: Bearer $GOOGLE_ACCESS_TOKEN\" https://api.example.com`\\n';\n    prompt += 'IMPORTANT: Do NOT check if env vars exist — they are pre-configured. Just use them.\\n\\n';\n  }\n\n  // Communication Protocols (generated from shared ProtocolRegistry)\n  prompt += '## Communication Protocols\\n\\n';\n  prompt += buildProtocolDocumentation();\n\n  // Input Data\n  if (inputData) {\n    // Inject use case context if present\n    const useCase = inputData['_use_case'] as Record<string, unknown> | undefined;\n    if (useCase) {\n      prompt += '## Use Case Context\\n';\n      if (typeof useCase['title'] === 'string') {\n        prompt += `You are executing the use case: **${useCase['title']}**\\n`;\n      }\n      if (typeof useCase['description'] === 'string') {\n        prompt += `Description: ${useCase['description']}\\n`;\n      }\n      prompt += 'Focus on this specific use case.\\n\\n';\n    }\n\n    // Inject time filter constraints\n    const timeFilter = inputData['_time_filter'] as Record<string, unknown> | undefined;\n    if (timeFilter) {\n      prompt += '## Time Filter (IMPORTANT)\\n';\n      if (typeof timeFilter['description'] === 'string') {\n        prompt += `${timeFilter['description']}\\n`;\n      }\n      if (typeof timeFilter['field'] === 'string' && typeof timeFilter['default_window'] === 'string') {\n        prompt += `When querying data, use the '${timeFilter['field']}' parameter to limit results to the last ${timeFilter['default_window']}. `;\n        prompt += 'Do NOT fetch all historical data — only process recent items within this time window.\\n';\n      }\n      prompt += '\\n';\n    }\n\n    prompt += '## Input Data\\n```json\\n';\n    prompt += JSON.stringify(inputData, null, 2);\n    prompt += '\\n```\\n\\n';\n  }\n\n  // Execute Now\n  prompt += '## EXECUTE NOW\\n';\n  prompt += `You are ${persona.name}. Execute your task now. Follow your instructions precisely.\\n`;\n  if (tools.length > 0) {\n    prompt += 'Use available tools as needed.\\n';\n  }\n  prompt += 'Respond naturally and complete the task.\\n';\n\n  return prompt;\n}\n\n// ---------------------------------------------------------------------------\n// CLI args builder (ported from engine/prompt.rs)\n// ---------------------------------------------------------------------------\n\nexport interface CliArgs {\n  command: string;\n  args: string[];\n  envOverrides: Array<[string, string]>;\n  envRemovals: string[];\n}\n\nexport function buildCliArgs(\n  persona?: Persona | null,\n): CliArgs {\n  const args = [\n    '-p', '-',\n    '--output-format', 'stream-json',\n    '--verbose',\n    '--dangerously-skip-permissions',\n  ];\n\n  // Persona-specific flags\n  if (persona) {\n    if (persona.maxBudgetUsd && persona.maxBudgetUsd > 0) {\n      args.push('--max-budget-usd', String(persona.maxBudgetUsd));\n    }\n    if (persona.maxTurns && persona.maxTurns > 0) {\n      args.push('--max-turns', String(persona.maxTurns));\n    }\n  }\n\n  const envOverrides: Array<[string, string]> = [];\n  const envRemovals: string[] = ['CLAUDECODE', 'CLAUDE_CODE'];\n\n  return { command: 'claude', args, envOverrides, envRemovals };\n}\n","numLines":232,"startLine":1,"totalLines":232}}}
