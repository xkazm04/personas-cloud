[2026-03-18T17:32:21.470Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011NANiNbC5CaNHJ7wTjmDrE","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→\n     4→const AUDIT_SCHEMA = `\n     5→CREATE TABLE IF NOT EXISTS audit_events (\n     6→  id INTEGER PRIMARY KEY AUTOINCREMENT,\n     7→  timestamp TEXT NOT NULL,\n     8→  action TEXT NOT NULL,\n     9→  tenant_id TEXT,\n    10→  actor TEXT,\n    11→  resource_type TEXT,\n    12→  resource_id TEXT,\n    13→  detail TEXT,\n    14→  ip_address TEXT\n    15→);\n    16→CREATE INDEX IF NOT EXISTS idx_audit_ts ON audit_events(timestamp);\n    17→CREATE INDEX IF NOT EXISTS idx_audit_tenant_action_ts ON audit_events(tenant_id, action, timestamp);\n    18→DROP INDEX IF EXISTS idx_audit_tenant_ts;\n    19→DROP INDEX IF EXISTS idx_audit_action;\n    20→`;\n    21→\n    22→/** Thrown when an audit event fails to persist — signals an audit trail gap. */\n    23→export class AuditWriteError extends Error {\n    24→  constructor(\n    25→    public readonly entry: AuditEntry,\n    26→    cause: unknown,\n    27→  ) {\n    28→    super(`Audit write failed for action \"${entry.action}\"`);\n    29→    this.name = 'AuditWriteError';\n    30→    this.cause = cause;\n    31→  }\n    32→}\n    33→\n    34→export interface AuditEntry {\n    35→  action: string;\n    36→  tenantId?: string;\n    37→  actor?: string;\n    38→  resourceType?: string;\n    39→  resourceId?: string;\n    40→  detail?: string;\n    41→  ipAddress?: string;\n    42→}\n    43→\n    44→/** Row shape returned by audit_events queries. */\n    45→export interface AuditEvent {\n    46→  id: number;\n    47→  timestamp: string;\n    48→  action: string;\n    49→  tenant_id: string | null;\n    50→  actor: string | null;\n    51→  resource_type: string | null;\n    52→  resource_id: string | null;\n    53→  detail: string | null;\n    54→  ip_address: string | null;\n    55→}\n    56→\n    57→/** Max entries buffered before an automatic flush. */\n    58→const BUFFER_FLUSH_SIZE = 50;\n    59→/** Interval (ms) between timer-based flushes. */\n    60→const BUFFER_FLUSH_INTERVAL_MS = 100;\n    61→\n    62→interface BufferedEntry {\n    63→  timestamp: string;\n    64→  action: string;\n    65→  tenantId: string | null;\n    66→  actor: string | null;\n    67→  resourceType: string | null;\n    68→  resourceId: string | null;\n    69→  detail: string | null;\n    70→  ipAddress: string | null;\n    71→}\n    72→\n    73→export class AuditLog {\n    74→  private db: Database.Database;\n    75→  private insertStmt: Database.Statement;\n    76→  private queryStmtCache = new Map<string, Database.Statement>();\n    77→  private buffer: BufferedEntry[] = [];\n    78→  private flushTimer: NodeJS.Timeout | null = null;\n    79→  private batchInsert: (...entries: BufferedEntry[]) => void;\n    80→\n    81→  constructor(\n    82→    dbPath: string,\n    83→    private logger: Logger,\n    84→  ) {\n    85→    this.db = new Database(dbPath);\n    86→    this.db.pragma('journal_mode = WAL');\n    87→    this.db.exec(AUDIT_SCHEMA);\n    88→    this.insertStmt = this.db.prepare(\n    89→      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',\n    90→    );\n    91→\n    92→    // Wrap N inserts in a single transaction — one fsync instead of N\n    93→    const stmt = this.insertStmt;\n    94→    this.batchInsert = this.db.transaction((...entries: BufferedEntry[]) => {\n    95→      for (const e of entries) {\n    96→        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress);\n    97→      }\n    98→    });\n    99→\n   100→    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n   101→\n   102→    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled)');\n   103→  }\n   104→\n   105→  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n   106→  countEvents(before?: string): number {\n   107→    const stmt = before\n   108→      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n   109→      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n   110→    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n   111→    return row.cnt;\n   112→  }\n   113→\n   114→  /**\n   115→   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   116→   * yielding the event loop between batches so concurrent DB operations\n   117→   * are not starved during large purges.\n   118→   */\n   119→  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n   120→    const deleteChunk = this.db.prepare(\n   121→      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n   122→    );\n   123→    let totalDeleted = 0;\n   124→    while (true) {\n   125→      const result = deleteChunk.run(cutoff, chunkSize);\n   126→      totalDeleted += result.changes;\n   127→      if (result.changes < chunkSize) break;\n   128→      await new Promise<void>((resolve) => setImmediate(resolve));\n   129→    }\n   130→    return totalDeleted;\n   131→  }\n   132→\n   133→  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n   134→  record(entry: AuditEntry): void {\n   135→    this.buffer.push({\n   136→      timestamp: new Date().toISOString(),\n   137→      action: entry.action,\n   138→      tenantId: entry.tenantId ?? null,\n   139→      actor: entry.actor ?? null,\n   140→      resourceType: entry.resourceType ?? null,\n   141→      resourceId: entry.resourceId ?? null,\n   142→      detail: entry.detail ?? null,\n   143→      ipAddress: entry.ipAddress ?? null,\n   144→    });\n   145→    if (this.buffer.length >= BUFFER_FLUSH_SIZE) {\n   146→      this.flush();\n   147→    }\n   148→  }\n   149→\n   150→  /** Flush buffered entries to SQLite in a single transaction. */\n   151→  flush(): void {\n   152→    if (this.buffer.length === 0) return;\n   153→    const batch = this.buffer;\n   154→    this.buffer = [];\n   155→    try {\n   156→      this.batchInsert(...batch);\n   157→    } catch (err) {\n   158→      this.logger.error({ err, count: batch.length }, 'Audit batch write failed — audit trail gap');\n   159→    }\n   160→  }\n   161→\n   162→  /** Query audit events with optional filters. */\n   163→  query(opts?: {\n   164→    tenantId?: string;\n   165→    action?: string;\n   166→    since?: string;\n   167→    limit?: number;\n   168→    offset?: number;\n   169→  }): AuditEvent[] {\n   170→    const params: unknown[] = [];\n   171→    const clauses: string[] = [];\n   172→    const keyParts: string[] = [];\n   173→\n   174→    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n   175→    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n   176→    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n   177→\n   178→    const key = keyParts.join('-') || 'none';\n   179→    let stmt = this.queryStmtCache.get(key);\n   180→    if (!stmt) {\n   181→      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   182→      stmt = this.db.prepare(\n   183→        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n   184→      );\n   185→      this.queryStmtCache.set(key, stmt);\n   186→    }\n   187→\n   188→    const limit = opts?.limit ?? 100;\n   189→    const offset = opts?.offset ?? 0;\n   190→\n   191→    return stmt.all(...params, limit, offset) as AuditEvent[];\n   192→  }\n   193→\n   194→  close(): void {\n   195→    if (this.flushTimer) {\n   196→      clearInterval(this.flushTimer);\n   197→      this.flushTimer = null;\n   198→    }\n   199→    this.flush();\n   200→    try { this.db.close(); } catch { /* best effort */ }\n   201→  }\n   202→}\n   203→"}]},"parent_tool_use_id":null,"session_id":"f2266619-55ec-4f66-aa7c-a6379337355a","uuid":"204cc44d-0099-4018-a655-81c6050b0b74","timestamp":"2026-03-18T17:32:21.208Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\auditLog.ts","content":"import Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\n\nconst AUDIT_SCHEMA = `\nCREATE TABLE IF NOT EXISTS audit_events (\n  id INTEGER PRIMARY KEY AUTOINCREMENT,\n  timestamp TEXT NOT NULL,\n  action TEXT NOT NULL,\n  tenant_id TEXT,\n  actor TEXT,\n  resource_type TEXT,\n  resource_id TEXT,\n  detail TEXT,\n  ip_address TEXT\n);\nCREATE INDEX IF NOT EXISTS idx_audit_ts ON audit_events(timestamp);\nCREATE INDEX IF NOT EXISTS idx_audit_tenant_action_ts ON audit_events(tenant_id, action, timestamp);\nDROP INDEX IF EXISTS idx_audit_tenant_ts;\nDROP INDEX IF EXISTS idx_audit_action;\n`;\n\n/** Thrown when an audit event fails to persist — signals an audit trail gap. */\nexport class AuditWriteError extends Error {\n  constructor(\n    public readonly entry: AuditEntry,\n    cause: unknown,\n  ) {\n    super(`Audit write failed for action \"${entry.action}\"`);\n    this.name = 'AuditWriteError';\n    this.cause = cause;\n  }\n}\n\nexport interface AuditEntry {\n  action: string;\n  tenantId?: string;\n  actor?: string;\n  resourceType?: string;\n  resourceId?: string;\n  detail?: string;\n  ipAddress?: string;\n}\n\n/** Row shape returned by audit_events queries. */\nexport interface AuditEvent {\n  id: number;\n  timestamp: string;\n  action: string;\n  tenant_id: string | null;\n  actor: string | null;\n  resource_type: string | null;\n  resource_id: string | null;\n  detail: string | null;\n  ip_address: string | null;\n}\n\n/** Max entries buffered before an automatic flush. */\nconst BUFFER_FLUSH_SIZE = 50;\n/** Interval (ms) between timer-based flushes. */\nconst BUFFER_FLUSH_INTERVAL_MS = 100;\n\ninterface BufferedEntry {\n  timestamp: string;\n  action: string;\n  tenantId: string | null;\n  actor: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  detail: string | null;\n  ipAddress: string | null;\n}\n\nexport class AuditLog {\n  private db: Database.Database;\n  private insertStmt: Database.Statement;\n  private queryStmtCache = new Map<string, Database.Statement>();\n  private buffer: BufferedEntry[] = [];\n  private flushTimer: NodeJS.Timeout | null = null;\n  private batchInsert: (...entries: BufferedEntry[]) => void;\n\n  constructor(\n    dbPath: string,\n    private logger: Logger,\n  ) {\n    this.db = new Database(dbPath);\n    this.db.pragma('journal_mode = WAL');\n    this.db.exec(AUDIT_SCHEMA);\n    this.insertStmt = this.db.prepare(\n      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',\n    );\n\n    // Wrap N inserts in a single transaction — one fsync instead of N\n    const stmt = this.insertStmt;\n    this.batchInsert = this.db.transaction((...entries: BufferedEntry[]) => {\n      for (const e of entries) {\n        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress);\n      }\n    });\n\n    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n\n    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled)');\n  }\n\n  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n  countEvents(before?: string): number {\n    const stmt = before\n      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n    return row.cnt;\n  }\n\n  /**\n   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   * yielding the event loop between batches so concurrent DB operations\n   * are not starved during large purges.\n   */\n  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n    const deleteChunk = this.db.prepare(\n      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n    );\n    let totalDeleted = 0;\n    while (true) {\n      const result = deleteChunk.run(cutoff, chunkSize);\n      totalDeleted += result.changes;\n      if (result.changes < chunkSize) break;\n      await new Promise<void>((resolve) => setImmediate(resolve));\n    }\n    return totalDeleted;\n  }\n\n  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n  record(entry: AuditEntry): void {\n    this.buffer.push({\n      timestamp: new Date().toISOString(),\n      action: entry.action,\n      tenantId: entry.tenantId ?? null,\n      actor: entry.actor ?? null,\n      resourceType: entry.resourceType ?? null,\n      resourceId: entry.resourceId ?? null,\n      detail: entry.detail ?? null,\n      ipAddress: entry.ipAddress ?? null,\n    });\n    if (this.buffer.length >= BUFFER_FLUSH_SIZE) {\n      this.flush();\n    }\n  }\n\n  /** Flush buffered entries to SQLite in a single transaction. */\n  flush(): void {\n    if (this.buffer.length === 0) return;\n    const batch = this.buffer;\n    this.buffer = [];\n    try {\n      this.batchInsert(...batch);\n    } catch (err) {\n      this.logger.error({ err, count: batch.length }, 'Audit batch write failed — audit trail gap');\n    }\n  }\n\n  /** Query audit events with optional filters. */\n  query(opts?: {\n    tenantId?: string;\n    action?: string;\n    since?: string;\n    limit?: number;\n    offset?: number;\n  }): AuditEvent[] {\n    const params: unknown[] = [];\n    const clauses: string[] = [];\n    const keyParts: string[] = [];\n\n    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n\n    const key = keyParts.join('-') || 'none';\n    let stmt = this.queryStmtCache.get(key);\n    if (!stmt) {\n      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n      stmt = this.db.prepare(\n        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n      );\n      this.queryStmtCache.set(key, stmt);\n    }\n\n    const limit = opts?.limit ?? 100;\n    const offset = opts?.offset ?? 0;\n\n    return stmt.all(...params, limit, offset) as AuditEvent[];\n  }\n\n  close(): void {\n    if (this.flushTimer) {\n      clearInterval(this.flushTimer);\n      this.flushTimer = null;\n    }\n    this.flush();\n    try { this.db.close(); } catch { /* best effort */ }\n  }\n}\n","numLines":203,"startLine":1,"totalLines":203}}}
