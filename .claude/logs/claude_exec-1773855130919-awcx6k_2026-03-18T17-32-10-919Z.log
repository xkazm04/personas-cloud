[2026-03-18T17:32:22.027Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KGRM7HjhtxxgLGzzdhvfre","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    11→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    12→import type { TenantDbManager } from './tenantDbManager.js';\n    13→import type { TenantKeyManager } from './tenantKeyManager.js';\n    14→import type { AuditLog } from './auditLog.js';\n    15→import type { EventProcessorHealth } from './eventProcessor.js';\n    16→import type { Logger } from 'pino';\n    17→import * as db from './db/index.js';\n    18→import { readBody, json } from './httpUtils.js';\n    19→\n    20→export function createHttpApi(\n    21→  auth: Auth,\n    22→  dispatcher: Dispatcher,\n    23→  pool: WorkerPool,\n    24→  tokenManager: TokenManager,\n    25→  oauth: OAuthManager,\n    26→  logger: Logger,\n    27→  database?: Database.Database,\n    28→  tenantDbManager?: TenantDbManager,\n    29→  tenantKeyManager?: TenantKeyManager,\n    30→  auditLog?: AuditLog,\n    31→  getEventProcessorHealth?: () => EventProcessorHealth,\n    32→): http.Server {\n    33→  const server = http.createServer(async (req, res) => {\n    34→    // Security headers\n    35→    res.setHeader('X-Content-Type-Options', 'nosniff');\n    36→\n    37→    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    38→    const origin = req.headers.origin ?? '';\n    39→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    40→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    41→    if (isAdminRoute) {\n    42→      // Admin routes: only allow same-origin requests (no CORS wildcard)\n    43→      if (origin && origin === allowedOrigin) {\n    44→        res.setHeader('Access-Control-Allow-Origin', origin);\n    45→      }\n    46→      // If no match, omit the header entirely — browser blocks the request\n    47→    } else {\n    48→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    49→    }\n    50→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    51→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n    52→\n    53→    if (req.method === 'OPTIONS') {\n    54→      res.writeHead(204);\n    55→      res.end();\n    56→      return;\n    57→    }\n    58→\n    59→    const url = req.url || '/';\n    60→    const [pathname, queryString] = url.split('?');\n    61→    const route = parseRoute(pathname ?? '');\n    62→\n    63→    // Unauthenticated endpoints\n    64→    if (pathname === '/health' && req.method === 'GET') {\n    65→      handleHealth(res, pool, oauth, getEventProcessorHealth, database, tenantDbManager);\n    66→      return;\n    67→    }\n    68→\n    69→    // Auth check for everything else — dual auth (API key + optional JWT)\n    70→    const ctx = auth.validateAndExtractContext(req);\n    71→    if (!ctx) {\n    72→      res.writeHead(401, { 'Content-Type': 'application/json' });\n    73→      res.end(JSON.stringify({ error: 'Unauthorized' }));\n    74→      return;\n    75→    }\n    76→\n    77→    // Helper: project scoping (admin sees all, user sees own project)\n    78→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n    79→\n    80→    // Resolve tenant-specific database when available\n    81→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n    82→      if (tenantDbManager && projectId) {\n    83→        return tenantDbManager.getTenantDb(projectId);\n    84→      }\n    85→      return database;\n    86→    };\n    87→    const tenantDb = resolveDatabase(ctx.projectId);\n    88→\n    89→    try {\n    90→      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n    91→      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n    92→        if (requireAdmin(ctx, res)) return;\n    93→        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n    94→        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n    95→        return;\n    96→      }\n    97→      // --- Persona CRUD ---\n    98→      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n    99→        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n   100→      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n   101→        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   102→        const persona = createPersonaWithDefaults({\n   103→          ...body,\n   104→          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   105→        });\n   106→        db.upsertPersona(tenantDb, persona);\n   107→        logger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   108→        json(res, 201, persona);\n   109→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n   110→        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n   111→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n   112→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   113→        if (!persona) return;\n   114→        const body = JSON.parse(await readBody(req)) as { toolId: string };\n   115→        db.linkTool(tenantDb, route.id, body.toolId);\n   116→        logger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   117→        json(res, 200, { linked: true });\n   118→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n   119→        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, logger), scopedProjectId, res);\n   120→        if (!hydrated) return;\n   121→        json(res, 200, hydrated);\n   122→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n   123→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   124→        if (!persona) return;\n   125→        json(res, 200, persona);\n   126→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   127→        db.deletePersona(tenantDb, route.id, scopedProjectId);\n   128→        logger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   129→        json(res, 200, { deleted: true });\n   130→      }\n   131→      // --- Tool Definitions ---\n   132→      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n   133→        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   134→        const tool = createToolDefinitionWithDefaults(body);\n   135→        db.upsertToolDefinition(tenantDb, tool);\n   136→        logger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   137→        json(res, 201, tool);\n   138→      }\n   139→      // --- Credentials ---\n   140→      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n   141→        const body = JSON.parse(await readBody(req));\n   142→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   143→\n   144→        // Require plaintext — clients must never supply pre-encrypted data\n   145→        if (!body.plaintext || typeof body.plaintext !== 'string') {\n   146→          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   147→          return;\n   148→        }\n   149→\n   150→        // Reject oversized plaintext before synchronous encryption blocks the event loop\n   151→        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   152→          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   153→          return;\n   154→        }\n   155→\n   156→        // Encryption is mandatory — reject if the key manager is unavailable\n   157→        if (!tenantKeyManager) {\n   158→          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   159→          return;\n   160→        }\n   161→\n   162→        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n   163→        delete body.encryptedData;\n   164→        delete body.iv;\n   165→        delete body.tag;\n   166→\n   167→        // Server-side encryption with per-tenant key\n   168→        const tenantId = body.projectId || ctx.projectId || 'default';\n   169→        const key = await tenantKeyManager.getKey(tenantId);\n   170→        const encrypted = encrypt(body.plaintext, key);\n   171→        body.encryptedData = encrypted.encrypted;\n   172→        body.iv = encrypted.iv;\n   173→        body.tag = encrypted.tag;\n   174→        delete body.plaintext;\n   175→\n   176→        const cred = db.createCredential(tenantDb, body);\n   177→        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n   178→        logger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   179→        json(res, 201, cred);\n   180→      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   181→        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n   182→        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   183→        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   184→        logger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   185→        json(res, 200, { deleted: true });\n   186→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n   187→        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n   188→        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   189→        // Strip encrypted data from response\n   190→        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   191→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n   192→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   193→        if (!persona) return;\n   194→        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   195→        db.linkCredential(tenantDb, route.id, body.credentialId);\n   196→        logger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route.id, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   197→        json(res, 200, { linked: true });\n   198→      }\n   199→      // --- Event Subscriptions ---\n   200→      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n   201→        const body = JSON.parse(await readBody(req));\n   202→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   203→        const missing: string[] = [];\n   204→        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   205→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   206→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   207→        const sub = db.createSubscription(tenantDb, body);\n   208→        json(res, 201, sub);\n   209→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   210→        const body = JSON.parse(await readBody(req));\n   211→        db.updateSubscription(tenantDb, route.id, body);\n   212→        const updated =