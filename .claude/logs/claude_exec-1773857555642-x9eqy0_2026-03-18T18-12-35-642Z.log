   42→      }\n    43→    });\n    44→  } else if (database) {\n    45→    const count = db.resetAllProcessingEvents(database);\n    46→    if (count > 0) {\n    47→      logger.warn({ count }, 'Reset orphaned processing events to pending at startup');\n    48→    }\n    49→  }\n    50→}\n    51→\n    52→/**\n    53→ * Periodic reaper: reset events stuck in 'processing' longer than the threshold.\n    54→ * Guards against edge cases during normal operation.\n    55→ */\n    56→function reapStaleEvents(\n    57→  database: Database.Database | null,\n    58→  logger: Logger,\n    59→  tenantDbManager?: TenantDbManager,\n    60→): void {\n    61→  if (tenantDbManager) {\n    62→    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    63→      const count = db.resetStaleProcessingEvents(tenantDb, STALE_EVENT_REAPER_SECONDS);\n    64→      if (count > 0) {\n    65→        logger.warn({ projectId, count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    66→      }\n    67→    });\n    68→  } else if (database) {\n    69→    const count = db.resetStaleProcessingEvents(database, STALE_EVENT_REAPER_SECONDS);\n    70→    if (count > 0) {\n    71→      logger.warn({ count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    72→    }\n    73→  }\n    74→}\n    75→\n    76→/**\n    77→ * Start the event processing loop.\n    78→ * Supports both tenant-isolated DBs (via TenantDbManager) and legacy single DB.\n    79→ */\n    80→export function startEventProcessor(\n    81→  database: Database.Database | null,\n    82→  dispatcher: Dispatcher,\n    83→  logger: Logger,\n    84→  interval: number = 2000,\n    85→  tenantDbManager?: TenantDbManager,\n    86→): EventProcessorHandle {\n    87→  // At startup, reset any events orphaned in 'processing' from a prior crash\n    88→  recoverOrphanedEvents(database, logger, tenantDbManager);\n    89→\n    90→  logger.info({ intervalMs: interval, tenantIsolated: !!tenantDbManager }, 'Event processor started (demand-driven with backstop)');\n    91→\n    92→  let tickCount = 0;\n    93→\n    94→  // Shared health state updated on every tick\n    95→  const health: EventProcessorHealth = {\n    96→    lastTickAt: null,\n    97→    pendingEvents: 0,\n    98→    backlogAgeMs: null,\n    99→  };\n   100→\n   101→  /** Core tick body — runs both on-demand (nudge) and via backstop interval. */\n   102→  function runTick(): void {\n   103→    try {\n   104→      tickCount++;\n   105→      health.lastTickAt = Date.now();\n   106→\n   107→      // Periodically reap stale processing events as a safety net\n   108→      if (tickCount % REAPER_TICK_INTERVAL === 0) {\n   109→        reapStaleEvents(database, logger, tenantDbManager);\n   110→      }\n   111→\n   112→      // Collect pending event stats for health reporting\n   113→      let totalPending = 0;\n   114→      let oldestCreatedAt: string | null = null;\n   115→\n   116→      if (tenantDbManager) {\n   117→        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n   118→          totalPending += db.countPendingEvents(tenantDb);\n   119→          const oldest = db.getOldestPendingEventCreatedAt(tenantDb);\n   120→          if (oldest && (!oldestCreatedAt || oldest < oldestCreatedAt)) {\n   121→            oldestCreatedAt = oldest;\n   122→          }\n   123→          eventBusTick(tenantDb, dispatcher, logger, projectId);\n   124→        });\n   125→      } else if (database) {\n   126→        totalPending = db.countPendingEvents(database);\n   127→        oldestCreatedAt = db.getOldestPendingEventCreatedAt(database);\n   128→        eventBusTick(database, dispatcher, logger);\n   129→      }\n   130→\n   131→      health.pendingEvents = totalPending;\n   132→      health.backlogAgeMs = oldestCreatedAt\n   133→        ? Math.max(0, Date.now() - new Date(oldestCreatedAt + 'Z').getTime())\n   134→        : null;\n   135→    } catch (err) {\n   136→      logger.error({ err }, 'Event processor tick failed');\n   137→    }\n   138→  }\n   139→\n   140→  // Backstop interval — catches any missed nudges or deferred/retried events\n   141→  const timer = setInterval(runTick, interval);\n   142→\n   143→  // Demand-driven nudge: coalesce rapid-fire signals into a single immediate tick\n   144→  let nudgeScheduled = false;\n   145→  function nudge(): void {\n   146→    if (nudgeScheduled) return;\n   147→    nudgeScheduled = true;\n   148→    setImmediate(() => {\n   149→      nudgeScheduled = false;\n   150→      runTick();\n   151→    });\n   152→  }\n   153→\n   154→  return {\n   155→    timer,\n   156→    getHealth: () => ({ ...health }),\n   157→    nudge,\n   158→  };\n   159→}\n   160→\n   161→function eventBusTick(\n   162→  database: Database.Database,\n   163→  dispatcher: Dispatcher,\n   164→  logger: Logger,\n   165→  projectId?: string,\n   166→): void {\n   167→  const tickStartMs = performance.now();\n   168→  let eventsFetched = 0;\n   169→  let matchesFound = 0;\n   170→  let delivered = 0;\n   171→  let skipped = 0;\n   172→  let failed = 0;\n   173→\n   174→  try {\n   175→    const events = db.getPendingEvents(database, 50);\n   176→    eventsFetched = events.length;\n   177→    if (eventsFetched === 0) return;\n   178→\n   179→    // Collect dispatch requests to fire *after* the transaction commits so that\n   180→    // the dispatcher never sees stale DB state.\n   181→    const pendingDispatches: ExecRequest[] = [];\n   182→\n   183→    // Wrap all DB reads/writes in a single transaction to avoid per-statement\n   184→    // fsync overhead (up to 100 individual commits per tick otherwise).\n   185→    database.transaction(() => {\n   186→      // Cache subscription lookups per unique (eventType, projectId) to avoid\n   187→      // redundant DB queries when the same event type fires multiple times in a batch.\n   188→      const subsCache = new Map<string, ReturnType<typeof db.getSubscriptionsByEventType>>();\n   189→\n   190→      // Phase 1: Mark events as processing, compute matches, collect unique persona IDs.\n   191→      const eventMatches: Array<{ event: PersonaEvent; matches: EventMatch[] }> = [];\n   192→      const allPersonaIds = new Set<string>();\n   193→\n   194→      for (const event of events) {\n   195→        db.updateEventStatus(database, event.id, 'processing');\n   196→\n   197→        const cacheKey = `${event.eventType}\\0${event.projectId}`;\n   198→        let subs = subsCache.get(cacheKey);\n   199→        if (subs === undefined) {\n   200→          subs = db.getSubscriptionsByEventType(database, event.eventType, event.projectId);\n   201→          subsCache.set(cacheKey, subs);\n   202→        }\n   203→        const matches = matchEvent(event, subs);\n   204→\n   205→        if (matches.length === 0) {\n   206→          db.updateEventStatus(database, event.id, 'skipped');\n   207→          skipped++;\n   208→          continue;\n   209→        }\n   210→\n   211→        matchesFound += matches.length;\n   212→        eventMatches.push({ event, matches });\n   213→        for (const match of matches) {\n   214→          allPersonaIds.add(match.personaId);\n   215→        }\n   216→      }\n   217→\n   218→      if (allPersonaIds.size === 0) return;\n   219→\n   220→      // Phase 2: Batch-fetch personas, tools, and running counts (2-3 queries total).\n   221→      const personaIds = [...allPersonaIds];\n   222→      const personaMap = db.getPersonasByIds(database, personaIds);\n   223→      const toolsMap = db.getToolsForPersonaIds(database, personaIds);\n   224→      const runningMap = db.countRunningExecutionsByPersonaIds(database, personaIds);\n   225→\n   226→      // Phase 3: Dispatch using Map lookups instead of per-match queries.\n   227→      // Track persona slots claimed within this tick to prevent over-dispatch.\n   228→      const claimed = new Map<string, number>();\n   229→\n   230→      for (const { event, matches } of eventMatches) {\n   231→        let eventDelivered = 0;\n   232→        let eventFailed = 0;\n   233→        let throttled = 0;\n   234→\n   235→        for (const match of matches) {\n   236→          try {\n   237→            const persona = personaMap.get(match.personaId);\n   238→            if (!persona) {\n   239→              logger.warn({ personaId: match.personaId, eventId: event.id }, 'Persona not found for event match');\n   240→              eventFailed++;\n   241→              failed++;\n   242→              continue;\n   243→            }\n   244→\n   245→            // Check concurrency (in-tick claims + batched DB count)\n   246→            const tickClaimed = claimed.get(persona.id) ?? 0;\n   247→            const running = runningMap.get(persona.id) ?? 0;\n   248→            if (running + tickClaimed >= persona.maxConcurrent) {\n   249→              logger.info({ personaId: persona.id, running, tickClaimed, max: persona.maxConcurrent }, 'Persona at concurrency limit, deferring');\n   250→              throttled++;\n   251→              continue;\n   252→            }\n   253→\n   254→            // Build input data from event payload\n   255→            let inputData: Record<string, unknown> | undefined;\n   256→            if (match.payload) {\n   257→              try {\n   258→                inputData = JSON.parse(match.payload);\n   259→              } catch (parseError) {\n   260→                logger.warn({ eventId: event.id, personaId: match.personaId, parseError }, 'Event payload JSON parse failed, using raw');\n   261→                inputData = { raw: match.payload };\n   262→              }\n   263→            }\n   264→\n   265→            // Assemble prompt using batched persona + tools\n   266→            const tools = toolsMap.get(persona.id) ?? [];\n   267→            const prompt = assemblePrompt(persona, tools, inputData);\n   268→\n   269→            // Queue dispatch request (fired after transaction commits)\n   270→            const request: ExecRequest = {\n   271→              executionId: nanoid(),\n   272→              personaId: persona.id,\n   273→              prompt,\n   274→              projectId: projectId ?? persona.projectId,\n   275→              config: { timeoutMs: persona.timeoutMs },\n   276→              eventId: event.id,\n   277→            };\n   278→\n   279→            pendingDispatches.push(request);\n   280→            claimed.set(persona.id, (claimed.get(persona.id) ?? 0) + 1);\n   281→            eventDelivered++;\n   282→            delivered++;\n   283→\n   284→            logger.info({\n   285→              eventId: event.id,\n   286→              personaId: persona.id,\n   287→              executionId: request.executionId,\n   288→              eventType: event.eventType,\n   289→              useCaseId: match.useCaseId,\n   290→            }, 'Event dispatched to persona');\n   291→          } catch (err) {\n   292→            logger.error({ err, personaId: match.personaId, eventId: event.id }, 'Failed to dispatch event match');\n   293→            eventFailed++;\n   294→            failed++;\n   295→          }\n   296→        }\n   297→\n   298→        // Update event status\n   299→        if (eventDelivered > 0 && eventFailed === 0 && throttled === 0) {\n   300→          db.updateEventStatus(database, event.id, 'delivered');\n   301→        } else if (eventDelivered > 0 && throttled > 0) {\n   302→          // Some matches delivered but others were concurrency-limited.\n   303→          // Defer with backoff so throttled matches get retried later.\n   304→          db.deferEventForRetry(database, event.id, event.retryCount);\n   305→          logger.info({ eventId: event.id, delivered: eventDelivered, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event partially delivered, deferring throttled matches for retry');\n   306→        } else if (eventDelivered > 0 && eventFailed > 0) {\n   307→          // Some matches delivered but others failed — mark as partial-retry\n   308→          // so the event can be re-processed for the failed matches.\n   309→          db.updateEventStatus(database, event.id, 'partial-retry');\n   310→          logger.info({ eventId: event.id, delivered: eventDelivered, failed: eventFailed }, 'Event partially delivered with failures, marked for retry');\n   311→        } else if (throttled > 0) {\n   312→          // All (or remaining) matches were concurrency-limited — defer with backoff.\n   313→          db.deferEventForRetry(database, event.id, event.retryCount);\n   314→          logger.info({ eventId: event.id, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event deferred due to concurrency limits');\n   315→        } else {\n   316→          db.updateEventStatus(database, event.id, 'failed', 'All subscription matches failed');\n   317→        }\n   318→      }\n   319→    })();\n   320→\n   321→    // Fire dispatches after the transaction has committed successfully\n   322→    for (const request of pendingDispatches) {\n   323→      dispatcher.submit(request);\n   324→    }\n   325→  } finally {\n   326→    const tickDurationMs = performance.now() - tickStartMs;\n   327→    logger.info({\n   328→      tickDurationMs,\n   329→      eventsFetched,\n   330→      matchesFound,\n   331→      delivered,\n   332→      skipped,\n   333→      failed\n   334→    }, 'Event processor tick complete');\n   335→  }\n   336→}\n   337→"}]},"parent_tool_use_id":null,"session_id":"597c251f-1873-4ca4-81df-2d4fcccf9ef7","uuid":"4f4b6fd1-d998-4081-95e6-c28f1a4044e6","timestamp":"2026-03-18T18:12:45.662Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\eventProcessor.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport { matchEvent, assemblePrompt } from '@dac-cloud/shared';\nimport type { ExecRequest, EventMatch, PersonaEvent } from '@dac-cloud/shared';\nimport { nanoid } from 'nanoid';\nimport * as db from './db/index.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\n\n/** Default threshold (seconds) for the periodic stale-event reaper. */\nconst STALE_EVENT_REAPER_SECONDS = 120;\n/** Run the reaper every N ticks (at 2s interval, 30 ticks = ~60s). */\nconst REAPER_TICK_INTERVAL = 30;\n\nexport interface EventProcessorHealth {\n  lastTickAt: number | null;\n  pendingEvents: number;\n  backlogAgeMs: number | null;\n}\n\nexport interface EventProcessorHandle {\n  timer: NodeJS.Timeout;\n  getHealth: () => EventProcessorHealth;\n  /** Signal that new events are available — triggers an immediate tick (coalesced). */\n  nudge: () => void;\n}\n\n/**\n * Recover events orphaned in 'processing' state from a prior crash.\n * Call once at startup before the tick loop begins.\n */\nfunction recoverOrphanedEvents(\n  database: Database.Database | null,\n  logger: Logger,\n  tenantDbManager?: TenantDbManager,\n): void {\n  if (tenantDbManager) {\n    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n      const count = db.resetAllProcessingEvents(tenantDb);\n      if (count > 0) {\n        logger.warn({ projectId, count }, 'Reset orphaned processing events to pending at startup');\n      }\n    });\n  } else if (database) {\n    const count = db.resetAllProcessingEvents(database);\n    if (count > 0) {\n      logger.warn({ count }, 'Reset orphaned processing events to pending at startup');\n    }\n  }\n}\n\n/**\n * Periodic reaper: reset events stuck in 'processing' longer than the threshold.\n * Guards against edge cases during normal operation.\n */\nfunction reapStaleEvents(\n  database: Database.Database | null,\n  logger: Logger,\n  tenantDbManager?: TenantDbManager,\n): void {\n  if (tenantDbManager) {\n    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n      const count = db.resetStaleProcessingEvents(tenantDb, STALE_EVENT_REAPER_SECONDS);\n      if (count > 0) {\n        logger.warn({ projectId, count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n      }\n    });\n  } else if (database) {\n    const count = db.resetStaleProcessingEvents(database, STALE_EVENT_REAPER_SECONDS);\n    if (count > 0) {\n      logger.warn({ count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    }\n  }\n}\n\n/**\n * Start the event processing loop.\n * Supports both tenant-isolated DBs (via TenantDbManager) and legacy single DB.\n */\nexport function startEventProcessor(\n  database: Database.Database | null,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  interval: number = 2000,\n  tenantDbManager?: TenantDbManager,\n): EventProcessorHandle {\n  // At startup, reset any events orphaned in 'processing' from a prior crash\n  recoverOrphanedEvents(database, logger, tenantDbManager);\n\n  logger.info({ intervalMs: interval, tenantIsolated: !!tenantDbManager }, 'Event processor started (demand-driven with backstop)');\n\n  let tickCount = 0;\n\n  // Shared health state updated on every tick\n  const health: EventProcessorHealth = {\n    lastTickAt: null,\n    pendingEvents: 0,\n    backlogAgeMs: null,\n  };\n\n  /** Core tick body — runs both on-demand (nudge) and via backstop interval. */\n  function runTick(): void {\n    try {\n      tickCount++;\n      health.lastTickAt = Date.now();\n\n      // Periodically reap stale processing events as a safety net\n      if (tickCount % REAPER_TICK_INTERVAL === 0) {\n        reapStaleEvents(database, logger, tenantDbManager);\n      }\n\n      // Collect pending event stats for health reporting\n      let totalPending = 0;\n      let oldestCreatedAt: string | null = null;\n\n      if (tenantDbManager) {\n        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n          totalPending += db.countPendingEvents(tenantDb);\n          const oldest = db.getOldestPendingEventCreatedAt(tenantDb);\n          if (oldest && (!oldestCreatedAt || oldest < oldestCreatedAt)) {\n            oldestCreatedAt = oldest;\n          }\n          eventBusTick(tenantDb, dispatcher, logger, projectId);\n        });\n      } else if (database) {\n        totalPending = db.countPendingEvents(database);\n        oldestCreatedAt = db.getOldestPendingEventCreatedAt(database);\n        eventBusTick(database, dispatcher, logger);\n      }\n\n      health.pendingEvents = totalPending;\n      health.backlogAgeMs = oldestCreatedAt\n        ? Math.max(0, Date.now() - new Date(oldestCreatedAt + 'Z').getTime())\n        : null;\n    } catch (err) {\n      logger.error({ err }, 'Event processor tick failed');\n    }\n  }\n\n  // Backstop interval — catches any missed nudges or deferred/retried events\n  const timer = setInterval(runTick, interval);\n\n  // Demand-driven nudge: coalesce rapid-fire signals into a single immediate tick\n  let nudgeScheduled = false;\n  function nudge(): void {\n    if (nudgeScheduled) return;\n    nudgeScheduled = true;\n    setImmediate(() => {\n      nudgeScheduled = false;\n      runTick();\n    });\n  }\n\n  return {\n    timer,\n    getHealth: () => ({ ...health }),\n    nudge,\n  };\n}\n\nfunction eventBusTick(\n  database: Database.Database,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  projectId?: string,\n): void {\n  const tickStartMs = performance.now();\n  let eventsFetched = 0;\n  let matchesFound = 0;\n  let delivered = 0;\n  let skipped = 0;\n  let failed = 0;\n\n  try {\n    const events = db.getPendingEvents(database, 50);\n    eventsFetched = events.length;\n    if (eventsFetched === 0) return;\n\n    // Collect dispatch requests to fire *after* the transaction commits so that\n    // the dispatcher never sees stale DB state.\n    const pendingDispatches: ExecRequest[] = [];\n\n    // Wrap all DB reads/writes in a single transaction to avoid per-statement\n    // fsync overhead (up to 100 individual commits per tick otherwise).\n    database.transaction(() => {\n      // Cache subscription lookups per unique (eventType, projectId) to avoid\n      // redundant DB queries when the same event type fires multiple times in a batch.\n      const subsCache = new Map<string, ReturnType<typeof db.getSubscriptionsByEventType>>();\n\n      // Phase 1: Mark events as processing, compute matches, collect unique persona IDs.\n      const eventMatches: Array<{ event: PersonaEvent; matches: EventMatch[] }> = [];\n      const allPersonaIds = new Set<string>();\n\n      for (const event of events) {\n        db.updateEventStatus(database, event.id, 'processing');\n\n        const cacheKey = `${event.eventType}\\0${event.projectId}`;\n        let subs = subsCache.get(cacheKey);\n        if (subs === undefined) {\n          subs = db.getSubscriptionsByEventType(database, event.eventType, event.projectId);\n          subsCache.set(cacheKey, subs);\n        }\n        const matches = matchEvent(event, subs);\n\n        if (matches.length === 0) {\n          db.updateEventStatus(database, event.id, 'skipped');\n          skipped++;\n          continue;\n        }\n\n        matchesFound += matches.length;\n        eventMatches.push({ event, matches });\n        for (const match of matches) {\n          allPersonaIds.add(match.personaId);\n        }\n      }\n\n      if (allPersonaIds.size === 0) return;\n\n      // Phase 2: Batch-fetch personas, tools, and running counts (2-3 queries total).\n      const personaIds = [...allPersonaIds];\n      const personaMap = db.getPersonasByIds(database, personaIds);\n      const toolsMap = db.getToolsForPersonaIds(database, personaIds);\n      const runningMap = db.countRunningExecutionsByPersonaIds(database, personaIds);\n\n      // Phase 3: Dispatch using Map lookups instead of per-match queries.\n      // Track persona slots claimed within this tick to prevent over-dispatch.\n      const claimed = new Map<string, number>();\n\n      for (const { event, matches } of eventMatches) {\n        let eventDelivered = 0;\n        let eventFailed = 0;\n        let throttled = 0;\n\n        for (const match of matches) {\n          try {\n            const persona = personaMap.get(match.personaId);\n            if (!persona) {\n              logger.warn({ personaId: match.personaId, eventId: event.id }, 'Persona not found for event match');\n              eventFailed++;\n              failed++;\n              continue;\n            }\n\n            // Check concurrency (in-tick claims + batched DB count)\n            const tickClaimed = claimed.get(persona.id) ?? 0;\n            const running = runningMap.get(persona.id) ?? 0;\n            if (running + tickClaimed >= persona.maxConcurrent) {\n              logger.info({ personaId: persona.id, running, tickClaimed, max: persona.maxConcurrent }, 'Persona at concurrency limit, deferring');\n              throttled++;\n              continue;\n            }\n\n            // Build input data from event payload\n            let inputData: Record<string, unknown> | undefined;\n            if (match.payload) {\n              try {\n                inputData = JSON.parse(match.payload);\n              } catch (parseError) {\n                logger.warn({ eventId: event.id, personaId: match.personaId, parseError }, 'Event payload JSON parse failed, using raw');\n                inputData = { raw: match.payload };\n              }\n            }\n\n            // Assemble prompt using batched persona + tools\n            const tools = toolsMap.get(persona.id) ?? [];\n            const prompt = assemblePrompt(persona, tools, inputData);\n\n            // Queue dispatch request (fired after transaction commits)\n            const request: ExecRequest = {\n              executionId: nanoid(),\n              personaId: persona.id,\n              prompt,\n              projectId: projectId ?? persona.projectId,\n              config: { timeoutMs: persona.timeoutMs },\n              eventId: event.id,\n            };\n\n            pendingDispatches.push(request);\n            claimed.set(persona.id, (claimed.get(persona.id) ?? 0) + 1);\n            eventDelivered++;\n            delivered++;\n\n            logger.info({\n              eventId: event.id,\n              personaId: persona.id,\n              executionId: request.executionId,\n              eventType: event.eventType,\n              useCaseId: match.useCaseId,\n            }, 'Event dispatched to persona');\n          } catch (err) {\n            logger.error({ err, personaId: match.personaId, eventId: event.id }, 'Failed to dispatch event match');\n            eventFailed++;\n            failed++;\n          }\n        }\n\n        // Update event status\n        if (eventDelivered > 0 && eventFailed === 0 && throttled === 0) {\n          db.updateEventStatus(database, event.id, 'delivered');\n        } else if (eventDelivered > 0 && throttled > 0) {\n          // Some matches delivered but others were concurrency-limited.\n          // Defer with backoff so throttled matches get retried later.\n          db.deferEventForRetry(database, event.id, event.retryCount);\n          logger.info({ eventId: event.id, delivered: eventDelivered, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event partially delivered, deferring throttled matches for retry');\n        } else if (eventDelivered > 0 && eventFailed > 0) {\n          // Some matches delivered but others failed — mark as partial-retry\n          // so the event can be re-processed for the failed matches.\n          db.updateEventStatus(database, event.id, 'partial-retry');\n          logger.info({ eventId: event.id, delivered: eventDelivered, failed: eventFailed }, 'Event partially delivered with failures, marked for retry');\n        } else if (throttled > 0) {\n          // All (or remaining) matches were concurrency-limited — defer with backoff.\n          db.deferEventForRetry(database, event.id, event.retryCount);\n          logger.info({ eventId: event.id, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event deferred due to concurrency limits');\n        } else {\n          db.updateEventStatus(database, event.id, 'failed', 'All subscription matches failed');\n        }\n      }\n    })();\n\n    // Fire dispatches after the transaction has committed successfully\n    for (const request of pendingDispatches) {\n      dispatcher.submit(request);\n    }\n  } finally {\n    const tickDurationMs = performance.now() - tickStartMs;\n    logger.info({\n      tickDurationMs,\n      eventsFetched,\n      matchesFound,\n      delivered,\n      skipped,\n      failed\n    }, 'Event processor tick complete');\n  }\n}\n","numLines":337,"startLine":1,"totalLines":337}}}
