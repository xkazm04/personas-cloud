face ExecRequest {\n   268→  executionId: string;\n   269→  personaId: string;\n   270→  prompt: string;\n   271→  projectId?: string;\n   272→  credentialIds?: string[];\n   273→  inputData?: unknown;\n   274→  config: {\n   275→    timeoutMs: number;\n   276→    maxConcurrent?: number;\n   277→  };\n   278→  triggerId?: string;\n   279→  triggerType?: string;\n   280→  /** Originating event ID — enables bidirectional event↔execution tracing. */\n   281→  eventId?: string;\n   282→}\n   283→\n   284→// Execution result — produced to Kafka by orchestrator\n   285→export interface ExecResult {\n   286→  executionId: string;\n   287→  personaId: string;\n   288→  status: 'completed' | 'failed' | 'cancelled';\n   289→  exitCode: number;\n   290→  durationMs: number;\n   291→  sessionId?: string;\n   292→  totalCostUsd?: number;\n   293→  phaseTimings?: import('./protocol.js').PhaseTimings;\n   294→  error?: string;\n   295→}\n   296→\n   297→// Worker info as tracked by orchestrator\n   298→export interface WorkerInfo {\n   299→  workerId: string;\n   300→  status: 'connecting' | 'idle' | 'executing' | 'disconnected';\n   301→  version: string;\n   302→  capabilities: string[];\n   303→  currentExecutionId?: string;\n   304→  connectedAt: number;\n   305→  lastHeartbeat: number;\n   306→  imageDigest?: string;\n   307→  claudeCliVersion?: string;\n   308→  verified: boolean;\n   309→}\n   310→\n   311→// Execution output chunk — produced to Kafka for Vibeman SSE consumption\n   312→export interface OutputChunk {\n   313→  executionId: string;\n   314→  chunk: string;\n   315→  timestamp: number;\n   316→}\n   317→\n   318→// Persona event — forwarded from worker to Kafka event bus\n   319→export interface PersonaCloudEvent {\n   320→  executionId: string;\n   321→  personaId: string;\n   322→  eventType: import('./protocolRegistry.js').ProtocolEventType;\n   323→  payload: unknown;\n   324→  timestamp: number;\n   325→}\n   326→\n   327→// Execution progress (ephemeral