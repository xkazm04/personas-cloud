[2026-03-18T12:16:32.975Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AwTrGiVnvNQA4vsdV7wA7G","type":"tool_result","content":"     1→import fs from 'node:fs';\n     2→import fsp from 'node:fs/promises';\n     3→import path from 'node:path';\n     4→import os from 'node:os';\n     5→import crypto from 'node:crypto';\n     6→import type { Logger } from 'pino';\n     7→\n     8→export interface InjectedCredentials {\n     9→  /** Path to the tmpfs-backed credential file */\n    10→  credentialFilePath: string;\n    11→  /** Environment variable key pointing to the file */\n    12→  envPointerKey: string;\n    13→  /** Call to delete the credential file */\n    14→  cleanup(): Promise<void>;\n    15→}\n    16→\n    17→/** File name prefix used for all credential temp files. */\n    18→const CRED_FILE_PREFIX = 'dac-creds-';\n    19→\n    20→/** Max age (ms) before an orphaned credential file is swept on startup. */\n    21→const ORPHAN_MAX_AGE_MS = 2 * 60 * 1000; // 2 minutes\n    22→\n    23→/**\n    24→ * Registry of credential file paths created by this process.\n    25→ * Used by the exit handler to synchronously remove files on crash.\n    26→ */\n    27→const activeCredentialFiles = new Set<string>();\n    28→\n    29→/** Whether the process exit handler has been installed. */\n    30→let exitHandlerInstalled = false;\n    31→\n    32→/**\n    33→ * Returns the directories where credential files may be written.\n    34→ */\n    35→function credentialDirs(): string[] {\n    36→  const dirs: string[] = [os.tmpdir()];\n    37→  if (process.platform === 'linux' && fs.existsSync('/dev/shm')) {\n    38→    dirs.push('/dev/shm');\n    39→  }\n    40→  return dirs;\n    41→}\n    42→\n    43→/**\n    44→ * Install a synchronous process exit handler that removes any credential\n    45→ * files still tracked in the registry. This covers cases where the process\n    46→ * exits abnormally (uncaughtException, unhandledRejection) but the