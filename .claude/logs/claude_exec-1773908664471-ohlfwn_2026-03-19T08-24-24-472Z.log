[2026-03-19T08:24:33.285Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UuHekfQwzZMM5y5Y7nBmnq","type":"tool_result","content":"     1→import { randomBytes, createHash } from 'node:crypto';\n     2→import type { Logger } from 'pino';\n     3→import type { AuditLog } from './auditLog.js';\n     4→\n     5→// Anthropic OAuth constants (from Claude Code CLI)\n     6→const OAUTH_AUTHORIZE_URL = 'https://claude.ai/oauth/authorize';\n     7→const OAUTH_TOKEN_URL = 'https://console.anthropic.com/v1/oauth/token';\n     8→const OAUTH_REVOKE_URL = 'https://console.anthropic.com/v1/oauth/revoke';\n     9→const CLIENT_ID = '9d1c250a-e61b-44d9-88ed-5944d1962f5e';\n    10→const REDIRECT_URI = 'https://console.anthropic.com/oauth/code/callback';\n    11→const SCOPES = 'org:create_api_key user:profile user:inference';\n    12→\n    13→export interface OAuthTokens {\n    14→  accessToken: string;\n    15→  refreshToken: string;\n    16→  expiresAt: number;    // unix ms\n    17→  scopes: string[];\n    18→}\n    19→\n    20→// ---------------------------------------------------------------------------\n    21→// OAuth error classification\n    22→// ---------------------------------------------------------------------------\n    23→\n    24→/** Classified OAuth error types for pattern detection and alerting. */\n    25→export type OAuthErrorType =\n    26→  | 'invalid_grant'   // refresh token consumed/expired — user must re-authenticate\n    27→  | 'rate_limited'    // 429 — back off and retry\n    28→  | 'server_error'    // 5xx — transient, retry with backoff\n    29→  | 'network_error'   // fetch threw (DNS, timeout, connection refused) — transient\n    30→  | 'invalid_request'; // 400 — likely a bug in request construction\n    31→\n    32→export interface OAuthError {\n    33→  errorType: OAuthErrorType;\n    34→  status?: number;       // HTTP status when available\n    35→  message: string;       // human-readable summary\n    36→  transient: boolean;    // true = self-healing, false = requires intervention\n    37→  raw?: string;          // raw error body (truncated)\n    38→}\n    39→\n    40→/**\n    41→ * Classify an HTTP error response from the OAuth token endpoint.\n    42→ */\n    43→function classifyHttpError(status: number, body: string): OAuthError {\n    44→  const truncated = body.length > 512 ? body.slice(0, 512) + '…' : body;\n    45→\n    46→  // 401 or body contains invalid_grant → refresh token consumed/expired\n    47→  if (status === 401 || /invalid_grant/i.test(body)) {\n    48→    return {\n    49→      errorType: 'invalid_grant',\n    50→      status,\n    51→      message: 'Refresh token expired or consumed — user must re-authenticate',\n    52→      transient: false,\n    53→      raw: truncated,\n    54→    };\n    55→  }\n    56→\n    57→  // 429 → rate limited\n    58→  if (status === 429) {\n    59→    return {\n    60→      errorType: 'rate_limited',\n    61→      status,\n    62→      message: 'Rate limited by OAuth provider — back off and retry',\n    63→      transient: true,\n    64→      raw: truncated,\n    65→    };\n    66→  }\n    67→\n    68→  // 5xx → server error (transient)\n    69→  if (status >= 500) {\n    70→    return {\n    71→      errorType: 'server_error',\n    72→      status,\n    73→      message: `OAuth provider returned ${status} — transient server error`,\n    74→      transient: true,\n    75→      raw: truncated,\n    76→    };\n    77→  }\n    78→\n    79→  // 400 or other 4xx → invalid request (likely a bug)\n    80→  return {\n    81→    errorType: 'invalid_request',\n    82→    status,\n    83→    message: `OAuth request rejected with ${status} — check request parameters`,\n    84→    transient: false,\n    85→    raw: truncated,\n    86→  };\n    87→}\n    88→\n    89→/**\n    90→ * Classify a network-level error (fetch threw before receiving a response).\n    91→ */\n    92→function classifyNetworkError(err: unknown): OAuthError {\n    93→  const message = err instanceof Error ? err.message : String(err);\n    94→  return {\n    95→    errorType: 'network_error',\n    96→    message: `Network error: ${message}`,\n    97→    transient: true,\n    98→  };\n    99→}\n   100→\n   101→/** Result of postTokenEndpoint: either tokens or a classified error. */\n   102→export type TokenEndpointResult =\n   103→  | { ok: true; tokens: OAuthTokens }\n   104→  | { ok: false; error: OAuthError };\n   105→\n   106→export interface OAuthState {\n   107→  state: string;\n   108→  codeVerifier: string;\n   109→  createdAt: number;\n   110→  expiresAt: number;    // unix ms, 10 minute window\n   111→}\n   112→\n   113→/** OAuth flow funnel metrics. */\n   114→export interface OAuthFunnelMetrics {\n   115→  flowsStarted: number;\n   116→  flowsCompleted: number;\n   117→  flowsExpired: number;\n   118→  flowsFailed: number;\n   119→}\n   120→\n   121→export class OAuthManager {\n   122→  private pendingStates = new Map<string, OAuthState>();\n   123→  private tokens: OAuthTokens | null = null;\n   124→  private refreshPromise: Promise<TokenEndpointResult> | null = null;\n   125→  private sweepTimer: ReturnType<typeof setInterval> | null = null;\n   126→  private auditLog?: AuditLog;\n   127→  private expiryWarningMs = 30 * 60 * 1000; // default 30 minutes\n   128→  private expiryWarningEmitted = false;\n   129→\n   130→  // OAuth flow funnel counters\n   131→  private flowsStarted = 0;\n   132→  private flowsCompleted = 0;\n   133→  private flowsExpired = 0;\n   134→  private flowsFailed = 0;\n   135→\n   136→  private static readonly DEFAULT_SCOPES = ['user:inference', 'user:profile'];\n   137→\n   138→  constructor(private logger: Logger) {\n   139→    // Sweep expired pending states every 60 seconds\n   140→    this.sweepTimer = setInterval(() => this.sweepExpiredStates(), 60_000);\n   141→    this.sweepTimer.unref();\n   142→  }\n   143→\n   144→  /**\n   145→   * Wire in the audit log and configurable expiry warning threshold.\n   146→   * Called after construction once the audit log is available.\n   147→   */\n   148→  setAuditLog(auditLog: AuditLog, warningMinutes?: number): void {\n   149→    this.auditLog = auditLog;\n   150→    if (warningMinutes !== undefined && warningMinutes > 0) {\n   151→      this.expiryWarningMs = warningMinutes * 60 * 1000;\n   152→    }\n   153→  }\n   154→\n   155→  private sweepExpiredStates(): void {\n   156→    const now = Date.now();\n   157→    let swept = 0;\n   158→    for (const [key, entry] of this.pendingStates) {\n   159→      if (now > entry.expiresAt) {\n   160→        this.pendingStates.delete(key);\n   161→        this.flowsExpired++;\n   162→        swept++;\n   163→        this.logger.info({ stateId: key, ageMs: now - entry.createdAt }, 'OAuth flow expired — state swept');\n   164→      }\n   165→    }\n   166→    if (swept > 0) {\n   167→      this.logger.info({ swept, remaining: this.pendingStates.size }, 'Swept expired OAuth states');\n   168→    }\n   169→  }\n   170→\n   171→  /**\n   172→   * POST to the OAuth token endpoint, parse the response, and map to OAuthTokens.\n   173→   * Callers supply only the grant-specific body fields and a scope fallback.\n   174→   * Returns a discriminated result with classified error info on failure.\n   175→   */\n   176→  private async postTokenEndpoint(\n   177→    body: Record<string, string>,\n   178→    fallbackScopes: string[],\n   179→    context: string,\n   180→  ): Promise<TokenEndpointResult> {\n   181→    try {\n   182→      const response = await fetch(OAUTH_TOKEN_URL, {\n   183→        method: 'POST',\n   184→        headers: {\n   185→          'Content-Type': 'application/json',\n   186→          'Accept': 'application/json',\n   187→        },\n   188→        body: JSON.stringify(body),\n   189→      });\n   190→\n   191→      if (!response.ok) {\n   192→        const errorText = await response.text();\n   193→        const classified = classifyHttpError(response.status, errorText);\n   194→        this.logger.error(\n   195→          { status: response.status, errorType: classified.errorType, transient: classified.transient },\n   196→          `OAuth ${context} failed: ${classified.message}`,\n   197→        );\n   198→        try {\n   199→          this.auditLog?.record({\n   200→            action: 'oauth:token_error',\n   201→            resourceType: 'oauth',\n   202→            detail: { errorType: classified.errorType, status: response.status, transient: classified.transient, context },\n   203→          });\n   204→        } catch { /* logged inside record() */ }\n   205→        return { ok: false, error: classified };\n   206→      }\n   207→\n   208→      const data = await response.json() as {\n   209→        access_token: string;\n   210→        refresh_token: string;\n   211→        expires_in: number;\n   212→        scope?: string;\n   213→      };\n   214→\n   215→      return {\n   216→        ok: true,\n   217→        tokens: {\n   218→          accessToken: data.access_token,\n   219→          refreshToken: data.refresh_token,\n   220→          expiresAt: Date.now() + data.expires_in * 1000,\n   221→          scopes: data.scope ? data.scope.split(' ') : fallbackScopes,\n   222→        },\n   223→      };\n   224→    } catch (err) {\n   225→      const classified = classifyNetworkError(err);\n   226→      this.logger.error(\n   227→        { err, errorType: classified.errorType, transient: classified.transient },\n   228→        `OAuth ${context} failed: ${classified.message}`,\n   229→      );\n   230→      try {\n   231→        this.auditLog?.record({\n   232→          action: 'oauth:token_error',\n   233→          resourceType: 'oauth',\n   234→          detail: { errorType: classified.errorType, transient: classified.transient, context },\n   235→        });\n   236→      } catch { /* logged inside record() */ }\n   237→      return { ok: false, error: classified };\n   238→    }\n   239→  }\n   240→\n   241→  /**\n   242→   * Step 1: Generate the authorization URL for the user to visit.\n   243→   * Returns the URL and stores PKCE state internally.\n   244→   */\n   245→  generateAuthUrl(): { url: string; state: string } {\n   246→    const state = randomBytes(32).toString('hex');\n   247→    const codeVerifier = randomBytes(32).toString('base64url');\n   248→    const codeChallenge = createHash('sha256')\n   249→      .update(codeVerifier)\n   250→      .digest('base64url');\n   251→\n   252→    const oauthState: OAuthState = {\n   253→      state,\n   254→      codeVerifier,\n   255→      createdAt: Date.now(),\n   256→      expiresAt: Date.now() + 10 * 60 * 1000, // 10 minutes\n   257→    };\n   258→\n   259→    this.pendingStates.set(state, oauthState);\n   260→\n   261→    const params = new URLSearchParams({\n   262→      code: 'true',\n   263→      client_id: CLIENT_ID,\n   264→      response_type: 'code',\n   265→      redirect_uri: REDIRECT_URI,\n   266→      scope: SCOPES,\n   267→      code_challenge: codeChallenge,\n   268→      code_challenge_method: 'S256',\n   269→      state,\n   270→    });\n   271→\n   272→    const url = `${OAUTH_AUTHORIZE_URL}?${params.toString()}`;\n   273→\n   274→    this.flowsStarted++;\n   275→    this.logger.info({ stateId: state }, 'OAuth flow started — authorization URL generated');\n   276→    return { url, state };\n   277→  }\n   278→\n   279→  /**\n   280→   * Step 2: Exchange the authorization code for tokens.\n   281→   * Called after user completes the OAuth flow and provides the code.\n   282→   */\n   283→  async exchangeCode(authorizationCode: string, state: string): Promise<TokenEndpointResult> {\n   284→    // Validate state\n   285→    const pending = this.pendingStates.get(state);\n   286→    if (!pending) {\n   287→      this.flowsFailed++;\n   288→      this.logger.info({ stateId: state }, 'OAuth flow failed — state not found or already consumed');\n   289→      return { ok: false, error: { errorType: 'invalid_request', message: 'OAuth state not found or already consumed', transient: false } };\n   290→    }\n   291→\n   292→    if (Date.now() > pending.expiresAt) {\n   293→      this.flowsFailed++;\n   294→      this.pendingStates.delete(state);\n   295→      this.logger.info({ stateId: state }, 'OAuth flow failed — state expired before code exchange');\n   296→      return { ok: false, error: { errorType: 'invalid_request', message: 'OAuth state expired', transient: false } };\n   297→    }\n   298→\n   299→    const cleanedCode = authorizationCode.split('#')[0]?.split('&')[0] ?? authorizationCode;\n   300→\n   301→    const result = await this.postTokenEndpoint(\n   302→      {\n   303→        grant_type: 'authorization_code',\n   304→        client_id: CLIENT_ID,\n   305→        code: cleanedCode,\n   306→        redirect_uri: REDIRECT_URI,\n   307→        code_verifier: pending.codeVerifier,\n   308→        state: pending.state,\n   309→      },\n   310→      OAuthManager.DEFAULT_SCOPES,\n   311→      'token exchange',\n   312→    );\n   313→\n   314→    this.pendingStates.delete(state);\n   315→\n   316→    if (result.ok) {\n   317→      this.tokens = result.tokens;\n   318→      this.logger.info({\n   319→        scopes: this.tokens.scopes,\n   320→        expiresAt: new Date(this.tokens.expiresAt).toISOString(),\n   321→      }, 'OAuth token exchange successful');\n   322→    }\n   323→\n   324→    return result;\n   325→  }\n   326→\n   327→  /**\n   328→   * Refresh the access token using the refresh token.\n   329→   * Called automatically before dispatching if token is near expiry.\n   330→   * Uses promise dedup so concurrent callers share one in-flight refresh,\n   331→   * preventing single-use rotating refresh tokens from being consumed twice.\n   332→   */\n   333→  async refreshAccessToken(): Promise<TokenEndpointResult> {\n   334→    if (!this.tokens) {\n   335→      this.logger.error('No tokens to refresh');\n   336→      return { ok: false, error: { errorType: 'invalid_request', message: 'No tokens to refresh', transient: false } };\n   337→    }\n   338→\n   339→    if (this.refreshPromise) {\n   340→      return this.refreshPromise;\n   341→    }\n   342→\n   343→    this.refreshPromise = this.executeRefresh().finally(() => {\n   344→      this.refreshPromise = null;\n   345→    });\n   346→    return this.refreshPromise;\n   347→  }\n   348→\n   349→  private async executeRefresh(): Promise<TokenEndpointResult> {\n   350→    const previousScopes = this.tokens!.scopes;\n   351→\n   352→    // Refresh tokens are single-use rotation — store the new one\n   353→    const result = await this.postTokenEndpoint(\n   354→      {\n   355→        grant_type: 'refresh_token',\n   356→        client_id: CLIENT_ID,\n   357→        refresh_token: this.tokens!.refreshToken,\n   358→      },\n   359→      previousScopes,\n   360→      'token refresh',\n   361→    );\n   362→\n   363→    if (result.ok) {\n   364→      this.tokens = result.tokens;\n   365→      this.logger.info({\n   366→        expiresAt: new Date(this.tokens.expiresAt).toISOString(),\n   367→      }, 'OAuth token refreshed');\n   368→      try { this.auditLog?.record({ action: 'oauth:refresh', resourceType: 'oauth', detail: { expiresAt: new Date(this.tokens.expiresAt).toISOString() } }); } catch { /* logged inside record() */ }\n   369→    } else {\n   370→      try { this.auditLog?.record({ action: 'oauth:refresh_failed', resourceType: 'oauth', detail: { reason: result.error.message, errorType: result.error.errorType } }); } catch { /* logged inside record() */ }\n   371→    }\n   372→\n   373→    return result;\n   374→  }\n   375→\n   376→  /**\n   377→   * Get a valid access token, refreshing if necessary.\n   378→   * Returns null if no tokens available or refresh fails.\n   379→   */\n   380→  async getValidAccessToken(): Promise<string | null> {\n   381→    if (!this.tokens) return null;\n   382→\n   383→    const now = Date.now();\n   384→    const remainingMs = this.tokens.expiresAt - now;\n   385→\n   386→    // Emit token:expiring_soon once per token when within the warning threshold\n   387→    if (remainingMs > 0 && remainingMs <= this.expiryWarningMs && !this.expiryWarningEmitted) {\n   388→      this.expiryWarningEmitted = true;\n   389→      try {\n   390→        this.auditLog?.record({\n   391→          action: 'token:expiring_soon',\n   392→          resourceType: 'oauth',\n   393→          detail: {\n   394→            expiresAt: new Date(this.tokens.expiresAt).toISOString(),\n   395→            remainingMinutes: Math.round(remainingMs / 60_000),\n   396→          },\n   397→        });\n   398→      } catch { /* logged inside record() */ }\n   399→      this.logger.warn({ remainingMinutes: Math.round(remainingMs / 60_000) }, 'OAuth token expiring soon');\n   400→    }\n   401→\n   402→    // Refresh if within 10 minutes of expiry\n   403→    const TEN_MINUTES = 10 * 60 * 1000;\n   404→    if (now > this.tokens.expiresAt - TEN_MINUTES) {\n   405→      this.logger.info('Access token near expiry, refreshing...');\n   406→      const result = await this.refreshAccessToken();\n   407→      if (!result.ok) return null;\n   408→      // Reset expiry warning flag after successful refresh\n   409→      this.expiryWarningEmitted = false;\n   410→    }\n   411→\n   412→    return this.tokens.accessToken;\n   413→  }\n   414→\n   415→  /**\n   416→   * Load tokens directly (e.g. from encrypted storage on startup).\n   417→   */\n   418→  loadTokens(tokens: OAuthTokens): void {\n   419→    this.tokens = tokens;\n   420→    this.logger.info({\n   421→      expiresAt: new Date(tokens.expiresAt).toISOString(),\n   422→      scopes: tokens.scopes,\n   423→    }, 'OAuth tokens loaded');\n   424→  }\n   425→\n   426→  /**\n   427→   * Get current tokens for persistence/encryption.\n   428→   */\n   429→  getTokens(): OAuthTokens | null {\n   430→    return this.tokens ? { ...this.tokens } : null;\n   431→  }\n   432→\n   433→  hasTokens(): boolean {\n   434→    return this.tokens !== null;\n   435→  }\n   436→\n   437→  /**\n   438→   * Revoke tokens on the Anthropic server (RFC 7009) then clear local state.\n   439→   * Best-effort: local state is always cleared even if revocation fails.\n   440→   */\n   441→  async revokeAndClearTokens(): Promise<{ revoked: boolean }> {\n   442→    const tokensToRevoke = this.tokens;\n   443→    // Clear local state immediately so the caller never stays \"connected\"\n   444→    this.tokens = null;\n   445→    this.pendingStates.clear();\n   446→\n   447→    if (!tokensToRevoke) {\n   448→      this.logger.info('No tokens to revoke, local state cleared');\n   449→      return { revoked: false };\n   450→    }\n   451→\n   452→    let revoked = false;\n   453→    // Revoke the refresh token first (invalidates the grant); then the access token.\n   454→    for (const { token, hint } of [\n   455→      { token: tokensToRevoke.refreshToken, hint: 'refresh_token' },\n   456→      { token: tokensToRevoke.accessToken, hint: 'access_token' },\n   457→    ] as const) {\n   458→      try {\n   459→        const response = await fetch(OAUTH_REVOKE_URL, {\n   460→          method: 'POST',\n   461→          headers: { 'Content-Type': 'application/json' },\n   462→          body: JSON.stringify({\n   463→            client_id: CLIENT_ID,\n   464→            token,\n   465→            token_type_hint: hint,\n   466→          }),\n   467→        });\n   468→        // RFC 7009 §2.2: the server responds with 200 even if the token was already invalid\n   469→        if (response.ok) {\n   470→          this.logger.info({ hint }, 'OAuth token revoked on server');\n   471→          revoked = true;\n   472→        } else {\n   473→          const errorText = await response.text();\n   474→          this.logger.warn({ hint, status: response.status, error: errorText }, 'OAuth token revocation returned non-OK');\n   475→        }\n   476→      } catch (err) {\n   477→        this.logger.warn({ err, hint }, 'OAuth token revocation request failed');\n   478→      }\n   479→    }\n   480→\n   481→    this.logger.info({ revoked }, 'OAuth disconnect complete, local tokens cleared');\n   482→    return { revoked };\n   483→  }\n   484→\n   485→  clearTokens(): void {\n   486→    this.tokens = null;\n   487→    this.pendingStates.clear();\n   488→    this.logger.info('OAuth tokens cleared');\n   489→  }\n   490→\n   491→  /**\n   492→   * Stop the background sweep timer. Call on shutdown.\n   493→   */\n   494→  dispose(): void {\n   495→    if (this.sweepTimer) {\n   496→      clearInterval(this.sweepTimer);\n   497→      this.sweepTimer = null;\n   498→    }\n   499→  }\n   500→}\n   501→"}]},"parent_tool_use_id":null,"session_id":"d3723eba-4b01-4936-8e79-68e61fc0bca1","uuid":"a4ead447-b2e1-431a-9091-274d2e2ef0a1","timestamp":"2026-03-19T08:24:32.811Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\oauth.ts","content":"import { randomBytes, createHash } from 'node:crypto';\nimport type { Logger } from 'pino';\nimport type { AuditLog } from './auditLog.js';\n\n// Anthropic OAuth constants (from Claude Code CLI)\nconst OAUTH_AUTHORIZE_URL = 'https://claude.ai/oauth/authorize';\nconst OAUTH_TOKEN_URL = 'https://console.anthropic.com/v1/oauth/token';\nconst OAUTH_REVOKE_URL = 'https://console.anthropic.com/v1/oauth/revoke';\nconst CLIENT_ID = '9d1c250a-e61b-44d9-88ed-5944d1962f5e';\nconst REDIRECT_URI = 'https://console.anthropic.com/oauth/code/callback';\nconst SCOPES = 'org:create_api_key user:profile user:inference';\n\nexport interface OAuthTokens {\n  accessToken: string;\n  refreshToken: string;\n  expiresAt: number;    // unix ms\n  scopes: string[];\n}\n\n// ---------------------------------------------------------------------------\n// OAuth error classification\n// ---------------------------------------------------------------------------\n\n/** Classified OAuth error types for pattern detection and alerting. */\nexport type OAuthErrorType =\n  | 'invalid_grant'   // refresh token consumed/expired — user must re-authenticate\n  | 'rate_limited'    // 429 — back off and retry\n  | 'server_error'    // 5xx — transient, retry with backoff\n  | 'network_error'   // fetch threw (DNS, timeout, connection refused) — transient\n  | 'invalid_request'; // 400 — likely a bug in request construction\n\nexport interface OAuthError {\n  errorType: OAuthErrorType;\n  status?: number;       // HTTP status when available\n  message: string;       // human-readable summary\n  transient: boolean;    // true = self-healing, false = requires intervention\n  raw?: string;          // raw error body (truncated)\n}\n\n/**\n * Classify an HTTP error response from the OAuth token endpoint.\n */\nfunction classifyHttpError(status: number, body: string): OAuthError {\n  const truncated = body.length > 512 ? body.slice(0, 512) + '…' : body;\n\n  // 401 or body contains invalid_grant → refresh token consumed/expired\n  if (status === 401 || /invalid_grant/i.test(body)) {\n    return {\n      errorType: 'invalid_grant',\n      status,\n      message: 'Refresh token expired or consumed — user must re-authenticate',\n      transient: false,\n      raw: truncated,\n    };\n  }\n\n  // 429 → rate limited\n  if (status === 429) {\n    return {\n      errorType: 'rate_limited',\n      status,\n      message: 'Rate limited by OAuth provider — back off and retry',\n      transient: true,\n      raw: truncated,\n    };\n  }\n\n  // 5xx → server error (transient)\n  if (status >= 500) {\n    return {\n      errorType: 'server_error',\n      status,\n      message: `OAuth provider returned ${status} — transient server error`,\n      transient: true,\n      raw: truncated,\n    };\n  }\n\n  // 400 or other 4xx → invalid request (likely a bug)\n  return {\n    errorType: 'invalid_request',\n    status,\n    message: `OAuth request rejected with ${status} — check request parameters`,\n    transient: false,\n    raw: truncated,\n  };\n}\n\n/**\n * Classify a network-level error (fetch threw before receiving a response).\n */\nfunction classifyNetworkError(err: unknown): OAuthError {\n  const message = err instanceof Error ? err.message : String(err);\n  return {\n    errorType: 'network_error',\n    message: `Network error: ${message}`,\n    transient: true,\n  };\n}\n\n/** Result of postTokenEndpoint: either tokens or a classified error. */\nexport type TokenEndpointResult =\n  | { ok: true; tokens: OAuthTokens }\n  | { ok: false; error: OAuthError };\n\nexport interface OAuthState {\n  state: string;\n  codeVerifier: string;\n  createdAt: number;\n  expiresAt: number;    // unix ms, 10 minute window\n}\n\n/** OAuth flow funnel metrics. */\nexport interface OAuthFunnelMetrics {\n  flowsStarted: number;\n  flowsCompleted: number;\n  flowsExpired: number;\n  flowsFailed: number;\n}\n\nexport class OAuthManager {\n  private pendingStates = new Map<string, OAuthState>();\n  private tokens: OAuthTokens | null = null;\n  private refreshPromise: Promise<TokenEndpointResult> | null = null;\n  private sweepTimer: ReturnType<typeof setInterval> | null = null;\n  private auditLog?: AuditLog;\n  private expiryWarningMs = 30 * 60 * 1000; // default 30 minutes\n  private expiryWarningEmitted = false;\n\n  // OAuth flow funnel counters\n  private flowsStarted = 0;\n  private flowsCompleted = 0;\n  private flowsExpired = 0;\n  private flowsFailed = 0;\n\n  private static readonly DEFAULT_SCOPES = ['user:inference', 'user:profile'];\n\n  constructor(private logger: Logger) {\n    // Sweep expired pending states every 60 seconds\n    this.sweepTimer = setInterval(() => this.sweepExpiredStates(), 60_000);\n    this.sweepTimer.unref();\n  }\n\n  /**\n   * Wire in the audit log and configurable expiry warning threshold.\n   * Called after construction once the audit log is available.\n   */\n  setAuditLog(auditLog: AuditLog, warningMinutes?: number): void {\n    this.auditLog = auditLog;\n    if (warningMinutes !== undefined && warningMinutes > 0) {\n      this.expiryWarningMs = warningMinutes * 60 * 1000;\n    }\n  }\n\n  private sweepExpiredStates(): void {\n    const now = Date.now();\n    let swept = 0;\n    for (const [key, entry] of this.pendingStates) {\n      if (now > entry.expiresAt) {\n        this.pendingStates.delete(key);\n        this.flowsExpired++;\n        swept++;\n        this.logger.info({ stateId: key, ageMs: now - entry.createdAt }, 'OAuth flow expired — state swept');\n      }\n    }\n    if (swept > 0) {\n      this.logger.info({ swept, remaining: this.pendingStates.size }, 'Swept expired OAuth states');\n    }\n  }\n\n  /**\n   * POST to the OAuth token endpoint, parse the response, and map to OAuthTokens.\n   * Callers supply only the grant-specific body fields and a scope fallback.\n   * Returns a discriminated result with classified error info on failure.\n   */\n  private async postTokenEndpoint(\n    body: Record<string, string>,\n    fallbackScopes: string[],\n    context: string,\n  ): Promise<TokenEndpointResult> {\n    try {\n      const response = await fetch(OAUTH_TOKEN_URL, {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          'Accept': 'application/json',\n        },\n        body: JSON.stringify(body),\n      });\n\n      if (!response.ok) {\n        const errorText = await response.text();\n        const classified = classifyHttpError(response.status, errorText);\n        this.logger.error(\n          { status: response.status, errorType: classified.errorType, transient: classified.transient },\n          `OAuth ${context} failed: ${classified.message}`,\n        );\n        try {\n          this.auditLog?.record({\n            action: 'oauth:token_error',\n            resourceType: 'oauth',\n            detail: { errorType: classified.errorType, status: response.status, transient: classified.transient, context },\n          });\n        } catch { /* logged inside record() */ }\n        return { ok: false, error: classified };\n      }\n\n      const data = await response.json() as {\n        access_token: string;\n        refresh_token: string;\n        expires_in: number;\n        scope?: string;\n      };\n\n      return {\n        ok: true,\n        tokens: {\n          accessToken: data.access_token,\n          refreshToken: data.refresh_token,\n          expiresAt: Date.now() + data.expires_in * 1000,\n          scopes: data.scope ? data.scope.split(' ') : fallbackScopes,\n        },\n      };\n    } catch (err) {\n      const classified = classifyNetworkError(err);\n      this.logger.error(\n        { err, errorType: classified.errorType, transient: classified.transient },\n        `OAuth ${context} failed: ${classified.message}`,\n      );\n      try {\n        this.auditLog?.record({\n          action: 'oauth:token_error',\n          resourceType: 'oauth',\n          detail: { errorType: classified.errorType, transient: classified.transient, context },\n        });\n      } catch { /* logged inside record() */ }\n      return { ok: false, error: classified };\n    }\n  }\n\n  /**\n   * Step 1: Generate the authorization URL for the user to visit.\n   * Returns the URL and stores PKCE state internally.\n   */\n  generateAuthUrl(): { url: string; state: string } {\n    const state = randomBytes(32).toString('hex');\n    const codeVerifier = randomBytes(32).toString('base64url');\n    const codeChallenge = createHash('sha256')\n      .update(codeVerifier)\n      .digest('base64url');\n\n    const oauthState: OAuthState = {\n      state,\n      codeVerifier,\n      createdAt: Date.now(),\n      expiresAt: Date.now() + 10 * 60 * 1000, // 10 minutes\n    };\n\n    this.pendingStates.set(state, oauthState);\n\n    const params = new URLSearchParams({\n      code: 'true',\n      client_id: CLIENT_ID,\n      response_type: 'code',\n      redirect_uri: REDIRECT_URI,\n      scope: SCOPES,\n      code_challenge: codeChallenge,\n      code_challenge_method: 'S256',\n      state,\n    });\n\n    const url = `${OAUTH_AUTHORIZE_URL}?${params.toString()}`;\n\n    this.flowsStarted++;\n    this.logger.info({ stateId: state }, 'OAuth flow started — authorization URL generated');\n    return { url, state };\n  }\n\n  /**\n   * Step 2: Exchange the authorization code for tokens.\n   * Called after user completes the OAuth flow and provides the code.\n   */\n  async exchangeCode(authorizationCode: string, state: string): Promise<TokenEndpointResult> {\n    // Validate state\n    const pending = this.pendingStates.get(state);\n    if (!pending) {\n      this.flowsFailed++;\n      this.logger.info({ stateId: state }, 'OAuth flow failed — state not found or already consumed');\n      return { ok: false, error: { errorType: 'invalid_request', message: 'OAuth state not found or already consumed', transient: false } };\n    }\n\n    if (Date.now() > pending.expiresAt) {\n      this.flowsFailed++;\n      this.pendingStates.delete(state);\n      this.logger.info({ stateId: state }, 'OAuth flow failed — state expired before code exchange');\n      return { ok: false, error: { errorType: 'invalid_request', message: 'OAuth state expired', transient: false } };\n    }\n\n    const cleanedCode = authorizationCode.split('#')[0]?.split('&')[0] ?? authorizationCode;\n\n    const result = await this.postTokenEndpoint(\n      {\n        grant_type: 'authorization_code',\n        client_id: CLIENT_ID,\n        code: cleanedCode,\n        redirect_uri: REDIRECT_URI,\n        code_verifier: pending.codeVerifier,\n        state: pending.state,\n      },\n      OAuthManager.DEFAULT_SCOPES,\n      'token exchange',\n    );\n\n    this.pendingStates.delete(state);\n\n    if (result.ok) {\n      this.tokens = result.tokens;\n      this.logger.info({\n        scopes: this.tokens.scopes,\n        expiresAt: new Date(this.tokens.expiresAt).toISOString(),\n      }, 'OAuth token exchange successful');\n    }\n\n    return result;\n  }\n\n  /**\n   * Refresh the access token using the refresh token.\n   * Called automatically before dispatching if token is near expiry.\n   * Uses promise dedup so concurrent callers share one in-flight refresh,\n   * preventing single-use rotating refresh tokens from being consumed twice.\n   */\n  async refreshAccessToken(): Promise<TokenEndpointResult> {\n    if (!this.tokens) {\n      this.logger.error('No tokens to refresh');\n      return { ok: false, error: { errorType: 'invalid_request', message: 'No tokens to refresh', transient: false } };\n    }\n\n    if (this.refreshPromise) {\n      return this.refreshPromise;\n    }\n\n    this.refreshPromise = this.executeRefresh().finally(() => {\n      this.refreshPromise = null;\n    });\n    return this.refreshPromise;\n  }\n\n  private async executeRefresh(): Promise<TokenEndpointResult> {\n    const previousScopes = this.tokens!.scopes;\n\n    // Refresh tokens are single-use rotation — store the new one\n    const result = await this.postTokenEndpoint(\n      {\n        grant_type: 'refresh_token',\n        client_id: CLIENT_ID,\n        refresh_token: this.tokens!.refreshToken,\n      },\n      previousScopes,\n      'token refresh',\n    );\n\n    if (result.ok) {\n      this.tokens = result.tokens;\n      this.logger.info({\n        expiresAt: new Date(this.tokens.expiresAt).toISOString(),\n      }, 'OAuth token refreshed');\n      try { this.auditLog?.record({ action: 'oauth:refresh', resourceType: 'oauth', detail: { expiresAt: new Date(this.tokens.expiresAt).toISOString() } }); } catch { /* logged inside record() */ }\n    } else {\n      try { this.auditLog?.record({ action: 'oauth:refresh_failed', resourceType: 'oauth', detail: { reason: result.error.message, errorType: result.error.errorType } }); } catch { /* logged inside record() */ }\n    }\n\n    return result;\n  }\n\n  /**\n   * Get a valid access token, refreshing if necessary.\n   * Returns null if no tokens available or refresh fails.\n   */\n  async getValidAccessToken(): Promise<string | null> {\n    if (!this.tokens) return null;\n\n    const now = Date.now();\n    const remainingMs = this.tokens.expiresAt - now;\n\n    // Emit token:expiring_soon once per token when within the warning threshold\n    if (remainingMs > 0 && remainingMs <= this.expiryWarningMs && !this.expiryWarningEmitted) {\n      this.expiryWarningEmitted = true;\n      try {\n        this.auditLog?.record({\n          action: 'token:expiring_soon',\n          resourceType: 'oauth',\n          detail: {\n            expiresAt: new Date(this.tokens.expiresAt).toISOString(),\n            remainingMinutes: Math.round(remainingMs / 60_000),\n          },\n        });\n      } catch { /* logged inside record() */ }\n      this.logger.warn({ remainingMinutes: Math.round(remainingMs / 60_000) }, 'OAuth token expiring soon');\n    }\n\n    // Refresh if within 10 minutes of expiry\n    const TEN_MINUTES = 10 * 60 * 1000;\n    if (now > this.tokens.expiresAt - TEN_MINUTES) {\n      this.logger.info('Access token near expiry, refreshing...');\n      const result = await this.refreshAccessToken();\n      if (!result.ok) return null;\n      // Reset expiry warning flag after successful refresh\n      this.expiryWarningEmitted = false;\n    }\n\n    return this.tokens.accessToken;\n  }\n\n  /**\n   * Load tokens directly (e.g. from encrypted storage on startup).\n   */\n  loadTokens(tokens: OAuthTokens): void {\n    this.tokens = tokens;\n    this.logger.info({\n      expiresAt: new Date(tokens.expiresAt).toISOString(),\n      scopes: tokens.scopes,\n    }, 'OAuth tokens loaded');\n  }\n\n  /**\n   * Get current tokens for persistence/encryption.\n   */\n  getTokens(): OAuthTokens | null {\n    return this.tokens ? { ...this.tokens } : null;\n  }\n\n  hasTokens(): boolean {\n    return this.tokens !== null;\n  }\n\n  /**\n   * Revoke tokens on the Anthropic server (RFC 7009) then clear local state.\n   * Best-effort: local state is always cleared even if revocation fails.\n   */\n  async revokeAndClearTokens(): Promise<{ revoked: boolean }> {\n    const tokensToRevoke = this.tokens;\n    // Clear local state immediately so the caller never stays \"connected\"\n    this.tokens = null;\n    this.pendingStates.clear();\n\n    if (!tokensToRevoke) {\n      this.logger.info('No tokens to revoke, local state cleared');\n      return { revoked: false };\n    }\n\n    let revoked = false;\n    // Revoke the refresh token first (invalidates the grant); then the access token.\n    for (const { token, hint } of [\n      { token: tokensToRevoke.refreshToken, hint: 'refresh_token' },\n      { token: tokensToRevoke.accessToken, hint: 'access_token' },\n    ] as const) {\n      try {\n        const response = await fetch(OAUTH_REVOKE_URL, {\n          method: 'POST',\n          headers: { 'Content-Type': 'application/json' },\n          body: JSON.stringify({\n            client_id: CLIENT_ID,\n            token,\n            token_type_hint: hint,\n          }),\n        });\n        // RFC 7009 §2.2: the server responds with 200 even if the token was already invalid\n        if (response.ok) {\n          this.logger.info({ hint }, 'OAuth token revoked on server');\n          revoked = true;\n        } else {\n          const errorText = await response.text();\n          this.logger.warn({ hint, status: response.status, error: errorText }, 'OAuth token revocation returned non-OK');\n        }\n      } catch (err) {\n        this.logger.warn({ err, hint }, 'OAuth token revocation request failed');\n      }\n    }\n\n    this.logger.info({ revoked }, 'OAuth disconnect complete, local tokens cleared');\n    return { revoked };\n  }\n\n  clearTokens(): void {\n    this.tokens = null;\n    this.pendingStates.clear();\n    this.logger.info('OAuth tokens cleared');\n  }\n\n  /**\n   * Stop the background sweep timer. Call on shutdown.\n   */\n  dispose