[2026-03-19T08:24:44.463Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017x8yZA9AQQnkSeuiKQnfXe","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher, SubmitResult } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import type { KafkaClient } from './kafka.js';\n    11→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    12→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    13→import type { TriggerSchedulerHandle } from './triggerScheduler.js';\n    14→import type { TenantDbManager } from './tenantDbManager.js';\n    15→import type { TenantKeyManager } from './tenantKeyManager.js';\n    16→import type { AuditLog, AuditEntry, AuditAction, AuditLogHealth } from './auditLog.js';\n    17→import type { EventProcessorHealth } from './eventProcessor.js';\n    18→import type { Logger } from 'pino';\n    19→import * as db from './db/index.js';\n    20→import { readBody, json } from './httpUtils.js';\n    21→\n    22→// --- Route types ---\n    23→\n    24→interface ParsedRoute {\n    25→  resource: string;\n    26→  id?: string;\n    27→  subResource?: string;\n    28→}\n    29→\n    30→type RouteHandler = (\n    31→  req: http.IncomingMessage,\n    32→  res: http.ServerResponse,\n    33→  ctx: RequestContext,\n    34→  route: ParsedRoute | null,\n    35→  queryString: string | undefined,\n    36→  tenantDb: Database.Database | undefined,\n    37→  scopedProjectId: string | undefined,\n    38→  reqLogger: Logger,\n    39→) => Promise<void> | void;\n    40→\n    41→interface RouteEntry {\n    42→  handler: RouteHandler;\n    43→  needsDb?: boolean;\n    44→  adminOnly?: boolean;\n    45→}\n    46→\n    47→/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\n    48→function resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n    49→  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n    50→}\n    51→\n    52→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n    53→function parseRoute(pathname: string): ParsedRoute | null {\n    54→  if (!pathname.startsWith('/api/')) return null;\n    55→  const segments = pathname.slice(5).split('/').filter(Boolean);\n    56→  if (segments.length === 0) return null;\n    57→  return {\n    58→    resource: segments[0]!,\n    59→    id: segments[1],\n    60→    subResource: segments[2],\n    61→  };\n    62→}\n    63→\n    64→export function createHttpApi(\n    65→  auth: Auth,\n    66→  dispatcher: Dispatcher,\n    67→  pool: WorkerPool,\n    68→  tokenManager: TokenManager,\n    69→  oauth: OAuthManager,\n    70→  logger: Logger,\n    71→  database?: Database.Database,\n    72→  tenantDbManager?: TenantDbManager,\n    73→  tenantKeyManager?: TenantKeyManager,\n    74→  auditLog?: AuditLog,\n    75→  getEventProcessorHealth?: () => EventProcessorHealth,\n    76→  kafka?: KafkaClient,\n    77→  onEventPublished?: () => void,\n    78→  triggerScheduler?: TriggerSchedulerHandle,\n    79→): http.Server {\n    80→\n    81→  /** Wrap a mutation handler to emit an audit event on successful response. */\n    82→  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    83→    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n    84→      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n    85→      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n    86→        try {\n    87→          auditLog.record({\n    88→            action,\n    89→            tenantId: ctx.projectId || 'default',\n    90→            actor: ctx.userEmail || ctx.projectId,\n    91→            resourceType,\n    92→            resourceId: route?.id,\n    93→            ipAddress: req.socket.remoteAddress,\n    94→          } as AuditEntry);\n    95→        } catch { /* logged inside record() */ }\n    96→      }\n    97→    };\n    98→  }\n    99→\n   100→  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n   101→  const exactRoutes = new Map<string, RouteEntry>();\n   102→\n   103→  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n   104→  for (const [path, method] of [\n   105→    ['/api/oauth/authorize', 'POST'],\n   106→    ['/api/oauth/callback', 'POST'],\n   107→    ['/api/oauth/status', 'GET'],\n   108→    ['/api/oauth/refresh', 'POST'],\n   109→    ['/api/oauth/disconnect', 'DELETE'],\n   110→    ['/api/token', 'POST'],\n   111→  ] as const) {\n   112→    exactRoutes.set(`${method}:${path}`, {\n   113→      adminOnly: true,\n   114→      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   115→        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger, auditLog);\n   116→      },\n   117→    });\n   118→  }\n   119→\n   120→  exactRoutes.set('GET:/api/status', {\n   121→    handler: (_req, res) => {\n   122→      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   123→    },\n   124→  });\n   125→\n   126→  exactRoutes.set('POST:/api/execute', {\n   127→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   128→      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n   129→    }, 'execution:submit', 'execution'),\n   130→  });\n   131→\n   132→  exactRoutes.set('POST:/api/gitlab/webhook', {\n   133→    needsDb: true,\n   134→    handler: withHttpAudit(async (req, res, _ctx, _route, _qs, tenantDb) => {\n   135→      const body = await readBody(req);\n   136→      let parsed: Record<string, unknown> = {};\n   137→      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   138→      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   139→      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   140→      const event = db.publishEvent(tenantDb!, {\n   141→        eventType: `gitlab_${objectKind}`,\n   142→        sourceType: 'gitlab',\n   143→        sourceId: projectPath ?? null,\n   144→        payload: body,\n   145→      });\n   146→      onEventPublished?.();\n   147→      json(res, 201, event);\n   148→    }, 'event:publish', 'event'),\n   149→  });\n   150→\n   151→  // Admin routes\n   152→  exactRoutes.set('GET:/api/admin/users', {\n   153→    adminOnly: true,\n   154→    handler: (_req, res) => {\n   155→      if (tenantDbManager) {\n   156→        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   157→      } else if (database) {\n   158→        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   159→      } else {\n   160→        json(res, 200, { projectIds: [] });\n   161→      }\n   162→    },\n   163→  });\n   164→\n   165→  exactRoutes.set('GET:/api/admin/personas', {\n   166→    adminOnly: true,\n   167→    handler: (_req, res) => {\n   168→      if (tenantDbManager) {\n   169→        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   170→        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   171→        json(res, 200, allPersonas);\n   172→      } else if (database) {\n   173→        json(res, 200, db.listPersonasSummary(database));\n   174→      } else {\n   175→        json(res, 200, []);\n   176→      }\n   177→    },\n   178→  });\n   179→\n   180→  exactRoutes.set('GET:/api/admin/executions', {\n   181→    adminOnly: true,\n   182→    handler: (_req, res, _ctx, _route, queryString) => {\n   183→      const params = new URLSearchParams(queryString || '');\n   184→      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   185→      if (tenantDbManager) {\n   186→        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   187→        tenantDbManager.forEachTenant((tDb) => {\n   188→          allExecs.push(...db.listExecutions(tDb, { limit }));\n   189→        });\n   190→        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   191→        json(res, 200, allExecs.slice(0, limit));\n   192→      } else if (database) {\n   193→        json(res, 200, db.listExecutions(database, {\n   194→          limit,\n   195→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   196→        }));\n   197→      } else {\n   198→        json(res, 200, []);\n   199→      }\n   200→    },\n   201→  });\n   202→\n   203→  exactRoutes.set('GET:/api/admin/audit', {\n   204→    adminOnly: true,\n   205→    handler: (_req, res, _ctx, _route, queryString) => {\n   206→      if (!auditLog) { json(res, 200, []); return; }\n   207→      const params = new URLSearchParams(queryString || '');\n   208→      json(res, 200, auditLog.query({\n   209→        tenantId: params.get('tenantId') ?? undefined,\n   210→        action: (params.get('action') ?? undefined) as AuditAction | undefined,\n   211→        since: params.get('since') ?? undefined,\n   212→        until: params.get('until') ?? undefined,\n   213→        actor: params.get('actor') ?? undefined,\n   214→        resourceType: params.get('resourceType') ?? undefined,\n   215→        resourceId: params.get('resourceId') ?? undefined,\n   216→        limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   217→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   218→      }));\n   219→    },\n   220→  });\n   221→\n   222→  exactRoutes.set('GET:/api/admin/audit/stats', {\n   223→    adminOnly: true,\n   224→    handler: (_req, res, _ctx, _route, queryString) => {\n   225→      if (!auditLog) { json(res, 200, { byAction: [], byTenant: [], topActors: [], trend: [] }); return; }\n   226→      const params = new URLSearchParams(queryString || '');\n   227→      const bucket = params.get('bucket') === 'hour' ? 'hour' : 'day';\n   228→      json(res, 200, auditLog.stats({\n   229→        tenantId: params.get('tenantId') ?? undefined,\n   230→        since: params.get('since') ?? undefined,\n   231→        until: params.get('until') ?? undefined,\n   232→        bucket,\n   233→      }));\n   234→    },\n   235→  });\n   236→\n   237→  exactRoutes.set('POST:/api/admin/audit/verify', {\n   238→    adminOnly: true,\n   239→    handler: async (req, res) => {\n   240→      if (!auditLog) { json(res, 200, { valid: true, verifiedCount: 0 }); return; }\n   241→      const body = await readBody(req);\n   242→      let opts: { since?: string; until?: string } | undefined;\n   243→      if (body) {\n   244→        try {\n   245→          const parsed = JSON.parse(body) as { since?: string; until?: string };\n   246→          if (parsed.since || parsed.until) opts = { since: parsed.since, until: parsed.until };\n   247→        } catch { /* empty body or non-JSON — verify entire chain */ }\n   248→      }\n   249→      json(res, 200, auditLog.verify(opts));\n   250→    },\n   251→  });\n   252→\n   253→  // ── Resource route table (O(1) lookup by `METHOD:resource[:id][:sub]`) ──\n   254→  const resourceRoutes = new Map<string, RouteEntry>();\n   255→\n   256→  // --- Persona CRUD ---\n   257→  resourceRoutes.set(resourceKey('GET', 'personas', false), {\n   258→    needsDb: true,\n   259→    handler: (_req, res, _ctx, _route, _qs, tenantDb, scopedProjectId) => {\n   260→      json(res, 200, db.listPersonasSummary(tenantDb!, scopedProjectId));\n   261→    },\n   262→  });\n   263→\n   264→  resourceRoutes.set(resourceKey('POST', 'personas', false), {\n   265→    needsDb: true,\n   266→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   267→      const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   268→      const persona = createPersonaWithDefaults({\n   269→        ...body,\n   270→        projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   271→      });\n   272→      db.upsertPersona(tenantDb!, persona);\n   273→      try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: persona.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   274→      reqLogger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   275→      json(res, 201, persona);\n   276→    },\n   277→  });\n   278→\n   279→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'tools'), {\n   280→    needsDb: true,\n   281→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   282→      json(res, 200, db.getToolsForPersona(tenantDb!, route!.id!));\n   283→    },\n   284→  });\n   285→\n   286→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'tools'), {\n   287→    needsDb: true,\n   288→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   289→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   290→      if (!persona) return;\n   291→      const body = JSON.parse(await readBody(req)) as { toolId: string };\n   292→      db.linkTool(tenantDb!, route!.id!, body.toolId);\n   293→      try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { toolId: body.toolId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   294→      reqLogger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route!.id!, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   295→      json(res, 200, { linked: true });\n   296→    },\n   297→  });\n   298→\n   299→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'full'), {\n   300→    needsDb: true,\n   301→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   302→      const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb!, route!.id!, reqLogger), scopedProjectId, res);\n   303→      if (!hydrated) return;\n   304→      json(res, 200, hydrated);\n   305→    },\n   306→  });\n   307→\n   308→  resourceRoutes.set(resourceKey('GET', 'personas', true), {\n   309→    needsDb: true,\n   310→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId) => {\n   311→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   312→      if (!persona) return;\n   313→      json(res, 200, persona);\n   314→    },\n   315→  });\n   316→\n   317→  resourceRoutes.set(resourceKey('DELETE', 'personas', true), {\n   318→    needsDb: true,\n   319→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   320→      db.deletePersona(tenantDb!, route!.id!, scopedProjectId);\n   321→      try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   322→      reqLogger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   323→      json(res, 200, { deleted: true });\n   324→    },\n   325→  });\n   326→\n   327→  // --- Persona sub-resources: credentials ---\n   328→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'credentials'), {\n   329→    needsDb: true,\n   330→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   331→      const creds = db.listCredentialsForPersona(tenantDb!, route!.id!);\n   332→      try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   333→      json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   334→    },\n   335→  });\n   336→\n   337→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'credentials'), {\n   338→    needsDb: true,\n   339→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   340→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   341→      if (!persona) return;\n   342→      const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   343→      db.linkCredential(tenantDb!, route!.id!, body.credentialId);\n   344→      try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { credentialId: body.credentialId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   345→      reqLogger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route!.id!, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   346→      json(res, 200, { linked: true });\n   347→    },\n   348→  });\n   349→\n   350→  // --- Persona sub-resources: subscriptions ---\n   351→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'subscriptions'), {\n   352→    needsDb: true,\n   353→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   354→      json(res, 200, db.listSubscriptionsForPersona(tenantDb!, route!.id!));\n   355→    },\n   356→  });\n   357→\n   358→  // --- Tool Definitions ---\n   359→  resourceRoutes.set(resourceKey('POST', 'tool-definitions', false), {\n   360→    needsDb: true,\n   361→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   362→      const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   363→      const tool = createToolDefinitionWithDefaults(body);\n   364→      db.upsertToolDefinition(tenantDb!, tool);\n   365→      try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'toolDefinition', resourceId: tool.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   366→      reqLogger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   367→      json(res, 201, tool);\n   368→    },\n   369→  });\n   370→\n   371→  // --- Credentials ---\n   372→  resourceRoutes.set(resourceKey('POST', 'credentials', false), {\n   373→    needsDb: true,\n   374→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   375→      const body = JSON.parse(await readBody(req));\n   376→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   377→\n   378→      if (!body.plaintext || typeof body.plaintext !== 'string') {\n   379→        json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   380→        return;\n   381→      }\n   382→      if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   383→        json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   384→        return;\n   385→      }\n   386→      if (!tenantKeyManager) {\n   387→        json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   388→        return;\n   389→      }\n   390→\n   391→      delete body.encryptedData;\n   392→      delete body.iv;\n   393→      delete body.tag;\n   394→\n   395→      const tenantId = body.projectId || ctx.projectId || 'default';\n   396→      const key = await tenantKeyManager.getKey(tenantId);\n   397→      const encrypted = encrypt(body.plaintext, key);\n   398→      body.encryptedData = encrypted.encrypted;\n   399→      body.iv = encrypted.iv;\n   400→      body.tag = encrypted.tag;\n   401→      delete body.plaintext;\n   402→\n   403→      const cred = db.createCredential(tenantDb!, body);\n   404→      try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: cred.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   405→      reqLogger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   406→      json(res, 201, cred);\n   407→    },\n   408→  });\n   409→\n   410→  resourceRoutes.set(resourceKey('DELETE', 'credentials', true), {\n   411→    needsDb: true,\n   412→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   413→      const changes = db.deleteCredential(tenantDb!, route!.id!, scopedProjectId);\n   414→      if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   415→      try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   416→      reqLogger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   417→      json(res, 200, { deleted: true });\n   418→    },\n   419→  });\n   420→\n   421→  // --- Event Subscriptions ---\n   422→  resourceRoutes.set(resourceKey('POST', 'subscriptions', false), {\n   423→    needsDb: true,\n   424→    handler: async (req, res, ctx, _route, _qs, tenantDb) => {\n   425→      const body = JSON.parse(await readBody(req));\n   426→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   427→      const missing: string[] = [];\n   428→      if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   429→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   430→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   431→      const sub = db.createSubscription(tenantDb!, body);\n   432→      try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: sub.id, detail: { personaId: body.personaId, eventType: body.eventType }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   433→      json(res, 201, sub);\n   434→    },\n   435→  });\n   436→\n   437→  resourceRoutes.set(resourceKey('PUT', 'subscriptions', true), {\n   438→    needsDb: true,\n   439→    handler: async (req, res, ctx, route, _qs, tenantDb) => {\n   440→      const body = JSON.parse(await readBody(req));\n   441→      db.updateSubscription(tenantDb!, route!.id!, body);\n   442→      const updated = db.getSubscription(tenantDb!, route!.id!);\n   443→      try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   444→      json(res, 200, updated);\n   445→    },\n   446→  });\n   447→\n   448→  resourceRoutes.set(resourceKey('DELETE', 'subscriptions', true), {\n   449→    needsDb: true,\n   450→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   451→      db.deleteSubscription(tenantDb!, route!.id!);\n   452→      try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   453→      json(res, 200, { deleted: true });\n   454→    },\n   455→  });\n   456→\n   457→  // --- Triggers (delegated to triggerHttpHandlers) ---\n   458→  const triggerHandler: RouteHandler = async (req, res, ctx, route, _qs, tenantDb) => {\n   459→    await handleTriggerRoute(route!, req.method!, req, res, tenantDb!, ctx, triggerScheduler);\n   460→  };\n   461→  resourceRoutes.set(resourceKey('POST', 'triggers', false), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:create', 'trigger') });\n   462→  resourceRoutes.set(resourceKey('PUT', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:update', 'trigger') });\n   463→  resourceRoutes.set(resourceKey('DELETE', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:delete', 'trigger') });\n   464→  resourceRoutes.set(resourceKey('GET', 'triggers', true, 'history'), { needsDb: true, handler: triggerHandler });\n   465→  resourceRoutes.set(resourceKey('GET', 'triggers', true, 'stats'), { needsDb: true, handler: triggerHandler });\n   466→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'triggers'), { needsDb: true, handler: triggerHandler });\n   467→\n   468→  // --- Events ---\n   469→  resourceRoutes.set(resourceKey('GET', 'events', false), {\n   470→    needsDb: true,\n   471→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   472→      const params = new URLSearchParams(queryString || '');\n   473→      const events = db.listEvents(tenantDb!, {\n   474→        eventType: params.get('eventType') ?? undefined,\n   475→        status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n   476→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   477→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   478→        projectId: scopedProjectId,\n   479→      });\n   480→      json(res, 200, events);\n   481→    },\n   482→  });\n   483→\n   484→  resourceRoutes.set(resourceKey('POST', 'events', false), {\n   485→    needsDb: true,\n   486→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, tenantDb) => {\n   487→      const body = JSON.parse(await readBody(req));\n   488→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   489→      const missing: string[] = [];\n   490→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   491→      if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   492→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   493→      const event = db.publishEvent(tenantDb!, body);\n   494→      onEventPublished?.();\n   495→      json(res, 201, event);\n   496→    }, 'event:publish', 'event'),\n   497→  });\n   498→\n   499→  resourceRoutes.set(resourceKey('PUT', 'events', true), {\n   500→    needsDb: true,\n   501→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   502→      const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n   503→      const updated = db.updateEventWithMetadata(tenantDb!, route!.id!, body.status, body.metadata);\n   504→      if (updated) {\n   505→        json(res, 200, updated);\n   506→      } else {\n   507→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   508→        res.end(JSON.stringify({ error: 'Event not found' }));\n   509→      }\n   510→    }, 'event:update', 'event'),\n   511→  });\n   512→\n   513→  // --- Webhooks ---\n   514→  resourceRoutes.set(resourceKey('POST', 'webhooks', true), {\n   515→    needsDb: true,\n   516→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   517→      const personaId = route!.id!;\n   518→      const body = await readBody(req);\n   519→      const event = db.publishEvent(tenantDb!, {\n   520→        eventType: 'webhook_received',\n   521→        sourceType: 'webhook',\n   522→        sourceId: personaId,\n   523→        targetPersonaId: personaId,\n   524→        payload: body,\n   525→      });\n   526→      onEventPublished?.();\n   527→      json(res, 201, event);\n   528→    }, 'webhook:receive', 'webhook'),\n   529→  });\n   530→\n   531→  // --- Executions ---\n   532→  resourceRoutes.set(resourceKey('GET', 'executions', false), {\n   533→    needsDb: true,\n   534→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   535→      const params = new URLSearchParams(queryString || '');\n   536→      const executions = db.listExecutions(tenantDb!, {\n   537→        personaId: params.get('personaId') ?? undefined,\n   538→        status: params.get('status') ?? undefined,\n   539→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   540→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   541→        projectId: scopedProjectId,\n   542→      });\n   543→      json(res, 200, executions);\n   544→    },\n   545→  });\n   546→\n   547→  resourceRoutes.set(resourceKey('POST', 'executions', true, 'cancel'), {\n   548→    handler: (_req, res, _ctx, route) => {\n   549→      handleCancelExecution(res, dispatcher, route!.id!);\n   550→    },\n   551→  });\n   552→\n   553→  resourceRoutes.set(resourceKey('GET', 'executions', true), {\n   554→    handler: (_req, res, _ctx, route, queryString) => {\n   555→      const params = new URLSearchParams(queryString || '');\n   556→      const offset = parseInt(params.get('offset') || '0', 10);\n   557→      handleGetExecution(res, dispatcher, route!.id!, offset);\n   558→    },\n   559→  });\n   560→\n   561→  // ── Request handler ──\n   562→  const server = http.createServer(async (req, res) => {\n   563→    // Request correlation ID\n   564→    const reqId = nanoid();\n   565→    const reqLogger = logger.child({ reqId });\n   566→    res.setHeader('X-Request-Id', reqId);\n   567→\n   568→    // Security headers\n   569→    res.setHeader('X-Content-Type-Options', 'nosniff');\n   570→\n   571→    // CORS headers\n   572→    const origin = req.headers.origin ?? '';\n   573→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n   574→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n   575→    if (isAdminRoute) {\n   576→      if (origin && origin === allowedOrigin) {\n   577→        res.setHeader('Access-Control-Allow-Origin', origin);\n   578→      }\n   579→    } else {\n   580→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n   581→    }\n   582→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n   583→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n   584→\n   585→    if (req.method === 'OPTIONS') {\n   586→      res.writeHead(204);\n   587→      res.end();\n   588→      return;\n   589→    }\n   590→\n   591→    const url = req.url || '/';\n   592→    const [pathname, queryString] = url.split('?');\n   593→    const route = parseRoute(pathname ?? '');\n   594→\n   595→    // Unauthenticated endpoint\n   596→    if (pathname === '/health' && req.method === 'GET') {\n   597→      await handleHealth(res, pool, dispatcher, tokenManager, oauth, getEventProcessorHealth, database, tenantDbManager, kafka, triggerScheduler, auditLog);\n   598→      return;\n   599→    }\n   600→\n   601→    // Auth check\n   602→    const ctx = auth.validateAndExtractContext(req);\n   603→    if (!ctx) {\n   604→      res.writeHead(401, { 'Content-Type': 'application/json' });\n   605→      res.end(JSON.stringify({ error: 'Unauthorized', reqId }));\n   606→      return;\n   607→    }\n   608→\n   609→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n   610→\n   611→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n   612→      if (tenantDbManager && projectId) {\n   613→        return tenantDbManager.getTenantDb(projectId);\n   614→      }\n   615→      return database;\n   616→    };\n   617→    const tenantDb = resolveDatabase(ctx.projectId);\n   618→\n   619→    try {\n   620→      // O(1) exact-path lookup\n   621→      const exactEntry = exactRoutes.get(`${req.method}:${pathname}`);\n   622→      if (exactEntry) {\n   623→        if (exactEntry.adminOnly && requireAdmin(ctx, res)) return;\n   624→        if (exactEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   625→        await exactEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   626→        return;\n   627→      }\n   628→\n   629→      // O(1) resource-route lookup\n   630→      if (route) {\n   631→        const resKey = resourceKey(req.method!, route.resource, !!route.id, route.subResource);\n   632→        const resEntry = resourceRoutes.get(resKey);\n   633→        if (resEntry) {\n   634→          if (resEntry.adminOnly && requireAdmin(ctx, res)) return;\n   635→          if (resEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   636→          await resEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   637→          return;\n   638→        }\n   639→      }\n   640→\n   641→      // No matching route\n   642→      json(res, 404, { error: 'Not found', reqId });\n   643→    } catch (err) {\n   644→      if (err instanceof Error && err.message === 'Payload too large') {\n   645→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   646→        res.end(JSON.stringify({ error: 'Payload too large', reqId }));\n   647→        return;\n   648→      }\n   649→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   650→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   651→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists', reqId }));\n   652→        return;\n   653→      }\n   654→      reqLogger.error({ err, url }, 'HTTP handler error');\n   655→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   656→      res.end(JSON.stringify({ error: 'Internal server error', reqId }));\n   657→    }\n   658→  });\n   659→\n   660→  return server;\n   661→}\n   662→\n   663→/**\n   664→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   665→ * Returns the entity on success, or null after sending a 404 response.\n   666→ */\n   667→function withScopedEntity<T extends { projectId?: string | null }>(\n   668→  entity: T | undefined,\n   669→  scopedProjectId: string | undefined,\n   670→  res: http.ServerResponse,\n   671→): T | null {\n   672→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   673→    json(res, 404, { error: 'Not found' });\n   674→    return null;\n   675→  }\n   676→  return entity;\n   677→}\n   678→\n   679→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   680→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   681→  if (ctx.authType !== 'admin') {\n   682→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   683→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   684→    return true;\n   685→  }\n   686→  return false;\n   687→}\n   688→\n   689→// --- Existing handlers ---\n   690→\n   691→/** Heartbeat age (ms) beyond which a worker is considered stale. */\n   692→const STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n   693→\n   694→async function handleHealth(\n   695→  res: http.ServerResponse,\n   696→  pool: WorkerPool,\n   697→  dispatcher: Dispatcher,\n   698→  tokenManager: TokenManager,\n   699→  oauth: OAuthManager,\n   700→  getEventProcessorHealth?: () => EventProcessorHealth,\n   701→  database?: Database.Database,\n   702→  tenantDbManager?: TenantDbManager,\n   703→  kafka?: KafkaClient,\n   704→  triggerScheduler?: TriggerSchedulerHandle,\n   705→  auditLog?: AuditLog,\n   706→): Promise<void> {\n   707→  const issues: string[] = [];\n   708→\n   709→  const counts = pool.getWorkerCount();\n   710→  const workers = pool.getWorkers();\n   711→  const now = Date.now();\n   712→  const staleWorkers = workers\n   713→    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n   714→    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n   715→\n   716→  if (staleWorkers.length > 0) {\n   717→    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n   718→  }\n   719→\n   720→  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n   721→  if (database) {\n   722→    try {\n   723→      database.prepare('SELECT 1').get();\n   724→      dbHealth.status = 'ok';\n   725→    } catch {\n   726→      dbHealth.status = 'error';\n   727→      issues.push('database unreachable');\n   728→    }\n   729→  }\n   730→  if (tenantDbManager) {\n   731→    try {\n   732→      const tenantIds = tenantDbManager.listTenantIds();\n   733→      dbHealth.tenantCount = tenantIds.length;\n   734→      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n   735→    } catch {\n   736→      dbHealth.tenantCount = -1;\n   737→      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n   738→      issues.push('tenant DB listing failed');\n   739→    }\n   740→  }\n   741→\n   742→  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n   743→  if (kafka) {\n   744→    const kh = await kafka.checkHealth();\n   745→    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n   746→    if (kh.status === 'error') {\n   747→      issues.push(`kafka: ${kh.detail || 'error'}`);\n   748→    }\n   749→  }\n   750→\n   751→  const queueDepth = dispatcher.getQueueLength();\n   752→  const activeExecutions = dispatcher.getActiveExecutions().length;\n   753→\n   754→  let eventProcessorHealth: EventProcessorHealth | undefined;\n   755→  if (getEventProcessorHealth) {\n   756→    eventProcessorHealth = getEventProcessorHealth();\n   757→  }\n   758→\n   759→  const tokenHealth = tokenManager.getHealth();\n   760→  if (tokenHealth.consecutiveDecryptionFailures > 0) {\n   761→    issues.push(`token decryption failures: ${tokenHealth.consecutiveDecryptionFailures} consecutive`);\n   762→  }\n   763→\n   764→  let verdict: 'healthy' | 'degraded' | 'unhealthy';\n   765→  if (issues.some(i => i.includes('database unreachable') || i.includes('kafka: '))) {\n   766→    verdict = 'unhealthy';\n   767→  } else if (issues.length > 0) {\n   768→    verdict = 'degraded';\n   769→  } else {\n   770→    verdict = 'healthy';\n   771→  }\n   772→\n   773→  const body: Record<string, unknown> = {\n   774→    status: verdict,\n   775→    timestamp: Date.now(),\n   776→    dependencies: {\n   777→      database: dbHealth,\n   778→      kafka: kafkaHealth,\n   779→      workers: {\n   780→        ...counts,\n   781→        staleWorkers: staleWorkers.length > 0 ? staleWorkers : undefined,\n   782→      },\n   783→      token: tokenHealth,\n   784→    },\n   785→    queue: {\n   786→      depth: queueDepth,\n   787→      activeExecutions,\n   788→    },\n   789→    hasSubscription: oauth.hasTokens(),\n   790→  };\n   791→\n   792→  if (eventProcessorHealth) {\n   793→    (body.dependencies as Record<string, unknown>).eventProcessor = eventProcessorHealth;\n   794→  }\n   795→\n   796→  if (triggerScheduler) {\n   797→    (body.dependencies as Record<string, unknown>).scheduler = triggerScheduler.getMetrics();\n   798→  }\n   799→\n   800→  if (auditLog) {\n   801→    const auditHealth = auditLog.getHealth();\n   802→    (body.dependencies as Record<string, unknown>).audit = auditHealth;\n   803→    if (auditHealth.droppedEvents > 0) {\n   804→      issues.push(`audit: ${auditHealth.droppedEvents} dropped events`);\n   805→    }\n   806→  }\n   807→\n   808→  if (issues.length > 0) {\n   809→    body.issues = issues;\n   810→  }\n   811→\n   812→  const httpStatus = verdict === 'unhealthy' ? 503 : 200;\n   813→  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n   814→  res.end(JSON.stringify(body));\n   815→}\n   816→\n   817→function handleStatus(\n   818→  res: http.ServerResponse,\n   819→  pool: WorkerPool,\n   820→  dispatcher: Dispatcher,\n   821→  tokenManager: TokenManager,\n   822→  oauth: OAuthManager,\n   823→): void {\n   824→  const oauthTokens = oauth.getTokens();\n   825→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   826→  res.end(JSON.stringify({\n   827→    workers: pool.getWorkers(),\n   828→    workerCounts: pool.getWorkerCount(),\n   829→    workerPoolMetrics: pool.getMetrics(),\n   830→    queueLength: dispatcher.getQueueLength(),\n   831→    activeExecutions: dispatcher.getActiveExecutions(),\n   832→    hasClaudeToken: tokenManager.hasToken(),\n   833→    oauth: {\n   834→      connected: oauth.hasTokens(),\n   835→      scopes: oauthTokens?.scopes || [],\n   836→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   837→    },\n   838→  }));\n   839→}\n   840→\n   841→async function handleExecute(\n   842→  req: http.IncomingMessage,\n   843→  res: http.ServerResponse,\n   844→  dispatcher: Dispatcher,\n   845→  logger: Logger,\n   846→  ctx?: RequestContext,\n   847→): Promise<void> {\n   848→  const body = await readBody(req);\n   849→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   850→\n   851→  try {\n   852→    parsed = JSON.parse(body);\n   853→  } catch {\n   854→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   855→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   856→    return;\n   857→  }\n   858→\n   859→  if (!parsed.prompt) {\n   860→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   861→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   862→    return;\n   863→  }\n   864→\n   865→  const request: ExecRequest = {\n   866→    executionId: nanoid(),\n   867→    personaId: parsed.personaId || 'manual',\n   868→    prompt: parsed.prompt,\n   869→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   870→    config: {\n   871→      timeoutMs: parsed.timeoutMs || 300_000,\n   872→    },\n   873→  };\n   874→\n   875→  const result: SubmitResult = dispatcher.submit(request);\n   876→\n   877→  if (!result.accepted) {\n   878→    logger.warn({ executionId: request.executionId, reason: result.reason }, 'Execution rejected by backpressure');\n   879→    res.writeHead(429, {\n   880→      'Content-Type': 'application/json',\n   881→      'Retry-After': String(result.retryAfterSeconds),\n   882→    });\n   883→    res.end(JSON.stringify({\n   884→      error: result.reason === 'tenant_quota_exceeded'\n   885→        ? 'Per-tenant queue quota exceeded'\n   886→        : 'Queue depth limit exceeded',\n   887→      retryAfterSeconds: result.retryAfterSeconds,\n   888→    }));\n   889→    return;\n   890→  }\n   891→\n   892→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   893→\n   894→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   895→  res.end(JSON.stringify({\n   896→    executionId: request.executionId,\n   897→    status: 'queued',\n   898→  }));\n   899→}\n   900→\n   901→function handleGetExecution(\n   902→  res: http.ServerResponse,\n   903→  dispatcher: Dispatcher,\n   904→  executionId: string,\n   905→  offset: number = 0,\n   906→): void {\n   907→  const exec = dispatcher.getExecution(executionId);\n   908→\n   909→  if (!exec) {\n   910→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   911→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   912→    return;\n   913→  }\n   914→\n   915→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   916→\n   917→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   918→  res.end(JSON.stringify({\n   919→    executionId,\n   920→    status: exec.status,\n   921→    outputLines: exec.output.length,\n   922→    output,\n   923→    durationMs: exec.durationMs,\n   924→    sessionId: exec.sessionId,\n   925→    totalCostUsd: exec.totalCostUsd,\n   926→    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n   927→  }));\n   928→}\n   929→\n   930→function handleCancelExecution(\n   931→  res: http.ServerResponse,\n   932→  dispatcher: Dispatcher,\n   933→  executionId: string,\n   934→): void {\n   935→  const cancelled = dispatcher.cancelExecution(executionId);\n   936→\n   937→  if (!cancelled) {\n   938→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   939→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   940→    return;\n   941→  }\n   942→\n   943→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   944→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   945→}\n   946→\n   947→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB\n   948→const MAX_QUERY_LIMIT = 500;\n   949→const MAX_QUERY_OFFSET = 100_000;\n   950→\n   951→/** Parse an integer query param and clamp it to safe bounds. */\n   952→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   953→  if (!value) return defaultValue;\n   954→  const parsed = parseInt(value, 10);\n   955→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   956→  return Math.min(parsed, max);\n   957→}\n   958→"}]},"parent_tool_use_id":null,"session_id":"d3723eba-4b01-4936-8e79-68e61fc0bca1","uuid":"4fbdb4d9-d7ef-46f3-9a35-642da151dcd0","timestamp":"2026-03-19T08:24:44.192Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher, SubmitResult } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TriggerSchedulerHandle } from './triggerScheduler.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog, AuditEntry, AuditAction, AuditLogHealth } from './auditLog.js';\nimport type { EventProcessorHealth } from './eventProcessor.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\n// --- Route types ---\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\ntype RouteHandler = (\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  ctx: RequestContext,\n  route: ParsedRoute | null,\n  queryString: string | undefined,\n  tenantDb: Database.Database | undefined,\n  scopedProjectId: string | undefined,\n  reqLogger: Logger,\n) => Promise<void> | void;\n\ninterface RouteEntry {\n  handler: RouteHandler;\n  needsDb?: boolean;\n  adminOnly?: boolean;\n}\n\n/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\nfunction resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  kafka?: KafkaClient,\n  onEventPublished?: () => void,\n  triggerScheduler?: TriggerSchedulerHandle,\n): http.Server {\n\n  /** Wrap a mutation handler to emit an audit event on successful response. */\n  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n        try {\n          auditLog.record({\n            action,\n            tenantId: ctx.projectId || 'default',\n            actor: ctx.userEmail || ctx.projectId,\n            resourceType,\n            resourceId: route?.id,\n            ipAddress: req.socket.remoteAddress,\n          } as AuditEntry);\n        } catch { /* logged inside record() */ }\n      }\n    };\n  }\n\n  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n  const exactRoutes = new Map<string, RouteEntry>();\n\n  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n  for (const [path, method] of [\n    ['/api/oauth/authorize', 'POST'],\n    ['/api/oauth/callback', 'POST'],\n    ['/api/oauth/status', 'GET'],\n    ['/api/oauth/refresh', 'POST'],\n    ['/api/oauth/disconnect', 'DELETE'],\n    ['/api/token', 'POST'],\n  ] as const) {\n    exactRoutes.set(`${method}:${path}`, {\n      adminOnly: true,\n      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger, auditLog);\n      },\n    });\n  }\n\n  exactRoutes.set('GET:/api/status', {\n    handler: (_req, res) => {\n      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n    },\n  });\n\n  exactRoutes.set('POST:/api/execute', {\n    handler: withHttpAudit(async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n    }, 'execution:submit', 'execution'),\n  });\n\n  exactRoutes.set('POST:/api/gitlab/webhook', {\n    needsDb: true,\n    handler: withHttpAudit(async (req, res, _ctx, _route, _qs, tenantDb) => {\n      const body = await readBody(req);\n      let parsed: Record<string, unknown> = {};\n      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n      const event = db.publishEvent(tenantDb!, {\n        eventType: `gitlab_${objectKind}`,\n        sourceType: 'gitlab',\n        sourceId: projectPath ?? null,\n        payload: body,\n      });\n      onEventPublished?.();\n      json(res, 201, event);\n    }, 'event:publish', 'event'),\n  });\n\n  // Admin routes\n  exactRoutes.set('GET:/api/admin/users', {\n    adminOnly: true,\n    handler: (_req, res) => {\n      if (tenantDbManager) {\n        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n      } else if (database) {\n        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n      } else {\n        json(res, 200, { projectIds: [] });\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/personas', {\n    adminOnly: true,\n    handler: (_req, res) => {\n      if (tenantDbManager) {\n        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n        json(res, 200, allPersonas);\n      } else if (database) {\n        json(res, 200, db.listPersonasSummary(database));\n      } else {\n        json(res, 200, []);\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/executions', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      const params = new URLSearchParams(queryString || '');\n      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n      if (tenantDbManager) {\n        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n        tenantDbManager.forEachTenant((tDb) => {\n          allExecs.push(...db.listExecutions(tDb, { limit }));\n        });\n        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n        json(res, 200, allExecs.slice(0, limit));\n      } else if (database) {\n        json(res, 200, db.listExecutions(database, {\n          limit,\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        }));\n      } else {\n        json(res, 200, []);\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/audit', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      if (!auditLog) { json(res, 200, []); return; }\n      const params = new URLSearchParams(queryString || '');\n      json(res, 200, auditLog.query({\n        tenantId: params.get('tenantId') ?? undefined,\n        action: (params.get('action') ?? undefined) as AuditAction | undefined,\n        since: params.get('since') ?? undefined,\n        until: params.get('until') ?? undefined,\n        actor: params.get('actor') ?? undefined,\n        resourceType: params.get('resourceType') ?? undefined,\n        resourceId: params.get('resourceId') ?? undefined,\n        limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n      }));\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/audit/stats', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      if (!auditLog) { json(res, 200, { byAction: [], byTenant: [], topActors: [], trend: [] }); return; }\n      const params = new URLSearchParams(queryString || '');\n      const bucket = params.get('bucket') === 'hour' ? 'hour' : 'day';\n      json(res, 200, auditLog.stats({\n        tenantId: params.get('tenantId') ?? undefined,\n        since: params.get('since') ?? undefined,\n        until: params.get('until') ?? undefined,\n        bucket,\n      }));\n    },\n  });\n\n  exactRoutes.set('POST:/api/admin/audit/verify', {\n    adminOnly: true,\n    handler: async (req, res) => {\n      if (!auditLog) { json(res, 200, { valid: true, verifiedCount: 0 }); return; }\n      const body = await readBody(req);\n      let opts: { since?: string; until?: string } | undefined;\n      if (body) {\n        try {\n          const parsed = JSON.parse(body) as { since?: string; until?: string };\n          if (parsed.since || parsed.until) opts = { since: parsed.since, until: parsed.until };\n        } catch { /* empty body or non-JSON — verify entire chain */ }\n      }\n      json(res, 200, auditLog.verify(opts));\n    },\n  });\n\n  // ── Resource route table (O(1) lookup by `METHOD:resource[:id][:sub]`) ──\n  const resourceRoutes = new Map<string, RouteEntry>();\n\n  // --- Persona CRUD ---\n  resourceRoutes.set(resourceKey('GET', 'personas', false), {\n    needsDb: true,\n    handler: (_req, res, _ctx, _route, _qs, tenantDb, scopedProjectId) => {\n      json(res, 200, db.listPersonasSummary(tenantDb!, scopedProjectId));\n    },\n  });\n\n  resourceRoutes.set(resourceKey('POST', 'personas', false), {\n    needsDb: true,\n    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n      const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n      const persona = createPersonaWithDefaults({\n        ...body,\n        projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n      });\n      db.upsertPersona(tenantDb!, persona);\n      try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: persona.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n      json(res, 201, persona);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'tools'), {\n    needsDb: true,\n    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n      json(res, 200, db.getToolsForPersona(tenantDb!, route!.id!));\n    },\n  });\n\n  resourceRoutes.set(resourceKey('POST', 'personas', true, 'tools'), {\n    needsDb: true,\n    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n      if (!persona) return;\n      const body = JSON.parse(await readBody(req)) as { toolId: string };\n      db.linkTool(tenantDb!, route!.id!, body.toolId);\n      try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { toolId: body.toolId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route!.id!, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n      json(res, 200, { linked: true });\n    },\n  });\n\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'full'), {\n    needsDb: true,\n    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb!, route!.id!, reqLogger), scopedProjectId, res);\n      if (!hydrated) return;\n      json(res, 200, hydrated);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('GET', 'personas', true), {\n    needsDb: true,\n    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId) => {\n      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n      if (!persona) return;\n      json(res, 200, persona);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('DELETE', 'personas', true), {\n    needsDb: true,\n    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      db.deletePersona(tenantDb!, route!.id!, scopedProjectId);\n      try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n      json(res, 200, { deleted: true });\n    },\n  });\n\n  // --- Persona sub-resources: credentials ---\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'credentials'), {\n    needsDb: true,\n    handler: (req, res, ctx, route, _qs, tenantDb) => {\n      const creds = db.listCredentialsForPersona(tenantDb!, route!.id!);\n      try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n    },\n  });\n\n  resourceRoutes.set(resourceKey('POST', 'personas', true, 'credentials'), {\n    needsDb: true,\n    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n      if (!persona) return;\n      const body = JSON.parse(await readBody(req)) as { credentialId: string };\n      db.linkCredential(tenantDb!, route!.id!, body.credentialId);\n      try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { credentialId: body.credentialId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route!.id!, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n      json(res, 200, { linked: true });\n    },\n  });\n\n  // --- Persona sub-resources: subscriptions ---\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'subscriptions'), {\n    needsDb: true,\n    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n      json(res, 200, db.listSubscriptionsForPersona(tenantDb!, route!.id!));\n    },\n  });\n\n  // --- Tool Definitions ---\n  resourceRoutes.set(resourceKey('POST', 'tool-definitions', false), {\n    needsDb: true,\n    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n      const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n      const tool = createToolDefinitionWithDefaults(body);\n      db.upsertToolDefinition(tenantDb!, tool);\n      try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'toolDefinition', resourceId: tool.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n      json(res, 201, tool);\n    },\n  });\n\n  // --- Credentials ---\n  resou
[2026-03-19T08:24:44.463Z] [STDOUT] rceRoutes.set(resourceKey('POST', 'credentials', false), {\n    needsDb: true,\n    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n      const body = JSON.parse(await readBody(req));\n      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n\n      if (!body.plaintext || typeof body.plaintext !== 'string') {\n        json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n        return;\n      }\n      if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n        json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n        return;\n      }\n      if (!tenantKeyManager) {\n        json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n        return;\n      }\n\n      delete body.encryptedData;\n      delete body.iv;\n      delete body.tag;\n\n      const tenantId = body.projectId || ctx.projectId || 'default';\n      const key = await tenantKeyManager.getKey(tenantId);\n      const encrypted = encrypt(body.plaintext, key);\n      body.encryptedData = encrypted.encrypted;\n      body.iv = encrypted.iv;\n      body.tag = encrypted.tag;\n      delete body.plaintext;\n\n      const cred = db.createCredential(tenantDb!, body);\n      try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: cred.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n      json(res, 201, cred);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('DELETE', 'credentials', true), {\n    needsDb: true,\n    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      const changes = db.deleteCredential(tenantDb!, route!.id!, scopedProjectId);\n      if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n      try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n      json(res, 200, { deleted: true });\n    },\n  });\n\n  // --- Event Subscriptions ---\n  resourceRoutes.set(resourceKey('POST', 'subscriptions', false), {\n    needsDb: true,\n    handler: async (req, res, ctx, _route, _qs, tenantDb) => {\n      const body = JSON.parse(await readBody(req));\n      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n      const missing: string[] = [];\n      if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n      const sub = db.createSubscription(tenantDb!, body);\n      try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: sub.id, detail: { personaId: body.personaId, eventType: body.eventType }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      json(res, 201, sub);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('PUT', 'subscriptions', true), {\n    needsDb: true,\n    handler: async (req, res, ctx, route, _qs, tenantDb) => {\n      const body = JSON.parse(await readBody(req));\n      db.updateSubscription(tenantDb!, route!.id!, body);\n      const updated = db.getSubscription(tenantDb!, route!.id!);\n      try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      json(res, 200, updated);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('DELETE', 'subscriptions', true), {\n    needsDb: true,\n    handler: (req, res, ctx, route, _qs, tenantDb) => {\n      db.deleteSubscription(tenantDb!, route!.id!);\n      try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      json(res, 200, { deleted: true });\n    },\n  });\n\n  // --- Triggers (delegated to triggerHttpHandlers) ---\n  const triggerHandler: RouteHandler = async (req, res, ctx, route, _qs, tenantDb) => {\n    await handleTriggerRoute(route!, req.method!, req, res, tenantDb!, ctx, triggerScheduler);\n  };\n  resourceRoutes.set(resourceKey('POST', 'triggers', false), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:create', 'trigger') });\n  resourceRoutes.set(resourceKey('PUT', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:update', 'trigger') });\n  resourceRoutes.set(resourceKey('DELETE', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:delete', 'trigger') });\n  resourceRoutes.set(resourceKey('GET', 'triggers', true, 'history'), { needsDb: true, handler: triggerHandler });\n  resourceRoutes.set(resourceKey('GET', 'triggers', true, 'stats'), { needsDb: true, handler: triggerHandler });\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'trigg