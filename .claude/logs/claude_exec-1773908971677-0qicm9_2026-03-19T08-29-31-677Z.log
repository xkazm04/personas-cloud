[2026-03-19T08:30:54.503Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MGrJaMP1q9G98ycyWEdkxb","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import { matchEvent, assemblePrompt } from '@dac-cloud/shared';\n     4→import type { ExecRequest } from '@dac-cloud/shared';\n     5→import { nanoid } from 'nanoid';\n     6→import * as db from './db.js';\n     7→import type { Dispatcher } from './dispatcher.js';\n     8→\n     9→/**\n    10→ * Start the event processing loop.\n    11→ * Ported from desktop engine/background.rs::event_bus_tick().\n    12→ *\n    13→ * Runs every `interval` ms (default 2s), picks up pending events,\n    14→ * matches them to subscriptions, and dispatches executions.\n    15→ */\n    16→export function startEventProcessor(\n    17→  database: Database.Database,\n    18→  dispatcher: Dispatcher,\n    19→  logger: Logger,\n    20→  interval: number = 2000,\n    21→): NodeJS.Timeout {\n    22→  logger.info({ intervalMs: interval }, 'Event processor started');\n    23→\n    24→  return setInterval(() => {\n    25→    try {\n    26→      eventBusTick(database, dispatcher, logger);\n    27→    } catch (err) {\n    28→      logger.error({ err }, 'Event processor tick failed');\n    29→    }\n    30→  }, interval);\n    31→}\n    32→\n    33→function eventBusTick(\n    34→  database: Database.Database,\n    35→  dispatcher: Dispatcher,\n    36→  logger: Logger,\n    37→): void {\n    38→  const events = db.getPendingEvents(database, 50);\n    39→  if (events.length === 0) return;\n    40→\n    41→  for (const event of events) {\n    42→    // Mark as processing\n    43→    db.updateEventStatus(database, event.id, 'processing');\n    44→\n    45→    // Get subscriptions by event type, scoped to the event's project\n    46→    const subs = db.getSubscriptionsByEventType(database, event.eventType, event.projectId !== 'default' ? event.projectId : undefined);\n    47→    const matches = matchEvent(event, subs);\n    48→\n    49→    if (matches.length === 0) {\n    50→      db.updateEventStatus(database, event.id, 'skipped');\n    51→      continue;\n    52→    }\n    53→\n    54→    let delivered = 0;\n    55→    let failed = 0;\n    56→\n    57→    for (const match of matches) {\n    58→      try {\n    59→        const persona = db.getPersona(database, match.personaId);\n    60→        if (!persona) {\n    61→          logger.warn({ personaId: match.personaId, eventId: event.id }, 'Persona not found for event match');\n    62→          failed++;\n    63→          continue;\n    64→        }\n    65→\n    66→        // Check concurrency\n    67→        const running = db.countRunningExecutions(database, persona.id);\n    68→        if (running >= persona.maxConcurrent) {\n    69→          logger.debug({ personaId: persona.id, running, max: persona.maxConcurrent }, 'Persona at concurrency limit, skipping');\n    70→          failed++;\n    71→          continue;\n    72→        }\n    73→\n    74→        // Build input data from event payload\n    75→        let inputData: Record<string, unknown> | undefined;\n    76→        if (match.payload) {\n    77→          try {\n    78→            inputData = JSON.parse(match.payload);\n    79→          } catch {\n    80→            inputData = { raw: match.payload };\n    81→          }\n    82→        }\n    83→\n    84→        // Assemble prompt\n    85→        const tools = db.getToolsForPersona(database, persona.id);\n    86→        const prompt = assemblePrompt(persona, tools, inputData);\n    87→\n    88→        // Submit execution\n    89→        const request: ExecRequest = {\n    90→          executionId: nanoid(),\n    91→          personaId: persona.id,\n    92→          prompt,\n    93→          config: { timeoutMs: persona.timeoutMs },\n    94→          triggerId: undefined,\n    95→          triggerType: undefined,\n    96→        };\n    97→\n    98→        dispatcher.submit(request);\n    99→        delivered++;\n   100→\n   101→        logger.info({\n   102→          eventId: event.id,\n   103→          personaId: persona.id,\n   104→          executionId: request.executionId,\n   105→          eventType: event.eventType,\n   106→          useCaseId: match.useCaseId,\n   107→        }, 'Event dispatched to persona');\n   108→      } catch (err) {\n   109→        logger.error({ err, personaId: match.personaId, eventId: event.id }, 'Failed to dispatch event match');\n   110→        failed++;\n   111→      }\n   112→    }\n   113→\n   114→    // Update event status\n   115→    if (failed === 0) {\n   116→      db.updateEventStatus(database, event.id, 'delivered');\n   117→    } else if (delivered > 0) {\n   118→      db.updateEventStatus(database, event.id, 'partial');\n   119→    } else {\n   120→      db.updateEventStatus(database, event.id, 'failed', 'All subscription matches failed');\n   121→    }\n   122→  }\n   123→}\n   124→"}]},"parent_tool_use_id":"toolu_01J2vHZQ8TdfrzHZF7PqhXgd","session_id":"7dcbcdb6-4ec4-4587-8878-e43fcc71925a","uuid":"cfcf1828-a886-47f3-9fd0-e90e9360a5c1","timestamp":"2026-03-19T08:30:54.404Z"}
