[2026-03-19T08:32:44.405Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VVNGAMatT6gV792GH6Qokw","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import { nanoid } from 'nanoid';\n     3→import type { Logger } from 'pino';\n     4→import type {\n     5→  Persona,\n     6→  PersonaToolDefinition,\n     7→  PersonaCredential,\n     8→  PersonaEvent,\n     9→  PersonaEventSubscription,\n    10→  PersonaTrigger,\n    11→  PersonaExecution,\n    12→} from '@dac-cloud/shared';\n    13→\n    14→// ---------------------------------------------------------------------------\n    15→// Initialization\n    16→// ---------------------------------------------------------------------------\n    17→\n    18→export function initDb(dbPath: string, logger: Logger): Database.Database {\n    19→  const db = new Database(dbPath);\n    20→  db.pragma('journal_mode = WAL');\n    21→  db.pragma('foreign_keys = ON');\n    22→\n    23→  db.exec(SCHEMA);\n    24→  runMigrations(db, logger);\n    25→  logger.info({ dbPath }, 'Database initialized');\n    26→  return db;\n    27→}\n    28→\n    29→// ---------------------------------------------------------------------------\n    30→// Migrations\n    31→// ---------------------------------------------------------------------------\n    32→\n    33→function runMigrations(db: Database.Database, logger: Logger): void {\n    34→  // Migration: add project_id column to tables that need per-user isolation\n    35→  const tablesToMigrate = [\n    36→    'persona_credentials',\n    37→    'persona_event_subscriptions',\n    38→    'persona_triggers',\n    39→    'persona_executions',\n    40→  ];\n    41→\n    42→  for (const table of tablesToMigrate) {\n    43→    const columns = db.prepare(`PRAGMA table_info(${table})`).all() as Array<{ name: string }>;\n    44→    const hasProjectId = columns.some(c => c.name === 'project_id');\n    45→    if (!hasProjectId) {\n    46→      db.exec(`ALTER TABLE ${table} ADD COLUMN project_id TEXT NOT NULL DEFAULT 'default'`);\n    47→      logger.info({ table }, 'Migration: added project_id column');\n    48→    }\n    49→  }\n    50→\n    51→  // Indexes for project_id\n    52→  db.exec(`\n    53→    CREATE INDEX IF NOT EXISTS idx_personas_project ON personas(project_id);\n    54→    CREATE INDEX IF NOT EXISTS idx_pe_project ON persona_events(project_id);\n    55→    CREATE INDEX IF NOT EXISTS idx_pcred_project ON persona_credentials(project_id);\n    56→    CREATE INDEX IF NOT EXISTS idx_pes_project ON persona_event_subscriptions(project_id);\n    57→    CREATE INDEX IF NOT EXISTS idx_pt_project ON persona_triggers(project_id);\n    58→    CREATE INDEX IF NOT EXISTS idx_pex_project ON persona_executions(project_id);\n    59→  `);\n    60→}\n    61→\n    62→// ---------------------------------------------------------------------------\n    63→// Schema\n    64→// ---------------------------------------------------------------------------\n    65→\n    66→const SCHEMA = `\n    67→CREATE TABLE IF NOT EXISTS personas (\n    68→  id TEXT PRIMARY KEY,\n    69→  project_id TEXT NOT NULL DEFAULT 'default',\n    70→  name TEXT NOT NULL,\n    71→  description TEXT,\n    72→  system_prompt TEXT NOT NULL DEFAULT '',\n    73→  structured_prompt TEXT,\n    74→  icon TEXT,\n    75→  color TEXT,\n    76→  enabled INTEGER NOT NULL DEFAULT 1,\n    77→  max_concurrent INTEGER NOT NULL DEFAULT 1,\n    78→  timeout_ms INTEGER NOT NULL DEFAULT 300000,\n    79→  model_profile TEXT,\n    80→  max_budget_usd REAL,\n    81→  max_turns INTEGER,\n    82→  design_context TEXT,\n    83→  group_id TEXT,\n    84→  created_at TEXT NOT NULL,\n    85→  updated_at TEXT NOT NULL\n    86→);\n    87→\n    88→CREATE TABLE IF NOT EXISTS persona_tool_definitions (\n    89→  id TEXT PRIMARY KEY,\n    90→  name TEXT NOT NULL UNIQUE,\n    91→  category TEXT NOT NULL,\n    92→  description TEXT NOT NULL,\n    93→  script_path TEXT NOT NULL DEFAULT '',\n    94→  input_schema TEXT,\n    95→  output_schema TEXT,\n    96→  requires_credential_type TEXT,\n    97→  implementation_guide TEXT,\n    98→  is_builtin INTEGER NOT NULL DEFAULT 0,\n    99→  created_at TEXT NOT NULL,\n   100→  updated_at TEXT NOT NULL\n   101→);\n   102→\n   103→CREATE TABLE IF NOT EXISTS persona_tools (\n   104→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   105→  tool_id TEXT NOT NULL REFERENCES persona_tool_definitions(id) ON DELETE CASCADE,\n   106→  PRIMARY KEY (persona_id, tool_id)\n   107→);\n   108→\n   109→CREATE TABLE IF NOT EXISTS persona_credentials (\n   110→  id TEXT PRIMARY KEY,\n   111→  project_id TEXT NOT NULL DEFAULT 'default',\n   112→  name TEXT NOT NULL,\n   113→  service_type TEXT NOT NULL,\n   114→  encrypted_data TEXT NOT NULL,\n   115→  iv TEXT NOT NULL,\n   116→  tag TEXT NOT NULL,\n   117→  metadata TEXT,\n   118→  last_used_at TEXT,\n   119→  created_at TEXT NOT NULL,\n   120→  updated_at TEXT NOT NULL\n   121→);\n   122→\n   123→CREATE TABLE IF NOT EXISTS persona_credential_links (\n   124→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   125→  credential_id TEXT NOT NULL REFERENCES persona_credentials(id) ON DELETE CASCADE,\n   126→  PRIMARY KEY (persona_id, credential_id)\n   127→);\n   128→\n   129→CREATE TABLE IF NOT EXISTS persona_events (\n   130→  id TEXT PRIMARY KEY,\n   131→  project_id TEXT NOT NULL DEFAULT 'default',\n   132→  event_type TEXT NOT NULL,\n   133→  source_type TEXT NOT NULL,\n   134→  source_id TEXT,\n   135→  target_persona_id TEXT,\n   136→  payload TEXT,\n   137→  status TEXT NOT NULL DEFAULT 'pending',\n   138→  error_message TEXT,\n   139→  processed_at TEXT,\n   140→  use_case_id TEXT,\n   141→  created_at TEXT NOT NULL\n   142→);\n   143→CREATE INDEX IF NOT EXISTS idx_pe_status ON persona_events(status);\n   144→\n   145→CREATE TABLE IF NOT EXISTS persona_event_subscriptions (\n   146→  id TEXT PRIMARY KEY,\n   147→  project_id TEXT NOT NULL DEFAULT 'default',\n   148→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   149→  event_type TEXT NOT NULL,\n   150→  source_filter TEXT,\n   151→  enabled INTEGER NOT NULL DEFAULT 1,\n   152→  use_case_id TEXT,\n   153→  created_at TEXT NOT NULL,\n   154→  updated_at TEXT NOT NULL\n   155→);\n   156→\n   157→CREATE TABLE IF NOT EXISTS persona_triggers (\n   158→  id TEXT PRIMARY KEY,\n   159→  project_id TEXT NOT NULL DEFAULT 'default',\n   160→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   161→  trigger_type TEXT NOT NULL CHECK(trigger_type IN ('manual','schedule','polling','webhook','chain')),\n   162→  config TEXT,\n   163→  enabled INTEGER NOT NULL DEFAULT 1,\n   164→  last_triggered_at TEXT,\n   165→  next_trigger_at TEXT,\n   166→  use_case_id TEXT,\n   167→  created_at TEXT NOT NULL,\n   168→  updated_at TEXT NOT NULL\n   169→);\n   170→\n   171→CREATE TABLE IF NOT EXISTS persona_executions (\n   172→  id TEXT PRIMARY KEY,\n   173→  project_id TEXT NOT NULL DEFAULT 'default',\n   174→  persona_id TEXT NOT NULL,\n   175→  trigger_id TEXT,\n   176→  use_case_id TEXT,\n   177→  status TEXT NOT NULL DEFAULT 'queued' CHECK(status IN ('queued','running','completed','failed','cancelled')),\n   178→  input_data TEXT,\n   179→  output_data TEXT,\n   180→  claude_session_id TEXT,\n   181→  model_used TEXT,\n   182→  input_tokens INTEGER DEFAULT 0,\n   183→  output_tokens INTEGER DEFAULT 0,\n   184→  cost_usd REAL DEFAULT 0,\n   185→  error_message TEXT,\n   186→  duration_ms INTEGER,\n   187→  retry_of_execution_id TEXT,\n   188→  retry_count INTEGER DEFAULT 0,\n   189→  started_at TEXT,\n   190→  completed_at TEXT,\n   191→  created_at TEXT NOT NULL\n   192→);\n   193→CREATE INDEX IF NOT EXISTS idx_pex_persona ON persona_executions(persona_id);\n   194→CREATE INDEX IF NOT EXISTS idx_pex_status ON persona_executions(status);\n   195→`;\n   196→\n   197→// ---------------------------------------------------------------------------\n   198→// Row → domain type mappers\n   199→// ---------------------------------------------------------------------------\n   200→\n   201→function rowToPersona(row: Record<string, unknown>): Persona {\n   202→  return {\n   203→    id: row['id'] as string,\n   204→    projectId: row['project_id'] as string,\n   205→    name: row['name'] as string,\n   206→    description: (row['description'] as string) ?? null,\n   207→    systemPrompt: row['system_prompt'] as string,\n   208→    structuredPrompt: (row['structured_prompt'] as string) ?? null,\n   209→    icon: (row['icon'] as string) ?? null,\n   210→    color: (row['color'] as string) ?? null,\n   211→    enabled: row['enabled'] === 1,\n   212→    maxConcurrent: row['max_concurrent'] as number,\n   213→    timeoutMs: row['timeout_ms'] as number,\n   214→    modelProfile: (row['model_profile'] as string) ?? null,\n   215→    maxBudgetUsd: (row['max_budget_usd'] as number) ?? null,\n   216→    maxTurns: (row['max_turns'] as number) ?? null,\n   217→    designContext: (row['design_context'] as string) ?? null,\n   218→    groupId: (row['group_id'] as string) ?? null,\n   219→    createdAt: row['created_at'] as string,\n   220→    updatedAt: row['updated_at'] as string,\n   221→  };\n   222→}\n   223→\n   224→function rowToTool(row: Record<string, unknown>): PersonaToolDefinition {\n   225→  return {\n   226→    id: row['id'] as string,\n   227→    name: row['name'] as string,\n   228→    category: row['category'] as string,\n   229→    description: row['description'] as string,\n   230→    scriptPath: row['script_path'] as string,\n   231→    inputSchema: (row['input_schema'] as string) ?? null,\n   232→    outputSchema: (row['output_schema'] as string) ?? null,\n   233→    requiresCredentialType: (row['requires_credential_type'] as string) ?? null,\n   234→    implementationGuide: (row['implementation_guide'] as string) ?? null,\n   235→    isBuiltin: row['is_builtin'] === 1,\n   236→    createdAt: row['created_at'] as string,\n   237→    updatedAt: row['updated_at'] as string,\n   238→  };\n   239→}\n   240→\n   241→function rowToCredential(row: Record<string, unknown>): PersonaCredential {\n   242→  return {\n   243→    id: row['id'] as string,\n   244→    projectId: (row['project_id'] as string) ?? 'default',\n   245→    name: row['name'] as string,\n   246→    serviceType: row['service_type'] as string,\n   247→    encryptedData: row['encrypted_data'] as string,\n   248→    iv: row['iv'] as string,\n   249→    tag: row['tag'] as string,\n   250→    metadata: (row['metadata'] as string) ?? null,\n   251→    lastUsedAt: (row['last_used_at'] as string) ?? null,\n   252→    createdAt: row['created_at'] as string,\n   253→    updatedAt: row['updated_at'] as string,\n   254→  };\n   255→}\n   256→\n   257→function rowToEvent(row: Record<string, unknown>): PersonaEvent {\n   258→  return {\n   259→    id: row['id'] as string,\n   260→    projectId: row['project_id'] as string,\n   261→    eventType: row['event_type'] as string,\n   262→    sourceType: row['source_type'] as string,\n   263→    sourceId: (row['source_id'] as string) ?? null,\n   264→    targetPersonaId: (row['target_persona_id'] as string) ?? null,\n   265→    payload: (row['payload'] as string) ?? null,\n   266→    status: row['status'] as string,\n   267→    errorMessage: (row['error_message'] as string) ?? null,\n   268→    processedAt: (row['processed_at'] as string) ?? null,\n   269→    useCaseId: (row['use_case_id'] as string) ?? null,\n   270→    createdAt: row['created_at'] as string,\n   271→  };\n   272→}\n   273→\n   274→function rowToSubscription(row: Record<string, unknown>): PersonaEventSubscription {\n   275→  return {\n   276→    id: row['id'] as string,\n   277→    personaId: row['persona_id'] as string,\n   278→    eventType: row['event_type'] as string,\n   279→    sourceFilter: (row['source_filter'] as string) ?? null,\n   280→    enabled: row['enabled'] === 1,\n   281→    useCaseId: (row['use_case_id'] as string) ?? null,\n   282→    createdAt: row['created_at'] as string,\n   283→    updatedAt: row['updated_at'] as string,\n   284→  };\n   285→}\n   286→\n   287→function rowToTrigger(row: Record<string, unknown>): PersonaTrigger {\n   288→  return {\n   289→    id: row['id'] as string,\n   290→    personaId: row['persona_id'] as string,\n   291→    triggerType: row['trigger_type'] as string,\n   292→    config: (row['config'] as string) ?? null,\n   293→    enabled: row['enabled'] === 1,\n   294→    lastTriggeredAt: (row['last_triggered_at'] as string) ?? null,\n   295→    nextTriggerAt: (row['next_trigger_at'] as string) ?? null,\n   296→    useCaseId: (row['use_case_id'] as string) ?? null,\n   297→    createdAt: row['created_at'] as string,\n   298→    updatedAt: row['updated_at'] as string,\n   299→  };\n   300→}\n   301→\n   302→function rowToExecution(row: Record<string, unknown>): PersonaExecution {\n   303→  return {\n   304→    id: row['id'] as string,\n   305→    projectId: (row['project_id'] as string) ?? 'default',\n   306→    personaId: row['persona_id'] as string,\n   307→    triggerId: (row['trigger_id'] as string) ?? null,\n   308→    useCaseId: (row['use_case_id'] as string) ?? null,\n   309→    status: row['status'] as string,\n   310→    inputData: (row['input_data'] as string) ?? null,\n   311→    outputData: (row['output_data'] as string) ?? null,\n   312→    claudeSessionId: (row['claude_session_id'] as string) ?? null,\n   313→    modelUsed: (row['model_used'] as string) ?? null,\n   314→    inputTokens: (row['input_tokens'] as number) ?? 0,\n   315→    outputTokens: (row['output_tokens'] as number) ?? 0,\n   316→    costUsd: (row['cost_usd'] as number) ?? 0,\n   317→    errorMessage: (row['error_message'] as string) ?? null,\n   318→    durationMs: (row['duration_ms'] as number) ?? null,\n   319→    retryOfExecutionId: (row['retry_of_execution_id'] as string) ?? null,\n   320→    retryCount: (row['retry_count'] as number) ?? 0,\n   321→    startedAt: (row['started_at'] as string) ?? null,\n   322→    completedAt: (row['completed_at'] as string) ?? null,\n   323→    createdAt: row['created_at'] as string,\n   324→  };\n   325→}\n   326→\n   327→// ---------------------------------------------------------------------------\n   328→// Persona CRUD\n   329→// ---------------------------------------------------------------------------\n   330→\n   331→export function getPersona(db: Database.Database, id: string): Persona | undefined {\n   332→  const row = db.prepare('SELECT * FROM personas WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n   333→  return row ? rowToPersona(row) : undefined;\n   334→}\n   335→\n   336→export function listPersonas(db: Database.Database, projectId?: string): Persona[] {\n   337→  if (projectId) {\n   338→    const rows = db.prepare('SELECT * FROM personas WHERE project_id = ? ORDER BY name').all(projectId) as Record<string, unknown>[];\n   339→    return rows.map(rowToPersona);\n   340→  }\n   341→  const rows = db.prepare('SELECT * FROM personas ORDER BY name').all() as Record<string, unknown>[];\n   342→  return rows.map(rowToPersona);\n   343→}\n   344→\n   345→export function upsertPersona(db: Database.Database, p: Persona): void {\n   346→  db.prepare(`\n   347→    INSERT INTO personas (id, project_id, name, description, system_prompt, structured_prompt, icon, color, enabled, max_concurrent, timeout_ms, model_profile, max_budget_usd, max_turns, design_context, group_id, created_at, updated_at)\n   348→    VALUES (@id, @projectId, @name, @description, @systemPrompt, @structuredPrompt, @icon, @color, @enabled, @maxConcurrent, @timeoutMs, @modelProfile, @maxBudgetUsd, @maxTurns, @designContext, @groupId, @createdAt, @updatedAt)\n   349→    ON CONFLICT(id) DO UPDATE SET\n   350→      name = excluded.name, description = excluded.description, system_prompt = excluded.system_prompt,\n   351→      structured_prompt = excluded.structured_prompt, icon = excluded.icon, color = excluded.color,\n   352→      enabled = excluded.enabled, max_concurrent = excluded.max_concurrent, timeout_ms = excluded.timeout_ms,\n   353→      model_profile = excluded.model_profile, max_budget_usd = excluded.max_budget_usd, max_turns = excluded.max_turns,\n   354→      design_context = excluded.design_context, group_id = excluded.group_id, updated_at = excluded.updated_at\n   355→  `).run({\n   356→    id: p.id,\n   357→    projectId: p.projectId,\n   358→    name: p.name,\n   359→    description: p.description,\n   360→    systemPrompt: p.systemPrompt,\n   361→    structuredPrompt: p.structuredPrompt,\n   362→    icon: p.icon,\n   363→    color: p.color,\n   364→    enabled: p.enabled ? 1 : 0,\n   365→    maxConcurrent: p.maxConcurrent,\n   366→    timeoutMs: p.timeoutMs,\n   367→    modelProfile: p.modelProfile,\n   368→    maxBudgetUsd: p.maxBudgetUsd,\n   369→    maxTurns: p.maxTurns,\n   370→    designContext: p.designContext,\n   371→    groupId: p.groupId,\n   372→    createdAt: p.createdAt,\n   373→    updatedAt: p.updatedAt,\n   374→  });\n   375→}\n   376→\n   377→export function deletePersona(db: Database.Database, id: string, projectId?: string): void {\n   378→  if (projectId) {\n   379→    db.prepare('DELETE FROM personas WHERE id = ? AND project_id = ?').run(id, projectId);\n   380→  } else {\n   381→    db.prepare('DELETE FROM personas WHERE id = ?').run(id);\n   382→  }\n   383→}\n   384→\n   385→// ---------------------------------------------------------------------------\n   386→// Tool Definitions\n   387→// ---------------------------------------------------------------------------\n   388→\n   389→export function getToolsForPersona(db: Database.Database, personaId: string): PersonaToolDefinition[] {\n   390→  const rows = db.prepare(`\n   391→    SELECT t.* FROM persona_tool_definitions t\n   392→    JOIN persona_tools pt ON pt.tool_id = t.id\n   393→    WHERE pt.persona_id = ?\n   394→  `).all(personaId) as Record<string, unknown>[];\n   395→  return rows.map(rowToTool);\n   396→}\n   397→\n   398→export function upsertToolDefinition(db: Database.Database, t: PersonaToolDefinition): void {\n   399→  db.prepare(`\n   400→    INSERT INTO persona_tool_definitions (id, name, category, description, script_path, input_schema, output_schema, requires_credential_type, implementation_guide, is_builtin, created_at, updated_at)\n   401→    VALUES (@id, @name, @category, @description, @scriptPath, @inputSchema, @outputSchema, @requiresCredentialType, @implementationGuide, @isBuiltin, @createdAt, @updatedAt)\n   402→    ON CONFLICT(id) DO UPDATE SET\n   403→      name = excluded.name, category = excluded.category, description = excluded.description,\n   404→      script_path = excluded.script_path, input_schema = excluded.input_schema, output_schema = excluded.output_schema,\n   405→      requires_credential_type = excluded.requires_credential_type, implementation_guide = excluded.implementation_guide,\n   406→      is_builtin = excluded.is_builtin, updated_at = excluded.updated_at\n   407→  `).run({\n   408→    id: t.id,\n   409→    name: t.name,\n   410→    category: t.category,\n   411→    description: t.description,\n   412→    scriptPath: t.scriptPath,\n   413→    inputSchema: t.inputSchema,\n   414→    outputSchema: t.outputSchema,\n   415→    requiresCredentialType: t.requiresCredentialType,\n   416→    implementationGuide: t.implementationGuide,\n   417→    isBuiltin: t.isBuiltin ? 1 : 0,\n   418→    createdAt: t.createdAt,\n   419→    updatedAt: t.updatedAt,\n   420→  });\n   421→}\n   422→\n   423→export function linkTool(db: Database.Database, personaId: string, toolId: string): void {\n   424→  db.prepare('INSERT OR IGNORE INTO persona_tools (persona_id, tool_id) VALUES (?, ?)').run(personaId, toolId);\n   425→}\n   426→\n   427→export function unlinkTool(db: Database.Database, personaId: string, toolId: string): void {\n   428→  db.prepare('DELETE FROM persona_tools WHERE persona_id = ? AND tool_id = ?').run(personaId, toolId);\n   429→}\n   430→\n   431→// ---------------------------------------------------------------------------\n   432→// Credentials\n   433→// ---------------------------------------------------------------------------\n   434→\n   435→export function createCredential(db: Database.Database, input: {\n   436→  name: string; serviceType: string; encryptedData: string; iv: string; tag: string; metadata?: string | null; projectId?: string;\n   437→}): PersonaCredential {\n   438→  const now = new Date().toISOString();\n   439→  const id = nanoid();\n   440→  db.prepare(`\n   441→    INSERT INTO persona_credentials (id, project_id, name, service_type, encrypted_data, iv, tag, metadata, created_at, updated_at)\n   442→    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n   443→  `).run(id, input.projectId ?? 'default', input.name, input.serviceType, input.encryptedData, input.iv, input.tag, input.metadata ?? null, now, now);\n   444→  return getCredential(db, id)!;\n   445→}\n   446→\n   447→export function getCredential(db: Database.Database, id: string): PersonaCredential | undefined {\n   448→  const row = db.prepare('SELECT * FROM persona_credentials WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n   449→  return row ? rowToCredential(row) : undefined;\n   450→}\n   451→\n   452→export function listCredentialsForPersona(db: Database.Database, personaId: string): PersonaCredential[] {\n   453→  const rows = db.prepare(`\n   454→    SELECT c.* FROM persona_credentials c\n   455→    JOIN persona_credential_links cl ON cl.credential_id = c.id\n   456→    WHERE cl.persona_id = ?\n   457→  `).all(personaId) as Record<string, unknown>[];\n   458→  return rows.map(rowToCredential);\n   459→}\n   460→\n   461→export function linkCredential(db: Database.Database, personaId: string, credentialId: string): void {\n   462→  db.prepare('INSERT OR IGNORE INTO persona_credential_links (persona_id, credential_id) VALUES (?, ?)').run(personaId, credentialId);\n   463→}\n   464→\n   465→export function deleteCredential(db: Database.Database, id: string): void {\n   466→  db.prepare('DELETE FROM persona_credentials WHERE id = ?').run(id);\n   467→}\n   468→\n   469→// ---------------------------------------------------------------------------\n   470→// Events\n   471→// ---------------------------------------------------------------------------\n   472→\n   473→export function publishEvent(db: Database.Database, input: {\n   474→  eventType: string; sourceType: string; sourceId?: string | null; targetPersonaId?: string | null;\n   475→  projectId?: string; payload?: string | null; useCaseId?: string | null;\n   476→}): PersonaEvent {\n   477→  const now = new Date().toISOString();\n   478→  const id = nanoid();\n   479→  db.prepare(`\n   480→    INSERT INTO persona_events (id, project_id, event_type, source_type, source_id, target_persona_id, payload, use_case_id, status, created_at)\n   481→    VALUES (?, ?, ?, ?, ?, ?, ?, ?, 'pending', ?)\n   482→  `).run(id, input.projectId ?? 'default', input.eventType, input.sourceType, input.sourceId ?? null, input.targetPersonaId ?? null, input.payload ?? null, input.useCaseId ?? null, now);\n   483→  return getEvent(db, id)!;\n   484→}\n   485→\n   486→export function getEvent(db: Database.Database, id: string): PersonaEvent | undefined {\n   487→  const row = db.prepare('SELECT * FROM persona_events WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n   488→  return row ? rowToEvent(row) : undefined;\n   489→}\n   490→\n   491→export function getPendingEvents(db: Database.Database, limit: number = 50): PersonaEvent[] {\n   492→  const rows = db.prepare(\"SELECT * FROM persona_events WHERE status = 'pending' ORDER BY created_at LIMIT ?\").all(limit) as Record<string, unknown>[];\n   493→  return rows.map(rowToEvent);\n   494→}\n   495→\n   496→export function listEvents(db: Database.Database, opts?: {\n   497→  eventType?: string; status?: string; projectId?: string; limit?: number; offset?: number;\n   498→}): PersonaEvent[] {\n   499→  const clauses: string[] = [];\n   500→  const params: unknown[] = [];\n   501→  if (opts?.eventType) { clauses.push('event_type = ?'); params.push(opts.eventType); }\n   502→  if (opts?.status) { clauses.push('status = ?'); params.push(opts.status); }\n   503→  if (opts?.projectId) { clauses.push('project_id = ?'); params.push(opts.projectId); }\n   504→  const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   505→  const limit = opts?.limit ?? 50;\n   506→  const offset = opts?.offset ?? 0;\n   507→  const rows = db.prepare(`SELECT * FROM persona_events ${where} ORDER BY created_at DESC LIMIT ? OFFSET ?`).all(...params, limit, offset) as Record<string, unknown>[];\n   508→  return rows.map(rowToEvent);\n   509→}\n   510→\n   511→export function updateEventStatus(db: Database.Database, id: string, status: string, errorMessage?: string | null): void {\n   512→  const now = new Date().toISOString();\n   513→  db.prepare('UPDATE persona_events SET status = ?, error_message = ?, processed_at = ? WHERE id = ?').run(status, errorMessage ?? null, now, id);\n   514→}\n   515→\n   516→export function updateEventWithMetadata(db: Database.Database, id: string, status: string, metadata?: string | null): PersonaEvent | undefined {\n   517→  const now = new Date().toISOString();\n   518→  db.prepare('UPDATE persona_events SET status = ?, processed_at = ?, payload = CASE WHEN ? IS NOT NULL THEN ? ELSE payload END WHERE id = ?')\n   519→    .run(status, now, metadata, metadata, id);\n   520→  return getEvent(db, id);\n   521→}\n   522→\n   523→// ---------------------------------------------------------------------------\n   524→// Event Subscriptions\n   525→// ---------------------------------------------------------------------------\n   526→\n   527→export function createSubscription(db: Database.Database, input: {\n   528→  personaId: string; eventType: string; sourceFilter?: string | null; enabled?: boolean; useCaseId?: string | null; projectId?: string;\n   529→}): PersonaEventSubscription {\n   530→  const now = new Date().toISOString();\n   531→  const id = nanoid();\n   532→  db.prepare(`\n   533→    INSERT INTO persona_event_subscriptions (id, project_id, persona_id, event_type, source_filter, enabled, use_case_id, created_at, updated_at)\n   534→    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n   535→  `).run(id, input.projectId ?? 'default', input.personaId, input.eventType, input.sourceFilter ?? null, input.enabled !== false ? 1 : 0, input.useCaseId ?? null, now, now);\n   536→  return getSubscription(db, id)!;\n   537→}\n   538→\n   539→export function getSubscription(db: Database.Database, id: string): PersonaEventSubscription | undefined {\n   540→  const row = db.prepare('SELECT * FROM persona_event_subscriptions WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n   541→  return row ? rowToSubscription(row) : undefined;\n   542→}\n   543→\n   544→export function listSubscriptionsForPersona(db: Database.Database, personaId: string): PersonaEventSubscription[] {\n   545→  const rows = db.prepare('SELECT * FROM persona_event_subscriptions WHERE persona_id = ?').all(personaId) as Record<string, unknown>[];\n   546→  return rows.map(rowToSubscription);\n   547→}\n   548→\n   549→export function getSubscriptionsByEventType(db: Database.Database, eventType: string, projectId?: string): PersonaEventSubscription[] {\n   550→  if (projectId) {\n   551→    const rows = db.prepare('SELECT * FROM persona_event_subscriptions WHERE event_type = ? AND project_id = ?').all(eventType, projectId) as Record<string, unknown>[];\n   552→    return rows.map(rowToSubscription);\n   553→  }\n   554→  const rows = db.prepare('SELECT * FROM persona_event_subscriptions WHERE event_type = ?').all(eventType) as Record<string, unknown>[];\n   555→  return rows.map(rowToSubscription);\n   556→}\n   557→\n   558→export function updateSubscription(db: Database.Database, id: string, updates: {\n   559→  eventType?: string | null; sourceFilter?: string | null; enabled?: boolean | null;\n   560→}): void {\n   561→  const now = new Date().toISOString();\n   562→  const sub = getSubscription(db, id);\n   563→  if (!sub) return;\n   564→  db.prepare(`\n   565→    UPDATE persona_event_subscriptions SET event_type = ?, source_filter = ?, enabled = ?, updated_at = ? WHERE id = ?\n   566→  `).run(\n   567→    updates.eventType ?? sub.eventType,\n   568→    updates.sourceFilter !== undefined ? updates.sourceFilter : sub.sourceFilter,\n   569→    updates.enabled !== undefined && updates.enabled !== null ? (updates.enabled ? 1 : 0) : (sub.enabled ? 1 : 0),\n   570→    now,\n   571→    id,\n   572→  );\n   573→}\n   574→\n   575→export function deleteSubscription(db: Database.Database, id: string): void {\n   576→  db.prepare('DELETE FROM persona_event_subscriptions WHERE id = ?').run(id);\n   577→}\n   578→\n   579→// ---------------------------------------------------------------------------\n   580→// Triggers\n   581→// ---------------------------------------------------------------------------\n   582→\n   583→export function createTrigger(db: Database.Database, input: {\n   584→  personaId: string; triggerType: string; config?: string | null; enabled?: boolean; useCaseId?: string | null; projectId?: string;\n   585→}): PersonaTrigger {\n   586→  const now = new Date().toISOString();\n   587→  const id = nanoid();\n   588→  db.prepare(`\n   589→    INSERT INTO persona_triggers (id, project_id, persona_id, trigger_type, config, enabled, use_case_id, created_at, updated_at)\n   590→    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n   591→  `).run(id, input.projectId ?? 'default', input.personaId, input.triggerType, input.config ?? null, input.enabled !== false ? 1 : 0, input.useCaseId ?? null, now, now);\n   592→  return getTrigger(db, id)!;\n   593→}\n   594→\n   595→export function getTrigger(db: Database.Database, id: string): PersonaTrigger | undefined {\n   596→  const row = db.prepare('SELECT * FROM persona_triggers WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n   597→  return row ? rowToTrigger(row) : undefined;\n   598→}\n   599→\n   600→export function listTriggersForPersona(db: Database.Database, personaId: string): PersonaTrigger[] {\n   601→  const rows = db.prepare('SELECT * FROM persona_triggers WHERE persona_id = ?').all(personaId) as Record<string, unknown>[];\n   602→  return rows.map(rowToTrigger);\n   603→}\n   604→\n   605→export function getDueTriggers(db: Database.Database): PersonaTrigger[] {\n   606→  const rows = db.prepare(\"SELECT * FROM persona_triggers WHERE enabled = 1 AND next_trigger_at <= datetime('now')\").all() as Record<string, unknown>[];\n   607→  return rows.map(rowToTrigger);\n   608→}\n   609→\n   610→export function updateTriggerTimings(db: Database.Database, id: string, lastTriggeredAt: string, nextTriggerAt: string | null): void {\n   611→  db.prepare('UPDATE persona_triggers SET last_triggered_at = ?, next_trigger_at = ?, updated_at = ? WHERE id = ?')\n   612→    .run(lastTriggeredAt, nextTriggerAt, new Date().toISOString(), id);\n   613→}\n   614→\n   615→export function updateTrigger(db: Database.Database, id: string, updates: {\n   616→  triggerType?: string | null; config?: string | null; enabled?: boolean | null;\n   617→}): void {\n   618→  const now = new Date().toISOString();\n   619→  const trigger = getTrigger(db, id);\n   620→  if (!trigger) return;\n   621→  db.prepare(`\n   622→    UPDATE persona_triggers SET trigger_type = ?, config = ?, enabled = ?, updated_at = ? WHERE id = ?\n   623→  `).run(\n   624→    updates.triggerType ?? trigger.triggerType,\n   625→    updates.config !== undefined ? updates.config : trigger.config,\n   626→    updates.enabled !== undefined && updates.enabled !== null ? (updates.enabled ? 1 : 0) : (trigger.enabled ? 1 : 0),\n   627→    now,\n   628→    id,\n   629→  );\n   630→}\n   631→\n   632→export function deleteTrigger(db: Database.Database, id: string): void {\n   633→  db.prepare('DELETE FROM persona_triggers WHERE id = ?').run(id);\n   634→}\n   635→\n   636→// ---------------------------------------------------------------------------\n   637→// Executions\n   638→// ---------------------------------------------------------------------------\n   639→\n   640→export function createExecution(db: Database.Database, input: {\n   641→  id?: string; personaId: string; triggerId?: string | null; useCaseId?: string | null; inputData?: string | null; projectId?: string;\n   642→}): PersonaExecution {\n   643→  const now = new Date().toISOString();\n   644→  const id = input.id ?? nanoid();\n   645→  db.prepare(`\n   646→    INSERT INTO persona_executions (id, project_id, persona_id, trigger_id, use_case_id, status, input_data, created_at)\n   647→    VALUES (?, ?, ?, ?, ?, 'queued', ?, ?)\n   648→  `).run(id, input.projectId ?? 'default', input.personaId, input.triggerId ?? null, input.useCaseId ?? null, input.inputData ?? null, now);\n   649→  return getExecution(db, id)!;\n   650→}\n   651→\n   652→export function getExecution(db: Database.Database, id: string): PersonaExecution | undefined {\n   653→  const row = db.prepare('SELECT * FROM persona_executions WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n   654→  return row ? rowToExecution(row) : undefined;\n   655→}\n   656→\n   657→export function listExecutions(db: Database.Database, opts?: {\n   658→  personaId?: string; status?: string; limit?: number; offset?: number; projectId?: string;\n   659→}): PersonaExecution[] {\n   660→  let sql = 'SELECT * FROM persona_executions WHERE 1=1';\n   661→  const params: unknown[] = [];\n   662→\n   663→  if (opts?.projectId) {\n   664→    sql += ' AND project_id = ?';\n   665→    params.push(opts.projectId);\n   666→  }\n   667→  if (opts?.personaId) {\n   668→    sql += ' AND persona_id = ?';\n   669→    params.push(opts.personaId);\n   670→  }\n   671→  if (opts?.status) {\n   672→    sql += ' AND status = ?';\n   673→    params.push(opts.status);\n   674→  }\n   675→  sql += ' ORDER BY created_at DESC';\n   676→  if (opts?.limit) {\n   677→    sql += ' LIMIT ?';\n   678→    params.push(opts.limit);\n   679→  }\n   680→  if (opts?.offset) {\n   681→    sql += ' OFFSET ?';\n   682→    params.push(opts.offset);\n   683→  }\n   684→\n   685→  const rows = db.prepare(sql).all(...params) as Record<string, unknown>[];\n   686→  return rows.map(rowToExecution);\n   687→}\n   688→\n   689→export function updateExecution(db: Database.Database, id: string, updates: Record<string, unknown>): void {\n   690→  const fields: string[] = [];\n   691→  const values: unknown[] = [];\n   692→\n   693→  const columnMap: Record<string, string> = {\n   694→    status: 'status',\n   695→    outputData: 'output_data',\n   696→    claudeSessionId: 'claude_session_id',\n   697→    modelUsed: 'model_used',\n   698→    inputTokens: 'input_tokens',\n   699→    outputTokens: 'output_tokens',\n   700→    costUsd: 'cost_usd',\n   701→    errorMessage: 'error_message',\n   702→    durationMs: 'duration_ms',\n   703→    startedAt: 'started_at',\n   704→    completedAt: 'completed_at',\n   705→  };\n   706→\n   707→  for (const [key, col] of Object.entries(columnMap)) {\n   708→    if (key in updates) {\n   709→      fields.push(`${col} = ?`);\n   710→      values.push(updates[key]);\n   711→    }\n   712→  }\n   713→\n   714→  if (fields.length === 0) return;\n   715→  values.push(id);\n   716→  db.prepare(`UPDATE persona_executions SET ${fields.join(', ')} WHERE id = ?`).run(...values);\n   717→}\n   718→\n   719→export function appendOutput(db: Database.Database, id: string, chunk: string): void {\n   720→  db.prepare(`\n   721→    UPDATE persona_executions SET output_data = COALESCE(output_data, '') || ? WHERE id = ?\n   722→  `).run(chunk, id);\n   723→}\n   724→\n   725→export function countRunningExecutions(db: Database.Database, personaId: string): number {\n   726→  const row = db.prepare(\"SELECT COUNT(*) as cnt FROM persona_executions WHERE persona_id = ? AND status = 'running'\").get(personaId) as { cnt: number };\n   727→  return row.cnt;\n   728→}\n   729→\n   730→// ---------------------------------------------------------------------------\n   731→// Admin queries\n   732→// ---------------------------------------------------------------------------\n   733→\n   734→export function listDistinctProjectIds(db: Database.Database): string[] {\n   735→  const rows = db.prepare('SELECT DISTINCT project_id FROM personas ORDER BY project_id').all() as Array<{ project_id: string }>;\n   736→  return rows.map(r => r.project_id);\n   737→}\n   738→"}]},"parent_tool_use_id":null,"session_id":"7dcbcdb6-4ec4-4587-8878-e43fcc71925a","uuid":"947cf7c3-3769-44f5-a250-92f8bec55081","timestamp":"2026-03-19T08:32:44.330Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\.claude\\worktrees\\reactive-gathering-parrot\\packages\\orchestrator\\src\\db.ts","content":"import Database from 'better-sqlite3';\nimport { nanoid } from 'nanoid';\nimport type { Logger } from 'pino';\nimport type {\n  Persona,\n  PersonaToolDefinition,\n  PersonaCredential,\n  PersonaEvent,\n  PersonaEventSubscription,\n  PersonaTrigger,\n  PersonaExecution,\n} from '@dac-cloud/shared';\n\n// ---------------------------------------------------------------------------\n// Initialization\n// ---------------------------------------------------------------------------\n\nexport function initDb(dbPath: string, logger: Logger): Database.Database {\n  const db = new Database(dbPath);\n  db.pragma('journal_mode = WAL');\n  db.pragma('foreign_keys = ON');\n\n  db.exec(SCHEMA);\n  runMigrations(db, logger);\n  logger.info({ dbPath }, 'Database initialized');\n  return db;\n}\n\n// ---------------------------------------------------------------------------\n// Migrations\n// ---------------------------------------------------------------------------\n\nfunction runMigrations(db: Database.Database, logger: Logger): void {\n  // Migration: add project_id column to tables that need per-user isolation\n  const tablesToMigrate = [\n    'persona_credentials',\n    'persona_event_subscriptions',\n    'persona_triggers',\n    'persona_executions',\n  ];\n\n  for (const table of tablesToMigrate) {\n    const columns = db.prepare(`PRAGMA table_info(${table})`).all() as Array<{ name: string }>;\n    const hasProjectId = columns.some(c => c.name === 'project_id');\n    if (!hasProjectId) {\n      db.exec(`ALTER TABLE ${table} ADD COLUMN project_id TEXT NOT NULL DEFAULT 'default'`);\n      logger.info({ table }, 'Migration: added project_id column');\n    }\n  }\n\n  // Indexes for project_id\n  db.exec(`\n    CREATE INDEX IF NOT EXISTS idx_personas_project ON personas(project_id);\n    CREATE INDEX IF NOT EXISTS idx_pe_project ON persona_events(project_id);\n    CREATE INDEX IF NOT EXISTS idx_pcred_project ON persona_credentials(project_id);\n    CREATE INDEX IF NOT EXISTS idx_pes_project ON persona_event_subscriptions(project_id);\n    CREATE INDEX IF NOT EXISTS idx_pt_project ON persona_triggers(project_id);\n    CREATE INDEX IF NOT EXISTS idx_pex_project ON persona_executions(project_id);\n  `);\n}\n\n// ---------------------------------------------------------------------------\n// Schema\n// ---------------------------------------------------------------------------\n\nconst SCHEMA = `\nCREATE TABLE IF NOT EXISTS personas (\n  id TEXT PRIMARY KEY,\n  project_id TEXT NOT NULL DEFAULT 'default',\n  name TEXT NOT NULL,\n  description TEXT,\n  system_prompt TEXT NOT NULL DEFAULT '',\n  structured_prompt TEXT,\n  icon TEXT,\n  color TEXT,\n  enabled INTEGER NOT NULL DEFAULT 1,\n  max_concurrent INTEGER NOT NULL DEFAULT 1,\n  timeout_ms INTEGER NOT NULL DEFAULT 300000,\n  model_profile TEXT,\n  max_budget_usd REAL,\n  max_turns INTEGER,\n  design_context TEXT,\n  group_id TEXT,\n  created_at TEXT NOT NULL,\n  updated_at TEXT NOT NULL\n);\n\nCREATE TABLE IF NOT EXISTS persona_tool_definitions (\n  id TEXT PRIMARY KEY,\n  name TEXT NOT NULL UNIQUE,\n  category TEXT NOT NULL,\n  description TEXT NOT NULL,\n  script_path TEXT NOT NULL DEFAULT '',\n  input_schema TEXT,\n  output_schema TEXT,\n  requires_credential_type TEXT,\n  implementation_guide TEXT,\n  is_builtin INTEGER NOT NULL DEFAULT 0,\n  created_at TEXT NOT NULL,\n  updated_at TEXT NOT NULL\n);\n\nCREATE TABLE IF NOT EXISTS persona_tools (\n  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n  tool_id TEXT NOT NULL REFERENCES persona_tool_definitions(id) ON DELETE CASCADE,\n  PRIMARY KEY (persona_id, tool_id)\n);\n\nCREATE TABLE IF NOT EXISTS persona_credentials (\n  id TEXT PRIMARY KEY,\n  project_id TEXT NOT NULL DEFAULT 'default',\n  name TEXT NOT NULL,\n  service_type TEXT NOT NULL,\n  encrypted_data TEXT NOT NULL,\n  iv TEXT NOT NULL,\n  tag TEXT NOT NULL,\n  metadata TEXT,\n  last_used_at TEXT,\n  created_at TEXT NOT NULL,\n  updated_at TEXT NOT NULL\n);\n\nCREATE TABLE IF NOT EXISTS persona_credential_links (\n  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n  credential_id TEXT NOT NULL REFERENCES persona_credentials(id) ON DELETE CASCADE,\n  PRIMARY KEY (persona_id, credential_id)\n);\n\nCREATE TABLE IF NOT EXISTS persona_events (\n  id TEXT PRIMARY KEY,\n  project_id TEXT NOT NULL DEFAULT 'default',\n  event_type TEXT NOT NULL,\n  source_type TEXT NOT NULL,\n  source_id TEXT,\n  target_persona_id TEXT,\n  payload TEXT,\n  status TEXT NOT NULL DEFAULT 'pending',\n  error_message TEXT,\n  processed_at TEXT,\n  use_case_id TEXT,\n  created_at TEXT NOT NULL\n);\nCREATE INDEX IF NOT EXISTS idx_pe_status ON persona_events(status);\n\nCREATE TABLE IF NOT EXISTS persona_event_subscriptions (\n  id TEXT PRIMARY KEY,\n  project_id TEXT NOT NULL DEFAULT 'default',\n  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n  event_type TEXT NOT NULL,\n  source_filter TEXT,\n  enabled INTEGER NOT NULL DEFAULT 1,\n  use_case_id TEXT,\n  created_at TEXT NOT NULL,\n  updated_at TEXT NOT NULL\n);\n\nCREATE TABLE IF NOT EXISTS persona_triggers (\n  id TEXT PRIMARY KEY,\n  project_id TEXT NOT NULL DEFAULT 'default',\n  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n  trigger_type TEXT NOT NULL CHECK(trigger_type IN ('manual','schedule','polling','webhook','chain')),\n  config TEXT,\n  enabled INTEGER NOT NULL DEFAULT 1,\n  last_triggered_at TEXT,\n  next_trigger_at TEXT,\n  use_case_id TEXT,\n  created_at TEXT NOT NULL,\n  updated_at TEXT NOT NULL\n);\n\nCREATE TABLE IF NOT EXISTS persona_executions (\n  id TEXT PRIMARY KEY,\n  project_id TEXT NOT NULL DEFAULT 'default',\n  persona_id TEXT NOT NULL,\n  trigger_id TEXT,\n  use_case_id TEXT,\n  status TEXT NOT NULL DEFAULT 'queued' CHECK(status IN ('queued','running','completed','failed','cancelled')),\n  input_data TEXT,\n  output_data TEXT,\n  claude_session_id TEXT,\n  model_used TEXT,\n  input_tokens INTEGER DEFAULT 0,\n  output_tokens INTEGER DEFAULT 0,\n  cost_usd REAL DEFAULT 0,\n  error_message TEXT,\n  duration_ms INTEGER,\n  retry_of_execution_id TEXT,\n  retry_count INTEGER DEFAULT 0,\n  started_at TEXT,\n  completed_at TEXT,\n  created_at TEXT NOT NULL\n);\nCREATE INDEX IF NOT EXISTS idx_pex_persona ON persona_executions(persona_id);\nCREATE INDEX IF NOT EXISTS idx_pex_status ON persona_executions(status);\n`;\n\n// ---------------------------------------------------------------------------\n// Row → domain type mappers\n// ---------------------------------------------------------------------------\n\nfunction rowToPersona(row: Record<string, unknown>): Persona {\n  return {\n    id: row['id'] as string,\n    projectId: row['project_id'] as string,\n    name: row['name'] as string,\n    description: (row['description'] as string) ?? null,\n    systemPrompt: row['system_prompt'] as string,\n    structuredPrompt: (row['structured_prompt'] as string) ?? null,\n    icon: (row['icon'] as string) ?? null,\n    color: (row['color'] as string) ?? null,\n    enabled: row['enabled'] === 1,\n    maxConcurrent: row['max_concurrent'] as number,\n    timeoutMs: row['timeout_ms'] as number,\n    modelProfile: (row['model_profile'] as string) ?? null,\n    maxBudgetUsd: (row['max_budget_usd'] as number) ?? null,\n    maxTurns: (row['max_turns'] as number) ?? null,\n    designContext: (row['design_context'] as string) ?? null,\n    groupId: (row['group_id'] as string) ?? null,\n    createdAt: row['created_at'] as string,\n    updatedAt: row['updated_at'] as string,\n  };\n}\n\nfunction rowToTool(row: Record<string, unknown>): PersonaToolDefinition {\n  return {\n    id: row['id'] as string,\n    name: row['name'] as string,\n    category: row['category'] as string,\n    description: row['description'] as string,\n    scriptPath: row['script_path'] as string,\n    inputSchema: (row['input_schema'] as string) ?? null,\n    outputSchema: (row['output_schema'] as string) ?? null,\n    requiresCredentialType: (row['requires_credential_type'] as string) ?? null,\n    implementationGuide: (row['implementation_guide'] as string) ?? null,\n    isBuiltin: row['is_builtin'] === 1,\n    createdAt: row['created_at'] as string,\n    updatedAt: row['updated_at'] as string,\n  };\n}\n\nfunction rowToCredential(row: Record<string, unknown>): PersonaCredential {\n  return {\n    id: row['id'] as string,\n    projectId: (row['project_id'] as string) ?? 'default',\n    name: row['name'] as string,\n    serviceType: row['service_type'] as string,\n    encryptedData: row['encrypted_data'] as string,\n    iv: row['iv'] as string,\n    tag: row['tag'] as string,\n    metadata: (row['metadata'] as string) ?? null,\n    lastUsedAt: (row['last_used_at'] as string) ?? null,\n    createdAt: row['created_at'] as string,\n    updatedAt: row['updated_at'] as string,\n  };\n}\n\nfunction rowToEvent(row: Record<string, unknown>): PersonaEvent {\n  return {\n    id: row['id'] as string,\n    projectId: row['project_id'] as string,\n    eventType: row['event_type'] as string,\n    sourceType: row['source_type'] as string,\n    sourceId: (row['source_id'] as string) ?? null,\n    targetPersonaId: (row['target_persona_id'] as string) ?? null,\n    payload: (row['payload'] as string) ?? null,\n    status: row['status'] as string,\n    errorMessage: (row['error_message'] as string) ?? null,\n    processedAt: (row['processed_at'] as string) ?? null,\n    useCaseId: (row['use_case_id'] as string) ?? null,\n    createdAt: row['created_at'] as string,\n  };\n}\n\nfunction rowToSubscription(row: Record<string, unknown>): PersonaEventSubscription {\n  return {\n    id: row['id'] as string,\n    personaId: row['persona_id'] as string,\n    eventType: row['event_type'] as string,\n    sourceFilter: (row['source_filter'] as string) ?? null,\n    enabled: row['enabled'] === 1,\n    useCaseId: (row['use_case_id'] as string) ?? null,\n    createdAt: row['created_at'] as string,\n    updatedAt: row['updated_at'] as string,\n  };\n}\n\nfunction rowToTrigger(row: Record<string, unknown>): PersonaTrigger {\n  return {\n    id: row['id'] as string,\n    personaId: row['persona_id'] as string,\n    triggerType: row['trigger_type'] as string,\n    config: (row['config'] as string) ?? null,\n    enabled: row['enabled'] === 1,\n    lastTriggeredAt: (row['last_triggered_at'] as string) ?? null,\n    nextTriggerAt: (row['next_trigger_at'] as string) ?? null,\n    useCaseId: (row['use_case_id'] as string) ?? null,\n    createdAt: row['created_at'] as string,\n    updatedAt: row['updated_at'] as string,\n  };\n}\n\nfunction rowToExecution(row: Record<string, unknown>): PersonaExecution {\n  return {\n    id: row['id'] as string,\n    projectId: (row['project_id'] as string) ?? 'default',\n    personaId: row['persona_id'] as string,\n    triggerId: (row['trigger_id'] as string) ?? null,\n    useCaseId: (row['use_case_id'] as string) ?? null,\n    status: row['status'] as string,\n    inputData: (row['input_data'] as string) ?? null,\n    outputData: (row['output_data'] as string) ?? null,\n    claudeSessionId: (row['claude_session_id'] as string) ?? null,\n    modelUsed: (row['model_used'] as string) ?? null,\n    inputTokens: (row['input_tokens'] as number) ?? 0,\n    outputTokens: (row['output_tokens'] as number) ?? 0,\n    costUsd: (row['cost_usd'] as number) ?? 0,\n    errorMessage: (row['error_message'] as string) ?? null,\n    durationMs: (row['duration_ms'] as number) ?? null,\n    retryOfExecutionId: (row['retry_of_execution_id'] as string) ?? null,\n    retryCount: (row['retry_count'] as number) ?? 0,\n    startedAt: (row['started_at'] as string) ?? null,\n    completedAt: (row['completed_at'] as string) ?? null,\n    createdAt: row['created_at'] as string,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Persona CRUD\n// ---------------------------------------------------------------------------\n\nexport function getPersona(db: Database.Database, id: string): Persona | undefined {\n  const row = db.prepare('SELECT * FROM personas WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n  return row ? rowToPersona(row) : undefined;\n}\n\nexport function listPersonas(db: Database.Database, projectId?: string): Persona[] {\n  if (projectId) {\n    const rows = db.prepare('SELECT * FROM personas WHERE project_id = ? ORDER BY name').all(projectId) as Record<string, unknown>[];\n    return rows.map(rowToPersona);\n  }\n  const rows = db.prepare('SELECT * FROM personas ORDER BY name').all() as Record<string, unknown>[];\n  return rows.map(rowToPersona);\n}\n\nexport function upsertPersona(db: Database.Database, p: Persona): void {\n  db.prepare(`\n    INSERT INTO personas (id, project_id, name, description, system_prompt, structured_prompt, icon, color, enabled, max_concurrent, timeout_ms, model_profile, max_budget_usd, max_turns, design_context, group_id, created_at, updated_at)\n    VALUES (@id, @projectId, @name, @description, @systemPrompt, @structuredPrompt, @icon, @color, @enabled, @maxConcurrent, @timeoutMs, @modelProfile, @maxBudgetUsd, @maxTurns, @designContext, @groupId, @createdAt, @updatedAt)\n    ON CONFLICT(id) DO UPDATE SET\n      name = excluded.name, description = excluded.description, system_prompt = excluded.system_prompt,\n      structured_prompt = excluded.structured_prompt, icon = excluded.icon, color = excluded.color,\n      enabled = excluded.enabled, max_concurrent = excluded.max_concurrent, timeout_ms = excluded.timeout_ms,\n      model_profile = excluded.model_profile, max_budget_usd = excluded.max_budget_usd, max_turns = excluded.max_turns,\n      design_context = excluded.design_context, group_id = excluded.group_id, updated_at = excluded.updated_at\n  `).run({\n    id: p.id,\n    projectId: p.projectId,\n    name: p.name,\n    description: p.description,\n    systemPrompt: p.systemPrompt,\n    structuredPrompt: p.structuredPrompt,\n    icon: p.icon,\n    color: p.color,\n    enabled: p.enabled ? 1 : 0,\n    maxConcurrent: p.maxConcurrent,\n    timeoutMs: p.timeoutMs,\n    modelProfile: p.modelProfile,\n    maxBudgetUsd: p.maxBudgetUsd,\n    maxTurns: p.maxTurns,\n    designContext: p.designContext,\n    groupId: p.groupId,\n    createdAt: p.createdAt,\n    updatedAt: p.updatedAt,\n  });\n}\n\nexport function deletePersona(db: Database.Database, id: string, projectId?: string): void {\n  if (projectId) {\n    db.prepare('DELETE FROM personas WHERE id = ? AND project_id = ?').run(id, projectId);\n  } else {\n    db.prepare('DELETE FROM personas WHERE id = ?').run(id);\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Tool Definitions\n// ---------------------------------------------------------------------------\n\nexport function getToolsForPersona(db: Database.Database, personaId: string): PersonaToolDefinition[] {\n  const rows = db.prepare(`\n    SELECT t.* FROM persona_tool_definitions t\n    JOIN persona_tools pt ON pt.tool_id = t.id\n    WHERE pt.persona_id = ?\n  `).all(personaId) as Record<string, unknown>[];\n  return rows.map(rowToTool);\n}\n\nexport function upsertToolDefinition(db: Database.Database, t: PersonaToolDefinition): void {\n  db.prepare(`\n    INSERT INTO persona_tool_definitions (id, name, category, description, script_path, input_schema, output_schema, requires_credential_type, implementation_guide, is_builtin, created_at, updated_at)\n    VALUES (@id, @name, @category, @description, @scriptPath, @inputSchema, @outputSchema, @requiresCredentialType, @implementationGuide, @isBuiltin, @createdAt, @updatedAt)\n    ON CONFLICT(id) DO UPDATE SET\n      name = excluded.name, category = excluded.category, description = excluded.description,\n      script_path = excluded.script_path, input_schema = excluded.input_schema, output_schema = excluded.output_schema,\n      requires_credential_type = excluded.requires_credential_type, implementation_guide = excluded.implementation_guide,\n      is_builtin = excluded.is_builtin, updated_at = excluded.updated_at\n  `).run({\n    id: t.id,\n    name: t.name,\n    category: t.category,\n    description: t.description,\n    scriptPath: t.scriptPath,\n    inputSchema: t.inputSchema,\n    outputSchema: t.outputSchema,\n    requiresCredentialType: t.requiresCredentialType,\n    implementationGuide: t.implementationGuide,\n    isBuiltin: t.isBuiltin ? 1 : 0,\n    createdAt: t.createdAt,\n    updatedAt: t.updatedAt,\n  });\n}\n\nexport function linkTool(db: Database.Database, personaId: string, toolId: string): void {\n  db.prepare('INSERT OR IGNORE INTO persona_tools (persona_id, tool_id) VALUES (?, ?)').run(personaId, toolId);\n}\n\nexport function unlinkTool(db: Database.Database, personaId: string, toolId: string): void {\n  db.prepare('DELETE FROM persona_tools WHERE persona_id = ? AND tool_id = ?').run(personaId, toolId);\n}\n\n// ---------------------------------------------------------------------------\n// Credentials\n// ---------------------------------------------------------------------------\n\nexport function createCredential(db: Database.Database, input: {\n  name: string; serviceType: string; encryptedData: string; iv: string; tag: string; metadata?: string | null; projectId?: string;\n}): PersonaCredential {\n  const now = new Date().toISOString();\n  const id = nanoid();\n  db.prepare(`\n    INSERT INTO persona_credentials (id, project_id, name, service_type, encrypted_data, iv, tag, metadata, created_at, updated_at)\n    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n  `).run(id, input.projectId ?? 'default', input.name, input.serviceType, input.encryptedData, input.iv, input.tag, input.metadata ?? null, now, now);\n  return getCredential(db, id)!;\n}\n\nexport function getCredential(db: Database.Database, id: string): PersonaCredential | undefined {\n  const row = db.prepare('SELECT * FROM persona_credentials WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n  return row ? rowToCredential(row) : undefined;\n}\n\nexport function listCredentialsForPersona(db: Database.Database, personaId: string): PersonaCredential[] {\n  const rows = db.prepare(`\n    SELECT c.* FROM persona_credentials c\n    JOIN persona_credential_links cl ON cl.credential_id = c.id\n    WHERE cl.persona_id = ?\n  `).all(personaId) as Record<string, unknown>[];\n  return rows.map(rowToCredential);\n}\n\nexport function linkCredential(db: Database.Database, personaId: string, credentialId: string): void {\n  db.prepare('INSERT OR IGNORE INTO persona_credential_links (persona_id, credential_id) VALUES (?, ?)').run(personaId, credentialId);\n}\n\nexport function deleteCredential(db: Database.Database, id: string): void {\n  db.prepare('DELETE FROM persona_credentials WHERE id = ?').run(id);\n}\n\n// ---------------------------------------------------------------------------\n// Events\n// ---------------------------------------------------------------------------\n\nexport function publishEvent(db: Database.Database, input: {\n  eventType: string; sourceType: string; sourceId?: string | null; targetPersonaId?: string | null;\n  projectId?: string; payload?: string | null; useCaseId?: string | null;\n}): PersonaEvent {\n  const now = new Date().toISOString();\n  const id = nanoid();\n  db.prepare(`\n    INSERT INTO persona_events (id, project_id, event_type, source_type, source_id, target_persona_id, payload, use_case_id, status, created_at)\n    VALUES (?, ?, ?, ?, ?, ?, ?, ?, 'pending', ?)\n  `).run(id, input.projectId ?? 'default', input.eventType, input.sourceType, input.sourceId ?? null, input.targetPersonaId ?? null, input.payload ?? null, input.useCaseId ?? null, now);\n  return getEvent(db, id)!;\n}\n\nexport function getEvent(db: Database.Database, id: string): PersonaEvent | undefined {\n  const row = db.prepare('SELECT * FROM persona_events WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n  return row ? rowToEvent(row) : undefined;\n}\n\nexport function getPendingEvents(db: Database.Database, limit: number = 50): PersonaEvent[] {\n  const rows = db.prepare(\"SELECT * FROM persona_events WHERE status = 'pending' ORDER BY created_at LIMIT ?\").all(limit) as Record<string, unknown>[];\n  return rows.map(rowToEvent);\n}\n\nexport function listEvents(db: Database.Database, opts?: {\n  eventType?: string; status?: string; projectId?: string; limit?: number; offset?: number;\n}): PersonaEvent[] {\n  const clauses: string[] = [];\n  const params: unknown[] = [];\n  if (opts?.eventType) { clauses.push('event_type = ?'); params.push(opts.eventType); }\n  if (opts?.status) { clauses.push('status = ?'); params.push(opts.status); }\n  if (opts?.projectId) { clauses.push('project_id = ?'); params.push(opts.projectId); }\n  const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n  const limit = opts?.limit ?? 50;\n  const offset = opts?.offset ?? 0;\n  const rows = db.prepare(`SELECT * FROM persona_events ${where} ORDER BY created_at DESC LIMIT ? OFFSET ?`).all(...params, limit, offset) as Record<string, unknown>[];\n  return rows.map(rowToEvent);\n}\n\nexport function updateEventStatus(db: Database.Database, id: string, status: string, errorMessage?: string | null): void {\n  const now = new Date().toISOString();\n  db.prepare('UPDATE persona_events SET status = ?, error_message = ?, processed_at = ? WHERE id = ?').run(status, errorMessage ?? null, now, id);\n}\n\nexport function updateEventWithMetadata(db: Database.Database, id: string, status: string, metadata?: string | null): PersonaEvent | undefined {\n  const now = new Date().toISOString();\n  db.prepare('UPDATE persona_events SET status = ?, processed_at = ?, payload = CASE WHEN ? IS NOT NULL THEN ? ELSE payload END WHERE id = ?')\n    .run(status, now, metadata, metadata, id);\n  return getEvent(db, id);\n}\n\n// ---------------------------------------------------------------------------\n// Event Subscriptions\n// ---------------------------------------------------------------------------\n\nexport function createSubscription(db: Database.Database, input: {\n  personaId: string; eventType: string; sourceFilter?: string | null; enabled?: boolean; useCaseId?: string | null; projectId?: string;\n}): PersonaEventSubscription {\n  const now = new Date().toISOString();\n  const id = nanoid();\n  db.prepare(`\n    INSERT INTO persona_event_subscriptions (id, project_id, persona_id, event_type, source_filter, enabled, use_case_id, created_at, updated_at)\n    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n  `).run(id, input.projectId ?? 'default', input.personaId, input.eventType, input.sourceFilter ?? null, input.enabled !== false ? 1 : 0, input.useCaseId ?? null, now, now);\n  return getSubscription(db, id)!;\n}\n\nexport function getSubscription(db: Database.Database, id: string): PersonaEventSubscription | undefined {\n  const row = db.prepare('SELECT * FROM persona_event_subscriptions WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n  return row ? rowToSubscription(row) : undefined;\n}\n\nexport function listSubscriptionsForPersona(db: Database.Database, personaId: string): PersonaEventSubscription[] {\n  const rows = db.prepare('SELECT * FROM persona_event_subscriptions WHERE persona_id = ?').all(personaId) as Record<string, unknown>[];\n  return rows.map(rowToSubscription);\n}\n\nexport function getSubscriptionsByEventType(db: Database.Database, eventType: string, projectId?: string): PersonaEventSubscription[] {\n  if (projectId) {\n    const rows = db.prepare('SELECT * FROM persona_event_subscriptions WHERE event_type = ? AND project_id = ?').all(eventType, projectId) as Record<string, unknown>[];\n    return rows.map(rowToSubscription);\n  }\n  const rows = db.prepare('SELECT * FROM persona_event_subscriptions WHERE event_type = ?').all(eventType) as Record<string, unknown>[];\n  return rows.map(rowToSubscription);\n}\n\nexport function updateSubscription(db: Database.Database, id: string, updates: {\n  eventType?: string | null; sourceFilter?: string | null; enabled?: boolean | null;\n}): void {\n  const now = new Date().toISOString();\n  const sub = getSubscription(db, id);\n  if (!sub) return;\n  db.prepare(`\n    UPDATE persona_event_subscriptions SET event_type = ?, source_filter = ?, enabled = ?, updated_at = ? WHERE id = ?\n  `).run(\n    updates.eventType ?? sub.eventType,\n    updates.sourceFilter !== undefined ? updates.sourceFilter : sub.sourceFilter,\n    updates.enabled !== undefined && updates.enabled !== null ? (updates.enabled ? 1 : 0) : (sub.enabled ? 1 : 0),\n    now,\n    id,\n  );\n}\n\nexport function deleteSubscription(db: Database.Database, id: string): void {\n  db.prepare('DELETE FROM persona_event_subscriptions WHERE id = ?').run(id);\n}\n\n// ---------------------------------------------------------------------------\n// Triggers\n// ---------------------------------------------------------------------------\n\nexport function createTrigger(db: Database.Database, input: {\n  personaId: string; triggerType: string; config?: string | null; enabled?: boolean; useCaseId?: string | null; projectId?: string;\n}): PersonaTrigger {\n  const now = new Date().toISOString();\n  const id = nanoid();\n  db.prepare(`\n    INSERT INTO persona_triggers (id, project_id, persona_id, trigger_type, config, enabled, use_case_id, created_at, updated_at)\n    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n  `).run(id, input.projectId ?? 'default', input.personaId, input.triggerType, input.config ?? null, input.enabled !== false ? 1 : 0, input.useCaseId ?? null, now, now);\n  return getTrigger(db, id)!;\n}\n\nexport function getTrigger(db: Database.Database, id: string): PersonaTrigger | undefined {\n  const row = db.prepare('SELECT * FROM persona_triggers WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n  return row ? rowToTrigger(row) : undefined;\n}\n\nexport function listTriggersForPersona(db: Database.Database, personaId: string): PersonaTrigger[] {\n  const rows = db.prepare('SELECT * FROM persona_triggers WHERE persona_id = ?').all(personaId) as Record<string, unknown>[];\n  return rows.map(rowToTrigger);\n}\n\nexport function getDueTriggers(db: Database.Database): PersonaTrigger[] {\n  const rows = db.prepare(\"SELECT * FROM persona_triggers WHERE enabled = 1 AND next_trigger_at <= datetime('now')\").all() as Record<string, unknown>[];\n  return rows.map(rowToTrigger);\n}\n\nexport function updateTriggerTimings(db: Database.Database, id: string, lastTriggeredAt: string, nextTriggerAt: string | null): void {\n  db.prepare('UPDATE persona_triggers SET last_triggered_at = ?, next_trigger_at = ?, updated_at = ? WHERE id = ?')\n    .run(lastTriggeredAt, nextTriggerAt, new Date().toISOString(), id);\n}\n\nexport function updateTrigger(db: Database.Database, id: string, updates: {\n  triggerType?: string | null; config?: string | null; enabled?: boolean | null;\n}): vo
[2026-03-19T08:32:44.406Z] [STDOUT] id {\n  const now = new Date().toISOString();\n  const trigger = getTrigger(db, id);\n  if (!trigger) return;\n  db.prepare(`\n    UPDATE persona_triggers SET trigger_type = ?, config = ?, enabled = ?, updated_at = ? WHERE id = ?\n  `).run(\n    updates.triggerType ?? trigger.triggerType,\n    updates.config !== undefined ? updates.config : trigger.config,\n    updates.enabled !== undefined && updates.enabled !== null ? (updates.enabled ? 1 : 0) : (trigger.enabled ? 1 : 0),\n    now,\n    id,\n  );\n}\n\nexport function deleteTrigger(db: Database.Database, id: string): void {\n  db.prepare('DELETE FROM persona_triggers WHERE id = ?').run(id);\n}\n\n// ---------------------------------------------------------------------------\n// Executions\n// ---------------------------------------------------------------------------\n\nexport function createExecution(db: Database.Database, input: {\n  id?: string; personaId: string; triggerId?: string | null; useCaseId?: string | null; inputData?: string | null; projectId?: string;\n}): PersonaExecution {\n  const now = new Date().toISOString();\n  const id = input.id ?? nanoid();\n  db.prepare(`\n    INSERT INTO persona_executions (id, project_id, persona_id, trigger_id, use_case_id, status, input_data, created_at)\n    VALUES (?, ?, ?, ?, ?, 'queued', ?, ?)\n  `).run(id, input.projectId ?? 'default', input.personaId, input.triggerId ?? null, input.useCaseId ?? null, input.inputData ?? null, now);\n  return getExecution(db, id)!;\n}\n\nexport function getExecution(db: Database.Database, id: string): PersonaExecution | undefined {\n  const row = db.prepare('SELECT * FROM persona_executions WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n  return row ? rowToExecution(row) : undefined;\n}\n\nexport function listExecutions(db: Database.Database, opts?: {\n  personaId?: string; status?: string; limit?: number; offset?: number; projectId?: string;\n}): PersonaExecution[] {\n  let sql = 'SELECT * FROM persona_executions WHERE 1=1';\n  const params: unknown[] = [];\n\n  if (opts?.projectId) {\n    sql += ' AND project_id = ?';\n    params.push(opts.projectId);\n  }\n  if (opts?.personaId) {\n    sql += ' AND persona_id = ?';\n    params.push(opts.personaId);\n  }\n  if (opts?.status) {\n    sql += ' AND status = ?';\n    params.push(opts.status);\n  }\n  sql += ' ORDER BY created_at DESC';\n  if (opts?.limit) {\n    sql += ' LIMIT ?';\n    params.push(opts.limit);\n  }\n  if (opts?.offset) {\n    sql += ' OFFSET ?';\n    params.push(opts.offset);\n  }\n\n  const rows = db.prepare(sql).all(...params) as Record<string, unknown>[];\n  return rows.map(rowToExecution);\n}\n\nexport function updateExecution(db: Database.Database, id: string, updates: Record<string, unknown>): void {\n  const fields: string[] = [];\n  const values: unknown[] = [];\n\n  const columnMap: Record<string, string> = {\n    status: 'status',\n    outputData: 'output_data',\n    claudeSessionId: 'claude_session_id',\n    modelUsed: 'model_used',\n    inputTokens: 'input_tokens',\n    outputTokens: 'output_tokens',\n    costUsd: 'cost_usd',\n    errorMessage: 'error_message',\n    durationMs: 'duration_ms',\n    startedAt: 'started_at',\n    completedAt: 'completed_at',\n  };\n\n  for (const [key, col] of Object.entries(columnMap)) {\n    if (key in updates) {\n      fields.push(`${col} = ?`);\n      values.push(updates[key]);\n    }\n  }\n\n  if (fields.length === 0) return;\n  values.push(id);\n  db.prepare(`UPDATE persona_executions SET ${fields.join(', ')} WHERE id = ?`).run(...values);\n}\n\nexport function appendOutput(db: Database.Database, id: string, chunk: string): void {\n  db.prepare(`\n    UPDATE persona_executions SET output_data = COALESCE(output_data, '') || ? WHERE id = ?\n  `).run(chunk, id);\n}\n\nexport function countRunningExecutions(db: Database.Database, personaId: string): number {\n  const row = db.prepare(\"SELECT COUNT(*) as cnt FROM persona_executions WHERE persona_id = ? AND status = 'running'\").get(personaId) as { cnt: number };\n  return row.cnt;\n}\n\n// ---------------------------------------------------------------------------\n// Admin queries\n// ---------------------------------------------------------------------------\n\nexport function listDistinctProjectIds(db: Database.Database): string[] {\n  const rows = db.prepare('SELECT DISTINCT project_id FROM personas ORDER BY project_id').all() as Array<{ project_id: string }>;\n  return rows.map(r => r.project_id);\n}\n","numLines":738,"startLine":1,"totalLines":738}}}
[2026-03-19T08:32:44.707Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LEwkvp7JM95pszhX4adL8k","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import type { ExecRequest, Persona, PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import type { Logger } from 'pino';\n    11→import * as db from './db.js';\n    12→\n    13→export function createHttpApi(\n    14→  auth: Auth,\n    15→  dispatcher: Dispatcher,\n    16→  pool: WorkerPool,\n    17→  tokenManager: TokenManager,\n    18→  oauth: OAuthManager,\n    19→  logger: Logger,\n    20→  database?: Database.Database,\n    21→): http.Server {\n    22→  const server = http.createServer(async (req, res) => {\n    23→    // CORS headers\n    24→    res.setHeader('Access-Control-Allow-Origin', '*');\n    25→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    26→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n    27→\n    28→    if (req.method === 'OPTIONS') {\n    29→      res.writeHead(204);\n    30→      res.end();\n    31→      return;\n    32→    }\n    33→\n    34→    const url = req.url || '/';\n    35→    const [pathname, queryString] = url.split('?');\n    36→\n    37→    // Unauthenticated endpoints\n    38→    if (pathname === '/health' && req.method === 'GET') {\n    39→      handleHealth(res, pool, oauth);\n    40→      return;\n    41→    }\n    42→\n    43→    // Auth check for everything else — dual auth (API key + optional JWT)\n    44→    const ctx = auth.validateAndExtractContext(req);\n    45→    if (!ctx) {\n    46→      res.writeHead(401, { 'Content-Type': 'application/json' });\n    47→      res.end(JSON.stringify({ error: 'Unauthorized' }));\n    48→      return;\n    49→    }\n    50→\n    51→    // Helper: project scoping (admin sees all, user sees own project)\n    52→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n    53→\n    54→    try {\n    55→      // --- OAuth endpoints ---\n    56→      if (pathname === '/api/oauth/authorize' && req.method === 'POST') {\n    57→        handleOAuthAuthorize(res, oauth);\n    58→      } else if (pathname === '/api/oauth/callback' && req.method === 'POST') {\n    59→        await handleOAuthCallback(req, res, oauth, tokenManager, logger);\n    60→      } else if (pathname === '/api/oauth/status' && req.method === 'GET') {\n    61→        handleOAuthStatus(res, oauth);\n    62→      } else if (pathname === '/api/oauth/refresh' && req.method === 'POST') {\n    63→        await handleOAuthRefresh(res, oauth, tokenManager, logger);\n    64→      } else if (pathname === '/api/oauth/disconnect' && req.method === 'DELETE') {\n    65→        handleOAuthDisconnect(res, oauth, tokenManager);\n    66→      }\n    67→      // --- Token injection (fallback for setup-token / direct paste) ---\n    68→      else if (pathname === '/api/token' && req.method === 'POST') {\n    69→        await handleSetToken(req, res, tokenManager, logger);\n    70→      }\n    71→      // --- Persona CRUD ---\n    72→      else if (pathname === '/api/personas' && req.method === 'GET' && database) {\n    73→        json(res, 200, db.listPersonas(database, scopedProjectId));\n    74→      } else if (pathname === '/api/personas' && req.method === 'POST' && database) {\n    75→        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n    76→        const now = new Date().toISOString();\n    77→        const persona: Persona = {\n    78→          id: body.id ?? nanoid(),\n    79→          projectId: ctx.authType === 'user' ? ctx.projectId : (body.projectId ?? 'default'),\n    80→          name: body.name ?? 'Untitled',\n    81→          description: body.description ?? null,\n    82→          systemPrompt: body.systemPrompt ?? '',\n    83→          structuredPrompt: body.structuredPrompt ?? null,\n    84→          icon: body.icon ?? null,\n    85→          color: body.color ?? null,\n    86→          enabled: body.enabled ?? true,\n    87→          maxConcurrent: body.maxConcurrent ?? 1,\n    88→          timeoutMs: body.timeoutMs ?? 300_000,\n    89→          modelProfile: body.modelProfile ?? null,\n    90→          maxBudgetUsd: body.maxBudgetUsd ?? null,\n    91→          maxTurns: body.maxTurns ?? null,\n    92→          designContext: body.designContext ?? null,\n    93→          groupId: body.groupId ?? null,\n    94→          createdAt: body.createdAt ?? now,\n    95→          updatedAt: now,\n    96→        };\n    97→        db.upsertPersona(database, persona);\n    98→        json(res, 201, persona);\n    99→      } else if (matchRoute(pathname, '/api/personas/') && req.method === 'GET' && database) {\n   100→        const id = pathname!.replace('/api/personas/', '');\n   101→        const persona = db.getPersona(database, id);\n   102→        if (!persona || (scopedProjectId && persona.projectId !== scopedProjectId)) { json(res, 404, { error: 'Not found' }); return; }\n   103→        json(res, 200, persona);\n   104→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/tools') && req.method === 'GET' && database) {\n   105→        const id = pathname!.replace('/api/personas/', '').replace('/tools', '');\n   106→        json(res, 200, db.getToolsForPersona(database, id));\n   107→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/tools') && req.method === 'POST' && database) {\n   108→        const id = pathname!.replace('/api/personas/', '').replace('/tools', '');\n   109→        const body = JSON.parse(await readBody(req)) as { toolId: string };\n   110→        db.linkTool(database, id, body.toolId);\n   111→        json(res, 200, { linked: true });\n   112→      } else if (matchRoute(pathname, '/api/personas/') && !pathname!.endsWith('/tools') && !pathname!.endsWith('/credentials') && !pathname!.endsWith('/subscriptions') && !pathname!.endsWith('/triggers') && req.method === 'DELETE' && database) {\n   113→        const id = pathname!.replace('/api/personas/', '');\n   114→        db.deletePersona(database, id, scopedProjectId);\n   115→        json(res, 200, { deleted: true });\n   116→      }\n   117→      // --- Tool Definitions ---\n   118→      else if (pathname === '/api/tool-definitions' && req.method === 'POST' && database) {\n   119→        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   120→        const now = new Date().toISOString();\n   121→        const tool: PersonaToolDefinition = {\n   122→          id: body.id ?? nanoid(),\n   123→          name: body.name ?? 'unnamed',\n   124→          category: body.category ?? 'general',\n   125→          description: body.description ?? '',\n   126→          scriptPath: body.scriptPath ?? '',\n   127→          inputSchema: body.inputSchema ?? null,\n   128→          outputSchema: body.outputSchema ?? null,\n   129→          requiresCredentialType: body.requiresCredentialType ?? null,\n   130→          implementationGuide: body.implementationGuide ?? null,\n   131→          isBuiltin: body.isBuiltin ?? false,\n   132→          createdAt: body.createdAt ?? now,\n   133→          updatedAt: now,\n   134→        };\n   135→        db.upsertToolDefinition(database, tool);\n   136→        json(res, 201, tool);\n   137→      }\n   138→      // --- Credentials ---\n   139→      else if (pathname === '/api/credentials' && req.method === 'POST' && database) {\n   140→        const body = JSON.parse(await readBody(req));\n   141→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   142→        const cred = db.createCredential(database, body);\n   143→        json(res, 201, cred);\n   144→      } else if (matchRoute(pathname, '/api/credentials/') && req.method === 'DELETE' && database) {\n   145→        const id = pathname!.replace('/api/credentials/', '');\n   146→        db.deleteCredential(database, id);\n   147→        json(res, 200, { deleted: true });\n   148→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/credentials') && req.method === 'GET' && database) {\n   149→        const id = pathname!.replace('/api/personas/', '').replace('/credentials', '');\n   150→        const creds = db.listCredentialsForPersona(database, id);\n   151→        // Strip encrypted data from response\n   152→        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   153→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/credentials') && req.method === 'POST' && database) {\n   154→        const id = pathname!.replace('/api/personas/', '').replace('/credentials', '');\n   155→        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   156→        db.linkCredential(database, id, body.credentialId);\n   157→        json(res, 200, { linked: true });\n   158→      }\n   159→      // --- Event Subscriptions ---\n   160→      else if (pathname === '/api/subscriptions' && req.method === 'POST' && database) {\n   161→        const body = JSON.parse(await readBody(req));\n   162→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   163→        const sub = db.createSubscription(database, body);\n   164→        json(res, 201, sub);\n   165→      } else if (matchRoute(pathname, '/api/subscriptions/') && req.method === 'PUT' && database) {\n   166→        const id = pathname!.replace('/api/subscriptions/', '');\n   167→        const body = JSON.parse(await readBody(req));\n   168→        db.updateSubscription(database, id, body);\n   169→        const updated = db.getSubscription(database, id);\n   170→        json(res, 200, updated);\n   171→      } else if (matchRoute(pathname, '/api/subscriptions/') && req.method === 'DELETE' && database) {\n   172→        const id = pathname!.replace('/api/subscriptions/', '');\n   173→        db.deleteSubscription(database, id);\n   174→        json(res, 200, { deleted: true });\n   175→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/subscriptions') && req.method === 'GET' && database) {\n   176→        const id = pathname!.replace('/api/personas/', '').replace('/subscriptions', '');\n   177→        json(res, 200, db.listSubscriptionsForPersona(database, id));\n   178→      }\n   179→      // --- Triggers ---\n   180→      else if (pathname === '/api/triggers' && req.method === 'POST' && database) {\n   181→        const body = JSON.parse(await readBody(req));\n   182→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   183→        const trigger = db.createTrigger(database, body);\n   184→        json(res, 201, trigger);\n   185→      } else if (matchRoute(pathname, '/api/triggers/') && req.method === 'PUT' && database) {\n   186→        const id = pathname!.replace('/api/triggers/', '');\n   187→        const body = JSON.parse(await readBody(req));\n   188→        db.updateTrigger(database, id, body);\n   189→        const updated = db.getTrigger(database, id);\n   190→        json(res, 200, updated);\n   191→      } else if (matchRoute(pathname, '/api/triggers/') && req.method === 'DELETE' && database) {\n   192→        const id = pathname!.replace('/api/triggers/', '');\n   193→        db.deleteTrigger(database, id);\n   194→        json(res, 200, { deleted: true });\n   195→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/triggers') && req.method === 'GET' && database) {\n   196→        const id = pathname!.replace('/api/personas/', '').replace('/triggers', '');\n   197→        json(res, 200, db.listTriggersForPersona(database, id));\n   198→      }\n   199→      // --- Events ---\n   200→      else if (pathname === '/api/events' && req.method === 'GET' && database) {\n   201→        const params = new URLSearchParams(queryString || '');\n   202→        const events = db.listEvents(database, {\n   203→          eventType: params.get('eventType') ?? undefined,\n   204→          status: params.get('status') ?? undefined,\n   205→          limit: params.get('limit') ? parseInt(params.get('limit')!, 10) : 50,\n   206→          offset: params.get('offset') ? parseInt(params.get('offset')!, 10) : undefined,\n   207→          projectId: scopedProjectId,\n   208→        });\n   209→        json(res, 200, events);\n   210→      } else if (pathname === '/api/events' && req.method === 'POST' && database) {\n   211→        const body = JSON.parse(await readBody(req));\n   212→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   213→        const event = db.publishEvent(database, body);\n   214→        json(res, 201, event);\n   215→      } else if (matchRoute(pathname, '/api/events/') && req.method === 'PUT' && database) {\n   216→        const id = pathname!.replace('/api/events/', '');\n   217→        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n   218→        const updated = db.updateEventWithMetadata(database, id, body.status, body.metadata);\n   219→        if (updated) {\n   220→          json(res, 200, updated);\n   221→        } else {\n   222→          res.writeHead(404, { 'Content-Type': 'application/json' });\n   223→          res.end(JSON.stringify({ error: 'Event not found' }));\n   224→        }\n   225→      }\n   226→      // --- Webhooks ---\n   227→      else if (matchRoute(pathname, '/api/webhooks/') && req.method === 'POST' && database) {\n   228→        const personaId = pathname!.replace('/api/webhooks/', '');\n   229→        const body = await readBody(req);\n   230→        const event = db.publishEvent(database, {\n   231→          eventType: 'webhook_received',\n   232→          sourceType: 'webhook',\n   233→          sourceId: personaId,\n   234→          targetPersonaId: personaId,\n   235→          payload: body,\n   236→        });\n   237→        json(res, 201, event);\n   238→      }\n   239→      // --- GitLab Webhook ---\n   240→      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && database) {\n   241→        const body = await readBody(req);\n   242→        let parsed: Record<string, unknown> = {};\n   243→        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   244→        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   245→        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   246→        const event = db.publishEvent(database, {\n   247→          eventType: `gitlab_${objectKind}`,\n   248→          sourceType: 'gitlab',\n   249→          sourceId: projectPath ?? null,\n   250→          payload: body,\n   251→        });\n   252→        json(res, 201, event);\n   253→      }\n   254→      // --- Executions ---\n   255→      else if (pathname === '/api/executions' && req.method === 'GET' && database) {\n   256→        const params = new URLSearchParams(queryString || '');\n   257→        const executions = db.listExecutions(database, {\n   258→          personaId: params.get('personaId') ?? undefined,\n   259→          status: params.get('status') ?? undefined,\n   260→          limit: params.get('limit') ? parseInt(params.get('limit')!, 10) : 50,\n   261→          offset: params.get('offset') ? parseInt(params.get('offset')!, 10) : undefined,\n   262→          projectId: scopedProjectId,\n   263→        });\n   264→        json(res, 200, executions);\n   265→      }\n   266→      // --- Existing execution endpoints ---\n   267→      else if (pathname === '/api/status' && req.method === 'GET') {\n   268→        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   269→      } else if (pathname === '/api/execute' && req.method === 'POST') {\n   270→        await handleExecute(req, res, dispatcher, logger, ctx);\n   271→      } else if (matchRoute(pathname, '/api/executions/') && pathname!.endsWith('/cancel') && req.method === 'POST') {\n   272→        const executionId = pathname!.replace('/api/executions/', '').replace('/cancel', '');\n   273→        handleCancelExecution(res, dispatcher, executionId || '');\n   274→      } else if (matchRoute(pathname, '/api/executions/') && req.method === 'GET') {\n   275→        const executionId = pathname!.replace('/api/executions/', '');\n   276→        const params = new URLSearchParams(queryString || '');\n   277→        const offset = parseInt(params.get('offset') || '0', 10);\n   278→        handleGetExecution(res, dispatcher, executionId, offset);\n   279→      }\n   280→      // --- Admin-only routes ---\n   281→      else if (pathname === '/api/admin/users' && req.method === 'GET' && database) {\n   282→        if (requireAdmin(ctx, res)) return;\n   283→        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   284→      } else if (pathname === '/api/admin/personas' && req.method === 'GET' && database) {\n   285→        if (requireAdmin(ctx, res)) return;\n   286→        json(res, 200, db.listPersonas(database));\n   287→      } else if (pathname === '/api/admin/executions' && req.method === 'GET' && database) {\n   288→        if (requireAdmin(ctx, res)) return;\n   289→        const params = new URLSearchParams(queryString || '');\n   290→        json(res, 200, db.listExecutions(database, {\n   291→          limit: params.get('limit') ? parseInt(params.get('limit')!, 10) : 100,\n   292→          offset: params.get('offset') ? parseInt(params.get('offset')!, 10) : undefined,\n   293→        }));\n   294→      } else {\n   295→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   296→        res.end(JSON.stringify({ error: 'Not found' }));\n   297→      }\n   298→    } catch (err) {\n   299→      if (err instanceof Error && err.message === 'Payload too large') {\n   300→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   301→        res.end(JSON.stringify({ error: 'Payload too large' }));\n   302→        return;\n   303→      }\n   304→      logger.error({ err, url }, 'HTTP handler error');\n   305→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   306→      res.end(JSON.stringify({ error: 'Internal server error' }));\n   307→    }\n   308→  });\n   309→\n   310→  return server;\n   311→}\n   312→\n   313→function json(res: http.ServerResponse, status: number, data: unknown): void {\n   314→  res.writeHead(status, { 'Content-Type': 'application/json' });\n   315→  res.end(JSON.stringify(data));\n   316→}\n   317→\n   318→function matchRoute(pathname: string | undefined, prefix: string): boolean {\n   319→  return !!pathname && pathname.startsWith(prefix) && pathname.length > prefix.length;\n   320→}\n   321→\n   322→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   323→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   324→  if (ctx.authType !== 'admin') {\n   325→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   326→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   327→    return true;\n   328→  }\n   329→  return false;\n   330→}\n   331→\n   332→// --- OAuth handlers ---\n   333→\n   334→function handleOAuthAuthorize(res: http.ServerResponse, oauth: OAuthManager): void {\n   335→  const { url, state } = oauth.generateAuthUrl();\n   336→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   337→  res.end(JSON.stringify({\n   338→    authUrl: url,\n   339→    state,\n   340→    instructions: [\n   341→      '1. Open the authUrl in a browser',\n   342→      '2. Log in with your Anthropic account and authorize',\n   343→      '3. You will be redirected to a page showing an authorization code',\n   344→      '4. Copy the code from the URL (the \"code\" query parameter)',\n   345→      '5. POST it to /api/oauth/callback with { \"code\": \"...\", \"state\": \"...\" }',\n   346→    ],\n   347→  }));\n   348→}\n   349→\n   350→async function handleOAuthCallback(\n   351→  req: http.IncomingMessage,\n   352→  res: http.ServerResponse,\n   353→  oauth: OAuthManager,\n   354→  tokenManager: TokenManager,\n   355→  logger: Logger,\n   356→): Promise<void> {\n   357→  const body = await readBody(req);\n   358→  let parsed: { code?: string; state?: string };\n   359→\n   360→  try {\n   361→    parsed = JSON.parse(body);\n   362→  } catch {\n   363→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   364→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   365→    return;\n   366→  }\n   367→\n   368→  if (!parsed.code || !parsed.state) {\n   369→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   370→    res.end(JSON.stringify({ error: 'Missing required fields: code, state' }));\n   371→    return;\n   372→  }\n   373→\n   374→  const tokens = await oauth.exchangeCode(parsed.code, parsed.state);\n   375→  if (!tokens) {\n   376→    res.writeHead(401, { 'Content-Type': 'application/json' });\n   377→    res.end(JSON.stringify({ error: 'OAuth token exchange failed' }));\n   378→    return;\n   379→  }\n   380→\n   381→  // Also store the access token in TokenManager for backward compatibility\n   382→  tokenManager.storeClaudeToken(tokens.accessToken);\n   383→\n   384→  logger.info('OAuth flow completed, subscription connected');\n   385→\n   386→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   387→  res.end(JSON.stringify({\n   388→    status: 'connected',\n   389→    scopes: tokens.scopes,\n   390→    expiresAt: new Date(tokens.expiresAt).toISOString(),\n   391→  }));\n   392→}\n   393→\n   394→function handleOAuthStatus(res: http.ServerResponse, oauth: OAuthManager): void {\n   395→  const tokens = oauth.getTokens();\n   396→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   397→  res.end(JSON.stringify({\n   398→    connected: oauth.hasTokens(),\n   399→    scopes: tokens?.scopes || [],\n   400→    expiresAt: tokens ? new Date(tokens.expiresAt).toISOString() : null,\n   401→    isExpired: tokens ? Date.now() > tokens.expiresAt : null,\n   402→  }));\n   403→}\n   404→\n   405→async function handleOAuthRefresh(\n   406→  res: http.ServerResponse,\n   407→  oauth: OAuthManager,\n   408→  tokenManager: TokenManager,\n   409→  logger: Logger,\n   410→): Promise<void> {\n   411→  const tokens = await oauth.refreshAccessToken();\n   412→  if (!tokens) {\n   413→    res.writeHead(500, { 'Content-Type': 'application/json' });\n   414→    res.end(JSON.stringify({ error: 'Token refresh failed' }));\n   415→    return;\n   416→  }\n   417→\n   418→  tokenManager.storeClaudeToken(tokens.accessToken);\n   419→  logger.info('OAuth token refreshed via API');\n   420→\n   421→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   422→  res.end(JSON.stringify({\n   423→    status: 'refreshed',\n   424→    expiresAt: new Date(tokens.expiresAt).toISOString(),\n   425→  }));\n   426→}\n   427→\n   428→function handleOAuthDisconnect(\n   429→  res: http.ServerResponse,\n   430→  oauth: OAuthManager,\n   431→  tokenManager: TokenManager,\n   432→): void {\n   433→  oauth.clearTokens();\n   434→  tokenManager.clearToken();\n   435→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   436→  res.end(JSON.stringify({ status: 'disconnected' }));\n   437→}\n   438→\n   439→// --- Token injection (for setup-token / manual paste) ---\n   440→\n   441→async function handleSetToken(\n   442→  req: http.IncomingMessage,\n   443→  res: http.ServerResponse,\n   444→  tokenManager: TokenManager,\n   445→  logger: Logger,\n   446→): Promise<void> {\n   447→  const body = await readBody(req);\n   448→  let parsed: { token?: string };\n   449→\n   450→  try {\n   451→    parsed = JSON.parse(body);\n   452→  } catch {\n   453→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   454→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   455→    return;\n   456→  }\n   457→\n   458→  if (!parsed.token) {\n   459→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   460→    res.end(JSON.stringify({ error: 'Missing required field: token' }));\n   461→    return;\n   462→  }\n   463→\n   464→  tokenManager.storeClaudeToken(parsed.token);\n   465→  logger.info('Claude token set via direct injection');\n   466→\n   467→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   468→  res.end(JSON.stringify({ status: 'token_stored' }));\n   469→}\n   470→\n   471→// --- Existing handlers ---\n   472→\n   473→function handleHealth(res: http.ServerResponse, pool: WorkerPool, oauth: OAuthManager): void {\n   474→  const counts = pool.getWorkerCount();\n   475→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   476→  res.end(JSON.stringify({\n   477→    status: 'ok',\n   478→    workers: counts,\n   479→    hasSubscription: oauth.hasTokens(),\n   480→    timestamp: Date.now(),\n   481→  }));\n   482→}\n   483→\n   484→function handleStatus(\n   485→  res: http.ServerResponse,\n   486→  pool: WorkerPool,\n   487→  dispatcher: Dispatcher,\n   488→  tokenManager: TokenManager,\n   489→  oauth: OAuthManager,\n   490→): void {\n   491→  const oauthTokens = oauth.getTokens();\n   492→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   493→  res.end(JSON.stringify({\n   494→    workers: pool.getWorkers(),\n   495→    workerCounts: pool.getWorkerCount(),\n   496→    queueLength: dispatcher.getQueueLength(),\n   497→    activeExecutions: dispatcher.getActiveExecutions(),\n   498→    hasClaudeToken: tokenManager.hasToken(),\n   499→    oauth: {\n   500→      connected: oauth.hasTokens(),\n   501→      scopes: oauthTokens?.scopes || [],\n   502→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   503→    },\n   504→  }));\n   505→}\n   506→\n   507→async function handleExecute(\n   508→  req: http.IncomingMessage,\n   509→  res: http.ServerResponse,\n   510→  dispatcher: Dispatcher,\n   511→  logger: Logger,\n   512→  ctx?: RequestContext,\n   513→): Promise<void> {\n   514→  const body = await readBody(req);\n   515→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   516→\n   517→  try {\n   518→    parsed = JSON.parse(body);\n   519→  } catch {\n   520→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   521→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   522→    return;\n   523→  }\n   524→\n   525→  if (!parsed.prompt) {\n   526→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   527→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   528→    return;\n   529→  }\n   530→\n   531→  const request: ExecRequest = {\n   532→    executionId: nanoid(),\n   533→    personaId: parsed.personaId || 'manual',\n   534→    prompt: parsed.prompt,\n   535→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   536→    config: {\n   537→      timeoutMs: parsed.timeoutMs || 300_000,\n   538→    },\n   539→  };\n   540→\n   541→  dispatcher.submit(request);\n   542→\n   543→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   544→\n   545→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   546→  res.end(JSON.stringify({\n   547→    executionId: request.executionId,\n   548→    status: 'queued',\n   549→  }));\n   550→}\n   551→\n   552→function handleGetExecution(\n   553→  res: http.ServerResponse,\n   554→  dispatcher: Dispatcher,\n   555→  executionId: string,\n   556→  offset: number = 0,\n   557→): void {\n   558→  const exec = dispatcher.getExecution(executionId);\n   559→\n   560→  if (!exec) {\n   561→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   562→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   563→    return;\n   564→  }\n   565→\n   566→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   567→\n   568→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   569→  res.end(JSON.stringify({\n   570→    executionId,\n   571→    status: exec.status,\n   572→    outputLines: exec.output.length,\n   573→    output,\n   574→    durationMs: exec.durationMs,\n   575→    sessionId: exec.sessionId,\n   576→    totalCostUsd: exec.totalCostUsd,\n   577→  }));\n   578→}\n   579→\n   580→function handleCancelExecution(\n   581→  res: http.ServerResponse,\n   582→  dispatcher: Dispatcher,\n   583→  executionId: string,\n   584→): void {\n   585→  const cancelled = dispatcher.cancelExecution(executionId);\n   586→\n   587→  if (!cancelled) {\n   588→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   589→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   590→    return;\n   591→  }\n   592→\n   593→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   594→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   595→}\n   596→\n   597→const MAX_BODY_BYTES = 1024 * 1024; // 1 MB\n   598→\n   599→function readBody(req: http.IncomingMessage): Promise<string> {\n   600→  return new Promise((resolve, reject) => {\n   601→    const chunks: Buffer[] = [];\n   602→    let totalBytes = 0;\n   603→    req.on('data', (chunk: Buffer) => {\n   604→      totalBytes += chunk.length;\n   605→      if (totalBytes > MAX_BODY_BYTES) {\n   606→        req.destroy();\n   607→        reject(new Error('Payload too large'));\n   608→        return;\n   609→      }\n   610→      chunks.push(chunk);\n   611→    });\n   612→    req.on('end', () => resolve(Buffer.concat(chunks).toString()));\n   613→    req.on('error', reject);\n   614→  });\n   615→}\n   616→"}]},"parent_tool_use_id":null,"session_id":"7dcbcdb6-4ec4-4587-8878-e43fcc71925a","uuid":"6605b456-65b7-469d-91a8-ec1400a6d148","timestamp":"2026-03-19T08:32:44.612Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\.claude\\worktrees\\reactive-gathering-parrot\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport type { ExecRequest, Persona, PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { Logger } from 'pino';\nimport * as db from './db.js';\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n): http.Server {\n  const server = http.createServer(async (req, res) => {\n    // CORS headers\n    res.setHeader('Access-Control-Allow-Origin', '*');\n    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n\n    if (req.method === 'OPTIONS') {\n      res.writeHead(204);\n      res.end();\n      return;\n    }\n\n    const url = req.url || '/';\n    const [pathname, queryString] = url.split('?');\n\n    // Unauthenticated endpoints\n    if (pathname === '/health' && req.method === 'GET') {\n      handleHealth(res, pool, oauth);\n      return;\n    }\n\n    // Auth check for everything else — dual auth (API key + optional JWT)\n    const ctx = auth.validateAndExtractContext(req);\n    if (!ctx) {\n      res.writeHead(401, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Unauthorized' }));\n      return;\n    }\n\n    // Helper: project scoping (admin sees all, user sees own project)\n    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n\n    try {\n      // --- OAuth endpoints ---\n      if (pathname === '/api/oauth/authorize' && req.method === 'POST') {\n        handleOAuthAuthorize(res, oauth);\n      } else if (pathname === '/api/oauth/callback' && req.method === 'POST') {\n        await handleOAuthCallback(req, res, oauth, tokenManager, logger);\n      } else if (pathname === '/api/oauth/status' && req.method === 'GET') {\n        handleOAuthStatus(res, oauth);\n      } else if (pathname === '/api/oauth/refresh' && req.method === 'POST') {\n        await handleOAuthRefresh(res, oauth, tokenManager, logger);\n      } else if (pathname === '/api/oauth/disconnect' && req.method === 'DELETE') {\n        handleOAuthDisconnect(res, oauth, tokenManager);\n      }\n      // --- Token injection (fallback for setup-token / direct paste) ---\n      else if (pathname === '/api/token' && req.method === 'POST') {\n        await handleSetToken(req, res, tokenManager, logger);\n      }\n      // --- Persona CRUD ---\n      else if (pathname === '/api/personas' && req.method === 'GET' && database) {\n        json(res, 200, db.listPersonas(database, scopedProjectId));\n      } else if (pathname === '/api/personas' && req.method === 'POST' && database) {\n        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n        const now = new Date().toISOString();\n        const persona: Persona = {\n          id: body.id ?? nanoid(),\n          projectId: ctx.authType === 'user' ? ctx.projectId : (body.projectId ?? 'default'),\n          name: body.name ?? 'Untitled',\n          description: body.description ?? null,\n          systemPrompt: body.systemPrompt ?? '',\n          structuredPrompt: body.structuredPrompt ?? null,\n          icon: body.icon ?? null,\n          color: body.color ?? null,\n          enabled: body.enabled ?? true,\n          maxConcurrent: body.maxConcurrent ?? 1,\n          timeoutMs: body.timeoutMs ?? 300_000,\n          modelProfile: body.modelProfile ?? null,\n          maxBudgetUsd: body.maxBudgetUsd ?? null,\n          maxTurns: body.maxTurns ?? null,\n          designContext: body.designContext ?? null,\n          groupId: body.groupId ?? null,\n          createdAt: body.createdAt ?? now,\n          updatedAt: now,\n        };\n        db.upsertPersona(database, persona);\n        json(res, 201, persona);\n      } else if (matchRoute(pathname, '/api/personas/') && req.method === 'GET' && database) {\n        const id = pathname!.replace('/api/personas/', '');\n        const persona = db.getPersona(database, id);\n        if (!persona || (scopedProjectId && persona.projectId !== scopedProjectId)) { json(res, 404, { error: 'Not found' }); return; }\n        json(res, 200, persona);\n      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/tools') && req.method === 'GET' && database) {\n        const id = pathname!.replace('/api/personas/', '').replace('/tools', '');\n        json(res, 200, db.getToolsForPersona(database, id));\n      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/tools') && req.method === 'POST' && database) {\n        const id = pathname!.replace('/api/personas/', '').replace('/tools', '');\n        const body = JSON.parse(await readBody(req)) as { toolId: string };\n        db.linkTool(database, id, body.toolId);\n        json(res, 200, { linked: true });\n      } else if (matchRoute(pathname, '/api/personas/') && !pathname!.endsWith('/tools') && !pathname!.endsWith('/credentials') && !pathname!.endsWith('/subscriptions') && !pathname!.endsWith('/triggers') && req.method === 'DELETE' && database) {\n        const id = pathname!.replace('/api/personas/', '');\n        db.deletePersona(database, id, scopedProjectId);\n        json(res, 200, { deleted: true });\n      }\n      // --- Tool Definitions ---\n      else if (pathname === '/api/tool-definitions' && req.method === 'POST' && database) {\n        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n        const now = new Date().toISOString();\n        const tool: PersonaToolDefinition = {\n          id: body.id ?? nanoid(),\n          name: body.name ?? 'unnamed',\n          category: body.category ?? 'general',\n          description: body.description ?? '',\n          scriptPath: body.scriptPath ?? '',\n          inputSchema: body.inputSchema ?? null,\n          outputSchema: body.outputSchema ?? null,\n          requiresCredentialType: body.requiresCredentialType ?? null,\n          implementationGuide: body.implementationGuide ?? null,\n          isBuiltin: body.isBuiltin ?? false,\n          createdAt: body.createdAt ?? now,\n          updatedAt: now,\n        };\n        db.upsertToolDefinition(database, tool);\n        json(res, 201, tool);\n      }\n      // --- Credentials ---\n      else if (pathname === '/api/credentials' && req.method === 'POST' && database) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const cred = db.createCredential(database, body);\n        json(res, 201, cred);\n      } else if (matchRoute(pathname, '/api/credentials/') && req.method === 'DELETE' && database) {\n        const id = pathname!.replace('/api/credentials/', '');\n        db.deleteCredential(database, id);\n        json(res, 200, { deleted: true });\n      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/credentials') && req.method === 'GET' && database) {\n        const id = pathname!.replace('/api/personas/', '').replace('/credentials', '');\n        const creds = db.listCredentialsForPersona(database, id);\n        // Strip encrypted data from response\n        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/credentials') && req.method === 'POST' && database) {\n        const id = pathname!.replace('/api/personas/', '').replace('/credentials', '');\n        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n        db.linkCredential(database, id, body.credentialId);\n        json(res, 200, { linked: true });\n      }\n      // --- Event Subscriptions ---\n      else if (pathname === '/api/subscriptions' && req.method === 'POST' && database) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const sub = db.createSubscription(database, body);\n        json(res, 201, sub);\n      } else if (matchRoute(pathname, '/api/subscriptions/') && req.method === 'PUT' && database) {\n        const id = pathname!.replace('/api/subscriptions/', '');\n        const body = JSON.parse(await readBody(req));\n        db.updateSubscription(database, id, body);\n        const updated = db.getSubscription(database, id);\n        json(res, 200, updated);\n      } else if (matchRoute(pathname, '/api/subscriptions/') && req.method === 'DELETE' && database) {\n        const id = pathname!.replace('/api/subscriptions/', '');\n        db.deleteSubscription(database, id);\n        json(res, 200, { deleted: true });\n      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/subscriptions') && req.method === 'GET' && database) {\n        const id = pathname!.replace('/api/personas/', '').replace('/subscriptions', '');\n        json(res, 200, db.listSubscriptionsForPersona(database, id));\n      }\n      // --- Triggers ---\n      else if (pathname === '/api/triggers' && req.method === 'POST' && database) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const trigger = db.createTrigger(database, body);\n        json(res, 201, trigger);\n      } else if (matchRoute(pathname, '/api/triggers/') && req.method === 'PUT' && database) {\n        const id = pathname!.replace('/api/triggers/', '');\n        const body = JSON.parse(await readBody(req));\n        db.updateTrigger(database, id, body);\n        const updated = db.getTrigger(database, id);\n        json(res, 200, updated);\n      } else if (matchRoute(pathname, '/api/triggers/') && req.method === 'DELETE' && database) {\n        const id = pathname!.replace('/api/triggers/', '');\n        db.deleteTrigger(database, id);\n        json(res, 200, { deleted: true });\n      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/triggers') && req.method === 'GET' && database) {\n        const id = pathname!.replace('/api/personas/', '').replace('/triggers', '');\n        json(res, 200, db.listTriggersForPersona(database, id));\n      }\n      // --- Events ---\n      else if (pathname === '/api/events' && req.method === 'GET' && database) {\n        const params = new URLSearchParams(queryString || '');\n        const events = db.listEvents(database, {\n          eventType: params.get('eventType') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: params.get('limit') ? parseInt(params.get('limit')!, 10) : 50,\n          offset: params.get('offset') ? parseInt(params.get('offset')!, 10) : undefined,\n          projectId: scopedProjectId,\n        });\n        json(res, 200, events);\n      } else if (pathname === '/api/events' && req.method === 'POST' && database) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const event = db.publishEvent(database, body);\n        json(res, 201, event);\n      } else if (matchRoute(pathname, '/api/events/') && req.method === 'PUT' && database) {\n        const id = pathname!.replace('/api/events/', '');\n        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n        const updated = db.updateEventWithMetadata(database, id, body.status, body.metadata);\n        if (updated) {\n          json(res, 200, updated);\n        } else {\n          res.writeHead(404, { 'Content-Type': 'application/json' });\n          res.end(JSON.stringify({ error: 'Event not found' }));\n        }\n      }\n      // --- Webhooks ---\n      else if (matchRoute(pathname, '/api/webhooks/') && req.method === 'POST' && database) {\n        const personaId = pathname!.replace('/api/webhooks/', '');\n        const body = await readBody(req);\n        const event = db.publishEvent(database, {\n          eventType: 'webhook_received',\n          sourceType: 'webhook',\n          sourceId: personaId,\n          targetPersonaId: personaId,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- GitLab Webhook ---\n      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && database) {\n        const body = await readBody(req);\n        let parsed: Record<string, unknown> = {};\n        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n        const event = db.publishEvent(database, {\n          eventType: `gitlab_${objectKind}`,\n          sourceType: 'gitlab',\n          sourceId: projectPath ?? null,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- Executions ---\n      else if (pathname === '/api/executions' && req.method === 'GET' && database) {\n        const params = new URLSearchParams(queryString || '');\n        const executions = db.listExecutions(database, {\n          personaId: params.get('personaId') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: params.get('limit') ? parseInt(params.get('limit')!, 10) : 50,\n          offset: params.get('offset') ? parseInt(params.get('offset')!, 10) : undefined,\n          projectId: scopedProjectId,\n        });\n        json(res, 200, executions);\n      }\n      // --- Existing execution endpoints ---\n      else if (pathname === '/api/status' && req.method === 'GET') {\n        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n      } else if (pathname === '/api/execute' && req.method === 'POST') {\n        await handleExecute(req, res, dispatcher, logger, ctx);\n      } else if (matchRoute(pathname, '/api/executions/') && pathname!.endsWith('/cancel') && req.method === 'POST') {\n        const executionId = pathname!.replace('/api/executions/', '').replace('/cancel', '');\n        handleCancelExecution(res, dispatcher, executionId || '');\n      } else if (matchRoute(pathname, '/api/executions/') && req.method === 'GET') {\n        const executionId = pathname!.replace('/api/executions/', '');\n        const params = new URLSearchParams(queryString || '');\n        const offset = parseInt(params.get('offset') || '0', 10);\n        handleGetExecution(res, dispatcher, executionId, offset);\n      }\n      // --- Admin-only routes ---\n      else if (pathname === '/api/admin/users' && req.method === 'GET' && database) {\n        if (requireAdmin(ctx, res)) return;\n        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n      } else if (pathname === '/api/admin/personas' && req.method === 'GET' && database) {\n        if (requireAdmin(ctx, res)) return;\n        json(res, 200, db.listPersonas(database));\n      } else if (pathname === '/api/admin/executions' && req.method === 'GET' && database) {\n        if (requireAdmin(ctx, res)) return;\n        const params = new URLSearchParams(queryString || '');\n        json(res, 200, db.listExecutions(database, {\n          limit: params.get('limit') ? parseInt(params.get('limit')!, 10) : 100,\n          offset: params.get('offset') ? parseInt(params.get('offset')!, 10) : undefined,\n        }));\n      } else {\n        res.writeHead(404, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Not found' }));\n      }\n    } catch (err) {\n      if (err instanceof Error && err.message === 'Payload too large') {\n        res.writeHead(413, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Payload too large' }));\n        return;\n      }\n      logger.error({ err, url }, 'HTTP handler error');\n      res.writeHead(500, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Internal server error' }));\n    }\n  });\n\n  return server;\n}\n\nfunction json(res: http.ServerResponse, status: number, data: unknown): void {\n  res.writeHead(status, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify(data));\n}\n\nfunction matchRoute(pathname: string | undefined, prefix: string): boolean {\n  return !!pathname && pathname.startsWith(prefix) && pathname.length > prefix.length;\n}\n\n/** Returns true (and sends 403) if the caller is NOT an admin. */\nfunction requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n  if (ctx.authType !== 'admin') {\n    res.writeHead(403, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Admin access required' }));\n    return true;\n  }\n  return false;\n}\n\n// --- OAuth handlers ---\n\nfunction handleOAuthAuthorize(res: http.ServerResponse, oauth: OAuthManager): void {\n  const { url, state } = oauth.generateAuthUrl();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    authUrl: url,\n    state,\n    instructions: [\n      '1. Open the authUrl in a browser',\n      '2. Log in with your Anthropic account and authorize',\n      '3. You will be redirected to a page showing an authorization code',\n      '4. Copy the code from the URL (the \"code\" query parameter)',\n      '5. POST it to /api/oauth/callback with { \"code\": \"...\", \"state\": \"...\" }',\n    ],\n  }));\n}\n\nasync function handleOAuthCallback(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  oauth: OAuthManager,\n  tokenManager: TokenManager,\n  logger: Logger,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { code?: string; state?: string };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.code || !parsed.state) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required fields: code, state' }));\n    return;\n  }\n\n  const tokens = await oauth.exchangeCode(parsed.code, parsed.state);\n  if (!tokens) {\n    res.writeHead(401, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'OAuth token exchange failed' }));\n    return;\n  }\n\n  // Also store the access token in TokenManager for backward compatibility\n  tokenManager.storeClaudeToken(tokens.accessToken);\n\n  logger.info('OAuth flow completed, subscription connected');\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    status: 'connected',\n    scopes: tokens.scopes,\n    expiresAt: new Date(tokens.expiresAt).toISOString(),\n  }));\n}\n\nfunction handleOAuthStatus(res: http.ServerResponse, oauth: OAuthManager): void {\n  const tokens = oauth.getTokens();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    connected: oauth.hasTokens(),\n    scopes: tokens?.scopes || [],\n    expiresAt: tokens ? new Date(tokens.expiresAt).toISOString() : null,\n    isExpired: tokens ? Date.now() > tokens.expiresAt : null,\n  }));\n}\n\nasync function handleOAuthRefresh(\n  res: http.ServerResponse,\n  oauth: OAuthManager,\n  tokenManager: TokenManager,\n  logger: Logger,\n): Promise<void> {\n  const tokens = await oauth.refreshAccessToken();\n  if (!tokens) {\n    res.writeHead(500, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Token refresh failed' }));\n    return;\n  }\n\n  tokenManager.storeClaudeToken(tokens.accessToken);\n  logger.info('OAuth token refreshed via API');\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    status: 'refreshed',\n    expiresAt: new Date(tokens.expiresAt).toISOString(),\n  }));\n}\n\nfunction handleOAuthDisconnect(\n  res: http.ServerResponse,\n  oauth: OAuthManager,\n  tokenManager: TokenManager,\n): void {\n  oauth.clearTokens();\n  tokenManager.clearToken();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ status: 'disconnected' }));\n}\n\n// --- Token injection (for setup-token / manual paste) ---\n\nasync function handleSetToken(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  tokenManager: TokenManager,\n  logger: Logger,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { token?: string };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.token) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required field: token' }));\n    return;\n  }\n\n  tokenManager.storeClaudeToken(parsed.token);\n  logger.info('Claude token set via direct injection');\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ status: 'token_stored' }));\n}\n\n// --- Existing handlers ---\n\nfunction handleHealth(res: http.ServerResponse, pool: WorkerPool, oauth: OAuthManager): void {\n  const counts = pool.getWorkerCount();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    status: 'ok',\n    workers: counts,\n    hasSubscription: oauth.hasTokens(),\n    timestamp: Date.now(),\n  }));\n}\n\nfunction handleStatus(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n): void {\n  const oauthTokens = oauth.getTokens();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    workers: pool.getWorkers(),\n    workerCounts: pool.getWorkerCount(),\n    queueLength: dispatcher.getQueueLength(),\n    activeExecutions: dispatcher.getActiveExecutions(),\n    hasClaudeToken: tokenManager.hasToken(),\n    oauth: {\n      connected: oauth.hasTokens(),\n      scopes: oauthTokens?.scopes || [],\n      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n    },\n  }));\n}\n\nasync function handleExecute(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  ctx?: RequestContext,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.prompt) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n    return;\n  }\n\n  const request: ExecRequest = {\n    executionId: nanoid(),\n    personaId: parsed.personaId || 'manual',\n    prompt: parsed.prompt,\n    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n    config: {\n      timeoutMs: parsed.timeoutMs || 300_000,\n    },\n  };\n\n  dispatcher.submit(request);\n\n  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n\n  res.writeHead(202, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId: request.executionId,\n    status: 'queued',\n  }));\n}\n\nfunction handleGetExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n  offset: number = 0,\n): void {\n  const exec = dispatcher.getExecution(executionId);\n\n  if (!exec) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found' }));\n    return;\n  }\n\n  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId,\n    status: exec.status,\n    outputLines: exec.output.length,\n    output,\n    durationMs: exec.durationMs,\n    sessionId: exec.sessionId,\n    totalCostUsd: exec.totalCostUsd,\n  }));\n}\n\nfunction handleCancelExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n): void {\n  const cancelled = dispatcher.cancelExecution(executionId);\n\n  if (!cancelled) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n    return;\n  }\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n}\n\nconst MAX_BODY_BYTES = 1024 * 1024; // 1 MB\n\nfunction readBody(req: http.IncomingMessage): Promise<string> {\n  return new Promise((resolve, reject) => {\n    const chunks: Buffer[] = [];\n    let totalBytes = 0;\n    req.on('data', (chunk: Buffer) => {\n      totalBytes += chunk.length;\n      if (totalBytes > MAX_BODY_BYTES) {\n        req.destroy();\n        reject(new Error('Payload too large'));\n        return;\n      }\n      chunks.push(chunk);\n    });\n    req.on('end', () => resolve(Buffer.concat(chunks).toString()));\n    req.on('error', reject);\n  });\n}\n","numLines":616,"startLine":1,"totalLines":616}}}
