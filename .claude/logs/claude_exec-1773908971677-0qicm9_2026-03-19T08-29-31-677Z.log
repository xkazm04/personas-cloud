onDays);\n    const durationMs = Date.now() - startMs;\n\n    lastRetentionRunAt = new Date().toISOString();\n\n    logger.info({\n      retention: {\n        retentionDays,\n        executionsDeleted: result.executionsDeleted,\n        eventsDeleted: result.eventsDeleted,\n        durationMs,\n        lastRunAt: lastRetentionRunAt,\n      },\n    }, 'Retention purge completed');\n  } catch (err) {\n    const durationMs = Date.now() - startMs;\n\n    logger.error({\n      err,\n      retention: {\n        retentionDays,\n        durationMs,\n      },\n    }, 'Retention purge failed');\n  }\n}\n","structuredPatch":[],"originalFile":null}}
