.from(b, 'utf8');\n    43→  if (bufA.length !== bufB.length) {\n    44→    // Compare against self to maintain constant timing, then return false\n    45→    crypto.timingSafeEqual(bufA, bufA);\n    46→    return false;\n    47→  }\n    48→  return crypto.timingSafeEqual(bufA, bufB);\n    49→}\n    50→\n    51→interface WorkerEntry {\n    52→  ws: WebSocket;\n    53→  info: WorkerInfo;\n    54→  heartbeatTimer?: ReturnType<typeof setInterval>;\n    55→}\n    56→\n    57→export class WorkerPool {\n    58→  private workers = new Map<string, WorkerEntry>();\n    59→  private idleWorkers = new Set<string>();\n    60→  private wss: WebSocketServer | null = null;\n    61→  private allowedDigests: string[];\n    62→  private rejectUnverified: boolean;\n    63→\n    64→  // Typed listener storage — one array per event name\n    65→  private listeners: { [K in keyof WorkerPoolEvents]?: WorkerPoolEvents[K][] } = {};\n    66→\n    67→  constructor(\n    68→    private expectedWorkerToken: string,\n    69→    private logger: Logger,\n    70→    opts?: { allowedDigests?: string[]; rejectUnverified?: boolean },\n    71→  ) {\n    72→    this.allowedDigests = opts?.allowedDigests ?? [];\n    73→    this.rejectUnverified = opts?.rejectUnverified ?? false;\n    74→  }\n    75→\n    76→  /** Register a typed event listener. */\n    77→  on<K extends keyof WorkerPoolEvents>(event: K, listener: WorkerPoolEvents[K]): this {\n    78→    if (!this.listeners[event]) {\n    79→      this.listeners[event] = [];\n    80→    }\n    81→    this.listeners[event]!.push(listener);\n    82→    return this;\n    83→  }\n    84→\n    85→  /** Emit a typed event. */\n    86→  private emit<K extends keyof WorkerPoolEvents>(event: K, ...args: Parameters<WorkerPoolEvents[K]>): void {\n    87→    const fns = this.listeners[event];\n    88→    if (fns) {\n    89→      for (const fn of fns) {\n    90→        (fn as (...a: Parameters<WorkerPoolEvents[K]>) => void)(...args);\n    91→      }\n    92→    }\n    93→  }\n    94→\n    95→  listen(port: number, tlsConfig?: TlsConfig): void {\n    96→    if (tlsConfig?.enabled) {\n    97→      const httpsServer = https.createServer({\n    98→        cert: fs.readFileSync(tlsConfig.certPath),\n    99→        key: fs.readFileSync(tlsConfig.keyPath),\n   100→        ca: tlsConfig.caPath ? fs.readFileSync(tlsConfig.caPath) : undefined,\n   101→        requestCert: tlsConfig.requireClientCert,\n   102→        rejectUnauthorized: tlsConfig.requireClientCert,\n   103→      });\n   104→      this.wss = new WebSocketServer({ server: httpsServer });\n   105→      httpsServer.listen(port);\n   106→      this.logger.info({ port, tls: true, mTLS: tlsConfig.requireClientCert }, 'Worker pool listening (WSS)');\n   107→    } else {\n   108→      this.wss = new WebSocketServer({ port });\n   109→      this.logger.info({ port, tls: false }, 'Worker pool listening (WS — plaintext)');\n   110→    }\n   111→\n   112→    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n   113→      this.logger.info({ remoteAddr: req.socket.remoteAddress }, 'Worker connection attempt');\n   114→\n   115→      // Validate worker token from Authorization header (timing-safe comparison)\n   116→      const authHeader = req.headers.authorization;\n   117→      const token = authHeader?.startsWith('Bearer ') ? authHeader.slice(7) : null;\n   118→      if (!token || !timingSafeTokenEqual(token, this.expectedWorkerToken)) {\n   119→        this.logger.warn({ remoteAddr: req.socket.remoteAddress }, 'Worker rejected: invalid token');\n   120→        ws.close(1008, 'Invalid worker token');\n   121→        return;\n   122→      }\n   123→\n   124→      this.handleConnection(ws);\n   125→    });\n   126→\n   127→    this.wss.on('error', (err) => {\n   128→      this.logger.error({ err }, 'WebSocket server error');\n   129→    });\n   130→  }\n   131→\n   132→  private handleConnection(ws: WebSocket): void {\n   133→    let workerId: string | null = null;\n 