[2026-03-18T11:54:34.197Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xs4QKDiEGYYNs8XfSc44ZV","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import { nanoid } from 'nanoid';\n     3→import type { PersonaExecution } from '@dac-cloud/shared';\n     4→import { stmt, createRowMapper, buildWhereClause } from './_helpers.js';\n     5→\n     6→// ---------------------------------------------------------------------------\n     7→// Row mapper\n     8→// ---------------------------------------------------------------------------\n     9→\n    10→const rowToExecution = createRowMapper<PersonaExecution>({\n    11→  id: { col: 'id' },\n    12→  projectId: { col: 'project_id', default: 'default' },\n    13→  personaId: { col: 'persona_id' },\n    14→  triggerId: { col: 'trigger_id', nullable: true },\n    15→  useCaseId: { col: 'use_case_id', nullable: true },\n    16→  status: { col: 'status' },\n    17→  inputData: { col: 'input_data', nullable: true },\n    18→  outputData: { col: 'output_data', nullable: true },\n    19→  claudeSessionId: { col: 'claude_session_id', nullable: true },\n    20→  modelUsed: { col: 'model_used', nullable: true },\n    21→  inputTokens: { col: 'input_tokens', default: 0 },\n    22→  outputTokens: { col: 'output_tokens', default: 0 },\n    23→  costUsd: { col: 'cost_usd', default: 0 },\n    24→  errorMessage: { col: 'error_message', nullable: true },\n    25→  durationMs: { col: 'duration_ms', nullable: true },\n    26→  retryOfExecutionId: { col: 'retry_of_execution_id', nullable: true },\n    27→  retryCount: { col: 'retry_count', default: 0 },\n    28→  startedAt: { col: 'started_at', nullable: true },\n    29→  completedAt: { col: 'completed_at', nullable: true },\n    30→  createdAt: { col: 'created_at' },\n    31→});\n    32→\n    33→// ---------------------------------------------------------------------------\n    34→// CRUD\n    35→// ---------------------------------------------------------------------------\n    36→\n    37→export function createExecution(db: Database.Database, input: {\n    38→  id?: string; personaId: string; triggerId?: string | null; useCaseId?: string | null; inputData?: string | null; projectId?: string;\n    39→}): PersonaExecution {\n    40→  const now = new Date().toISOString();\n    41→  const id = input.id ?? nanoid();\n    42→  const projectId = input.projectId ?? 'default';\n    43→  const triggerId = input.triggerId ?? null;\n    44→  const useCaseId = input.useCaseId ?? null;\n    45→  const inputData = input.inputData ?? null;\n    46→  stmt(db,`\n    47→    INSERT INTO persona_executions (id, project_id, persona_id, trigger_id, use_case_id, status, input_data, created_at)\n    48→    VALUES (?, ?, ?, ?, ?, 'queued', ?, ?)\n    49→  `).run(id, projectId, input.personaId, triggerId, useCaseId, inputData, now);\n    50→  return {\n    51→    id,\n    52→    projectId,\n    53→    personaId: input.personaId,\n    54→    triggerId,\n    55→    useCaseId,\n    56→    status: 'queued',\n    57→    inputData,\n    58→    outputData: null,\n    59→    claudeSessionId: null,\n    60→    modelUsed: null,\n    61→    inputTokens: 0,\n    62→    outputTokens: 0,\n    63→    costUsd: 0,\n    64→    errorMessage: null,\n    65→    durationMs: null,\n    66→    retryOfExecutionId: null,\n    67→    retryCount: 0,\n    68→    startedAt: null,\n    69→    completedAt: null,\n    70→    createdAt: now,\n    71→  };\n    72→}\n    73→\n    74→export function getExecution(db: Database.Database, id: string): PersonaExecution | undefined {\n    75→  const row = stmt(db,'SELECT * FROM persona_executions WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n    76→  return row ? rowToExecution(row) : undefined;\n    77→}\n    78→\n    79→export function listExecutions(db: Database.Database, opts?: {\n    80→  personaId?: string; status?: string; limit?: number; offset?: number; projectId?: string;\n    81→}): PersonaExecution[] {\n    82→  const { sql: where, params } = buildWhereClause(\n    83→    { projectId: opts?.projectId, personaId: opts?.personaId, status: opts?.status },\n    84→    { projectId: 'project_id', personaId: 'persona_id', status: 'status' },\n    85→  );\n    86→  const limit = opts?.limit ?? 50;\n    87→  const offset = opts?.offset ?? 0;\n    88→  const rows = stmt(db,`SELECT * FROM persona_executions ${where} ORDER BY created_at DESC LIMIT ? OFFSET ?`).all(...params, limit, offset) as Record<string, unknown>[];\n    89→  return rows.map(rowToExecution);\n    90→}\n    91→\n    92→export function updateExecution(db: Database.Database, id: string, updates: Record<string, unknown>): void {\n    93→  const fields: string[] = [];\n    94→  const values: unknown[] = [];\n    95→\n    96→  const columnMap: Record<string, string> = {\n    97→    status: 'status',\n    98→    outputData: 'output_data',\n    99→    claudeSessionId: 'claude_session_id',\n   100→    modelUsed: 'model_used',\n   101→    inputTokens: 'input_tokens',\n   102→    outputTokens: 'output_tokens',\n   103→    costUsd: 'cost_usd',\n   104→    errorMessage: 'error_message',\n   105→    durationMs: 'duration_ms',\n   106→    startedAt: 'started_at',\n   107→    completedAt: 'completed_at',\n   108→  };\n   109→\n   110→  for (const [key, col] of Object.entries(columnMap)) {\n   111→    if (key in updates) {\n   112→      fields.push(`${col} = ?`);\n   113→      values.push(updates[key]);\n   114→    }\n   115→  }\n   116→\n   117→  if (fields.length === 0) return;\n   118→  values.push(id);\n   119→  stmt(db,`UPDATE persona_executions SET ${fields.join(', ')} WHERE id = ?`).run(...values);\n   120→}\n   121→\n   122→export function appendOutput(db: Database.Database, id: string, chunk: string): void {\n   123→  stmt(db,`\n   124→    UPDATE persona_executions SET output_data = COALESCE(output_data, '') || ? WHERE id = ?\n   125→  `).run(chunk, id);\n   126→}\n   127→\n   128→export function countRunningExecutions(db: Database.Database, personaId: string): number {\n   129→  const row = stmt(db,\"SELECT COUNT(*) as cnt FROM persona_executions WHERE persona_id = ? AND status = 'running'\").get(personaId) as { cnt: number };\n   130→  return row.cnt;\n   131→}\n   132→\n   133→/** Batch-count running executions for multiple personas. Returns a Map keyed by persona ID. */\n   134→export function countRunningExecutionsByPersonaIds(db: Database.Database, personaIds: string[]): Map<string, number> {\n   135→  const map = new Map<string, number>();\n   136→  if (personaIds.length === 0) return map;\n   137→  const placeholders = personaIds.map(() => '?').join(',');\n   138→  const rows = db.prepare(\n   139→    `SELECT persona_id, COUNT(*) as cnt FROM persona_executions WHERE persona_id IN (${placeholders}) AND status = 'running' GROUP BY persona_id`\n   140→  ).all(...personaIds) as Array<{ persona_id: string; cnt: number }>;\n   141→  for (const row of rows) {\n   142→    map.set(row.persona_id, row.cnt);\n   143→  }\n   144→  return map;\n   145→}\n   146→"}]},"parent_tool_use_id":null,"session_id":"da887717-607b-4e0c-93f9-db7f0cbe8830","uuid":"9963ae72-af9a-44f2-8f35-75785bc67474","timestamp":"2026-03-18T11:54:34.117Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\db\\executions.ts","content":"import Database from 'better-sqlite3';\nimport { nanoid } from 'nanoid';\nimport type { PersonaExecution } from '@dac-cloud/shared';\nimport { stmt, createRowMapper, buildWhereClause } from './_helpers.js';\n\n// ---------------------------------------------------------------------------\n// Row mapper\n// ---------------------------------------------------------------------------\n\nconst rowToExecution = createRowMapper<PersonaExecution>({\n  id: { col: 'id' },\n  projectId: { col: 'project_id', default: 'default' },\n  personaId: { col: 'persona_id' },\n  triggerId: { col: 'trigger_id', nullable: true },\n  useCaseId: { col: 'use_case_id', nullable: true },\n  status: { col: 'status' },\n  inputData: { col: 'input_data', nullable: true },\n  outputData: { col: 'output_data', nullable: true },\n  claudeSessionId: { col: 'claude_session_id', nullable: true },\n  modelUsed: { col: 'model_used', nullable: true },\n  inputTokens: { col: 'input_tokens', default: 0 },\n  outputTokens: { col: 'output_tokens', default: 0 },\n  costUsd: { col: 'cost_usd', default: 0 },\n  errorMessage: { col: 'error_message', nullable: true },\n  durationMs: { col: 'duration_ms', nullable: true },\n  retryOfExecutionId: { col: 'retry_of_execution_id', nullable: true },\n  retryCount: { col: 'retry_count', default: 0 },\n  startedAt: { col: 'started_at', nullable: true },\n  completedAt: { col: 'completed_at', nullable: true },\n  createdAt: { col: 'created_at' },\n});\n\n// ---------------------------------------------------------------------------\n// CRUD\n// ---------------------------------------------------------------------------\n\nexport function createExecution(db: Database.Database, input: {\n  id?: string; personaId: string; triggerId?: string | null; useCaseId?: string | null; inputData?: string | null; projectId?: string;\n}): PersonaExecution {\n  const now = new Date().toISOString();\n  const id = input.id ?? nanoid();\n  const projectId = input.projectId ?? 'default';\n  const triggerId = input.triggerId ?? null;\n  const useCaseId = input.useCaseId ?? null;\n  const inputData = input.inputData ?? null;\n  stmt(db,`\n    INSERT INTO persona_executions (id, project_id, persona_id, trigger_id, use_case_id, status, input_data, created_at)\n    VALUES (?, ?, ?, ?, ?, 'queued', ?, ?)\n  `).run(id, projectId, input.personaId, triggerId, useCaseId, inputData, now);\n  return {\n    id,\n    projectId,\n    personaId: input.personaId,\n    triggerId,\n    useCaseId,\n    status: 'queued',\n    inputData,\n    outputData: null,\n    claudeSessionId: null,\n    modelUsed: null,\n    inputTokens: 0,\n    outputTokens: 0,\n    costUsd: 0,\n    errorMessage: null,\n    durationMs: null,\n    retryOfExecutionId: null,\n    retryCount: 0,\n    startedAt: null,\n    completedAt: null,\n    createdAt: now,\n  };\n}\n\nexport function getExecution(db: Database.Database, id: string): PersonaExecution | undefined {\n  const row = stmt(db,'SELECT * FROM persona_executions WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n  return row ? rowToExecution(row) : undefined;\n}\n\nexport function listExecutions(db: Database.Database, opts?: {\n  personaId?: string; status?: string; limit?: number; offset?: number; projectId?: string;\n}): PersonaExecution[] {\n  const { sql: where, params } = buildWhereClause(\n    { projectId: opts?.projectId, personaId: opts?.personaId, status: opts?.status },\n    { projectId: 'project_id', personaId: 'persona_id', status: 'status' },\n  );\n  const limit = opts?.limit ?? 50;\n  const offset = opts?.offset ?? 0;\n  const rows = stmt(db,`SELECT * FROM persona_executions ${where} ORDER BY created_at DESC LIMIT ? OFFSET ?`).all(...params, limit, offset) as Record<string, unknown>[];\n  return rows.map(rowToExecution);\n}\n\nexport function updateExecution(db: Database.Database, id: string, updates: Record<string, unknown>): void {\n  const fields: string[] = [];\n  const values: unknown[] = [];\n\n  const columnMap: Record<string, string> = {\n    status: 'status',\n    outputData: 'output_data',\n    claudeSessionId: 'claude_session_id',\n    modelUsed: 'model_used',\n    inputTokens: 'input_tokens',\n    outputTokens: 'output_tokens',\n    costUsd: 'cost_usd',\n    errorMessage: 'error_message',\n    durationMs: 'duration_ms',\n    startedAt: 'started_at',\n    completedAt: 'completed_at',\n  };\n\n  for (const [key, col] of Object.entries(columnMap)) {\n    if (key in updates) {\n      fields.push(`${col} = ?`);\n      values.push(updates[key]);\n    }\n  }\n\n  if (fields.length === 0) return;\n  values.push(id);\n  stmt(db,`UPDATE persona_executions SET ${fields.join(', ')} WHERE id = ?`).run(...values);\n}\n\nexport function appendOutput(db: Database.Database, id: string, chunk: string): void {\n  stmt(db,`\n    UPDATE persona_executions SET output_data = COALESCE(output_data, '') || ? WHERE id = ?\n  `).run(chunk, id);\n}\n\nexport function countRunningExecutions(db: Database.Database, personaId: string): number {\n  const row = stmt(db,\"SELECT COUNT(*) as cnt FROM persona_executions WHERE persona_id = ? AND status = 'running'\").get(personaId) as { cnt: number };\n  return row.cnt;\n}\n\n/** Batch-count running executions for multiple personas. Returns a Map keyed by persona ID. */\nexport function countRunningExecutionsByPersonaIds(db: Database.Database, personaIds: string[]): Map<string, number> {\n  const map = new Map<string, number>();\n  if (personaIds.length === 0) return map;\n  const placeholders = personaIds.map(() => '?').join(',');\n  const rows = db.prepare(\n    `SELECT persona_id, COUNT(*) as cnt FROM persona_executions WHERE persona_id IN (${placeholders}) AND status = 'running' GROUP BY persona_id`\n  ).all(...personaIds) as Array<{ persona_id: string; cnt: number }>;\n  for (const row of rows) {\n    map.set(row.persona_id, row.cnt);\n  }\n  return map;\n}\n","numLines":146,"startLine":1,"totalLines":146}}}
