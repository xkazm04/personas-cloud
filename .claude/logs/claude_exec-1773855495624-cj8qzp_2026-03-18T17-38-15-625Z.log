k(\n  database: Database.Database,\n  logger: Logger,\n  projectId?: string,\n  onEventPublished?: () => void,\n): void {\n  const triggers = db.getDueTriggersWithPersona(database);\n  if (triggers.length === 0) return;\n\n  for (const trigger of triggers) {\n    // Skip polling triggers (handled separately if needed)\n    if (trigger.triggerType === 'polling') continue;\n\n    try {\n      // Use pre-parsed typed config — no JSON.parse in the hot path\n      const parsedConfig = trigger.parsedConfig;\n\n      let eventType = 'trigger_fired';\n      let payload: string | null = null;\n      if (parsedConfig) {\n        if (parsedConfig.event_type) eventType = parsedConfig.event_type;\n        if (parsedConfig.payload) payload = JSON.stringify(parsedConfig.payload);\n      }\n\n      // Skip triggers for deleted or disabled personas (persona info from JOIN)\n      if (trigger.personaProjectId == null) {\n        logger.warn({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona not found (deleted?)');\n        continue;\n      }\n      if (!trigger.personaEnabled) {\n        logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');\n        continue;\n      }\n\n      const triggerProjectId = projectId ?? trigger.personaProjectId;\n\n      // Publish event to bus\n      db.publishEvent(database, {\n        eventType,\n        sourceType: 'trigger',\n        sourceId: trigger.id,\n        targetPersonaId: trigger.personaId,\n        projectId: triggerProjectId,\n        useCaseId: trigger.useCaseId,\n        payload,\n      });\n      onEventPublished?.();\n\n      // Compute next trigger time using already-parsed config\n      const now = new Date().toISOString();\n      const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);\n\n      db.updateTriggerTimings(database, trigger.id, now, nextTriggerAt);\n\n      logger.info({\n        triggerId: trigger.id,\n        personaId: trigger.personaId,\n        eventType,\n        nextTriggerAt,\n      }, 'Trigger fired');\n    } catch (err) {\n      logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');\n    }\n  }\n}\n","numLines":103,"startLine":1,"totalLines":103}}}
