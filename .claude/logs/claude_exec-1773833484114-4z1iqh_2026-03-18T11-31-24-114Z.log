[2026-03-18T11:31:36.123Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ESXx8JKVg34NACUJk5urS4","type":"tool_result","content":"     1→import { type ExecAssign, type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type InferenceProfile, type NetworkPolicy, type EncryptedPayload, TOPICS, assemblePrompt, decrypt, deriveMasterKeyAsync, toEncryptedPayload, resolveEnvOverrides, parseNetworkPolicy } from '@dac-cloud/shared';\n     2→import type Database from 'better-sqlite3';\n     3→import type { WorkerPool } from './workerPool.js';\n     4→import type { TokenManager } from './tokenManager.js';\n     5→import type { OAuthManager } from './oauth.js';\n     6→import type { KafkaClient } from './kafka.js';\n     7→import type { TenantDbManager } from './tenantDbManager.js';\n     8→import type { TenantKeyManager } from './tenantKeyManager.js';\n     9→import type { AuditLog } from './auditLog.js';\n    10→import type { Logger } from 'pino';\n    11→import * as db from './db/index.js';\n    12→\n    13→interface QueuedExecution {\n    14→  request: ExecRequest;\n    15→  receivedAt: number;\n    16→}\n    17→\n    18→// In-memory tracking for active executions (real-time output streaming)\n    19→interface ActiveExecution {\n    20→  workerId: string;\n    21→  startedAt: number;\n    22→  output: string[];\n    23→  status: 'running' | 'completed' | 'failed' | 'cancelled';\n    24→  progress?: ProgressInfo;\n    25→  completedAt?: number;\n    26→  exitCode?: number;\n    27→  durationMs?: number;\n    28→  sessionId?: string;\n    29→  totalCostUsd?: number;\n    30→}\n    31→\n    32→const OUTPUT_FLUSH_INTERVAL_MS = 500;\n    33→\n    34→export class Dispatcher {\n    35→  private queue: QueuedExecution[] = [];\n    36→  // In-memory map for real-time output + cancel routing (active executions only)\n    37→  private active = new Map<string, ActiveExecution>();\n    38→  private tenantDbManager: TenantDbManager | null = null;\n    39→  private masterKey: Buffer | null = null;\n    40→  private tenantKeyManager: TenantKeyManager | null = null;\n    41→  private auditLog: AuditLog | null = null;\n    42→  // Maps executionId → projectId for DB resolution during callbacks\n    43→  private executionTenant = new Map<string, string>();\n    44→  // Batched output buffers: executionId → pending chunks\n    45→  private outputBuffers = new Map<string, string[]>();\n    46→  private outputFlushTimer: NodeJS.Timeout;\n    47→  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n    48→  private dispatching = false;\n    49→\n    50→  constructor(\n    51→    private pool: WorkerPool,\n    52→    private tokenManager: TokenManager,\n    53→    private oauth: OAuthManager | null,\n    54→    private kafka: KafkaClient,\n    55→    private logger: Logger,\n    56→  ) {\n    57→    // Periodic flush of batched output to DB\n    58→    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n    59→\n    60→    // When a worker becomes ready, try to dispatch queued work\n    61→    this.pool.on('worker-ready', () => {\n    62→      this.processQueue();\n    63→    });\n    64→\n    65→    // When a worker connects, try to dispatch\n    66→    this.pool.on('worker-connected', () => {\n    67→      this.processQueue();\n    68→    });\n    69→\n    70→    // Track stdout for execution output\n    71→    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n    72→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    73→    });\n    74→\n    75→    // Track stderr for debugging failed executions\n    76→    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n    77→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n    78→      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    79→    });\n    80→\n    81→    // Handle execution completion\n    82→    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n    83→      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n    84→        executionId: msg.executionId,\n    85→        status: msg.status,\n    86→        exitCode: msg.exitCode,\n    87→        durationMs: msg.durationMs,\n    88→        sessionId: msg.sessionId,\n    89→        totalCostUsd: msg.totalCostUsd,\n    90→      }), msg.executionId).catch(err => {\n    91→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n    92→      });\n    93→\n    94→      // Flush any remaining buffered output before persisting completion\n    95→      this.flushOutputForExecution(msg.executionId);\n    96→\n    97→      // Update in-memory\n    98→      const exec = this.active.get(msg.executionId);\n    99→      if (exec) {\n   100→        exec.status = msg.status;\n   101→        exec.completedAt = Date.now();\n   102→        exec.exitCode = msg.exitCode;\n   103→        exec.durationMs = msg.durationMs;\n   104→        exec.sessionId = msg.sessionId;\n   105→        exec.totalCostUsd = msg.totalCostUsd;\n   106→        // Remove from active after a short delay (allow polling to pick up final state)\n   107→        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n   108→      }\n   109→\n   110→      // Persist to DB\n   111→      const completeDb = this.resolveDbForExecution(msg.executionId);\n   112→      if (completeDb) {\n   113→        try {\n   114→          db.updateExecution(completeDb, msg.executionId, {\n   115→            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n   116→            completedAt: new Date().toISOString(),\n   117→            durationMs: msg.durationMs,\n   118→            claudeSessionId: msg.sessionId,\n   119→            costUsd: msg.totalCostUsd ?? 0,\n   120→          });\n   121→        } catch (err) {\n   122→          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n   123→        }\n   124→      }\n   125→\n   126→      // Clean up tenant mapping after completion delay\n   127→      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n   128→\n   129→      // Process next queued item\n   130→      this.processQueue();\n   131→    });\n   132→\n   133→    // Track execution progress\n   134→    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n   135→      const exec = this.active.get(msg.executionId);\n   136→      if (exec) {\n   137→        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n   138→      }\n   139→      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n   140→        executionId: msg.executionId,\n   141→        phase: msg.phase,\n   142→        percent: msg.percent,\n   143→        detail: msg.detail,\n   144→        timestamp: msg.timestamp,\n   145→      }), msg.executionId).catch(err => {\n   146→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n   147→      });\n   148→    });\n   149→\n   150→    // Forward persona events to Kafka\n   151→    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n   152→      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n   153→        executionId: msg.executionId,\n   154→        eventType: msg.eventType,\n   155→        payload: msg.payload,\n   156→        timestamp: Date.now(),\n   157→      }), msg.executionId).catch(err => {\n   158→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n   159→      });\n   160→    });\n   161→\n   162→    // Handle worker busy nack — re-queue the rejected execution\n   163→    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n   164→      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n   165→      const exec = this.active.get(msg.executionId);\n   166→      if (exec) {\n   167→        this.active.delete(msg.executionId);\n   168→      }\n   169→      // Re-queue so it can be dispatched to another idle worker\n   170→      const projectId = this.executionTenant.get(msg.executionId) || 'default';\n   171→      const reqDb = this.resolveDb(projectId);\n   172→      if (reqDb) {\n   173→        try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch { /* best effort */ }\n   174→      }\n   175→      // Reconstruct a minimal request from what we know and re-queue\n   176→      // The execution was already created in the DB, so we need to find the original request data\n   177→      const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n   178→      if (dbExec) {\n   179→        this.queue.unshift({\n   180→          request: {\n   181→            executionId: msg.executionId,\n   182→            personaId: dbExec.personaId,\n   183→            prompt: dbExec.inputData || '',\n   184→            projectId,\n   185→            config: { timeoutMs: 300_000 },\n   186→          },\n   187→          receivedAt: Date.now(),\n   188→        });\n   189→        this.processQueue();\n   190→      }\n   191→    });\n   192→\n   193→    // Handle worker disconnect during execution\n   194→    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n   195→      if (executionId) {\n   196→        this.logger.error({ executionId }, 'Worker disconnected during execution');\n   197→        const exec = this.active.get(executionId);\n   198→        if (exec) {\n   199→          exec.status = 'failed';\n   200→          exec.completedAt = Date.now();\n   201→          setTimeout(() => this.active.delete(executionId), 30_000);\n   202→        }\n   203→\n   204→        // Persist failure\n   205→        const disconnDb = this.resolveDbForExecution(executionId);\n   206→        if (disconnDb) {\n   207→          try {\n   208→            db.updateExecution(disconnDb, executionId, {\n   209→              status: 'failed',\n   210→              errorMessage: 'Worker disconnected',\n   211→              completedAt: new Date().toISOString(),\n   212→            });\n   213→          } catch { /* best effort */ }\n   214→        }\n   215→        this.executionTenant.delete(executionId);\n   216→\n   217→        this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   218→          executionId,\n   219→          status: 'failed',\n   220→          error: 'Worker disconnected',\n   221→          durationMs: 0,\n   222→        }), executionId).catch(() => {});\n   223→      }\n   224→    });\n   225→  }\n   226→\n   227→  setTenantDbManager(mgr: TenantDbManager): void {\n   228→    this.tenantDbManager = mgr;\n   229→  }\n   230→\n   231→  async setMasterKey(masterKeyHex: string): Promise<void> {\n   232→    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n   233→  }\n   234→\n   235→  setTenantKeyManager(mgr: TenantKeyManager): void {\n   236→    this.tenantKeyManager = mgr;\n   237→  }\n   238→\n   239→  setAuditLog(log: AuditLog): void {\n   240→    this.auditLog = log;\n   241→  }\n   242→\n   243→  /** Resolve the database for a given projectId via tenant DB manager. */\n   244→  private resolveDb(projectId?: string): Database.Database | null {\n   245→    if (this.tenantDbManager && projectId) {\n   246→      return this.tenantDbManager.getTenantDb(projectId);\n   247→    }\n   248→    return null;\n   249→  }\n   250→\n   251→  /** Resolve the database for an in-flight execution by its ID. */\n   252→  private resolveDbForExecution(executionId: string): Database.Database | null {\n   253→    const projectId = this.executionTenant.get(executionId);\n   254→    return this.resolveDb(projectId);\n   255→  }\n   256→\n   257→  /**\n   258→   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   259→   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   260→   */\n   261→  private async decryptWithAudit(\n   262→    payload: EncryptedPayload,\n   263→    tenantId: string,\n   264→    resourceId: string,\n   265→    logContext: Record<string, unknown>,\n   266→    logMessage: string,\n   267→  ): Promise<string | undefined> {\n   268→    const decryptKey = this.tenantKeyManager\n   269→      ? await this.tenantKeyManager.getKey(tenantId)\n   270→      : this.masterKey;\n   271→    if (!decryptKey) return undefined;\n   272→\n   273→    try {\n   274→      const decrypted = decrypt(payload, decryptKey);\n   275→      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n   276→      return decrypted;\n   277→    } catch (err) {\n   278→      const reason = err instanceof Error ? err.message : String(err);\n   279→      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n   280→      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: reason }); } catch { /* logged inside record() */ }\n   281→      return undefined;\n   282→    }\n   283→  }\n   284→\n   285→  submit(request: ExecRequest): void {\n   286→    this.logger.info({\n   287→      executionId: request.executionId,\n   288→      personaId: request.personaId,\n   289→    }, 'Execution submitted');\n   290→\n   291→    // Track which tenant owns this execution (for callback DB resolution)\n   292→    const projectId = request.projectId || 'default';\n   293→    this.executionTenant.set(request.executionId, projectId);\n   294→\n   295→    // Create DB record immediately\n   296→    const submitDb = this.resolveDb(projectId);\n   297→    if (submitDb) {\n   298→      try {\n   299→        db.createExecution(submitDb, {\n   300→          id: request.executionId,\n   301→          personaId: request.personaId,\n   302→          inputData: request.prompt,\n   303→          projectId,\n   304→        });\n   305→      } catch (err) {\n   306→        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n   307→      }\n   308→    }\n   309→\n   310→    this.queue.push({ request, receivedAt: Date.now() });\n   311→    this.processQueue();\n   312→  }\n   313→\n   314→  private async processQueue(): Promise<void> {\n   315→    // Guard: only one processQueue loop runs at a time to prevent concurrent\n   316→    // calls from racing on getIdleWorker()/assign() and double-claiming a worker.\n   317→    if (this.dispatching) return;\n   318→    this.dispatching = true;\n   319→    try {\n   320→      while (this.queue.length > 0) {\n   321→        const workerId = this.pool.getIdleWorker();\n   322→        if (!workerId) {\n   323→          this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n   324→          return;\n   325→        }\n   326→\n   327→        const item = this.queue.shift()!;\n   328→        await this.dispatchToWorker(workerId, item.request);\n   329→      }\n   330→    } finally {\n   331→      this.dispatching = false;\n   332→    }\n   333→  }\n   334→\n   335→  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n   336→    // Try to get a fresh token via OAuth (auto-refreshes if near expiry)\n   337→    let claudeToken: string | null = null;\n   338→    if (this.oauth?.hasTokens()) {\n   339→      claudeToken = await this.oauth.getValidAccessToken();\n   340→      if (claudeToken) {\n   341→        this.tokenManager.storeClaudeToken(claudeToken);\n   342→      }\n   343→    }\n   344→    // Fallback to stored token\n   345→    if (!claudeToken) {\n   346→      claudeToken = this.tokenManager.getClaudeToken();\n   347→    }\n   348→    if (!claudeToken) {\n   349→      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n   350→      this.queue.unshift({ request, receivedAt: Date.now() });\n   351→      return;\n   352→    }\n   353→\n   354→    // Build environment variables for the worker\n   355→    const env: Record<string, string> = {\n   356→      ANTHROPIC_API_KEY: claudeToken,\n   357→    };\n   358→\n   359→    // If persona exists in DB, assemble prompt from persona config and inject credentials\n   360→    let prompt = request.prompt;\n   361→    const dispatchDb = this.resolveDb(request.projectId || 'default');\n   362→    const persona = dispatchDb ? db.getPersona(dispatchDb, request.personaId) : null;\n   363→    if (dispatchDb) {\n   364→      if (persona) {\n   365→        const tools = db.getToolsForPersona(dispatchDb, persona.id);\n   366→        const creds = db.listCredentialsForPersona(dispatchDb, persona.id);\n   367→\n   368→        // Decrypt credentials and inject as env vars\n   369→        const credentialHints: string[] = [];\n   370→        const tenantId = request.projectId || 'default';\n   371→        for (const cred of creds) {\n   372→          const envName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   373→          credentialHints.push(envName);\n   374→\n   375→          const decrypted = await this.decryptWithAudit(\n   376→            toEncryptedPayload(cred),\n   377→            tenantId,\n   378→            cred.id,\n   379→            { credentialId: cred.id, credentialName: cred.name },\n   380→            'Failed to decrypt credential',\n   381→          );\n   382→          if (decrypted !== undefined) {\n   383→            // Try to parse as JSON with multiple fields\n   384→            try {\n   385→              const fields = JSON.parse(decrypted) as Record<string, string>;\n   386→              for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n   387→                const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   388→                env[fieldEnvName] = String(fieldValue);\n   389→              }\n   390→            } catch {\n   391→              // Not JSON — inject as single value\n   392→              env[envName] = decrypted;\n   393→            }\n   394→          }\n   395→        }\n   396→\n   397→        const inputData = request.inputData ? (request.inputData as Record<string, unknown>) : undefined;\n   398→        prompt = assemblePrompt(persona, tools, inputData, credentialHints.length > 0 ? credentialHints : undefined);\n   399→\n   400→        // Apply inference profile or legacy model profile env overrides\n   401→        let inferenceProfile: InferenceProfile | undefined;\n   402→        if (persona.inferenceProfileId) {\n   403→          inferenceProfile = db.getInferenceProfile(dispatchDb, persona.inferenceProfileId);\n   404→        }\n   405→        if (inferenceProfile) {\n   406→          // Decrypt auth token first so resolveEnvOverrides can map it to env vars\n   407→          let decryptedAuthToken: string | undefined;\n   408→          if (inferenceProfile.authTokenEncrypted && inferenceProfile.authTokenIv && inferenceProfile.authTokenTag) {\n   409→            decryptedAuthToken = await this.decryptWithAudit(\n   410→              { encrypted: inferenceProfile.authTokenEncrypted, iv: inferenceProfile.authTokenIv, tag: inferenceProfile.authTokenTag },\n   411→              tenantId,\n   412→              `inference-profile:${inferenceProfile.id}`,\n   413→              { profileId: inferenceProfile.id },\n   414→              'Failed to decrypt inference profile auth token',\n   415→            );\n   416→          }\n   417→          const overrides = resolveEnvOverrides(inferenceProfile, decryptedAuthToken);\n   418→          for (const [k, v] of Object.entries(overrides.set)) env[k] = v;\n   419→          for (const k of overrides.remove) delete env[k];\n   420→        }\n   421→\n   422→        this.logger.info({ personaId: persona.id, toolCount: tools.length, credCount: creds.length }, 'Assembled prompt from DB persona');\n   423→      }\n   424→    }\n   425→\n   426→    // Resolve network policy from persona config\n   427→    let networkPolicy: NetworkPolicy | undefined;\n   428→    if (persona?.networkPolicy) {\n   429→      networkPolicy = parseNetworkPolicy(persona.networkPolicy) ?? undefined;\n   430→    }\n   431→\n   432→    const assignment: ExecAssign = {\n   433→      type: 'assign',\n   434→      executionId: request.executionId,\n   435→      personaId: request.personaId,\n   436→      prompt,\n   437→      env,\n   438→      config: {\n   439→        timeoutMs: request.config.timeoutMs || 300_000,\n   440→        maxOutputBytes: 10 * 1024 * 1024, // 10MB\n   441→        ...(networkPolicy ? { networkPolicy } : {}),\n   442→        ...(persona?.maxBudgetUsd ? { maxBudgetUsd: persona.maxBudgetUsd } : {}),\n   443→        ...(persona?.maxTurns ? { maxTurns: persona.maxTurns } : {}),\n   444→      },\n   445→    };\n   446→\n   447→    // Track in-memory for real-time streaming\n   448→    this.active.set(request.executionId, {\n   449→      workerId,\n   450→      startedAt: Date.now(),\n   451→      output: [],\n   452→      status: 'running',\n   453→    });\n   454→\n   455→    // Mark running in DB\n   456→    if (dispatchDb) {\n   457→      try {\n   458→        db.updateExecution(dispatchDb, request.executionId, {\n   459→          status: 'running',\n   460→          startedAt: new Date().toISOString(),\n   461→        });\n   462→      } catch { /* best effort */ }\n   463→    }\n   464→\n   465→    const sent = this.pool.assign(workerId, assignment);\n   466→    if (!sent) {\n   467→      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n   468→      this.active.delete(request.executionId);\n   469→      if (dispatchDb) {\n   470→        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch { /* best effort */ }\n   471→      }\n   472→      // Re-queue and retry dispatch — another idle worker may be available\n   473→      this.queue.unshift({ request, receivedAt: Date.now() });\n   474→      this.processQueue();\n   475→    } else {\n   476→      this.logger.info({\n   477→        workerId,\n   478→        executionId: request.executionId,\n   479→        personaId: request.personaId,\n   480→      }, 'Execution dispatched to worker');\n   481→    }\n   482→  }\n   483→\n   484→  cancelExecution(executionId: string): boolean {\n   485→    const exec = this.active.get(executionId);\n   486→    if (!exec || exec.status !== 'running') return false;\n   487→\n   488→    return this.pool.send(exec.workerId, {\n   489→      type: 'cancel',\n   490→      executionId,\n   491→    });\n   492→  }\n   493→\n   494→  getQueueLength(): number {\n   495→    return this.queue.length;\n   496→  }\n   497→\n   498→  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n   499→    return Array.from(this.active.entries())\n   500→      .filter(([, e]) => e.status === 'running')\n   501→      .map(([executionId, e]) => ({\n   502→        executionId,\n   503→        workerId: e.workerId,\n   504→        startedAt: e.startedAt,\n   505→      }));\n   506→  }\n   507→\n   508→  /**\n   509→   * Get execution state. Tries in-memory first (for real-time output),\n   510→   * then falls back to DB for completed/historical executions.\n   511→   */\n   512→  getExecution(executionId: string): ActiveExecution | null {\n   513→    // Check in-memory active executions first\n   514→    const active = this.active.get(executionId);\n   515→    if (active) return active;\n   516→\n   517→    const execDb = this.resolveDbForExecution(executionId);\n   518→    if (execDb) {\n   519→      const dbExec = db.getExecution(execDb, executionId);\n   520→      if (dbExec) {\n   521→        return {\n   522→          workerId: '',\n   523→          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n   524→          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n   525→          status: dbExec.status as ActiveExecution['status'],\n   526→          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n   527→          durationMs: dbExec.durationMs ?? undefined,\n   528→          sessionId: dbExec.claudeSessionId ?? undefined,\n   529→          totalCostUsd: dbExec.costUsd ?? undefined,\n   530→        };\n   531→      }\n   532→    }\n   533→\n   534→    return null;\n   535→  }\n   536→\n   537→  getExecutionOutput(executionId: string): string[] | null {\n   538→    const exec = this.getExecution(executionId);\n   539→    return exec?.output ?? null;\n   540→  }\n   541→\n   542→  /** Shared handler for stdout/stderr output chunks. */\n   543→  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n   544→    const line = prefix ? `${prefix}${chunk}` : chunk;\n   545→\n   546→    const exec = this.active.get(executionId);\n   547→    if (exec) {\n   548→      exec.output.push(line);\n   549→    }\n   550→\n   551→    this.bufferOutput(executionId, line + '\\n');\n   552→\n   553→    // Forward stdout to Kafka (stderr is not forwarded)\n   554→    if (!prefix) {\n   555→      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n   556→        executionId,\n   557→        chunk,\n   558→        timestamp,\n   559→      }), executionId).catch(err => {\n   560→        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n   561→      });\n   562→    }\n   563→  }\n   564→\n   565→  /** Buffer an output chunk for batched DB write. */\n   566→  private bufferOutput(executionId: string, chunk: string): void {\n   567→    let buf = this.outputBuffers.get(executionId);\n   568→    if (!buf) {\n   569→      buf = [];\n   570→      this.outputBuffers.set(executionId, buf);\n   571→    }\n   572→    buf.push(chunk);\n   573→  }\n   574→\n   575→  /** Flush buffered output for a specific execution to DB. */\n   576→  private flushOutputForExecution(executionId: string): void {\n   577→    const buf = this.outputBuffers.get(executionId);\n   578→    if (!buf || buf.length === 0) return;\n   579→\n   580→    const combined = buf.join('');\n   581→    this.outputBuffers.delete(executionId);\n   582→\n   583→    const outputDb = this.resolveDbForExecution(executionId);\n   584→    if (outputDb) {\n   585→      try { db.appendOutput(outputDb, executionId, combined); } catch { /* best effort */ }\n   586→    }\n   587→  }\n   588→\n   589→  /** Flush all buffered output across all executions to DB. */\n   590→  private flushOutputBuffers(): void {\n   591→    for (const executionId of this.outputBuffers.keys()) {\n   592→      this.flushOutputForExecution(executionId);\n   593→    }\n   594→  }\n   595→\n   596→  shutdown(): void {\n   597→    clearInterval(this.outputFlushTimer);\n   598→    this.flushOutputBuffers();\n   599→  }\n   600→}\n   601→"}]},"parent_tool_use_id":null,"session_id":"b500da2d-9507-4008-8b1b-785ca760ac43","uuid":"0449554c-4a98-4beb-97fd-2cf002f54752","timestamp":"2026-03-18T11:31:35.639Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\dispatcher.ts","content":"import { type ExecAssign, type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type InferenceProfile, type NetworkPolicy, type EncryptedPayload, TOPICS, assemblePrompt, decrypt, deriveMasterKeyAsync, toEncryptedPayload, resolveEnvOverrides, parseNetworkPolicy } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\n\ninterface QueuedExecution {\n  request: ExecRequest;\n  receivedAt: number;\n}\n\n// In-memory tracking for active executions (real-time output streaming)\ninterface ActiveExecution {\n  workerId: string;\n  startedAt: number;\n  output: string[];\n  status: 'running' | 'completed' | 'failed' | 'cancelled';\n  progress?: ProgressInfo;\n  completedAt?: number;\n  exitCode?: number;\n  durationMs?: number;\n  sessionId?: string;\n  totalCostUsd?: number;\n}\n\nconst OUTPUT_FLUSH_INTERVAL_MS = 500;\n\nexport class Dispatcher {\n  private queue: QueuedExecution[] = [];\n  // In-memory map for real-time output + cancel routing (active executions only)\n  private active = new Map<string, ActiveExecution>();\n  private tenantDbManager: TenantDbManager | null = null;\n  private masterKey: Buffer | null = null;\n  private tenantKeyManager: TenantKeyManager | null = null;\n  private auditLog: AuditLog | null = null;\n  // Maps executionId → projectId for DB resolution during callbacks\n  private executionTenant = new Map<string, string>();\n  // Batched output buffers: executionId → pending chunks\n  private outputBuffers = new Map<string, string[]>();\n  private outputFlushTimer: NodeJS.Timeout;\n  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n  private dispatching = false;\n\n  constructor(\n    private pool: WorkerPool,\n    private tokenManager: TokenManager,\n    private oauth: OAuthManager | null,\n    private kafka: KafkaClient,\n    private logger: Logger,\n  ) {\n    // Periodic flush of batched output to DB\n    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n\n    // When a worker becomes ready, try to dispatch queued work\n    this.pool.on('worker-ready', () => {\n      this.processQueue();\n    });\n\n    // When a worker connects, try to dispatch\n    this.pool.on('worker-connected', () => {\n      this.processQueue();\n    });\n\n    // Track stdout for execution output\n    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    });\n\n    // Track stderr for debugging failed executions\n    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    });\n\n    // Handle execution completion\n    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n        executionId: msg.executionId,\n        status: msg.status,\n        exitCode: msg.exitCode,\n        durationMs: msg.durationMs,\n        sessionId: msg.sessionId,\n        totalCostUsd: msg.totalCostUsd,\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n      });\n\n      // Flush any remaining buffered output before persisting completion\n      this.flushOutputForExecution(msg.executionId);\n\n      // Update in-memory\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.status = msg.status;\n        exec.completedAt = Date.now();\n        exec.exitCode = msg.exitCode;\n        exec.durationMs = msg.durationMs;\n        exec.sessionId = msg.sessionId;\n        exec.totalCostUsd = msg.totalCostUsd;\n        // Remove from active after a short delay (allow polling to pick up final state)\n        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n      }\n\n      // Persist to DB\n      const completeDb = this.resolveDbForExecution(msg.executionId);\n      if (completeDb) {\n        try {\n          db.updateExecution(completeDb, msg.executionId, {\n            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n            completedAt: new Date().toISOString(),\n            durationMs: msg.durationMs,\n            claudeSessionId: msg.sessionId,\n            costUsd: msg.totalCostUsd ?? 0,\n          });\n        } catch (err) {\n          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n        }\n      }\n\n      // Clean up tenant mapping after completion delay\n      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n\n      // Process next queued item\n      this.processQueue();\n    });\n\n    // Track execution progress\n    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n      }\n      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n        executionId: msg.executionId,\n        phase: msg.phase,\n        percent: msg.percent,\n        detail: msg.detail,\n        timestamp: msg.timestamp,\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n      });\n    });\n\n    // Forward persona events to Kafka\n    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n        executionId: msg.executionId,\n        eventType: msg.eventType,\n        payload: msg.payload,\n        timestamp: Date.now(),\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n      });\n    });\n\n    // Handle worker busy nack — re-queue the rejected execution\n    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        this.active.delete(msg.executionId);\n      }\n      // Re-queue so it can be dispatched to another idle worker\n      const projectId = this.executionTenant.get(msg.executionId) || 'default';\n      const reqDb = this.resolveDb(projectId);\n      if (reqDb) {\n        try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch { /* best effort */ }\n      }\n      // Reconstruct a minimal request from what we know and re-queue\n      // The execution was already created in the DB, so we need to find the original request data\n      const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n      if (dbExec) {\n        this.queue.unshift({\n          request: {\n            executionId: msg.executionId,\n            personaId: dbExec.personaId,\n            prompt: dbExec.inputData || '',\n            projectId,\n            config: { timeoutMs: 300_000 },\n          },\n          receivedAt: Date.now(),\n        });\n        this.processQueue();\n      }\n    });\n\n    // Handle worker disconnect during execution\n    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n      if (executionId) {\n        this.logger.error({ executionId }, 'Worker disconnected during execution');\n        const exec = this.active.get(executionId);\n        if (exec) {\n          exec.status = 'failed';\n          exec.completedAt = Date.now();\n          setTimeout(() => this.active.delete(executionId), 30_000);\n        }\n\n        // Persist failure\n        const disconnDb = this.resolveDbForExecution(executionId);\n        if (disconnDb) {\n          try {\n            db.updateExecution(disconnDb, executionId, {\n              status: 'failed',\n              errorMessage: 'Worker disconnected',\n              completedAt: new Date().toISOString(),\n            });\n          } catch { /* best effort */ }\n        }\n        this.executionTenant.delete(executionId);\n\n        this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n          executionId,\n          status: 'failed',\n          error: 'Worker disconnected',\n          durationMs: 0,\n        }), executionId).catch(() => {});\n      }\n    });\n  }\n\n  setTenantDbManager(mgr: TenantDbManager): void {\n    this.tenantDbManager = mgr;\n  }\n\n  async setMasterKey(masterKeyHex: string): Promise<void> {\n    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n  }\n\n  setTenantKeyManager(mgr: TenantKeyManager): void {\n    this.tenantKeyManager = mgr;\n  }\n\n  setAuditLog(log: AuditLog): void {\n    this.auditLog = log;\n  }\n\n  /** Resolve the database for a given projectId via tenant DB manager. */\n  private resolveDb(projectId?: string): Database.Database | null {\n    if (this.tenantDbManager && projectId) {\n      return this.tenantDbManager.getTenantDb(projectId);\n    }\n    return null;\n  }\n\n  /** Resolve the database for an in-flight execution by its ID. */\n  private resolveDbForExecution(executionId: string): Database.Database | null {\n    const projectId = this.executionTenant.get(executionId);\n    return this.resolveDb(projectId);\n  }\n\n  /**\n   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   */\n  private async decryptWithAudit(\n    payload: EncryptedPayload,\n    tenantId: string,\n    resourceId: string,\n    logContext: Record<string, unknown>,\n    logMessage: string,\n  ): Promise<string | undefined> {\n    const decryptKey = this.tenantKeyManager\n      ? await this.tenantKeyManager.getKey(tenantId)\n      : this.masterKey;\n    if (!decryptKey) return undefined;\n\n    try {\n      const decrypted = decrypt(payload, decryptKey);\n      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n      return decrypted;\n    } catch (err) {\n      const reason = err instanceof Error ? err.message : String(err);\n      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: reason }); } catch { /* logged inside record() */ }\n      return undefined;\n    }\n  }\n\n  submit(request: ExecRequest): void {\n    this.logger.info({\n      executionId: request.executionId,\n      personaId: request.personaId,\n    }, 'Execution submitted');\n\n    // Track which tenant owns this execution (for callback DB resolution)\n    const projectId = request.projectId || 'default';\n    this.executionTenant.set(request.executionId, projectId);\n\n    // Create DB record immediately\n    const submitDb = this.resolveDb(projectId);\n    if (submitDb) {\n      try {\n        db.createExecution(submitDb, {\n          id: request.executionId,\n          personaId: request.personaId,\n          inputData: request.prompt,\n          projectId,\n        });\n      } catch (err) {\n        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n      }\n    }\n\n    this.queue.push({ request, receivedAt: Date.now() });\n    this.processQueue();\n  }\n\n  private async processQueue(): Promise<void> {\n    // Guard: only one processQueue loop runs at a time to prevent concurrent\n    // calls from racing on getIdleWorker()/assign() and double-claiming a worker.\n    if (this.dispatching) return;\n    this.dispatching = true;\n    try {\n      while (this.queue.length > 0) {\n        const workerId = this.pool.getIdleWorker();\n        if (!workerId) {\n          this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n          return;\n        }\n\n        const item = this.queue.shift()!;\n        await this.dispatchToWorker(workerId, item.request);\n      }\n    } finally {\n      this.dispatching = false;\n    }\n  }\n\n  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n    // Try to get a fresh token via OAuth (auto-refreshes if near expiry)\n    let claudeToken: string | null = null;\n    if (this.oauth?.hasTokens()) {\n      claudeToken = await this.oauth.getValidAccessToken();\n      if (claudeToken) {\n        this.tokenManager.storeClaudeToken(claudeToken);\n      }\n    }\n    // Fallback to stored token\n    if (!claudeToken) {\n      claudeToken = this.tokenManager.getClaudeToken();\n    }\n    if (!claudeToken) {\n      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      return;\n    }\n\n    // Build environment variables for the worker\n    const env: Record<string, string> = {\n      ANTHROPIC_API_KEY: claudeToken,\n    };\n\n    // If persona exists in DB, assemble prompt from persona config and inject credentials\n    let prompt = request.prompt;\n    const dispatchDb = this.resolveDb(request.projectId || 'default');\n    const persona = dispatchDb ? db.getPersona(dispatchDb, request.personaId) : null;\n    if (dispatchDb) {\n      if (persona) {\n        const tools = db.getToolsForPersona(dispatchDb, persona.id);\n        const creds = db.listCredentialsForPersona(dispatchDb, persona.id);\n\n        // Decrypt credentials and inject as env vars\n        const credentialHints: string[] = [];\n        const tenantId = request.projectId || 'default';\n        for (const cred of creds) {\n          const envName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n          credentialHints.push(envName);\n\n          const decrypted = await this.decryptWithAudit(\n            toEncryptedPayload(cred),\n            tenantId,\n            cred.id,\n            { credentialId: cred.id, credentialName: cred.name },\n            'Failed to decrypt credential',\n          );\n          if (decrypted !== undefined) {\n            // Try to parse as JSON with multiple fields\n            try {\n              const fields = JSON.parse(decrypted) as Record<string, string>;\n              for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n                const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n                env[fieldEnvName] = String(fieldValue);\n              }\n            } catch {\n              // Not JSON — inject as single value\n              env[envName] = decrypted;\n            }\n          }\n        }\n\n        const inputData = request.inputData ? (request.inputData as Record<string, unknown>) : undefined;\n        prompt = assemblePrompt(persona, tools, inputData, credentialHints.length > 0 ? credentialHints : undefined);\n\n        // Apply inference profile or legacy model profile env overrides\n        let inferenceProfile: InferenceProfile | undefined;\n        if (persona.inferenceProfileId) {\n          inferenceProfile = db.getInferenceProfile(dispatchDb, persona.inferenceProfileId);\n        }\n        if (inferenceProfile) {\n          // Decrypt auth token first so resolveEnvOverrides can map it to env vars\n          let decryptedAuthToken: string | undefined;\n          if (inferenceProfile.authTokenEncrypted && inferenceProfile.authTokenIv && inferenceProfile.authTokenTag) {\n            decryptedAuthToken = await this.decryptWithAudit(\n              { encrypted: inferenceProfile.authTokenEncrypted, iv: inferenceProfile.authTokenIv, tag: inferenceProfile.authTokenTag },\n              tenantId,\n              `inference-profile:${inferenceProfile.id}`,\n              { profileId: inferenceProfile.id },\n              'Failed to decrypt inference profile auth token',\n            );\n          }\n          const overrides = resolveEnvOverrides(inferenceProfile, decryptedAuthToken);\n          for (const [k, v] of Object.entries(overrides.set)) env[k] = v;\n          for (const k of overrides.remove) delete env[k];\n        }\n\n        this.logger.info({ personaId: persona.id, toolCount: tools.length, credCount: creds.length }, 'Assembled prompt from DB persona');\n      }\n    }\n\n    // Resolve network policy from persona config\n    let networkPolicy: NetworkPolicy | undefined;\n    if (persona?.networkPolicy) {\n      networkPolicy = parseNetworkPolicy(persona.networkPolicy) ?? undefined;\n    }\n\n    const assignment: ExecAssign = {\n      type: 'assign',\n      executionId: request.executionId,\n      personaId: request.personaId,\n      prompt,\n      env,\n      config: {\n        timeoutMs: request.config.timeoutMs || 300_000,\n        maxOutputBytes: 10 * 1024 * 1024, // 10MB\n        ...(networkPolicy ? { networkPolicy } : {}),\n        ...(persona?.maxBudgetUsd ? { maxBudgetUsd: persona.maxBudgetUsd } : {}),\n        ...(persona?.maxTurns ? { maxTurns: persona.maxTurns } : {}),\n      },\n    };\n\n    // Track in-memory for real-time streaming\n    this.active.set(request.executionId, {\n      workerId,\n      startedAt: Date.now(),\n      output: [],\n      status: 'running',\n    });\n\n    // Mark running in DB\n    if (dispatchDb) {\n      try {\n        db.updateExecution(dispatchDb, request.executionId, {\n          status: 'running',\n          startedAt: new Date().toISOString(),\n        });\n      } catch { /* best effort */ }\n    }\n\n    const sent = this.pool.assign(workerId, assignment);\n    if (!sent) {\n      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n      this.active.delete(request.executionId);\n      if (dispatchDb) {\n        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch { /* best effort */ }\n      }\n      // Re-queue and retry dispatch — another idle worker may be available\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      this.processQueue();\n    } else {\n      this.logger.info({\n        workerId,\n        executionId: request.executionId,\n        personaId: request.personaId,\n      }, 'Execution dispatched to worker');\n    }\n  }\n\n  cancelExecution(executionId: string): boolean {\n    const exec = this.active.get(executionId);\n    if (!exec || exec.status !== 'running') return false;\n\n    return this.pool.send(exec.workerId, {\n      type: 'cancel',\n      executionId,\n    });\n  }\n\n  getQueueLength(): number {\n    return this.queue.length;\n  }\n\n  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n    return Array.from(this.active.entries())\n      .filter(([, e]) => e.status === 'running')\n      .map(([executionId, e]) => ({\n        executionId,\n        workerId: e.workerId,\n        startedAt: e.startedAt,\n      }));\n  }\n\n  /**\n   * Get execution state. Tries in-memory first (for real-time output),\n   * then falls back to DB for completed/historical executions.\n   */\n  getExecution(executionId: string): ActiveExecution | null {\n    // Check in-memory active executions first\n    const active = this.active.get(executionId);\n    if (active) return active;\n\n    const execDb = this.resolveDbForExecution(executionId);\n    if (execDb) {\n      const dbExec = db.getExecution(execDb, executionId);\n      if (dbExec) {\n        return {\n          workerId: '',\n          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n          status: dbExec.status as ActiveExecution['status'],\n          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n          durationMs: dbExec.durationMs ?? undefined,\n          sessionId: dbExec.claudeSessionId ?? undefined,\n          totalCostUsd: dbExec.costUsd ?? undefined,\n        };\n      }\n    }\n\n    return null;\n  }\n\n  getExecutionOutput(executionId: string): string[] | null {\n    const exec = this.getExecution(executionId);\n    return exec?.output ?? null;\n  }\n\n  /** Shared handler for stdout/stderr output chunks. */\n  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n    const line = prefix ? `${prefix}${chunk}` : chunk;\n\n    const exec = this.active.get(executionId);\n    if (exec) {\n      exec.output.push(line);\n    }\n\n    this.bufferOutput(executionId, line + '\\n');\n\n    // Forward stdout to Kafka (stderr is not forwarded)\n    if (!prefix) {\n      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n        executionId,\n        chunk,\n        timestamp,\n      }), executionId).catch(err => {\n        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n      });\n    }\n  }\n\n  /** Buffer an output chunk for batched DB write. */\n  private bufferOutput(executionId: string, chunk: string): void {\n    let buf = this.outputBuffers.get(executionId);\n    if (!buf) {\n      buf = [];\n      this.outputBuffers.set(executionId, buf);\n    }\n    buf.push(chunk);\n  }\n\n  /** Flush buffered output for a specific execution to DB. */\n  private flushOutputForExecution(executionId: string): void {\n    const buf = this.outputBuffers.get(executionId);\n    if (!buf || buf.length === 0) return;\n\n    const combined = buf.join('');\n    this.outputBuffers.delete(executionId);\n\n    const outputDb = this.resolveDbForExecution(executionId);\n    if (outputDb) {\n      try { db.appendOutput(outputDb, executionId, combined); } catch { /* best effort */ }\n    }\n  }\n\n  /** Flush all buffered output across all executions to DB. */\n  private flushOutputBuffers(): void {\n    for (const executionId of this.outputBuffers.keys()) {\n      this.flushOutputForExecution(executionId);\n    }\n  }\n\n  shutdown(): void {\n    clearInterval(this.outputFlushTimer);\n    this.flushOutputBuffers();\n  }\n}\n","numLines":601,"startLine":1,"totalLines":601}}}
