l deletion, proxy teardown) has finished.\n    36→   * If no execution is active, resolves immediately.\n    37→   *\n    38→   * An optional `timeoutMs` ensures the caller is never blocked forever\n    39→   * (defaults to 10 s).\n    40→   */\n    41→  waitForCleanup(timeoutMs = 10_000): Promise<void> {\n    42→    if (!this.executionDone) return Promise.resolve();\n    43→\n    44→    return Promise.race([\n    45→      this.executionDone,\n    46→      new Promise<void>((resolve) => setTimeout(resolve, timeoutMs)),\n    47→    ]);\n    48→  }\n    49→\n    50→  private processStdoutLine(line: string, callbacks: ExecutorCallbacks): void {\n    51→    callbacks.onStdout(line, Date.now());\n    52→\n    53→    const streamEvents = extractStreamEvents(line, this.logger);\n    54→    if (streamEvents.sessionId) this.sessionId = streamEvents.sessionId;\n    55→    if (streamEvents.totalCostUsd) this.totalCostUsd = streamEvents.totalCostUsd;\n    56→    for (const event of streamEvents.personaEvents) {\n    57→      callbacks.onEvent(event.eventType, event.payload);\n    58→    }\n    59→    if (streamEvents.progress) {\n    60→      callbacks.onProgress(streamEvents.progress.phase, streamEvents.progress.percent, streamEvents.progress.detail);\n    61→    }\n    62→  }\n    63→\n    64→  /** Returns true if an execution is currently in progress. */\n    65→  isBusy(): boolean {\n    66→    return this.childProcess !== null;\n    67→  }\n    68→\n    69→  async execute(assignment: ExecAssign, callbacks: ExecutorCallbacks): Promise<void> {\n    70→    const run = this.doExecute(assignment, callbacks);\n    71→    this.executionDone = run.catch(() => {});   // swallow – callers handle errors via callbacks\n    72→    try {\n    73→      await run;\n    74→    } finally {\n    75→      this.executionDone = null;\n    76→    }\n    77→  }\n    78→\n    79→  private async doExecute(assignment: ExecAssign, callbacks: ExecutorCallbacks): Promise<void> {\n    80→    const start