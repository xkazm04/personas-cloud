[2026-03-18T12:00:55.425Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HQVu6skFYfuMREpZjWEgyF","type":"tool_result","content":"     1→import fs from 'node:fs';\n     2→import path from 'node:path';\n     3→import os from 'node:os';\n     4→import { execSync } from 'node:child_process';\n     5→import type { Logger } from 'pino';\n     6→\n     7→import { buildCliArgs, type NetworkPolicy } from '@dac-cloud/shared';\n     8→\n     9→export interface SandboxConfig {\n    10→  executionId: string;\n    11→  env: Record<string, string>;\n    12→  accessToken?: string;\n    13→  networkAccess: boolean;\n    14→  networkPolicy?: NetworkPolicy;\n    15→  timeoutMs: number;\n    16→  maxBudgetUsd?: number;\n    17→  maxTurns?: number;\n    18→}\n    19→\n    20→export interface SandboxResult {\n    21→  command: string;\n    22→  args: string[];\n    23→  env: Record<string, string>;\n    24→  cwd: string;\n    25→  sandboxDir: string;\n    26→  proxyRequired?: boolean;\n    27→}\n    28→\n    29→let _bwrapAvailable: boolean | null = null;\n    30→\n    31→/**\n    32→ * Cached bwrap args for static system paths that never change between executions.\n    33→ * Computed once at module load time to avoid 6 synchronous fs.existsSync calls per execution.\n    34→ */\n    35→const _cachedStaticBwrapArgs: string[] = (() => {\n    36→  if (process.platform !== 'linux') return [];\n    37→\n    38→  const args: string[] = [];\n    39→  const conditionalPaths: Array<{ path: string; args: string[] }> = [\n    40→    { path: '/lib', args: ['--ro-bind', '/lib', '/lib'] },\n    41→    { path: '/lib64', args: ['--ro-bind', '/lib64', '/lib64'] },\n    42→    { path: '/etc/ssl', args: ['--ro-bind', '/etc/ssl', '/etc/ssl'] },\n    43→    { path: '/etc/ca-certificates', args: ['--ro-bind', '/etc/ca-certificates', '/etc/ca-certificates'] },\n    44→    { path: '/usr/local/lib/node_modules', args: ['--ro-bind', '/usr/local/lib/node_modules', '/usr/local/l