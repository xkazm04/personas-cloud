[2026-03-18T12:00:57.935Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014u9t1N57NpNASJbsaYuaxV","type":"tool_result","content":"     1→import type { Persona, PersonaToolDefinition, StructuredPrompt } from './types.js';\n     2→\n     3→// ---------------------------------------------------------------------------\n     4→// Protocol instruction constants (matching desktop engine/prompt.rs)\n     5→// ---------------------------------------------------------------------------\n     6→\n     7→const PROTOCOL_USER_MESSAGE = `### User Message Protocol\n     8→To send a message to the user, output a JSON object on its own line:\n     9→\\`\\`\\`json\n    10→{\"user_message\": {\"title\": \"Optional Title\", \"content\": \"Message content here\", \"content_type\": \"info\", \"priority\": \"normal\"}}\n    11→\\`\\`\\`\n    12→Fields:\n    13→- \\`title\\` (optional): Short title for the message\n    14→- \\`content\\` (required): The message body\n    15→- \\`content_type\\` (optional): \"info\", \"warning\", \"error\", \"success\" (default: \"info\")\n    16→- \\`priority\\` (optional): \"low\", \"normal\", \"high\", \"urgent\" (default: \"normal\")\n    17→\n    18→`;\n    19→\n    20→const PROTOCOL_PERSONA_ACTION = `### Persona Action Protocol\n    21→To trigger an action on another persona, output a JSON object on its own line:\n    22→\\`\\`\\`json\n    23→{\"persona_action\": {\"target\": \"target-persona-id\", \"action\": \"run\", \"input\": {\"key\": \"value\"}}}\n    24→\\`\\`\\`\n    25→Fields:\n    26→- \\`target\\` (required): The persona ID to target\n    27→- \\`action\\` (optional): Action to perform (default: \"run\")\n    28→- \\`input\\` (optional): JSON data to pass to the target persona\n    29→\n    30→`;\n    31→\n    32→const PROTOCOL_EMIT_EVENT = `### Emit Event Protocol\n    33→To emit an event to the system event bus, output a JSON object on its own line:\n    34→\\`\\`\\`json\n    35→{\"emit_event\": {\"type\": \"task_completed\", \"data\": {\"result\": \"success\", \"details\": \"...\"}}}\n    36→\\`\\`\\`\n    37→Fields:\n    38→- \\`type\\` (required): Event type identifier\n    39→- \\`data\\` (optional): Arbitrary JSON payload\n    40→\n    41→`;\n    42→\n    43→const PROTOCOL_AGENT_MEMORY = `### Agent Memory Protocol\n    44→To store a memory for future reference, output a JSON object on its own line:\n    45→\\`\\`\\`json\n    46→{\"agent_memory\": {\"title\": \"Memory Title\", \"content\": \"What to remember\", \"category\": \"learning\", \"importance\": 5, \"tags\": [\"tag1\", \"tag2\"]}}\n    47→\\`\\`\\`\n    48→Fields:\n    49→- \\`title\\` (required): Short title for the memory\n    50→- \\`content\\` (required): Detailed content to remember\n    51→- \\`category\\` (optional): \"learning\", \"preference\", \"fact\", \"procedure\" (default: \"general\")\n    52→- \\`importance\\` (optional): 1-10 importance rating (default: 5)\n    53→- \\`tags\\` (optional): Array of string tags for categorization\n    54→\n    55→`;\n    56→\n    57→const PROTOCOL_MANUAL_REVIEW = `### Manual Review Protocol\n    58→To flag something for human review, output a JSON object on its own line:\n    59→\\`\\`\\`json\n    60→{\"manual_review\": {\"title\": \"Review Title\", \"description\": \"What needs review\", \"severity\": \"medium\", \"context_data\": \"relevant context\", \"suggested_actions\": [\"action1\", \"action2\"]}}\n    61→\\`\\`\\`\n    62→Fields:\n    63→- \\`title\\` (required): Short title describing the review item\n    64→- \\`description\\` (optional): Detailed description\n    65→- \\`severity\\` (optional): \"low\", \"medium\", \"high\", \"critical\" (default: \"medium\")\n    66→- \\`context_data\\` (optional): Additional context string\n    67→- \\`suggested_actions\\` (optional): Array of suggested resolution steps\n    68→\n    69→`;\n    70→\n    71→const PROTOCOL_EXECUTION_FLOW = `### Execution Flow Protocol\n    72→To declare execution flow metadata, output a JSON object on its own line:\n    73→\\`\\`\\`json\n    74→{\"execution_flow\": {\"flows\": [{\"step\": 1, \"action\": \"analyze\", \"status\": \"completed\"}, {\"step\": 2, \"action\": \"implement\", \"status\": \"pending\"}]}}\n    75→\\`\\`\\`\n    76→Fields:\n    77→- \\`flows\\` (required): JSON value describing the execution flow steps\n    78→\n    79→`;\n    80→\n    81→const PROTOCOL_OUTCOME_ASSESSMENT = `### Outcome Assessment Protocol\n    82→IMPORTANT: At the very end of your execution, you MUST output an outcome assessment as the last thing before finishing:\n    83→\\`\\`\\`json\n    84→{\"outcome_assessment\": {\"accomplished\": true, \"summary\": \"Brief description of what was achieved\"}}\n    85→\\`\\`\\`\n    86→Fields:\n    87→- \\`accomplished\\` (required): true if the task was successfully completed from a business perspective, false if it could not be completed\n    88→- \\`summary\\` (required): Brief description of the outcome\n    89→- \\`blockers\\` (optional): List of reasons the task could not be completed (only when accomplished is false)\n    90→\n    91→You MUST always output this assessment. Set accomplished to false if:\n    92→- Required data was not available or accessible\n    93→- External services were unreachable or returned errors that prevented task completion\n    94→- The task requirements could not be fulfilled with the available tools\n    95→- You could not verify the task was completed correctly\n    96→\n    97→`;\n    98→\n    99→// ---------------------------------------------------------------------------\n   100→// Tool documentation\n   101→// ---------------------------------------------------------------------------\n   102→\n   103→export function buildToolDocumentation(tool: PersonaToolDefinition): string {\n   104→  let doc = `### ${tool.name}\\n${tool.description}\\n`;\n   105→  doc += `**Category**: ${tool.category}\\n`;\n   106→\n   107→  if (!tool.scriptPath) {\n   108→    if (tool.implementationGuide) {\n   109→      doc += '**Implementation Guide**:\\n';\n   110→      doc += tool.implementationGuide;\n   111→      doc += '\\n';\n   112→    } else {\n   113→      doc += '**Implementation**: Use the Bash tool with `curl` to call the API. Credentials are available as environment variables (e.g. `$GOOGLE_ACCESS_TOKEN`).\\n';\n   114→    }\n   115→  } else {\n   116→    doc += `**Usage**: npx tsx \"${tool.scriptPath}\" --input '<JSON>'\\n`;\n   117→  }\n   118→\n   119→  if (tool.inputSchema) {\n   120→    doc += `**Input Schema**: ${tool.inputSchema}\\n`;\n   121→  }\n   122→  if (tool.requiresCredentialType) {\n   123→    doc += `**Requires Credential**: ${tool.requiresCredentialType} (available as env var)\\n`;\n   124→  }\n   125→  return doc;\n   126→}\n   127→\n   128→// ---------------------------------------------------------------------------\n   129→// Prompt assembly (ported from engine/prompt.rs)\n   130→// ---------------------------------------------------------------------------\n   131→\n   132→export function assemblePrompt(\n   133→  persona: Persona,\n   134→  tools: PersonaToolDefinition[],\n   135→  inputData?: Record<string, unknown>,\n   136→  credentialHints?: string[],\n   137→): string {\n   138→  let prompt = '';\n   139→\n   140→  // Header\n   141→  prompt += `# Persona: ${persona.name}\\n\\n`;\n   142→\n   143→  // Description\n   144→  if (persona.description) {\n   145→    prompt += '## Description\\n';\n   146→    prompt += persona.description;\n   147→    prompt += '\\n\\n';\n   148→  }\n   149→\n   150→  // Identity and Instructions from structured_prompt or system_prompt\n   151→  let usedStructured = false;\n   152→  if (persona.structuredPrompt) {\n   153→    try {\n   154→      const sp: StructuredPrompt = JSON.parse(persona.structuredPrompt);\n   155→      usedStructured = true;\n   156→\n   157→      if (sp.identity) {\n   158→        prompt += '## Identity\\n';\n   159→        prompt += sp.identity;\n   160→        prompt += '\\n\\n';\n   161→      }\n   162→\n   163→      if (sp.instructions) {\n   164→        prompt += '## Instructions\\n';\n   165→        prompt += sp.instructions;\n   166→        prompt += '\\n\\n';\n   167→      }\n   168→\n   169→      if (sp.toolGuidance) {\n   170→        prompt += '## Tool Guidance\\n';\n   171→        prompt += sp.toolGuidance;\n   172→        prompt += '\\n\\n';\n   173→      }\n   174→\n   175→      if (sp.examples) {\n   176→        prompt += '## Examples\\n';\n   177→        prompt += sp.examples;\n   178→        prompt += '\\n\\n';\n   179→      }\n   180→\n   181→      if (sp.errorHandling) {\n   182→        prompt += '## Error Handling\\n';\n   183→        prompt += sp.errorHandling;\n   184→        prompt += '\\n\\n';\n   185→      }\n   186→\n   187→      if (sp.customSections) {\n   188→        for (const section of sp.customSections) {\n   189→          const heading = section.title ?? section.label ?? section.name ?? section.key;\n   190→          if (heading && section.content) {\n   191→            prompt += `## ${heading}\\n`;\n   192→            prompt += section.content;\n   193→            prompt += '\\n\\n';\n   194→          }\n   195→        }\n   196→      }\n   197→\n   198→      if (sp.webSearch) {\n   199→        prompt += '## Web Search Research Prompt\\n';\n   200→        prompt += 'When performing web searches during this execution, use the following research guidance:\\n\\n';\n   201→        prompt += sp.webSearch;\n   202→        prompt += '\\n\\n';\n   203→      }\n   204→    } catch {\n   205→      usedStructured = false;\n   206→    }\n   207→  }\n   208→\n   209→  if (!usedStructured) {\n   210→    prompt += '## Identity\\n';\n   211→    prompt += persona.systemPrompt;\n   212→    prompt += '\\n\\n';\n   213→  }\n   214→\n   215→  // Available Tools\n   216→  if (tools.length > 0) {\n   217→    prompt += '## Available Tools\\n';\n   218→    for (const tool of tools) {\n   219→      prompt += buildToolDocumentation(tool);\n   220→      prompt += '\\n';\n   221→    }\n   222→  }\n   223→\n   224→  // Execution Environment (always Linux for cloud)\n   225→  prompt += '## Execution Environment\\n';\n   226→  prompt += '- Platform: Linux/macOS\\n';\n   227→  prompt += '- Available: `curl`, `node`, `npx`, `git`, `bash`\\n';\n   228→  prompt += '- PREFER `curl` for HTTP API calls — avoid writing scripts when a single curl command works\\n';\n   229→  prompt += '- Credentials are pre-injected as environment variables — access them with `$ENV_VAR_NAME` in curl commands\\n\\n';\n   230→\n   231→  // Available Credentials\n   232→  if (credentialHints && credentialHints.length > 0) {\n   233→    prompt += '## Available Credentials (as environment variables)\\n';\n   234→    prompt += 'These env vars are ALREADY SET in your shell — use them directly in curl commands:\\n';\n   235→    for (const hint of credentialHints) {\n   236→      prompt += `- ${hint}\\n`;\n   237→    }\n   238→    prompt += '\\nExample: `curl -H \"Authorization: Bearer $GOOGLE_ACCESS_TOKEN\" https://api.example.com`\\n';\n   239→    prompt += 'IMPORTANT: Do NOT check if env vars exist — they are pre-configured. Just use them.\\n\\n';\n   240→  }\n   241→\n   242→  // Communication Protocols\n   243→  prompt += '## Communication Protocols\\n\\n';\n   244→  prompt += PROTOCOL_USER_MESSAGE;\n   245→  prompt += PROTOCOL_PERSONA_ACTION;\n   246→  prompt += PROTOCOL_EMIT_EVENT;\n   247→  prompt += PROTOCOL_AGENT_MEMORY;\n   248→  prompt += PROTOCOL_MANUAL_REVIEW;\n   249→  prompt += PROTOCOL_EXECUTION_FLOW;\n   250→  prompt += PROTOCOL_OUTCOME_ASSESSMENT;\n   251→\n   252→  // Input Data\n   253→  if (inputData) {\n   254→    // Inject use case context if present\n   255→    const useCase = inputData['_use_case'] as Record<string, unknown> | undefined;\n   256→    if (useCase) {\n   257→      prompt += '## Use Case Context\\n';\n   258→      if (typeof useCase['title'] === 'string') {\n   259→        prompt += `You are executing the use case: **${useCase['title']}**\\n`;\n   260→      }\n   261→      if (typeof useCase['description'] === 'string') {\n   262→        prompt += `Description: ${useCase['description']}\\n`;\n   263→      }\n   264→      prompt += 'Focus on this specific use case.\\n\\n';\n   265→    }\n   266→\n   267→    // Inject time filter constraints\n   268→    const timeFilter = inputData['_time_filter'] as Record<string, unknown> | undefined;\n   269→    if (timeFilter) {\n   270→      prompt += '## Time Filter (IMPORTANT)\\n';\n   271→      if (typeof timeFilter['description'] === 'string') {\n   272→        prompt += `${timeFilter['description']}\\n`;\n   273→      }\n   274→      if (typeof timeFilter['field'] === 'string' && typeof timeFilter['default_window'] === 'string') {\n   275→        prompt += `When querying data, use the '${timeFilter['field']}' parameter to limit results to the last ${timeFilter['default_window']}. `;\n   276→        prompt += 'Do NOT fetch all historical data — only process recent items within this time window.\\n';\n   277→      }\n   278→      prompt += '\\n';\n   279→    }\n   280→\n   281→    prompt += '## Input Data\\n```json\\n';\n   282→    prompt += JSON.stringify(inputData, null, 2);\n   283→    prompt += '\\n```\\n\\n';\n   284→  }\n   285→\n   286→  // Execute Now\n   287→  prompt += '## EXECUTE NOW\\n';\n   288→  prompt += `You are ${persona.name}. Execute your task now. Follow your instructions precisely.\\n`;\n   289→  if (tools.length > 0) {\n   290→    prompt += 'Use available tools as needed.\\n';\n   291→  }\n   292→  prompt += 'Respond naturally and complete the task.\\n';\n   293→\n   294→  return prompt;\n   295→}\n   296→\n   297→// ---------------------------------------------------------------------------\n   298→// CLI args builder (ported from engine/prompt.rs)\n   299→// ---------------------------------------------------------------------------\n   300→\n   301→export interface CliArgs {\n   302→  command: string;\n   303→  args: string[];\n   304→  envOverrides: Array<[string, string]>;\n   305→  envRemovals: string[];\n   306→}\n   307→\n   308→export function buildCliArgs(\n   309→  persona?: Persona | null,\n   310→): CliArgs {\n   311→  const args = [\n   312→    '-p', '-',\n   313→    '--output-format', 'stream-json',\n   314→    '--verbose',\n   315→    '--dangerously-skip-permissions',\n   316→  ];\n   317→\n   318→  // Persona-specific flags\n   319→  if (persona) {\n   320→    if (persona.maxBudgetUsd && persona.maxBudgetUsd > 0) {\n   321→      args.push('--max-budget-usd', String(persona.maxBudgetUsd));\n   322→    }\n   323→    if (persona.maxTurns && persona.maxTurns > 0) {\n   324→      args.push('--max-turns', String(persona.maxTurns));\n   325→    }\n   326→  }\n   327→\n   328→  const envOverrides: Array<[string, string]> = [];\n   329→  const envRemovals: string[] = ['CLAUDECODE', 'CLAUDE_CODE'];\n   330→\n   331→  return { command: 'claude', args, envOverrides, envRemovals };\n   332→}\n   333→"}]},"parent_tool_use_id":null,"session_id":"5ccd4a17-e6fd-4409-a07f-eea32410d852","uuid":"aa4fc36c-ab89-42b2-86e7-da029efba987","timestamp":"2026-03-18T12:00:57.724Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\shared\\src\\prompt.ts","content":"import type { Persona, PersonaToolDefinition, StructuredPrompt } from './types.js';\n\n// ---------------------------------------------------------------------------\n// Protocol instruction constants (matching desktop engine/prompt.rs)\n// ---------------------------------------------------------------------------\n\nconst PROTOCOL_USER_MESSAGE = `### User Message Protocol\nTo send a message to the user, output a JSON object on its own line:\n\\`\\`\\`json\n{\"user_message\": {\"title\": \"Optional Title\", \"content\": \"Message content here\", \"content_type\": \"info\", \"priority\": \"normal\"}}\n\\`\\`\\`\nFields:\n- \\`title\\` (optional): Short title for the message\n- \\`content\\` (required): The message body\n- \\`content_type\\` (optional): \"info\", \"warning\", \"error\", \"success\" (default: \"info\")\n- \\`priority\\` (optional): \"low\", \"normal\", \"high\", \"urgent\" (default: \"normal\")\n\n`;\n\nconst PROTOCOL_PERSONA_ACTION = `### Persona Action Protocol\nTo trigger an action on another persona, output a JSON object on its own line:\n\\`\\`\\`json\n{\"persona_action\": {\"target\": \"target-persona-id\", \"action\": \"run\", \"input\": {\"key\": \"value\"}}}\n\\`\\`\\`\nFields:\n- \\`target\\` (required): The persona ID to target\n- \\`action\\` (optional): Action to perform (default: \"run\")\n- \\`input\\` (optional): JSON data to pass to the target persona\n\n`;\n\nconst PROTOCOL_EMIT_EVENT = `### Emit Event Protocol\nTo emit an event to the system event bus, output a JSON object on its own line:\n\\`\\`\\`json\n{\"emit_event\": {\"type\": \"task_completed\", \"data\": {\"result\": \"success\", \"details\": \"...\"}}}\n\\`\\`\\`\nFields:\n- \\`type\\` (required): Event type identifier\n- \\`data\\` (optional): Arbitrary JSON payload\n\n`;\n\nconst PROTOCOL_AGENT_MEMORY = `### Agent Memory Protocol\nTo store a memory for future reference, output a JSON object on its own line:\n\\`\\`\\`json\n{\"agent_memory\": {\"title\": \"Memory Title\", \"content\": \"What to remember\", \"category\": \"learning\", \"importance\": 5, \"tags\": [\"tag1\", \"tag2\"]}}\n\\`\\`\\`\nFields:\n- \\`title\\` (required): Short title for the memory\n- \\`content\\` (required): Detailed content to remember\n- \\`category\\` (optional): \"learning\", \"preference\", \"fact\", \"procedure\" (default: \"general\")\n- \\`importance\\` (optional): 1-10 importance rating (default: 5)\n- \\`tags\\` (optional): Array of string tags for categorization\n\n`;\n\nconst PROTOCOL_MANUAL_REVIEW = `### Manual Review Protocol\nTo flag something for human review, output a JSON object on its own line:\n\\`\\`\\`json\n{\"manual_review\": {\"title\": \"Review Title\", \"description\": \"What needs review\", \"severity\": \"medium\", \"context_data\": \"relevant context\", \"suggested_actions\": [\"action1\", \"action2\"]}}\n\\`\\`\\`\nFields:\n- \\`title\\` (required): Short title describing the review item\n- \\`description\\` (optional): Detailed description\n- \\`severity\\` (optional): \"low\", \"medium\", \"high\", \"critical\" (default: \"medium\")\n- \\`context_data\\` (optional): Additional context string\n- \\`suggested_actions\\` (optional): Array of suggested resolution steps\n\n`;\n\nconst PROTOCOL_EXECUTION_FLOW = `### Execution Flow Protocol\nTo declare execution flow metadata, output a JSON object on its own line:\n\\`\\`\\`json\n{\"execution_flow\": {\"flows\": [{\"step\": 1, \"action\": \"analyze\", \"status\": \"completed\"}, {\"step\": 2, \"action\": \"implement\", \"status\": \"pending\"}]}}\n\\`\\`\\`\nFields:\n- \\`flows\\` (required): JSON value describing the execution flow steps\n\n`;\n\nconst PROTOCOL_OUTCOME_ASSESSMENT = `### Outcome Assessment Protocol\nIMPORTANT: At the very end of your execution, you MUST output an outcome assessment as the last thing before finishing:\n\\`\\`\\`json\n{\"outcome_assessment\": {\"accomplished\": true, \"summary\": \"Brief description of what was achieved\"}}\n\\`\\`\\`\nFields:\n- \\`accomplished\\` (required): true if the task was successfully completed from a business perspective, false if it could not be completed\n- \\`summary\\` (required): Brief description of the outcome\n- \\`blockers\\` (optional): List of reasons the task could not be completed (only when accomplished is false)\n\nYou MUST always output this assessment. Set accomplished to false if:\n- Required data was not available or accessible\n- External services were unreachable or returned errors that prevented task completion\n- The task requirements could not be fulfilled with the available tools\n- You could not verify the task was completed correctly\n\n`;\n\n// ---------------------------------------------------------------------------\n// Tool documentation\n// ---------------------------------------------------------------------------\n\nexport function buildToolDocumentation(tool: PersonaToolDefinition): string {\n  let doc = `### ${tool.name}\\n${tool.description}\\n`;\n  doc += `**Category**: ${tool.category}\\n`;\n\n  if (!tool.scriptPath) {\n    if (tool.implementationGuide) {\n      doc += '**Implementation Guide**:\\n';\n      doc += tool.implementationGuide;\n      doc += '\\n';\n    } else {\n      doc += '**Implementation**: Use the Bash tool with `curl` to call the API. Credentials are available as environment variables (e.g. `$GOOGLE_ACCESS_TOKEN`).\\n';\n    }\n  } else {\n    doc += `**Usage**: npx tsx \"${tool.scriptPath}\" --input '<JSON>'\\n`;\n  }\n\n  if (tool.inputSchema) {\n    doc += `**Input Schema**: ${tool.inputSchema}\\n`;\n  }\n  if (tool.requiresCredentialType) {\n    doc += `**Requires Credential**: ${tool.requiresCredentialType} (available as env var)\\n`;\n  }\n  return doc;\n}\n\n// ---------------------------------------------------------------------------\n// Prompt assembly (ported from engine/prompt.rs)\n// ---------------------------------------------------------------------------\n\nexport function assemblePrompt(\n  persona: Persona,\n  tools: PersonaToolDefinition[],\n  inputData?: Record<string, unknown>,\n  credentialHints?: string[],\n): string {\n  let prompt = '';\n\n  // Header\n  prompt += `# Persona: ${persona.name}\\n\\n`;\n\n  // Description\n  if (persona.description) {\n    prompt += '## Description\\n';\n    prompt += persona.description;\n    prompt += '\\n\\n';\n  }\n\n  // Identity and Instructions from structured_prompt or system_prompt\n  let usedStructured = false;\n  if (persona.structuredPrompt) {\n    try {\n      const sp: StructuredPrompt = JSON.parse(persona.structuredPrompt);\n      usedStructured = true;\n\n      if (sp.identity) {\n        prompt += '## Identity\\n';\n        prompt += sp.identity;\n        prompt += '\\n\\n';\n      }\n\n      if (sp.instructions) {\n        prompt += '## Instructions\\n';\n        prompt += sp.instructions;\n        prompt += '\\n\\n';\n      }\n\n      if (sp.toolGuidance) {\n        prompt += '## Tool Guidance\\n';\n        prompt += sp.toolGuidance;\n        prompt += '\\n\\n';\n      }\n\n      if (sp.examples) {\n        prompt += '## Examples\\n';\n        prompt += sp.examples;\n        prompt += '\\n\\n';\n      }\n\n      if (sp.errorHandling) {\n        prompt += '## Error Handling\\n';\n        prompt += sp.errorHandling;\n        prompt += '\\n\\n';\n      }\n\n      if (sp.customSections) {\n        for (const section of sp.customSections) {\n          const heading = section.title ?? section.label ?? section.name ?? section.key;\n          if (heading && section.content) {\n            prompt += `## ${heading}\\n`;\n            prompt += section.content;\n            prompt += '\\n\\n';\n          }\n        }\n      }\n\n      if (sp.webSearch) {\n        prompt += '## Web Search Research Prompt\\n';\n        prompt += 'When performing web searches during this execution, use the following research guidance:\\n\\n';\n        prompt += sp.webSearch;\n        prompt += '\\n\\n';\n      }\n    } catch {\n      usedStructured = false;\n    }\n  }\n\n  if (!usedStructured) {\n    prompt += '## Identity\\n';\n    prompt += persona.systemPrompt;\n    prompt += '\\n\\n';\n  }\n\n  // Available Tools\n  if (tools.length > 0) {\n    prompt += '## Available Tools\\n';\n    for (const tool of tools) {\n      prompt += buildToolDocumentation(tool);\n      prompt += '\\n';\n    }\n  }\n\n  // Execution Environment (always Linux for cloud)\n  prompt += '## Execution Environment\\n';\n  prompt += '- Platform: Linux/macOS\\n';\n  prompt += '- Available: `curl`, `node`, `npx`, `git`, `bash`\\n';\n  prompt += '- PREFER `curl` for HTTP API calls — avoid writing scripts when a single curl command works\\n';\n  prompt += '- Credentials are pre-injected as environment variables — access them with `$ENV_VAR_NAME` in curl commands\\n\\n';\n\n  // Available Credentials\n  if (credentialHints && credentialHints.length > 0) {\n    prompt += '## Available Credentials (as environment variables)\\n';\n    prompt += 'These env vars are ALREADY SET in your shell — use them directly in curl commands:\\n';\n    for (const hint of credentialHints) {\n      prompt += `- ${hint}\\n`;\n    }\n    prompt += '\\nExample: `curl -H \"Authorization: Bearer $GOOGLE_ACCESS_TOKEN\" https://api.example.com`\\n';\n    prompt += 'IMPORTANT: Do NOT check if env vars exist — they are pre-configured. Just use them.\\n\\n';\n  }\n\n  // Communication Protocols\n  prompt += '## Communication Protocols\\n\\n';\n  prompt += PROTOCOL_USER_MESSAGE;\n  prompt += PROTOCOL_PERSONA_ACTION;\n  prompt += PROTOCOL_EMIT_EVENT;\n  prompt += PROTOCOL_AGENT_MEMORY;\n  prompt += PROTOCOL_MANUAL_REVIEW;\n  prompt += PROTOCOL_EXECUTION_FLOW;\n  prompt += PROTOCOL_OUTCOME_ASSESSMENT;\n\n  // Input Data\n  if (inputData) {\n    // Inject use case context if present\n    const useCase = inputData['_use_case'] as Record<string, unknown> | undefined;\n    if (useCase) {\n      prompt += '## Use Case Context\\n';\n      if (typeof useCase['title'] === 'string') {\n        prompt += `You are executing the use case: **${useCase['title']}**\\n`;\n      }\n      if (typeof useCase['description'] === 'string') {\n        prompt += `Description: ${useCase['description']}\\n`;\n      }\n      prompt += 'Focus on this specific use case.\\n\\n';\n    }\n\n    // Inject time filter constraints\n    const timeFilter = inputData['_time_filter'] as Record<string, unknown> | undefined;\n    if (timeFilter) {\n      prompt += '## Time Filter (IMPORTANT)\\n';\n      if (typeof timeFilter['description'] === 'string') {\n        prompt += `${timeFilter['description']}\\n`;\n      }\n      if (typeof timeFilter['field'] === 'string' && typeof timeFilter['default_window'] === 'string') {\n        prompt += `When querying data, use the '${timeFilter['field']}' parameter to limit results to the last ${timeFilter['default_window']}. `;\n        prompt += 'Do NOT fetch all historical data — only process recent items within this time window.\\n';\n      }\n      prompt += '\\n';\n    }\n\n    prompt += '## Input Data\\n```json\\n';\n    prompt += JSON.stringify(inputData, null, 2);\n    prompt += '\\n```\\n\\n';\n  }\n\n  // Execute Now\n  prompt += '## EXECUTE NOW\\n';\n  prompt += `You are ${persona.name}. Execute your task now. Follow your instructions precisely.\\n`;\n  if (tools.length > 0) {\n    prompt += 'Use available tools as needed.\\n';\n  }\n  prompt += 'Respond naturally and complete the task.\\n';\n\n  return prompt;\n}\n\n// ---------------------------------------------------------------------------\n// CLI args builder (ported from engine/prompt.rs)\n// ---------------------------------------------------------------------------\n\nexport interface CliArgs {\n  command: string;\n  args: string[];\n  envOverrides: Array<[string, string]>;\n  envRemovals: string[];\n}\n\nexport function buildCliArgs(\n  persona?: Persona | null,\n): CliArgs {\n  const args = [\n    '-p', '-',\n    '--output-format', 'stream-json',\n    '--verbose',\n    '--dangerously-skip-permissions',\n  ];\n\n  // Persona-specific flags\n  if (persona) {\n    if (persona.maxBudgetUsd && persona.maxBudgetUsd > 0) {\n      args.push('--max-budget-usd', String(persona.maxBudgetUsd));\n    }\n    if (persona.maxTurns && persona.maxTurns > 0) {\n      args.push('--max-turns', String(persona.maxTurns));\n    }\n  }\n\n  const envOverrides: Array<[string, string]> = [];\n  const envRemovals: string[] = ['CLAUDECODE', 'CLAUDE_CODE'];\n\n  return { command: 'claude', args, envOverrides, envRemovals };\n}\n","numLines":333,"startLine":1,"totalLines":333}}}
