[2026-03-19T08:16:54.066Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LVfRY8KcJMMJehzG7FKpsA","type":"tool_result","content":"     1→import crypto from 'node:crypto';\n     2→import fs from 'node:fs';\n     3→import Database from 'better-sqlite3';\n     4→import type { Logger } from 'pino';\n     5→\n     6→/** SHA-256 hash chain genesis value (64 hex zeros). */\n     7→const GENESIS_HASH = '0'.repeat(64);\n     8→\n     9→/**\n    10→ * Compute a chain hash: SHA-256(previousHash + deterministic JSON of entry fields).\n    11→ * Each entry's hash commits to the entire chain history before it.\n    12→ */\n    13→function computeChainHash(prevHash: string, entry: BufferedEntry): string {\n    14→  const payload = prevHash + JSON.stringify([\n    15→    entry.timestamp,\n    16→    entry.action,\n    17→    entry.tenantId,\n    18→    entry.actor,\n    19→    entry.resourceType,\n    20→    entry.resourceId,\n    21→    entry.detail,\n    22→    entry.ipAddress,\n    23→  ]);\n    24→  return crypto.createHash('sha256').update(payload).digest('hex');\n    25→}\n    26→\n    27→const AUDIT_SCHEMA = `\n    28→CREATE TABLE IF NOT EXISTS audit_events (\n    29→  id INTEGER PRIMARY KEY AUTOINCREMENT,\n    30→  timestamp TEXT NOT NULL,\n    31→  action TEXT NOT NULL,\n    32→  tenant_id TEXT,\n    33→  actor TEXT,\n    34→  resource_type TEXT,\n    35→  resource_id TEXT,\n    36→  detail TEXT,\n    37→  ip_address TEXT,\n    38→  prev_hash TEXT\n    39→);\n    40→CREATE INDEX IF NOT EXISTS idx_audit_ts ON audit_events(timestamp);\n    41→CREATE INDEX IF NOT EXISTS idx_audit_tenant_action_ts ON audit_events(tenant_id, action, timestamp);\n    42→CREATE INDEX IF NOT EXISTS idx_audit_actor ON audit_events(actor);\n    43→CREATE INDEX IF NOT EXISTS idx_audit_resource_type ON audit_events(resource_type);\n    44→DROP INDEX IF EXISTS idx_audit_tenant_ts;\n    45→DROP INDEX IF EXISTS idx_audit_action;\n    46→`;\n    47→\n    48→/** Thrown when an audit event fails to persist — signals an audit trail gap. */\n    49→export class AuditWriteError extends Error {\n    50→  constructor(\n    51→    public readonly entry: AuditEntry,\n    52→    cause: unknown,\n    53→  ) {\n    54→    super(`Audit write failed for action \"${entry.action}\"`);\n    55→    this.name = 'AuditWriteError';\n    56→    this.cause = cause;\n    57→  }\n    58→}\n    59→\n    60→// ---------------------------------------------------------------------------\n    61→// Discriminated-union audit entries — each action carries its own typed payload\n    62→// ---------------------------------------------------------------------------\n    63→\n    64→/** Fields common to every audit entry. */\n    65→interface AuditEntryBase {\n    66→  tenantId?: string;\n    67→  actor?: string;\n    68→  ipAddress?: string;\n    69→}\n    70→\n    71→// --- Key management ---\n    72→interface KeyEncryptEntry extends AuditEntryBase {\n    73→  action: 'key:encrypt';\n    74→  resourceType: 'credential';\n    75→  resourceId: string;\n    76→}\n    77→\n    78→interface KeyDecryptEntry extends AuditEntryBase {\n    79→  action: 'key:decrypt';\n    80→  resourceType: 'credential';\n    81→  resourceId: string;\n    82→}\n    83→\n    84→interface KeyDecryptFailedEntry extends AuditEntryBase {\n    85→  action: 'key:decrypt_failed';\n    86→  resourceType: 'credential';\n    87→  resourceId: string;\n    88→  detail: { reason: string };\n    89→}\n    90→\n    91→interface KeyDeleteEntry extends AuditEntryBase {\n    92→  action: 'key:delete';\n    93→  resourceType: 'credential';\n    94→  resourceId: string;\n    95→}\n    96→\n    97→interface KeyAccessEntry extends AuditEntryBase {\n    98→  action: 'key:access';\n    99→  resourceType: 'credential';\n   100→  resourceId: string;\n   101→}\n   102→\n   103→interface KeyDeriveEntry extends AuditEntryBase {\n   104→  action: 'key:derive';\n   105→}\n   106→\n   107→// --- Persona management ---\n   108→interface PersonaCreateEntry extends AuditEntryBase {\n   109→  action: 'persona:create';\n   110→  resourceType: 'persona';\n   111→  resourceId: string;\n   112→}\n   113→\n   114→interface PersonaDeleteEntry extends AuditEntryBase {\n   115→  action: 'persona:delete';\n   116→  resourceType: 'persona';\n   117→  resourceId: string;\n   118→}\n   119→\n   120→// --- Tool management ---\n   121→interface ToolLinkEntry extends AuditEntryBase {\n   122→  action: 'tool:link';\n   123→  resourceType: 'persona';\n   124→  resourceId: string;\n   125→  detail: { toolId: string };\n   126→}\n   127→\n   128→interface ToolDefinitionCreateEntry extends AuditEntryBase {\n   129→  action: 'tool-definition:create';\n   130→  resourceType: 'toolDefinition';\n   131→  resourceId: string;\n   132→}\n   133→\n   134→// --- Credential linking ---\n   135→interface CredentialLinkEntry extends AuditEntryBase {\n   136→  action: 'credential:link';\n   137→  resourceType: 'persona';\n   138→  resourceId: string;\n   139→  detail: { credentialId: string };\n   140→}\n   141→\n   142→// --- Subscriptions ---\n   143→interface SubscriptionCreateEntry extends AuditEntryBase {\n   144→  action: 'subscription:create';\n   145→  resourceType: 'subscription';\n   146→  resourceId: string;\n   147→  detail: { personaId: string; eventType: string };\n   148→}\n   149→\n   150→interface SubscriptionUpdateEntry extends AuditEntryBase {\n   151→  action: 'subscription:update';\n   152→  resourceType: 'subscription';\n   153→  resourceId: string;\n   154→}\n   155→\n   156→interface SubscriptionDeleteEntry extends AuditEntryBase {\n   157→  action: 'subscription:delete';\n   158→  resourceType: 'subscription';\n   159→  resourceId: string;\n   160→}\n   161→\n   162→// --- Worker pool ---\n   163→interface WorkerConnectedEntry extends AuditEntryBase {\n   164→  action: 'worker:connected';\n   165→  detail: { workerId: string };\n   166→}\n   167→\n   168→interface WorkerDisconnectedEntry extends AuditEntryBase {\n   169→  action: 'worker:disconnected';\n   170→  detail: { workerId: string };\n   171→  resourceId?: string;\n   172→}\n   173→\n   174→// --- Triggers ---\n   175→interface TriggerCreateEntry extends AuditEntryBase {\n   176→  action: 'trigger:create';\n   177→  resourceType: 'trigger';\n   178→  resourceId?: string;\n   179→}\n   180→\n   181→interface TriggerUpdateEntry extends AuditEntryBase {\n   182→  action: 'trigger:update';\n   183→  resourceType: 'trigger';\n   184→  resourceId: string;\n   185→}\n   186→\n   187→interface TriggerDeleteEntry extends AuditEntryBase {\n   188→  action: 'trigger:delete';\n   189→  resourceType: 'trigger';\n   190→  resourceId: string;\n   191→}\n   192→\n   193→// --- Events ---\n   194→interface EventPublishEntry extends AuditEntryBase {\n   195→  action: 'event:publish';\n   196→  resourceType: 'event';\n   197→  resourceId?: string;\n   198→}\n   199→\n   200→interface EventUpdateEntry extends AuditEntryBase {\n   201→  action: 'event:update';\n   202→  resourceType: 'event';\n   203→  resourceId: string;\n   204→}\n   205→\n   206→// --- Executions ---\n   207→interface ExecutionSubmitEntry extends AuditEntryBase {\n   208→  action: 'execution:submit';\n   209→  resourceType: 'execution';\n   210→  resourceId?: string;\n   211→}\n   212→\n   213→// --- Webhooks ---\n   214→interface WebhookReceiveEntry extends AuditEntryBase {\n   215→  action: 'webhook:receive';\n   216→  resourceType: 'webhook';\n   217→  resourceId: string;\n   218→}\n   219→\n   220→// --- OAuth lifecycle ---\n   221→interface OAuthAuthorizeEntry extends AuditEntryBase {\n   222→  action: 'oauth:authorize';\n   223→  resourceType: 'oauth';\n   224→  resourceId: string; // state parameter\n   225→}\n   226→\n   227→interface OAuthExchangeEntry extends AuditEntryBase {\n   228→  action: 'oauth:exchange';\n   229→  resourceType: 'oauth';\n   230→  detail: { scopes: string[]; expiresAt: string };\n   231→}\n   232→\n   233→interface OAuthRefreshEntry extends AuditEntryBase {\n   234→  action: 'oauth:refresh';\n   235→  resourceType: 'oauth';\n   236→  detail: { expiresAt: string };\n   237→}\n   238→\n   239→interface OAuthRefreshFailedEntry extends AuditEntryBase {\n   240→  action: 'oauth:refresh_failed';\n   241→  resourceType: 'oauth';\n   242→  detail: { reason: string; errorType?: string };\n   243→}\n   244→\n   245→interface OAuthTokenErrorEntry extends AuditEntryBase {\n   246→  action: 'oauth:token_error';\n   247→  resourceType: 'oauth';\n   248→  detail: { errorType: string; status?: number; transient: boolean; context: string };\n   249→}\n   250→\n   251→interface OAuthDisconnectEntry extends AuditEntryBase {\n   252→  action: 'oauth:disconnect';\n   253→  resourceType: 'oauth';\n   254→  detail: { serverRevoked: boolean };\n   255→}\n   256→\n   257→// --- Token lifecycle ---\n   258→interface TokenInjectEntry extends AuditEntryBase {\n   259→  action: 'token:inject';\n   260→  resourceType: 'token';\n   261→}\n   262→\n   263→interface TokenExpiringSoonEntry extends AuditEntryBase {\n   264→  action: 'token:expiring_soon';\n   265→  resourceType: 'oauth';\n   266→  detail: { expiresAt: string; remainingMinutes: number };\n   267→}\n   268→\n   269→/** Discriminated union of all audit event types. */\n   270→export type AuditEntry =\n   271→  | KeyEncryptEntry\n   272→  | KeyDecryptEntry\n   273→  | KeyDecryptFailedEntry\n   274→  | KeyDeleteEntry\n   275→  | KeyAccessEntry\n   276→  | KeyDeriveEntry\n   277→  | PersonaCreateEntry\n   278→  | PersonaDeleteEntry\n   279→  | ToolLinkEntry\n   280→  | ToolDefinitionCreateEntry\n   281→  | CredentialLinkEntry\n   282→  | SubscriptionCreateEntry\n   283→  | SubscriptionUpdateEntry\n   284→  | SubscriptionDeleteEntry\n   285→  | WorkerConnectedEntry\n   286→  | WorkerDisconnectedEntry\n   287→  | TriggerCreateEntry\n   288→  | TriggerUpdateEntry\n   289→  | TriggerDeleteEntry\n   290→  | EventPublishEntry\n   291→  | EventUpdateEntry\n   292→  | ExecutionSubmitEntry\n   293→  | WebhookReceiveEntry\n   294→  | OAuthAuthorizeEntry\n   295→  | OAuthExchangeEntry\n   296→  | OAuthRefreshEntry\n   297→  | OAuthRefreshFailedEntry\n   298→  | OAuthTokenErrorEntry\n   299→  | OAuthDisconnectEntry\n   300→  | TokenInjectEntry\n   301→  | TokenExpiringSoonEntry;\n   302→\n   303→/** String-literal union of all valid audit actions. */\n   304→export type AuditAction = AuditEntry['action'];\n   305→\n   306→/** Row shape returned by audit_events queries. */\n   307→export interface AuditEvent {\n   308→  id: number;\n   309→  timestamp: string;\n   310→  action: string;\n   311→  tenant_id: string | null;\n   312→  actor: string | null;\n   313→  resource_type: string | null;\n   314→  resource_id: string | null;\n   315→  detail: string | null;\n   316→  ip_address: string | null;\n   317→  prev_hash: string | null;\n   318→}\n   319→\n   320→/** Result of verifying the audit hash chain. */\n   321→export interface ChainVerifyResult {\n   322→  valid: boolean;\n   323→  verifiedCount: number;\n   324→  brokenAtId?: number;\n   325→}\n   326→\n   327→/** Max entries buffered before an automatic flush. */\n   328→const BUFFER_FLUSH_SIZE = 50;\n   329→/** Interval (ms) between timer-based flushes. */\n   330→const BUFFER_FLUSH_INTERVAL_MS = 100;\n   331→\n   332→interface BufferedEntry {\n   333→  timestamp: string;\n   334→  action: string;\n   335→  tenantId: string | null;\n   336→  actor: string | null;\n   337→  resourceType: string | null;\n   338→  resourceId: string | null;\n   339→  detail: string | null;\n   340→  ipAddress: string | null;\n   341→}\n   342→\n   343→/** Health snapshot returned by AuditLog.getHealth(). */\n   344→export interface AuditLogHealth {\n   345→  /** Total number of audit events successfully written to disk. */\n   346→  totalEventsWritten: number;\n   347→  /** Total number of audit events dropped due to flush failures. */\n   348→  droppedEvents: number;\n   349→  /** Number of events currently waiting in the in-memory buffer. */\n   350→  bufferDepth: number;\n   351→  /** Duration of the most recent flush in milliseconds, or null if no flush has occurred. */\n   352→  lastFlushDurationMs: number | null;\n   353→  /** Result of the most recent chain verification, or null if verify() has not been called. */\n   354→  lastChainVerifyResult: ChainVerifyResult | null;\n   355→  /** Size of the audit SQLite database file in bytes, or null if unavailable. */\n   356→  dbSizeBytes: number | null;\n   357→}\n   358→\n   359→export class AuditLog {\n   360→  private db: Database.Database;\n   361→  private insertStmt: Database.Statement;\n   362→  private queryStmtCache = new Map<string, Database.Statement>();\n   363→  private buffer: BufferedEntry[] = [];\n   364→  private flushTimer: NodeJS.Timeout | null = null;\n   365→  private batchInsert: (entries: BufferedEntry[], hashes: string[]) => void;\n   366→  private lastHash: string;\n   367→  private droppedEvents = 0;\n   368→  private totalEventsWritten = 0;\n   369→  private lastFlushDurationMs: number | null = null;\n   370→  private lastChainVerifyResult: ChainVerifyResult | null = null;\n   371→  private dbPath: string;\n   372→\n   373→  constructor(\n   374→    dbPath: string,\n   375→    private logger: Logger,\n   376→  ) {\n   377→    this.dbPath = dbPath;\n   378→    this.db = new Database(dbPath);\n   379→    this.db.pragma('journal_mode = WAL');\n   380→    this.db.exec(AUDIT_SCHEMA);\n   381→\n   382→    // Migration: add prev_hash column to existing databases that lack it\n   383→    const cols = this.db.pragma('table_info(audit_events)') as { name: string }[];\n   384→    if (!cols.some((c) => c.name === 'prev_hash')) {\n   385→      this.db.exec('ALTER TABLE audit_events ADD COLUMN prev_hash TEXT');\n   386→    }\n   387→\n   388→    this.insertStmt = this.db.prepare(\n   389→      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address, prev_hash) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',\n   390→    );\n   391→\n   392→    // Initialize chain from last stored hash (or genesis for empty / pre-chain DBs)\n   393→    const lastRow = this.db.prepare(\n   394→      'SELECT prev_hash FROM audit_events WHERE prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n   395→    ).get() as { prev_hash: string } | undefined;\n   396→    this.lastHash = lastRow?.prev_hash ?? GENESIS_HASH;\n   397→\n   398→    // Wrap N inserts in a single transaction — one fsync instead of N\n   399→    const stmt = this.insertStmt;\n   400→    this.batchInsert = this.db.transaction((entries: BufferedEntry[], hashes: string[]) => {\n   401→      for (let i = 0; i < entries.length; i++) {\n   402→        const e = entries[i];\n   403→        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress, hashes[i]);\n   404→      }\n   405→    });\n   406→\n   407→    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n   408→\n   409→    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled, hash-chain active)');\n   410→  }\n   411→\n   412→  /** Expose the underlying database for use by RetentionPolicy. */\n   413→  getDb(): Database.Database {\n   414→    return this.db;\n   415→  }\n   416→\n   417→  /** Health snapshot — a nonzero droppedEvents value means the audit trail has gaps. */\n   418→  getHealth(): AuditLogHealth {\n   419→    return {\n   420→      droppedEvents: this.droppedEvents,\n   421→      bufferedEvents: this.buffer.length,\n   422→    };\n   423→  }\n   424→\n   425→  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n   426→  countEvents(before?: string): number {\n   427→    const stmt = before\n   428→      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n   429→      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n   430→    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n   431→    return row.cnt;\n   432→  }\n   433→\n   434→  /**\n   435→   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   436→   * yielding the event loop between batches so concurrent DB operations\n   437→   * are not starved during large purges.\n   438→   */\n   439→  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n   440→    const deleteChunk = this.db.prepare(\n   441→      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n   442→    );\n   443→    let totalDeleted = 0;\n   444→    while (true) {\n   445→      const result = deleteChunk.run(cutoff, chunkSize);\n   446→      totalDeleted += result.changes;\n   447→      if (result.changes < chunkSize) break;\n   448→      await new Promise<void>((resolve) => setImmediate(resolve));\n   449→    }\n   450→    return totalDeleted;\n   451→  }\n   452→\n   453→  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n   454→  record(entry: AuditEntry): void {\n   455→    this.buffer.push({\n   456→      timestamp: new Date().toISOString(),\n   457→      action: entry.action,\n   458→      tenantId: entry.tenantId ?? null,\n   459→      actor: entry.actor ?? null,\n   460→      resourceType: 'resourceType' in entry ? entry.resourceType : null,\n   461→      resourceId: 'resourceId' in entry ? (entry.resourceId ?? null) : null,\n   462→      detail: 'detail' in entry ? JSON.stringify(entry.detail) : null,\n   463→      ipAddress: entry.ipAddress ?? null,\n   464→    });\n   465→    if (this.buffer.length >= BUFFER_FLUSH_SIZE) {\n   466→      this.flush();\n   467→    }\n   468→  }\n   469→\n   470→  /** Flush buffered entries to SQLite in a single transaction, computing chain hashes. */\n   471→  flush(): void {\n   472→    if (this.buffer.length === 0) return;\n   473→    const batch = this.buffer;\n   474→    this.buffer = [];\n   475→\n   476→    // Compute chain hashes for the batch\n   477→    const hashes: string[] = [];\n   478→    let prevHash = this.lastHash;\n   479→    for (const entry of batch) {\n   480→      prevHash = computeChainHash(prevHash, entry);\n   481→      hashes.push(prevHash);\n   482→    }\n   483→\n   484→    try {\n   485→      this.batchInsert(batch, hashes);\n   486→      this.lastHash = prevHash;\n   487→    } catch (err) {\n   488→      this.droppedEvents += batch.length;\n   489→      this.logger.error({ err, count: batch.length, totalDropped: this.droppedEvents }, 'Audit batch write failed — audit trail gap');\n   490→    }\n   491→  }\n   492→\n   493→  /** Aggregated audit event statistics for dashboard consumption. */\n   494→  stats(opts?: {\n   495→    tenantId?: string;\n   496→    since?: string;\n   497→    until?: string;\n   498→    bucket?: 'hour' | 'day';\n   499→  }): {\n   500→    byAction: { action: string; count: number }[];\n   501→    byTenant: { tenant_id: string; count: number }[];\n   502→    topActors: { actor: string; count: number }[];\n   503→    trend: { bucket: string; count: number }[];\n   504→  } {\n   505→    this.flush(); // ensure buffered entries are visible\n   506→\n   507→    const params: unknown[] = [];\n   508→    const clauses: string[] = [];\n   509→    if (opts?.tenantId) { clauses.push('tenant_id = ?'); params.push(opts.tenantId); }\n   510→    if (opts?.since) { clauses.push('timestamp >= ?'); params.push(opts.since); }\n   511→    if (opts?.until) { clauses.push('timestamp < ?'); params.push(opts.until); }\n   512→    const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   513→\n   514→    const bucketExpr = opts?.bucket === 'hour'\n   515→      ? \"substr(timestamp, 1, 13)\"  // YYYY-MM-DDTHH\n   516→      : \"substr(timestamp, 1, 10)\"; // YYYY-MM-DD\n   517→\n   518→    const byAction = this.db.prepare(\n   519→      `SELECT action, COUNT(*) as count FROM audit_events ${where} GROUP BY action ORDER BY count DESC`,\n   520→    ).all(...params) as { action: string; count: number }[];\n   521→\n   522→    const byTenant = this.db.prepare(\n   523→      `SELECT COALESCE(tenant_id, '__none__') as tenant_id, COUNT(*) as count FROM audit_events ${where} GROUP BY tenant_id ORDER BY count DESC LIMIT 50`,\n   524→    ).all(...params) as { tenant_id: string; count: number }[];\n   525→\n   526→    const topActors = this.db.prepare(\n   527→      `SELECT COALESCE(actor, '__none__') as actor, COUNT(*) as count FROM audit_events ${where} GROUP BY actor ORDER BY count DESC LIMIT 20`,\n   528→    ).all(...params) as { actor: string; count: number }[];\n   529→\n   530→    const trend = this.db.prepare(\n   531→      `SELECT ${bucketExpr} as bucket, COUNT(*) as count FROM audit_events ${where} GROUP BY bucket ORDER BY bucket ASC`,\n   532→    ).all(...params) as { bucket: string; count: number }[];\n   533→\n   534→    return { byAction, byTenant, topActors, trend };\n   535→  }\n   536→\n   537→  /** Query audit events with optional filters. */\n   538→  query(opts?: {\n   539→    tenantId?: string;\n   540→    action?: AuditAction;\n   541→    since?: string;\n   542→    until?: string;\n   543→    actor?: string;\n   544→    resourceType?: string;\n   545→    resourceId?: string;\n   546→    limit?: number;\n   547→    offset?: number;\n   548→  }): AuditEvent[] {\n   549→    const params: unknown[] = [];\n   550→    const clauses: string[] = [];\n   551→    const keyParts: string[] = [];\n   552→\n   553→    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n   554→    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n   555→    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n   556→    if (opts?.until) { clauses.push('timestamp <= ?'); keyParts.push('until'); params.push(opts.until); }\n   557→    if (opts?.actor) { clauses.push('actor = ?'); keyParts.push('actor'); params.push(opts.actor); }\n   558→    if (opts?.resourceType) { clauses.push('resource_type = ?'); keyParts.push('rtype'); params.push(opts.resourceType); }\n   559→    if (opts?.resourceId) { clauses.push('resource_id = ?'); keyParts.push('rid'); params.push(opts.resourceId); }\n   560→\n   561→    const key = keyParts.join('-') || 'none';\n   562→    let stmt = this.queryStmtCache.get(key);\n   563→    if (!stmt) {\n   564→      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   565→      stmt = this.db.prepare(\n   566→        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n   567→      );\n   568→      this.queryStmtCache.set(key, stmt);\n   569→    }\n   570→\n   571→    const limit = opts?.limit ?? 100;\n   572→    const offset = opts?.offset ?? 0;\n   573→\n   574→    return stmt.all(...params, limit, offset) as AuditEvent[];\n   575→  }\n   576→\n   577→  /**\n   578→   * Verify the integrity of the audit hash chain.\n   579→   * Iterates all chained rows and checks that each hash is consistent with\n   580→   * its predecessor. Pre-chain rows (migrated without prev_hash) are skipped.\n   581→   * If rows were purged, the chain will break at the first remaining row\n   582→   * — this is by design (deletions are detectable).\n   583→   *\n   584→   * When `since`/`until` are provided, only rows within that timestamp range\n   585→   * are checked. The initial previous-hash is seeded from the last chained\n   586→   * row before the range (or genesis if none exists).\n   587→   */\n   588→  verify(opts?: { since?: string; until?: string }): ChainVerifyResult {\n   589→    this.flush(); // ensure all buffered entries are persisted\n   590→\n   591→    const hasRange = opts?.since || opts?.until;\n   592→    const clauses: string[] = [];\n   593→    const params: unknown[] = [];\n   594→    if (opts?.since) { clauses.push('timestamp >= ?'); params.push(opts.since); }\n   595→    if (opts?.until) { clauses.push('timestamp < ?'); params.push(opts.until); }\n   596→    const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   597→\n   598→    const iter = this.db.prepare(\n   599→      `SELECT * FROM audit_events ${where} ORDER BY id ASC`,\n   600→    ).iterate(...params);\n   601→\n   602→    // Seed the previous hash: for ranged queries, look up the last chained\n   603→    // row before the first matching row; for full scans use genesis.\n   604→    let prevHash = GENESIS_HASH;\n   605→    let seeded = !hasRange; // full scan is pre-seeded with genesis\n   606→\n   607→    let verifiedCount = 0;\n   608→\n   609→    for (const raw of iter) {\n   610→      const row = raw as AuditEvent;\n   611→      if (row.prev_hash === null) continue; // pre-chain row\n   612→\n   613→      // Lazily seed prevHash on the first chained row of a ranged query\n   614→      if (!seeded) {\n   615→        const prev = this.db.prepare(\n   616→          'SELECT prev_hash FROM audit_events WHERE id < ? AND prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n   617→        ).get(row.id) as { prev_hash: string } | undefined;\n   618→        prevHash = prev?.prev_hash ?? GENESIS_HASH;\n   619→        seeded = true;\n   620→      }\n   621→\n   622→      const expected = computeChainHash(prevHash, {\n   623→        timestamp: row.timestamp,\n   624→        action: row.action,\n   625→        tenantId: row.tenant_id,\n   626→        actor: row.actor,\n   627→        resourceType: row.resource_type,\n   628→        resourceId: row.resource_id,\n   629→        detail: row.detail,\n   630→        ipAddress: row.ip_address,\n   631→      });\n   632→\n   633→      if (row.prev_hash !== expected) {\n   634→        return { valid: false, verifiedCount, brokenAtId: row.id };\n   635→      }\n   636→\n   637→      prevHash = row.prev_hash;\n   638→      verifiedCount++;\n   639→    }\n   640→\n   641→    return { valid: true, verifiedCount };\n   642→  }\n   643→\n   644→  close(): void {\n   645→    if (this.flushTimer) {\n   646→      clearInterval(this.flushTimer);\n   647→      this.flushTimer = null;\n   648→    }\n   649→    this.flush();\n   650→    try { this.db.close(); } catch { /* best effort */ }\n   651→  }\n   652→}\n   653→"}]},"parent_tool_use_id":null,"session_id":"49a1deed-6488-452d-9e7c-3c755a46230b","uuid":"1f596ffb-ad82-434c-b8db-5f05e8d1bedb","timestamp":"2026-03-19T08:16:53.970Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\auditLog.ts","content":"import crypto from 'node:crypto';\nimport fs from 'node:fs';\nimport Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\n\n/** SHA-256 hash chain genesis value (64 hex zeros). */\nconst GENESIS_HASH = '0'.repeat(64);\n\n/**\n * Compute a chain hash: SHA-256(previousHash + deterministic JSON of entry fields).\n * Each entry's hash commits to the entire chain history before it.\n */\nfunction computeChainHash(prevHash: string, entry: BufferedEntry): string {\n  const payload = prevHash + JSON.stringify([\n    entry.timestamp,\n    entry.action,\n    entry.tenantId,\n    entry.actor,\n    entry.resourceType,\n    entry.resourceId,\n    entry.detail,\n    entry.ipAddress,\n  ]);\n  return crypto.createHash('sha256').update(payload).digest('hex');\n}\n\nconst AUDIT_SCHEMA = `\nCREATE TABLE IF NOT EXISTS audit_events (\n  id INTEGER PRIMARY KEY AUTOINCREMENT,\n  timestamp TEXT NOT NULL,\n  action TEXT NOT NULL,\n  tenant_id TEXT,\n  actor TEXT,\n  resource_type TEXT,\n  resource_id TEXT,\n  detail TEXT,\n  ip_address TEXT,\n  prev_hash TEXT\n);\nCREATE INDEX IF NOT EXISTS idx_audit_ts ON audit_events(timestamp);\nCREATE INDEX IF NOT EXISTS idx_audit_tenant_action_ts ON audit_events(tenant_id, action, timestamp);\nCREATE INDEX IF NOT EXISTS idx_audit_actor ON audit_events(actor);\nCREATE INDEX IF NOT EXISTS idx_audit_resource_type ON audit_events(resource_type);\nDROP INDEX IF EXISTS idx_audit_tenant_ts;\nDROP INDEX IF EXISTS idx_audit_action;\n`;\n\n/** Thrown when an audit event fails to persist — signals an audit trail gap. */\nexport class AuditWriteError extends Error {\n  constructor(\n    public readonly entry: AuditEntry,\n    cause: unknown,\n  ) {\n    super(`Audit write failed for action \"${entry.action}\"`);\n    this.name = 'AuditWriteError';\n    this.cause = cause;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Discriminated-union audit entries — each action carries its own typed payload\n// ---------------------------------------------------------------------------\n\n/** Fields common to every audit entry. */\ninterface AuditEntryBase {\n  tenantId?: string;\n  actor?: string;\n  ipAddress?: string;\n}\n\n// --- Key management ---\ninterface KeyEncryptEntry extends AuditEntryBase {\n  action: 'key:encrypt';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyDecryptEntry extends AuditEntryBase {\n  action: 'key:decrypt';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyDecryptFailedEntry extends AuditEntryBase {\n  action: 'key:decrypt_failed';\n  resourceType: 'credential';\n  resourceId: string;\n  detail: { reason: string };\n}\n\ninterface KeyDeleteEntry extends AuditEntryBase {\n  action: 'key:delete';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyAccessEntry extends AuditEntryBase {\n  action: 'key:access';\n  resourceType: 'credential';\n  resourceId: string;\n}\n\ninterface KeyDeriveEntry extends AuditEntryBase {\n  action: 'key:derive';\n}\n\n// --- Persona management ---\ninterface PersonaCreateEntry extends AuditEntryBase {\n  action: 'persona:create';\n  resourceType: 'persona';\n  resourceId: string;\n}\n\ninterface PersonaDeleteEntry extends AuditEntryBase {\n  action: 'persona:delete';\n  resourceType: 'persona';\n  resourceId: string;\n}\n\n// --- Tool management ---\ninterface ToolLinkEntry extends AuditEntryBase {\n  action: 'tool:link';\n  resourceType: 'persona';\n  resourceId: string;\n  detail: { toolId: string };\n}\n\ninterface ToolDefinitionCreateEntry extends AuditEntryBase {\n  action: 'tool-definition:create';\n  resourceType: 'toolDefinition';\n  resourceId: string;\n}\n\n// --- Credential linking ---\ninterface CredentialLinkEntry extends AuditEntryBase {\n  action: 'credential:link';\n  resourceType: 'persona';\n  resourceId: string;\n  detail: { credentialId: string };\n}\n\n// --- Subscriptions ---\ninterface SubscriptionCreateEntry extends AuditEntryBase {\n  action: 'subscription:create';\n  resourceType: 'subscription';\n  resourceId: string;\n  detail: { personaId: string; eventType: string };\n}\n\ninterface SubscriptionUpdateEntry extends AuditEntryBase {\n  action: 'subscription:update';\n  resourceType: 'subscription';\n  resourceId: string;\n}\n\ninterface SubscriptionDeleteEntry extends AuditEntryBase {\n  action: 'subscription:delete';\n  resourceType: 'subscription';\n  resourceId: string;\n}\n\n// --- Worker pool ---\ninterface WorkerConnectedEntry extends AuditEntryBase {\n  action: 'worker:connected';\n  detail: { workerId: string };\n}\n\ninterface WorkerDisconnectedEntry extends AuditEntryBase {\n  action: 'worker:disconnected';\n  detail: { workerId: string };\n  resourceId?: string;\n}\n\n// --- Triggers ---\ninterface TriggerCreateEntry extends AuditEntryBase {\n  action: 'trigger:create';\n  resourceType: 'trigger';\n  resourceId?: string;\n}\n\ninterface TriggerUpdateEntry extends AuditEntryBase {\n  action: 'trigger:update';\n  resourceType: 'trigger';\n  resourceId: string;\n}\n\ninterface TriggerDeleteEntry extends AuditEntryBase {\n  action: 'trigger:delete';\n  resourceType: 'trigger';\n  resourceId: string;\n}\n\n// --- Events ---\ninterface EventPublishEntry extends AuditEntryBase {\n  action: 'event:publish';\n  resourceType: 'event';\n  resourceId?: string;\n}\n\ninterface EventUpdateEntry extends AuditEntryBase {\n  action: 'event:update';\n  resourceType: 'event';\n  resourceId: string;\n}\n\n// --- Executions ---\ninterface ExecutionSubmitEntry extends AuditEntryBase {\n  action: 'execution:submit';\n  resourceType: 'execution';\n  resourceId?: string;\n}\n\n// --- Webhooks ---\ninterface WebhookReceiveEntry extends AuditEntryBase {\n  action: 'webhook:receive';\n  resourceType: 'webhook';\n  resourceId: string;\n}\n\n// --- OAuth lifecycle ---\ninterface OAuthAuthorizeEntry extends AuditEntryBase {\n  action: 'oauth:authorize';\n  resourceType: 'oauth';\n  resourceId: string; // state parameter\n}\n\ninterface OAuthExchangeEntry extends AuditEntryBase {\n  action: 'oauth:exchange';\n  resourceType: 'oauth';\n  detail: { scopes: string[]; expiresAt: string };\n}\n\ninterface OAuthRefreshEntry extends AuditEntryBase {\n  action: 'oauth:refresh';\n  resourceType: 'oauth';\n  detail: { expiresAt: string };\n}\n\ninterface OAuthRefreshFailedEntry extends AuditEntryBase {\n  action: 'oauth:refresh_failed';\n  resourceType: 'oauth';\n  detail: { reason: string; errorType?: string };\n}\n\ninterface OAuthTokenErrorEntry extends AuditEntryBase {\n  action: 'oauth:token_error';\n  resourceType: 'oauth';\n  detail: { errorType: string; status?: number; transient: boolean; context: string };\n}\n\ninterface OAuthDisconnectEntry extends AuditEntryBase {\n  action: 'oauth:disconnect';\n  resourceType: 'oauth';\n  detail: { serverRevoked: boolean };\n}\n\n// --- Token lifecycle ---\ninterface TokenInjectEntry extends AuditEntryBase {\n  action: 'token:inject';\n  resourceType: 'token';\n}\n\ninterface TokenExpiringSoonEntry extends AuditEntryBase {\n  action: 'token:expiring_soon';\n  resourceType: 'oauth';\n  detail: { expiresAt: string; remainingMinutes: number };\n}\n\n/** Discriminated union of all audit event types. */\nexport type AuditEntry =\n  | KeyEncryptEntry\n  | KeyDecryptEntry\n  | KeyDecryptFailedEntry\n  | KeyDeleteEntry\n  | KeyAccessEntry\n  | KeyDeriveEntry\n  | PersonaCreateEntry\n  | PersonaDeleteEntry\n  | ToolLinkEntry\n  | ToolDefinitionCreateEntry\n  | CredentialLinkEntry\n  | SubscriptionCreateEntry\n  | SubscriptionUpdateEntry\n  | SubscriptionDeleteEntry\n  | WorkerConnectedEntry\n  | WorkerDisconnectedEntry\n  | TriggerCreateEntry\n  | TriggerUpdateEntry\n  | TriggerDeleteEntry\n  | EventPublishEntry\n  | EventUpdateEntry\n  | ExecutionSubmitEntry\n  | WebhookReceiveEntry\n  | OAuthAuthorizeEntry\n  | OAuthExchangeEntry\n  | OAuthRefreshEntry\n  | OAuthRefreshFailedEntry\n  | OAuthTokenErrorEntry\n  | OAuthDisconnectEntry\n  | TokenInjectEntry\n  | TokenExpiringSoonEntry;\n\n/** String-literal union of all valid audit actions. */\nexport type AuditAction = AuditEntry['action'];\n\n/** Row shape returned by audit_events queries. */\nexport interface AuditEvent {\n  id: number;\n  timestamp: string;\n  action: string;\n  tenant_id: string | null;\n  actor: string | null;\n  resource_type: string | null;\n  resource_id: string | null;\n  detail: string | null;\n  ip_address: string | null;\n  prev_hash: string | null;\n}\n\n/** Result of verifying the audit hash chain. */\nexport interface ChainVerifyResult {\n  valid: boolean;\n  verifiedCount: number;\n  brokenAtId?: number;\n}\n\n/** Max entries buffered before an automatic flush. */\nconst BUFFER_FLUSH_SIZE = 50;\n/** Interval (ms) between timer-based flushes. */\nconst BUFFER_FLUSH_INTERVAL_MS = 100;\n\ninterface BufferedEntry {\n  timestamp: string;\n  action: string;\n  tenantId: string | null;\n  actor: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  detail: string | null;\n  ipAddress: string | null;\n}\n\n/** Health snapshot returned by AuditLog.getHealth(). */\nexport interface AuditLogHealth {\n  /** Total number of audit events successfully written to disk. */\n  totalEventsWritten: number;\n  /** Total number of audit events dropped due to flush failures. */\n  droppedEvents: number;\n  /** Number of events currently waiting in the in-memory buffer. */\n  bufferDepth: number;\n  /** Duration of the most recent flush in milliseconds, or null if no flush has occurred. */\n  lastFlushDurationMs: number | null;\n  /** Result of the most recent chain verification, or null if verify() has not been called. */\n  lastChainVerifyResult: ChainVerifyResult | null;\n  /** Size of the audit SQLite database file in bytes, or null if unavailable. */\n  dbSizeBytes: number | null;\n}\n\nexport class AuditLog {\n  private db: Database.Database;\n  private insertStmt: Database.Statement;\n  private queryStmtCache = new Map<string, Database.Statement>();\n  private buffer: BufferedEntry[] = [];\n  private flushTimer: NodeJS.Timeout | null = null;\n  private batchInsert: (entries: BufferedEntry[], hashes: string[]) => void;\n  private lastHash: string;\n  private droppedEvents = 0;\n  private totalEventsWritten = 0;\n  private lastFlushDurationMs: number | null = null;\n  private lastChainVerifyResult: ChainVerifyResult | null = null;\n  private dbPath: string;\n\n  constructor(\n    dbPath: string,\n    private logger: Logger,\n  ) {\n    this.dbPath = dbPath;\n    this.db = new Database(dbPath);\n    this.db.pragma('journal_mode = WAL');\n    this.db.exec(AUDIT_SCHEMA);\n\n    // Migration: add prev_hash column to existing databases that lack it\n    const cols = this.db.pragma('table_info(audit_events)') as { name: string }[];\n    if (!cols.some((c) => c.name === 'prev_hash')) {\n      this.db.exec('ALTER TABLE audit_events ADD COLUMN prev_hash TEXT');\n    }\n\n    this.insertStmt = this.db.prepare(\n      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address, prev_hash) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',\n    );\n\n    // Initialize chain from last stored hash (or genesis for empty / pre-chain DBs)\n    const lastRow = this.db.prepare(\n      'SELECT prev_hash FROM audit_events WHERE prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n    ).get() as { prev_hash: string } | undefined;\n    this.lastHash = lastRow?.prev_hash ?? GENESIS_HASH;\n\n    // Wrap N inserts in a single transaction — one fsync instead of N\n    const stmt = this.insertStmt;\n    this.batchInsert = this.db.transaction((entries: BufferedEntry[], hashes: string[]) => {\n      for (let i = 0; i < entries.length; i++) {\n        const e = entries[i];\n        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress, hashes[i]);\n      }\n    });\n\n    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n\n    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled, hash-chain active)');\n  }\n\n  /** Expose the underlying database for use by RetentionPolicy. */\n  getDb(): Database.Database {\n    return this.db;\n  }\n\n  /** Health snapshot — a nonzero droppedEvents value means the audit trail has gaps. */\n  getHealth(): AuditLogHealth {\n    return {\n      droppedEvents: this.droppedEvents,\n      bufferedEvents: this.buffer.length,\n    };\n  }\n\n  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n  countEvents(before?: string): number {\n    const stmt = before\n      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n    return row.cnt;\n  }\n\n  /**\n   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   * yielding the event loop between batches so concurrent DB operations\n   * are not starved during large purges.\n   */\n  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n    const deleteChunk = this.db.prepare(\n      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n    );\n    let totalDeleted = 0;\n    while (true) {\n      const result = deleteChunk.run(cutoff, chunkSize);\n      totalDeleted += result.changes;\n      if (result.changes < chunkSize) break;\n      await new Promise<void>((resolve) => setImmediate(resolve));\n    }\n    return totalDeleted;\n  }\n\n  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n  record(entry: AuditEntry): void {\n    this.buffer.push({\n      timestamp: new Date().toISOString(),\n      action: entry.action,\n      tenantId: entry.tenantId ?? null,\n      actor: entry.actor ?? null,\n      resourceType: 'resourceType' in entry ? entry.resourceType : null,\n      resourceId: 'resourceId' in entry ? (entry.resourceId ?? null) : null,\n      detail: 'detail' in entry ? JSON.stringify(entry.detail) : null,\n      ipAddress: entry.ipAddress ?? null,\n    });\n    if (this.buffer.length >= BUFFER_FLUSH_SIZE) {\n      this.flush();\n    }\n  }\n\n  /** Flush buffered entries to SQLite in a single transaction, computing chain hashes. */\n  flush(): void {\n    if (this.buffer.length === 0) return;\n    const batch = this.buffer;\n    this.buffer = [];\n\n    // Compute chain hashes for the batch\n    const hashes: string[] = [];\n    let prevHash = this.lastHash;\n    for (const entry of batch) {\n      prevHash = computeChainHash(prevHash, entry);\n      hashes.push(prevHash);\n    }\n\n    try {\n      this.batchInsert(batch, hashes);\n      this.lastHash = prevHash;\n    } catch (err) {\n      this.droppedEvents += batch.length;\n      this.logger.error({ err, count: batch.length, totalDropped: this.droppedEvents }, 'Audit batch write failed — audit trail gap');\n    }\n  }\n\n  /** Aggregated audit event statistics for dashboard consumption. */\n  stats(opts?: {\n    tenantId?: string;\n    since?: string;\n    until?: string;\n    bucket?: 'hour' | 'day';\n  }): {\n    byAction: { action: string; count: number }[];\n    byTenant: { tenant_id: string; count: number }[];\n    topActors: { actor: string; count: number }[];\n    trend: { bucket: string; count: number }[];\n  } {\n    this.flush(); // ensure buffered entries are visible\n\n    const params: unknown[] = [];\n    const clauses: string[] = [];\n    if (opts?.tenantId) { clauses.push('tenant_id = ?'); params.push(opts.tenantId); }\n    if (opts?.since) { clauses.push('timestamp >= ?'); params.push(opts.since); }\n    if (opts?.until) { clauses.push('timestamp < ?'); params.push(opts.until); }\n    const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n\n    const bucketExpr = opts?.bucket === 'hour'\n      ? \"substr(timestamp, 1, 13)\"  // YYYY-MM-DDTHH\n      : \"substr(timestamp, 1, 10)\"; // YYYY-MM-DD\n\n    const byAction = this.db.prepare(\n      `SELECT action, COUNT(*) as count FROM audit_events ${where} GROUP BY action ORDER BY count DESC`,\n    ).all(...params) as { action: string; count: number }[];\n\n    const byTenant = this.db.prepare(\n      `SELECT COALESCE(tenant_id, '__none__') as tenant_id, COUNT(*) as count FROM audit_events ${where} GROUP BY tenant_id ORDER BY count DESC LIMIT 50`,\n    ).all(...params) as { tenant_id: string; count: number }[];\n\n    const topActors = this.db.prepare(\n      `SELECT COALESCE(actor, '__none__') as actor, COUNT(*) as count FROM audit_events ${where} GROUP BY actor ORDER BY count DESC LIMIT 20`,\n    ).all(...params) as { actor: string; count: number }[];\n\n    const trend = this.db.prepare(\n      `SELECT ${bucketExpr} as bucket, COUNT(*) as count FROM audit_events ${where} GROUP BY bucket ORDER BY bucket ASC`,\n    ).all(...params) as { bucket: string; count: number }[];\n\n    return { byAction, byTenant, topActors, trend };\n  }\n\n  /** Query audit events with optional filters. */\n  query(opts?: {\n    tenantId?: string;\n    action?: AuditAction;\n    since?: string;\n    until?: string;\n    actor?: string;\n    resourceType?: string;\n    resourceId?: string;\n    limit?: number;\n    offset?: number;\n  }): AuditEvent[] {\n    const params: unknown[] = [];\n    const clauses: string[] = [];\n    const keyParts: string[] = [];\n\n    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n    if (opts?.until) { clauses.push('timestamp <= ?'); keyParts.push('until'); params.push(opts.until); }\n    if (opts?.actor) { clauses.push('actor = ?'); keyParts.push('actor'); params.push(opts.actor); }\n    if (opts?.resourceType) { clauses.push('resource_type = ?'); keyParts.push('rtype'); params.push(opts.resourceType); }\n    if (opts?.resourceId) { clauses.push('resource_id = ?'); keyParts.push('rid'); params.push(opts.resourceId); }\n\n    const key = keyParts.join('-') || 'none';\n    let stmt = this.queryStmtCache.get(key);\n    if (!stmt) {\n      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n      stmt = this.db.prepare(\n        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n      );\n      this.queryStmtCache.set(key, stmt);\n    }\n\n    const limit = opts?.limit ?? 100;\n    const offset = opts?.offset ?? 0;\n\n    return stmt.all(...params, limit, offset) as AuditEvent[];\n  }\n\n  /**\n   * Verify the integrity of the audit hash chain.\n   * Iterates all chained rows and checks that each hash is consistent with\n   * its predecessor. Pre-chain rows (migrated without prev_hash) are skipped.\n   * If rows were purged, the chain will break at the first remaining row\n   * — this is by design (deletions are detectable).\n   *\n   * When `since`/`until` are provided, only rows within that timestamp range\n   * are checked. The initial previous-hash is seeded from the last chained\n   * row before the range (or genesis if none exists).\n   */\n  verify(opts?: { since?: string; until?: string }): ChainVerifyResult {\n    this.flush(); // ensure all buffered entries are persisted\n\n    const hasRange = opts?.since || opts?.until;\n    const clauses: string[] = [];\n    const params: unknown[] = [];\n    if (opts?.since) { clauses.push('timestamp >= ?'); params.push(opts.since); }\n    if (opts?.until) { clauses.push('timestamp < ?'); params.push(opts.until); }\n    const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n\n    const iter = this.db.prepare(\n      `SELECT * FROM audit_events ${where} ORDER BY id ASC`,\n    ).iterate(...params);\n\n    // Seed the previous hash: for ranged queries, look up the last chained\n    // row before the first matching row; for full scans use genesis.\n    let prevHash = GENESIS_HASH;\n    let seeded = !hasRange; // full scan is pre-seeded with genesis\n\n    let verifiedCount = 0;\n\n    for (const raw of iter) {\n      const row = raw as AuditEvent;\n      if (row.prev_hash === null) continue; // pre-chain row\n\n      // Lazily seed prevHash on the first chained row of a ranged query\n      if (!seeded) {\n        const prev = this.db.prepare(\n          'SELECT prev_hash FROM audit_events WHERE id < ? AND prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n        ).get(row.id) as { prev_hash: string } | undefined;\n        prevHash = prev?.prev_hash ?? GENESIS_HASH;\n        seeded = true;\n      }\n\n      const expected = computeChainHash(prevHash, {\n        timestamp: row.timestamp,\n        action: row.action,\n        tenantId: row.tenant_id,\n        actor: row.actor,\n        resourceType: row.resource_type,\n        resourceId: row.resource_id,\n        detail: row.detail,\n        ipAddress: row.ip_address,\n      });\n\n      if (row.prev_hash !== expected) {\n        return { valid: false, verifiedCount, brokenAtId: row.id };\n      }\n\n      prevHash = row.prev_hash;\n      verifiedCount++;\n    }\n\n    return { valid: true, verifiedCount };\n  }\n\n  close(): void {\n    if (this.flushTimer) {\n      clearInterval(this.flushTimer);\n      this.flushTimer = null;\n    }\n    this.flush();\n    try { this.db.close(); } catch { /* best effort */ }\n  }\n}\n","numLines":653,"startLine":1,"totalLines":653}}}
