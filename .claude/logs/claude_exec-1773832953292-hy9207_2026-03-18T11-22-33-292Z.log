    56→    this.db.exec(AUDIT_SCHEMA);\n    57→    this.insertStmt = this.db.prepare(\n    58→      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',\n    59→    );\n    60→    logger.info({ dbPath }, 'Audit log initialized');\n    61→  }\n    62→\n    63→  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n    64→  countEvents(before?: string): number {\n    65→    const stmt = before\n    66→      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n    67→      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n    68→    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n    69→    return row.cnt;\n    70→  }\n    71→\n    72→  /**\n    73→   * Delete audit events older than `cutoff` in chunks of `chunkSize`.\n    74→   * Returns the total number of rows deleted.\n    75→   */\n    76→  purgeOlderThan(cutoff: string, chunkSize: number): number {\n    77→    const deleteChunk = this.db.prepare(\n    78→      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n    79→    );\n    80→    let totalDeleted = 0;\n    81→    while (true) {\n    82→      const result = deleteChunk.run(cutoff, chunkSize);\n    83→      totalDeleted += result.changes;\n    84→      if (result.changes < chunkSize) break;\n    85→    }\n    86→    return totalDeleted;\n    87→  }\n    88→\n    89→  /** Append an audit event (append-only, never updated). */\n    90→  record(entry: AuditEntry): void {\n    91→    try {\n    92→      this.insertStmt.run(\n    93→        new Date().toISOString(),\n    94→        entry.action,\n    95→        entry.tenantId ?? null,\n    96→        entry.actor ?? null,\n    97→        entry.resourceType ?? null,\n    98→        entry.resourceId ?? null,\n    99→        entry.detail ?? null,\n   100→        entry.ipAddress