[2026-03-19T09:48:00.979Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013cKWqzFtAWDnWT4gzpfihc","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher, SubmitResult } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import type { KafkaClient } from './kafka.js';\n    11→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    12→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    13→import type { TriggerSchedulerHandle } from './triggerScheduler.js';\n    14→import type { TenantDbManager } from './tenantDbManager.js';\n    15→import type { TenantKeyManager } from './tenantKeyManager.js';\n    16→import type { AuditLog, AuditEntry, AuditAction, AuditLogHealth } from './auditLog.js';\n    17→import type { EventProcessorHealth } from './eventProcessor.js';\n    18→import type { RetentionHealth } from './retention.js';\n    19→import type { Logger } from 'pino';\n    20→import * as db from './db/index.js';\n    21→import { readBody, json } from './httpUtils.js';\n    22→\n    23→// --- Route types ---\n    24→\n    25→interface ParsedRoute {\n    26→  resource: string;\n    27→  id?: string;\n    28→  subResource?: string;\n    29→}\n    30→\n    31→type RouteHandler = (\n    32→  req: http.IncomingMessage,\n    33→  res: http.ServerResponse,\n    34→  ctx: RequestContext,\n    35→  route: ParsedRoute | null,\n    36→  queryString: string | undefined,\n    37→  tenantDb: Database.Database | undefined,\n    38→  scopedProjectId: string | undefined,\n    39→  reqLogger: Logger,\n    40→) => Promise<void> | void;\n    41→\n    42→interface RouteEntry {\n    43→  handler: RouteHandler;\n    44→  needsDb?: boolean;\n    45→  adminOnly?: boolean;\n    46→}\n    47→\n    48→/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\n    49→function resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n    50→  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n    51→}\n    52→\n    53→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n    54→function parseRoute(pathname: string): ParsedRoute | null {\n    55→  if (!pathname.startsWith('/api/')) return null;\n    56→  const segments = pathname.slice(5).split('/').filter(Boolean);\n    57→  if (segments.length === 0) return null;\n    58→  return {\n    59→    resource: segments[0]!,\n    60→    id: segments[1],\n    61→    subResource: segments[2],\n    62→  };\n    63→}\n    64→\n    65→export function createHttpApi(\n    66→  auth: Auth,\n    67→  dispatcher: Dispatcher,\n    68→  pool: WorkerPool,\n    69→  tokenManager: TokenManager,\n    70→  oauth: OAuthManager,\n    71→  logger: Logger,\n    72→  database?: Database.Database,\n    73→  tenantDbManager?: TenantDbManager,\n    74→  tenantKeyManager?: TenantKeyManager,\n    75→  auditLog?: AuditLog,\n    76→  getEventProcessorHealth?: () => EventProcessorHealth,\n    77→  kafka?: KafkaClient,\n    78→  onEventPublished?: () => void,\n    79→  triggerScheduler?: TriggerSchedulerHandle,\n    80→  getRetentionHealth?: () => RetentionHealth,\n    81→): http.Server {\n    82→\n    83→  /** Wrap a mutation handler to emit an audit event on successful response. */\n    84→  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    85→    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n    86→      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n    87→      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n    88→        try {\n    89→          auditLog.record({\n    90→            action,\n    91→            tenantId: ctx.projectId || 'default',\n    92→            actor: ctx.userEmail || ctx.projectId,\n    93→            resourceType,\n    94→            resourceId: route?.id,\n    95→            ipAddress: req.socket.remoteAddress,\n    96→          } as AuditEntry);\n    97→        } catch { /* logged inside record() */ }\n    98→      }\n    99→    };\n   100→  }\n   101→\n   102→  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n   103→  const exactRoutes = new Map<string, RouteEntry>();\n   104→\n   105→  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n   106→  for (const [path, method] of [\n   107→    ['/api/oauth/authorize', 'POST'],\n   108→    ['/api/oauth/callback', 'POST'],\n   109→    ['/api/oauth/status', 'GET'],\n   110→    ['/api/oauth/refresh', 'POST'],\n   111→    ['/api/oauth/disconnect', 'DELETE'],\n   112→    ['/api/token', 'POST'],\n   113→  ] as const) {\n   114→    exactRoutes.set(`${method}:${path}`, {\n   115→      adminOnly: true,\n   116→      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   117→        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger, auditLog);\n   118→      },\n   119→    });\n   120→  }\n   121→\n   122→  exactRoutes.set('GET:/api/status', {\n   123→    handler: (_req, res) => {\n   124→      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   125→    },\n   126→  });\n   127→\n   128→  exactRoutes.set('POST:/api/execute', {\n   129→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   130→      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n   131→    }, 'execution:submit', 'execution'),\n   132→  });\n   133→\n   134→  exactRoutes.set('POST:/api/gitlab/webhook', {\n   135→    needsDb: true,\n   136→    handler: withHttpAudit(async (req, res, _ctx, _route, _qs, tenantDb) => {\n   137→      const body = await readBody(req);\n   138→      let parsed: Record<string, unknown> = {};\n   139→      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   140→      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   141→      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   142→      const event = db.publishEvent(tenantDb!, {\n   143→        eventType: `gitlab_${objectKind}`,\n   144→        sourceType: 'gitlab',\n   145→        sourceId: projectPath ?? null,\n   146→        payload: body,\n   147→      });\n   148→      onEventPublished?.();\n   149→      json(res, 201, event);\n   150→    }, 'event:publish', 'event'),\n   151→  });\n   152→\n   153→  // Admin routes\n   154→  exactRoutes.set('GET:/api/admin/users', {\n   155→    adminOnly: true,\n   156→    handler: (_req, res) => {\n   157→      if (tenantDbManager) {\n   158→        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   159→      } else if (database) {\n   160→        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   161→      } else {\n   162→        json(res, 200, { projectIds: [] });\n   163→      }\n   164→    },\n   165→  });\n   166→\n   167→  exactRoutes.set('GET:/api/admin/personas', {\n   168→    adminOnly: true,\n   169→    handler: (_req, res) => {\n   170→      if (tenantDbManager) {\n   171→        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   172→        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   173→        json(res, 200, allPersonas);\n   174→      } else if (database) {\n   175→        json(res, 200, db.listPersonasSummary(database));\n   176→      } else {\n   177→        json(res, 200, []);\n   178→      }\n   179→    },\n   180→  });\n   181→\n   182→  exactRoutes.set('GET:/api/admin/executions', {\n   183→    adminOnly: true,\n   184→    handler: (_req, res, _ctx, _route, queryString) => {\n   185→      const params = new URLSearchParams(queryString || '');\n   186→      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   187→      if (tenantDbManager) {\n   188→        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   189→        tenantDbManager.forEachTenant((tDb) => {\n   190→          allExecs.push(...db.listExecutions(tDb, { limit }));\n   191→        });\n   192→        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   193→        json(res, 200, allExecs.slice(0, limit));\n   194→      } else if (database) {\n   195→        json(res, 200, db.listExecutions(database, {\n   196→          limit,\n   197→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   198→        }));\n   199→      } else {\n   200→        json(res, 200, []);"}]},"parent_tool_use_id":"toolu_01E1Gu5fsFsuPsUk5357FSL8","session_id":"f83562c4-7cd5-4d50-b7ac-458d47ebaf2f","uuid":"ad9ecdda-5055-4b21-8e0b-e7a88c2420a4","timestamp":"2026-03-19T09:48:00.832Z"}
