ptions (\n   158→  id TEXT PRIMARY KEY,\n   159→  project_id TEXT NOT NULL DEFAULT 'default',\n   160→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   161→  event_type TEXT NOT NULL,\n   162→  source_filter TEXT,\n   163→  enabled INTEGER NOT NULL DEFAULT 1,\n   164→  use_case_id TEXT,\n   165→  created_at TEXT NOT NULL,\n   166→  updated_at TEXT NOT NULL\n   167→);\n   168→CREATE INDEX IF NOT EXISTS idx_pes_event_type ON persona_event_subscriptions(event_type, enabled);\n   169→\n   170→CREATE TABLE IF NOT EXISTS persona_triggers (\n   171→  id TEXT PRIMARY KEY,\n   172→  project_id TEXT NOT NULL DEFAULT 'default',\n   173→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   174→  trigger_type TEXT NOT NULL CHECK(trigger_type IN ('manual','schedule','polling','webhook','chain')),\n   175→  config TEXT,\n   176→  enabled INTEGER NOT NULL DEFAULT 1,\n   177→  last_triggered_at TEXT,\n   178→  next_trigger_at TEXT,\n   179→  use_case_id TEXT,\n   180→  created_at TEXT NOT NULL,\n   181→  updated_at TEXT NOT NULL\n   182→);\n   183→CREATE INDEX IF NOT EXISTS idx_pt_due ON persona_triggers(enabled, next_trigger_at);\n   184→\n   185→CREATE TABLE IF NOT EXISTS trigger_fires (\n   186→  id TEXT PRIMARY KEY,\n   187→  trigger_id TEXT NOT NULL,\n   188→  event_id TEXT,\n   189→  execution_id TEXT,\n   190→  status TEXT NOT NULL DEFAULT 'fired' CHECK(status IN ('fired','completed','failed')),\n   191→  duration_ms INTEGER,\n   192→  error_message TEXT,\n   193→  fired_at TEXT NOT NULL\n   194→);\n   195→CREATE INDEX IF NOT EXISTS idx_tf_trigger_fired ON trigger_fires(trigger_id, fired_at DESC);\n   196→CREATE INDEX IF NOT EXISTS idx_tf_trigger_status ON trigger_fires(trigger_id, status);\n   197→\n   198→CREATE TABLE IF NOT EXISTS persona_executions (\n   199→  id TEXT PRIMARY KEY,\n   200→  project_id TEXT NOT NULL DEFAULT 'default',\n   201→  persona_id TEXT NOT NULL,\n   202→  trigger_id TEXT,\n   203→  use_case_id TEXT,\n   204→  event_id TEXT,\n   205→  status TEXT NOT NULL DEFAULT 'queued' CHECK(status IN ('queued','running','completed','failed','cancelled')),\n   206→  input_data TEXT,\n   207→  output_data TEXT,\n   208→  claude_session_id TEXT,\n   209→  model_used TEXT,\n   210→  input_tokens INTEGER DEFAULT 0,\n   211→  output_tokens INTEGER DEFAULT 0,\n   212→  cost_usd REAL DEFAULT 0,\n   213→  error_message TEXT,\n   214→  duration_ms INTEGER,\n   215→  retry_of_execution_id TEXT,\n   216→  retry_count INTEGER DEFAULT 0,\n   217→  started_at TEXT,\n   218→  completed_at TEXT,\n   219→  created_at TEXT NOT NULL\n   220→);\n   221→CREATE INDEX IF NOT EXISTS idx_pex_persona ON persona_executions(persona_id);\n   222→CREATE INDEX IF NOT EXISTS idx_pex_status ON persona_executions(status);\n   223→CREATE INDEX IF NOT EXISTS idx_pex_created_status ON persona_executions(created_at, status);\n   224→\n   225→${DAILY_METRICS_TABLE}\n   226→\n   227→${INFERENCE_PROFILES_TABLE}\n   228→`;\n   229→\n   230→// ---------------------------------------------------------------------------\n   231→// Migrations (legacy single-db)\n   232→// ---------------------------------------------------------------------------\n   233→\n   234→function runLegacyMigrations(db: Database.Database, logger: Logger): void {\n   235→  const tablesToMigrate = [\n   236→    'persona_credentials',\n   237→    'persona_event_subscriptions',\n   238→    'persona_triggers',\n   239→    'persona_executions',\n   240→  ];\n   241→\n   242→  for (const table of tablesToMigrate) {\n   243→    const columns = stmt(db,`PRAGMA table_info(${table})`).all() as Array<{ name: string }>;\n   244→    const hasProjectId = columns.some(c => c.name === 'project_id');\n   245→    if (!hasProjectId) {\n   246→      db.exec(`ALTER TABLE ${table} ADD COLUMN project_id TEXT NOT NULL DEFAULT 'default'`);\n   247→      logger.info({ table }, 'Migration: added project_id column');\n   248→    }\n   249→  }\n   250→\n   251→  db.exec(`\n   252