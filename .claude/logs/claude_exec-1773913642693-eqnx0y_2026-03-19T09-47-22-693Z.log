[2026-03-19T09:48:22.334Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PzasZWmyZzMNP3UXSErrVX","type":"tool_result","content":"     1→import crypto from 'node:crypto';\n     2→import fs from 'node:fs';\n     3→import Database from 'better-sqlite3';\n     4→import type { Logger } from 'pino';\n     5→\n     6→/** SHA-256 hash chain genesis value (64 hex zeros). */\n     7→const GENESIS_HASH = '0'.repeat(64);\n     8→\n     9→/**\n    10→ * Compute a chain hash: SHA-256(previousHash + deterministic JSON of entry fields).\n    11→ * Each entry's hash commits to the entire chain history before it.\n    12→ */\n    13→function computeChainHash(prevHash: string, entry: BufferedEntry): string {\n    14→  const payload = prevHash + JSON.stringify([\n    15→    entry.timestamp,\n    16→    entry.action,\n    17→    entry.tenantId,\n    18→    entry.actor,\n    19→    entry.resourceType,\n    20→    entry.resourceId,\n    21→    entry.detail,\n    22→    entry.ipAddress,\n    23→  ]);\n    24→  return crypto.createHash('sha256').update(payload).digest('hex');\n    25→}\n    26→\n    27→const AUDIT_SCHEMA = `\n    28→CREATE TABLE IF NOT EXISTS audit_events (\n    29→  id INTEGER PRIMARY KEY AUTOINCREMENT,\n    30→  timestamp TEXT NOT NULL,\n    31→  action TEXT NOT NULL,\n    32→  tenant_id TEXT,\n    33→  actor TEXT,\n    34→  resource_type TEXT,\n    35→  resource_id TEXT,\n    36→  detail TEXT,\n    37→  ip_address TEXT,\n    38→  prev_hash TEXT\n    39→);\n    40→CREATE INDEX IF NOT EXISTS idx_audit_ts ON audit_events(timestamp);\n    41→CREATE INDEX IF NOT EXISTS idx_audit_tenant_action_ts ON audit_events(tenant_id, action, timestamp);\n    42→CREATE INDEX IF NOT EXISTS idx_audit_actor ON audit_events(actor);\n    43→CREATE INDEX IF NOT EXISTS idx_audit_resource_type ON audit_events(resource_type);\n    44→DROP INDEX IF EXISTS idx_audit_tenant_ts;\n    45→DROP INDEX IF EXISTS idx_audit_action;\n    46→`;\n    47→\n    48→/** Thrown when an audit event fails to persist — signals an audit trail gap. */\n    49→export class AuditWriteError extends Error {\n    50→  constructor(\n    51→    public readonly entry: AuditEntry,\n    52→    cause: unknown,\n    53→  ) {\n    54→    super(`Audit write failed for action \"${entry.action}\"`);\n    55→    this.name = 'AuditWriteError';\n    56→    this.cause = cause;\n    57→  }\n    58→}\n    59→\n    60→// ---------------------------------------------------------------------------\n    61→// Discriminated-union audit entries — each action carries its own typed payload\n    62→// ---------------------------------------------------------------------------\n    63→\n    64→/** Fields common to every audit entry. */\n    65→interface AuditEntryBase {\n    66→  tenantId?: string;\n    67→  actor?: string;\n    68→  ipAddress?: string;\n    69→}\n    70→\n    71→// --- Key management ---\n    72→interface KeyEncryptEntry extends AuditEntryBase {\n    73→  action: 'key:encrypt';\n    74→  resourceType: 'credential';\n    75→  resourceId: string;\n    76→}\n    77→\n    78→interface KeyDecryptEntry extends AuditEntryBase {\n    79→  action: 'key:decrypt';\n    80→  resourceType: 'credential';\n    81→  resourceId: string;\n    82→}\n    83→\n    84→interface KeyDecryptFailedEntry extends AuditEntryBase {\n    85→  action: 'key:decrypt_failed';\n    86→  resourceType: 'credential';\n    87→  resourceId: string;\n    88→  detail: { reason: string };\n    89→}\n    90→\n    91→interface KeyDeleteEntry extends AuditEntryBase {\n    92→  action: 'key:delete';\n    93→  resourceType: 'credential';\n    94→  resourceId: string;\n    95→}\n    96→\n    97→interface KeyAccessEntry extends AuditEntryBase {\n    98→  action: 'key:access';\n    99→  resourceType: 'credential';\n   100→  resourceId: string;\n   101→}\n   102→\n   103→interface KeyDeriveEntry extends AuditEntryBase {\n   104→  action: 'key:derive';\n   105→}\n   106→\n   107→// --- Persona management ---\n   108→interface PersonaCreateEntry extends AuditEntryBase {\n   109→  action: 'persona:create';\n   110→  resourceType: 'persona';\n   111→  resourceId: string;\n   112→}\n   113→\n   114→interface PersonaDeleteEntry extends AuditEntryBase {\n   115→  action: 'persona:delete';\n   116→  resourceType: 'persona';\n   117→  resourceId: string;\n   118→}\n   119→\n   120→// --- Tool management ---\n   121→interface ToolLinkEntry extends AuditEntryBase {\n   122→  action: 'tool:link';\n   123→  resourceType: 'persona';\n   124→  resourceId: string;\n   125→  detail: { toolId: string };\n   126→}\n   127→\n   128→interface ToolDefinitionCreateEntry extends AuditEntryBase {\n   129→  action: 'tool-definition:create';\n   130→  resourceType: 'toolDefinition';\n   131→  resourceId: string;\n   132→}\n   133→\n   134→// --- Credential linking ---\n   135→interface CredentialLinkEntry extends AuditEntryBase {\n   136→  action: 'credential:link';\n   137→  resourceType: 'persona';\n   138→  resourceId: string;\n   139→  detail: { credentialId: string };\n   140→}\n   141→\n   142→// --- Subscriptions ---\n   143→interface SubscriptionCreateEntry extends AuditEntryBase {\n   144→  action: 'subscription:create';\n   145→  resourceType: 'subscription';\n   146→  resourceId: string;\n   147→  detail: { personaId: string; eventType: string };\n   148→}\n   149→\n   150→interface SubscriptionUpdateEntry extends AuditEntryBase {"}]},"parent_tool_use_id":"toolu_01E1Gu5fsFsuPsUk5357FSL8","session_id":"f83562c4-7cd5-4d50-b7ac-458d47ebaf2f","uuid":"3d94211e-78f2-45d3-aab2-bf8710f5f7ec","timestamp":"2026-03-19T09:48:22.238Z"}
