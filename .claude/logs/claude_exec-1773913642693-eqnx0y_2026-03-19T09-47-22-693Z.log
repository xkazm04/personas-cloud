[2026-03-19T09:48:09.804Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UdC583QyxoHgEyyLttixNE","type":"tool_result","content":"   500→\n   501→  resourceRoutes.set(resourceKey('PUT', 'events', true), {\n   502→    needsDb: true,\n   503→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   504→      const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n   505→      const updated = db.updateEventWithMetadata(tenantDb!, route!.id!, body.status, body.metadata);\n   506→      if (updated) {\n   507→        json(res, 200, updated);\n   508→      } else {\n   509→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   510→        res.end(JSON.stringify({ error: 'Event not found' }));\n   511→      }\n   512→    }, 'event:update', 'event'),\n   513→  });\n   514→\n   515→  // --- Webhooks ---\n   516→  resourceRoutes.set(resourceKey('POST', 'webhooks', true), {\n   517→    needsDb: true,\n   518→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   519→      const personaId = route!.id!;\n   520→      const body = await readBody(req);\n   521→      const event = db.publishEvent(tenantDb!, {\n   522→        eventType: 'webhook_received',\n   523→        sourceType: 'webhook',\n   524→        sourceId: personaId,\n   525→        targetPersonaId: personaId,\n   526→        payload: body,\n   527→      });\n   528→      onEventPublished?.();\n   529→      json(res, 201, event);\n   530→    }, 'webhook:receive', 'webhook'),\n   531→  });\n   532→\n   533→  // --- Executions ---\n   534→  resourceRoutes.set(resourceKey('GET', 'executions', false), {\n   535→    needsDb: true,\n   536→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   537→      const params = new URLSearchParams(queryString || '');\n   538→      const executions = db.listExecutions(tenantDb!, {\n   539→        personaId: params.get('personaId') ?? undefined,\n   540→        status: params.get('status') ?? undefined,\n   541→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   542→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   543→        projectId: scopedProjectId,\n   544→      });\n   545→      json(res, 200, executions);\n   546→    },\n   547→  });\n   548→\n   549→  resourceRoutes.set(resourceKey('POST', 'executions', true, 'cancel'), {\n   550→    handler: (_req, res, _ctx, route) => {\n   551→      handleCancelExecution(res, dispatcher, route!.id!);\n   552→    },\n   553→  });\n   554→\n   555→  resourceRoutes.set(resourceKey('GET', 'executions', true), {\n   556→    handler: (_req, res, _ctx, route, queryString) => {\n   557→      const params = new URLSearchParams(queryString || '');\n   558→      const offset = parseInt(params.get('offset') || '0', 10);\n   559→      handleGetExecution(res, dispatcher, route!.id!, offset);\n   560→    },\n   561→  });\n   562→\n   563→  // ── Request handler ──\n   564→  const server = http.createServer(async (req, res) => {\n   565→    // Request correlation ID\n   566→    const reqId = nanoid();\n   567→    const reqLogger = logger.child({ reqId });\n   568→    res.setHeader('X-Request-Id', reqId);\n   569→\n   570→    // Security headers\n   571→    res.setHeader('X-Content-Type-Options', 'nosniff');\n   572→\n   573→    // CORS headers\n   574→    const origin = req.headers.origin ?? '';\n   575→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n   576→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n   577→    if (isAdminRoute) {\n   578→      if (origin && origin === allowedOrigin) {\n   579→        res.setHeader('Access-Control-Allow-Origin', origin);\n   580→      }\n   581→    } else {\n   582→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n   583→    }\n   584→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n   585→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n   586→\n   587→    if (req.method === 'OPTIONS') {\n   588→      res.writeHead(204);\n   589→      res.end();\n   590→      return;\n   591→    }\n   592→\n   593→    const url = req.url || '/';\n   594→    const [pathname, queryString] = url.split('?');\n   595→    const route = parseRoute(pathname ?? '');\n   596→\n   597→    // Unauthenticated endpoint\n   598→    if (pathname === '/health' && req.method === 'GET') {\n   599→      await handleHealth(res, pool, dispatcher, tokenManager, oauth, getEventProcessorHealth, database, tenantDbManager, kafka, triggerScheduler, auditLog, getRetentionHealth);\n   600→      return;\n   601→    }\n   602→\n   603→    // Auth check\n   604→    const ctx = auth.validateAndExtractContext(req);\n   605→    if (!ctx) {\n   606→      res.writeHead(401, { 'Content-Type': 'application/json' });\n   607→      res.end(JSON.stringify({ error: 'Unauthorized', reqId }));\n   608→      return;\n   609→    }\n   610→\n   611→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n   612→\n   613→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n   614→      if (tenantDbManager && projectId) {\n   615→        return tenantDbManager.getTenantDb(projectId);\n   616→      }\n   617→      return database;\n   618→    };\n   619→    const tenantDb = resolveDatabase(ctx.projectId);\n   620→\n   621→    try {\n   622→      // O(1) exact-path lookup\n   623→      const exactEntry = exactRoutes.get(`${req.method}:${pathname}`);\n   624→      if (exactEntry) {\n   625→        if (exactEntry.adminOnly && requireAdmin(ctx, res)) return;\n   626→        if (exactEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   627→        await exactEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   628→        return;\n   629→      }\n   630→\n   631→      // O(1) resource-route lookup\n   632→      if (route) {\n   633→        const resKey = resourceKey(req.method!, route.resource, !!route.id, route.subResource);\n   634→        const resEntry = resourceRoutes.get(resKey);\n   635→        if (resEntry) {\n   636→          if (resEntry.adminOnly && requireAdmin(ctx, res)) return;\n   637→          if (resEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   638→          await resEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   639→          return;\n   640→        }\n   641→      }\n   642→\n   643→      // No matching route\n   644→      json(res, 404, { error: 'Not found', reqId });\n   645→    } catch (err) {\n   646→      if (err instanceof Error && err.message === 'Payload too large') {\n   647→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   648→        res.end(JSON.stringify({ error: 'Payload too large', reqId }));\n   649→        return;\n   650→      }\n   651→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   652→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   653→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists', reqId }));\n   654→        return;\n   655→      }\n   656→      reqLogger.error({ err, url }, 'HTTP handler error');\n   657→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   658→      res.end(JSON.stringify({ error: 'Internal server error', reqId }));\n   659→    }\n   660→  });\n   661→\n   662→  return server;\n   663→}\n   664→\n   665→/**\n   666→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   667→ * Returns the entity on success, or null after sending a 404 response.\n   668→ */\n   669→function withScopedEntity<T extends { projectId?: string | null }>(\n   670→  entity: T | undefined,\n   671→  scopedProjectId: string | undefined,\n   672→  res: http.ServerResponse,\n   673→): T | null {\n   674→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   675→    json(res, 404, { error: 'Not found' });\n   676→    return null;\n   677→  }\n   678→  return entity;\n   679→}\n   680→\n   681→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   682→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   683→  if (ctx.authType !== 'admin') {\n   684→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   685→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   686→    return true;\n   687→  }\n   688→  return false;\n   689→}\n   690→\n   691→// --- Existing handlers ---\n   692→\n   693→/** Heartbeat age (ms) beyond which a worker is considered stale. */\n   694→const STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n   695→\n   696→async function handleHealth(\n   697→  res: http.ServerResponse,\n   698→  pool: WorkerPool,\n   699→  dispatcher: Dispatcher,\n   700→  tokenManager: TokenManager,\n   701→  oauth: OAuthManager,\n   702→  getEventProcessorHealth?: () => EventProcessorHealth,\n   703→  database?: Database.Database,\n   704→  tenantDbManager?: TenantDbManager,\n   705→  kafka?: KafkaClient,\n   706→  triggerScheduler?: TriggerSchedulerHandle,\n   707→  auditLog?: AuditLog,\n   708→  getRetentionHealth?: () => RetentionHealth,\n   709→): Promise<void> {\n   710→  const issues: string[] = [];\n   711→\n   712→  const counts = pool.getWorkerCount();\n   713→  const workers = pool.getWorkers();\n   714→  const now = Date.now();\n   715→  const staleWorkers = workers\n   716→    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n   717→    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n   718→\n   719→  if (staleWorkers.length > 0) {\n   720→    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n   721→  }\n   722→\n   723→  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n   724→  if (database) {\n   725→    try {\n   726→      database.prepare('SELECT 1').get();\n   727→      dbHealth.status = 'ok';\n   728→    } catch {\n   729→      dbHealth.status = 'error';\n   730→      issues.push('database unreachable');\n   731→    }\n   732→  }\n   733→  if (tenantDbManager) {\n   734→    try {\n   735→      const tenantIds = tenantDbManager.listTenantIds();\n   736→      dbHealth.tenantCount = tenantIds.length;\n   737→      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n   738→    } catch {\n   739→      dbHealth.tenantCount = -1;\n   740→      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n   741→      issues.push('tenant DB listing failed');\n   742→    }\n   743→  }\n   744→\n   745→  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n   746→  if (kafka) {\n   747→    const kh = await kafka.checkHealth();\n   748→    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n   749→    if (kh.status === 'error') {"}]},"parent_tool_use_id":"toolu_01E1Gu5fsFsuPsUk5357FSL8","session_id":"f83562c4-7cd5-4d50-b7ac-458d47ebaf2f","uuid":"24ced9dd-eca7-4573-b719-935c7964428e","timestamp":"2026-03-19T09:48:09.646Z"}
