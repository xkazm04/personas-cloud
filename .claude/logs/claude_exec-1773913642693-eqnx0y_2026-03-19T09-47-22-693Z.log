[2026-03-19T09:49:28.779Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BAgV8GxvXXpFPh8J2dxq2M","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→\n     3→// ---------------------------------------------------------------------------\n     4→// Prepared statement cache — compile SQL once per (db, sql) pair\n     5→// ---------------------------------------------------------------------------\n     6→\n     7→const _stmtCache = new WeakMap<Database.Database, Map<string, Database.Statement>>();\n     8→\n     9→export function stmt(db: Database.Database, sql: string): Database.Statement {\n    10→  let map = _stmtCache.get(db);\n    11→  if (!map) {\n    12→    map = new Map();\n    13→    _stmtCache.set(db, map);\n    14→  }\n    15→  let s = map.get(sql);\n    16→  if (!s) {\n    17→    s = db.prepare(sql);\n    18→    map.set(sql, s);\n    19→  }\n    20→  return s;\n    21→}\n    22→\n    23→// ---------------------------------------------------------------------------\n    24→// Dynamic WHERE-clause builder\n    25→// ---------------------------------------------------------------------------\n    26→\n    27→/**\n    28→ * Build a WHERE clause from a filter object and a mapping of filter keys to SQL column names.\n    29→ * Only keys present (non-undefined) in `filters` are included.\n    30→ */\n    31→export function buildWhereClause(\n    32→  filters: Record<string, unknown>,\n    33→  columnMap: Record<string, string>,\n    34→): { sql: string; params: unknown[] } {\n    35→  const clauses: string[] = [];\n    36→  const params: unknown[] = [];\n    37→  for (const [key, col] of Object.entries(columnMap)) {\n    38→    const value = filters[key];\n    39→    if (value !== undefined) {\n    40→      clauses.push(`${col} = ?`);\n    41→      params.push(value);\n    42→    }\n    43→  }\n    44→  const sql = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n    45→  return { sql, params };\n    46→}\n    47→\n    48→// ---------------------------------------------------------------------------\n    49→// Merge-update helpers\n    50→// ---------------------------------------------------------------------------\n    51→\n    52→/** Convert an optional boolean update into a SQLite 0/1 integer, falling back to the current value. */\n    53→export function mergeEnabled(update: boolean | null | undefined, current: boolean): number {\n    54→  return update !== undefined && update !== null ? (update ? 1 : 0) : (current ? 1 : 0);\n    55→}\n    56→\n    57→/** Run an UPDATE … SET <columns>, updated_at = ? WHERE id = ? with the given column→value map. */\n    58→export function mergeUpdate(db: Database.Database, table: string, id: string, columns: Record<string, unknown>): void {\n    59→  const now = new Date().toISOString();\n    60→  const setClauses = Object.keys(columns).map(col => `${col} = ?`).join(', ');\n    61→  const values = Object.values(columns);\n    62→  stmt(db, `UPDATE ${table} SET ${setClauses}, updated_at = ? WHERE id = ?`).run(...values, now, id);\n    63→}\n    64→\n    65→// ---------------------------------------------------------------------------\n    66→// Generic row mapper — replaces per-entity rowTo* boilerplate\n    67→// ---------------------------------------------------------------------------\n    68→\n    69→export interface FieldSpec {\n    70→  col: string;\n    71→  bool?: boolean;\n    72→  json?: boolean;\n    73→  nullable?: boolean;\n    74→  optional?: boolean;\n    75→  default?: unknown;\n    76→}\n    77→\n    78→export type ColumnMap<T> = { [K in keyof T]-?: FieldSpec };\n    79→\n    80→export function createRowMapper<T>(columnMap: ColumnMap<T>): (row: Record<string, unknown>) => T {\n    81→  const entries = Object.entries(columnMap) as [string, FieldSpec][];\n    82→  return (row: Record<string, unknown>): T => {\n    83→    const result: Record<string, unknown> = {};\n    84→    for (const [key, spec] of entries) {\n    85→      const val = row[spec.col];\n    86→      if (spec.bool) {\n    87→        result[key] = val === 1;\n    88→      } else if (spec.json) {\n    89→        result[key] = JSON.parse((val as string) || (spec.default as string ?? '[]'));\n    90→      } else if (spec.nullable) {\n    91→        result[key] = val ?? null;\n    92→      } else if (spec.optional) {\n    93→        result[key] = val ?? undefined;\n    94→      } else if ('default' in spec) {\n    95→        result[key] = val ?? spec.default;\n    96→      } else {\n    97→        result[key] = val;\n    98→      }\n    99→    }\n   100→    return result as T;\n   101→  };\n   102→}\n   103→"}]},"parent_tool_use_id":null,"session_id":"f83562c4-7cd5-4d50-b7ac-458d47ebaf2f","uuid":"db18a7dd-545f-4bf5-af81-cc2c5b3a8c79","timestamp":"2026-03-19T09:49:28.680Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\db\\_helpers.ts","content":"import Database from 'better-sqlite3';\n\n// ---------------------------------------------------------------------------\n// Prepared statement cache — compile SQL once per (db, sql) pair\n// ---------------------------------------------------------------------------\n\nconst _stmtCache = new WeakMap<Database.Database, Map<string, Database.Statement>>();\n\nexport function stmt(db: Database.Database, sql: string): Database.Statement {\n  let map = _stmtCache.get(db);\n  if (!map) {\n    map = new Map();\n    _stmtCache.set(db, map);\n  }\n  let s = map.get(sql);\n  if (!s) {\n    s = db.prepare(sql);\n    map.set(sql, s);\n  }\n  return s;\n}\n\n// ---------------------------------------------------------------------------\n// Dynamic WHERE-clause builder\n// ---------------------------------------------------------------------------\n\n/**\n * Build a WHERE clause from a filter object and a mapping of filter keys to SQL column names.\n * Only keys present (non-undefined) in `filters` are included.\n */\nexport function buildWhereClause(\n  filters: Record<string, unknown>,\n  columnMap: Record<string, string>,\n): { sql: string; params: unknown[] } {\n  const clauses: string[] = [];\n  const params: unknown[] = [];\n  for (const [key, col] of Object.entries(columnMap)) {\n    const value = filters[key];\n    if (value !== undefined) {\n      clauses.push(`${col} = ?`);\n      params.push(value);\n    }\n  }\n  const sql = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n  return { sql, params };\n}\n\n// ---------------------------------------------------------------------------\n// Merge-update helpers\n// ---------------------------------------------------------------------------\n\n/** Convert an optional boolean update into a SQLite 0/1 integer, falling back to the current value. */\nexport function mergeEnabled(update: boolean | null | undefined, current: boolean): number {\n  return update !== undefined && update !== null ? (update ? 1 : 0) : (current ? 1 : 0);\n}\n\n/** Run an UPDATE … SET <columns>, updated_at = ? WHERE id = ? with the given column→value map. */\nexport function mergeUpdate(db: Database.Database, table: string, id: string, columns: Record<string, unknown>): void {\n  const now = new Date().toISOString();\n  const setClauses = Object.keys(columns).map(col => `${col} = ?`).join(', ');\n  const values = Object.values(columns);\n  stmt(db, `UPDATE ${table} SET ${setClauses}, updated_at = ? WHERE id = ?`).run(...values, now, id);\n}\n\n// ---------------------------------------------------------------------------\n// Generic row mapper — replaces per-entity rowTo* boilerplate\n// ---------------------------------------------------------------------------\n\nexport interface FieldSpec {\n  col: string;\n  bool?: boolean;\n  json?: boolean;\n  nullable?: boolean;\n  optional?: boolean;\n  default?: unknown;\n}\n\nexport type ColumnMap<T> = { [K in keyof T]-?: FieldSpec };\n\nexport function createRowMapper<T>(columnMap: ColumnMap<T>): (row: Record<string, unknown>) => T {\n  const entries = Object.entries(columnMap) as [string, FieldSpec][];\n  return (row: Record<string, unknown>): T => {\n    const result: Record<string, unknown> = {};\n    for (const [key, spec] of entries) {\n      const val = row[spec.col];\n      if (spec.bool) {\n        result[key] = val === 1;\n      } else if (spec.json) {\n        result[key] = JSON.parse((val as string) || (spec.default as string ?? '[]'));\n      } else if (spec.nullable) {\n        result[key] = val ?? null;\n      } else if (spec.optional) {\n        result[key] = val ?? undefined;\n      } else if ('default' in spec) {\n        result[key] = val ?? spec.default;\n      } else {\n        result[key] = val;\n      }\n    }\n    return result as T;\n  };\n}\n","numLines":103,"startLine":1,"totalLines":103}}}
