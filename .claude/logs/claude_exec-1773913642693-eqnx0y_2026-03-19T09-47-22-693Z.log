I (`packages/orchestrator/src/httpApi.ts`)\n- **`GET /api/metrics/daily`** endpoint with `?from=YYYY-MM-DD&to=YYYY-MM-DD` query params\n- Admin auth: aggregates across all tenants (merges daily rows by date)\n- User auth: scoped to their tenant DB\n- Response shape: `{ daily: DailyMetricsRow[], byPersona: DailyMetricsByPersonaRow[] }`"}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":406,"cache_read_input_tokens":79911,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":406},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f83562c4-7cd5-4d50-b7ac-458d47ebaf2f","uuid":"ddd55470-60d0-4ba0-a716-5b1ffc1b89c1"}
