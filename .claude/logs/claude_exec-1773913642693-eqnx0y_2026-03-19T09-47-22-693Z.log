[2026-03-19T09:48:19.727Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MV8J5TFGLA2UMguCin8EV5","type":"tool_result","content":"     1→/**\n     2→ * In-memory min-heap keyed by next_trigger_at (epoch ms).\n     3→ *\n     4→ * The heap avoids full-table DB scans on every scheduler tick.\n     5→ * The database remains the source of truth — the heap is rebuilt on startup\n     6→ * from the DB and updated incrementally on trigger CRUD operations.\n     7→ */\n     8→\n     9→export interface HeapEntry {\n    10→  triggerId: string;\n    11→  tenantId: string; // 'default' for single-tenant mode\n    12→  nextTriggerAt: number; // epoch ms\n    13→}\n    14→\n    15→export class TriggerHeap {\n    16→  private heap: HeapEntry[] = [];\n    17→  /** triggerId → index in heap array. Enables O(log n) remove/update. */\n    18→  private index = new Map<string, number>();\n    19→\n    20→  get size(): number {\n    21→    return this.heap.length;\n    22→  }\n    23→\n    24→  /** Look at the earliest entry without removing it. */\n    25→  peek(): HeapEntry | undefined {\n    26→    return this.heap[0];\n    27→  }\n    28→\n    29→  /** Add an entry (or update if triggerId already exists). */\n    30→  push(entry: HeapEntry): void {\n    31→    const existing = this.index.get(entry.triggerId);\n    32→    if (existing !== undefined) {\n    33→      // Update in place and re-heapify\n    34→      this.heap[existing] = entry;\n    35→      this.siftUp(existing);\n    36→      this.siftDown(existing);\n    37→      return;\n    38→    }\n    39→    const i = this.heap.length;\n    40→    this.heap.push(entry);\n    41→    this.index.set(entry.triggerId, i);\n    42→    this.siftUp(i);\n    43→  }\n    44→\n    45→  /** Remove and return the earliest entry. */\n    46→  pop(): HeapEntry | undefined {\n    47→    if (this.heap.length === 0) return undefined;\n    48→    const top = this.heap[0]!;\n    49→    this.removeAt(0);\n    50→    return top;\n    51→  }\n    52→\n    53→  /** Remove an entry by triggerId. Returns true if found. */\n    54→  remove(triggerId: string): boolean {\n    55→    const i = this.index.get(triggerId);\n    56→    if (i === undefined) return false;\n    57→    this.removeAt(i);\n    58→    return true;\n    59→  }\n    60→\n    61→  /** Pop all entries whose nextTriggerAt <= now. Returns them in ascending order. */\n    62→  popDue(now: number): HeapEntry[] {\n    63→    const result: HeapEntry[] = [];\n    64→    while (this.heap.length > 0 && this.heap[0]!.nextTriggerAt <= now) {\n    65→      result.push(this.pop()!);\n    66→    }\n    67→    return result;\n    68→  }\n    69→\n    70→  /** Remove all entries. */\n    71→  clear(): void {\n    72→    this.heap.length = 0;\n    73→    this.index.clear();\n    74→  }\n    75→\n    76→  // ---- internal heap operations ----\n    77→\n    78→  private removeAt(i: number): void {\n    79→    const last = this.heap.length - 1;\n    80→    const removed = this.heap[i]!;\n    81→    this.index.delete(removed.triggerId);\n    82→\n    83→    if (i === last) {\n    84→      this.heap.pop();\n    85→      return;\n    86→    }\n    87→\n    88→    // Move last element into the gap and re-heapify\n    89→    const moved = this.heap.pop()!;\n    90→    this.heap[i] = moved;\n    91→    this.index.set(moved.triggerId, i);\n    92→    this.siftUp(i);\n    93→    this.siftDown(i);\n    94→  }\n    95→\n    96→  private siftUp(i: number): void {\n    97→    while (i > 0) {\n    98→      const parent = (i - 1) >> 1;\n    99→      if (this.heap[parent]!.nextTriggerAt <= this.heap[i]!.nextTriggerAt) break;\n   100→      this.swap(i, parent);\n   101→      i = parent;\n   102→    }\n   103→  }\n   104→\n   105→  private siftDown(i: number): void {\n   106→    const n = this.heap.length;\n   107→    while (true) {\n   108→      let smallest = i;\n   109→      const left = 2 * i + 1;\n   110→      const right = 2 * i + 2;\n   111→      if (left < n && this.heap[left]!.nextTriggerAt < this.heap[smallest]!.nextTriggerAt) {\n   112→        smallest = left;\n   113→      }\n   114→      if (right < n && this.heap[right]!.nextTriggerAt < this.heap[smallest]!.nextTriggerAt) {\n   115→        smallest = right;\n   116→      }\n   117→      if (smallest === i) break;\n   118→      this.swap(i, smallest);\n   119→      i = smallest;\n   120→    }\n   121→  }\n   122→\n   123→  private swap(a: number, b: number): void {\n   124→    const entryA = this.heap[a]!;\n   125→    const entryB = this.heap[b]!;\n   126→    this.heap[a] = entryB;\n   127→    this.heap[b] = entryA;\n   128→    this.index.set(entryA.triggerId, b);\n   129→    this.index.set(entryB.triggerId, a);\n   130→  }\n   131→}\n   132→"}]},"parent_tool_use_id":"toolu_01E1Gu5fsFsuPsUk5357FSL8","session_id":"f83562c4-7cd5-4d50-b7ac-458d47ebaf2f","uuid":"e913737c-37d6-47de-91a3-0ee66c0f5a7c","timestamp":"2026-03-19T09:48:19.652Z"}
