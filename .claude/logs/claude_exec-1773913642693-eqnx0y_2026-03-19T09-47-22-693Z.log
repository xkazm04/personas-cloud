 += chunk.length;\n      if (totalBytes > MAX_BODY_BYTES) {\n        req.destroy();\n        reject(new Error('Payload too large'));\n        return;\n      }\n      chunks.push(chunk);\n    });\n    req.on('end', () => resolve(Buffer.concat(chunks).toString()));\n    req.on('error', reject);\n  });\n}\n","numLines":27,"startLine":1,"totalLines":27}}}
