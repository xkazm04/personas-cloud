[2026-03-19T09:48:04.458Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017kqmLVN8mxJe1yCw9JPEQw","type":"tool_result","content":"   200→      try {\n   201→        const tenantDb = tenantDbManager.getTenantDb(tenantId);\n   202→        const loaded = loadDbIntoHeap(heap, tenantDb, tenantId);\n   203→        triggerCount += loaded;\n   204→        logger.debug({ tenantId, triggerCount: loaded }, 'Loaded tenant triggers into heap');\n   205→      } catch (err) {\n   206→        const loadedBeforeFailure = heap.size - heapSizeBefore;\n   207→        failedTenants++;\n   208→        logger.error({ err, tenantId, triggersLoadedBeforeFailure: loadedBeforeFailure }, 'Failed to load triggers for tenant into heap');\n   209→      }\n   210→    }\n   211→  } else if (database) {\n   212→    tenantCount = 1;\n   213→    const loaded = loadDbIntoHeap(heap, database, 'default');\n   214→    triggerCount += loaded;\n   215→  }\n   216→\n   217→  const totalDurationMs = Date.now() - startMs;\n   218→  const summary: BootstrapSummary = { totalDurationMs, tenantCount, triggerCount, failedTenants };\n   219→  logger.info(summary, 'Heap bootstrap complete');\n   220→  return summary;\n   221→}\n   222→\n   223→function loadDbIntoHeap(heap: TriggerHeap, dbConn: Database.Database, tenantId: string): number {\n   224→  const rows = db.loadEnabledTriggerTimes(dbConn);\n   225→  for (const row of rows) {\n   226→    heap.push({\n   227→      triggerId: row.id,\n   228→      tenantId,\n   229→      nextTriggerAt: new Date(row.nextTriggerAt).getTime(),\n   230→    });\n   231→  }\n   232→  return rows.length;\n   233→}\n   234→\n   235→// ---------------------------------------------------------------------------\n   236→// Compute next delay from the heap (O(1) peek)\n   237→// ---------------------------------------------------------------------------\n   238→\n   239→function computeNextDelay(heap: TriggerHeap): number {\n   240→  const top = heap.peek();\n   241→  if (!top) return MAX_DELAY_MS;\n   242→  const deltaMs = top.nextTriggerAt - Date.now();\n   243→  return Math.min(MAX_DELAY_MS, Math.max(MIN_DELAY_MS, deltaMs));\n   244→}\n   245→\n   246→// ---------------------------------------------------------------------------\n   247→// Fire due triggers — batch-fetch from DB by ID, then process\n   248→// ---------------------------------------------------------------------------\n   249→\n   250→function fireDueEntries(\n   251→  due: HeapEntry[],\n   252→  tickNow: number,\n   253→  database: Database.Database | null,\n   254→  tenantDbManager: TenantDbManager | undefined,\n   255→  heap: TriggerHeap,\n   256→  logger: Logger,\n   257→  onEventPublished?: () => void,\n   258→): { fired: number; missed: number } {\n   259→  let firedCount = 0;\n   260→  let missedCount = 0;\n   261→\n   262→  // Build latency lookup from heap entries for missed-trigger detection\n   263→  const scheduledAtByTriggerId = new Map<string, number>();\n   264→  for (const entry of due) {\n   265→    scheduledAtByTriggerId.set(entry.triggerId, entry.nextTriggerAt);\n   266→  }\n   267→\n   268→  // Group by tenantId so we hit each DB once with a batch query\n   269→  const byTenant = new Map<string, HeapEntry[]>();\n   270→  for (const entry of due) {\n   271→    let list = byTenant.get(entry.tenantId);\n   272→    if (!list) {\n   273→      list = [];\n   274→      byTenant.set(entry.tenantId, list);\n   275→    }\n   276→    list.push(entry);\n   277→  }\n   278→\n   279→  for (const [tenantId, entries] of byTenant) {\n   280→    try {\n   281→      const tenantDb = tenantDbManager\n   282→        ? tenantDbManager.getTenantDb(tenantId)\n   283→        : database;\n   284→      if (!tenantDb) continue;\n   285→\n   286→      const ids = entries.map(e => e.triggerId);\n   287→      const triggers = db.getTriggersByIdsWithPersona(tenantDb, ids);\n   288→\n   289→      for (const trigger of triggers) {\n   290→        // Skip polling triggers\n   291→        if (trigger.triggerType === 'polling') continue;\n   292→\n   293→        // Detect missed trigger (due more than 60 s ago) and log with full context\n   294→        const scheduledAt = scheduledAtByTriggerId.get(trigger.id);\n   295→        if (scheduledAt !== undefined) {\n   296→          const latencyMs = tickNow - scheduledAt;\n   297→          if (latencyMs > MAX_DELAY_MS) {\n   298→            missedCount++;\n   299→            logger.warn({\n   300→              triggerId: trigger.id,\n   301→              tenantId,\n   302→              personaId: trigger.personaId,\n   303→              scheduledAt: new Date(scheduledAt).toISOString(),\n   304→              latencyMs,\n   305→            }, 'Missed trigger: fired late');\n   306→          }\n   307→        }\n   308→\n   309→        try {\n   310→          const parsedConfig = trigger.parsedConfig;\n   311→          let eventType = 'trigger_fired';\n   312→          let payload: string | null = null;\n   313→          if (parsedConfig) {\n   314→            if (parsedConfig.event_type) eventType = parsedConfig.event_type;\n   315→            if (parsedConfig.payload) payload = JSON.stringify(parsedConfig.payload);\n   316→          }\n   317→\n   318→          // Skip triggers for deleted or disabled personas\n   319→          if (trigger.personaProjectId == null) {\n   320→            logger.warn({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona not found (deleted?)');\n   321→            continue;\n   322→          }\n   323→          if (!trigger.personaEnabled) {\n   324→            logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');\n   325→            continue;\n   326→          }\n   327→\n   328→          const triggerProjectId = tenantId !== 'default' ? tenantId : trigger.personaProjectId;\n   329→\n   330→          // Publish event\n   331→          const publishedEvent = db.publishEvent(tenantDb, {\n   332→            eventType,\n   333→            sourceType: 'trigger',\n   334→            sourceId: trigger.id,\n   335→            targetPersonaId: trigger.personaId,\n   336→            projectId: triggerProjectId,\n   337→            useCaseId: trigger.useCaseId,\n   338→            payload,\n   339→          });\n   340→          onEventPublished?.();\n   341→\n   342→          // Record fire history\n   343→          db.recordTriggerFire(tenantDb, {\n   344→            triggerId: trigger.id,\n   345→            eventId: publishedEvent.id,\n   346→          });\n   347→\n   348→          // Compute next trigger time and update DB\n   349→          const now = new Date().toISOString();\n   350→          const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);\n   351→          db.updateTriggerTimings(tenantDb, trigger.id, now, nextTriggerAt);\n   352→\n   353→          // Push updated time back into heap\n   354→          if (nextTriggerAt) {\n   355→            heap.push({ triggerId: trigger.id, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });\n   356→          }\n   357→\n   358→          logger.info({\n   359→            triggerId: trigger.id,\n   360→            personaId: trigger.personaId,\n   361→            eventType,\n   362→            nextTriggerAt,\n   363→          }, 'Trigger fired');\n   364→          firedCount++;\n   365→        } catch (err) {\n   366→          logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');\n   367→        }\n   368→      }\n   369→    } catch (err) {\n   370→      logger.error({ err, tenantId }, 'Trigger scheduler tick failed for tenant');\n   371→    }\n   372→  }\n   373→  return { fired: firedCount, missed: missedCount };\n   374→}\n   375→"}]},"parent_tool_use_id":"toolu_01E1Gu5fsFsuPsUk5357FSL8","session_id":"f83562c4-7cd5-4d50-b7ac-458d47ebaf2f","uuid":"cba45c01-528f-4075-858f-31b45cfae703","timestamp":"2026-03-19T09:48:0