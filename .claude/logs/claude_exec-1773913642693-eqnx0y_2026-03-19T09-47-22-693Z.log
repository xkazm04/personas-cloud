[2026-03-19T09:49:22.036Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NSuvntJFBAepDiiBakmMjk","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import type { TenantDbManager } from './tenantDbManager.js';\n     4→import { RetentionPolicy } from './retentionPolicy.js';\n     5→\n     6→// ── Declarative retention policies for tenant tables ────────────────────\n     7→// Each policy is parameterised by its TABLE_REGISTRY spec; the shared\n     8→// RetentionPolicy class handles safety-fraction checks and chunked deletes.\n     9→\n    10→const execPolicy = new RetentionPolicy({\n    11→  table: 'persona_executions',\n    12→  deleteFilter: \"status IN ('completed', 'failed', 'cancelled')\",\n    13→});\n    14→\n    15→const eventsPolicy = new RetentionPolicy({\n    16→  table: 'persona_events',\n    17→  deleteFilter: \"status NOT IN ('pending', 'processing', 'partial-retry')\",\n    18→});\n    19→\n    20→const stuckEventsPolicy = new RetentionPolicy({\n    21→  table: 'persona_events',\n    22→  deleteFilter: \"status IN ('pending', 'processing', 'partial-retry')\",\n    23→});\n    24→\n    25→const dailyMetricsPolicy = new RetentionPolicy({ table: 'daily_metrics' });\n    26→const systemDailyMetricsPolicy = new RetentionPolicy({ table: 'system_daily_metrics' });\n    27→\n    28→/** Yield the event loop so concurrent reads/writes can proceed between tenants. */\n    29→function yieldTick(): Promise<void> {\n    30→  return new Promise((resolve) => setImmediate(resolve));\n    31→}\n    32→\n    33→/** How often we check whether it's time for the daily run (60 seconds). */\n    34→const SCHEDULE_CHECK_MS = 60_000;\n    35→\n    36→/** system_kv keys used to persist retention job state. */\n    37→const LAST_RUN_KEY = 'retention_last_run_date';\n    38→const LAST_RUN_AT_KEY = 'retention_last_run_at';\n    39→\n    40→/** Return today's UTC date as YYYY-MM-DD. */\n    41→function utcToday(): string {\n    42→  return new Date().toISOString().slice(0, 10);\n    43→}\n    44→\n    45→/** Read the last-run UTC date from system_kv, or null if never run. */\n    46→function getLastRunDate(tenantDbManager: TenantDbManager): string | null {\n    47→  const row = tenantDbManager.getSystemDb().prepare(\n    48→    'SELECT value FROM system_kv WHERE key = ?',\n    49→  ).get(LAST_RUN_KEY) as { value: string } | undefined;\n    50→  return row?.value ?? null;\n    51→}\n    52→\n    53→/** Persist the current UTC date as the last-run date. */\n    54→function setLastRunDate(tenantDbManager: TenantDbManager, date: string): void {\n    55→  tenantDbManager.getSystemDb().prepare(\n    56→    'INSERT INTO system_kv (key, value) VALUES (?, ?) ON CONFLICT(key) DO UPDATE SET value = excluded.value',\n    57→  ).run(LAST_RUN_KEY, date);\n    58→}\n    59→\n    60→/** Persist the ISO timestamp of the last successful run. */\n    61→function setLastRunAt(tenantDbManager: TenantDbManager, isoTimestamp: string): void {\n    62→  tenantDbManager.getSystemDb().prepare(\n    63→    'INSERT INTO system_kv (key, value) VALUES (?, ?) ON CONFLICT(key) DO UPDATE SET value = excluded.value',\n    64→  ).run(LAST_RUN_AT_KEY, isoTimestamp);\n    65→}\n    66→\n    67→/** Read the ISO timestamp of the last successful run, or null. */\n    68→function getLastRunAt(tenantDbManager: TenantDbManager): string | null {\n    69→  const row = tenantDbManager.getSystemDb().prepare(\n    70→    'SELECT value FROM system_kv WHERE key = ?',\n    71→  ).get(LAST_RUN_AT_KEY) as { value: string } | undefined;\n    72→  return row?.value ?? null;\n    73→}\n    74→\n    75→// ── Structured metrics ──────────────────────────────────────────────────\n    76→\n    77→/** Health snapshot returned by getHealth(). */\n    78→export interface RetentionHealth {\n    79→  lastRunAt: string | null;\n    80→  lastRunDurationMs: number | null;\n    81→  retentionDays: number;\n    82→  metricsRetentionDays: number;\n    83→  totalRuns: number;\n    84→  totalErrors: number;\n    85→  running: boolean;\n    86→  lastRun: RetentionRunMetrics | null;\n    87→}\n    88→\n    89→/** Per-run structured metrics emitted as a log entry and cached in memory. */\n    90→export interface RetentionRunMetrics {\n    91→  tenantsProcessed: number;\n    92→  tenantErrors: number;\n    93→  rowsDeleted: {\n    94→    persona_executions: number;\n    95→    persona_events: number;\n    96→    persona_events_stuck: number;\n    97→    daily_metrics: number;\n    98→    system_daily_metrics: number;\n    99→  };\n   100→  retentionDays: number;\n   101→  metricsRetentionDays: number;\n   102→  cutoff: string;\n   103→  stuckCutoff: string;\n   104→  metricsCutoff: string;\n   105→  durationMs: number;\n   106→  errors: string[];\n   107→}\n   108→\n   109→/** Handle returned by startRetentionJob. */\n   110→export interface RetentionJobHandle {\n   111→  timer: NodeJS.Timeout;\n   112→  getHealth: () => RetentionHealth;\n   113→}\n   114→\n   115→/**\n   116→ * Daily retention job: purge old executions/events and aggregate daily metrics.\n   117→ *\n   118→ * Uses a 60-second wall-clock poll instead of a drifting 24-hour setInterval.\n   119→ * The last successful run date is persisted in system_kv so the job runs\n   120→ * exactly once per UTC calendar day regardless of restarts or event-loop delays.\n   121→ */\n   122→export function startRetentionJob(\n   123→  tenantDbManager: TenantDbManager,\n   124→  retentionDays: number,\n   125→  metricsRetentionDays: number,\n   126→  logger: Logger,\n   127→): RetentionJobHandle {\n   128→  logger.info({ retentionDays, metricsRetentionDays }, 'Retention job scheduled (wall-clock daily)');\n   129→\n   130→  let running = false;\n   131→  let totalRuns = 0;\n   132→  let totalErrors = 0;\n   133→  let lastRunMetrics: RetentionRunMetrics | null = null;\n   134→  let lastRunDurationMs: number | null = null;\n   135→\n   136→  // Seed lastRunAt from persisted value so the health endpoint is informative\n   137→  // even before the first run of this process.\n   138→  let lastRunAt: string | null = getLastRunAt(tenantDbManager);\n   139→\n   140→  async function tick(): Promise<void> {\n   141→    if (running) return;\n   142→\n   143→    const today = utcToday();\n   144→    const lastRun = getLastRunDate(tenantDbManager);\n   145→\n   146→    if (lastRun === today) return; // already ran today\n   147→\n   148→    running = true;\n   149→    logger.info({ today, lastRun }, 'Retention job triggered');\n   150→    const t0 = Date.now();\n   151→    try {\n   152→      const metrics = await runRetention(tenantDbManager, retentionDays, metricsRetentionDays, logger);\n   153→      const durationMs = Date.now() - t0;\n   154→      metrics.durationMs = durationMs;\n   155→\n   156→      lastRunMetrics = metrics;\n   157→      lastRunDurationMs = durationMs;\n   158→      totalRuns++;\n   159→      if (metrics.tenantErrors > 0) totalErrors += metrics.tenantErrors;\n   160→\n   161→      const now = new Date().toISOString();\n   162→      lastRunAt = now;\n   163→      setLastRunDate(tenantDbManager, today);\n   164→      setLastRunAt(tenantDbManager, now);\n   165→\n   166→      logger.info({\n   167→        component: 'retention',\n   168→        event: 'retention_run_complete',\n   169→        durationMs,\n   170→        retentionDays,\n   171→        metricsRetentionDays,\n   172→        tenantsProcessed: metrics.tenantsProcessed,\n   173→        tenantErrors: metrics.tenantErrors,\n   174→        rowsDeleted: metrics.rowsDeleted,\n   175→        cutoff: metrics.cutoff,\n   176→        stuckCutoff: metrics.stuckCutoff,\n   177→        metricsCutoff: metrics.metricsCutoff,\n   178→        errors: metrics.errors.length > 0 ? metrics.errors : undefined,\n   179→      }, 'Retention job completed');\n   180→    } catch (err) {\n   181→      const durationMs = Date.now() - t0;\n   182→      totalErrors++;\n   183→\n   184→      logger.error({\n   185→        component: 'retention',\n   186→        event: 'retention_run_failed',\n   187→        err,\n   188→        durationMs,\n   189→        retentionDays,\n   190→        metricsRetentionDays,\n   191→      }, 'Retention job failed — will retry next tick');\n   192→    } finally {\n   193→      running = false;\n   194→    }\n   195→  }\n   196→\n   197→  // First check shortly after startup, then every 60 seconds\n   198→  setTimeout(() => tick(), 5000);\n   199→\n   200→  const timer = setInterval(() => {\n   201→    tick();\n   202→  }, SCHEDULE_CHECK_MS);\n   203→\n   204→  function getHealth(): RetentionHealth {\n   205→    return {\n   206→      lastRunAt,\n   207→      lastRunDurationMs,\n   208→      retentionDays,\n   209→      metricsRetentionDays,\n   210→      totalRuns,\n   211→      totalErrors,\n   212→      running,\n   213→      lastRun: lastRunMetrics,\n   214→    };\n   215→  }\n   216→\n   217→  return { timer, getHealth };\n   218→}\n   219→\n   220→async function runRetention(\n   221→  tenantDbManager: TenantDbManager,\n   222→  retentionDays: number,\n   223→  metricsRetentionDays: number,\n   224→  logger: Logger,\n   225→): Promise<RetentionRunMetrics> {\n   226→  const cutoff = new Date(Date.now() - retentionDays * 86_400_000).toISOString();\n   227→  const stuckCutoff = new Date(Date.now() - retentionDays * 7 * 86_400_000).toISOString();\n   228→  const metricsCutoff = new Date(Date.now() - metricsRetentionDays * 86_400_000).toISOString().slice(0, 10);\n   229→\n   230→  const metrics: RetentionRunMetrics = {\n   231→    tenantsProcessed: 0,\n   232→    tenantErrors: 0,\n   233→    rowsDeleted: {\n   234→      persona_executions: 0,\n   235→      persona_events: 0,\n   236→      persona_events_stuck: 0,\n   237→      daily_metrics: 0,\n   238→      system_daily_metrics: 0,\n   239→    },\n   240→    retentionDays,\n   241→    metricsRetentionDays,\n   242→    cutoff,\n   243→    stuckCutoff,\n   244→    metricsCutoff,\n   245→    durationMs: 0, // filled in by caller\n   246→    errors: [],\n   247→  };\n   248→\n   249→  const tenantIds = tenantDbManager.listTenantIds();\n   250→  for (const projectId of tenantIds) {\n   251→    try {\n   252→      const db = tenantDbManager.getTenantDb(projectId);\n   253→      const ctx = { projectId };\n   254→\n   255→      const purgedExecutions = await execPolicy.purge(db, cutoff, logger, ctx);\n   256→      const purgedEvents = await eventsPolicy.purge(db, cutoff, logger, ctx);\n   257→      const purgedStuckEvents = await stuckEventsPolicy.purge(db, stuckCutoff, logger, ctx);\n   258→      const purgedMetrics = await dailyMetricsPolicy.purge(db, metricsCutoff, logger, ctx);\n   259→\n   260→      metrics.rowsDeleted.persona_executions += purgedExecutions;\n   261→      metrics.rowsDeleted.persona_events += purgedEvents;\n   262→      metrics.rowsDeleted.persona_events_stuck += purgedStuckEvents;\n   263→      metrics.rowsDeleted.daily_metrics += purgedMetrics;\n   264→      metrics.tenantsProcessed++;\n   265→\n   266→      if (purgedExecutions > 0 || purgedEvents > 0 || purgedStuckEvents > 0 || purgedMetrics > 0) {\n   267→        logger.info({ projectId, purgedExecutions, purgedEvents, purgedStuckEvents, purgedMetrics }, 'Retention cleanup complete');\n   268→      }\n   269→    } catch (err) {\n   270→      metrics.tenantErrors++;\n   271→      const msg = err instanceof Error ? err.message : String(err);\n   272→      metrics.errors.push(`${projectId}: ${msg}`);\n   273→      logger.error({ err, projectId }, 'Retention cleanup failed for tenant');\n   274→    }\n   275→    // Yield between tenants so the event loop stays responsive\n   276→    await yieldTick();\n   277→  }\n   278→\n   279→  // ── Reduce phase: aggregate all tenant metrics into system.db ──\n   280→  try {\n   281→    aggregateSystemMetrics(tenantDbManager, logger);\n   282→  } catch (err) {\n   283→    const msg = err instanceof Error ? err.message : String(err);\n   284→    metrics.errors.push(`aggregation: ${msg}`);\n   285→    logger.error({ err }, 'System-wide metrics aggregation failed');\n   286→  }\n   287→\n   288→  // ── Purge old system-wide metrics ──\n   289→  try {\n   290→    const purged = await systemDailyMetricsPolicy.purge(\n   291→      tenantDbManager.getSystemDb(), metricsCutoff, logger,\n   292→    );\n   293→    metrics.rowsDeleted.system_daily_metrics += purged;\n   294→    if (purged > 0) {\n   295→      logger.info({ purged }, 'Purged old system_daily_metrics rows');\n   296→    }\n   297→  } catch (err) {\n   298→    const msg = err instanceof Error ? err.message : String(err);\n   299→    metrics.errors.push(`system_daily_metrics: ${msg}`);\n   300→    logger.error({ err }, 'system_daily_metrics purge failed');\n   301→  }\n   302→\n   303→  return metrics;\n   304→}\n   305→\n   306→/**\n   307→ * Map-reduce step: read daily_metrics from every tenant DB and write\n   308→ * a system-wide summary to the system_daily_metrics table in system.db.\n   309→ * Replaces rows wholesale each run so the system view is always consistent.\n   310→ */\n   311→function aggregateSystemMetrics(\n   312→  tenantDbManager: TenantDbManager,\n   313→  logger: Logger,\n   314→): void {\n   315→  const systemDb = tenantDbManager.getSystemDb();\n   316→  const tenantIds = tenantDbManager.listTenantIds();\n   317→\n   318→  // Accumulate per-day totals across all tenants\n   319→  const dayMap = new Map<string, {\n   320→    total_executions: number;\n   321→    completed: number;\n   322→    failed: number;\n   323→    total_cost_usd: number;\n   324→    total_duration_ms: number;\n   325→    tenant_count: number;\n   326→  }>();\n   327→\n   328→  for (const projectId of tenantIds) {\n   329→    try {\n   330→      const db = tenantDbManager.getTenantDb(projectId);\n   331→      const rows = db.prepare(\n   332→        'SELECT date, total_executions, completed, failed, total_cost_usd, total_duration_ms FROM daily_metrics',\n   333→      ).all() as Array<{\n   334→        date: string;\n   335→        total_executions: number;\n   336→        completed: number;\n   337→        failed: number;\n   338→        total_cost_usd: number;\n   339→        total_duration_ms: number;\n   340→      }>;\n   341→\n   342→      for (const row of rows) {\n   343→        const existing = dayMap.get(row.date);\n   344→        if (existing) {\n   345→          existing.total_executions += row.total_executions;\n   346→          existing.completed += row.completed;\n   347→          existing.failed += row.failed;\n   348→          existing.total_cost_usd += row.total_cost_usd;\n   349→          existing.total_duration_ms += row.total_duration_ms;\n   350→          existing.tenant_count += 1;\n   351→        } else {\n   352→          dayMap.set(row.date, {\n   353→            total_executions: row.total_executions,\n   354→            completed: row.completed,\n   355→            failed: row.failed,\n   356→            total_cost_usd: row.total_cost_usd,\n   357→            total_duration_ms: row.total_duration_ms,\n   358→            tenant_count: 1,\n   359→          });\n   360→        }\n   361→      }\n   362→    } catch (err) {\n   363→      logger.warn({ err, projectId }, 'Failed to read metrics for tenant during aggregation');\n   364→    }\n   365→  }\n   366→\n   367→  if (dayMap.size === 0) return;\n   368→\n   369→  // Write aggregated metrics in a single transaction\n   370→  const now = new Date().toISOString();\n   371→  systemDb.transaction(() => {\n   372→    const upsert = systemDb.prepare(`\n   373→      INSERT INTO system_daily_metrics\n   374→        (date, total_executions, completed, failed, total_cost_usd, total_duration_ms, tenant_count, aggregated_at)\n   375→      VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n   376→      ON CONFLICT(date) DO UPDATE SET\n   377→        total_executions = excluded.total_executions,\n   378→        completed = excluded.completed,\n   379→        failed = excluded.failed,\n   380→        total_cost_usd = excluded.total_cost_usd,\n   381→        total_duration_ms = excluded.total_duration_ms,\n   382→        tenant_count = excluded.tenant_count,\n   383→        aggregated_at = excluded.aggregated_at\n   384→    `);\n   385→    for (const [date, m] of dayMap) {\n   386→      upsert.run(date, m.total_executions, m.completed, m.failed, m.total_cost_usd, m.total_duration_ms, m.tenant_count, now);\n   387→    }\n   388→  })();\n   389→\n   390→  logger.info({ days: dayMap.size, tenants: tenantIds.length }, 'System-wide metrics aggregation complete');\n   391→}\n   392→"}]},"parent_tool_use_id":null,"session_id":"f83562c4-7cd5-4d50-b7ac-458d47ebaf2f","uuid":"41f98f2a-3d27-436c-9143-606eba1fd3e8","timestamp":"2026-03-19T09:49:21.962Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\retention.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport { RetentionPolicy } from './retentionPolicy.js';\n\n// ── Declarative retention policies for tenant tables ────────────────────\n// Each policy is parameterised by its TABLE_REGISTRY spec; the shared\n// RetentionPolicy class handles safety-fraction checks and chunked deletes.\n\nconst execPolicy = new RetentionPolicy({\n  table: 'persona_executions',\n  deleteFilter: \"status IN ('completed', 'failed', 'cancelled')\",\n});\n\nconst eventsPolicy = new RetentionPolicy({\n  table: 'persona_events',\n  deleteFilter: \"status NOT IN ('pending', 'processing', 'partial-retry')\",\n});\n\nconst stuckEventsPolicy = new RetentionPolicy({\n  table: 'persona_events',\n  deleteFilter: \"status IN ('pending', 'processing', 'partial-retry')\",\n});\n\nconst dailyMetricsPolicy = new RetentionPolicy({ table: 'daily_metrics' });\nconst systemDailyMetricsPolicy = new RetentionPolicy({ table: 'system_daily_metrics' });\n\n/** Yield the event loop so concurrent reads/writes can proceed between tenants. */\nfunction yieldTick(): Promise<void> {\n  return new Promise((resolve) => setImmediate(resolve));\n}\n\n/** How often we check whether it's time for the daily run (60 seconds). */\nconst SCHEDULE_CHECK_MS = 60_000;\n\n/** system_kv keys used to persist retention job state. */\nconst LAST_RUN_KEY = 'retention_last_run_date';\nconst LAST_RUN_AT_KEY = 'retention_last_run_at';\n\n/** Return today's UTC date as YYYY-MM-DD. */\nfunction utcToday(): string {\n  return new Date().toISOString().slice(0, 10);\n}\n\n/** Read the last-run UTC date from system_kv, or null if never run. */\nfunction getLastRunDate(tenantDbManager: TenantDbManager): string | null {\n  const row = tenantDbManager.getSystemDb().prepare(\n    'SELECT value FROM system_kv WHERE key = ?',\n  ).get(LAST_RUN_KEY) as { value: string } | undefined;\n  return row?.value ?? null;\n}\n\n/** Persist the current UTC date as the last-run date. */\nfunction setLastRunDate(tenantDbManager: TenantDbManager, date: string): void {\n  tenantDbManager.getSystemDb().prepare(\n    'INSERT INTO system_kv (key, value) VALUES (?, ?) ON CONFLICT(key) DO UPDATE SET value = excluded.value',\n  ).run(LAST_RUN_KEY, date);\n}\n\n/** Persist the ISO timestamp of the last successful run. */\nfunction setLastRunAt(tenantDbManager: TenantDbManager, isoTimestamp: string): void {\n  tenantDbManager.getSystemDb().prepare(\n    'INSERT INTO system_kv (key, value) VALUES (?, ?) ON CONFLICT(key) DO UPDATE SET value = excluded.value',\n  ).run(LAST_RUN_AT_KEY, isoTimestamp);\n}\n\n/** Read the ISO timestamp of the last successful run, or null. */\nfunction getLastRunAt(tenantDbManager: TenantDbManager): string | null {\n  const row = tenantDbManager.getSystemDb().prepare(\n    'SELECT value FROM system_kv WHERE key = ?',\n  ).get(LAST_RUN_AT_KEY) as { value: string } | undefined;\n  return row?.value ?? null;\n}\n\n// ── Structured metrics ──────────────────────────────────────────────────\n\n/** Health snapshot returned by getHealth(). */\nexport interface RetentionHealth {\n  lastRunAt: string | null;\n  lastRunDurationMs: number | null;\n  retentionDays: number;\n  metricsRetentionDays: number;\n  totalRuns: number;\n  totalErrors: number;\n  running: boolean;\n  lastRun: RetentionRunMetrics | null;\n}\n\n/** Per-run structured metrics emitted as a log entry and cached in memory. */\nexport interface RetentionRunMetrics {\n  tenantsProcessed: number;\n  tenantErrors: number;\n  rowsDeleted: {\n    persona_executions: number;\n    persona_events: number;\n    persona_events_stuck: number;\n    daily_metrics: number;\n    system_daily_metrics: number;\n  };\n  retentionDays: number;\n  metricsRetentionDays: number;\n  cutoff: string;\n  stuckCutoff: string;\n  metricsCutoff: string;\n  durationMs: number;\n  errors: string[];\n}\n\n/** Handle returned by startRetentionJob. */\nexport interface RetentionJobHandle {\n  timer: NodeJS.Timeout;\n  getHealth: () => RetentionHealth;\n}\n\n/**\n * Daily retention job: purge old executions/events and aggregate daily metrics.\n *\n * Uses a 60-second wall-clock poll instead of a drifting 24-hour setInterval.\n * The last successful run date is persisted in system_kv so the job runs\n * exactly once per UTC calendar day regardless of restarts or event-loop delays.\n */\nexport function startRetentionJob(\n  tenantDbManager: TenantDbManager,\n  retentionDays: number,\n  metricsRetentionDays: number,\n  logger: Logger,\n): RetentionJobHandle {\n  logger.info({ retentionDays, metricsRetentionDays }, 'Retention job scheduled (wall-clock daily)');\n\n  let running = false;\n  let totalRuns = 0;\n  let totalErrors = 0;\n  let lastRunMetrics: RetentionRunMetrics | null = null;\n  let lastRunDurationMs: number | null = null;\n\n  // Seed lastRunAt from persisted value so the health endpoint is informative\n  // even before the first run of this process.\n  let lastRunAt: string | null = getLastRunAt(tenantDbManager);\n\n  async function tick(): Promise<void> {\n    if (running) return;\n\n    const today = utcToday();\n    const lastRun = getLastRunDate(tenantDbManager);\n\n    if (lastRun === today) return; // already ran today\n\n    running = true;\n    logger.info({ today, lastRun }, 'Retention job triggered');\n    const t0 = Date.now();\n    try {\n      const metrics = await runRetention(tenantDbManager, retentionDays, metricsRetentionDays, logger);\n      const durationMs = Date.now() - t0;\n      metrics.durationMs = durationMs;\n\n      lastRunMetrics = metrics;\n      lastRunDurationMs = durationMs;\n      totalRuns++;\n      if (metrics.tenantErrors > 0) totalErrors += metrics.tenantErrors;\n\n      const now = new Date().toISOString();\n      lastRunAt = now;\n      setLastRunDate(tenantDbManager, today);\n      setLastRunAt(tenantDbManager, now);\n\n      logger.info({\n        component: 'retention',\n        event: 'retention_run_complete',\n        durationMs,\n        retentionDays,\n        metricsRetentionDays,\n        tenantsProcessed: metrics.tenantsProcessed,\n        tenantErrors: metrics.tenantErrors,\n        rowsDeleted: metrics.rowsDeleted,\n        cutoff: metrics.cutoff,\n        stuckCutoff: metrics.stuckCutoff,\n        metricsCutoff: metrics.metricsCutoff,\n        errors: metrics.errors.length > 0 ? metrics.errors : undefined,\n      }, 'Retention job completed');\n    } catch (err) {\n      const durationMs = Date.now() - t0;\n      totalErrors++;\n\n      logger.error({\n        component: 'retention',\n        event: 'retention_run_failed',\n        err,\n        durationMs,\n        retentionDays,\n        metricsRetentionDays,\n      }, 'Retention job failed — will retry next tick');\n    } finally {\n      running = false;\n    }\n  }\n\n  // First check shortly after startup, then every 60 seconds\n  setTimeout(() => tick(), 5000);\n\n  const timer = setInterval(() => {\n    tick();\n  }, SCHEDULE_CHECK_MS);\n\n  function getHealth(): RetentionHealth {\n    return {\n      lastRunAt,\n      lastRunDurationMs,\n      retentionDays,\n      metricsRetentionDays,\n      totalRuns,\n      totalErrors,\n      running,\n      lastRun: lastRunMetrics,\n    };\n  }\n\n  return { timer, getHealth };\n}\n\nasync function runRetention(\n  tenantDbManager: TenantDbManager,\n  retentionDays: number,\n  metricsRetentionDays: number,\n  logger: Logger,\n): Promise<RetentionRunMetrics> {\n  const cutoff = new Date(Date.now() - retentionDays * 86_400_000).toISOString();\n  const stuckCutoff = new Date(Date.now() - retentionDays * 7 * 86_400_000).toISOString();\n  const metricsCutoff = new Date(Date.now() - metricsRetentionDays * 86_400_000).toISOString().slice(0, 10);\n\n  const metrics: RetentionRunMetrics = {\n    tenantsProcessed: 0,\n    tenantErrors: 0,\n    rowsDeleted: {\n      persona_executions: 0,\n      persona_events: 0,\n      persona_events_stuck: 0,\n      daily_metrics: 0,\n      system_daily_metrics: 0,\n    },\n    retentionDays,\n    metricsRetentionDays,\n    cutoff,\n    stuckCutoff,\n    metricsCutoff,\n    durationMs: 0, // filled in by caller\n    errors: [],\n  };\n\n  const tenantIds = tenantDbManager.listTenantIds();\n  for (const projectId of tenantIds) {\n    try {\n      const db = tenantDbManager.getTenantDb(projectId);\n      const ctx = { projectId };\n\n      const purgedExecutions = await execPolicy.purge(db, cutoff, logger, ctx);\n      const purgedEvents = await eventsPolicy.purge(db, cutoff, logger, ctx);\n      const purgedStuckEvents = await stuckEventsPolicy.purge(db, stuckCutoff, logger, ctx);\n      const purgedMetrics = await dailyMetricsPolicy.purge(db, metricsCutoff, logger, ctx);\n\n      metrics.rowsDeleted.persona_executions += purgedExecutions;\n      metrics.rowsDeleted.persona_events += purgedEvents;\n      metrics.rowsDeleted.persona_events_stuck += purgedStuckEvents;\n      metrics.rowsDeleted.daily_metrics += purgedMetrics;\n      metrics.tenantsProcessed++;\n\n      if (purgedExecutions > 0 || purgedEvents > 0 || purgedStuckEvents > 0 || purgedMetrics > 0) {\n        logger.info({ projectId, purgedExecutions, purgedEvents, purgedStuckEvents, purgedMetrics }, 'Retention cleanup complete');\n      }\n    } catch (err) {\n      metrics.tenantErrors++;\n      const msg = err instanceof Error ? err.message : String(err);\n      metrics.errors.push(`${projectId}: ${msg}`);\n      logger.error({ err, projectId }, 'Retention cleanup failed for tenant');\n    }\n    // Yield between tenants so the event loop stays responsive\n    await yieldTick();\n  }\n\n  // ── Reduce phase: aggregate all tenant metrics into system.db ──\n  try {\n    aggregateSystemMetrics(tenantDbManager, logger);\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    metrics.errors.push(`aggregation: ${msg}`);\n    logger.error({ err }, 'System-wide metrics aggregation failed');\n  }\n\n  // ── Purge old system-wide metrics ──\n  try {\n    const purged = await systemDailyMetricsPolicy.purge(\n      tenantDbManager.getSystemDb(), metricsCutoff, logger,\n    );\n    metrics.rowsDeleted.system_daily_metrics += purged;\n    if (purged > 0) {\n      logger.info({ purged }, 'Purged old system_daily_metrics rows');\n    }\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    metrics.errors.push(`system_daily_metrics: ${msg}`);\n    logger.error({ err }, 'system_daily_metrics purge failed');\n  }\n\n  return metrics;\n}\n\n/**\n * Map-reduce step: read daily_metrics from every tenant DB and write\n * a system-wide summary to the system_daily_metrics table in system.db.\n * Replaces rows wholesale each run so the system view is always consistent.\n */\nfunction aggregateSystemMetrics(\n  tenantDbManager: TenantDbManager,\n  logger: Logger,\n): void {\n  const systemDb = tenantDbManager.getSystemDb();\n  const tenantIds = tenantDbManager.listTenantIds();\n\n  // Accumulate per-day totals across all tenants\n  const dayMap = new Map<string, {\n    total_executions: number;\n    completed: number;\n    failed: number;\n    total_cost_usd: number;\n    total_duration_ms: number;\n    tenant_count: number;\n  }>();\n\n  for (const projectId of tenantIds) {\n    try {\n      const db = tenantDbManager.getTenantDb(projectId);\n      const rows = db.prepare(\n        'SELECT date, total_executions, completed, failed, total_cost_usd, total_duration_ms FROM daily_metrics',\n      ).all() as Array<{\n        date: string;\n        total_executions: number;\n        completed: number;\n        failed: number;\n        total_cost_usd: number;\n        total_duration_ms: number;\n      }>;\n\n      for (const row of rows) {\n        const existing = dayMap.get(row.date);\n        if (existing) {\n          existing.total_executions += row.total_executions;\n          existing.completed += row.completed;\n          existing.failed += row.failed;\n          existing.total_cost_usd += row.total_cost_usd;\n          existing.total_duration_ms += row.total_duration_ms;\n          existing.tenant_count += 1;\n        } else {\n          dayMap.set(row.date, {\n            total_executions: row.total_executions,\n            completed: row.completed,\n            failed: row.failed,\n            total_cost_usd: row.total_cost_usd,\n            total_duration_ms: row.total_duration_ms,\n            tenant_count: 1,\n          });\n        }\n      }\n    } catch (err) {\n      logger.warn({ err, projectId }, 'Failed to read metrics for tenant during aggregation');\n    }\n  }\n\n  if (dayMap.size === 0) return;\n\n  // Write aggregated metrics in a single transaction\n  const now = new Date().toISOString();\n  systemDb.transaction(() => {\n    const upsert = systemDb.prepare(`\n      INSERT INTO system_daily_metrics\n        (date, total_executions, completed, failed, total_cost_usd, total_duration_ms, tenant_count, aggregated_at)\n      VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n      ON CONFLICT(date) DO UPDATE SET\n        total_executions = excluded.total_executions,\n        completed = excluded.completed,\n        failed = excluded.failed,\n        total_cost_usd = excluded.total_cost_usd,\n        total_duration_ms = excluded.total_duration_ms,\n        tenant_count = excluded.tenant_count,\n        aggregated_at = excluded.aggregated_at\n    `);\n    for (const [date, m] of dayMap) {\n      upsert.run(date, m.total_executions, m.completed, m.failed, m.total_cost_usd, m.total_duration_ms, m.tenant_count, now);\n    }\n  })();\n\n  logger.info({ days: dayMap.size, tenants: tenantIds.length }, 'System-wide metrics aggregation complete');\n}\n","numLines":392,"startLine":1,"totalLines":392}}}
