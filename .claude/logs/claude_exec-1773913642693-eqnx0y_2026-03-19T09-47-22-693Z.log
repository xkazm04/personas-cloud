[2026-03-19T09:48:04.524Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016jV1wYvFPwp94ko87ZVDYP","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import fs from 'node:fs';\n     3→import path from 'node:path';\n     4→import crypto from 'node:crypto';\n     5→import type { Logger } from 'pino';\n     6→import { initTenantDb, initSystemDb } from './db/index.js';\n     7→\n     8→interface CachedDb {\n     9→  db: Database.Database;\n    10→  lastAccess: number;\n    11→}\n    12→\n    13→export interface DbHealthStats {\n    14→  totalSizeBytes: number;\n    15→  tenantCount: number;\n    16→  totalExecutionRows: number;\n    17→  totalEventRows: number;\n    18→  oldestUnpurgedAgeMs: number | null;\n    19→  perTenant: Array<{\n    20→    projectId: string;\n    21→    sizeBytes: number;\n    22→    executionRows: number;\n    23→    eventRows: number;\n    24→    oldestRecordAge: string | null;\n    25→  }>;\n    26→}\n    27→\n    28→const IDLE_EVICT_MS = 10 * 60 * 1000; // 10 minutes\n    29→const EVICT_CHECK_MS = 60 * 1000;     // check every 1 minute\n    30→\n    31→/**\n    32→ * Manages per-tenant SQLite databases with connection pooling.\n    33→ *\n    34→ * Layout:\n    35→ *   {dataDir}/system.db           — tenant registry\n    36→ *   {dataDir}/tenants/{hash}.db   — per-tenant data\n    37→ *\n    38→ * The hash is derived from the projectId to produce safe filenames.\n    39→ */\n    40→export type TenantCreatedCallback = (tenantId: string) => void;\n    41→\n    42→export class TenantDbManager {\n    43→  private systemDb: Database.Database;\n    44→  private tenantDbs = new Map<string, CachedDb>();\n    45→  private tenantsDir: string;\n    46→  private evictTimer: NodeJS.Timeout;\n    47→  private onTenantCreated: TenantCreatedCallback | null = null;\n    48→\n    49→  constructor(\n    50→    private dataDir: string,\n    51→    private logger: Logger,\n    52→  ) {\n    53→    fs.mkdirSync(dataDir, { recursive: true });\n    54→    this.tenantsDir = path.join(dataDir, 'tenants');\n    55→    fs.mkdirSync(this.tenantsDir, { recursive: true });\n    56→\n    57→    // Initialize system DB\n    58→    const systemDbPath = path.join(dataDir, 'system.db');\n    59→    this.systemDb = initSystemDb(systemDbPath, logger);\n    60→\n    61→    // Idle eviction loop\n    62→    this.evictTimer = setInterval(() => this.evictIdle(), EVICT_CHECK_MS);\n    63→  }\n    64→\n    65→  /**\n    66→   * Register a callback invoked when a new tenant is first registered.\n    67→   */\n    68→  setTenantCreatedCallback(cb: TenantCreatedCallback): void {\n    69→    this.onTenantCreated = cb;\n    70→  }\n    71→\n    72→  getSystemDb(): Database.Database {\n    73→    return this.systemDb;\n    74→  }\n    75→\n    76→  /**\n    77→   * Get (or create) a tenant-specific database.\n    78→   * Automatically registers the tenant in system.db on first access.\n    79→   */\n    80→  getTenantDb(projectId: string): Database.Database {\n    81→    const cached = this.tenantDbs.get(projectId);\n    82→    if (cached) {\n    83→      cached.lastAccess = Date.now();\n    84→      return cached.db;\n    85→    }\n    86→\n    87→    // Create/open tenant DB\n    88→    const hash = this.hashProjectId(projectId);\n    89→    const dbPath = path.join(this.tenantsDir, `${hash}.db`);\n    90→    const db = initTenantDb(dbPath, this.logger);\n    91→\n    92→    this.tenantDbs.set(projectId, { db, lastAccess: Date.now() });\n    93→\n    94→    // Register in system DB if not already present\n    95→    this.registerTenant(projectId);\n    96→\n    97→    this.logger.info({ projectId, dbPath }, 'Tenant database opened');\n    98→    return db;\n    99→  }\n   100→\n   101→  /**\n   102→   * List all registered tenant IDs from the system DB.\n   103→   */\n   104→  listTenantIds(): string[] {\n   105→    const rows = this.systemDb\n   106→      .prepare('SELECT id FROM tenants ORDER BY id')\n   107→      .all() as Array<{ id: string }>;\n   108→    return rows.map(r => r.id);\n   109→  }\n   110→\n   111→  /**\n   112→   * Execute a function against every tenant's database.\n   113→   * Opens DBs as needed (and caches them).\n   114→   */\n   115→  forEachTenant(fn: (db: Database.Database, projectId: string) => void): void {\n   116→    const ids = this.listTenantIds();\n   117→    for (const id of ids) {\n   118→      try {\n   119→        const db = this.getTenantDb(id);\n   120→        fn(db, id);\n   121→      } catch (err) {\n   122→        this.logger.error({ err, projectId: id }, 'Error processing tenant');\n   123→      }\n   124→    }\n   125→  }\n   126→\n   127→  /**\n   128→   * Collect health stats across all tenant databases:\n   129→   * file size, row counts, and oldest un-purged record age.\n   130→   */\n   131→  getHealthStats(): DbHealthStats {\n   132→    const ids = this.listTenantIds();\n   133→    const now = Date.now();\n   134→    let totalSizeBytes = 0;\n   135→    let totalExecutionRows = 0;\n   136→    let totalEventRows = 0;\n   137→    let oldestUnpurgedAgeMs: number | null = null;\n   138→    const perTenant: DbHealthStats['perTenant'] = [];\n   139→\n   140→    // Include system DB size\n   141→    const sysSizeRow = this.systemDb.prepare('SELECT page_count * page_size AS size FROM pragma_page_count(), pragma_page_size()').get() as { size: number } | undefined;\n   142→    if (sysSizeRow) totalSizeBytes += sysSizeRow.size;\n   143→\n   144→    for (const id of ids) {\n   145→      try {\n   146→        const db = this.getTenantDb(id);\n   147→\n   148→        const sizeRow = db.prepare('SELECT page_count * page_size AS size FROM pragma_page_count(), pragma_page_size()').get() as { size: number } | undefined;\n   149→        const sizeBytes = sizeRow?.size ?? 0;\n   150→\n   151→        const execRow = db.prepare('SELECT COUNT(*) AS cnt FROM persona_executions').get() as { cnt: number };\n   152→        const eventRow = db.prepare('SELECT COUNT(*) AS cnt FROM persona_events').get() as { cnt: number };\n   153→\n   154→        const oldestExec = db.prepare('SELECT MIN(created_at) AS oldest FROM persona_executions').get() as { oldest: string | null };\n   155→        const oldestEvent = db.prepare('SELECT MIN(created_at) AS oldest FROM persona_events').get() as { oldest: string | null };\n   156→\n   157→        // Pick the oldest of the two tables\n   158→        let oldestRecord: string | null = null;\n   159→        if (oldestExec.oldest && oldestEvent.oldest) {\n   160→          oldestRecord = oldestExec.oldest < oldestEvent.oldest ? oldestExec.oldest : oldestEvent.oldest;\n   161→        } else {\n   162→          oldestRecord = oldestExec.oldest ?? oldestEvent.oldest;\n   163→        }\n   164→\n   165→        if (oldestRecord) {\n   166→          const ageMs = now - new Date(oldestRecord).getTime();\n   167→          if (oldestUnpurgedAgeMs === null || ageMs > oldestUnpurgedAgeMs) {\n   168→            oldestUnpurgedAgeMs = ageMs;\n   169→          }\n   170→        }\n   171→\n   172→        totalSizeBytes += sizeBytes;\n   173→        totalExecutionRows += execRow.cnt;\n   174→        totalEventRows += eventRow.cnt;\n   175→\n   176→        perTenant.push({\n   177→          projectId: id,\n   178→          sizeBytes,\n   179→          executionRows: execRow.cnt,\n   180→          eventRows: eventRow.cnt,\n   181→          oldestRecordAge: oldestRecord,\n   182→        });\n   183→      } catch (err) {\n   184→        this.logger.warn({ err, projectId: id }, 'Failed to collect health stats for tenant');\n   185→      }\n   186→    }\n   187→\n   188→    return {\n   189→      totalSizeBytes,\n   190→      tenantCount: ids.length,\n   191→      totalExecutionRows,\n   192→      totalEventRows,\n   193→      oldestUnpurgedAgeMs,\n   194→      perTenant,\n   195→    };\n   196→  }\n   197→\n   198→  /**\n   199→   * Close all database connections and stop eviction timer.\n   200→   */\n   201→  close(): void {\n   202→    clearInterval(this.evictTimer);\n   203→\n   204→    for (const [projectId, cached] of this.tenantDbs) {\n   205→      try {\n   206→        cached.db.close();\n   207→        this.logger.debug({ projectId }, 'Tenant database closed');\n   208→      } catch { /* best effort */ }\n   209→    }\n   210→    this.tenantDbs.clear();\n   211→\n   212→    try {\n   213→      this.systemDb.close();\n   214→    } catch { /* best effort */ }\n   215→  }\n   216→\n   217→  private registerTenant(projectId: string): void {\n   218→    const existing = this.systemDb\n   219→      .prepare('SELECT id FROM tenants WHERE id = ?')\n   220→      .get(projectId);\n   221→\n   222→    if (!existing) {\n   223→      this.systemDb\n   224→        .prepare('INSERT INTO tenants (id, created_at) VALUES (?, ?)')\n   225→        .run(projectId, new Date().toISOString());\n   226→      this.logger.info({ projectId }, 'Tenant registered in system DB');\n   227→      this.onTenantCreated?.(projectId);\n   228→    }\n   229→  }\n   230→\n   231→  private hashProjectId(projectId: string): string {\n   232→    return crypto.createHash('sha256').update(projectId).digest('hex').slice(0, 16);\n   233→  }\n   234→\n   235→  private evictIdle(): void {\n   236→    const now = Date.now();\n   237→    for (const [projectId, cached] of this.tenantDbs) {\n   238→      if (now - cached.lastAccess > IDLE_EVICT_MS) {\n   239→        try {\n   240→          cached.db.close();\n   241→          this.tenantDbs.delete(projectId);\n   242→          this.logger.debug({ projectId }, 'Evicted idle tenant database');\n   243→        } catch (err) {\n   244→          this.logger.warn({ err, projectId }, 'Failed to evict tenant database');\n   245→        }\n   246→      }\n   247→    }\n   248→  }\n   249→}\n   250→"}]},"parent_tool_use_id":"toolu_01E1Gu5fsFsuPsUk5357FSL8","session_id":"f83562c4-7cd5-4d50-b7ac-458d47ebaf2f","uuid":"b0472d93-de0b-46f0-a80f-73cbe450c705","timestamp":"2026-03-19T09:48:04.450Z"}
[2026-03-19T09:48:04.529Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FneRn16QYyChgNuQAP1aUy","type":"tool_result","content":"     1→// ---------------------------------------------------------------------------\n     2→// Table lifecycle classification registry\n     3→// ---------------------------------------------------------------------------\n     4→//\n     5→// Every time-series table (one with a temporal column subject to retention)\n     6→// is classified as either *metrizable* or *ephemeral*:\n     7→//\n     8→//   metrizable  – contains numeric columns worth aggregating into summary\n     9→//                 metrics before rows are purged (e.g. cost_usd, duration_ms).\n    10→//   ephemeral   – rows are simply deleted after the retention window; no\n    11→//                 pre-purge aggregation is performed.\n    12→//\n    13→// This registry is the single source of truth for that classification.\n    14→// The retention engine and any future table additions should consult it\n    15→// rather than hard-coding lifecycle decisions in procedural code.\n    16→// ---------------------------------------------------------------------------\n    17→\n    18→/** Lifecycle category for a time-series table. */\n    19→export type TableLifecycle = 'metrizable' | 'ephemeral';\n    20→\n    21→/** Describes a numeric column that should be aggregated before purge. */\n    22→export interface MetrizableColumn {\n    23→  /** SQLite column name. */\n    24→  column: string;\n    25→  /** SQL aggregation function applied during rollup (SUM, AVG, COUNT, etc.). */\n    26→  aggregation: 'SUM' | 'COUNT' | 'AVG' | 'MAX' | 'MIN';\n    27→}\n    28→\n    29→/** Retention spec for a metrizable table. */\n    30→export interface MetrizableTableSpec {\n    31→  lifecycle: 'metrizable';\n    32→  /** The SQLite table name. */\n    33→  table: string;\n    34→  /** Temporal column used to determine row age. */\n    35→  timestampColumn: string;\n    36→  /** Numeric columns aggregated into a summary table before purge. */\n    37→  metrizableColumns: MetrizableColumn[];\n    38→  /** Target table where aggregated metrics are written. */\n    39→  aggregationTarget: string;\n    40→  /** Maximum fraction of rows deletable in a single purge cycle (safety cap). */\n    41→  maxPurgeFraction?: number;\n    42→}\n    43→\n    44→/** Retention spec for an ephemeral table. */\n    45→export interface EphemeralTableSpec {\n    46→  lifecycle: 'ephemeral';\n    47→  /** The SQLite table name. */\n    48→  table: string;\n    49→  /** Temporal column used to determine row age. */\n    50→  timestampColumn: string;\n    51→  /** Minimum retention days (e.g. compliance floor for audit data). */\n    52→  minRetentionDays?: number;\n    53→  /** Maximum fraction of rows deletable in a single purge cycle (safety cap). */\n    54→  maxPurgeFraction?: number;\n    55→}\n    56→\n    57→export type TableRetentionSpec = MetrizableTableSpec | EphemeralTableSpec;\n    58→\n    59→// ---------------------------------------------------------------------------\n    60→// Registry of all time-series tables and their lifecycle classification\n    61→// ---------------------------------------------------------------------------\n    62→\n    63→export const TABLE_REGISTRY: readonly TableRetentionSpec[] = [\n    64→  // ── Metrizable: numeric data aggregated into daily_metrics before purge ──\n    65→  {\n    66→    lifecycle: 'metrizable',\n    67→    table: 'persona_executions',\n    68→    timestampColumn: 'created_at',\n    69→    metrizableColumns: [\n    70→      { column: 'cost_usd', aggregation: 'SUM' },\n    71→      { column: 'duration_ms', aggregation: 'SUM' },\n    72→      { column: 'input_tokens', aggregation: 'SUM' },\n    73→      { column: 'output_tokens', aggregation: 'SUM' },\n    74→    ],\n    75→    aggregationTarget: 'daily_metrics',\n    76→    maxPurgeFraction: 0.8,\n    77→  },\n    78→\n    79→  // ── Ephemeral: purged without aggregation ────────────────────────────────\n    80→  {\n    81→    lifecycle: 'ephemeral',\n    82→    table: 'persona_events',\n    83→    timestampColumn: 'created_at',\n    84→    maxPurgeFraction: 0.8,\n    85→  },\n    86→  {\n    87→    lifecycle: 'ephemeral',\n    88→    table: 'audit_events',\n    89→    timestampColumn: 'timestamp',\n    90→    minRetentionDays: 90,\n    91→    maxPurgeFraction: 0.8,\n    92→  },\n    93→  {\n    94→    lifecycle: 'ephemeral',\n    95→    table: 'trigger_fires',\n    96→    timestampColumn: 'fired_at',\n    97→    maxPurgeFraction: 0.8,\n    98→  },\n    99→  {\n   100→    lifecycle: 'ephemeral',\n   101→    table: 'daily_metrics',\n   102→    timestampColumn: 'date',\n   103→    maxPurgeFraction: 0.8,\n   104→  },\n   105→  {\n   106→    lifecycle: 'ephemeral',\n   107→    table: 'system_daily_metrics',\n   108→    timestampColumn: 'date',\n   109→    maxPurgeFraction: 0.8,\n   110→  },\n   111→] as const;\n   112→\n   113→// ---------------------------------------------------------------------------\n   114→// Lookup helpers\n   115→// ---------------------------------------------------------------------------\n   116→\n   117→/** Look up the retention spec for a table by name. */\n   118→export function getTableSpec(tableName: string): TableRetentionSpec | undefined {\n   119→  return TABLE_REGISTRY.find((s) => s.table === tableName);\n   120→}\n   121→\n   122→/** Return all tables classified with the given lifecycle. */\n   123→export function getTablesByLifecycle(lifecycle: TableLifecycle): readonly TableRetentionSpec[] {\n   124→  return TABLE_REGISTRY.filter((s) => s.lifecycle === lifecycle);\n   125→}\n   126→\n   127→/** Type guard: is this spec metrizable? */\n   128→export function isMetrizable(spec: TableRetentionSpec): spec is MetrizableTableSpec {\n   129→  return spec.lifecycle === 'metrizable';\n   130→}\n   131→\n   132→/** Type guard: is this spec ephemeral? */\n   133→export function isEphemeral(spec: TableRetentionSpec): spec is EphemeralTableSpec {\n   134→  return spec.lifecycle === 'ephemeral';\n   135→}\n   136→"}]},"parent_tool_use_id":"toolu_01E1Gu5fsFsuPsUk5357FSL8","session_id":"f83562c4-7cd5-4d50-b7ac-458d47ebaf2f","uuid":"e954e8fe-e6f8-4649-88f8-9a87c4bb0db6","timestamp":"2026-03-19T09:48:04.460Z"}
