[2026-03-19T09:48:22.217Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Cs1uQejwefocURufP5jS6Y","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import { nanoid } from 'nanoid';\n     3→import type { TriggerFire, TriggerFireStatus, TriggerStats } from '@dac-cloud/shared';\n     4→import { stmt, createRowMapper } from './_helpers.js';\n     5→\n     6→// ---------------------------------------------------------------------------\n     7→// Row mapper\n     8→// ---------------------------------------------------------------------------\n     9→\n    10→const rowToTriggerFire = createRowMapper<TriggerFire>({\n    11→  id: { col: 'id' },\n    12→  triggerId: { col: 'trigger_id' },\n    13→  eventId: { col: 'event_id', nullable: true },\n    14→  executionId: { col: 'execution_id', nullable: true },\n    15→  status: { col: 'status' },\n    16→  durationMs: { col: 'duration_ms', nullable: true },\n    17→  errorMessage: { col: 'error_message', nullable: true },\n    18→  firedAt: { col: 'fired_at' },\n    19→});\n    20→\n    21→// ---------------------------------------------------------------------------\n    22→// Write\n    23→// ---------------------------------------------------------------------------\n    24→\n    25→export function recordTriggerFire(db: Database.Database, input: {\n    26→  triggerId: string;\n    27→  eventId?: string | null;\n    28→  status?: TriggerFireStatus;\n    29→}): TriggerFire {\n    30→  const id = nanoid();\n    31→  const now = new Date().toISOString();\n    32→  const status = input.status ?? 'fired';\n    33→  const eventId = input.eventId ?? null;\n    34→  stmt(db, `\n    35→    INSERT INTO trigger_fires (id, trigger_id, event_id, status, fired_at)\n    36→    VALUES (?, ?, ?, ?, ?)\n    37→  `).run(id, input.triggerId, eventId, status, now);\n    38→  return {\n    39→    id,\n    40→    triggerId: input.triggerId,\n    41→    eventId,\n    42→    executionId: null,\n    43→    status,\n    44→    durationMs: null,\n    45→    errorMessage: null,\n    46→    firedAt: now,\n    47→  };\n    48→}\n    49→\n    50→export function updateTriggerFire(db: Database.Database, id: string, updates: {\n    51→  executionId?: string;\n    52→  status?: TriggerFireStatus;\n    53→  durationMs?: number;\n    54→  errorMessage?: string;\n    55→}): void {\n    56→  const setClauses: string[] = [];\n    57→  const values: unknown[] = [];\n    58→  if (updates.executionId !== undefined) { setClauses.push('execution_id = ?'); values.push(updates.executionId); }\n    59→  if (updates.status !== undefined) { setClauses.push('status = ?'); values.push(updates.status); }\n    60→  if (updates.durationMs !== undefined) { setClauses.push('duration_ms = ?'); values.push(updates.durationMs); }\n    61→  if (updates.errorMessage !== undefined) { setClauses.push('error_message = ?'); values.push(updates.errorMessage); }\n    62→  if (setClauses.length === 0) return;\n    63→  stmt(db, `UPDATE trigger_fires SET ${setClauses.join(', ')} WHERE id = ?`).run(...values, id);\n    64→}\n    65→\n    66→// ---------------------------------------------------------------------------\n    67→// Read — history\n    68→// ---------------------------------------------------------------------------\n    69→\n    70→export function listTriggerFires(db: Database.Database, triggerId: string, limit: number = 50): TriggerFire[] {\n    71→  const rows = stmt(db, `\n    72→    SELECT * FROM trigger_fires\n    73→    WHERE trigger_id = ?\n    74→    ORDER BY fired_at DESC\n    75→    LIMIT ?\n    76→  `).all(triggerId, limit) as Record<string, unknown>[];\n    77→  return rows.map(rowToTriggerFire);\n    78→}\n    79→\n    80→// ---------------------------------------------------------------------------\n    81→// Read — aggregate stats\n    82→// ---------------------------------------------------------------------------\n    83→\n    84→export function getTriggerStats(db: Database.Database, triggerId: string): TriggerStats {\n    85→  const row = stmt(db, `\n    86→    SELECT\n    87→      COUNT(*) AS total_fires,\n    88→      SUM(CASE WHEN status = 'completed' THEN 1 ELSE 0 END) AS success_count,\n    89→      SUM(CASE WHEN status = 'failed' THEN 1 ELSE 0 END) AS failure_count,\n    90→      AVG(CASE WHEN status = 'completed' THEN duration_ms ELSE NULL END) AS avg_duration_ms\n    91→    FROM trigger_fires\n    92→    WHERE trigger_id = ?\n    93→  `).get(triggerId) as Record<string, unknown> | undefined;\n    94→\n    95→  const lastRow = stmt(db, `\n    96→    SELECT status, fired_at FROM trigger_fires\n    97→    WHERE trigger_id = ?\n    98→    ORDER BY fired_at DESC\n    99→    LIMIT 1\n   100→  `).get(triggerId) as Record<string, unknown> | undefined;\n   101→\n   102→  const totalFires = (row?.total_fires as number) ?? 0;\n   103→  const successCount = (row?.success_count as number) ?? 0;\n   104→  const failureCount = (row?.failure_count as number) ?? 0;\n   105→  const avgDurationMs = row?.avg_duration_ms != null ? Math.round(row.avg_duration_ms as number) : null;\n   106→\n   107→  return {\n   108→    totalFires,\n   109→    successCount,\n   110→    failureCount,\n   111→    successRate: totalFires > 0 ? Math.round((successCount / totalFires) * 10000) / 10000 : 0,\n   112→    avgDurationMs,\n   113→    lastFireStatus: (lastRow?.status as TriggerFireStatus) ?? null,\n   114→    lastFiredAt: (lastRow?.fired_at as string) ?? null,\n   115→  };\n   116→}\n   117→"}]},"parent_tool_use_id":"toolu_01E1Gu5fsFsuPsUk5357FSL8","session_id":"f83562c4-7cd5-4d50-b7ac-458d47ebaf2f","uuid":"159b9609-1940-48ce-be11-b52deafc8853","timestamp":"2026-03-19T09:48:22.020Z"}
