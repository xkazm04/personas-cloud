[2026-03-19T09:48:19.579Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QXgT2E6WULmjMmCmsYhqLY","type":"tool_result","content":"     1→import pino from 'pino';\n     2→import { loadConfig } from './config.js';\n     3→import { createAuth } from './auth.js';\n     4→import { createTokenManager } from './tokenManager.js';\n     5→import { OAuthManager } from './oauth.js';\n     6→import { WorkerPool, type WorkerPoolEvents } from './workerPool.js';\n     7→import { createKafkaClient, createNoopKafkaClient } from './kafka.js';\n     8→import { Dispatcher } from './dispatcher.js';\n     9→import { createHttpApi } from './httpApi.js';\n    10→import { TenantDbManager } from './tenantDbManager.js';\n    11→import { TenantKeyManager, type TenantKeyEvents } from './tenantKeyManager.js';\n    12→import { AuditLog } from './auditLog.js';\n    13→import { AuditPolicy } from './auditPolicy.js';\n    14→import { AuditRetentionPolicy } from './auditRetentionPolicy.js';\n    15→import { AuditChainVerifier } from './auditChainVerifier.js';\n    16→import { startRetentionJob } from './retention.js';\n    17→import { startEventProcessor } from './eventProcessor.js';\n    18→import { startTriggerScheduler } from './triggerScheduler.js';\n    19→import { loadTlsConfig } from './tls.js';\n    20→import { TOPICS, type ExecRequest } from '@dac-cloud/shared';\n    21→\n    22→const logger = pino({ level: process.env['LOG_LEVEL'] || 'info' });\n    23→\n    24→async function main() {\n    25→  logger.info('Starting DAC Cloud Orchestrator...');\n    26→\n    27→  // Load configuration\n    28→  const config = loadConfig();\n    29→  logger.info({\n    30→    kafkaEnabled: config.kafkaEnabled,\n    31→    wsPort: config.wsPort,\n    32→    httpPort: config.httpPort,\n    33→    hasDirectToken: !!config.claudeToken,\n    34→  }, 'Configuration loaded');\n    35→\n    36→  // Initialize components\n    37→  const auth = createAuth(config.teamApiKey, config.supabaseJwtSecret || undefined);\n    38→  const tokenManager = await createTokenManager(config.masterKey, logger);\n    39→  const oauth = new OAuthManager(logger);\n    40→\n    41→  // If a direct Claude token is provided (from setup-token), store it\n    42→  if (config.claudeToken) {\n    43→    tokenManager.storeClaudeToken(config.claudeToken);\n    44→    logger.info('Direct Claude token loaded from environment');\n    45→  } else {\n    46→    logger.info('No direct Claude token — use OAuth flow via POST /api/oauth/authorize');\n    47→  }\n    48→\n    49→  // Tenant-isolated database manager\n    50→  const tenantDbManager = new TenantDbManager(config.dataDir, logger);\n    51→  logger.info({ dataDir: config.dataDir }, 'Tenant DB manager initialized');\n    52→\n    53→  // Worker pool (WebSocket server)\n    54→  const pool = new WorkerPool(config.workerToken, logger, {\n    55→    allowedDigests: config.allowedImageDigests,\n    56→    rejectUnverified: config.rejectUnverifiedWorkers,\n    57→  });\n    58→\n    59→  // Kafka client\n    60→  const kafka = config.kafkaEnabled\n    61→    ? createKafkaClient(config.kafkaBrokers, config.kafkaUsername, config.kafkaPassword, logger)\n    62→    : createNoopKafkaClient(logger);\n    63→\n    64→  // Audit log (separate append-only DB)\n    65→  const auditLog = new AuditLog(config.auditDbPath, logger);\n    66→  const auditRetention = new AuditRetentionPolicy(auditLog, config.auditRetentionDays, logger);\n    67→  auditRetention.startDailyPurge();\n    68→\n    69→  // Periodic hash chain integrity verification\n    70→  const auditChainVerifier = new AuditChainVerifier(\n    71→    auditLog, logger, config.auditChainVerifyIntervalMinutes * 60_000,\n    72→  );\n    73→  auditChainVerifier.start();\n    74→\n    75→  // Wire audit log into OAuth manager for token lifecycle events\n    76→  oauth.setAuditLog(auditLog, config.tokenExpiryWarningMinutes);\n    77→\n    78→  // Per-tenant key manager (cached key derivation with TTL)\n    79→  const tenantKeyManager = new TenantKeyManager(config.masterKey, logger);\n    80→\n    81→  // Declarative audit policy — maps emitter events to audit entries\n    82→  const auditPolicy = new AuditPolicy(auditLog);\n    83→\n    84→  auditPolicy.attach<TenantKeyEvents>(tenantKeyManager, {\n    85→    'key:derived': (e) => ({ action: 'key:derive', tenantId: e.tenantId }),\n    86→  });\n    87→\n    88→  auditPolicy.attach<WorkerPoolEvents>(pool, {\n    89→    'worker-connected': (info) => ({ action: 'worker:connected', detail: { workerId: info.workerId } }),\n    90→    'worker-disconnected': (workerId, executionId) => ({ action: 'worker:disconnected', detail: { workerId }, resourceId: executionId }),\n    91→  });\n    92→\n    93→  // Wire tenant ID source for key pre-warming and proactive renewal\n    94→  await tenantKeyManager.setTenantIdSource(() => tenantDbManager.listTenantIds());\n    95→  // Eagerly warm key cache when a new tenant is registered\n    96→  tenantDbManager.setTenantCreatedCallback((tenantId) => tenantKeyManager.warmTenant(tenantId));\n    97→\n    98→  // Dispatcher — uses OAuth manager for token refresh\n    99→  const dispatcher = new Dispatcher(pool, tokenManager, oauth, kafka, logger, {\n   100→    maxQueueDepth: config.maxQueueDepth,"}]},"parent_tool_use_id":"toolu_01E1Gu5fsFsuPsUk5357FSL8","session_id":"f83562c4-7cd5-4d50-b7ac-458d47ebaf2f","uuid":"1dfbff70-079a-49d7-a0b3-d2152988a491","timestamp":"2026-03-19T09:48:19.497Z"}
