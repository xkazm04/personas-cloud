[2026-03-18T17:32:31.047Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012m4ceWjnNFYBzqg72n378p","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import { matchEvent, assemblePrompt } from '@dac-cloud/shared';\n     4→import type { ExecRequest, EventMatch, PersonaEvent } from '@dac-cloud/shared';\n     5→import { nanoid } from 'nanoid';\n     6→import * as db from './db/index.js';\n     7→import type { Dispatcher } from './dispatcher.js';\n     8→import type { TenantDbManager } from './tenantDbManager.js';\n     9→\n    10→/** Default threshold (seconds) for the periodic stale-event reaper. */\n    11→const STALE_EVENT_REAPER_SECONDS = 120;\n    12→/** Run the reaper every N ticks (at 2s interval, 30 ticks = ~60s). */\n    13→const REAPER_TICK_INTERVAL = 30;\n    14→\n    15→export interface EventProcessorHealth {\n    16→  lastTickAt: number | null;\n    17→  pendingEvents: number;\n    18→  backlogAgeMs: number | null;\n    19→}\n    20→\n    21→export interface EventProcessorHandle {\n    22→  timer: NodeJS.Timeout;\n    23→  getHealth: () => EventProcessorHealth;\n    24→}\n    25→\n    26→/**\n    27→ * Recover events orphaned in 'processing' state from a prior crash.\n    28→ * Call once at startup before the tick loop begins.\n    29→ */\n    30→function recoverOrphanedEvents(\n    31→  database: Database.Database | null,\n    32→  logger: Logger,\n    33→  tenantDbManager?: TenantDbManager,\n    34→): void {\n    35→  if (tenantDbManager) {\n    36→    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    37→      const count = db.resetAllProcessingEvents(tenantDb);\n    38→      if (count > 0) {\n    39→        logger.warn({ projectId, count }, 'Reset orphaned processing events to pending at startup');\n    40→      }\n    41→    });\n    42→  } else if (database) {\n    43→    const count = db.resetAllProcessingEvents(database);\n    44→    if (count > 0) {\n    45→      logger.warn({ count }, 'Reset orphaned processing events to pending at startup');\n    46→    }\n    47→  }\n    48→}\n    49→\n    50→/**\n    51→ * Periodic reaper: reset events stuck in 'processing' longer than the threshold.\n    52→ * Guards against edge cases during normal operation.\n    53→ */\n    54→function reapStaleEvents(\n    55→  database: Database.Database | null,\n    56→  logger: Logger,\n    57→  tenantDbManager?: TenantDbManager,\n    58→): void {\n    59→  if (tenantDbManager) {\n    60→    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    61→      const count = db.resetStaleProcessingEvents(tenantDb, STALE_EVENT_REAPER_SECONDS);\n    62→      if (count > 0) {\n    63→        logger.warn({ projectId, count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    64→      }\n    65→    });\n    66→  } else if (database) {\n    67→    const count = db.resetStaleProcessingEvents(database, STALE_EVENT_REAPER_SECONDS);\n    68→    if (count > 0) {\n    69→      logger.warn({ count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    70→    }\n    71→  }\n    72→}\n    73→\n    74→/**\n    75→ * Start the event processing loop.\n    76→ * Supports both tenant-isolated DBs (via TenantDbManager) and legacy single DB.\n    77→ */\n    78→export function startEventProcessor(\n    79→  database: Database.Database | null,\n    80→  dispatcher: Dispatcher,\n    81→  logger: Logger,\n    82→  interval: number = 2000,\n    83→  tenantDbManager?: TenantDbManager,\n    84→): EventProcessorHandle {\n    85→  // At startup, reset any events orphaned in 'processing' from a prior crash\n    86→  recoverOrphanedEvents(database, logger, tenantDbManager);\n    87→\n    88→  logger.info({ intervalMs: interval, tenantIsolated: !!tenantDbManager }, 'Event processor started');\n    89→\n    90→  let tickCount = 0;\n    91→\n    92→  // Shared health state updated on every tick\n    93→  const health: EventProcessorHealth = {\n    94→    lastTickAt: null,\n    95→    pendingEvents: 0,\n    96→    backlogAgeMs: null,\n    97→  };\n    98→\n    99→  const timer = setInterval(() => {\n   100→    try {\n   101→      tickCount++;\n   102→      health.lastTickAt = Date.now();\n   103→\n   104→      // Periodically reap stale processing events as a safety net\n   105→      if (tickCount % REAPER_TICK_INTERVAL === 0) {\n   106→        reapStaleEvents(database, logger, tenantDbManager);\n   107→      }\n   108→\n   109→      // Collect pending event stats for health reporting\n   110→      let totalPending = 0;\n   111→      let oldestCreatedAt: string | null = null;\n   112→\n   113→      if (tenantDbManager) {\n   114→        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n   115→          totalPending += db.countPendingEvents(tenantDb);\n   116→          const oldest = db.getOldestPendingEventCreatedAt(tenantDb);\n   117→          if (oldest && (!oldestCreatedAt || oldest < oldestCreatedAt)) {\n   118→            oldestCreatedAt = oldest;\n   119→          }\n   120→          eventBusTick(tenantDb, dispatcher, logger, projectId);\n   121→        });\n   122→      } else if (database) {\n   123→        totalPending = db.countPendingEvents(database);\n   124→        oldestCreatedAt = db.getOldestPendingEventCreatedAt(database);\n   125→        eventBusTick(database, dispatcher, logger);\n   126→      }\n   127→\n   128→      health.pendingEvents = totalPending;\n   129→      health.backlogAgeMs = oldestCreatedAt\n   130→        ? Math.max(0, Date.now() - new Date(oldestCreatedAt + 'Z').getTime())\n   131→        : null;\n   132→    } catch (err) {\n   133→      logger.error({ err }, 'Event processor tick failed');\n   134→    }\n   135→  }, interval);\n   136→\n   137→  return {\n   138→    timer,\n   139→    getHealth: () => ({ ...health }),\n   140→  };\n   141→}\n   142→\n   143→function eventBusTick(\n   144→  database: Database.Database,\n   145→  dispatcher: Dispatcher,\n   146→  logger: Logger,\n   147→  projectId?: string,\n   148→): void {\n   149→  const tickStartMs = performance.now();\n   150→  let eventsFetched = 0;\n   151→  let matchesFound = 0;\n   152→  let delivered = 0;\n   153→  let skipped = 0;\n   154→  let failed = 0;\n   155→\n   156→  try {\n   157→    const events = db.getPendingEvents(database, 50);\n   158→    eventsFetched = events.length;\n   159→    if (eventsFetched === 0) return;\n   160→\n   161→    // Collect dispatch requests to fire *after* the transaction commits so that\n   162→    // the dispatcher never sees stale DB state.\n   163→    const pendingDispatches: ExecRequest[] = [];\n   164→\n   165→    // Wrap all DB reads/writes in a single transaction to avoid per-statement\n   166→    // fsync overhead (up to 100 individual commits per tick otherwise).\n   167→    database.transaction(() => {\n   168→      // Cache subscription lookups per unique (eventType, projectId) to avoid\n   169→      // redundant DB queries when the same event type fires multiple times in a batch.\n   170→      const subsCache = new Map<string, ReturnType<typeof db.getSubscriptionsByEventType>>();\n   171→\n   172→      // Phase 1: Mark events as processing, compute matches, collect unique persona IDs.\n   173→      const eventMatches: Array<{ event: PersonaEvent; matches: EventMatch[] }> = [];\n   174→      const allPersonaIds = new Set<string>();\n   175→\n   176→      for (const event of events) {\n   177→        db.updateEventStatus(database, event.id, 'processing');\n   178→\n   179→        const cacheKey = `${event.eventType}\\0${event.projectId}`;\n   180→        let subs = subsCache.get(cacheKey);\n   181→        if (subs === undefined) {\n   182→          subs = db.getSubscriptionsByEventType(database, event.eventType, event.projectId);\n   183→          subsCache.set(cacheKey, subs);\n   184→        }\n   185→        const matches = matchEvent(event, subs);\n   186→\n   187→        if (matches.length === 0) {\n   188→          db.updateEventStatus(database, event.id, 'skipped');\n   189→          skipped++;\n   190→          continue;\n   191→        }\n   192→\n   193→        matchesFound += matches.length;\n   194→        eventMatches.push({ event, matches });\n   195→        for (const match of matches) {\n   196→          allPersonaIds.add(match.personaId);\n   197→        }\n   198→      }\n   199→\n   200→      if (allPersonaIds.size === 0) return;\n   201→\n   202→      // Phase 2: Batch-fetch personas, tools, and running counts (2-3 queries total).\n   203→      const personaIds = [...allPersonaIds];\n   204→      const personaMap = db.getPersonasByIds(database, personaIds);\n   205→      const toolsMap = db.getToolsForPersonaIds(database, personaIds);\n   206→      const runningMap = db.countRunningExecutionsByPersonaIds(database, personaIds);\n   207→\n   208→      // Phase 3: Dispatch using Map lookups instead of per-match queries.\n   209→      // Track persona slots claimed within this tick to prevent over-dispatch.\n   210→      const claimed = new Map<string, number>();\n   211→\n   212→      for (const { event, matches } of eventMatches) {\n   213→        let eventDelivered = 0;\n   214→        let eventFailed = 0;\n   215→        let throttled = 0;\n   216→\n   217→        for (const match of matches) {\n   218→          try {\n   219→            const persona = personaMap.get(match.personaId);\n   220→            if (!persona) {\n   221→              logger.warn({ personaId: match.personaId, eventId: event.id }, 'Persona not found for event match');\n   222→              eventFailed++;\n   223→              failed++;\n   224→              continue;\n   225→            }\n   226→\n   227→            // Check concurrency (in-tick claims + batched DB count)\n   228→            const tickClaimed = claimed.get(persona.id) ?? 0;\n   229→            const running = runningMap.get(persona.id) ?? 0;\n   230→            if (running + tickClaimed >= persona.maxConcurrent) {\n   231→              logger.info({ personaId: persona.id, running, tickClaimed, max: persona.maxConcurrent }, 'Persona at concurrency limit, deferring');\n   232→              throttled++;\n   233→              continue;\n   234→            }\n   235→\n   236→            // Build input data from event payload\n   237→            let inputData: Record<string, unknown> | undefined;\n   238→            if (match.payload) {\n   239→              try {\n   240→                inputData = JSON.parse(match.payload);\n   241→              } catch (parseError) {\n   242→                logger.warn({ eventId: event.id, personaId: match.personaId, parseError }, 'Event payload JSON parse failed, using raw');\n   243→                inputData = { raw: match.payload };\n   244→              }\n   245→            }\n   246→\n   247→            // Assemble prompt using batched persona + tools\n   248→            const tools = toolsMap.get(persona.id) ?? [];\n   249→            const prompt = assemblePrompt(persona, tools, inputData);\n   250→\n   251→            // Queue dispatch request (fired after transaction commits)\n   252→            const request: ExecRequest = {\n   253→              executionId: nanoid(),\n   254→              personaId: persona.id,\n   255→              prompt,\n   256→              projectId: projectId ?? persona.projectId,\n   257→              config: { timeoutMs: persona.timeoutMs },\n   258→            };\n   259→\n   260→            pendingDispatches.push(request);\n   261→            claimed.set(persona.id, (claimed.get(persona.id) ?? 0) + 1);\n   262→            eventDelivered++;\n   263→            delivered++;\n   264→\n   265→            logger.info({\n   266→              eventId: event.id,\n   267→              personaId: persona.id,\n   268→              executionId: request.executionId,\n   269→              eventType: event.eventType,\n   270→              useCaseId: match.useCaseId,\n   271→            }, 'Event dispatched to persona');\n   272→          } catch (err) {\n   273→            logger.error({ err, personaId: match.personaId, eventId: event.id }, 'Failed to dispatch event match');\n   274→            eventFailed++;\n   275→            failed++;\n   276→          }\n   277→        }\n   278→\n   279→        // Update event status\n   280→        if (eventDelivered > 0 && eventFailed === 0 && throttled === 0) {\n   281→          db.updateEventStatus(database, event.id, 'delivered');\n   282→        } else if (eventDelivered > 0 && throttled > 0) {\n   283→          // Some matches delivered but others were concurrency-limited.\n   284→          // Defer with backoff so throttled matches get retried later.\n   285→          db.deferEventForRetry(database, event.id, event.retryCount);\n   286→          logger.info({ eventId: event.id, delivered: eventDelivered, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event partially delivered, deferring throttled matches for retry');\n   287→        } else if (eventDelivered > 0 && eventFailed > 0) {\n   288→          // Some matches delivered but others failed — mark as partial-retry\n   289→          // so the event can be re-processed for the failed matches.\n   290→          db.updateEventStatus(database, event.id, 'partial-retry');\n   291→          logger.info({ eventId: event.id, delivered: eventDelivered, failed: eventFailed }, 'Event partially delivered with failures, marked for retry');\n   292→        } else if (throttled > 0) {\n   293→          // All (or remaining) matches were concurrency-limited — defer with backoff.\n   294→          db.deferEventForRetry(database, event.id, event.retryCount);\n   295→          logger.info({ eventId: event.id, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event deferred due to concurrency limits');\n   296→        } else {\n   297→          db.updateEventStatus(database, event.id, 'failed', 'All subscription matches failed');\n   298→        }\n   299→      }\n   300→    })();\n   301→\n   302→    // Fire dispatches after the transaction has committed successfully\n   303→    for (const request of pendingDispatches) {\n   304→      dispatcher.submit(request);\n   305→    }\n   306→  } finally {\n   307→    const tickDurationMs = performance.now() - tickStartMs;\n   308→    logger.info({\n   309→      tickDurationMs,\n   310→      eventsFetched,\n   311→      matchesFound,\n   312→      delivered,\n   313→      skipped,\n   314→      failed\n   315→    }, 'Event processor tick complete');\n   316→  }\n   317→}\n   318→"}]},"parent_tool_use_id":null,"session_id":"17bd0134-d09a-4683-b90e-56b5b71c91c6","uuid":"ccb2aaa5-2b8d-4278-ae12-5a479f87d23c","timestamp":"2026-03-18T17:32:30.660Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\eventProcessor.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport { matchEvent, assemblePrompt } from '@dac-cloud/shared';\nimport type { ExecRequest, EventMatch, PersonaEvent } from '@dac-cloud/shared';\nimport { nanoid } from 'nanoid';\nimport * as db from './db/index.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\n\n/** Default threshold (seconds) for the periodic stale-event reaper. */\nconst STALE_EVENT_REAPER_SECONDS = 120;\n/** Run the reaper every N ticks (at 2s interval, 30 ticks = ~60s). */\nconst REAPER_TICK_INTERVAL = 30;\n\nexport interface EventProcessorHealth {\n  lastTickAt: number | null;\n  pendingEvents: number;\n  backlogAgeMs: number | null;\n}\n\nexport interface EventProcessorHandle {\n  timer: NodeJS.Timeout;\n  getHealth: () => EventProcessorHealth;\n}\n\n/**\n * Recover events orphaned in 'processing' state from a prior crash.\n * Call once at startup before the tick loop begins.\n */\nfunction recoverOrphanedEvents(\n  database: Database.Database | null,\n  logger: Logger,\n  tenantDbManager?: TenantDbManager,\n): void {\n  if (tenantDbManager) {\n    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n      const count = db.resetAllProcessingEvents(tenantDb);\n      if (count > 0) {\n        logger.warn({ projectId, count }, 'Reset orphaned processing events to pending at startup');\n      }\n    });\n  } else if (database) {\n    const count = db.resetAllProcessingEvents(database);\n    if (count > 0) {\n      logger.warn({ count }, 'Reset orphaned processing events to pending at startup');\n    }\n  }\n}\n\n/**\n * Periodic reaper: reset events stuck in 'processing' longer than the threshold.\n * Guards against edge cases during normal operation.\n */\nfunction reapStaleEvents(\n  database: Database.Database | null,\n  logger: Logger,\n  tenantDbManager?: TenantDbManager,\n): void {\n  if (tenantDbManager) {\n    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n      const count = db.resetStaleProcessingEvents(tenantDb, STALE_EVENT_REAPER_SECONDS);\n      if (count > 0) {\n        logger.warn({ projectId, count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n      }\n    });\n  } else if (database) {\n    const count = db.resetStaleProcessingEvents(database, STALE_EVENT_REAPER_SECONDS);\n    if (count > 0) {\n      logger.warn({ count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    }\n  }\n}\n\n/**\n * Start the event processing loop.\n * Supports both tenant-isolated DBs (via TenantDbManager) and legacy single DB.\n */\nexport function startEventProcessor(\n  database: Database.Database | null,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  interval: number = 2000,\n  tenantDbManager?: TenantDbManager,\n): EventProcessorHandle {\n  // At startup, reset any events orphaned in 'processing' from a prior crash\n  recoverOrphanedEvents(database, logger, tenantDbManager);\n\n  logger.info({ intervalMs: interval, tenantIsolated: !!tenantDbManager }, 'Event processor started');\n\n  let tickCount = 0;\n\n  // Shared health state updated on every tick\n  const health: EventProcessorHealth = {\n    lastTickAt: null,\n    pendingEvents: 0,\n    backlogAgeMs: null,\n  };\n\n  const timer = setInterval(() => {\n    try {\n      tickCount++;\n      health.lastTickAt = Date.now();\n\n      // Periodically reap stale processing events as a safety net\n      if (tickCount % REAPER_TICK_INTERVAL === 0) {\n        reapStaleEvents(database, logger, tenantDbManager);\n      }\n\n      // Collect pending event stats for health reporting\n      let totalPending = 0;\n      let oldestCreatedAt: string | null = null;\n\n      if (tenantDbManager) {\n        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n          totalPending += db.countPendingEvents(tenantDb);\n          const oldest = db.getOldestPendingEventCreatedAt(tenantDb);\n          if (oldest && (!oldestCreatedAt || oldest < oldestCreatedAt)) {\n            oldestCreatedAt = oldest;\n          }\n          eventBusTick(tenantDb, dispatcher, logger, projectId);\n        });\n      } else if (database) {\n        totalPending = db.countPendingEvents(database);\n        oldestCreatedAt = db.getOldestPendingEventCreatedAt(database);\n        eventBusTick(database, dispatcher, logger);\n      }\n\n      health.pendingEvents = totalPending;\n      health.backlogAgeMs = oldestCreatedAt\n        ? Math.max(0, Date.now() - new Date(oldestCreatedAt + 'Z').getTime())\n        : null;\n    } catch (err) {\n      logger.error({ err }, 'Event processor tick failed');\n    }\n  }, interval);\n\n  return {\n    timer,\n    getHealth: () => ({ ...health }),\n  };\n}\n\nfunction eventBusTick(\n  database: Database.Database,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  projectId?: string,\n): void {\n  const tickStartMs = performance.now();\n  let eventsFetched = 0;\n  let matchesFound = 0;\n  let delivered = 0;\n  let skipped = 0;\n  let failed = 0;\n\n  try {\n    const events = db.getPendingEvents(database, 50);\n    eventsFetched = events.length;\n    if (eventsFetched === 0) return;\n\n    // Collect dispatch requests to fire *after* the transaction commits so that\n    // the dispatcher never sees stale DB state.\n    const pendingDispatches: ExecRequest[] = [];\n\n    // Wrap all DB reads/writes in a single transaction to avoid per-statement\n    // fsync overhead (up to 100 individual commits per tick otherwise).\n    database.transaction(() => {\n      // Cache subscription lookups per unique (eventType, projectId) to avoid\n      // redundant DB queries when the same event type fires multiple times in a batch.\n      const subsCache = new Map<string, ReturnType<typeof db.getSubscriptionsByEventType>>();\n\n      // Phase 1: Mark events as processing, compute matches, collect unique persona IDs.\n      const eventMatches: Array<{ event: PersonaEvent; matches: EventMatch[] }> = [];\n      const allPersonaIds = new Set<string>();\n\n      for (const event of events) {\n        db.updateEventStatus(database, event.id, 'processing');\n\n        const cacheKey = `${event.eventType}\\0${event.projectId}`;\n        let subs = subsCache.get(cacheKey);\n        if (subs === undefined) {\n          subs = db.getSubscriptionsByEventType(database, event.eventType, event.projectId);\n          subsCache.set(cacheKey, subs);\n        }\n        const matches = matchEvent(event, subs);\n\n        if (matches.length === 0) {\n          db.updateEventStatus(database, event.id, 'skipped');\n          skipped++;\n          continue;\n        }\n\n        matchesFound += matches.length;\n        eventMatches.push({ event, matches });\n        for (const match of matches) {\n          allPersonaIds.add(match.personaId);\n        }\n      }\n\n      if (allPersonaIds.size === 0) return;\n\n      // Phase 2: Batch-fetch personas, tools, and running counts (2-3 queries total).\n      const personaIds = [...allPersonaIds];\n      const personaMap = db.getPersonasByIds(database, personaIds);\n      const toolsMap = db.getToolsForPersonaIds(database, personaIds);\n      const runningMap = db.countRunningExecutionsByPersonaIds(database, personaIds);\n\n      // Phase 3: Dispatch using Map lookups instead of per-match queries.\n      // Track persona slots claimed within this tick to prevent over-dispatch.\n      const claimed = new Map<string, number>();\n\n      for (const { event, matches } of eventMatches) {\n        let eventDelivered = 0;\n        let eventFailed = 0;\n        let throttled = 0;\n\n        for (const match of matches) {\n          try {\n            const persona = personaMap.get(match.personaId);\n            if (!persona) {\n              logger.warn({ personaId: match.personaId, eventId: event.id }, 'Persona not found for event match');\n              eventFailed++;\n              failed++;\n              continue;\n            }\n\n            // Check concurrency (in-tick claims + batched DB count)\n            const tickClaimed = claimed.get(persona.id) ?? 0;\n            const running = runningMap.get(persona.id) ?? 0;\n            if (running + tickClaimed >= persona.maxConcurrent) {\n              logger.info({ personaId: persona.id, running, tickClaimed, max: persona.maxConcurrent }, 'Persona at concurrency limit, deferring');\n              throttled++;\n              continue;\n            }\n\n            // Build input data from event payload\n            let inputData: Record<string, unknown> | undefined;\n            if (match.payload) {\n              try {\n                inputData = JSON.parse(match.payload);\n              } catch (parseError) {\n                logger.warn({ eventId: event.id, personaId: match.personaId, parseError }, 'Event payload JSON parse failed, using raw');\n                inputData = { raw: match.payload };\n              }\n            }\n\n            // Assemble prompt using batched persona + tools\n            const tools = toolsMap.get(persona.id) ?? [];\n            const prompt = assemblePrompt(persona, tools, inputData);\n\n            // Queue dispatch request (fired after transaction commits)\n            const request: ExecRequest = {\n              executionId: nanoid(),\n              personaId: persona.id,\n              prompt,\n              projectId: projectId ?? persona.projectId,\n              config: { timeoutMs: persona.timeoutMs },\n            };\n\n            pendingDispatches.push(request);\n            claimed.set(persona.id, (claimed.get(persona.id) ?? 0) + 1);\n            eventDelivered++;\n            delivered++;\n\n            logger.info({\n              eventId: event.id,\n              personaId: persona.id,\n              executionId: request.executionId,\n              eventType: event.eventType,\n              useCaseId: match.useCaseId,\n            }, 'Event dispatched to persona');\n          } catch (err) {\n            logger.error({ err, personaId: match.personaId, eventId: event.id }, 'Failed to dispatch event match');\n            eventFailed++;\n            failed++;\n          }\n        }\n\n        // Update event status\n        if (eventDelivered > 0 && eventFailed === 0 && throttled === 0) {\n          db.updateEventStatus(database, event.id, 'delivered');\n        } else if (eventDelivered > 0 && throttled > 0) {\n          // Some matches delivered but others were concurrency-limited.\n          // Defer with backoff so throttled matches get retried later.\n          db.deferEventForRetry(database, event.id, event.retryCount);\n          logger.info({ eventId: event.id, delivered: eventDelivered, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event partially delivered, deferring throttled matches for retry');\n        } else if (eventDelivered > 0 && eventFailed > 0) {\n          // Some matches delivered but others failed — mark as partial-retry\n          // so the event can be re-processed for the failed matches.\n          db.updateEventStatus(database, event.id, 'partial-retry');\n          logger.info({ eventId: event.id, delivered: eventDelivered, failed: eventFailed }, 'Event partially delivered with failures, marked for retry');\n        } else if (throttled > 0) {\n          // All (or remaining) matches were concurrency-limited — defer with backoff.\n          db.deferEventForRetry(database, event.id, event.retryCount);\n          logger.info({ eventId: event.id, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event deferred due to concurrency limits');\n        } else {\n          db.updateEventStatus(database, event.id, 'failed', 'All subscription matches failed');\n        }\n      }\n    })();\n\n    // Fire dispatches after the transaction has committed successfully\n    for (const request of pendingDispatches) {\n      dispatcher.submit(request);\n    }\n  } finally {\n    const tickDurationMs = performance.now() - tickStartMs;\n    logger.info({\n      tickDurationMs,\n      eventsFetched,\n      matchesFound,\n      delivered,\n      skipped,\n      failed\n    }, 'Event processor tick complete');\n  }\n}\n","numLines":318,"startLine":1,"totalLines":318}}}
