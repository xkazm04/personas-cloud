[2026-03-18T17:32:24.867Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XhYD6n7mVRj6BGXbBYNzve","type":"tool_result","content":"     1→import { Kafka, type Producer, type Consumer, type EachMessagePayload, logLevel } from 'kafkajs';\n     2→import { TOPICS, sealEnvelope, deriveMasterKeyAsync } from '@dac-cloud/shared';\n     3→import type { Logger } from 'pino';\n     4→\n     5→export interface KafkaClient {\n     6→  producer: Producer;\n     7→  consumer: Consumer;\n     8→  connect(): Promise<void>;\n     9→  disconnect(): Promise<void>;\n    10→  subscribe(handler: (topic: string, value: string, key?: string) => Promise<void>): Promise<void>;\n    11→  produce(topic: string, value: string, key?: string): Promise<void>;\n    12→  /** Produce a message encrypted with per-tenant envelope encryption. */\n    13→  produceEncrypted(topic: string, payload: unknown, tenantId: string, key?: string): Promise<void>;\n    14→  setMasterKey(masterKeyHex: string): Promise<void>;\n    15→}\n    16→\n    17→export function createKafkaClient(\n    18→  brokers: string,\n    19→  username: string,\n    20→  password: string,\n    21→  logger: Logger,\n    22→): KafkaClient {\n    23→  const kafka = new Kafka({\n    24→    clientId: 'dac-orchestrator',\n    25→    brokers: brokers.split(','),\n    26→    ssl: true,\n    27→    sasl: {\n    28→      mechanism: 'scram-sha-256',\n    29→      username,\n    30→      password,\n    31→    },\n    32→    logLevel: logLevel.WARN,\n    33→  });\n    34→\n    35→  const producer = kafka.producer();\n    36→  const consumer = kafka.consumer({ groupId: 'dac-orchestrator' });\n    37→  let masterKey: Buffer | null = null;\n    38→\n    39→  return {\n    40→    producer,\n    41→    consumer,\n    42→\n    43→    async setMasterKey(masterKeyHex: string) {\n    44→      masterKey = await deriveMasterKeyAsync(masterKeyHex);\n    45→    },\n    46→\n    47→    async connect() {\n    48→      await producer.connect();\n    49→      await consumer.connect();\n    50→      logger.info('Kafka connected');\n    51→    },\n    52→\n    53→    async disconnect() {\n    54→      await producer.disconnect();\n    55→      await consumer.disconnect();\n    56→      logger.info('Kafka disconnected');\n    57→    },\n    58→\n    59→    async subscribe(handler: (topic: string, value: string, key?: string) => Promise<void>) {\n    60→      await consumer.subscribe({ topic: TOPICS.EXEC_REQUESTS, fromBeginning: false });\n    61→\n    62→      await consumer.run({\n    63→        eachMessage: async ({ topic, message }: EachMessagePayload) => {\n    64→          const value = message.value?.toString();\n    65→          const key = message.key?.toString();\n    66→          if (value) {\n    67→            try {\n    68→              await handler(topic, value, key);\n    69→            } catch (err) {\n    70→              logger.error({ err, topic, key }, 'Kafka message handler error');\n    71→            }\n    72→          }\n    73→        },\n    74→      });\n    75→\n    76→      logger.info({ topic: TOPICS.EXEC_REQUESTS }, 'Kafka consumer subscribed');\n    77→    },\n    78→\n    79→    async produce(topic: string, value: string, key?: string) {\n    80→      await producer.send({\n    81→        topic,\n    82→        messages: [{\n    83→          key: key || undefined,\n    84→          value,\n    85→        }],\n    86→      });\n    87→    },\n    88→\n    89→    async produceEncrypted(topic: string, payload: unknown, tenantId: string, key?: string) {\n    90→      if (!masterKey) {\n    91→        // Fallback to plaintext if no master key configured\n    92→        await this.produce(topic, JSON.stringify(payload), key);\n    93→        return;\n    94→      }\n    95→      const envelope = sealEnvelope(tenantId, payload, masterKey);\n    96→      await producer.send({\n    97→        topic,\n    98→        messages: [{\n    99→          key: key || undefined,\n   100→          value: JSON.stringify(envelope),\n   101→        }],\n   102→      });\n   103→    },\n   104→  };\n   105→}\n   106→\n   107→// No-op Kafka client for when Kafka is not configured (local testing)\n   108→export function createNoopKafkaClient(logger: Logger): KafkaClient {\n   109→  logger.info('Kafka disabled — using no-op client');\n   110→\n   111→  return {\n   112→    producer: {} as Producer,\n   113→    consumer: {} as Consumer,\n   114→    async setMasterKey() {},\n   115→    async connect() {},\n   116→    async disconnect() {},\n   117→    async subscribe() {},\n   118→    async produce(topic: string, value: string) {\n   119→      logger.debug({ topic, valueLength: value.length }, 'No-op Kafka produce');\n   120→    },\n   121→    async produceEncrypted(topic: string, payload: unknown) {\n   122→      logger.debug({ topic }, 'No-op Kafka produceEncrypted');\n   123→    },\n   124→  };\n   125→}\n   126→"}]},"parent_tool_use_id":null,"session_id":"17bd0134-d09a-4683-b90e-56b5b71c91c6","uuid":"568fd127-b62b-4bc9-b83f-f05d18f65fd8","timestamp":"2026-03-18T17:32:24.719Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\kafka.ts","content":"import { Kafka, type Producer, type Consumer, type EachMessagePayload, logLevel } from 'kafkajs';\nimport { TOPICS, sealEnvelope, deriveMasterKeyAsync } from '@dac-cloud/shared';\nimport type { Logger } from 'pino';\n\nexport interface KafkaClient {\n  producer: Producer;\n  consumer: Consumer;\n  connect(): Promise<void>;\n  disconnect(): Promise<void>;\n  subscribe(handler: (topic: string, value: string, key?: string) => Promise<void>): Promise<void>;\n  produce(topic: string, value: string, key?: string): Promise<void>;\n  /** Produce a message encrypted with per-tenant envelope encryption. */\n  produceEncrypted(topic: string, payload: unknown, tenantId: string, key?: string): Promise<void>;\n  setMasterKey(masterKeyHex: string): Promise<void>;\n}\n\nexport function createKafkaClient(\n  brokers: string,\n  username: string,\n  password: string,\n  logger: Logger,\n): KafkaClient {\n  const kafka = new Kafka({\n    clientId: 'dac-orchestrator',\n    brokers: brokers.split(','),\n    ssl: true,\n    sasl: {\n      mechanism: 'scram-sha-256',\n      username,\n      password,\n    },\n    logLevel: logLevel.WARN,\n  });\n\n  const producer = kafka.producer();\n  const consumer = kafka.consumer({ groupId: 'dac-orchestrator' });\n  let masterKey: Buffer | null = null;\n\n  return {\n    producer,\n    consumer,\n\n    async setMasterKey(masterKeyHex: string) {\n      masterKey = await deriveMasterKeyAsync(masterKeyHex);\n    },\n\n    async connect() {\n      await producer.connect();\n      await consumer.connect();\n      logger.info('Kafka connected');\n    },\n\n    async disconnect() {\n      await producer.disconnect();\n      await consumer.disconnect();\n      logger.info('Kafka disconnected');\n    },\n\n    async subscribe(handler: (topic: string, value: string, key?: string) => Promise<void>) {\n      await consumer.subscribe({ topic: TOPICS.EXEC_REQUESTS, fromBeginning: false });\n\n      await consumer.run({\n        eachMessage: async ({ topic, message }: EachMessagePayload) => {\n          const value = message.value?.toString();\n          const key = message.key?.toString();\n          if (value) {\n            try {\n              await handler(topic, value, key);\n            } catch (err) {\n              logger.error({ err, topic, key }, 'Kafka message handler error');\n            }\n          }\n        },\n      });\n\n      logger.info({ topic: TOPICS.EXEC_REQUESTS }, 'Kafka consumer subscribed');\n    },\n\n    async produce(topic: string, value: string, key?: string) {\n      await producer.send({\n        topic,\n        messages: [{\n          key: key || undefined,\n          value,\n        }],\n      });\n    },\n\n    async produceEncrypted(topic: string, payload: unknown, tenantId: string, key?: string) {\n      if (!masterKey) {\n        // Fallback to plaintext if no master key configured\n        await this.produce(topic, JSON.stringify(payload), key);\n        return;\n      }\n      const envelope = sealEnvelope(tenantId, payload, masterKey);\n      await producer.send({\n        topic,\n        messages: [{\n          key: key || undefined,\n          value: JSON.stringify(envelope),\n        }],\n      });\n    },\n  };\n}\n\n// No-op Kafka client for when Kafka is not configured (local testing)\nexport function createNoopKafkaClient(logger: Logger): KafkaClient {\n  logger.info('Kafka disabled — using no-op client');\n\n  return {\n    producer: {} as Producer,\n    consumer: {} as Consumer,\n    async setMasterKey() {},\n    async connect() {},\n    async disconnect() {},\n    async subscribe() {},\n    async produce(topic: string, value: string) {\n      logger.debug({ topic, valueLength: value.length }, 'No-op Kafka produce');\n    },\n    async produceEncrypted(topic: string, payload: unknown) {\n      logger.debug({ topic }, 'No-op Kafka produceEncrypted');\n    },\n  };\n}\n","numLines":126,"startLine":1,"totalLines":126}}}
