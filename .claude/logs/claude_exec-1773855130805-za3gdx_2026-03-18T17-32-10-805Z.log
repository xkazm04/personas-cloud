[2026-03-18T17:33:49.828Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0192zKPcTQdvMPaqdN5XdDey","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import type { KafkaClient } from './kafka.js';\n    11→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    12→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    13→import type { TenantDbManager } from './tenantDbManager.js';\n    14→import type { TenantKeyManager } from './tenantKeyManager.js';\n    15→import type { AuditLog } from './auditLog.js';\n    16→import type { EventProcessorHealth } from './eventProcessor.js';\n    17→import type { Logger } from 'pino';\n    18→import * as db from './db/index.js';\n    19→import { readBody, json } from './httpUtils.js';\n    20→\n    21→export function createHttpApi(\n    22→  auth: Auth,\n    23→  dispatcher: Dispatcher,\n    24→  pool: WorkerPool,\n    25→  tokenManager: TokenManager,\n    26→  oauth: OAuthManager,\n    27→  logger: Logger,\n    28→  database?: Database.Database,\n    29→  tenantDbManager?: TenantDbManager,\n    30→  tenantKeyManager?: TenantKeyManager,\n    31→  auditLog?: AuditLog,\n    32→  getEventProcessorHealth?: () => EventProcessorHealth,\n    33→): http.Server {\n    34→  const server = http.createServer(async (req, res) => {\n    35→    // Security headers\n    36→    res.setHeader('X-Content-Type-Options', 'nosniff');\n    37→\n    38→    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    39→    const origin = req.headers.origin ?? '';\n    40→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    41→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    42→    if (isAdminRoute) {\n    43→      // Admin routes: only allow same-origin requests (no CORS wildcard)\n    44→      if (origin && origin === allowedOrigin) {\n    45→        res.setHeader('Access-Control-Allow-Origin', origin);\n    46→      }\n    47→      // If no match, omit the header entirely — browser blocks the request\n    48→    } else {\n    49→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    50→    }\n    51→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    52→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n    53→\n    54→    if (req.method === 'OPTIONS') {\n    55→      res.writeHead(204);\n    56→      res.end();\n    57→      return;\n    58→    }\n    59→\n    60→    const url = req.url || '/';\n    61→    const [pathname, queryString] = url.split('?');\n    62→    const route = parseRoute(pathname ?? '');\n    63→\n    64→    // Unauthenticated endpoints\n    65→    if (pathname === '/health' && req.method === 'GET') {\n    66→      handleHealth(res, pool, oauth, getEventProcessorHealth, database, tenantDbManager);\n    67→      return;\n    68→    }\n    69→\n    70→    // Auth check for everything else — dual auth (API key + optional JWT)\n    71→    const ctx = auth.validateAndExtractContext(req);\n    72→    if (!ctx) {\n    73→      res.writeHead(401, { 'Content-Type': 'application/json' });\n    74→      res.end(JSON.stringify({ error: 'Unauthorized' }));\n    75→      return;\n    76→    }\n    77→\n    78→    // Helper: project scoping (admin sees all, user sees own project)\n    79→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n    80→\n    81→    // Resolve tenant-specific database when available\n    82→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n    83→      if (tenantDbManager && projectId) {\n    84→        return tenantDbManager.getTenantDb(projectId);\n    85→      }\n    86→      return database;\n    87→    };\n    88→    const tenantDb = resolveDatabase(ctx.projectId);\n    89→\n    90→    try {\n    91→      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n    92→      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n    93→        if (requireAdmin(ctx, res)) return;\n    94→        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n    95→        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n    96→        return;\n    97→      }\n    98→      // --- Persona CRUD ---\n    99→      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n   100→        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n   101→      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n   102→        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   103→        const persona = createPersonaWithDefaults({\n   104→          ...body,\n   105→          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   106→        });\n   107→        db.upsertPersona(tenantDb, persona);\n   108→        try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: persona.id }); } catch { /* logged inside record() */ }\n   109→        logger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   110→        json(res, 201, persona);\n   111→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n   112→        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n   113→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n   114→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   115→        if (!persona) return;\n   116→        const body = JSON.parse(await readBody(req)) as { toolId: string };\n   117→        db.linkTool(tenantDb, route.id, body.toolId);\n   118→        try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id, detail: JSON.stringify({ toolId: body.toolId }) }); } catch { /* logged inside record() */ }\n   119→        logger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   120→        json(res, 200, { linked: true });\n   121→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n   122→        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, logger), scopedProjectId, res);\n   123→        if (!hydrated) return;\n   124→        json(res, 200, hydrated);\n   125→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n   126→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   127→        if (!persona) return;\n   128→        json(res, 200, persona);\n   129→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   130→        db.deletePersona(tenantDb, route.id, scopedProjectId);\n   131→        try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id }); } catch { /* logged inside record() */ }\n   132→        logger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   133→        json(res, 200, { deleted: true });\n   134→      }\n   135→      // --- Tool Definitions ---\n   136→      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n   137→        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   138→        const tool = createToolDefinitionWithDefaults(body);\n   139→        db.upsertToolDefinition(tenantDb, tool);\n   140→        try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', resourceType: 'toolDefinition', resourceId: tool.id }); } catch { /* logged inside record() */ }\n   141→        logger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   142→        json(res, 201, tool);\n   143→      }\n   144→      // --- Credentials ---\n   145→      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n   146→        const body = JSON.parse(await readBody(req));\n   147→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   148→\n   149→        // Require plaintext — clients must never supply pre-encrypted data\n   150→        if (!body.plaintext || typeof body.plaintext !== 'string') {\n   151→          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   152→          return;\n   153→        }\n   154→\n   155→        // Reject oversized plaintext before synchronous encryption blocks the event loop\n   156→        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   157→          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   158→          return;\n   159→        }\n   160→\n   161→        // Encryption is mandatory — reject if the key manager is unavailable\n   162→        if (!tenantKeyManager) {\n   163→          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   164→          return;\n   165→        }\n   166→\n   167→        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n   168→        delete body.encryptedData;\n   169→        delete body.iv;\n   170→        delete body.tag;\n   171→\n   172→        // Server-side encryption with per-tenant key\n   173→        const tenantId = body.projectId || ctx.projectId || 'default';\n   174→        const key = await tenantKeyManager.getKey(tenantId);\n   175→        const encrypted = encrypt(body.plaintext, key);\n   176→        body.encryptedData = encrypted.encrypted;\n   177→        body.iv = encrypted.iv;\n   178→        body.tag = encrypted.tag;\n   179→        delete body.plaintext;\n   180→\n   181→        const cred = db.createCredential(tenantDb, body);\n   182→        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n   183→        logger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   184→        json(res, 201, cred);\n   185→      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   186→        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n   187→        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   188→        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   189→        logger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   190→        json(res, 200, { deleted: true });\n   191→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n   192→        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n   193→        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   194→        // Strip encrypted data from response\n   195→        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   196→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n   197→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   198→        if (!persona) return;\n   199→        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   200→        db.linkCredential(tenantDb, route.id, body.credentialId);\n   201→        try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id, detail: JSON.stringify({ credentialId: body.credentialId }) }); } catch { /* logged inside record() */ }\n   202→        logger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route.id, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   203→        json(res, 200, { linked: true });\n   204→      }\n   205→      // --- Event Subscriptions ---\n   206→      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n   207→        const body = JSON.parse(await readBody(req));\n   208→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   209→        const missing: string[] = [];\n   210→        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   211→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   212→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   213→        const sub = db.createSubscription(tenantDb, body);\n   214→        try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: sub.id, detail: JSON.stringify({ personaId: body.personaId, eventType: body.eventType }) }); } catch { /* logged inside record() */ }\n   215→        json(res, 201, sub);\n   216→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   217→        const body = JSON.parse(await readBody(req));\n   218→        db.updateSubscription(tenantDb, route.id, body);\n   219→        const updated = db.getSubscription(tenantDb, route.id);\n   220→        try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: route.id }); } catch { /* logged inside record() */ }\n   221→        json(res, 200, updated);\n   222→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   223→        db.deleteSubscription(tenantDb, route.id);\n   224→        try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: route.id }); } catch { /* logged inside record() */ }\n   225→        json(res, 200, { deleted: true });\n   226→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n   227→        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n   228→      }\n   229→      // --- Triggers (delegated to triggerHttpHandlers) ---\n   230→      else if (route && tenantDb && (\n   231→        route.resource === 'triggers' ||\n   232→        (route.resource === 'personas' && route.subResource === 'triggers')\n   233→      )) {\n   234→        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n   235→        return;\n   236→      }\n   237→      // --- Events ---\n   238→      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n   239→        const params = new URLSearchParams(queryString || '');\n   240→        const events = db.listEvents(tenantDb, {\n   241→          eventType: params.get('eventType') ?? undefined,\n   242→          status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n   243→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   244→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   245→          projectId: scopedProjectId,\n   246→        });\n   247→        json(res, 200, events);\n   248→      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n   249→        const body = JSON.parse(await readBody(req));\n   250→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   251→        const missing: string[] = [];\n   252→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   253→        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   254→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   255→        const event = db.publishEvent(tenantDb, body);\n   256→        json(res, 201, event);\n   257→      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   258→        const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n   259→        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n   260→        if (updated) {\n   261→          json(res, 200, updated);\n   262→        } else {\n   263→          res.writeHead(404, { 'Content-Type': 'application/json' });\n   264→          res.end(JSON.stringify({ error: 'Event not found' }));\n   265→        }\n   266→      }\n   267→      // --- Webhooks ---\n   268→      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n   269→        const personaId = route.id;\n   270→        const body = await readBody(req);\n   271→        const event = db.publishEvent(tenantDb, {\n   272→          eventType: 'webhook_received',\n   273→          sourceType: 'webhook',\n   274→          sourceId: personaId,\n   275→          targetPersonaId: personaId,\n   276→          payload: body,\n   277→        });\n   278→        json(res, 201, event);\n   279→      }\n   280→      // --- GitLab Webhook ---\n   281→      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n   282→        const body = await readBody(req);\n   283→        let parsed: Record<string, unknown> = {};\n   284→        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   285→        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   286→        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   287→        const event = db.publishEvent(tenantDb, {\n   288→          eventType: `gitlab_${objectKind}`,\n   289→          sourceType: 'gitlab',\n   290→          sourceId: projectPath ?? null,\n   291→          payload: body,\n   292→        });\n   293→        json(res, 201, event);\n   294→      }\n   295→      // --- Executions ---\n   296→      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n   297→        const params = new URLSearchParams(queryString || '');\n   298→        const executions = db.listExecutions(tenantDb, {\n   299→          personaId: params.get('personaId') ?? undefined,\n   300→          status: params.get('status') ?? undefined,\n   301→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   302→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   303→          projectId: scopedProjectId,\n   304→        });\n   305→        json(res, 200, executions);\n   306→      }\n   307→      // --- Existing execution endpoints ---\n   308→      else if (pathname === '/api/status' && req.method === 'GET') {\n   309→        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   310→      } else if (pathname === '/api/execute' && req.method === 'POST') {\n   311→        await handleExecute(req, res, dispatcher, logger, ctx);\n   312→      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n   313→        handleCancelExecution(res, dispatcher, route.id);\n   314→      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n   315→        const executionId = route.id;\n   316→        const params = new URLSearchParams(queryString || '');\n   317→        const offset = parseInt(params.get('offset') || '0', 10);\n   318→        handleGetExecution(res, dispatcher, executionId, offset);\n   319→      }\n   320→      // --- Admin-only routes ---\n   321→      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n   322→        if (requireAdmin(ctx, res)) return;\n   323→        if (tenantDbManager) {\n   324→          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   325→        } else if (database) {\n   326→          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   327→        } else {\n   328→          json(res, 200, { projectIds: [] });\n   329→        }\n   330→      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n   331→        if (requireAdmin(ctx, res)) return;\n   332→        if (tenantDbManager) {\n   333→          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   334→          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   335→          json(res, 200, allPersonas);\n   336→        } else if (database) {\n   337→          json(res, 200, db.listPersonasSummary(database));\n   338→        } else {\n   339→          json(res, 200, []);\n   340→        }\n   341→      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n   342→        if (requireAdmin(ctx, res)) return;\n   343→        const params = new URLSearchParams(queryString || '');\n   344→        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   345→        if (tenantDbManager) {\n   346→          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   347→          tenantDbManager.forEachTenant((tDb) => {\n   348→            allExecs.push(...db.listExecutions(tDb, { limit }));\n   349→          });\n   350→          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   351→          json(res, 200, allExecs.slice(0, limit));\n   352→        } else if (database) {\n   353→          json(res, 200, db.listExecutions(database, {\n   354→            limit,\n   355→            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   356→          }));\n   357→        } else {\n   358→          json(res, 200, []);\n   359→        }\n   360→      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n   361→        if (requireAdmin(ctx, res)) return;\n   362→        if (!auditLog) { json(res, 200, []); return; }\n   363→        const params = new URLSearchParams(queryString || '');\n   364→        json(res, 200, auditLog.query({\n   365→          tenantId: params.get('tenantId') ?? undefined,\n   366→          action: params.get('action') ?? undefined,\n   367→          since: params.get('since') ?? undefined,\n   368→          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   369→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   370→        }));\n   371→      } else {\n   372→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   373→        res.end(JSON.stringify({ error: 'Not found' }));\n   374→      }\n   375→    } catch (err) {\n   376→      if (err instanceof Error && err.message === 'Payload too large') {\n   377→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   378→        res.end(JSON.stringify({ error: 'Payload too large' }));\n   379→        return;\n   380→      }\n   381→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   382→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   383→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n   384→        return;\n   385→      }\n   386→      logger.error({ err, url }, 'HTTP handler error');\n   387→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   388→      res.end(JSON.stringify({ error: 'Internal server error' }));\n   389→    }\n   390→  });\n   391→\n   392→  return server;\n   393→}\n   394→\n   395→interface ParsedRoute {\n   396→  resource: string;\n   397→  id?: string;\n   398→  subResource?: string;\n   399→}\n   400→\n   401→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n   402→function parseRoute(pathname: string): ParsedRoute | null {\n   403→  if (!pathname.startsWith('/api/')) return null;\n   404→  const segments = pathname.slice(5).split('/').filter(Boolean);\n   405→  if (segments.length === 0) return null;\n   406→  return {\n   407→    resource: segments[0]!,\n   408→    id: segments[1],\n   409→    subResource: segments[2],\n   410→  };\n   411→}\n   412→\n   413→/**\n   414→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   415→ * Returns the entity on success, or null after sending a 404 response.\n   416→ */\n   417→function withScopedEntity<T extends { projectId?: string | null }>(\n   418→  entity: T | undefined,\n   419→  scopedProjectId: string | undefined,\n   420→  res: http.ServerResponse,\n   421→): T | null {\n   422→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   423→    json(res, 404, { error: 'Not found' });\n   424→    return null;\n   425→  }\n   426→  return entity;\n   427→}\n   428→\n   429→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   430→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   431→  if (ctx.authType !== 'admin') {\n   432→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   433→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   434→    return true;\n   435→  }\n   436→  return false;\n   437→}\n   438→\n   439→// --- Existing handlers ---\n   440→\n   441→function handleHealth(\n   442→  res: http.ServerResponse,\n   443→  pool: WorkerPool,\n   444→  oauth: OAuthManager,\n   445→  getEventProcessorHealth?: () => EventProcessorHealth,\n   446→  database?: Database.Database,\n   447→  tenantDbManager?: TenantDbManager,\n   448→): void {\n   449→  const counts = pool.getWorkerCount();\n   450→\n   451→  // Lightweight database connectivity check\n   452→  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n   453→  if (database) {\n   454→    try {\n   455→      database.prepare('SELECT 1').get();\n   456→      dbHealth.status = 'ok';\n   457→    } catch {\n   458→      dbHealth.status = 'error';\n   459→    }\n   460→  }\n   461→  if (tenantDbManager) {\n   462→    try {\n   463→      const tenantIds = tenantDbManager.listTenantIds();\n   464→      dbHealth.tenantCount = tenantIds.length;\n   465→    } catch {\n   466→      dbHealth.tenantCount = -1;\n   467→    }\n   468→  }\n   469→\n   470→  const body: Record<string, unknown> = {\n   471→    status: 'ok',\n   472→    workers: counts,\n   473→    hasSubscription: oauth.hasTokens(),\n   474→    database: dbHealth,\n   475→    timestamp: Date.now(),\n   476→  };\n   477→  if (getEventProcessorHealth) {\n   478→    body.eventProcessor = getEventProcessorHealth();\n   479→  }\n   480→\n   481→  // Degrade overall status if database is unhealthy\n   482→  if (dbHealth.status === 'error') {\n   483→    body.status = 'degraded';\n   484→  }\n   485→\n   486→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   487→  res.end(JSON.stringify(body));\n   488→}\n   489→\n   490→function handleStatus(\n   491→  res: http.ServerResponse,\n   492→  pool: WorkerPool,\n   493→  dispatcher: Dispatcher,\n   494→  tokenManager: TokenManager,\n   495→  oauth: OAuthManager,\n   496→): void {\n   497→  const oauthTokens = oauth.getTokens();\n   498→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   499→  res.end(JSON.stringify({\n   500→    workers: pool.getWorkers(),\n   501→    workerCounts: pool.getWorkerCount(),\n   502→    workerPoolMetrics: pool.getMetrics(),\n   503→    queueLength: dispatcher.getQueueLength(),\n   504→    activeExecutions: dispatcher.getActiveExecutions(),\n   505→    hasClaudeToken: tokenManager.hasToken(),\n   506→    oauth: {\n   507→      connected: oauth.hasTokens(),\n   508→      scopes: oauthTokens?.scopes || [],\n   509→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   510→    },\n   511→  }));\n   512→}\n   513→\n   514→async function handleExecute(\n   515→  req: http.IncomingMessage,\n   516→  res: http.ServerResponse,\n   517→  dispatcher: Dispatcher,\n   518→  logger: Logger,\n   519→  ctx?: RequestContext,\n   520→): Promise<void> {\n   521→  const body = await readBody(req);\n   522→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   523→\n   524→  try {\n   525→    parsed = JSON.parse(body);\n   526→  } catch {\n   527→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   528→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   529→    return;\n   530→  }\n   531→\n   532→  if (!parsed.prompt) {\n   533→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   534→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   535→    return;\n   536→  }\n   537→\n   538→  const request: ExecRequest = {\n   539→    executionId: nanoid(),\n   540→    personaId: parsed.personaId || 'manual',\n   541→    prompt: parsed.prompt,\n   542→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   543→    config: {\n   544→      timeoutMs: parsed.timeoutMs || 300_000,\n   545→    },\n   546→  };\n   547→\n   548→  dispatcher.submit(request);\n   549→\n   550→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   551→\n   552→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   553→  res.end(JSON.stringify({\n   554→    executionId: request.executionId,\n   555→    status: 'queued',\n   556→  }));\n   557→}\n   558→\n   559→function handleGetExecution(\n   560→  res: http.ServerResponse,\n   561→  dispatcher: Dispatcher,\n   562→  executionId: string,\n   563→  offset: number = 0,\n   564→): void {\n   565→  const exec = dispatcher.getExecution(executionId);\n   566→\n   567→  if (!exec) {\n   568→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   569→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   570→    return;\n   571→  }\n   572→\n   573→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   574→\n   575→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   576→  res.end(JSON.stringify({\n   577→    executionId,\n   578→    status: exec.status,\n   579→    outputLines: exec.output.length,\n   580→    output,\n   581→    durationMs: exec.durationMs,\n   582→    sessionId: exec.sessionId,\n   583→    totalCostUsd: exec.totalCostUsd,\n   584→    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n   585→  }));\n   586→}\n   587→\n   588→function handleCancelExecution(\n   589→  res: http.ServerResponse,\n   590→  dispatcher: Dispatcher,\n   591→  executionId: string,\n   592→): void {\n   593→  const cancelled = dispatcher.cancelExecution(executionId);\n   594→\n   595→  if (!cancelled) {\n   596→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   597→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   598→    return;\n   599→  }\n   600→\n   601→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   602→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   603→}\n   604→\n   605→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\n   606→const MAX_QUERY_LIMIT = 500;\n   607→const MAX_QUERY_OFFSET = 100_000;\n   608→\n   609→/** Parse an integer query param and clamp it to safe bounds. */\n   610→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   611→  if (!value) return defaultValue;\n   612→  const parsed = parseInt(value, 10);\n   613→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   614→  return Math.min(parsed, max);\n   615→}\n   616→"}]},"parent_tool_use_id":null,"session_id":"17bd0134-d09a-4683-b90e-56b5b71c91c6","uuid":"c83d7f24-5bd8-4de5-8505-7d335b476490","timestamp":"2026-03-18T17:33:49.746Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { EventProcessorHealth } from './eventProcessor.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n): http.Server {\n  const server = http.createServer(async (req, res) => {\n    // Security headers\n    res.setHeader('X-Content-Type-Options', 'nosniff');\n\n    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    const origin = req.headers.origin ?? '';\n    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    if (isAdminRoute) {\n      // Admin routes: only allow same-origin requests (no CORS wildcard)\n      if (origin && origin === allowedOrigin) {\n        res.setHeader('Access-Control-Allow-Origin', origin);\n      }\n      // If no match, omit the header entirely — browser blocks the request\n    } else {\n      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    }\n    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n\n    if (req.method === 'OPTIONS') {\n      res.writeHead(204);\n      res.end();\n      return;\n    }\n\n    const url = req.url || '/';\n    const [pathname, queryString] = url.split('?');\n    const route = parseRoute(pathname ?? '');\n\n    // Unauthenticated endpoints\n    if (pathname === '/health' && req.method === 'GET') {\n      handleHealth(res, pool, oauth, getEventProcessorHealth, database, tenantDbManager);\n      return;\n    }\n\n    // Auth check for everything else — dual auth (API key + optional JWT)\n    const ctx = auth.validateAndExtractContext(req);\n    if (!ctx) {\n      res.writeHead(401, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Unauthorized' }));\n      return;\n    }\n\n    // Helper: project scoping (admin sees all, user sees own project)\n    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n\n    // Resolve tenant-specific database when available\n    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n      if (tenantDbManager && projectId) {\n        return tenantDbManager.getTenantDb(projectId);\n      }\n      return database;\n    };\n    const tenantDb = resolveDatabase(ctx.projectId);\n\n    try {\n      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n        if (requireAdmin(ctx, res)) return;\n        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n        return;\n      }\n      // --- Persona CRUD ---\n      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n        const persona = createPersonaWithDefaults({\n          ...body,\n          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n        });\n        db.upsertPersona(tenantDb, persona);\n        try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: persona.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n        json(res, 201, persona);\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { toolId: string };\n        db.linkTool(tenantDb, route.id, body.toolId);\n        try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id, detail: JSON.stringify({ toolId: body.toolId }) }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n        json(res, 200, { linked: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, logger), scopedProjectId, res);\n        if (!hydrated) return;\n        json(res, 200, hydrated);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        json(res, 200, persona);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deletePersona(tenantDb, route.id, scopedProjectId);\n        try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n        json(res, 200, { deleted: true });\n      }\n      // --- Tool Definitions ---\n      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n        const tool = createToolDefinitionWithDefaults(body);\n        db.upsertToolDefinition(tenantDb, tool);\n        try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', resourceType: 'toolDefinition', resourceId: tool.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n        json(res, 201, tool);\n      }\n      // --- Credentials ---\n      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n\n        // Require plaintext — clients must never supply pre-encrypted data\n        if (!body.plaintext || typeof body.plaintext !== 'string') {\n          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n          return;\n        }\n\n        // Reject oversized plaintext before synchronous encryption blocks the event loop\n        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n          return;\n        }\n\n        // Encryption is mandatory — reject if the key manager is unavailable\n        if (!tenantKeyManager) {\n          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n          return;\n        }\n\n        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n        delete body.encryptedData;\n        delete body.iv;\n        delete body.tag;\n\n        // Server-side encryption with per-tenant key\n        const tenantId = body.projectId || ctx.projectId || 'default';\n        const key = await tenantKeyManager.getKey(tenantId);\n        const encrypted = encrypt(body.plaintext, key);\n        body.encryptedData = encrypted.encrypted;\n        body.iv = encrypted.iv;\n        body.tag = encrypted.tag;\n        delete body.plaintext;\n\n        const cred = db.createCredential(tenantDb, body);\n        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n        json(res, 201, cred);\n      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n        // Strip encrypted data from response\n        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n        db.linkCredential(tenantDb, route.id, body.credentialId);\n        try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id, detail: JSON.stringify({ credentialId: body.credentialId }) }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route.id, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n        json(res, 200, { linked: true });\n      }\n      // --- Event Subscriptions ---\n      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const sub = db.createSubscription(tenantDb, body);\n        try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: sub.id, detail: JSON.stringify({ personaId: body.personaId, eventType: body.eventType }) }); } catch { /* logged inside record() */ }\n        json(res, 201, sub);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        db.updateSubscription(tenantDb, route.id, body);\n        const updated = db.getSubscription(tenantDb, route.id);\n        try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: route.id }); } catch { /* logged inside record() */ }\n        json(res, 200, updated);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deleteSubscription(tenantDb, route.id);\n        try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: route.id }); } catch { /* logged inside record() */ }\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n      }\n      // --- Triggers (delegated to triggerHttpHandlers) ---\n      else if (route && tenantDb && (\n        route.resource === 'triggers' ||\n        (route.resource === 'personas' && route.subResource === 'triggers')\n      )) {\n        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n        return;\n      }\n      // --- Events ---\n      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const events = db.listEvents(tenantDb, {\n          eventType: params.get('eventType') ?? undefined,\n          status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, events);\n      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const event = db.publishEvent(tenantDb, body);\n        json(res, 201, event);\n      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n        if (updated) {\n          json(res, 200, updated);\n        } else {\n          res.writeHead(404, { 'Content-Type': 'application/json' });\n          res.end(JSON.stringify({ error: 'Event not found' }));\n        }\n      }\n      // --- Webhooks ---\n      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n        const personaId = route.id;\n        const body = await readBody(req);\n        const event = db.publishEvent(tenantDb, {\n          eventType: 'webhook_received',\n          sourceType: 'webhook',\n          sourceId: personaId,\n          targetPersonaId: personaId,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- GitLab Webhook ---\n      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n        const body = await readBody(req);\n        let parsed: Record<string, unknown> = {};\n        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n        const event = db.publishEvent(tenantDb, {\n          eventType: `gitlab_${objectKind}`,\n          sourceType: 'gitlab',\n          sourceId: projectPath ?? null,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- Executions ---\n      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const executions = db.listExecutions(tenantDb, {\n          personaId: params.get('personaId') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, executions);\n      }\n      // --- Existing execution endpoints ---\n      else if (pathname === '/api/status' && req.method === 'GET') {\n        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n      } else if (pathname === '/api/execute' && req.method === 'POST') {\n        await handleExecute(req, res, dispatcher, logger, ctx);\n      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n        handleCancelExecution(res, dispatcher, route.id);\n      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n        const executionId = route.id;\n        const params = new URLSearchParams(queryString || '');\n        const offset = parseInt(params.get('offset') || '0', 10);\n        handleGetExecution(res, dispatcher, executionId, offset);\n      }\n      // --- Admin-only routes ---\n      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n        } else if (database) {\n          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n        } else {\n          json(res, 200, { projectIds: [] });\n        }\n      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n          json(res, 200, allPersonas);\n        } else if (database) {\n          json(res, 200, db.listPersonasSummary(database));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        const params = new URLSearchParams(queryString || '');\n        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n        if (tenantDbManager) {\n          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n          tenantDbManager.forEachTenant((tDb) => {\n            allExecs.push(...db.listExecutions(tDb, { limit }));\n          });\n          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n          json(res, 200, allExecs.slice(0, limit));\n        } else if (database) {\n          json(res, 200, db.listExecutions(database, {\n            limit,\n            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          }));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (!auditLog) { json(res, 200, []); return; }\n        const params = new URLSearchParams(queryString || '');\n        json(res, 200, auditLog.query({\n          tenantId: params.get('tenantId') ?? undefined,\n          action: params.get('action') ?? undefined,\n          since: params.get('since') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        }));\n      } else {\n        res.writeHead(404, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Not found' }));\n      }\n    } catch (err) {\n      if (err instanceof Error && err.message === 'Payload too large') {\n        res.writeHead(413, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Payload too large' }));\n        return;\n      }\n      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n        res.writeHead(409, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n        return;\n      }\n      logger.error({ err, url }, 'HTTP handler error');\n      res.writeHead(500, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Internal server error' }));\n    }\n  });\n\n  return server;\n}\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\n/**\n * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n * Returns the entity on success, or null after sending a 404 response.\n */\nfunction withScopedEntity<T extends { projectId?: string | null }>(\n  entity: T | undefined,\n  scopedProjectId: string | undefined,\n  res: http.ServerResponse,\n): T | null {\n  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n    json(res, 404, { error: 'Not found' });\n    return null;\n  }\n  return entity;\n}\n\n/** Returns true (and sends 403) if the caller is NOT an admin. */\nfunction requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n  if (ctx.authType !== 'admin') {\n    res.writeHead(403, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Admin access required' }));\n    return true;\n  }\n  return false;\n}\n\n// --- Existing handlers ---\n\nfunction handleHealth(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  oauth: OAuthManager,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n): void {\n  const counts = pool.getWorkerCount();\n\n  // Lightweight database connectivity check\n  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n  if (database) {\n    try {\n      database.prepare('SELECT 1').get();\n      dbHealth.status = 'ok';\n    } catch {\n      dbHealth.status = 'error';\n    }\n  }\n  if (tenantDbManager) {\n    try {\n      const tenantIds = tenantDbManager.listTenantIds();\n      dbHealth.tenantCount = tenantIds.length;\n    } catch {\n      dbHealth.tenantCount = -1;\n    }\n  }\n\n  const body: Record<string, unknown> = {\n    status: 'ok',\n    workers: counts,\n    hasSubscription: oauth.hasTokens(),\n    database: dbHealth,\n    timestamp: Date.now(),\n  };\n  if (getEventProcessorHealth) {\n    body.eventProcessor = getEventProcessorHealth();\n  }\n\n  // Degrade overall status if database is unhealthy\n  if (dbHealth.status === 'error') {\n    body.status = 'degraded';\n  }\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify(body));\n}\n\nfunction handleStatus(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n): void {\n  const oauthTokens = oauth.getTokens();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    workers: pool.getWorkers(),\n    workerCounts: pool.getWorkerCount(),\n    workerPoolMetrics: pool.getMetrics(),\n    queueLength: dispatcher.getQueueLength(),\n    activeExecutions: dispatcher.getActiveExecutions(),\n    hasClaudeToken: tokenManager.hasToken(),\n    oauth: {\n      connected: oauth.hasTokens(),\n      scopes: oauthTokens?.scopes || [],\n      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n    },\n  }));\n}\n\nasync function handleExecute(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  ctx?: RequestContext,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.prompt) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n    return;\n  }\n\n  const request: ExecRequest = {\n    executionId: nanoid(),\n    personaId: parsed.personaId || 'manual',\n    prompt: parsed.prompt,\n    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n    config: {\n      timeoutMs: parsed.timeoutMs || 300_000,\n    },\n  };\n\n  dispatcher.submit(request);\n\n  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n\n  res.writeHead(202, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId: request.executionId,\n    status: 'queued',\n  }));\n}\n\nfunction handleGetExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n  offset: number = 0,\n): void {\n  const exec = dispatcher.getExecution(executionId);\n\n  if (!exec) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found' }));\n    return;\n  }\n\n  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId,\n    status: exec.status,\n    outputLines: exec.output.length,\n    output,\n    durationMs: exec.durationMs,\n    sessionId: exec.sessionId,\n    totalCostUsd: exec.totalCostUsd,\n    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n  }));\n}\n\nfunction handleCancelExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n): void {\n  const cancelled = dispatcher.cancelExecution(executionId);\n\n  if (!cancelled) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n    return;\n  }\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n}\n\nconst MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\nconst MAX_QUERY_LIMIT = 500;\nconst MAX_QUERY_OFFSET = 100_000;\n\n/** Parse an integer query param and clamp it to safe bounds. */\nfunction clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n  if (!value) return defaultValue;\n  const parsed = parseInt(value, 10);\n  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n  return Math.min(parsed, max);\n}\n","numLines":616,"startLine":1,"totalLines":616}}}
