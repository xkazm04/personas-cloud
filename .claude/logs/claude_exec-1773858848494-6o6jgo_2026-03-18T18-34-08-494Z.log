[2026-03-18T18:34:28.500Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SEPgomuh85JhBFLqbz9k6D","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import type { KafkaClient } from './kafka.js';\n    11→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    12→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    13→import type { TriggerSchedulerHandle } from './triggerScheduler.js';\n    14→import type { TenantDbManager } from './tenantDbManager.js';\n    15→import type { TenantKeyManager } from './tenantKeyManager.js';\n    16→import type { AuditLog, AuditEntry, AuditAction } from './auditLog.js';\n    17→import type { EventProcessorHealth } from './eventProcessor.js';\n    18→import type { Logger } from 'pino';\n    19→import * as db from './db/index.js';\n    20→import { readBody, json } from './httpUtils.js';\n    21→\n    22→// --- Route types ---\n    23→\n    24→interface ParsedRoute {\n    25→  resource: string;\n    26→  id?: string;\n    27→  subResource?: string;\n    28→}\n    29→\n    30→type RouteHandler = (\n    31→  req: http.IncomingMessage,\n    32→  res: http.ServerResponse,\n    33→  ctx: RequestContext,\n    34→  route: ParsedRoute | null,\n    35→  queryString: string | undefined,\n    36→  tenantDb: Database.Database | undefined,\n    37→  scopedProjectId: string | undefined,\n    38→  reqLogger: Logger,\n    39→) => Promise<void> | void;\n    40→\n    41→interface RouteEntry {\n    42→  handler: RouteHandler;\n    43→  needsDb?: boolean;\n    44→  adminOnly?: boolean;\n    45→}\n    46→\n    47→/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\n    48→function resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n    49→  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n    50→}\n    51→\n    52→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n    53→function parseRoute(pathname: string): ParsedRoute | null {\n    54→  if (!pathname.startsWith('/api/')) return null;\n    55→  const segments = pathname.slice(5).split('/').filter(Boolean);\n    56→  if (segments.length === 0) return null;\n    57→  return {\n    58→    resource: segments[0]!,\n    59→    id: segments[1],\n    60→    subResource: segments[2],\n    61→  };\n    62→}\n    63→\n    64→export function createHttpApi(\n    65→  auth: Auth,\n    66→  dispatcher: Dispatcher,\n    67→  pool: WorkerPool,\n    68→  tokenManager: TokenManager,\n    69→  oauth: OAuthManager,\n    70→  logger: Logger,\n    71→  database?: Database.Database,\n    72→  tenantDbManager?: TenantDbManager,\n    73→  tenantKeyManager?: TenantKeyManager,\n    74→  auditLog?: AuditLog,\n    75→  getEventProcessorHealth?: () => EventProcessorHealth,\n    76→  kafka?: KafkaClient,\n    77→  onEventPublished?: () => void,\n    78→  triggerScheduler?: TriggerSchedulerHandle,\n    79→): http.Server {\n    80→\n    81→  /** Wrap a mutation handler to emit an audit event on successful response. */\n    82→  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    83→    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n    84→      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n    85→      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n    86→        try {\n    87→          auditLog.record({\n    88→            action,\n    89→            tenantId: ctx.projectId || 'default',\n    90→            actor: ctx.userEmail || ctx.projectId,\n    91→            resourceType,\n    92→            resourceId: route?.id,\n    93→            ipAddress: req.socket.remoteAddress,\n    94→          } as AuditEntry);\n    95→        } catch { /* logged inside record() */ }\n    96→      }\n    97→    };\n    98→  }\n    99→\n   100→  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n   101→  const exactRoutes = new Map<string, RouteEntry>();\n   102→\n   103→  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n   104→  for (const [path, method] of [\n   105→    ['/api/oauth/authorize', 'POST'],\n   106→    ['/api/oauth/callback', 'POST'],\n   107→    ['/api/oauth/status', 'GET'],\n   108→    ['/api/oauth/refresh', 'POST'],\n   109→    ['/api/oauth/disconnect', 'DELETE'],\n   110→    ['/api/token', 'POST'],\n   111→  ] as const) {\n   112→    exactRoutes.set(`${method}:${path}`, {\n   113→      adminOnly: true,\n   114→      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   115→        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger);\n   116→      },\n   117→    });\n   118→  }\n   119→\n   120→  exactRoutes.set('GET:/api/status', {\n   121→    handler: (_req, res) => {\n   122→      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   123→    },\n   124→  });\n   125→\n   126→  exactRoutes.set('POST:/api/execute', {\n   127→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   128→      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n   129→    }, 'execution:submit', 'execution'),\n   130→  });\n   131→\n   132→  exactRoutes.set('POST:/api/gitlab/webhook', {\n   133→    needsDb: true,\n   134→    handler: withHttpAudit(async (req, res, _ctx, _route, _qs, tenantDb) => {\n   135→      const body = await readBody(req);\n   136→      let parsed: Record<string, unknown> = {};\n   137→      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   138→      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   139→      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   140→      const event = db.publishEvent(tenantDb!, {\n   141→        eventType: `gitlab_${objectKind}`,\n   142→        sourceType: 'gitlab',\n   143→        sourceId: projectPath ?? null,\n   144→        payload: body,\n   145→      });\n   146→      onEventPublished?.();\n   147→      json(res, 201, event);\n   148→    }, 'event:publish', 'event'),\n   149→  });\n   150→\n   151→  // Admin routes\n   152→  exactRoutes.set('GET:/api/admin/users', {\n   153→    adminOnly: true,\n   154→    handler: (_req, res) => {\n   155→      if (tenantDbManager) {\n   156→        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   157→      } else if (database) {\n   158→        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   159→      } else {\n   160→        json(res, 200, { projectIds: [] });\n   161→      }\n   162→    },\n   163→  });\n   164→\n   165→  exactRoutes.set('GET:/api/admin/personas', {\n   166→    adminOnly: true,\n   167→    handler: (_req, res) => {\n   168→      if (tenantDbManager) {\n   169→        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   170→        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   171→        json(res, 200, allPersonas);\n   172→      } else if (database) {\n   173→        json(res, 200, db.listPersonasSummary(database));\n   174→      } else {\n   175→        json(res, 200, []);\n   176→      }\n   177→    },\n   178→  });\n   179→\n   180→  exactRoutes.set('GET:/api/admin/executions', {\n   181→    adminOnly: true,\n   182→    handler: (_req, res, _ctx, _route, queryString) => {\n   183→      const params = new URLSearchParams(queryString || '');\n   184→      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   185→      if (tenantDbManager) {\n   186→        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   187→        tenantDbManager.forEachTenant((tDb) => {\n   188→          allExecs.push(...db.listExecutions(tDb, { limit }));\n   189→        });\n   190→        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   191→        json(res, 200, allExecs.slice(0, limit));\n   192→      } else if (database) {\n   193→        json(res, 200, db.listExecutions(database, {\n   194→          limit,\n   195→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   196→        }));\n   197→      } else {\n   198→        json(res, 200, []);\n   199→      }\n   200→    },\n   201→  });\n   202→\n   203→  exactRoutes.set('GET:/api/admin/audit', {\n   204→    adminOnly: true,\n   205→    handler: (_req, res, _ctx, _route, queryString) => {\n   206→      if (!auditLog) { json(res, 200, []); return; }\n   207→      const params = new URLSearchParams(queryString || '');\n   208→      json(res, 200, auditLog.query({\n   209→        tenantId: params.get('tenantId') ?? undefined,\n   210→        action: (params.get('action') ?? undefined) as AuditAction | undefined,\n   211→        since: params.get('since') ?? undefined,\n   212→        limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   213→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   214→      }));\n   215→    },\n   216→  });\n   217→\n   218→  exactRoutes.set('GET:/api/admin/audit/stats', {\n   219→    adminOnly: true,\n   220→    handler: (_req, res, _ctx, _route, queryString) => {\n   221→      if (!auditLog) { json(res, 200, { byAction: [], byTenant: [], topActors: [], trend: [] }); return; }\n   222→      const params = new URLSearchParams(queryString || '');\n   223→      const bucket = params.get('bucket') === 'hour' ? 'hour' : 'day';\n   224→      json(res, 200, auditLog.stats({\n   225→        tenantId: params.get('tenantId') ?? undefined,\n   226→        since: params.get('since') ?? undefined,\n   227→        until: params.get('until') ?? undefined,\n   228→        bucket,\n   229→      }));\n   230→    },\n   231→  });\n   232→\n   233→  exactRoutes.set('POST:/api/admin/audit/verify', {\n   234→    adminOnly: true,\n   235→    handler: async (req, res) => {\n   236→      if (!auditLog) { json(res, 200, { valid: true, verifiedCount: 0 }); return; }\n   237→      const body = await readBody(req);\n   238→      let opts: { since?: string; until?: string } | undefined;\n   239→      if (body) {\n   240→        try {\n   241→          const parsed = JSON.parse(body) as { since?: string; until?: string };\n   242→          if (parsed.since || parsed.until) opts = { since: parsed.since, until: parsed.until };\n   243→        } catch { /* empty body or non-JSON — verify entire chain */ }\n   244→      }\n   245→      json(res, 200, auditLog.verify(opts));\n   246→    },\n   247→  });\n   248→\n   249→  // ── Resource route table (O(1) lookup by `METHOD:resource[:id][:sub]`) ──\n   250→  const resourceRoutes = new Map<string, RouteEntry>();\n   251→\n   252→  // --- Persona CRUD ---\n   253→  resourceRoutes.set(resourceKey('GET', 'personas', false), {\n   254→    needsDb: true,\n   255→    handler: (_req, res, _ctx, _route, _qs, tenantDb, scopedProjectId) => {\n   256→      json(res, 200, db.listPersonasSummary(tenantDb!, scopedProjectId));\n   257→    },\n   258→  });\n   259→\n   260→  resourceRoutes.set(resourceKey('POST', 'personas', false), {\n   261→    needsDb: true,\n   262→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   263→      const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   264→      const persona = createPersonaWithDefaults({\n   265→        ...body,\n   266→        projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   267→      });\n   268→      db.upsertPersona(tenantDb!, persona);\n   269→      try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: persona.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   270→      reqLogger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   271→      json(res, 201, persona);\n   272→    },\n   273→  });\n   274→\n   275→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'tools'), {\n   276→    needsDb: true,\n   277→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   278→      json(res, 200, db.getToolsForPersona(tenantDb!, route!.id!));\n   279→    },\n   280→  });\n   281→\n   282→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'tools'), {\n   283→    needsDb: true,\n   284→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   285→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   286→      if (!persona) return;\n   287→      const body = JSON.parse(await readBody(req)) as { toolId: string };\n   288→      db.linkTool(tenantDb!, route!.id!, body.toolId);\n   289→      try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { toolId: body.toolId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   290→      reqLogger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route!.id!, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   291→      json(res, 200, { linked: true });\n   292→    },\n   293→  });\n   294→\n   295→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'full'), {\n   296→    needsDb: true,\n   297→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   298→      const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb!, route!.id!, reqLogger), scopedProjectId, res);\n   299→      if (!hydrated) return;\n   300→      json(res, 200, hydrated);\n   301→    },\n   302→  });\n   303→\n   304→  resourceRoutes.set(resourceKey('GET', 'personas', true), {\n   305→    needsDb: true,\n   306→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId) => {\n   307→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   308→      if (!persona) return;\n   309→      json(res, 200, persona);\n   310→    },\n   311→  });\n   312→\n   313→  resourceRoutes.set(resourceKey('DELETE', 'personas', true), {\n   314→    needsDb: true,\n   315→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   316→      db.deletePersona(tenantDb!, route!.id!, scopedProjectId);\n   317→      try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   318→      reqLogger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   319→      json(res, 200, { deleted: true });\n   320→    },\n   321→  });\n   322→\n   323→  // --- Persona sub-resources: credentials ---\n   324→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'credentials'), {\n   325→    needsDb: true,\n   326→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   327→      const creds = db.listCredentialsForPersona(tenantDb!, route!.id!);\n   328→      try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   329→      json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   330→    },\n   331→  });\n   332→\n   333→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'credentials'), {\n   334→    needsDb: true,\n   335→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   336→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   337→      if (!persona) return;\n   338→      const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   339→      db.linkCredential(tenantDb!, route!.id!, body.credentialId);\n   340→      try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { credentialId: body.credentialId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   341→      reqLogger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route!.id!, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   342→      json(res, 200, { linked: true });\n   343→    },\n   344→  });\n   345→\n   346→  // --- Persona sub-resources: subscriptions ---\n   347→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'subscriptions'), {\n   348→    needsDb: true,\n   349→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   350→      json(res, 200, db.listSubscriptionsForPersona(tenantDb!, route!.id!));\n   351→    },\n   352→  });\n   353→\n   354→  // --- Tool Definitions ---\n   355→  resourceRoutes.set(resourceKey('POST', 'tool-definitions', false), {\n   356→    needsDb: true,\n   357→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   358→      const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   359→      const tool = createToolDefinitionWithDefaults(body);\n   360→      db.upsertToolDefinition(tenantDb!, tool);\n   361→      try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'toolDefinition', resourceId: tool.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   362→      reqLogger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   363→      json(res, 201, tool);\n   364→    },\n   365→  });\n   366→\n   367→  // --- Credentials ---\n   368→  resourceRoutes.set(resourceKey('POST', 'credentials', false), {\n   369→    needsDb: true,\n   370→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   371→      const body = JSON.parse(await readBody(req));\n   372→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   373→\n   374→      if (!body.plaintext || typeof body.plaintext !== 'string') {\n   375→        json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   376→        return;\n   377→      }\n   378→      if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   379→        json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   380→        return;\n   381→      }\n   382→      if (!tenantKeyManager) {\n   383→        json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   384→        return;\n   385→      }\n   386→\n   387→      delete body.encryptedData;\n   388→      delete body.iv;\n   389→      delete body.tag;\n   390→\n   391→      const tenantId = body.projectId || ctx.projectId || 'default';\n   392→      const key = await tenantKeyManager.getKey(tenantId);\n   393→      const encrypted = encrypt(body.plaintext, key);\n   394→      body.encryptedData = encrypted.encrypted;\n   395→      body.iv = encrypted.iv;\n   396→      body.tag = encrypted.tag;\n   397→      delete body.plaintext;\n   398→\n   399→      const cred = db.createCredential(tenantDb!, body);\n   400→      try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: cred.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   401→      reqLogger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   402→      json(res, 201, cred);\n   403→    },\n   404→  });\n   405→\n   406→  resourceRoutes.set(resourceKey('DELETE', 'credentials', true), {\n   407→    needsDb: true,\n   408→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   409→      const changes = db.deleteCredential(tenantDb!, route!.id!, scopedProjectId);\n   410→      if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   411→      try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   412→      reqLogger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   413→      json(res, 200, { deleted: true });\n   414→    },\n   415→  });\n   416→\n   417→  // --- Event Subscriptions ---\n   418→  resourceRoutes.set(resourceKey('POST', 'subscriptions', false), {\n   419→    needsDb: true,\n   420→    handler: async (req, res, ctx, _route, _qs, tenantDb) => {\n   421→      const body = JSON.parse(await readBody(req));\n   422→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   423→      const missing: string[] = [];\n   424→      if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   425→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   426→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   427→      const sub = db.createSubscription(tenantDb!, body);\n   428→      try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: sub.id, detail: { personaId: body.personaId, eventType: body.eventType }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   429→      json(res, 201, sub);\n   430→    },\n   431→  });\n   432→\n   433→  resourceRoutes.set(resourceKey('PUT', 'subscriptions', true), {\n   434→    needsDb: true,\n   435→    handler: async (req, res, ctx, route, _qs, tenantDb) => {\n   436→      const body = JSON.parse(await readBody(req));\n   437→      db.updateSubscription(tenantDb!, route!.id!, body);\n   438→      const updated = db.getSubscription(tenantDb!, route!.id!);\n   439→      try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   440→      json(res, 200, updated);\n   441→    },\n   442→  });\n   443→\n   444→  resourceRoutes.set(resourceKey('DELETE', 'subscriptions', true), {\n   445→    needsDb: true,\n   446→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   447→      db.deleteSubscription(tenantDb!, route!.id!);\n   448→      try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   449→      json(res, 200, { deleted: true });\n   450→    },\n   451→  });\n   452→\n   453→  // --- Triggers (delegated to triggerHttpHandlers) ---\n   454→  const triggerHandler: RouteHandler = async (req, res, ctx, route, _qs, tenantDb) => {\n   455→    await handleTriggerRoute(route!, req.method!, req, res, tenantDb!, ctx, triggerScheduler);\n   456→  };\n   457→  resourceRoutes.set(resourceKey('POST', 'triggers', false), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:create', 'trigger') });\n   458→  resourceRoutes.set(resourceKey('PUT', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:update', 'trigger') });\n   459→  resourceRoutes.set(resourceKey('DELETE', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:delete', 'trigger') });\n   460→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'triggers'), { needsDb: true, handler: triggerHandler });\n   461→\n   462→  // --- Events ---\n   463→  resourceRoutes.set(resourceKey('GET', 'events', false), {\n   464→    needsDb: true,\n   465→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   466→      const params = new URLSearchParams(queryString || '');\n   467→      const events = db.listEvents(tenantDb!, {\n   468→        eventType: params.get('eventType') ?? undefined,\n   469→        status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n   470→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   471→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   472→        projectId: scopedProjectId,\n   473→      });\n   474→      json(res, 200, events);\n   475→    },\n   476→  });\n   477→\n   478→  resourceRoutes.set(resourceKey('POST', 'events', false), {\n   479→    needsDb: true,\n   480→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, tenantDb) => {\n   481→      const body = JSON.parse(await readBody(req));\n   482→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   483→      const missing: string[] = [];\n   484→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   485→      if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   486→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   487→      const event = db.publishEvent(tenantDb!, body);\n   488→      onEventPublished?.();\n   489→      json(res, 201, event);\n   490→    }, 'event:publish', 'event'),\n   491→  });\n   492→\n   493→  resourceRoutes.set(resourceKey('PUT', 'events', true), {\n   494→    needsDb: true,\n   495→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   496→      const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n   497→      const updated = db.updateEventWithMetadata(tenantDb!, route!.id!, body.status, body.metadata);\n   498→      if (updated) {\n   499→        json(res, 200, updated);\n   500→      } else {\n   501→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   502→        res.end(JSON.stringify({ error: 'Event not found' }));\n   503→      }\n   504→    }, 'event:update', 'event'),\n   505→  });\n   506→\n   507→  // --- Webhooks ---\n   508→  resourceRoutes.set(resourceKey('POST', 'webhooks', true), {\n   509→    needsDb: true,\n   510→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   511→      const personaId = route!.id!;\n   512→      const body = await readBody(req);\n   513→      const event = db.publishEvent(tenantDb!, {\n   514→        eventType: 'webhook_received',\n   515→        sourceType: 'webhook',\n   516→        sourceId: personaId,\n   517→        targetPersonaId: personaId,\n   518→        payload: body,\n   519→      });\n   520→      onEventPublished?.();\n   521→      json(res, 201, event);\n   522→    }, 'webhook:receive', 'webhook'),\n   523→  });\n   524→\n   525→  // --- Executions ---\n   526→  resourceRoutes.set(resourceKey('GET', 'executions', false), {\n   527→    needsDb: true,\n   528→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   529→      const params = new URLSearchParams(queryString || '');\n   530→      const executions = db.listExecutions(tenantDb!, {\n   531→        personaId: params.get('personaId') ?? undefined,\n   532→        status: params.get('status') ?? undefined,\n   533→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   534→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   535→        projectId: scopedProjectId,\n   536→      });\n   537→      json(res, 200, executions);\n   538→    },\n   539→  });\n   540→\n   541→  resourceRoutes.set(resourceKey('POST', 'executions', true, 'cancel'), {\n   542→    handler: (_req, res, _ctx, route) => {\n   543→      handleCancelExecution(res, dispatcher, route!.id!);\n   544→    },\n   545→  });\n   546→\n   547→  resourceRoutes.set(resourceKey('GET', 'executions', true), {\n   548→    handler: (_req, res, _ctx, route, queryString) => {\n   549→      const params = new URLSearchParams(queryString || '');\n   550→      const offset = parseInt(params.get('offset') || '0', 10);\n   551→      handleGetExecution(res, dispatcher, route!.id!, offset);\n   552→    },\n   553→  });\n   554→\n   555→  // ── Request handler ──\n   556→  const server = http.createServer(async (req, res) => {\n   557→    // Request correlation ID\n   558→    const reqId = nanoid();\n   559→    const reqLogger = logger.child({ reqId });\n   560→    res.setHeader('X-Request-Id', reqId);\n   561→\n   562→    // Security headers\n   563→    res.setHeader('X-Content-Type-Options', 'nosniff');\n   564→\n   565→    // CORS headers\n   566→    const origin = req.headers.origin ?? '';\n   567→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n   568→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n   569→    if (isAdminRoute) {\n   570→      if (origin && origin === allowedOrigin) {\n   571→        res.setHeader('Access-Control-Allow-Origin', origin);\n   572→      }\n   573→    } else {\n   574→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n   575→    }\n   576→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n   577→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n   578→\n   579→    if (req.method === 'OPTIONS') {\n   580→      res.writeHead(204);\n   581→      res.end();\n   582→      return;\n   583→    }\n   584→\n   585→    const url = req.url || '/';\n   586→    const [pathname, queryString] = url.split('?');\n   587→    const route = parseRoute(pathname ?? '');\n   588→\n   589→    // Unauthenticated endpoint\n   590→    if (pathname === '/health' && req.method === 'GET') {\n   591→      await handleHealth(res, pool, dispatcher, oauth, getEventProcessorHealth, database, tenantDbManager, kafka, triggerScheduler);\n   592→      return;\n   593→    }\n   594→\n   595→    // Auth check\n   596→    const ctx = auth.validateAndExtractContext(req);\n   597→    if (!ctx) {\n   598→      res.writeHead(401, { 'Content-Type': 'application/json' });\n   599→      res.end(JSON.stringify({ error: 'Unauthorized', reqId }));\n   600→      return;\n   601→    }\n   602→\n   603→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n   604→\n   605→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n   606→      if (tenantDbManager && projectId) {\n   607→        return tenantDbManager.getTenantDb(projectId);\n   608→      }\n   609→      return database;\n   610→    };\n   611→    const tenantDb = resolveDatabase(ctx.projectId);\n   612→\n   613→    try {\n   614→      // O(1) exact-path lookup\n   615→      const exactEntry = exactRoutes.get(`${req.method}:${pathname}`);\n   616→      if (exactEntry) {\n   617→        if (exactEntry.adminOnly && requireAdmin(ctx, res)) return;\n   618→        if (exactEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   619→        await exactEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   620→        return;\n   621→      }\n   622→\n   623→      // O(1) resource-route lookup\n   624→      if (route) {\n   625→        const resKey = resourceKey(req.method!, route.resource, !!route.id, route.subResource);\n   626→        const resEntry = resourceRoutes.get(resKey);\n   627→        if (resEntry) {\n   628→          if (resEntry.adminOnly && requireAdmin(ctx, res)) return;\n   629→          if (resEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   630→          await resEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   631→          return;\n   632→        }\n   633→      }\n   634→\n   635→      // No matching route\n   636→      json(res, 404, { error: 'Not found', reqId });\n   637→    } catch (err) {\n   638→      if (err instanceof Error && err.message === 'Payload too large') {\n   639→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   640→        res.end(JSON.stringify({ error: 'Payload too large', reqId }));\n   641→        return;\n   642→      }\n   643→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   644→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   645→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists', reqId }));\n   646→        return;\n   647→      }\n   648→      reqLogger.error({ err, url }, 'HTTP handler error');\n   649→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   650→      res.end(JSON.stringify({ error: 'Internal server error', reqId }));\n   651→    }\n   652→  });\n   653→\n   654→  return server;\n   655→}\n   656→\n   657→/**\n   658→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   659→ * Returns the entity on success, or null after sending a 404 response.\n   660→ */\n   661→function withScopedEntity<T extends { projectId?: string | null }>(\n   662→  entity: T | undefined,\n   663→  scopedProjectId: string | undefined,\n   664→  res: http.ServerResponse,\n   665→): T | null {\n   666→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   667→    json(res, 404, { error: 'Not found' });\n   668→    return null;\n   669→  }\n   670→  return entity;\n   671→}\n   672→\n   673→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   674→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   675→  if (ctx.authType !== 'admin') {\n   676→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   677→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   678→    return true;\n   679→  }\n   680→  return false;\n   681→}\n   682→\n   683→// --- Existing handlers ---\n   684→\n   685→/** Heartbeat age (ms) beyond which a worker is considered stale. */\n   686→const STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n   687→\n   688→async function handleHealth(\n   689→  res: http.ServerResponse,\n   690→  pool: WorkerPool,\n   691→  dispatcher: Dispatcher,\n   692→  oauth: OAuthManager,\n   693→  getEventProcessorHealth?: () => EventProcessorHealth,\n   694→  database?: Database.Database,\n   695→  tenantDbManager?: TenantDbManager,\n   696→  kafka?: KafkaClient,\n   697→  triggerScheduler?: TriggerSchedulerHandle,\n   698→): Promise<void> {\n   699→  const issues: string[] = [];\n   700→\n   701→  const counts = pool.getWorkerCount();\n   702→  const workers = pool.getWorkers();\n   703→  const now = Date.now();\n   704→  const staleWorkers = workers\n   705→    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n   706→    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n   707→\n   708→  if (staleWorkers.length > 0) {\n   709→    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n   710→  }\n   711→\n   712→  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n   713→  if (database) {\n   714→    try {\n   715→      database.prepare('SELECT 1').get();\n   716→      dbHealth.status = 'ok';\n   717→    } catch {\n   718→      dbHealth.status = 'error';\n   719→      issues.push('database unreachable');\n   720→    }\n   721→  }\n   722→  if (tenantDbManager) {\n   723→    try {\n   724→      const tenantIds = tenantDbManager.listTenantIds();\n   725→      dbHealth.tenantCount = tenantIds.length;\n   726→      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n   727→    } catch {\n   728→      dbHealth.tenantCount = -1;\n   729→      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n   730→      issues.push('tenant DB listing failed');\n   731→    }\n   732→  }\n   733→\n   734→  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n   735→  if (kafka) {\n   736→    const kh = await kafka.checkHealth();\n   737→    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n   738→    if (kh.status === 'error') {\n   739→      issues.push(`kafka: ${kh.detail || 'error'}`);\n   740→    }\n   741→  }\n   742→\n   743→  const queueDepth = dispatcher.getQueueLength();\n   744→  const activeExecutions = dispatcher.getActiveExecutions().length;\n   745→\n   746→  let eventProcessorHealth: EventProcessorHealth | undefined;\n   747→  if (getEventProcessorHealth) {\n   748→    eventProcessorHealth = getEventProcessorHealth();\n   749→  }\n   750→\n   751→  let verdict: 'healthy' | 'degraded' | 'unhealthy';\n   752→  if (issues.some(i => i.includes('database unreachable') || i.includes('kafka: '))) {\n   753→    verdict = 'unhealthy';\n   754→  } else if (issues.length > 0) {\n   755→    verdict = 'degraded';\n   756→  } else {\n   757→    verdict = 'healthy';\n   758→  }\n   759→\n   760→  const body: Record<string, unknown> = {\n   761→    status: verdict,\n   762→    timestamp: Date.now(),\n   763→    dependencies: {\n   764→      database: dbHealth,\n   765→      kafka: kafkaHealth,\n   766→      workers: {\n   767→        ...counts,\n   768→        staleWorkers: staleWorkers.length > 0 ? staleWorkers : undefined,\n   769→      },\n   770→    },\n   771→    queue: {\n   772→      depth: queueDepth,\n   773→      activeExecutions,\n   774→    },\n   775→    hasSubscription: oauth.hasTokens(),\n   776→  };\n   777→\n   778→  if (eventProcessorHealth) {\n   779→    (body.dependencies as Record<string, unknown>).eventProcessor = eventProcessorHealth;\n   780→  }\n   781→\n   782→  if (triggerScheduler) {\n   783→    (body as Record<string, unknown>).scheduler = triggerScheduler.getMetrics();\n   784→  }\n   785→\n   786→  if (issues.length > 0) {\n   787→    body.issues = issues;\n   788→  }\n   789→\n   790→  const httpStatus = verdict === 'unhealthy' ? 503 : 200;\n   791→  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n   792→  res.end(JSON.stringify(body));\n   793→}\n   794→\n   795→function handleStatus(\n   796→  res: http.ServerResponse,\n   797→  pool: WorkerPool,\n   798→  dispatcher: Dispatcher,\n   799→  tokenManager: TokenManager,\n   800→  oauth: OAuthManager,\n   801→): void {\n   802→  const oauthTokens = oauth.getTokens();\n   803→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   804→  res.end(JSON.stringify({\n   805→    workers: pool.getWorkers(),\n   806→    workerCounts: pool.getWorkerCount(),\n   807→    workerPoolMetrics: pool.getMetrics(),\n   808→    queueLength: dispatcher.getQueueLength(),\n   809→    activeExecutions: dispatcher.getActiveExecutions(),\n   810→    hasClaudeToken: tokenManager.hasToken(),\n   811→    oauth: {\n   812→      connected: oauth.hasTokens(),\n   813→      scopes: oauthTokens?.scopes || [],\n   814→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   815→    },\n   816→  }));\n   817→}\n   818→\n   819→async function handleExecute(\n   820→  req: http.IncomingMessage,\n   821→  res: http.ServerResponse,\n   822→  dispatcher: Dispatcher,\n   823→  logger: Logger,\n   824→  ctx?: RequestContext,\n   825→): Promise<void> {\n   826→  const body = await readBody(req);\n   827→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   828→\n   829→  try {\n   830→    parsed = JSON.parse(body);\n   831→  } catch {\n   832→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   833→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   834→    return;\n   835→  }\n   836→\n   837→  if (!parsed.prompt) {\n   838→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   839→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   840→    return;\n   841→  }\n   842→\n   843→  const request: ExecRequest = {\n   844→    executionId: nanoid(),\n   845→    personaId: parsed.personaId || 'manual',\n   846→    prompt: parsed.prompt,\n   847→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   848→    config: {\n   849→      timeoutMs: parsed.timeoutMs || 300_000,\n   850→    },\n   851→  };\n   852→\n   853→  dispatcher.submit(request);\n   854→\n   855→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   856→\n   857→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   858→  res.end(JSON.stringify({\n   859→    executionId: request.executionId,\n   860→    status: 'queued',\n   861→  }));\n   862→}\n   863→\n   864→function handleGetExecution(\n   865→  res: http.ServerResponse,\n   866→  dispatcher: Dispatcher,\n   867→  executionId: string,\n   868→  offset: number = 0,\n   869→): void {\n   870→  const exec = dispatcher.getExecution(executionId);\n   871→\n   872→  if (!exec) {\n   873→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   874→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   875→    return;\n   876→  }\n   877→\n   878→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   879→\n   880→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   881→  res.end(JSON.stringify({\n   882→    executionId,\n   883→    status: exec.status,\n   884→    outputLines: exec.output.length,\n   885→    output,\n   886→    durationMs: exec.durationMs,\n   887→    sessionId: exec.sessionId,\n   888→    totalCostUsd: exec.totalCostUsd,\n   889→    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n   890→  }));\n   891→}\n   892→\n   893→function handleCancelExecution(\n   894→  res: http.ServerResponse,\n   895→  dispatcher: Dispatcher,\n   896→  executionId: string,\n   897→): void {\n   898→  const cancelled = dispatcher.cancelExecution(executionId);\n   899→\n   900→  if (!cancelled) {\n   901→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   902→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   903→    return;\n   904→  }\n   905→\n   906→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   907→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   908→}\n   909→\n   910→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB\n   911→const MAX_QUERY_LIMIT = 500;\n   912→const MAX_QUERY_OFFSET = 100_000;\n   913→\n   914→/** Parse an integer query param and clamp it to safe bounds. */\n   915→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   916→  if (!value) return defaultValue;\n   917→  const parsed = parseInt(value, 10);\n   918→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   919→  return Math.min(parsed, max);\n   920→}\n   921→"}]},"parent_tool_use_id":"toolu_01TTNuZaKLtbV566JuRfX3m3","session_id":"2f4f2ce6-4bd2-4ba0-af5f-a82e0e15723d","uuid":"d1659d59-8e36-4560-87c6-6e465bb91ebc","timestamp":"2026-03-18T18:34:28.270Z"}
[2026-03-18T18:34:28.500Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ESP1epU69myZq7MDoYgX7w","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import { stmt } from './_helpers.js';\n     4→\n     5→// ---------------------------------------------------------------------------\n     6→// System schema (tenant registry)\n     7→// ---------------------------------------------------------------------------\n     8→\n     9→const SYSTEM_SCHEMA = `\n    10→CREATE TABLE IF NOT EXISTS tenants (\n    11→  id TEXT PRIMARY KEY,\n    12→  name TEXT,\n    13→  created_at TEXT NOT NULL\n    14→);\n    15→\n    16→CREATE TABLE IF NOT EXISTS system_daily_metrics (\n    17→  date TEXT NOT NULL,\n    18→  total_executions INTEGER DEFAULT 0,\n    19→  completed INTEGER DEFAULT 0,\n    20→  failed INTEGER DEFAULT 0,\n    21→  total_cost_usd REAL DEFAULT 0,\n    22→  total_duration_ms INTEGER DEFAULT 0,\n    23→  tenant_count INTEGER DEFAULT 0,\n    24→  aggregated_at TEXT NOT NULL,\n    25→  PRIMARY KEY (date)\n    26→);\n    27→\n    28→CREATE TABLE IF NOT EXISTS system_kv (\n    29→  key TEXT PRIMARY KEY,\n    30→  value TEXT NOT NULL\n    31→);\n    32→`;\n    33→\n    34→const INFERENCE_PROFILES_TABLE = `\n    35→CREATE TABLE IF NOT EXISTS inference_profiles (\n    36→  id TEXT PRIMARY KEY,\n    37→  project_id TEXT NOT NULL DEFAULT 'default',\n    38→  name TEXT NOT NULL,\n    39→  provider TEXT NOT NULL,\n    40→  model TEXT,\n    41→  base_url TEXT,\n    42→  auth_token_encrypted TEXT,\n    43→  auth_token_iv TEXT,\n    44→  auth_token_tag TEXT,\n    45→  env_mappings TEXT NOT NULL DEFAULT '[]',\n    46→  remove_env_keys TEXT NOT NULL DEFAULT '[]',\n    47→  is_preset INTEGER NOT NULL DEFAULT 0,\n    48→  created_at TEXT NOT NULL,\n    49→  updated_at TEXT NOT NULL\n    50→);\n    51→`;\n    52→\n    53→const DAILY_METRICS_TABLE = `\n    54→CREATE TABLE IF NOT EXISTS daily_metrics (\n    55→  date TEXT NOT NULL,\n    56→  total_executions INTEGER DEFAULT 0,\n    57→  completed INTEGER DEFAULT 0,\n    58→  failed INTEGER DEFAULT 0,\n    59→  total_cost_usd REAL DEFAULT 0,\n    60→  total_duration_ms INTEGER DEFAULT 0,\n    61→  PRIMARY KEY (date)\n    62→);\n    63→\n    64→CREATE TABLE IF NOT EXISTS retention_watermark (\n    65→  key TEXT PRIMARY KEY DEFAULT 'executions',\n    66→  last_rowid INTEGER NOT NULL DEFAULT 0\n    67→);\n    68→`;\n    69→\n    70→// ---------------------------------------------------------------------------\n    71→// Shared entity tables (used by both legacy single-db and per-tenant dbs)\n    72→// ---------------------------------------------------------------------------\n    73→\n    74→const SHARED_TABLES = `\n    75→CREATE TABLE IF NOT EXISTS personas (\n    76→  id TEXT PRIMARY KEY,\n    77→  project_id TEXT NOT NULL DEFAULT 'default',\n    78→  name TEXT NOT NULL,\n    79→  description TEXT,\n    80→  system_prompt TEXT NOT NULL DEFAULT '',\n    81→  structured_prompt TEXT,\n    82→  icon TEXT,\n    83→  color TEXT,\n    84→  enabled INTEGER NOT NULL DEFAULT 1,\n    85→  max_concurrent INTEGER NOT NULL DEFAULT 1,\n    86→  timeout_ms INTEGER NOT NULL DEFAULT 300000,\n    87→  inference_profile_id TEXT,\n    88→  network_policy TEXT,\n    89→  max_budget_usd REAL,\n    90→  max_turns INTEGER,\n    91→  design_context TEXT,\n    92→  group_id TEXT,\n    93→  created_at TEXT NOT NULL,\n    94→  updated_at TEXT NOT NULL\n    95→);\n    96→\n    97→CREATE TABLE IF NOT EXISTS persona_tool_definitions (\n    98→  id TEXT PRIMARY KEY,\n    99→  name TEXT NOT NULL UNIQUE,\n   100→  category TEXT NOT NULL,\n   101→  description TEXT NOT NULL,\n   102→  script_path TEXT NOT NULL DEFAULT '',\n   103→  input_schema TEXT,\n   104→  output_schema TEXT,\n   105→  requires_credential_type TEXT,\n   106→  implementation_guide TEXT,\n   107→  is_builtin INTEGER NOT NULL DEFAULT 0,\n   108→  created_at TEXT NOT NULL,\n   109→  updated_at TEXT NOT NULL\n   110→);\n   111→\n   112→CREATE TABLE IF NOT EXISTS persona_tools (\n   113→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   114→  tool_id TEXT NOT NULL REFERENCES persona_tool_definitions(id) ON DELETE CASCADE,\n   115→  PRIMARY KEY (persona_id, tool_id)\n   116→);\n   117→\n   118→CREATE TABLE IF NOT EXISTS persona_credentials (\n   119→  id TEXT PRIMARY KEY,\n   120→  project_id TEXT NOT NULL DEFAULT 'default',\n   121→  name TEXT NOT NULL,\n   122→  service_type TEXT NOT NULL,\n   123→  encrypted_data TEXT NOT NULL,\n   124→  iv TEXT NOT NULL,\n   125→  tag TEXT NOT NULL,\n   126→  metadata TEXT,\n   127→  last_used_at TEXT,\n   128→  created_at TEXT NOT NULL,\n   129→  updated_at TEXT NOT NULL\n   130→);\n   131→\n   132→CREATE TABLE IF NOT EXISTS persona_credential_links (\n   133→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   134→  credential_id TEXT NOT NULL REFERENCES persona_credentials(id) ON DELETE CASCADE,\n   135→  PRIMARY KEY (persona_id, credential_id)\n   136→);\n   137→\n   138→CREATE TABLE IF NOT EXISTS persona_events (\n   139→  id TEXT PRIMARY KEY,\n   140→  project_id TEXT NOT NULL DEFAULT 'default',\n   141→  event_type TEXT NOT NULL,\n   142→  source_type TEXT NOT NULL,\n   143→  source_id TEXT,\n   144→  target_persona_id TEXT,\n   145→  payload TEXT,\n   146→  status TEXT NOT NULL DEFAULT 'pending' CHECK(status IN ('pending','processing','delivered','skipped','failed','partial','partial-retry')),\n   147→  error_message TEXT,\n   148→  processed_at TEXT,\n   149→  use_case_id TEXT,\n   150→  retry_after TEXT,\n   151→  retry_count INTEGER NOT NULL DEFAULT 0,\n   152→  created_at TEXT NOT NULL\n   153→);\n   154→CREATE INDEX IF NOT EXISTS idx_pe_status ON persona_events(status);\n   155→CREATE INDEX IF NOT EXISTS idx_pe_created_status ON persona_events(created_at, status);\n   156→\n   157→CREATE TABLE IF NOT EXISTS persona_event_subscriptions (\n   158→  id TEXT PRIMARY KEY,\n   159→  project_id TEXT NOT NULL DEFAULT 'default',\n   160→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   161→  event_type TEXT NOT NULL,\n   162→  source_filter TEXT,\n   163→  enabled INTEGER NOT NULL DEFAULT 1,\n   164→  use_case_id TEXT,\n   165→  created_at TEXT NOT NULL,\n   166→  updated_at TEXT NOT NULL\n   167→);\n   168→CREATE INDEX IF NOT EXISTS idx_pes_event_type ON persona_event_subscriptions(event_type, enabled);\n   169→\n   170→CREATE TABLE IF NOT EXISTS persona_triggers (\n   171→  id TEXT PRIMARY KEY,\n   172→  project_id TEXT NOT NULL DEFAULT 'default',\n   173→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   174→  trigger_type TEXT NOT NULL CHECK(trigger_type IN ('manual','schedule','polling','webhook','chain')),\n   175→  config TEXT,\n   176→  enabled INTEGER NOT NULL DEFAULT 1,\n   177→  last_triggered_at TEXT,\n   178→  next_trigger_at TEXT,\n   179→  use_case_id TEXT,\n   180→  created_at TEXT NOT NULL,\n   181→  updated_at TEXT NOT NULL\n   182→);\n   183→CREATE INDEX IF NOT EXISTS idx_pt_due ON persona_triggers(enabled, next_trigger_at);\n   184→\n   185→CREATE TABLE IF NOT EXISTS persona_executions (\n   186→  id TEXT PRIMARY KEY,\n   187→  project_id TEXT NOT NULL DEFAULT 'default',\n   188→  persona_id TEXT NOT NULL,\n   189→  trigger_id TEXT,\n   190→  use_case_id TEXT,\n   191→  event_id TEXT,\n   192→  status TEXT NOT NULL DEFAULT 'queued' CHECK(status IN ('queued','running','completed','failed','cancelled')),\n   193→  input_data TEXT,\n   194→  output_data TEXT,\n   195→  claude_session_id TEXT,\n   196→  model_used TEXT,\n   197→  input_tokens INTEGER DEFAULT 0,\n   198→  output_tokens INTEGER DEFAULT 0,\n   199→  cost_usd REAL DEFAULT 0,\n   200→  error_message TEXT,\n   201→  duration_ms INTEGER,\n   202→  retry_of_execution_id TEXT,\n   203→  retry_count INTEGER DEFAULT 0,\n   204→  started_at TEXT,\n   205→  completed_at TEXT,\n   206→  created_at TEXT NOT NULL\n   207→);\n   208→CREATE INDEX IF NOT EXISTS idx_pex_persona ON persona_executions(persona_id);\n   209→CREATE INDEX IF NOT EXISTS idx_pex_status ON persona_executions(status);\n   210→CREATE INDEX IF NOT EXISTS idx_pex_created_status ON persona_executions(created_at, status);\n   211→\n   212→${DAILY_METRICS_TABLE}\n   213→\n   214→${INFERENCE_PROFILES_TABLE}\n   215→`;\n   216→\n   217→// ---------------------------------------------------------------------------\n   218→// Migrations (legacy single-db)\n   219→// ---------------------------------------------------------------------------\n   220→\n   221→function runLegacyMigrations(db: Database.Database, logger: Logger): void {\n   222→  const tablesToMigrate = [\n   223→    'persona_credentials',\n   224→    'persona_event_subscriptions',\n   225→    'persona_triggers',\n   226→    'persona_executions',\n   227→  ];\n   228→\n   229→  for (const table of tablesToMigrate) {\n   230→    const columns = stmt(db,`PRAGMA table_info(${table})`).all() as Array<{ name: string }>;\n   231→    const hasProjectId = columns.some(c => c.name === 'project_id');\n   232→    if (!hasProjectId) {\n   233→      db.exec(`ALTER TABLE ${table} ADD COLUMN project_id TEXT NOT NULL DEFAULT 'default'`);\n   234→      logger.info({ table }, 'Migration: added project_id column');\n   235→    }\n   236→  }\n   237→\n   238→  db.exec(`\n   239→    CREATE INDEX IF NOT EXISTS idx_personas_project ON personas(project_id);\n   240→    CREATE INDEX IF NOT EXISTS idx_pe_project ON persona_events(project_id);\n   241→    CREATE INDEX IF NOT EXISTS idx_pcred_project ON persona_credentials(project_id);\n   242→    CREATE INDEX IF NOT EXISTS idx_pes_project ON persona_event_subscriptions(project_id);\n   243→    CREATE INDEX IF NOT EXISTS idx_pes_event_type ON persona_event_subscriptions(event_type, enabled);\n   244→    CREATE INDEX IF NOT EXISTS idx_pt_project ON persona_triggers(project_id);\n   245→    DROP INDEX IF EXISTS idx_pt_next_trigger;\n   246→    CREATE INDEX IF NOT EXISTS idx_pt_due ON persona_triggers(enabled, next_trigger_at);\n   247→    CREATE INDEX IF NOT EXISTS idx_pex_project ON persona_executions(project_id);\n   248→  `);\n   249→\n   250→  // Add inference_profile_id to personas if missing\n   251→  const personaCols = stmt(db,'PRAGMA table_info(personas)').all() as Array<{ name: string }>;\n   252→  if (!personaCols.some(c => c.name === 'inference_profile_id')) {\n   253→    db.exec('ALTER TABLE personas ADD COLUMN inference_profile_id TEXT');\n   254→    logger.info('Migration: added inference_profile_id to personas');\n   255→  }\n   256→  if (!personaCols.some(c => c.name === 'network_policy')) {\n   257→    db.exec('ALTER TABLE personas ADD COLUMN network_policy TEXT');\n   258→    logger.info('Migration: added network_policy to personas');\n   259→  }\n   260→\n   261→  // Create inference_profiles table if missing\n   262→  db.exec(INFERENCE_PROFILES_TABLE);\n   263→\n   264→  // Add retry_after and retry_count to persona_events if missing\n   265→  const eventCols = stmt(db,'PRAGMA table_info(persona_events)').all() as Array<{ name: string }>;\n   266→  if (!eventCols.some(c => c.name === 'retry_after')) {\n   267→    db.exec('ALTER TABLE persona_events ADD COLUMN retry_after TEXT');\n   268→    logger.info('Migration: added retry_after to persona_events');\n   269→  }\n   270→  if (!eventCols.some(c => c.name === 'retry_count')) {\n   271→    db.exec('ALTER TABLE persona_events ADD COLUMN retry_count INTEGER NOT NULL DEFAULT 0');\n   272→    logger.info('Migration: added retry_count to persona_events');\n   273→  }\n   274→\n   275→  // Add event_id to persona_executions for event↔execution correlation tracing\n   276→  const execCols = stmt(db,'PRAGMA table_info(persona_executions)').all() as Array<{ name: string }>;\n   277→  if (!execCols.some(c => c.name === 'event_id')) {\n   278→    db.exec('ALTER TABLE persona_executions ADD COLUMN event_id TEXT');\n   279→    logger.info('Migration: added event_id to persona_executions');\n   280→  }\n   281→}\n   282→\n   283→// ---------------------------------------------------------------------------\n   284→// Initialization\n   285→// ---------------------------------------------------------------------------\n   286→\n   287→/** Legacy: initialize a single monolithic database (used by migration script). */\n   288→export function initDb(dbPath: string, logger: Logger): Database.Database {\n   289→  const db = new Database(dbPath);\n   290→  db.pragma('journal_mode = WAL');\n   291→  db.pragma('foreign_keys = ON');\n   292→\n   293→  db.exec(SHARED_TABLES);\n   294→  runLegacyMigrations(db, logger);\n   295→  logger.info({ dbPath }, 'Database initialized (legacy single-db)');\n   296→  return db;\n   297→}\n   298→\n   299→/** Initialize the system-level database (tenant registry). */\n   300→export function initSystemDb(dbPath: string, logger: Logger): Database.Database {\n   301→  const db = new Database(dbPath);\n   302→  db.pragma('journal_mode = WAL');\n   303→  db.pragma('foreign_keys = ON');\n   304→\n   305→  db.exec(SYSTEM_SCHEMA);\n   306→  logger.info({ dbPath }, 'System database initialized');\n   307→  return db;\n   308→}\n   309→\n   310→/** Initialize a per-tenant database. */\n   311→export function initTenantDb(dbPath: string, logger: Logger): Database.Database {\n   312→  const db = new Database(dbPath);\n   313→  db.pragma('journal_mode = WAL');\n   314→  db.pragma('foreign_keys = ON');\n   315→\n   316→  db.exec(SHARED_TABLES);\n   317→  runTenantMigrations(db, logger);\n   318→  logger.info({ dbPath }, 'Tenant database initialized');\n   319→  return db;\n   320→}\n   321→\n   322→/** Migrations applied to per-tenant databases. */\n   323→function runTenantMigrations(db: Database.Database, logger: Logger): void {\n   324→  const eventCols = stmt(db,'PRAGMA table_info(persona_events)').all() as Array<{ name: string }>;\n   325→  if (!eventCols.some(c => c.name === 'retry_after')) {\n   326→    db.exec('ALTER TABLE persona_events ADD COLUMN retry_after TEXT');\n   327→    logger.info('Tenant migration: added retry_after to persona_events');\n   328→  }\n   329→  if (!eventCols.some(c => c.name === 'retry_count')) {\n   330→    db.exec('ALTER TABLE persona_events ADD COLUMN retry_count INTEGER NOT NULL DEFAULT 0');\n   331→    logger.info('Tenant migration: added retry_count to persona_events');\n   332→  }\n   333→\n   334→  // Add event_id to persona_executions for event↔execution correlation tracing\n   335→  const execCols = stmt(db,'PRAGMA table_info(persona_executions)').all() as Array<{ name: string }>;\n   336→  if (!execCols.some(c => c.name === 'event_id')) {\n   337→    db.exec('ALTER TABLE persona_executions ADD COLUMN event_id TEXT');\n   338→    logger.info('Tenant migration: added event_id to persona_executions');\n   339→  }\n   340→}\n   341→"}]},"parent_tool_use_id":"toolu_01TTNuZaKLtbV566JuRfX3m3","session_id":"2f4f2ce6-4bd2-4ba0-af5f-a82e0e15723d","uuid":"03d72fac-ec77-4d1b-8bbf-489b3a671076","timestamp":"2026-03-18T18:34:28.265Z"}
