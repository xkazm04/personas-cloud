[2026-03-18T18:15:18.273Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WZYcrpnYVR7TwYn53NWUFT","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import type { KafkaClient } from './kafka.js';\n    11→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    12→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    13→import type { TriggerSchedulerHandle } from './triggerScheduler.js';\n    14→import type { TenantDbManager } from './tenantDbManager.js';\n    15→import type { TenantKeyManager } from './tenantKeyManager.js';\n    16→import type { AuditLog, AuditEntry, AuditAction } from './auditLog.js';\n    17→import type { EventProcessorHealth } from './eventProcessor.js';\n    18→import type { Logger } from 'pino';\n    19→import * as db from './db/index.js';\n    20→import { readBody, json } from './httpUtils.js';\n    21→\n    22→// --- Route types ---\n    23→\n    24→interface ParsedRoute {\n    25→  resource: string;\n    26→  id?: string;\n    27→  subResource?: string;\n    28→}\n    29→\n    30→type RouteHandler = (\n    31→  req: http.IncomingMessage,\n    32→  res: http.ServerResponse,\n    33→  ctx: RequestContext,\n    34→  route: ParsedRoute | null,\n    35→  queryString: string | undefined,\n    36→  tenantDb: Database.Database | undefined,\n    37→  scopedProjectId: string | undefined,\n    38→  reqLogger: Logger,\n    39→) => Promise<void> | void;\n    40→\n    41→interface RouteEntry {\n    42→  handler: RouteHandler;\n    43→  needsDb?: boolean;\n    44→  adminOnly?: boolean;\n    45→}\n    46→\n    47→/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\n    48→function resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n    49→  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n    50→}\n    51→\n    52→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n    53→function parseRoute(pathname: string): ParsedRoute | null {\n    54→  if (!pathname.startsWith('/api/')) return null;\n    55→  const segments = pathname.slice(5).split('/').filter(Boolean);\n    56→  if (segments.length === 0) return null;\n    57→  return {\n    58→    resource: segments[0]!,\n    59→    id: segments[1],\n    60→    subResource: segments[2],\n    61→  };\n    62→}\n    63→\n    64→export function createHttpApi(\n    65→  auth: Auth,\n    66→  dispatcher: Dispatcher,\n    67→  pool: WorkerPool,\n    68→  tokenManager: TokenManager,\n    69→  oauth: OAuthManager,\n    70→  logger: Logger,\n    71→  database?: Database.Database,\n    72→  tenantDbManager?: TenantDbManager,\n    73→  tenantKeyManager?: TenantKeyManager,\n    74→  auditLog?: AuditLog,\n    75→  getEventProcessorHealth?: () => EventProcessorHealth,\n    76→  kafka?: KafkaClient,\n    77→  onEventPublished?: () => void,\n    78→  triggerScheduler?: TriggerSchedulerHandle,\n    79→): http.Server {\n    80→\n    81→  /** Wrap a mutation handler to emit an audit event on successful response. */\n    82→  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    83→    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n    84→      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n    85→      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n    86→        try {\n    87→          auditLog.record({\n    88→            action,\n    89→            tenantId: ctx.projectId || 'default',\n    90→            actor: ctx.userEmail || ctx.projectId,\n    91→            resourceType,\n    92→            resourceId: route?.id,\n    93→            ipAddress: req.socket.remoteAddress,\n    94→          } as AuditEntry);\n    95→        } catch { /* logged inside record() */ }\n    96→      }\n    97→    };\n    98→  }\n    99→\n   100→  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n   101→  const exactRoutes = new Map<string, RouteEntry>();\n   102→\n   103→  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n   104→  for (const [path, method] of [\n   105→    ['/api/oauth/authorize', 'POST'],\n   106→    ['/api/oauth/callback', 'POST'],\n   107→    ['/api/oauth/status', 'GET'],\n   108→    ['/api/oauth/refresh', 'POST'],\n   109→    ['/api/oauth/disconnect', 'DELETE'],\n   110→    ['/api/token', 'POST'],\n   111→  ] as const) {\n   112→    exactRoutes.set(`${method}:${path}`, {\n   113→      adminOnly: true,\n   114→      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   115→        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger);\n   116→      },\n   117→    });\n   118→  }\n   119→\n   120→  exactRoutes.set('GET:/api/status', {\n   121→    handler: (_req, res) => {\n   122→      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   123→    },\n   124→  });\n   125→\n   126→  exactRoutes.set('POST:/api/execute', {\n   127→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   128→      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n   129→    }, 'execution:submit', 'execution'),\n   130→  });\n   131→\n   132→  exactRoutes.set('POST:/api/gitlab/webhook', {\n   133→    needsDb: true,\n   134→    handler: withHttpAudit(async (req, res, _ctx, _route, _qs, tenantDb) => {\n   135→      const body = await readBody(req);\n   136→      let parsed: Record<string, unknown> = {};\n   137→      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   138→      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   139→      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   140→      const event = db.publishEvent(tenantDb!, {\n   141→        eventType: `gitlab_${objectKind}`,\n   142→        sourceType: 'gitlab',\n   143→        sourceId: projectPath ?? null,\n   144→        payload: body,\n   145→      });\n   146→      onEventPublished?.();\n   147→      json(res, 201, event);\n   148→    }, 'event:publish', 'event'),\n   149→  });\n   150→\n   151→  // Admin routes\n   152→  exactRoutes.set('GET:/api/admin/users', {\n   153→    adminOnly: true,\n   154→    handler: (_req, res) => {\n   155→      if (tenantDbManager) {\n   156→        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   157→      } else if (database) {\n   158→        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   159→      } else {\n   160→        json(res, 200, { projectIds: [] });\n   161→      }\n   162→    },\n   163→  });\n   164→\n   165→  exactRoutes.set('GET:/api/admin/personas', {\n   166→    adminOnly: true,\n   167→    handler: (_req, res) => {\n   168→      if (tenantDbManager) {\n   169→        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   170→        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   171→        json(res, 200, allPersonas);\n   172→      } else if (database) {\n   173→        json(res, 200, db.listPersonasSummary(database));\n   174→      } else {\n   175→        json(res, 200, []);\n   176→      }\n   177→    },\n   178→  });\n   179→\n   180→  exactRoutes.set('GET:/api/admin/executions', {\n   181→    adminOnly: true,\n   182→    handler: (_req, res, _ctx, _route, queryString) => {\n   183→      const params = new URLSearchParams(queryString || '');\n   184→      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   185→      if (tenantDbManager) {\n   186→        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   187→        tenantDbManager.forEachTenant((tDb) => {\n   188→          allExecs.push(...db.listExecutions(tDb, { limit }));\n   189→        });\n   190→        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   191→        json(res, 200, allExecs.slice(0, limit));\n   192→      } else if (database) {\n   193→        json(res, 200, db.listExecutions(database, {\n   194→          limit,\n   195→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   196→        }));\n   197→      } else {\n   198→        json(res, 200, []);\n   199→      }\n   200→    },\n   201→  });\n   202→\n   203→  exactRoutes.set('GET:/api/admin/audit', {\n   204→    adminOnly: true,\n   205→    handler: (_req, res, _ctx, _route, queryString) => {\n   206→      if (!auditLog) { json(res, 200, []); return; }\n   207→      const params = new URLSearchParams(queryString || '');\n   208→      json(res, 200, auditLog.query({\n   209→        tenantId: params.get('tenantId') ?? undefined,\n   210→        action: (params.get('action') ?? undefined) as AuditAction | undefined,\n   211→        since: params.get('since') ?? undefined,\n   212→        limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   213→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   214→      }));\n   215→    },\n   216→  });\n   217→\n   218→  // ── Resource route table (O(1) lookup by `METHOD:resource[:id][:sub]`) ──\n   219→  const resourceRoutes = new Map<string, RouteEntry>();\n   220→\n   221→  // --- Persona CRUD ---\n   222→  resourceRoutes.set(resourceKey('GET', 'personas', false), {\n   223→    needsDb: true,\n   224→    handler: (_req, res, _ctx, _route, _qs, tenantDb, scopedProjectId) => {\n   225→      json(res, 200, db.listPersonasSummary(tenantDb!, scopedProjectId));\n   226→    },\n   227→  });\n   228→\n   229→  resourceRoutes.set(resourceKey('POST', 'personas', false), {\n   230→    needsDb: true,\n   231→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   232→      const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   233→      const persona = createPersonaWithDefaults({\n   234→        ...body,\n   235→        projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   236→      });\n   237→      db.upsertPersona(tenantDb!, persona);\n   238→      try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: persona.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   239→      reqLogger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   240→      json(res, 201, persona);\n   241→    },\n   242→  });\n   243→\n   244→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'tools'), {\n   245→    needsDb: true,\n   246→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   247→      json(res, 200, db.getToolsForPersona(tenantDb!, route!.id!));\n   248→    },\n   249→  });\n   250→\n   251→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'tools'), {\n   252→    needsDb: true,\n   253→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   254→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   255→      if (!persona) return;\n   256→      const body = JSON.parse(await readBody(req)) as { toolId: string };\n   257→      db.linkTool(tenantDb!, route!.id!, body.toolId);\n   258→      try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { toolId: body.toolId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   259→      reqLogger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route!.id!, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   260→      json(res, 200, { linked: true });\n   261→    },\n   262→  });\n   263→\n   264→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'full'), {\n   265→    needsDb: true,\n   266→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   267→      const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb!, route!.id!, reqLogger), scopedProjectId, res);\n   268→      if (!hydrated) return;\n   269→      json(res, 200, hydrated);\n   270→    },\n   271→  });\n   272→\n   273→  resourceRoutes.set(resourceKey('GET', 'personas', true), {\n   274→    needsDb: true,\n   275→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId) => {\n   276→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   277→      if (!persona) return;\n   278→      json(res, 200, persona);\n   279→    },\n   280→  });\n   281→\n   282→  resourceRoutes.set(resourceKey('DELETE', 'personas', true), {\n   283→    needsDb: true,\n   284→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   285→      db.deletePersona(tenantDb!, route!.id!, scopedProjectId);\n   286→      try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   287→      reqLogger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   288→      json(res, 200, { deleted: true });\n   289→    },\n   290→  });\n   291→\n   292→  // --- Persona sub-resources: credentials ---\n   293→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'credentials'), {\n   294→    needsDb: true,\n   295→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   296→      const creds = db.listCredentialsForPersona(tenantDb!, route!.id!);\n   297→      try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   298→      json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   299→    },\n   300→  });\n   301→\n   302→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'credentials'), {\n   303→    needsDb: true,\n   304→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   305→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   306→      if (!persona) return;\n   307→      const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   308→      db.linkCredential(tenantDb!, route!.id!, body.credentialId);\n   309→      try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { credentialId: body.credentialId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   310→      reqLogger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route!.id!, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   311→      json(res, 200, { linked: true });\n   312→    },\n   313→  });\n   314→\n   315→  // --- Persona sub-resources: subscriptions ---\n   316→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'subscriptions'), {\n   317→    needsDb: true,\n   318→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   319→      json(res, 200, db.listSubscriptionsForPersona(tenantDb!, route!.id!));\n   320→    },\n   321→  });\n   322→\n   323→  // --- Tool Definitions ---\n   324→  resourceRoutes.set(resourceKey('POST', 'tool-definitions', false), {\n   325→    needsDb: true,\n   326→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   327→      const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   328→      const tool = createToolDefinitionWithDefaults(body);\n   329→      db.upsertToolDefinition(tenantDb!, tool);\n   330→      try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'toolDefinition', resourceId: tool.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   331→      reqLogger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   332→      json(res, 201, tool);\n   333→    },\n   334→  });\n   335→\n   336→  // --- Credentials ---\n   337→  resourceRoutes.set(resourceKey('POST', 'credentials', false), {\n   338→    needsDb: true,\n   339→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   340→      const body = JSON.parse(await readBody(req));\n   341→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   342→\n   343→      if (!body.plaintext || typeof body.plaintext !== 'string') {\n   344→        json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   345→        return;\n   346→      }\n   347→      if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   348→        json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   349→        return;\n   350→      }\n   351→      if (!tenantKeyManager) {\n   352→        json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   353→        return;\n   354→      }\n   355→\n   356→      delete body.encryptedData;\n   357→      delete body.iv;\n   358→      delete body.tag;\n   359→\n   360→      const tenantId = body.projectId || ctx.projectId || 'default';\n   361→      const key = await tenantKeyManager.getKey(tenantId);\n   362→      const encrypted = encrypt(body.plaintext, key);\n   363→      body.encryptedData = encrypted.encrypted;\n   364→      body.iv = encrypted.iv;\n   365→      body.tag = encrypted.tag;\n   366→      delete body.plaintext;\n   367→\n   368→      const cred = db.createCredential(tenantDb!, body);\n   369→      try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: cred.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   370→      reqLogger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   371→      json(res, 201, cred);\n   372→    },\n   373→  });\n   374→\n   375→  resourceRoutes.set(resourceKey('DELETE', 'credentials', true), {\n   376→    needsDb: true,\n   377→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   378→      const changes = db.deleteCredential(tenantDb!, route!.id!, scopedProjectId);\n   379→      if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   380→      try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   381→      reqLogger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   382→      json(res, 200, { deleted: true });\n   383→    },\n   384→  });\n   385→\n   386→  // --- Event Subscriptions ---\n   387→  resourceRoutes.set(resourceKey('POST', 'subscriptions', false), {\n   388→    needsDb: true,\n   389→    handler: async (req, res, ctx, _route, _qs, tenantDb) => {\n   390→      const body = JSON.parse(await readBody(req));\n   391→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   392→      const missing: string[] = [];\n   393→      if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   394→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   395→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   396→      const sub = db.createSubscription(tenantDb!, body);\n   397→      try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: sub.id, detail: { personaId: body.personaId, eventType: body.eventType }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   398→      json(res, 201, sub);\n   399→    },\n   400→  });\n   401→\n   402→  resourceRoutes.set(resourceKey('PUT', 'subscriptions', true), {\n   403→    needsDb: true,\n   404→    handler: async (req, res, ctx, route, _qs, tenantDb) => {\n   405→      const body = JSON.parse(await readBody(req));\n   406→      db.updateSubscription(tenantDb!, route!.id!, body);\n   407→      const updated = db.getSubscription(tenantDb!, route!.id!);\n   408→      try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   409→      json(res, 200, updated);\n   410→    },\n   411→  });\n   412→\n   413→  resourceRoutes.set(resourceKey('DELETE', 'subscriptions', true), {\n   414→    needsDb: true,\n   415→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   416→      db.deleteSubscription(tenantDb!, route!.id!);\n   417→      try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   418→      json(res, 200, { deleted: true });\n   419→    },\n   420→  });\n   421→\n   422→  // --- Triggers (delegated to triggerHttpHandlers) ---\n   423→  const triggerHandler: RouteHandler = async (req, res, ctx, route, _qs, tenantDb) => {\n   424→    await handleTriggerRoute(route!, req.method!, req, res, tenantDb!, ctx, triggerScheduler);\n   425→  };\n   426→  resourceRoutes.set(resourceKey('POST', 'triggers', false), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:create', 'trigger') });\n   427→  resourceRoutes.set(resourceKey('PUT', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:update', 'trigger') });\n   428→  resourceRoutes.set(resourceKey('DELETE', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:delete', 'trigger') });\n   429→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'triggers'), { needsDb: true, handler: triggerHandler });\n   430→\n   431→  // --- Events ---\n   432→  resourceRoutes.set(resourceKey('GET', 'events', false), {\n   433→    needsDb: true,\n   434→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   435→      const params = new URLSearchParams(queryString || '');\n   436→      const events = db.listEvents(tenantDb!, {\n   437→        eventType: params.get('eventType') ?? undefined,\n   438→        status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n   439→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   440→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   441→        projectId: scopedProjectId,\n   442→      });\n   443→      json(res, 200, events);\n   444→    },\n   445→  });\n   446→\n   447→  resourceRoutes.set(resourceKey('POST', 'events', false), {\n   448→    needsDb: true,\n   449→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, tenantDb) => {\n   450→      const body = JSON.parse(await readBody(req));\n   451→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   452→      const missing: string[] = [];\n   453→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   454→      if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   455→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   456→      const event = db.publishEvent(tenantDb!, body);\n   457→      onEventPublished?.();\n   458→      json(res, 201, event);\n   459→    }, 'event:publish', 'event'),\n   460→  });\n   461→\n   462→  resourceRoutes.set(resourceKey('PUT', 'events', true), {\n   463→    needsDb: true,\n   464→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   465→      const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n   466→      const updated = db.updateEventWithMetadata(tenantDb!, route!.id!, body.status, body.metadata);\n   467→      if (updated) {\n   468→        json(res, 200, updated);\n   469→      } else {\n   470→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   471→        res.end(JSON.stringify({ error: 'Event not found' }));\n   472→      }\n   473→    }, 'event:update', 'event'),\n   474→  });\n   475→\n   476→  // --- Webhooks ---\n   477→  resourceRoutes.set(resourceKey('POST', 'webhooks', true), {\n   478→    needsDb: true,\n   479→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   480→      const personaId = route!.id!;\n   481→      const body = await readBody(req);\n   482→      const event = db.publishEvent(tenantDb!, {\n   483→        eventType: 'webhook_received',\n   484→        sourceType: 'webhook',\n   485→        sourceId: personaId,\n   486→        targetPersonaId: personaId,\n   487→        payload: body,\n   488→      });\n   489→      onEventPublished?.();\n   490→      json(res, 201, event);\n   491→    }, 'webhook:receive', 'webhook'),\n   492→  });\n   493→\n   494→  // --- Executions ---\n   495→  resourceRoutes.set(resourceKey('GET', 'executions', false), {\n   496→    needsDb: true,\n   497→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   498→      const params = new URLSearchParams(queryString || '');\n   499→      const executions = db.listExecutions(tenantDb!, {\n   500→        personaId: params.get('personaId') ?? undefined,\n   501→        status: params.get('status') ?? undefined,\n   502→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   503→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   504→        projectId: scopedProjectId,\n   505→      });\n   506→      json(res, 200, executions);\n   507→    },\n   508→  });\n   509→\n   510→  resourceRoutes.set(resourceKey('POST', 'executions', true, 'cancel'), {\n   511→    handler: (_req, res, _ctx, route) => {\n   512→      handleCancelExecution(res, dispatcher, route!.id!);\n   513→    },\n   514→  });\n   515→\n   516→  resourceRoutes.set(resourceKey('GET', 'executions', true), {\n   517→    handler: (_req, res, _ctx, route, queryString) => {\n   518→      const params = new URLSearchParams(queryString || '');\n   519→      const offset = parseInt(params.get('offset') || '0', 10);\n   520→      handleGetExecution(res, dispatcher, route!.id!, offset);\n   521→    },\n   522→  });\n   523→\n   524→  // ── Request handler ──\n   525→  const server = http.createServer(async (req, res) => {\n   526→    // Request correlation ID\n   527→    const reqId = nanoid();\n   528→    const reqLogger = logger.child({ reqId });\n   529→    res.setHeader('X-Request-Id', reqId);\n   530→\n   531→    // Security headers\n   532→    res.setHeader('X-Content-Type-Options', 'nosniff');\n   533→\n   534→    // CORS headers\n   535→    const origin = req.headers.origin ?? '';\n   536→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n   537→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n   538→    if (isAdminRoute) {\n   539→      if (origin && origin === allowedOrigin) {\n   540→        res.setHeader('Access-Control-Allow-Origin', origin);\n   541→      }\n   542→    } else {\n   543→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n   544→    }\n   545→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n   546→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n   547→\n   548→    if (req.method === 'OPTIONS') {\n   549→      res.writeHead(204);\n   550→      res.end();\n   551→      return;\n   552→    }\n   553→\n   554→    const url = req.url || '/';\n   555→    const [pathname, queryString] = url.split('?');\n   556→    const route = parseRoute(pathname ?? '');\n   557→\n   558→    // Unauthenticated endpoint\n   559→    if (pathname === '/health' && req.method === 'GET') {\n   560→      await handleHealth(res, pool, dispatcher, oauth, getEventProcessorHealth, database, tenantDbManager, kafka);\n   561→      return;\n   562→    }\n   563→\n   564→    // Auth check\n   565→    const ctx = auth.validateAndExtractContext(req);\n   566→    if (!ctx) {\n   567→      res.writeHead(401, { 'Content-Type': 'application/json' });\n   568→      res.end(JSON.stringify({ error: 'Unauthorized', reqId }));\n   569→      return;\n   570→    }\n   571→\n   572→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n   573→\n   574→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n   575→      if (tenantDbManager && projectId) {\n   576→        return tenantDbManager.getTenantDb(projectId);\n   577→      }\n   578→      return database;\n   579→    };\n   580→    const tenantDb = resolveDatabase(ctx.projectId);\n   581→\n   582→    try {\n   583→      // O(1) exact-path lookup\n   584→      const exactEntry = exactRoutes.get(`${req.method}:${pathname}`);\n   585→      if (exactEntry) {\n   586→        if (exactEntry.adminOnly && requireAdmin(ctx, res)) return;\n   587→        if (exactEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   588→        await exactEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   589→        return;\n   590→      }\n   591→\n   592→      // O(1) resource-route lookup\n   593→      if (route) {\n   594→        const resKey = resourceKey(req.method!, route.resource, !!route.id, route.subResource);\n   595→        const resEntry = resourceRoutes.get(resKey);\n   596→        if (resEntry) {\n   597→          if (resEntry.adminOnly && requireAdmin(ctx, res)) return;\n   598→          if (resEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   599→          await resEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   600→          return;\n   601→        }\n   602→      }\n   603→\n   604→      // No matching route\n   605→      json(res, 404, { error: 'Not found', reqId });\n   606→    } catch (err) {\n   607→      if (err instanceof Error && err.message === 'Payload too large') {\n   608→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   609→        res.end(JSON.stringify({ error: 'Payload too large', reqId }));\n   610→        return;\n   611→      }\n   612→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   613→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   614→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists', reqId }));\n   615→        return;\n   616→      }\n   617→      reqLogger.error({ err, url }, 'HTTP handler error');\n   618→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   619→      res.end(JSON.stringify({ error: 'Internal server error', reqId }));\n   620→    }\n   621→  });\n   622→\n   623→  return server;\n   624→}\n   625→\n   626→/**\n   627→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   628→ * Returns the entity on success, or null after sending a 404 response.\n   629→ */\n   630→function withScopedEntity<T extends { projectId?: string | null }>(\n   631→  entity: T | undefined,\n   632→  scopedProjectId: string | undefined,\n   633→  res: http.ServerResponse,\n   634→): T | null {\n   635→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   636→    json(res, 404, { error: 'Not found' });\n   637→    return null;\n   638→  }\n   639→  return entity;\n   640→}\n   641→\n   642→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   643→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   644→  if (ctx.authType !== 'admin') {\n   645→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   646→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   647→    return true;\n   648→  }\n   649→  return false;\n   650→}\n   651→\n   652→// --- Existing handlers ---\n   653→\n   654→/** Heartbeat age (ms) beyond which a worker is considered stale. */\n   655→const STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n   656→\n   657→async function handleHealth(\n   658→  res: http.ServerResponse,\n   659→  pool: WorkerPool,\n   660→  dispatcher: Dispatcher,\n   661→  oauth: OAuthManager,\n   662→  getEventProcessorHealth?: () => EventProcessorHealth,\n   663→  database?: Database.Database,\n   664→  tenantDbManager?: TenantDbManager,\n   665→  kafka?: KafkaClient,\n   666→): Promise<void> {\n   667→  const issues: string[] = [];\n   668→\n   669→  const counts = pool.getWorkerCount();\n   670→  const workers = pool.getWorkers();\n   671→  const now = Date.now();\n   672→  const staleWorkers = workers\n   673→    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n   674→    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n   675→\n   676→  if (staleWorkers.length > 0) {\n   677→    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n   678→  }\n   679→\n   680→  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n   681→  if (database) {\n   682→    try {\n   683→      database.prepare('SELECT 1').get();\n   684→      dbHealth.status = 'ok';\n   685→    } catch {\n   686→      dbHealth.status = 'error';\n   687→      issues.push('database unreachable');\n   688→    }\n   689→  }\n   690→  if (tenantDbManager) {\n   691→    try {\n   692→      const tenantIds = tenantDbManager.listTenantIds();\n   693→      dbHealth.tenantCount = tenantIds.length;\n   694→      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n   695→    } catch {\n   696→      dbHealth.tenantCount = -1;\n   697→      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n   698→      issues.push('tenant DB listing failed');\n   699→    }\n   700→  }\n   701→\n   702→  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n   703→  if (kafka) {\n   704→    const kh = await kafka.checkHealth();\n   705→    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n   706→    if (kh.status === 'error') {\n   707→      issues.push(`kafka: ${kh.detail || 'error'}`);\n   708→    }\n   709→  }\n   710→\n   711→  const queueDepth = dispatcher.getQueueLength();\n   712→  const activeExecutions = dispatcher.getActiveExecutions().length;\n   713→\n   714→  let eventProcessorHealth: EventProcessorHealth | undefined;\n   715→  if (getEventProcessorHealth) {\n   716→    eventProcessorHealth = getEventProcessorHealth();\n   717→  }\n   718→\n   719→  let verdict: 'healthy' | 'degraded' | 'unhealthy';\n   720→  if (issues.some(i => i.includes('database unreachable') || i.includes('kafka: '))) {\n   721→    verdict = 'unhealthy';\n   722→  } else if (issues.length > 0) {\n   723→    verdict = 'degraded';\n   724→  } else {\n   725→    verdict = 'healthy';\n   726→  }\n   727→\n   728→  const body: Record<string, unknown> = {\n   729→    status: verdict,\n   730→    timestamp: Date.now(),\n   731→    dependencies: {\n   732→      database: dbHealth,\n   733→      kafka: kafkaHealth,\n   734→      workers: {\n   735→        ...counts,\n   736→        staleWorkers: staleWorkers.length > 0 ? staleWorkers : undefined,\n   737→      },\n   738→    },\n   739→    queue: {\n   740→      depth: queueDepth,\n   741→      activeExecutions,\n   742→    },\n   743→    hasSubscription: oauth.hasTokens(),\n   744→  };\n   745→\n   746→  if (eventProcessorHealth) {\n   747→    (body.dependencies as Record<string, unknown>).eventProcessor = eventProcessorHealth;\n   748→  }\n   749→\n   750→  if (issues.length > 0) {\n   751→    body.issues = issues;\n   752→  }\n   753→\n   754→  const httpStatus = verdict === 'unhealthy' ? 503 : 200;\n   755→  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n   756→  res.end(JSON.stringify(body));\n   757→}\n   758→\n   759→function handleStatus(\n   760→  res: http.ServerResponse,\n   761→  pool: WorkerPool,\n   762→  dispatcher: Dispatcher,\n   763→  tokenManager: TokenManager,\n   764→  oauth: OAuthManager,\n   765→): void {\n   766→  const oauthTokens = oauth.getTokens();\n   767→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   768→  res.end(JSON.stringify({\n   769→    workers: pool.getWorkers(),\n   770→    workerCounts: pool.getWorkerCount(),\n   771→    workerPoolMetrics: pool.getMetrics(),\n   772→    queueLength: dispatcher.getQueueLength(),\n   773→    activeExecutions: dispatcher.getActiveExecutions(),\n   774→    hasClaudeToken: tokenManager.hasToken(),\n   775→    oauth: {\n   776→      connected: oauth.hasTokens(),\n   777→      scopes: oauthTokens?.scopes || [],\n   778→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   779→    },\n   780→  }));\n   781→}\n   782→\n   783→async function handleExecute(\n   784→  req: http.IncomingMessage,\n   785→  res: http.ServerResponse,\n   786→  dispatcher: Dispatcher,\n   787→  logger: Logger,\n   788→  ctx?: RequestContext,\n   789→): Promise<void> {\n   790→  const body = await readBody(req);\n   791→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   792→\n   793→  try {\n   794→    parsed = JSON.parse(body);\n   795→  } catch {\n   796→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   797→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   798→    return;\n   799→  }\n   800→\n   801→  if (!parsed.prompt) {\n   802→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   803→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   804→    return;\n   805→  }\n   806→\n   807→  const request: ExecRequest = {\n   808→    executionId: nanoid(),\n   809→    personaId: parsed.personaId || 'manual',\n   810→    prompt: parsed.prompt,\n   811→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   812→    config: {\n   813→      timeoutMs: parsed.timeoutMs || 300_000,\n   814→    },\n   815→  };\n   816→\n   817→  dispatcher.submit(request);\n   818→\n   819→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   820→\n   821→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   822→  res.end(JSON.stringify({\n   823→    executionId: request.executionId,\n   824→    status: 'queued',\n   825→  }));\n   826→}\n   827→\n   828→function handleGetExecution(\n   829→  res: http.ServerResponse,\n   830→  dispatcher: Dispatcher,\n   831→  executionId: string,\n   832→  offset: number = 0,\n   833→): void {\n   834→  const exec = dispatcher.getExecution(executionId);\n   835→\n   836→  if (!exec) {\n   837→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   838→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   839→    return;\n   840→  }\n   841→\n   842→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   843→\n   844→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   845→  res.end(JSON.stringify({\n   846→    executionId,\n   847→    status: exec.status,\n   848→    outputLines: exec.output.length,\n   849→    output,\n   850→    durationMs: exec.durationMs,\n   851→    sessionId: exec.sessionId,\n   852→    totalCostUsd: exec.totalCostUsd,\n   853→    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n   854→  }));\n   855→}\n   856→\n   857→function handleCancelExecution(\n   858→  res: http.ServerResponse,\n   859→  dispatcher: Dispatcher,\n   860→  executionId: string,\n   861→): void {\n   862→  const cancelled = dispatcher.cancelExecution(executionId);\n   863→\n   864→  if (!cancelled) {\n   865→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   866→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   867→    return;\n   868→  }\n   869→\n   870→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   871→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   872→}\n   873→\n   874→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB\n   875→const MAX_QUERY_LIMIT = 500;\n   876→const MAX_QUERY_OFFSET = 100_000;\n   877→\n   878→/** Parse an integer query param and clamp it to safe bounds. */\n   879→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   880→  if (!value) return defaultValue;\n   881→  const parsed = parseInt(value, 10);\n   882→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   883→  return Math.min(parsed, max);\n   884→}\n   885→"}]},"parent_tool_use_id":null,"session_id":"18cf733e-5086-44f8-9b8f-c7145785d79c","uuid":"94a29345-d191-4387-ad73-4bf2910982aa","timestamp":"2026-03-18T18:15:17.936Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TriggerSchedulerHandle } from './triggerScheduler.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog, AuditEntry, AuditAction } from './auditLog.js';\nimport type { EventProcessorHealth } from './eventProcessor.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\n// --- Route types ---\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\ntype RouteHandler = (\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  ctx: RequestContext,\n  route: ParsedRoute | null,\n  queryString: string | undefined,\n  tenantDb: Database.Database | undefined,\n  scopedProjectId: string | undefined,\n  reqLogger: Logger,\n) => Promise<void> | void;\n\ninterface RouteEntry {\n  handler: RouteHandler;\n  needsDb?: boolean;\n  adminOnly?: boolean;\n}\n\n/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\nfunction resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  kafka?: KafkaClient,\n  onEventPublished?: () => void,\n  triggerScheduler?: TriggerSchedulerHandle,\n): http.Server {\n\n  /** Wrap a mutation handler to emit an audit event on successful response. */\n  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n        try {\n          auditLog.record({\n            action,\n            tenantId: ctx.projectId || 'default',\n            actor: ctx.userEmail || ctx.projectId,\n            resourceType,\n            resourceId: route?.id,\n            ipAddress: req.socket.remoteAddress,\n          } as AuditEntry);\n        } catch { /* logged inside record() */ }\n      }\n    };\n  }\n\n  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n  const exactRoutes = new Map<string, RouteEntry>();\n\n  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n  for (const [path, method] of [\n    ['/api/oauth/authorize', 'POST'],\n    ['/api/oauth/callback', 'POST'],\n    ['/api/oauth/status', 'GET'],\n    ['/api/oauth/refresh', 'POST'],\n    ['/api/oauth/disconnect', 'DELETE'],\n    ['/api/token', 'POST'],\n  ] as const) {\n    exactRoutes.set(`${method}:${path}`, {\n      adminOnly: true,\n      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger);\n      },\n    });\n  }\n\n  exactRoutes.set('GET:/api/status', {\n    handler: (_req, res) => {\n      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n    },\n  });\n\n  exactRoutes.set('POST:/api/execute', {\n    handler: withHttpAudit(async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n    }, 'execution:submit', 'execution'),\n  });\n\n  exactRoutes.set('POST:/api/gitlab/webhook', {\n    needsDb: true,\n    handler: withHttpAudit(async (req, res, _ctx, _route, _qs, tenantDb) => {\n      const body = await readBody(req);\n      let parsed: Record<string, unknown> = {};\n      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n      const event = db.publishEvent(tenantDb!, {\n        eventType: `gitlab_${objectKind}`,\n        sourceType: 'gitlab',\n        sourceId: projectPath ?? null,\n        payload: body,\n      });\n      onEventPublished?.();\n      json(res, 201, event);\n    }, 'event:publish', 'event'),\n  });\n\n  // Admin routes\n  exactRoutes.set('GET:/api/admin/users', {\n    adminOnly: true,\n    handler: (_req, res) => {\n      if (tenantDbManager) {\n        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n      } else if (database) {\n        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n      } else {\n        json(res, 200, { projectIds: [] });\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/personas', {\n    adminOnly: true,\n    handler: (_req, res) => {\n      if (tenantDbManager) {\n        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n        json(res, 200, allPersonas);\n      } else if (database) {\n        json(res, 200, db.listPersonasSummary(database));\n      } else {\n        json(res, 200, []);\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/executions', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      const params = new URLSearchParams(queryString || '');\n      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n      if (tenantDbManager) {\n        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n        tenantDbManager.forEachTenant((tDb) => {\n          allExecs.push(...db.listExecutions(tDb, { limit }));\n        });\n        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n        json(res, 200, allExecs.slice(0, limit));\n      } else if (database) {\n        json(res, 200, db.listExecutions(database, {\n          limit,\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        }));\n      } else {\n        json(res, 200, []);\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/audit', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      if (!auditLog) { json(res, 200, []); return; }\n      const params = new URLSearchParams(queryString || '');\n      json(res, 200, auditLog.query({\n        tenantId: params.get('tenantId') ?? undefined,\n        action: (params.get('action') ?? undefined) as AuditAction | undefined,\n        since: params.get('since') ?? undefined,\n        limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n      }));\n    },\n  });\n\n  // ── Resource route table (O(1) lookup by `METHOD:resource[:id][:sub]`) ──\n  const resourceRoutes = new Map<string, RouteEntry>();\n\n  // --- Persona CRUD ---\n  resourceRoutes.set(resourceKey('GET', 'personas', false), {\n    needsDb: true,\n    handler: (_req, res, _ctx, _route, _qs, tenantDb, scopedProjectId) => {\n      json(res, 200, db.listPersonasSummary(tenantDb!, scopedProjectId));\n    },\n  });\n\n  resourceRoutes.set(resourceKey('POST', 'personas', false), {\n    needsDb: true,\n    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n      const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n      const persona = createPersonaWithDefaults({\n        ...body,\n        projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n      });\n      db.upsertPersona(tenantDb!, persona);\n      try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: persona.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n      json(res, 201, persona);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'tools'), {\n    needsDb: true,\n    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n      json(res, 200, db.getToolsForPersona(tenantDb!, route!.id!));\n    },\n  });\n\n  resourceRoutes.set(resourceKey('POST', 'personas', true, 'tools'), {\n    needsDb: true,\n    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n      if (!persona) return;\n      const body = JSON.parse(await readBody(req)) as { toolId: string };\n      db.linkTool(tenantDb!, route!.id!, body.toolId);\n      try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { toolId: body.toolId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route!.id!, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n      json(res, 200, { linked: true });\n    },\n  });\n\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'full'), {\n    needsDb: true,\n    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb!, route!.id!, reqLogger), scopedProjectId, res);\n      if (!hydrated) return;\n      json(res, 200, hydrated);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('GET', 'personas', true), {\n    needsDb: true,\n    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId) => {\n      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n      if (!persona) return;\n      json(res, 200, persona);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('DELETE', 'personas', true), {\n    needsDb: true,\n    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      db.deletePersona(tenantDb!, route!.id!, scopedProjectId);\n      try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n      json(res, 200, { deleted: true });\n    },\n  });\n\n  // --- Persona sub-resources: credentials ---\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'credentials'), {\n    needsDb: true,\n    handler: (req, res, ctx, route, _qs, tenantDb) => {\n      const creds = db.listCredentialsForPersona(tenantDb!, route!.id!);\n      try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n    },\n  });\n\n  resourceRoutes.set(resourceKey('POST', 'personas', true, 'credentials'), {\n    needsDb: true,\n    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n      if (!persona) return;\n      const body = JSON.parse(await readBody(req)) as { credentialId: string };\n      db.linkCredential(tenantDb!, route!.id!, body.credentialId);\n      try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { credentialId: body.credentialId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route!.id!, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n      json(res, 200, { linked: true });\n    },\n  });\n\n  // --- Persona sub-resources: subscriptions ---\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'subscriptions'), {\n    needsDb: true,\n    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n      json(res, 200, db.listSubscriptionsForPersona(tenantDb!, route!.id!));\n    },\n  });\n\n  // --- Tool Definitions ---\n  resourceRoutes.set(resourceKey('POST', 'tool-definitions', false), {\n    needsDb: true,\n    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n      const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n      const tool = createToolDefinitionWithDefaults(body);\n      db.upsertToolDefinition(tenantDb!, tool);\n      try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'toolDefinition', resourceId: tool.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n      json(res, 201, tool);\n    },\n  });\n\n  // --- Credentials ---\n  resourceRoutes.set(resourceKey('POST', 'credentials', false), {\n    needsDb: true,\n    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n      const body = JSON.parse(await readBody(req));\n      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n\n      if (!body.plaintext || typeof body.plaintext !== 'string') {\n        json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n        return;\n      }\n      if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n        json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n        return;\n      }\n      if (!tenantKeyManager) {\n        json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n        return;\n      }\n\n      delete body.encryptedData;\n      delete body.iv;\n      delete body.tag;\n\n      const tenantId = body.projectId || ctx.projectId || 'default';\n      const key = await tenantKeyManager.getKey(tenantId);\n      const encrypted = encrypt(body.plaintext, key);\n      body.encryptedData = encrypted.encrypted;\n      body.iv = encrypted.iv;\n      body.tag = encrypted.tag;\n      delete body.plaintext;\n\n      const cred = db.createCredential(tenantDb!, body);\n      try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: cred.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n      json(res, 201, cred);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('DELETE', 'credentials', true), {\n    needsDb: true,\n    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      const changes = db.deleteCredential(tenantDb!, route!.id!, scopedProjectId);\n      if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n      try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n      json(res, 200, { deleted: true });\n    },\n  });\n\n  // --- Event Subscriptions ---\n  resourceRoutes.set(resourceKey('POST', 'subscriptions', false), {\n    needsDb: true,\n    handler: async (req, res, ctx, _route, _qs, tenantDb) => {\n      const body = JSON.parse(await readBody(req));\n      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n      const missing: string[] = [];\n      if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n      const sub = db.createSubscription(tenantDb!, body);\n      try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: sub.id, detail: { personaId: body.personaId, eventType: body.eventType }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      json(res, 201, sub);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('PUT', 'subscriptions', true), {\n    needsDb: true,\n    handler: async (req, res, ctx, route, _qs, tenantDb) => {\n      const body = JSON.parse(await readBody(req));\n      db.updateSubscription(tenantDb!, route!.id!, body);\n      const updated = db.getSubscription(tenantDb!, route!.id!);\n      try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      json(res, 200, updated);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('DELETE', 'subscriptions', true), {\n    needsDb: true,\n    handler: (req, res, ctx, route, _qs, tenantDb) => {\n      db.deleteSubscription(tenantDb!, route!.id!);\n      try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      json(res, 200, { deleted: true });\n    },\n  });\n\n  // --- Triggers (delegated to triggerHttpHandlers) ---\n  const triggerHandler: RouteHandler = async (req, res, ctx, route, _qs, tenantDb) => {\n    await handleTriggerRoute(route!, req.method!, req, res, tenantDb!, ctx, triggerScheduler);\n  };\n  resourceRoutes.set(resourceKey('POST', 'triggers', false), { needsDb: true, handler: withHttp
