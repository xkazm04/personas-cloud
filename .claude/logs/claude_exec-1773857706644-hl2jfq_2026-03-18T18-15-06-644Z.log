gerHeap();\n    40→\n    41→  // ---- Heap bootstrap: load all enabled triggers from DB ----\n    42→  buildHeap(heap, database, tenantDbManager, logger);\n    43→\n    44→  logger.info(\n    45→    { heapSize: heap.size, minDelayMs: MIN_DELAY_MS, maxDelayMs: MAX_DELAY_MS, tenantIsolated: !!tenantDbManager },\n    46→    'Heap-driven trigger scheduler started',\n    47→  );\n    48→\n    49→  function scheduleTick(delayMs: number): void {\n    50→    if (stopped) return;\n    51→    timer = setTimeout(tick, delayMs);\n    52→  }\n    53→\n    54→  function tick(): void {\n    55→    if (stopped) return;\n    56→    try {\n    57→      const now = Date.now();\n    58→      const due = heap.popDue(now);\n    59→\n    60→      if (due.length > 0) {\n    61→        fireDueEntries(due, database, tenantDbManager, heap, logger, onEventPublished);\n    62→      }\n    63→    } catch (err) {\n    64→      logger.error({ err }, 'Trigger scheduler tick failed');\n    65→    }\n    66→\n    67→    // Schedule next tick based on heap peek\n    68→    const delayMs = computeNextDelay(heap);\n    69→    scheduleTick(delayMs);\n    70→  }\n    71→\n    72→  // Kick off the first tick immediately\n    73→  scheduleTick(0);\n    74→\n    75→  return {\n    76→    close() {\n    77→      stopped = true;\n    78→      if (timer != null) {\n    79→        clearTimeout(timer);\n    80→        timer = null;\n    81→      }\n    82→    },\n    83→    nudge() {\n    84→      if (stopped) return;\n    85→      if (timer != null) {\n    86→        clearTimeout(timer);\n    87→        timer = null;\n    88→      }\n    89→      scheduleTick(0);\n    90→    },\n    91→    heapPush(triggerId: string, tenantId: string, nextTriggerAt: string | null) {\n    92→      if (!nextTriggerAt) {\n    93→        heap.remove(triggerId);\n    94→        return;\n    95→      }\n    96→      heap.push({ triggerId, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });\n    97→    },\n    98→    heapRemove(triggerId: string) {\n    99→      heap.remove(triggerId);\n   100→    },\n   101→  };\n   102→}\n   103→\n   104→// ---------------------------------------------------------------------------\n   105→// Heap bootstrap — load all enabled triggers from every tenant DB\n   106→// ---------------------------------------------------------------------------\n   107→\n   108→function buildHeap(\n   109→  heap: TriggerHeap,\n   110→  database: Database.Database | null,\n   111→  tenantDbManager: TenantDbManager | undefined,\n   112→  logger: Logger,\n   113→): void {\n   114→  heap.clear();\n   115→\n   116→  if (tenantDbManager) {\n   117→    const tenantIds = tenantDbManager.listTenantIds();\n   118→    for (const tenantId of tenantIds) {\n   119→      try {\n   120→        const tenantDb = tenantDbManager.getTenantDb(tenantId);\n   121→        loadDbIntoHeap(heap, tenantDb, tenantId);\n   122→      } catch (err) {\n   123→        logger.error({ err, tenantId }, 'Failed to load triggers for tenant into heap');\n   124→      }\n   125→    }\n   126→  } else if (database) {\n   127→    loadDbIntoHeap(heap, database, 'default');\n   128→  }\n   129→}\n   130→\n   131→function loadDbIntoHeap(heap: TriggerHeap, dbConn: Database.Database, tenantId: string): void {\n   132→  const rows = db.loadEnabledTriggerTimes(dbConn);\n   133→  for (const row of rows) {\n   134→    heap.push({\n   135→      triggerId: row.id,\n   136→      tenantId,\n   137→      nextTriggerAt: new Date(row.nextTriggerAt).getTime(),\n   138→    });\n   139→  }\n   140→}\n   141→\n   142→// ---------------------------------------------------------------------------\n   143→// Compute next delay from the heap (O(1) peek)\n   144→// ---------------------------------------------------------------------------\n   145→\n   146→function computeNextDelay(heap: TriggerHeap): number {\n   147→  const top = heap.peek();\n   148→  if (!top) return MAX_DELAY_MS;\n   149→  const deltaMs = top.nextTriggerAt - Date.now();\n   150→  return Math.min(MAX_DELAY_MS, Math.max(MIN_DELAY_MS, deltaMs));\n   151→}\n   152→\n   153→// ---------------------------------------------------------------------------\n   154→// Fire due triggers — batch-fetch from DB by ID, then process\n   155→// ---------------------------------------------------------------------------\n   156→\n   157→function fireDueEntries(\n   158→  due: HeapEntry[],\n   159→  database: Database.Database | null,\n   160→  tenantDbManager: TenantDbManager | undefined,\n   161→  heap: TriggerHeap,\n   162→  logger: Logger,\n   163→  onEventPublished?: () => void,\n   164→): void {\n   165→  // Group by tenantId so we hit each DB once with a batch query\n   166→  const byTenant = new Map<string, HeapEntry[]>();\n   167→  for (const entry of due) {\n   168→    let list = byTenant.get(entry.tenantId);\n   169→    if (!list) {\n   170→      list = [];\n   171→      byTenant.set(entry.tenantId, list);\n   172→    }\n   173→    list.push(entry);\n   174→  }\n   175→\n   176→  for (const [tenantId, entries] of byTenant) {\n   177→    try {\n   178→      const tenantDb = tenantDbManager\n   179→        ? tenantDbManager.getTenantDb(tenantId)\n   180→        : database;\n   181→      if (!tenantDb) continue;\n   182→\n   183→      const ids = entries.map(e => e.triggerId);\n   184→      const triggers = db.getTriggersByIdsWithPersona(tenantDb, ids);\n   185→\n   186→      for (const trigger of triggers) {\n   187→        // Skip polling triggers\n   188→        if (trigger.triggerType === 'polling') continue;\n   189→\n   190→        try {\n   191→          const parsedConfig = trigger.parsedConfig;\n   192→          let eventType = 'trigger_fired';\n   193→          let payload: string | null = null;\n   194→          if (parsedConfig) {\n   195→            if (parsedConfig.event_type) eventType = parsedConfig.event_type;\n   196→            if (parsedConfig.payload) payload = JSON.stringify(parsedConfig.payload);\n   197→          }\n   198→\n   199→          // Skip triggers for deleted or disabled personas\n   200→          if (trigger.personaProjectId == null) {\n   201→            logger.warn({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona not found (deleted?)');\n   202→            continue;\n   203→          }\n   204→          if (!trigger.personaEnabled) {\n   205→            logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');\n   206→            continue;\n   207→          }\n   208→\n   209→          const triggerProjectId = tenantId !== 'default' ? tenantId : trigger.personaProjectId;\n   210→\n   211→          // Publish event\n   212→          db.publishEvent(tenantDb, {\n   213→            eventType,\n   214→            sourceType: 'trigger',\n   215→            sourceId: trigger.id,\n   216→            targetPersonaId: trigger.personaId,\n   217→            projectId: triggerProjectId,\n   218→            useCaseId: trigger.useCaseId,\n   219→            payload,\n   220→          });\n   221→          onEventPublished?.();\n   222→\n   223→          // Compute next trigger time and update DB\n   224→          const now = new Date().toISOString();\n   225→          const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);\n   226→          db.updateTriggerTimings(tenantDb, trigger.id, now, nextTriggerAt);\n   227→\n   228→          // Push updated time back into heap\n   229→          if (nextTriggerAt) {\n   230→            heap.push({ triggerId: trigger.id, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });\n   231→          }\n   232→\n   233→          logger.info({\n   234→            triggerId: trigger.id,\n   235→            personaId: trigger.personaId,\n   236→            eventType,\n   237→            nextTriggerAt,\n   238→          }, 'Trigger fired');\n   239→        } catch (err) {\n   240→          logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');\n   241→        }\n   242→      }\n   243→    } catch (err) {\n   244→      logger.error({ err, tenantId }, 'Trigger scheduler tick failed for tenant');\n   245→    }\n   246→  }\n   247→}\n   248→"}]},"parent_tool_use_id":null,"session_id":"18cf733e-5086-44f8-9b8f-c7145785d79c","uuid":"4390d11d-2a62-4542-9ee4-353e880da0e1","timestamp":"2026-03-18T18:15:17.001Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\triggerScheduler.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { TriggerHeap, type HeapEntry } from './triggerHeap.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\n\nconst MIN_DELAY_MS = 100;\nconst MAX_DELAY_MS = 60_000;\n\nexport interface TriggerSchedulerHandle {\n  /** Stop the scheduler. */\n  close(): void;\n  /** Nudge the scheduler to re-evaluate immediately (e.g. after trigger create/update). */\n  nudge(): void;\n  /** Push or update a trigger in the heap after CRUD. */\n  heapPush(triggerId: string, tenantId: string, nextTriggerAt: string | null): void;\n  /** Remove a trigger from the heap (e.g. after delete or disable). */\n  heapRemove(triggerId: string): void;\n}\n\n/**\n * Start the heap-driven trigger scheduler.\n *\n * On startup the scheduler loads all enabled triggers from the DB into an\n * in-memory min-heap keyed by next_trigger_at.  On each tick it pops entries\n * whose time has passed, fires them, and pushes the updated next-fire times\n * back into the heap.  The DB remains the source of truth — the heap is a\n * hot-path cache that eliminates full table scans.\n */\nexport function startTriggerScheduler(\n  database: Database.Database | null,\n  logger: Logger,\n  _interval?: number, // kept for signature compat; ignored\n  tenantDbManager?: TenantDbManager,\n  onEventPublished?: () => void,\n): TriggerSchedulerHandle {\n  let timer: ReturnType<typeof setTimeout> | null = null;\n  let stopped = false;\n  const heap = new TriggerHeap();\n\n  // ---- Heap bootstrap: load all enabled triggers from DB ----\n  buildHeap(heap, database, tenantDbManager, logger);\n\n  logger.info(\n    { heapSize: heap.size, minDelayMs: MIN_DELAY_MS, maxDelayMs: MAX_DELAY_MS, tenantIsolated: !!tenantDbManager },\n    'Heap-driven trigger scheduler started',\n  );\n\n  function scheduleTick(delayMs: number): void {\n    if (stopped) return;\n    timer = setTimeout(tick, delayMs);\n  }\n\n  function tick(): void {\n    if (stopped) return;\n    try {\n      const now = Date.now();\n      const due = heap.popDue(now);\n\n      if (due.length > 0) {\n        fireDueEntries(due, database, tenantDbManager, heap, logger, onEventPublished);\n      }\n    } catch (err) {\n      logger.error({ err }, 'Trigger scheduler tick failed');\n    }\n\n    // Schedule next tick based on heap peek\n    const delayMs = computeNextDelay(heap);\n    scheduleTick(delayMs);\n  }\n\n  // Kick off the first tick immediately\n  scheduleTick(0);\n\n  return {\n    close() {\n      stopped = true;\n      if (timer != null) {\n        clearTimeout(timer);\n        timer = null;\n      }\n    },\n    nudge() {\n      if (stopped) return;\n      if (timer != null) {\n        clearTimeout(timer);\n        timer = null;\n      }\n      scheduleTick(0);\n    },\n    heapPush(triggerId: string, tenantId: string, nextTriggerAt: string | null) {\n      if (!nextTriggerAt) {\n        heap.remove(triggerId);\n        return;\n      }\n      heap.push({ triggerId, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });\n    },\n    heapRemove(triggerId: string) {\n      heap.remove(triggerId);\n    },\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Heap bootstrap — load all enabled triggers from every tenant DB\n// ---------------------------------------------------------------------------\n\nfunction buildHeap(\n  heap: TriggerHeap,\n  database: Database.Database | null,\n  tenantDbManager: TenantDbManager | undefined,\n  logger: Logger,\n): void {\n  heap.clear();\n\n  if (tenantDbManager) {\n    const tenantIds = tenantDbManager.listTenantIds();\n    for (const tenantId of tenantIds) {\n      try {\n        const tenantDb = tenantDbManager.getTenantDb(tenantId);\n        loadDbIntoHeap(heap, tenantDb, tenantId);\n      } catch (err) {\n        logger.error({ err, tenantId }, 'Failed to load triggers for tenant into heap');\n      }\n    }\n  } else if (database) {\n    loadDbIntoHeap(heap, database, 'default');\n  }\n}\n\nfunction loadDbIntoHeap(heap: TriggerHeap, dbConn: Database.Database, tenantId: string): void {\n  const rows = db.loadEnabledTriggerTimes(dbConn);\n  for (const row of rows) {\n    heap.push({\n      triggerId: row.id,\n      tenantId,\n      nextTriggerAt: new Date(row.nextTriggerAt).getTime(),\n    });\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Compute next delay from the heap (O(1) peek)\n// ---------------------------------------------------------------------------\n\nfunction computeNextDelay(heap: TriggerHeap): number {\n  const top = heap.peek();\n  if (!top) return MAX_DELAY_MS;\n  const deltaMs = top.nextTriggerAt - Date.now();\n  return Math.min(MAX_DELAY_MS, Math.max(MIN_DELAY_MS, deltaMs));\n}\n\n// ---------------------------------------------------------------------------\n// Fire due triggers — batch-fetch from DB by ID, then process\n// ---------------------------------------------------------------------------\n\nfunction fireDueEntries(\n  due: HeapEntry[],\n  database: Database.Database | null,\n  tenantDbManager: TenantDbManager | undefined,\n  heap: TriggerHeap,\n  logger: Logger,\n  onEventPublished?: () => void,\n): void {\n  // Group by tenantId so we hit each DB once with a batch query\n  const byTenant = new Map<string, HeapEntry[]>();\n  for (const entry of due) {\n    let list = byTenant.get(entry.tenantId);\n    if (!list) {\n      list = [];\n      byTenant.set(entry.tenantId, list);\n    }\n    list.push(entry);\n  }\n\n  for (const [tenantId, entries] of byTenant) {\n    try {\n      const tenantDb = tenantDbManager\n        ? tenantDbManager.getTenantDb(tenantId)\n        : database;\n      if (!tenantDb) continue;\n\n      const ids = entries.map(e => e.triggerId);\n      const triggers = db.getTriggersByIdsWithPersona(tenantDb, ids);\n\n      for (const trigger of triggers) {\n        // Skip polling triggers\n        if (trigger.triggerType === 'polling') continue;\n\n        try {\n          const parsedConfig = trigger.parsedConfig;\n          let eventType = 'trigger_fired';\n          let payload: string | null = null;\n          if (parsedConfig) {\n            if (parsedConfig.event_type) eventType = parsedConfig.event_type;\n            if (parsedConfig.payload) payload = JSON.stringify(parsedConfig.payload);\n          }\n\n          // Skip triggers for deleted or disabled personas\n          if (trigger.personaProjectId == null) {\n            logger.warn({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona not found (deleted?)');\n            continue;\n          }\n          if (!trigger.personaEnabled) {\n            logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');\n            continue;\n          }\n\n          const triggerProjectId = tenantId !== 'default' ? tenantId : trigger.personaProjectId;\n\n          // Publish event\n          db.publishEvent(tenantDb, {\n            eventType,\n            sourceType: 'trigger',\n            sourceId: trigger.id,\n            targetPersonaId: trigger.personaId,\n            projectId: triggerProjectId,\n            useCaseId: trigger.useCaseId,\n            payload,\n          });\n          onEventPublished?.();\n\n          // Compute next trigger time and update DB\n          const now = new Date().toISOString();\n          const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);\n          db.updateTriggerTimings(tenantDb, trigger.id, now, nextTriggerAt);\n\n          // Push updated time back into heap\n          if (nextTriggerAt) {\n            heap.push({ triggerId: trigger.id, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });\n          }\n\n          logger.info({\n            triggerId: trigger.id,\n            personaId: trigger.personaId,\n            eventType,\n            nextTriggerAt,\n          }, 'Trigger fired');\n        } catch (err) {\n          logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');\n        }\n      }\n    } catch (err) {\n      logger.error({ err, tenantId }, 'Trigger scheduler tick failed for tenant');\n    }\n  }\n}\n","numLines":248,"startLine":1,"totalLines":248}}}
