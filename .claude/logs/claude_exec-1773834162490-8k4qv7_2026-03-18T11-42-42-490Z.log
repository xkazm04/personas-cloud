| null;\n   116→  processedAt: string | null;\n   117→  useCaseId: string | null;\n   118→  createdAt: string;\n   119→}\n   120→\n   121→export interface PersonaEventSubscription {\n   122→  id: string;\n   123→  personaId: string;\n   124→  eventType: string;\n   125→  sourceFilter: string | null;\n   126→  enabled: boolean;\n   127→  useCaseId: string | null;\n   128→  createdAt: string;\n   129→  updatedAt: string;\n   130→}\n   131→\n   132→// ---------------------------------------------------------------------------\n   133→// Trigger config discriminated union\n   134→// ---------------------------------------------------------------------------\n   135→\n   136→export type TriggerType = 'manual' | 'schedule' | 'polling' | 'webhook' | 'chain';\n   137→\n   138→interface TriggerConfigBase {\n   139→  event_type?: string;\n   140→  payload?: unknown;\n   141→}\n   142→\n   143→export interface ScheduleTriggerConfig extends TriggerConfigBase {\n   144→  kind: 'schedule';\n   145→  cron?: string;\n   146→  interval_seconds?: number;\n   147→}\n   148→\n   149→export interface ManualTriggerConfig extends TriggerConfigBase {\n   150→  kind: 'manual';\n   151→}\n   152→\n   153→export interface PollingTriggerConfig extends TriggerConfigBase {\n   154→  kind: 'polling';\n   155→  poll_url?: string;\n   156→  poll_interval_seconds?: number;\n   157→}\n   158→\n   159→export interface WebhookTriggerConfig extends TriggerConfigBase {\n   160→  kind: 'webhook';\n   161→  url?: string;\n   162→  secret?: string;\n   163→}\n   164→\n   165→export interface ChainTriggerConfig extends TriggerConfigBase {\n   166→  kind: 'chain';\n   167→  source_persona_id?: string;\n   168→  source_event_type?: string;\n   169→}\n   170→\n   171→export type TriggerConfig =\n   172→  | ScheduleTriggerConfig\n   173→  | ManualTriggerConfig\n   174→  | PollingTriggerConfig\n   175→  | WebhookTriggerConfig\n   176→  | ChainTriggerConfig;\n   177→\n   178→export interface PersonaTrigger {\n   179→  id: string;\n   180→  personaId: string;\n   181→  triggerType: TriggerType;\n   182→  config: string | null;\n   183→  enabled: boolean;\n   184→  lastTriggeredAt: string | null;\n   185→  nextTriggerAt: string | null;\n   186→  useCaseId: string | null;\n   187→  createdAt: string;\n   188→  updatedAt: string;\n   189→}\n   190→\n   191→/** Fully hydrated persona with all related entities. */\n   192→export interface HydratedPersona extends Persona {\n   193→  tools: PersonaToolDefinition[];\n   194→  credentials: Omit<PersonaCredential, 'encryptedData' | 'iv' | 'tag'>[];\n   195→  subscriptions: PersonaEventSubscription[];\n   196→  triggers: PersonaTrigger[];\n   197→}\n   198→\n   199→export interface PersonaExecution {\n   200→  id: string;\n   201→  projectId?: string;\n   202→  personaId: string;\n   203→  triggerId: string | null;\n   204→  useCaseId: string | null;\n   205→  status: string;\n   206→  inputData: string | null;\n   207→  outputData: string | null;\n   208→  claudeSessionId: string | null;\n   209→  modelUsed: string | null;\n   210→  inputTokens: number;\n   211→  outputTokens: number;\n   212→  costUsd: number;\n   213→  errorMessage: string | null;\n   214→  durationMs: number | null;\n   215→  retryOfExecutionId: string | null;\n   216→  retryCount: number;\n   217→  startedAt: string | null;\n   218→  completedAt: string | null;\n   219→  createdAt: string;\n   220→}\n   221→\n   222→// ---------------------------------------------------------------------------\n   223→// Execution request — produced to Kafka by Vibeman, consumed by orchestrator\n   224→// ---------------------------------------------------------------------------\n   225→\n   226→export interface ExecRequest {\n   227→  executionId: string;\n   228→  personaId: string;\n   229→  prompt: string;\n   230→  projectId?: string;\n   231→  credentialIds?: string[];\n   232→  inputData?: unknown;\n   233→  config: {\n   234→    timeoutMs: number;\n   235→    maxConcurrent?: number;\n   236→  };\n   237→  triggerId?: string;\n   238→  triggerType?: string;\n   239→}\n   240→\n   241→// Execution result — produced to Kafka by orchestrator\n   242→export interface ExecResult {\n   243→  executionId: string;\n   244→  personaId: string;\n   245→  status: 'completed' | 'failed' | 'cancelled';\n   246→  exitCode: number;\n   247→  durationMs: number;\n   248→  sessionId?: string;\n   249→  totalCostUsd?: number;\n   250→  error?: string;\n   251→}\n   252→\n   253→// Worker info as tracked by orchestrator\n   254→export interface WorkerInfo {\n   255→  workerId: string;\n   256→  status: 'connecting' | 'idle' | 'executing' | 'disconnected';\n   257→  version: string;\n   258→  capabilities: string[];\n   259→  currentExecutionId?: string;\n   260→  connectedAt: number;\n   261→  lastHeartbeat: number;\n   262→  imageDigest?: string;\n   263→  claudeCliVersion?: string;\n   264→  verified: boolean;\n   265→}\n   266→\n   267→// Execution output chunk — produced to Kafka for Vibeman SSE consumption\n   268→export interface OutputChunk {\n   269→  executionId: string;\n   270→  chunk: string;\n   271→  timestamp: number;\n   272→}\n   273→\n   274→// Persona event — forwarded from worker to Kafka event bus\n   275→export interface PersonaCloudEvent {\n   276→  executionId: string;\n   277→  personaId: string;\n   278→  eventType: 'manual_review' | 'user_message' | 'persona_action' | 'emit_event';\n   279→  payload: unknown;\n   280→  timestamp: number;\n   281→}\n   282→\n   283→// Execution progress (ephemeral — tracked in-memory + Kafka only)\n   284→export interface ProgressInfo {\n   285→  phase: string;\n   286→  percent: number;\n   287→  detail?: string;\n   288→  updatedAt: number;\n   289→}\n   290→\n   291→// Kafka topic names\n   292→export const TOPICS = {\n   293→  EXEC_REQUESTS: 'persona.exec.v1',\n   294→  EXEC_OUTPUT: 'persona.output.v1',\n   295→  EXEC_LIFECYCLE: 'persona.lifecycle.v1',\n   296→  EXEC_PROGRESS: 'persona.progress.v1',\n   297→  EVENTS: 'persona.events.v1',\n   298→  DLQ: 'persona.dlq.v1',\n   299→} as const;\n   300→\n   301→// Protocol version\n   302→export const PROTOCOL_VERSION = '0.2.0';\n   303→"}]},"parent_tool_use_id":null,"session_id":"43babe3f-d692-4a25-8476-901485a68cf5","uuid":"5fe089c6-9e5b-4405-a4b0-aa5e33867770","timestamp":"2026-03-18T11:43:56.891Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\shared\\src\\types.ts","content":"// ---------------------------------------------------------------------------\n// Persona domain types (mirroring desktop Tauri models)\n// ---------------------------------------------------------------------------\n\nexport interface Persona {\n  id: string;\n  projectId: string;\n  name: string;\n  description: string | null;\n  systemPrompt: string;\n  structuredPrompt: string | null;\n  icon: string | null;\n  color: string | null;\n  enabled: boolean;\n  maxConcurrent: number;\n  timeoutMs: number;\n  inferenceProfileId: string | null;\n  networkPolicy: string | null;\n  maxBudgetUsd: number | null;\n  maxTurns: number | null;\n  designContext: string | null;\n  groupId: string | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\n/** Lightweight projection for list views — omits large text fields. */\nexport interface PersonaSummary {\n  id: string;\n  projectId: string;\n  name: string;\n  description: string | null;\n  icon: string | null;\n  color: string | null;\n  enabled: boolean;\n  groupId: string | null;\n}\n\nexport interface PersonaToolDefinition {\n  id: string;\n  name: string;\n  category: string;\n  description: string;\n  scriptPath: string;\n  inputSchema: string | null;\n  outputSchema: string | null;\n  requiresCredentialType: string | null;\n  implementationGuide: string | null;\n  isBuiltin: boolean;\n  createdAt: string;\n  updatedAt: string;\n}\n\nexport interface StructuredPrompt {\n  identity?: string;\n  instructions?: string;\n  toolGuidance?: string;\n  examples?: string;\n  errorHandling?: string;\n  customSections?: Array<{ title?: string; label?: string; name?: string; key?: string; content?: string }>;\n  webSearch?: string;\n}\n\n// ---------------------------------------------------------------------------\n// Inference profiles\n// ---------------------------------------------------------------------------\n\nexport type InferenceProvider = 'claude' | 'ollama' | 'litellm' | 'openai-compatible' | 'custom';\n\nexport interface InferenceProviderEnvMapping {\n  envVar: string;\n  source: 'baseUrl' | 'authToken' | 'model';\n}\n\nexport interface InferenceProfile {\n  id: string;\n  projectId: string;\n  name: string;\n  provider: InferenceProvider;\n  model?: string;\n  baseUrl?: string;\n  authTokenEncrypted?: string;\n  authTokenIv?: string;\n  authTokenTag?: string;\n  envMappings: InferenceProviderEnvMapping[];\n  removeEnvKeys?: string[];\n  isPreset: boolean;\n  createdAt: string;\n  updatedAt: string;\n}\n\nexport interface PersonaCredential {\n  id: string;\n  projectId?: string;\n  name: string;\n  serviceType: string;\n  encryptedData: string;\n  iv: string;\n  tag: string;\n  metadata: string | null;\n  lastUsedAt: string | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\nexport interface PersonaEvent {\n  id: string;\n  projectId: string;\n  eventType: string;\n  sourceType: string;\n  sourceId: string | null;\n  targetPersonaId: string | null;\n  payload: string | null;\n  status: string;\n  errorMessage: string | null;\n  processedAt: string | null;\n  useCaseId: string | null;\n  createdAt: string;\n}\n\nexport interface PersonaEventSubscription {\n  id: string;\n  personaId: string;\n  eventType: string;\n  sourceFilter: string | null;\n  enabled: boolean;\n  useCaseId: string | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\n// ---------------------------------------------------------------------------\n// Trigger config discriminated union\n// ---------------------------------------------------------------------------\n\nexport type TriggerType = 'manual' | 'schedule' | 'polling' | 'webhook' | 'chain';\n\ninterface TriggerConfigBase {\n  event_type?: string;\n  payload?: unknown;\n}\n\nexport interface ScheduleTriggerConfig extends TriggerConfigBase {\n  kind: 'schedule';\n  cron?: string;\n  interval_seconds?: number;\n}\n\nexport interface ManualTriggerConfig extends TriggerConfigBase {\n  kind: 'manual';\n}\n\nexport interface PollingTriggerConfig extends TriggerConfigBase {\n  kind: 'polling';\n  poll_url?: string;\n  poll_interval_seconds?: number;\n}\n\nexport interface WebhookTriggerConfig extends TriggerConfigBase {\n  kind: 'webhook';\n  url?: string;\n  secret?: string;\n}\n\nexport interface ChainTriggerConfig extends TriggerConfigBase {\n  kind: 'chain';\n  source_persona_id?: string;\n  source_event_type?: string;\n}\n\nexport type TriggerConfig =\n  | ScheduleTriggerConfig\n  | ManualTriggerConfig\n  | PollingTriggerConfig\n  | WebhookTriggerConfig\n  | ChainTriggerConfig;\n\nexport interface PersonaTrigger {\n  id: string;\n  personaId: string;\n  triggerType: TriggerType;\n  config: string | null;\n  enabled: boolean;\n  lastTriggeredAt: string | null;\n  nextTriggerAt: string | null;\n  useCaseId: string | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\n/** Fully hydrated persona with all related entities. */\nexport interface HydratedPersona extends Persona {\n  tools: PersonaToolDefinition[];\n  credentials: Omit<PersonaCredential, 'encryptedData' | 'iv' | 'tag'>[];\n  subscriptions: PersonaEventSubscription[];\n  triggers: PersonaTrigger[];\n}\n\nexport interface PersonaExecution {\n  id: string;\n  projectId?: string;\n  personaId: string;\n  triggerId: string | null;\n  useCaseId: string | null;\n  status: string;\n  inputData: string | null;\n  outputData: string | null;\n  claudeSessionId: string | null;\n  modelUsed: string | null;\n  inputTokens: number;\n  outputTokens: number;\n  costUsd: number;\n  errorMessage: string | null;\n  durationMs: number | null;\n  retryOfExecutionId: string | null;\n  retryCount: number;\n  startedAt: string | null;\n  completedAt: string | null;\n  createdAt: string;\n}\n\n// ---------------------------------------------------------------------------\n// Execution request — produced to Kafka by Vibeman, consumed by orchestrator\n// ---------------------------------------------------------------------------\n\nexport interface ExecRequest {\n  executionId: string;\n  personaId: string;\n  prompt: string;\n  projectId?: string;\n  credentialIds?: string[];\n  inputData?: unknown;\n  config: {\n    timeoutMs: number;\n    maxConcurrent?: number;\n  };\n  triggerId?: string;\n  triggerType?: string;\n}\n\n// Execution result — produced to Kafka by orchestrator\nexport interface ExecResult {\n  executionId: string;\n  personaId: string;\n  status: 'completed' | 'failed' | 'cancelled';\n  exitCode: number;\n  durationMs: number;\n  sessionId?: string;\n  totalCostUsd?: number;\n  error?: string;\n}\n\n// Worker info as tracked by orchestrator\nexport interface WorkerInfo {\n  workerId: string;\n  status: 'connecting' | 'idle' | 'executing' | 'disconnected';\n  version: string;\n  capabilities: string[];\n  currentExecutionId?: string;\n  connectedAt: number;\n  lastHeartbeat: number;\n  imageDigest?: string;\n  claudeCliVersion?: string;\n  verified: boolean;\n}\n\n// Execution output chunk — produced to Kafka for Vibeman SSE consumption\nexport interface OutputChunk {\n  executionId: string;\n  chunk: string;\n  timestamp: number;\n}\n\n// Persona event — forwarded from worker to Kafka event bus\nexport interface PersonaCloudEvent {\n  executionId: string;\n  personaId: string;\n  eventType: 'manual_review' | 'user_message' | 'persona_action' | 'emit_event';\n  payload: unknown;\n  timestamp: number;\n}\n\n// Execution progress (ephemeral — tracked in-memory + Kafka only)\nexport interface ProgressInfo {\n  phase: string;\n  percent: number;\n  detail?: string;\n  updatedAt: number;\n}\n\n// Kafka topic names\nexport const TOPICS = {\n  EXEC_REQUESTS: 'persona.exec.v1',\n  EXEC_OUTPUT: 'persona.output.v1',\n  EXEC_LIFECYCLE: 'persona.lifecycle.v1',\n  EXEC_PROGRESS: 'persona.progress.v1',\n  EVENTS: 'persona.events.v1',\n  DLQ: 'persona.dlq.v1',\n} as const;\n\n// Protocol version\nexport const PROTOCOL_VERSION = '0.2.0';\n","numLines":303,"startLine":1,"totalLines":303}}}
