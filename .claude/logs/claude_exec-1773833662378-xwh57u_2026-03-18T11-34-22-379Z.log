0→\n   211→  /**\n   212→   * Get a valid access token, refreshing if necessary.\n   213→   * Returns null if no tokens available or refresh fails.\n   214→   */\n   215→  async getValidAccessToken(): Promise<string | null> {\n   216→    if (!this.tokens) return null;\n   217→\n   218→    // Refresh if within 10 minutes of expiry\n   219→    const TEN_MINUTES = 10 * 60 * 1000;\n   220→    if (Date.now() > this.tokens.expiresAt - TEN_MINUTES) {\n   221→      this.logger.info('Access token near expiry, refreshing...');\n   222→      if (!this.refreshPromise) {\n   223→        this.refreshPromise = this.refreshAccessToken().finally(() => {\n   224→          this.refreshPromise = null;\n   225→        });\n   226→      }\n   227→      const refreshed = await this.refreshPromise;\n   228→      if (!refreshed) return null;\n   229→    }\n   230→\n   231→    return this.tokens.accessToken;\n   232→  }\n   233→\n   234→  /**\n   235→   * Load tokens directly (e.g. from encrypted storage on startup).\n   236→   */\n   237→  loadTokens(tokens: OAuthTokens): void {\n   238→    this.tokens = tokens;\n   239→    this.logger.info({\n   240→      expiresAt: new Date(tokens.expiresAt).toISOString(),\n   241→      scopes: tokens.scopes,\n   242→    }, 'OAuth tokens loaded');\n   243→  }\n   244→\n   245→  /**\n   246→   * Get current tokens for persistence/encryption.\n   247→   */\n   248→  getTokens(): OAuthTokens | null {\n   249→    return this.tokens ? { ...this.tokens } : null;\n   250→  }\n   251→\n   252→  hasTokens(): boolean {\n   253→    return this.tokens !== null;\n   254→  }\n   255→\n   256→  clearTokens(): void {\n   257→    this.tokens = null;\n   258→    this.pendingStates.clear();\n   259→    this.logger.info('OAuth tokens cleared');\n   260→  }\n   261→\n   262→  /**\n   263→   * Stop the background sweep timer. Call on shutdown.\n   264→   */\n   265→  dispose(): void {\n   266→    if (this.sweepTimer) {\n   267→      clearInterval(this.sweepTimer);\n   268→    