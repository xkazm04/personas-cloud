ux' && fs.existsSync('/dev/shm')) {\n    47→    dirs.push('/dev/shm');\n    48→  }\n    49→  return dirs;\n    50→}\n    51→\n    52→/**\n    53→ * Install a synchronous process exit handler that removes any credential\n    54→ * files still tracked in the registry. This covers cases where the process\n    55→ * exits abnormally (uncaughtException, unhandledRejection) but the event\n    56→ * loop is still alive long enough to fire the 'exit' event.\n    57→ *\n    58→ * Call once during worker startup.\n    59→ */\n    60→export function installCredentialExitHandler(logger: Logger): void {\n    61→  if (exitHandlerInstalled) return;\n    62→  exitHandlerInstalled = true;\n    63→\n    64→  process.on('exit', () => {\n    65→    const totalFiles = activeCredentialFiles.size;\n    66→    const results: { path: string; success: boolean }[] = [];\n    67→\n    68→    for (const filePath of activeCredentialFiles) {\n    69→      try {\n    70→        fs.unlinkSync(filePath);\n    71→        results.push({ path: filePath, success: true });\n    72→      } catch {\n    73→        results.push({ path: filePath, success: false });\n    74→      }\n    75→    }\n    76→\n    77→    const succeeded = results.filter((r) => r.success).length;\n    78→    const failed = results.filter((r) => !r.success).length;\n    79→\n    80→    // Logger may not flush during 'exit', but try anyway\n    81→    if (totalFiles > 0) {\n    82→      logger.info(\n    83→        { totalFiles, succeeded, failed, files: results },\n    84→        'Exit handler credential file cleanup',\n    85→      );\n    86→    }\n    87→  });\n    88→}\n    89→\n    90→/**\n    91→ * Scan credential temp directories for orphaned `dac-creds-*` files older\n    92→ * than ORPHAN_MAX_AGE_MS and remove them. Intended to be called once during\n    93→ * worker startup before any executions begin.\n    94→ */\n    95→export async function sweepOrphanedCredentialFiles(logger: Logger): Promise<number> {\n    96→  const now = Date.now();\n    97→  let swept = 0;\n    98→\n    99→  for (const dir of credentialDirs()) {\n   100→    let entries: string[];\n   101→    try {\n   102→      entries = await fsp.readdir(dir);\n   103→    } catch (err) {\n   104→      logger.warn({ err, dir, operation: 'sweep_readdir' }, 'Failed to read credential directory');\n   105→      continue; // directory inaccessible\n   106→    }\n   107→\n   108→    for (const entry of entries) {\n   109→      if (!entry.startsWith(CRED_FILE_PREFIX)) continue;\n   110→\n   111→      const fullPath = path.join(dir, entry);\n   112→      try {\n   113→        const stat = await fsp.stat(fullPath);\n   114→        if (now - stat.mtimeMs > ORPHAN_MAX_AGE_MS) {\n   115→          await fsp.unlink(fullPath);\n   116→          swept++;\n   117→          logger.warn({ credentialFile: fullPath, ageMs: now - stat.mtimeMs }, 'Swept orphaned credential file');\n   118→        }\n   119→      } catch {\n   120→        // File disappeared between readdir and stat/unlink — fine\n   121→      }\n   122→    }\n   123→  }\n   124→\n   125→  logger.info(\n   126→    { swept, activeCredentialFiles: activeCredentialFiles.size },\n   127→    'Credential file sweep complete',\n   128→  );\n   129→\n   130→  return swept;\n   131→}\n   132→\n   133→/**\n   134→ * Write credentials to a temporary file (preferring tmpfs/ramfs) instead of\n   135→ * injecting them as environment variables. This prevents credential exposure\n   136→ * via /proc/pid/environ or `ps auxe`.\n   137→ *\n   138→ * Returns the file path and a cleanup function. The child process receives\n   139→ * the DAC_CREDENTIALS_FILE env var pointing to the file.\n   140→ */\n   141→export async function injectCredentialsViaFile(\n   142→  env: Record<string, string>,\n   143→  executionId: string,\n   144→  logger: Logger,\n   145→): Promise<InjectedCredentials> {\n   146→  // Prefer /dev/shm (tmpfs, never hits disk) on Linux\n   147→  let tmpBase: string;\n   148→  if (process.platform === 'linux' && fs.existsSync('/dev/shm')) {\n   149→    tmpBase = '/dev/shm';\n   150→  } else {\n   151→    tmpBase = os.tmpdir();\n   152→  }\n   153→\n   154→  const randomSuffix = crypto.randomBytes(8).toString('hex');\n   155→  const credFilePath = path.join(tmpBase, `${CRED_FILE_PREFIX}${executionId}-${randomSuffix}.json`);\n   156→\n   157→  // Collect credential env vars into the file\n   158→  const credentials: Record<string, string> = {};\n   159→  const credentialKeys: string[] = [];\n   160→\n   161→  for (const [key, value] of Object.entries(env)) {\n   162→    // Credential env vars follow the CONNECTOR_* pattern or are well-known secret keys\n   163→    if (\n   164→      key.startsWith('CONNECTOR_') ||\n   165→      key === 'ANTHROPIC_API_KEY' ||\n   166→      key.includes('TOKEN') ||\n   167→      key.includes('SECRET') ||\n   168→      key.includes('PASSWORD') ||\n   169→      key.includes('API_KEY')\n   170→    ) {\n   171→      credentials[key] = value;\n   172→      credentialKeys.push(key);\n   173→    }\n   174→  }\n   175→\n   176→  // Write credential file asynchronously\n   177→  await fsp.writeFile(credFilePath, JSON.stringify(credentials), { mode: 0o600 });\n   178→\n   179→  // Track the file so exit handler can clean it up on crash\n   180→  activeCredentialFiles.add(credFilePath);\n   181→\n   182→  // Remove credential keys from the env dict (they'll be read from file instead)\n   183→  for (const key of credentialKeys) {\n   184→    delete env[key];\n   185→  }\n   186→\n   187→  logger.debug({\n   188→    executionId,\n   189→    credentialFile: credFilePath,\n   190→    credentialCount: credentialKeys.length,\n   191→    onTmpfs: tmpBase === '/dev/shm',\n   192→  }, 'Credentials written to temporary file');\n   193→\n   194→  return {\n   195→    credentialFilePath: credFilePath,\n   196→    envPointerKey: 'DAC_CREDENTIALS_FILE',\n   197→    async cleanup() {\n   198→      activeCredentialFiles.delete(credFilePath);\n  