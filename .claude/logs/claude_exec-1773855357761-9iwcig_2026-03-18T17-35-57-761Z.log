this.executionDone = null;\n    78→    }\n    79→  }\n    80→\n    81→  private async doExecute(assignment: ExecAssign, callbacks: ExecutorCallbacks): Promise<void> {\n    82→    const startTime = Date.now();\n    83→    this.sessionId = undefined;\n    84→    this.totalCostUsd = undefined;\n    85→\n    86→    const netPolicy = assignment.config.networkPolicy ?? undefined;\n    87→    const sandboxConfig: SandboxConfig = {\n    88→      executionId: assignment.executionId,\n    89→      env: { ...assignment.env },\n    90→      networkAccess: !netPolicy, // full access only if no policy set\n    91→      networkPolicy: netPolicy,\n    92→      timeoutMs: assignment.config.timeoutMs,\n    93→      maxBudgetUsd: assignment.config.maxBudgetUsd,\n    94→      maxTurns: assignment.config.maxTurns,\n    95→    };\n    96→\n    97→    let t0 = Date.now();\n    98→    const sandbox = prepareSandbox(sandboxConfig, this.logger);\n    99→    const sandboxSetupMs = Date.now() - t0;\n   100→\n   101→    let proxy: ProxyHandle | null = null;\n   102→    let injectedCreds: InjectedCredentials | null = null;\n   103→    let proxyStartupMs: number | null = null;\n   104→    let credentialInjectionMs = 0;\n   105→    let cliRuntimeMs = 0;\n   106→    let exitCode = 1;\n   107→    let completedNormally = false;\n   108→\n   109→    this.logger.info({\n   110→      executionId: assignment.executionId,\n   111→      personaId: assignment.personaId,\n   112→      sandboxDir: sandbox.sandboxDir,\n   113→      timeoutMs: assignment.config.timeoutMs,\n   114→    }, 'Starting execution');\n   115→\n   116→    try {\n   117→      // Start filtering proxy for allow-list network policies\n   118→      if (sandbox.proxyRequired && netPolicy) {\n   119→        t0 = Date.now();\n   120→        proxy = await startFilterProxy(netPolicy, this.logger, assignment.executionId);\n   121→        proxyStartupMs = Date.now() - t0;\n   122→        const proxyUrl = `http://127.0.0.1:${proxy.port}`;\n   123→ 