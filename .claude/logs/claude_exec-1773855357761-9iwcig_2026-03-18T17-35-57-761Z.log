ized: process.env['TLS_REJECT_UNAUTHORIZED'] !== 'false',\n  };\n}\n","structuredPatch":[{"oldStart":36,"oldLines":5,"newStart":36,"newLines":6,"lines":["     tlsCertPath: process.env['TLS_CERT_PATH'] || '',","     tlsKeyPath: process.env['TLS_KEY_PATH'] || '',","     tlsRejectUnauthorized: process.env['TLS_REJECT_UNAUTHORIZED'] !== 'false',","+    healthPort: parseInt(process.env['HEALTH_PORT'] || '0', 10),","   };"," }"]}],"userModified":false,"replaceAll":false}}
