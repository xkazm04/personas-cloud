[2026-03-18T17:38:17.263Z] [STDOUT] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01E3iXKoSbG2yQoUqoceBZxz","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011uRVKUBa3NZvjUsHNp3XDy","name":"Write","input":{"file_path":"C:/Users/kazda/kiro/personas-cloud/packages/worker/src/healthProbe.ts","content":"import http from 'node:http';\nimport fs from 'node:fs';\nimport os from 'node:os';\nimport type { Logger } from 'pino';\nimport type { Connection } from './connection.js';\nimport type { Executor } from './executor.js';\nimport { isSandboxAvailable } from './sandbox.js';\nimport { getActiveCredentialFileCount } from './credentialInjector.js';\n\nexport interface ExecutionSnapshot {\n  executionId: string | null;\n  startedAt: number | null;\n}\n\ninterface DiskInfo {\n  path: string;\n  availableBytes: number;\n  totalBytes: number;\n}\n\nfunction getDiskInfo(dirPath: string): DiskInfo | null {\n  try {\n    const stats = fs.statfsSync(dirPath);\n    return {\n      path: dirPath,\n      availableBytes: stats.bavail * stats.bsize,\n      totalBytes: stats.blocks * stats.bsize,\n    };\n  } catch {\n    return null;\n  }\n}\n\nfunction buildHealthPayload(\n  connection: Connection,\n  executor: Executor,\n  getExecution: () => ExecutionSnapshot,\n  startTime: number,\n) {\n  const wsState = connection.getConnectionState();\n  const exec = getExecution();\n  const now = Date.now();\n\n  const tmpdir = getDiskInfo(os.tmpdir());\n  const devShm = process.platform === 'linux' && fs.existsSync('/dev/shm')\n    ? getDiskInfo('/dev/shm')\n    : null;\n\n  const healthy = wsState === 'connected';\n\n  return {\n    status: healthy ? 'healthy' as const : 'degraded' as const,\n    uptimeMs: now - startTime,\n    websocket: wsState,\n    execution: {\n      state: executor.isBusy() ? 'busy' as const : 'idle' as const,\n      executionId: exec.executionId,\n      durationMs: exec.startedAt ? now - exec.startedAt : null,\n    },\n    sandbox: {\n      bwrapAvailable: isSandboxAvailable(),\n    },\n    disk: {\n      tmpdir,\n      devShm,\n    },\n    credentials: {\n      activeFileCount: getActiveCredentialFileCount(),\n    },\n  };\n}\n\nexport function startHealthProbe(\n  port: number,\n  connection: Connection,\n  executor: Executor,\n  getExecution: () => ExecutionSnapshot,\n  logger: Logger,\n): http.Server {\n  const startTime = Date.now();\n\n  const server = http.createServer((req, res) => {\n    if (req.method !== 'GET') {\n      res.writeHead(405);\n      res.end();\n      return;\n    }\n\n    const payload = buildHealthPayload(connection, executor, getExecution, startTime);\n\n    if (req.url === '/healthz') {\n      // Liveness: healthy if process is running and WS isn't permanently disconnected\n      const alive = payload.websocket !== 'disconnected';\n      res.writeHead(alive ? 200 : 503, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify(payload));\n      return;\n    }\n\n    if (req.url === '/readyz') {\n      // Readiness: ready to accept work when connected and idle\n      const ready = payload.websocket === 'connected' && payload.execution.state === 'idle';\n      res.writeHead(ready ? 200 : 503, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify(payload));\n      return;\n    }\n\n    res.writeHead(404);\n    res.end();\n  });\n\n  server.listen(port, '0.0.0.0', () => {\n    logger.info({ port }, 'Health probe listening');\n  });\n\n  return server;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":265,"cache_read_input_tokens":44153,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":265},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4ac23663-2b94-4a88-95a8-b1d1a8af070a","uuid":"e0b9a1ec-072c-4b63-82b9-e7924ce04cef"}
