[2026-03-18T17:36:20.248Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016S38huzbWuYXSStYt1shig","type":"tool_result","content":"     1→import pino from 'pino';\n     2→import { loadConfig } from './config.js';\n     3→import { Connection, type WorkerTlsConfig } from './connection.js';\n     4→import { Executor } from './executor.js';\n     5→import { installCredentialExitHandler, sweepOrphanedCredentialFiles } from './credentialInjector.js';\n     6→import type { ExecAssign } from '@dac-cloud/shared';\n     7→\n     8→const logger = pino({ level: process.env['LOG_LEVEL'] || 'info' });\n     9→\n    10→async function main() {\n    11→  logger.info('Starting DAC Cloud Worker...');\n    12→\n    13→  const config = loadConfig();\n    14→  logger.info({ workerId: config.workerId, orchestratorUrl: config.orchestratorUrl }, 'Configuration loaded');\n    15→\n    16→  // Clean up any credential files left behind by a previous crash\n    17→  installCredentialExitHandler(logger);\n    18→  await sweepOrphanedCredentialFiles(logger);\n    19→\n    20→  const executor = new Executor(logger);\n    21→  let currentExecutionId: string | null = null;\n    22→\n    23→  const connection = new Connection(\n    24→    config.orchestratorUrl,\n    25→    config.workerId,\n    26→    config.workerToken,\n    27→    {\n    28→      onAssign(msg: ExecAssign) {\n    29→        if (currentExecutionId || executor.isBusy()) {\n    30→          logger.warn(\n    31→            { executionId: msg.executionId, currentExecutionId },\n    32→            'Received assignment while busy, sending busy nack',\n    33→          );\n    34→          connection.sendBusy(msg.executionId, 'Worker is already executing');\n    35→          return;\n    36→        }\n    37→\n    38→        currentExecutionId = msg.executionId;\n    39→\n    40→        executor.execute(msg, {\n    41→          onStdout(chunk: string, timestamp: number) {\n    42→            connection.sendStdout(msg.executionId, chunk);\n    43→          },\n    44→\n    45→          onStderr(chunk: string, timestamp: number) {\n    46→            logger.warn({ executionId: msg.executionId, stderr: chunk }, 'CLI stderr');\n    47→            connection.sendStderr(msg.executionId, chunk);\n    48→          },\n    49→\n    50→          onEvent(eventType: 'manual_review' | 'user_message' | 'persona_action' | 'emit_event', payload: unknown) {\n    51→            connection.sendEvent(msg.executionId, eventType, payload);\n    52→          },\n    53→\n    54→          onProgress(phase: string, percent: number, detail?: string) {\n    55→            connection.sendProgress(msg.executionId, phase, percent, detail);\n    56→          },\n    57→\n    58→          onComplete(status, exitCode, durationMs, sessionId, totalCostUsd, phaseTimings) {\n    59→            connection.sendComplete(msg.executionId, status, exitCode, durationMs, sessionId, totalCostUsd, phaseTimings);\n    60→            currentExecutionId = null;\n    61→\n    62→            // Signal ready for next assignment\n    63→            connection.sendReady();\n    64→          },\n    65→        }).catch((err) => {\n    66→          logger.error({ err, executionId: msg.executionId }, 'Execution error');\n    67→          connection.sendComplete(msg.executionId, 'failed', 1, 0);\n    68→          currentExecutionId = null;\n    69→          connection.sendReady();\n    70→        });\n    71→      },\n    72→\n    73→      onCancel(msg) {\n    74→        if (currentExecutionId === msg.executionId) {\n    75→          logger.info({ executionId: msg.executionId }, 'Cancelling execution');\n    76→          executor.kill();\n    77→        }\n    78→      },\n    79→\n    80→      onShutdown(msg) {\n    81→        logger.info({ reason: msg.reason, gracePeriodMs: msg.gracePeriodMs }, 'Shutdown requested');\n    82→\n    83→        if (currentExecutionId) {\n    84→          // Wait for current execution to finish, then exit\n    85→          logger.info('Waiting for current execution to complete before shutdown');\n    86→          const checkInterval = setInterval(() => {\n    87→            if (!currentExecutionId) {\n    88→              clearInterval(checkInterval);\n    89→              shutdown();\n    90→            }\n    91→          }, 1000);\n    92→\n    93→          // Force shutdown after grace period\n    94→          setTimeout(() => {\n    95→            clearInterval(checkInterval);\n    96→            executor.kill();\n    97→            shutdown();\n    98→          }, msg.gracePeriodMs);\n    99→        } else {\n   100→          shutdown();\n   101→        }\n   102→      },\n   103→    },\n   104→    logger,\n   105→    // Pass TLS config if CA or client certs are configured\n   106→    (config.tlsCaPath || config.tlsCertPath) ? {\n   107→      caPath: config.tlsCaPath,\n   108→      certPath: config.tlsCertPath,\n   109→      keyPath: config.tlsKeyPath,\n   110→      rejectUnauthorized: config.tlsRejectUnauthorized,\n   111→    } as WorkerTlsConfig : undefined,\n   112→    { imageDigest: config.imageDigest, claudeCliVersion: config.claudeCliVersion },\n   113→  );\n   114→\n   115→  // Connect to orchestrator\n   116→  connection.connect();\n   117→\n   118→  // Graceful shutdown — waits for sandbox/credential cleanup before exiting\n   119→  let shuttingDown = false;\n   120→  async function shutdown() {\n   121→    if (shuttingDown) return;   // prevent double-shutdown\n   122→    shuttingDown = true;\n   123→    logger.info('Shutting down worker...');\n   124→    connection.disconnect();\n   125→\n   126→    // Drain the executor's finally-block cleanup (sandbox dirs, credential\n   127→    // files, proxy) before calling process.exit so nothing is leaked.\n   128→    await executor.waitForCleanup();\n   129→    process.exit(0);\n   130→  }\n   131→\n   132→  const onTermSignal = () => {\n   133→    if (currentExecutionId) {\n   134→      logger.info('Termination signal received, killing current execution');\n   135→      executor.kill();\n   136→    }\n   137→    shutdown();\n   138→  };\n   139→\n   140→  process.on('SIGINT', onTermSignal);\n   141→  process.on('SIGTERM', onTermSignal);\n   142→\n   143→  logger.info('DAC Cloud Worker started');\n   144→}\n   145→\n   146→main().catch((err) => {\n   147→  logger.fatal({ err }, 'Failed to start worker');\n   148→  process.exit(1);\n   149→});\n   150→"}]},"parent_tool_use_id":"toolu_01AusAuTVWFD2XBKVmR4gsG4","session_id":"4ac23663-2b94-4a88-95a8-b1d1a8af070a","uuid":"c3c07e91-e8bc-483d-bde4-34a9c9fe5b75","timestamp":"2026-03-18T17:36:20.043Z"}
