string;\n    55→  authToken?: string;\n    56→}\n    57→\n    58→export interface PersonaCredential {\n    59→  id: string;\n    60→  projectId?: string;\n    61→  name: string;\n    62→  serviceType: string;\n    63→  encryptedData: string;\n    64→  iv: string;\n    65→  tag: string;\n    66→  metadata: string | null;\n    67→  lastUsedAt: string | null;\n    68→  createdAt: string;\n    69→  updatedAt: string;\n    70→}\n    71→\n    72→export interface PersonaEvent {\n    73→  id: string;\n    74→  projectId: string;\n    75→  eventType: string;\n    76→  sourceType: string;\n    77→  sourceId: string | null;\n    78→  targetPersonaId: string | null;\n    79→  payload: string | null;\n    80→  status: string;\n    81→  errorMessage: string | null;\n    82→  processedAt: string | null;\n    83→  useCaseId: string | null;\n    84→  createdAt: string;\n    85→}\n    86→\n    87→export interface PersonaEventSubscription {\n    88→  id: string;\n    89→  personaId: string;\n    90→  eventType: string;\n    91→  sourceFilter: string | null;\n    92→  enabled: boolean;\n    93→  useCaseId: string | null;\n    94→  createdAt: string;\n    95→  updatedAt: string;\n    96→}\n    97→\n    98→export interface PersonaTrigger {\n    99→  id: string;\n   100→  personaId: string;\n   101→  triggerType: string;\n   102→  config: string | null;\n   103→  enabled: boolean;\n   104→  lastTriggeredAt: string | null;\n   105→  nextTriggerAt: string | null;\n   106→  useCaseId: string | null;\n   107→  createdAt: string;\n   108→  updatedAt: string;\n   109→}\n   110→\n   111→export interface PersonaExecution {\n   112→  id: string;\n   113→  projectId?: string;\n   114→  personaId: string;\n   115→  triggerId: string | null;\n   116→  useCaseId: string | null;\n   117→  status: string;\n   118→  inputData: string | null;\n   119→  outputData: string | null;\n   120→  claudeSessionId: string | null;\n   121→  modelUsed: string | null;\n   122→  inputTokens: number;\n   123→  outputTokens: number;\n   124→  costUsd: number;\n   125→  errorMessage: string | null;\n   126→  durationMs: number | null;\n   127→  retryOfExecutionId: string | null;\n   128→  retryCount: number;\n   129→  startedAt: string | null;\n   130→  completedAt: string | null;\n   131→  createdAt: string;\n   132→}\n   133→\n   134→// ---------------------------------------------------------------------------\n   135→// Execution request — produced to Kafka by Vibeman, consumed by orchestrator\n   136→// ---------------------------------------------------------------------------\n   137→\n   138→export interface ExecRequest {\n   139→  executionId: string;\n   140→  personaId: string;\n   141→  prompt: string;\n   142→  projectId?: string;\n   143→  credentialIds?: string[];\n   144→  inputData?: unknown;\n   145→  config: {\n   146→    timeoutMs: number;\n   147→    maxConcurrent?: number;\n   148→  };\n   149→  triggerId?: string;\n   150→  triggerType?: string;\n   151→}\n   152→\n   153→// Execution result — produced to Kafka by orchestrator\n   154→export interface ExecResult {\n   155→  executionId: string;\n   156→  personaId: string;\n   157→  status: 'completed' | 'failed' | 'cancelled';\n   158→  exitCode: number;\n   159→  durationMs: number;\n   160→  sessionId?: string;\n   161→  totalCostUsd?: number;\n   162→  error?: string;\n   163→}\n   164→\n   165→// Worker info as tracked by orchestrator\n   166→export interface WorkerInfo {\n   167→  workerId: string;\n   168→  status: 'connecting' | 'idle' | 'executing' | 'disconnected';\n   169→  version: string;\n   170→  capabilities: string[];\n   171→  currentExecutionId?: string;\n   172→  connectedAt: number;\n   173→  lastHeartbeat: number;\n   174→}\n   175→\n   176→// Execution output chunk — produced to Kafka for Vibeman SSE consumption\n   177→export interface OutputChunk {\n   178→  executionId: string;\n   179→  chunk: string;\n   180→  timestamp: number;\n   181→}\n   182→\n   183→// Persona event — forwarded from worker to Kafka event bus\n   184→export interface PersonaCloudEvent {\n   185→  executionId: string;\n   186→  personaId: string;\n   187→  eventType: 'manual_review' | 'user_message' | 'persona_action' | 'emit_event';\n   188→  payload: unknown;\n   189→  timestamp: number;\n   190→}\n   191→\n   192→// Kafka topic names\n   193→export const TOPICS = {\n   194→  EXEC_REQUESTS: 'persona.exec.v1',\n   195→  EXEC_OUTPUT: 'persona.output.v1',\n   196→  EXEC_LIFECYCLE: 'persona.lifecycle.v1',\n   197→  EVENTS: 'persona.events.v1',\n   198→  DLQ: 'persona.dlq.v1',\n   199→} as const;\n   200→\n   201→// Protocol version\n   202→export const PROTOCOL_VERSION = '0.1.0';\n   203→"}]},"parent_tool_use_id":"toolu_01LPkFLZp5iMkJiXtGc1zvki","session_id":"b1918db3-404e-4a21-ad71-d84694ad33d6","uuid":"fc909807-a4a9-48b0-85f5-41dfc50ab883","timestamp":"2026-03-19T08:36:19.873Z"}
[2026-03-19T08:36:20.282Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SNwWcffzVpBmMj8NfJeT5a","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import type { ExecRequest, Persona, PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import type { Logger } from 'pino';\n    11→import * as db from './db.js';\n    12→\n    13→export function createHttpApi(\n    14→  auth: Auth,\n    15→  dispatcher: Dispatcher,\n    16→  pool: WorkerPool,\n    17→  tokenManager: TokenManager,\n    18→  oauth: OAuthManager,\n    19→  logger: Logger,\n    20→  database?: Database.Database,\n    21→): http.Server {\n    22→  const server = http.createServer(async (req, res) => {\n    23→    // CORS headers\n    24→    res.setHeader('Access-Control-Allow-Origin', '*');\n    25→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    26→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n    27→\n    28→    if (req.method === 'OPTIONS') {\n    29→      res.writeHead(204);\n    30→      res.end();\n    31→      return;\n    32→    }\n    33→\n    34→    const url = req.url || '/';\n    35→    const [pathname, queryString] = url.split('?');\n    36→\n    37→    // Unauthenticated endpoints\n    38→    if (pathname === '/health' && req.method === 'GET') {\n    39→      handleHealth(res, pool, oauth);\n    40→      return;\n    41→    }\n    42→\n    43→    // Auth check for everything else — dual auth (API key + optional JWT)\n    44→    const ctx = auth.validateAndExtractContext(req);\n    45→    if (!ctx) {\n    46→      res.writeHead(401, { 'Content-Type': 'application/json' });\n    47→      res.end(JSON.stringify({ error: 'Unauthorized' }));\n    48→      return;\n    49→    }\n    50→\n    51→    // Helper: project scoping (admin sees all, user sees own project)\n    52→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n    53→\n    54→    try {\n    55→      // --- OAuth endpoints ---\n    56→      if (pathname === '/api/oauth/authorize' && req.method === 'POST') {\n    57→        handleOAuthAuthorize(res, oauth);\n    58→      } else if (pathname === '/api/oauth/callback' && req.method === 'POST') {\n    59→        await handleOAuthCallback(req, res, oauth, tokenManager, logger);\n    60→      } else if (pathname === '/api/oauth/status' && req.method === 'GET') {\n    61→        handleOAuthStatus(res, oauth);\n    62→      } else if (pathname === '/api/oauth/refresh' && req.method === 'POST') {\n    63→        await handleOAuthRefresh(res, oauth, tokenManager, logger);\n    64→      } else if (pathname === '/api/oauth/disconnect' && req.method === 'DELETE') {\n    65→        handleOAuthDisconnect(res, oauth, tokenManager);\n    66→      }\n    67→      // --- Token injection (fallback for setup-token / direct paste) ---\n    68→      else if (pathname === '/api/token' && req.method === 'POST') {\n    69→        await handleSetToken(req, res, tokenManager, logger);\n    70→      }\n    71→      // --- Persona CRUD ---\n    72→      else if (pathname === '/api/personas' && req.method === 'GET' && database) {\n    73→        json(res, 200, db.listPersonas(database, scopedProjectId));\n    74→      } else if (pathname === '/api/personas' && req.method === 'POST' && database) {\n    75→        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n    76→        const now = new Date().toISOString();\n    77→        const persona: Persona = {\n    78→          id: body.id ?? nanoid(),\n    79→          projectId: ctx.authType === 'user' ? ctx.projectId : (body.projectId ?? 'default'),\n    80→          name: body.name ?? 'Untitled',\n    81→          description: body.description ?? null,\n    82→          systemPrompt: body.systemPrompt ?? '',\n    83→          structuredPrompt: body.structuredPrompt ?? null,\n    84→          icon: body.icon ?? null,\n    85→          color: body.color ?? null,\n    86→          enabled: body.enabled ?? true,\n    87→          maxConcurrent: body.maxConcurrent ?? 1,\n    88→          timeoutMs: body.timeoutMs ?? 300_000,\n    89→          modelProfile: body.modelProfile ?? null,\n    90→          maxBudgetUsd: body.maxBudgetUsd ?? null,\n    91→          maxTurns: body.maxTurns ?? null,\n    92→          designContext: body.designContext ?? null,\n    93→          groupId: body.groupId ?? null,\n    94→          createdAt: body.createdAt ?? now,\n    95→          updatedAt: now,\n    96→        };\n    97→        db.upsertPersona(database, persona);\n    98→        json(res, 201, persona);\n    99→      } else if (matchRoute(pathname, '/api/personas/') && req.method === 'GET' && database) {\n   100→        const id = pathname!.replace('/api/personas/', '');\n   101→        const persona = db.getPersona(database, id);\n   102→        if (!persona || (scopedProjectId && persona.projectId !== scopedProjectId)) { json(res, 404, { error: 'Not found' }); return; }\n   103→        json(res, 200, persona);\n   104→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/tools') && req.method === 'GET' && database) {\n   105→        const id = pathname!.replace('/api/personas/', '').replace('/tools', '');\n   106→        json(res, 200, db.getToolsForPersona(database, id));\n   107→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/tools') && req.method === 'POST' && database) {\n   108→        const id = pathname!.replace('/api/personas/', '').replace('/tools', '');\n   109→        const body = JSON.parse(await readBody(req)) as { toolId: string };\n   110→        db.linkTool(database, id, body.toolId);\n   111→        json(res, 200, { linked: true });\n   112→      } else if (matchRoute(pathname, '/api/personas/') && !pathname!.endsWith('/tools') && !pathname!.endsWith('/credentials') && !pathname!.endsWith('/subscriptions') && !pathname!.endsWith('/triggers') && req.method === 'DELETE' && database) {\n   113→        const id = pathname!.replace('/api/personas/', '');\n   114→        db.deletePersona(database, id, scopedProjectId);\n   115→        json(res, 200, { deleted: true });\n   116→      }\n   117→      // --- Tool Definitions ---\n   118→      else if (pathname === '/api/tool-definitions' && req.method === 'POST' && database) {\n   119→        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   120→        const now = new Date().toISOString();\n   121→        const tool: PersonaToolDefinition = {\n   122→          id: body.id ?? nanoid(),\n   123→          name: body.name ?? 'unnamed',\n   124→          category: body.category ?? 'general',\n   125→          description: body.description ?? '',\n   126→          scriptPath: body.scriptPath ?? '',\n   127→          inputSchema: body.inputSchema ?? null,\n   128→          outputSchema: body.outputSchema ?? null,\n   129→          requiresCredentialType: body.requiresCredentialType ?? null,\n   130→          implementationGuide: body.implementationGuide ?? null,\n   131→          isBuiltin: body.isBuiltin ?? false,\n   132→          createdAt: body.createdAt ?? now,\n   133→          updatedAt: now,\n   134→        };\n   135→        db.upsertToolDefinition(database, tool);\n   136→        json(res, 201, tool);\n   137→      }\n   138→      // --- Credentials ---\n   139→      else if (pathname === '/api/credentials' && req.method === 'POST' && database) {\n   140→        const body = JSON.parse(await readBody(req));\n   141→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   142→        const cred = db.createCredential(database, body);\n   143→        json(res, 201, cred);\n   144→      } else if (matchRoute(pathname, '/api/credentials/') && req.method === 'DELETE' && database) {\n   145→        const id = pathname!.replace('/api/credentials/', '');\n   146→        db.deleteCredential(database, id);\n   147→        json(res, 200, { deleted: true });\n   148→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/credentials') && req.method === 'GET' && database) {\n   149→        const id = pathname!.replace('/api/personas/', '').replace('/credentials', '');\n   150→        const creds = db.listCredentialsForPersona(database, id);\n   151→        // Strip encrypted data from response\n   152→        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   153→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/credentials') && req.method === 'POST' && database) {\n   154→        const id = pathname!.replace('/api/personas/', '').replace('/credentials', '');\n   155→        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   156→        db.linkCredential(database, id, body.credentialId);\n   157→        json(res, 200, { linked: true });\n   158→      }\n   159→      // --- Event Subscriptions ---\n   160→      else if (pathname === '/api/subscriptions' && req.method === 'POST' && database) {\n   161→        const body = JSON.parse(await readBody(req));\n   162→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   163→        const sub = db.createSubscription(database, body);\n   164→        json(res, 201, sub);\n   165→      } else if (matchRoute(pathname, '/api/subscriptions/') && req.method === 'PUT' && database) {\n   166→        const id = pathname!.replace('/api/subscriptions/', '');\n   167→        const body = JSON.parse(await readBody(req));\n   168→        db.updateSubscription(database, id, body);\n   169→        const updated = db.getSubscription(database, id);\n   170→        json(res, 200, updated);\n   171→      } else if (matchRoute(pathname, '/api/subscriptions/') && req.method === 'DELETE' && database) {\n   172→        const id = pathname!.replace('/api/subscriptions/', '');\n   173→        db.deleteSubscription(database, id);\n   174→        json(res, 200, { deleted: true });\n   175→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/subscriptions') && req.method === 'GET' && database) {\n   176→        const id = pathname!.replace('/api/personas/', '').replace('/subscriptions', '');\n   177→        json(res, 200, db.listSubscriptionsForPersona(database, id));\n   178→      }\n   179→      // --- Triggers ---\n   180→      else if (pathname === '/api/triggers' && req.method === 'POST' && database) {\n   181→        const body = JSON.parse(await readBody(req));\n   182→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   183→        const trigger = db.createTrigger(database, body);\n   184→        json(res, 201, trigger);\n   185→      } else if (matchRoute(pathname, '/api/triggers/') && req.method === 'PUT' && database) {\n   186→        const id = pathname!.replace('/api/triggers/', '');\n   187→        const body = JSON.parse(await readBody(req));\n   188→        db.updateTrigger(database, id, body);\n   189→        const updated = db.getTrigger(database, id);\n   190→        json(res, 200, updated);\n   191→      } else if (matchRoute(pathname, '/api/triggers/') && req.method === 'DELETE' && database) {\n   192→        const id = pathname!.replace('/api/triggers/', '');\n   193→        db.deleteTrigger(database, id);\n   194→        json(res, 200, { deleted: true });\n   195→      } else if (matchRoute(pathname, '/api/personas/') && pathname!.endsWith('/triggers') && req.method === 'GET' && database) {\n   196→        const id = pathname!.replace('/api/personas/', '').replace('/triggers', '');\n   197→        json(res, 200, db.listTriggersForPersona(database, id));\n   198→      }\n   199→      // --- Events ---\n   200→      else if (pathname === '/api/events' && req.method === 'GET' && database) {\n   201→        const params = new URLSearchParams(queryString || '');\n   202→        const events = db.listEvents(database, {\n   203→          eventType: params.get('eventType') ?? undefined,\n   204→          status: params.get('status') ?? undefined,\n   205→          limit: params.get('limit') ? parseInt(params.get('limit')!, 10) : 50,\n   206→          offset: params.get('offset') ? parseInt(params.get('offset')!, 10) : undefined,\n   207→          projectId: scopedProjectId,\n   208→        });\n   209→        json(res, 200, events);\n   210→      } else if (pathname === '/api/events' && req.method === 'POST' && database) {\n   211→        const body = JSON.parse(await readBody(req));\n   212→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   213→        const event = db.publishEvent(database, body);\n   214→        json(res, 201, event);\n   215→      } else if (matchRoute(pathname, '/api/events/') && req.method === 'PUT' && database) {\n   216→        const id = pathname!.replace('/api/events/', '');\n   217→        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n   218→        const updated = db.updateEventWithMetadata(database, id, body.status, body.metadata);\n   219→        if (updated) {\n   220→          json(res, 200, updated);\n   221→        } else {\n   222→          res.writeHead(404, { 'Content-Type': 'application/json' });\n   223→          res.end(JSON.stringify({ error: 'Event not found' }));\n   224→        }\n   225→      }\n   226→      // --- Webhooks ---\n   227→      else if (matchRoute(pathname, '/api/webhooks/') && req.method === 'POST' && database) {\n   228→        const personaId = pathname!.replace('/api/webhooks/', '');\n   229→        const body = await readBody(req);\n   230→        const event = db.publishEvent(database, {\n   231→          eventType: 'webhook_received',\n   232→          sourceType: 'webhook',\n   233→          sourceId: personaId,\n   234→          targetPersonaId: personaId,\n   235→          payload: body,\n   236→        });\n   237→        json(res, 201, event);\n   238→      }\n   239→      // --- GitLab Webhook ---\n   240→      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && database) {\n   241→        const body = await readBody(req);\n   242→        let parsed: Record<string, unknown> = {};\n   243→        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   244→        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   245→        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   246→        const event = db.publishEvent(database, {\n   247→          eventType: `gitlab_${objectKind}`,\n   248→          sourceType: 'gitlab',\n   249→          sourceId: projectPath ?? null,\n   250→          payload: body,\n   251→        });\n   252→        json(res, 201, event);\n   253→      }\n   254→      // --- Executions ---\n   255→      else if (pathname === '/api/executions' && req.method === 'GET' && database) {\n   256→        const params = new URLSearchParams(queryString || '');\n   257→        const executions = db.listExecutions(database, {\n   258→          personaId: params.get('personaId') ?? undefined,\n   259→          status: params.get('status') ?? undefined,\n   260→          limit: params.get('limit') ? parseInt(params.get('limit')!, 10) : 50,\n   261→          offset: params.get('offset') ? parseInt(params.get('offset')!, 10) : undefined,\n   262→          projectId: scopedProjectId,\n   263→        });\n   264→        json(res, 200, executions);\n   265→      }\n   266→      // --- Existing execution endpoints ---\n   267→      else if (pathname === '/api/status' && req.method === 'GET') {\n   268→        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   269→      } else if (pathname === '/api/execute' && req.method === 'POST') {\n   270→        await handleExecute(req, res, dispatcher, logger, ctx);\n   271→      } else if (matchRoute(pathname, '/api/executions/') && pathname!.endsWith('/cancel') && req.method === 'POST') {\n   272→        const executionId = pathname!.replace('/api/executions/', '').replace('/cancel', '');\n   273→        handleCancelExecution(res, dispatcher, executionId || '');\n   274→      } else if (matchRoute(pathname, '/api/executions/') && req.method === 'GET') {\n   275→        const executionId = pathname!.replace('/api/executions/', '');\n   276→        const params = new URLSearchParams(queryString || '');\n   277→        const offset = parseInt(params.get('offset') || '0', 10);\n   278→        handleGetExecution(res, dispatcher, executionId, offset);\n   279→      }\n   280→      // --- Admin-only routes ---\n   281→      else if (pathname === '/api/admin/users' && req.method === 'GET' && database) {\n   282→        if (requireAdmin(ctx, res)) return;\n   283→        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   284→      } else if (pathname === '/api/admin/personas' && req.method === 'GET' && database) {\n   285→        if (requireAdmin(ctx, res)) return;\n   286→        json(res, 200, db.listPersonas(database));\n   287→      } else if (pathname === '/api/admin/executions' && req.method === 'GET' && database) {\n   288→        if (requireAdmin(ctx, res)) return;\n   289→        const params = new URLSearchParams(queryString || '');\n   290→        json(res, 200, db.listExecutions(database, {\n   291→          limit: params.get('limit') ? parseInt(params.get('limit')!, 10) : 100,\n   292→          offset: params.get('offset') ? parseInt(params.get('offset')!, 10) : undefined,\n   293→        }));\n   294→      } else {\n   295→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   296→        res.end(JSON.stringify({ error: 'Not found' }));\n   297→      }\n   298→    } catch (err) {\n   299→      if (err instanceof Error && err.message === 'Payload too large') {\n   300→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   301→        res.end(JSON.stringify({ error: 'Payload too large' }));\n   302→        return;\n   303→      }\n   304→      logger.error({ err, url }, 'HTTP handler error');\n   305→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   306→      res.end(JSON.stringify({ error: 'Internal server error' }));\n   307→    }\n   308→  });\n   309→\n   310→  return server;\n   311→}\n   312→\n   313→function json(res: http.ServerResponse, status: number, data: unknown): void {\n   314→  res.writeHead(status, { 'Content-Type': 'application/json' });\n   315→  res.end(JSON.stringify(data));\n   316→}\n   317→\n   318→function matchRoute(pathname: string | undefined, prefix: string): boolean {\n   319→  return !!pathname && pathname.startsWith(prefix) && pathname.length > prefix.length;\n   320→}\n   321→\n   322→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   323→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   324→  if (ctx.authType !== 'admin') {\n   325→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   326→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   327→    return true;\n   328→  }\n   329→  return false;\n   330→}\n   331→\n   332→// --- OAuth handlers ---\n   333→\n   334→function handleOAuthAuthorize(res: http.ServerResponse, oauth: OAuthManager): void {\n   335→  const { url, state } = oauth.generateAuthUrl();\n   336→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   337→  res.end(JSON.stringify({\n   338→    authUrl: url,\n   339→    state,\n   340→    instructions: [\n   341→      '1. Open the authUrl in a browser',\n   342→      '2. Log in with your Anthropic account and authorize',\n   343→      '3. You will be redirected to a page showing an authorization code',\n   344→      '4. Copy the code from the URL (the \"code\" query parameter)',\n   345→      '5. POST it to /api/oauth/callback with { \"code\": \"...\", \"state\": \"...\" }',\n   346→    ],\n   347→  }));\n   348→}\n   349→\n   350→async function handleOAuthCallback(\n   351→  req: http.IncomingMessage,\n   352→  res: http.ServerResponse,\n   353→  oauth: OAuthManager,\n   354→  tokenManager: TokenManager,\n   355→  logger: Logger,\n   356→): Promise<void> {\n   357→  const body = await readBody(req);\n   358→  let parsed: { code?: string; state?: string };\n   359→\n   360→  try {\n   361→    parsed = JSON.parse(body);\n   362→  } catch {\n   363→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   364→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   365→    return;\n   366→  }\n   367→\n   368→  if (!parsed.code || !parsed.state) {\n   369→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   370→    res.end(JSON.stringify({ error: 'Missing required fields: code, state' }));\n   371→    return;\n   372→  }\n   373→\n   374→  const tokens = await oauth.exchangeCode(parsed.code, parsed.state);\n   375→  if (!tokens) {\n   376→    res.writeHead(401, { 'Content-Type': 'application/json' });\n   377→    res.end(JSON.stringify({ error: 'OAuth token exchange failed' }));\n   378→    return;\n   379→  }\n   380→\n   381→  // Also store the access token in TokenManager for backward compatibility\n   382→  tokenManager.storeClaudeToken(tokens.accessToken);\n   383→\n   384→  logger.info('OAuth flow completed, subscription connected');\n   385→\n   386→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   387→  res.end(JSON.stringify({\n   388→    status: 'connected',\n   389→    scopes: tokens.scopes,\n   390→    expiresAt: new Date(tokens.expiresAt).toISOString(),\n   391→  }));\n   392→}\n   393→\n   394→function handleOAuthStatus(res: http.ServerResponse, oauth: OAuthManager): void {\n   395→  const tokens = oauth.getTokens();\n   396→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   397→  res.end(JSON.stringify({\n   398→    connected: oauth.hasTokens(),\n   399→    scopes: tokens?.scopes || [],\n   400→    expiresAt: tokens ? new Date(tokens.expiresAt).toISOString() : null,\n   401→    isExpired: tokens ? Date.now() > tokens.expiresAt : null,\n   402→  }));\n   403→}\n   404→\n   405→async function handleOAuthRefresh(\n   406→  res: http.ServerResponse,\n   407→  oauth: OAuthManager,\n   408→  tokenManager: TokenManager,\n   409→  logger: Logger,\n   410→): Promise<void> {\n   411→  const tokens = await oauth.refreshAccessToken();\n   412→  if (!tokens) {\n   413→    res.writeHead(500, { 'Content-Type': 'application/json' });\n   414→    res.end(JSON.stringify({ error: 'Token refresh failed' }));\n   415→    return;\n   416→  }\n   417→\n   418→  tokenManager.storeClaudeToken(tokens.accessToken);\n   419→  logger.info('OAuth token refreshed via API');\n   420→\n   421→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   422→  res.end(JSON.stringify({\n   423→    status: 'refreshed',\n   424→    expiresAt: new Date(tokens.expiresAt).toISOString(),\n   425→  }));\n   426→}\n   427→\n   428→function handleOAuthDisconnect(\n   429→  res: http.ServerResponse,\n   430→  oauth: OAuthManager,\n   431→  tokenManager: TokenManager,\n   432→): void {\n   433→  oauth.clearTokens();\n   434→  tokenManager.clearToken();\n   435→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   436→  res.end(JSON.stringify({ status: 'disconnected' }));\n   437→}\n   438→\n   439→// --- Token injection (for setup-token / manual paste) ---\n   440→\n   441→async function handleSetToken(\n   442→  req: http.IncomingMessage,\n   443→  res: h