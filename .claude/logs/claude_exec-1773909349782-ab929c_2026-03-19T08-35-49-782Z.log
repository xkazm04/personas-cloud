er.error({ err, consecutiveDecryptionFailures }, 'Failed to decrypt Claude token');\n        return null;\n      }\n    },\n\n    hasToken(): boolean {\n      return storedToken !== null;\n    },\n\n    clearToken(): void {\n      storedToken = null;\n      consecutiveDecryptionFailures = 0;\n      logger.info('Claude token cleared');\n    },\n\n    getHealth(): { hasToken: boolean; consecutiveDecryptionFailures: number } {\n      return {\n        hasToken: storedToken !== null,\n        consecutiveDecryptionFailures,\n      };\n    },\n  };\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":682,"cache_read_input_tokens":19844,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":682},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b1918db3-404e-4a21-ad71-d84694ad33d6","uuid":"24b516ab-2e10-42af-a068-5e5e07e40572"}
