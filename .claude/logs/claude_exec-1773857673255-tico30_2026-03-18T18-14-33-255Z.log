[2026-03-18T18:16:26.304Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GxsFX2sM7Xs3DxSfCT2cuB","type":"tool_result","content":"     1→import { type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type PhaseTimings, type EncryptedPayload, TOPICS, decrypt, DecryptionError, deriveMasterKeyAsync } from '@dac-cloud/shared';\n     2→import type Database from 'better-sqlite3';\n     3→import type { WorkerPool } from './workerPool.js';\n     4→import type { TokenManager } from './tokenManager.js';\n     5→import type { OAuthManager } from './oauth.js';\n     6→import type { KafkaClient } from './kafka.js';\n     7→import type { TenantDbManager } from './tenantDbManager.js';\n     8→import type { TenantKeyManager } from './tenantKeyManager.js';\n     9→import type { AuditLog } from './auditLog.js';\n    10→import type { Logger } from 'pino';\n    11→import * as db from './db/index.js';\n    12→import { resolveToken, ExecutionPreparer, type Decryptor } from './dispatchPipeline.js';\n    13→\n    14→interface QueuedExecution {\n    15→  request: ExecRequest;\n    16→  receivedAt: number;\n    17→}\n    18→\n    19→// Maximum number of times an execution will be re-queued after worker disconnect\n    20→const MAX_DISCONNECT_RETRIES = 2;\n    21→\n    22→/** All valid execution statuses. */\n    23→type ExecutionStatus = 'queued' | 'running' | 'completed' | 'failed' | 'cancelled';\n    24→\n    25→/** What triggered a state transition. */\n    26→type TransitionTrigger =\n    27→  | 'submit'\n    28→  | 'dispatch'\n    29→  | 'complete'\n    30→  | 'busy-nack'\n    31→  | 'disconnect-retry'\n    32→  | 'disconnect-exhausted'\n    33→  | 'assign-failure';\n    34→\n    35→// In-memory tracking for active executions (real-time output streaming)\n    36→interface ActiveExecution {\n    37→  workerId: string;\n    38→  startedAt: number;\n    39→  output: string[];\n    40→  status: 'running' | 'completed' | 'failed' | 'cancelled';\n    41→  progress?: ProgressInfo;\n    42→  completedAt?: number;\n    43→  exitCode?: number;\n    44→  durationMs?: number;\n    45→  sessionId?: string;\n    46→  totalCostUsd?: number;\n    47→  phaseTimings?: PhaseTimings;\n    48→  /** Original request kept for re-queuing on worker disconnect. Only present for in-flight executions. */\n    49→  request?: ExecRequest;\n    50→  /** How many times this execution has been re-queued after a worker disconnect. */\n    51→  disconnectRetries?: number;\n    52→}\n    53→\n    54→const OUTPUT_FLUSH_INTERVAL_MS = 500;\n    55→\n    56→export class Dispatcher {\n    57→  private queue: QueuedExecution[] = [];\n    58→  // In-memory map for real-time output + cancel routing (active executions only)\n    59→  private active = new Map<string, ActiveExecution>();\n    60→  private tenantDbManager: TenantDbManager | null = null;\n    61→  private masterKey: Buffer | null = null;\n    62→  private tenantKeyManager: TenantKeyManager | null = null;\n    63→  private auditLog: AuditLog | null = null;\n    64→  private preparer: ExecutionPreparer | null = null;\n    65→  // Maps executionId → projectId for DB resolution during callbacks\n    66→  private executionTenant = new Map<string, string>();\n    67→  // Batched output buffers: executionId → pending chunks\n    68→  private outputBuffers = new Map<string, string[]>();\n    69→  private outputFlushTimer: NodeJS.Timeout;\n    70→  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n    71→  private dispatching = false;\n    72→\n    73→  constructor(\n    74→    private pool: WorkerPool,\n    75→    private tokenManager: TokenManager,\n    76→    private oauth: OAuthManager | null,\n    77→    private kafka: KafkaClient,\n    78→    private logger: Logger,\n    79→  ) {\n    80→    // Periodic flush of batched output to DB\n    81→    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n    82→\n    83→    // When a worker becomes ready, try to dispatch queued work\n    84→    this.pool.on('worker-ready', () => {\n    85→      this.processQueue();\n    86→    });\n    87→\n    88→    // When a worker connects, try to dispatch\n    89→    this.pool.on('worker-connected', () => {\n    90→      this.processQueue();\n    91→    });\n    92→\n    93→    // Track stdout for execution output\n    94→    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n    95→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    96→    });\n    97→\n    98→    // Track stderr for debugging failed executions\n    99→    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n   100→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n   101→      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n   102→    });\n   103→\n   104→    // Handle execution completion\n   105→    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n   106→      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   107→        executionId: msg.executionId,\n   108→        status: msg.status,\n   109→        exitCode: msg.exitCode,\n   110→        durationMs: msg.durationMs,\n   111→        sessionId: msg.sessionId,\n   112→        totalCostUsd: msg.totalCostUsd,\n   113→        ...(msg.phaseTimings ? { phaseTimings: msg.phaseTimings } : {}),\n   114→      }), msg.executionId).catch(err => {\n   115→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n   116→      });\n   117→\n   118→      // Flush any remaining buffered output before persisting completion\n   119→      this.flushOutputForExecution(msg.executionId);\n   120→\n   121→      // Update in-memory\n   122→      const exec = this.active.get(msg.executionId);\n   123→      const terminalStatus: ExecutionStatus = msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed';\n   124→      this.logTransition({\n   125→        executionId: msg.executionId,\n   126→        previousState: 'running',\n   127→        newState: terminalStatus,\n   128→        trigger: 'complete',\n   129→        workerId: exec?.workerId,\n   130→        disconnectRetries: exec?.disconnectRetries ?? 0,\n   131→      });\n   132→      if (exec) {\n   133→        exec.status = msg.status;\n   134→        exec.completedAt = Date.now();\n   135→        exec.exitCode = msg.exitCode;\n   136→        exec.durationMs = msg.durationMs;\n   137→        exec.sessionId = msg.sessionId;\n   138→        exec.totalCostUsd = msg.totalCostUsd;\n   139→        exec.phaseTimings = msg.phaseTimings;\n   140→        // Remove from active after a short delay (allow polling to pick up final state)\n   141→        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n   142→      }\n   143→\n   144→      // Persist to DB\n   145→      const completeDb = this.resolveDbForExecution(msg.executionId);\n   146→      if (completeDb) {\n   147→        try {\n   148→          db.updateExecution(completeDb, msg.executionId, {\n   149→            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n   150→            completedAt: new Date().toISOString(),\n   151→            durationMs: msg.durationMs,\n   152→            claudeSessionId: msg.sessionId,\n   153→            costUsd: msg.totalCostUsd ?? 0,\n   154→          });\n   155→        } catch (err) {\n   156→          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n   157→        }\n   158→      }\n   159→\n   160→      // Clean up tenant mapping after completion delay\n   161→      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n   162→\n   163→      // Process next queued item\n   164→      this.processQueue();\n   165→    });\n   166→\n   167→    // Track execution progress\n   168→    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n   169→      const exec = this.active.get(msg.executionId);\n   170→      if (exec) {\n   171→        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n   172→      }\n   173→      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n   174→        executionId: msg.executionId,\n   175→        phase: msg.phase,\n   176→        percent: msg.percent,\n   177→        detail: msg.detail,\n   178→        timestamp: msg.timestamp,\n   179→      }), msg.executionId).catch(err => {\n   180→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n   181→      });\n   182→    });\n   183→\n   184→    // Forward persona events to Kafka\n   185→    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n   186→      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n   187→        executionId: msg.executionId,\n   188→        eventType: msg.eventType,\n   189→        payload: msg.payload,\n   190→        timestamp: Date.now(),\n   191→      }), msg.executionId).catch(err => {\n   192→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n   193→      });\n   194→    });\n   195→\n   196→    // Handle worker busy nack — re-queue the rejected execution\n   197→    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n   198→      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n   199→      const exec = this.active.get(msg.executionId);\n   200→      if (exec?.request) {\n   201→        const request = exec.request;\n   202→        this.logTransition({\n   203→          executionId: msg.executionId,\n   204→          previousState: 'running',\n   205→          newState: 'queued',\n   206→          trigger: 'busy-nack',\n   207→          workerId: _workerId,\n   208→          personaId: request.personaId,\n   209→          disconnectRetries: exec.disconnectRetries ?? 0,\n   210→        });\n   211→        this.active.delete(msg.executionId);\n   212→        // Mark as queued in DB\n   213→        const reqDb = this.resolveDbForExecution(msg.executionId);\n   214→        if (reqDb) {\n   215→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack'); }\n   216→        }\n   217→        this.queue.unshift({ request, receivedAt: Date.now() });\n   218→        this.processQueue();\n   219→      } else {\n   220→        // Fallback: reconstruct from DB if request was not stored (should not happen)\n   221→        this.logTransition({\n   222→          executionId: msg.executionId,\n   223→          previousState: 'running',\n   224→          newState: 'queued',\n   225→          trigger: 'busy-nack',\n   226→          workerId: _workerId,\n   227→        });\n   228→        this.active.delete(msg.executionId);\n   229→        const projectId = this.executionTenant.get(msg.executionId) || 'default';\n   230→        const reqDb = this.resolveDb(projectId);\n   231→        if (reqDb) {\n   232→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack fallback'); }\n   233→        }\n   234→        const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n   235→        if (dbExec) {\n   236→          this.queue.unshift({\n   237→            request: {\n   238→              executionId: msg.executionId,\n   239→              personaId: dbExec.personaId,\n   240→              prompt: dbExec.inputData || '',\n   241→              projectId,\n   242→              config: { timeoutMs: 300_000 },\n   243→            },\n   244→            receivedAt: Date.now(),\n   245→          });\n   246→          this.processQueue();\n   247→        }\n   248→      }\n   249→    });\n   250→\n   251→    // Handle worker disconnect during execution — re-queue if retries remain\n   252→    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n   253→      if (executionId) {\n   254→        const exec = this.active.get(executionId);\n   255→        const retries = exec?.disconnectRetries ?? 0;\n   256→\n   257→        if (exec?.request && retries < MAX_DISCONNECT_RETRIES) {\n   258→          // Re-queue for retry\n   259→          const nextRetry = retries + 1;\n   260→          this.logTransition({\n   261→            executionId,\n   262→            previousState: 'running',\n   263→            newState: 'queued',\n   264→            trigger: 'disconnect-retry',\n   265→            workerId: _workerId,\n   266→            personaId: exec.request.personaId,\n   267→            disconnectRetries: nextRetry,\n   268→            errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n   269→          });\n   270→\n   271→          // Clear the active entry so dispatchToWorker can create a fresh one\n   272→          this.active.delete(executionId);\n   273→\n   274→          // Mark as queued in DB\n   275→          const disconnDb = this.resolveDbForExecution(executionId);\n   276→          if (disconnDb) {\n   277→            try {\n   278→              db.updateExecution(disconnDb, executionId, {\n   279→                status: 'queued',\n   280→                errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n   281→              });\n   282→            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on worker disconnect re-queue'); }\n   283→          }\n   284→\n   285→          // Temporarily store the retry count so dispatchToWorker picks it up\n   286→          const request = exec.request;\n   287→          // Create a placeholder active entry to carry retry count across re-dispatch\n   288→          this.active.set(executionId, {\n   289→            workerId: '',\n   290→            startedAt: 0,\n   291→            output: [],\n   292→            status: 'running',\n   293→            request,\n   294→            disconnectRetries: nextRetry,\n   295→          });\n   296→\n   297→          this.queue.unshift({ request, receivedAt: Date.now() });\n   298→          this.processQueue();\n   299→        } else {\n   300→          // Retries exhausted or no request stored — permanent failure\n   301→          this.logTransition({\n   302→            executionId,\n   303→            previousState: 'running',\n   304→            newState: 'failed',\n   305→            trigger: 'disconnect-exhausted',\n   306→            workerId: _workerId,\n   307→            disconnectRetries: retries,\n   308→            errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n   309→          });\n   310→          if (exec) {\n   311→            exec.status = 'failed';\n   312→            exec.completedAt = Date.now();\n   313→            setTimeout(() => this.active.delete(executionId), 30_000);\n   314→          }\n   315→\n   316→          const disconnDb = this.resolveDbForExecution(executionId);\n   317→          if (disconnDb) {\n   318→            try {\n   319→              db.updateExecution(disconnDb, executionId, {\n   320→                status: 'failed',\n   321→                errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n   322→                completedAt: new Date().toISOString(),\n   323→              });\n   324→            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:failed' }, 'Failed to persist execution failure on worker disconnect'); }\n   325→          }\n   326→          this.executionTenant.delete(executionId);\n   327→\n   328→          this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   329→            executionId,\n   330→            status: 'failed',\n   331→            error: 'Worker disconnected (retries exhausted)',\n   332→            durationMs: 0,\n   333→          }), executionId).catch(err => { this.logger.warn({ err, executionId, op: 'kafka:exec_lifecycle' }, 'Failed to produce disconnect failure lifecycle to Kafka'); });\n   334→        }\n   335→      }\n   336→    });\n   337→  }\n   338→\n   339→  setTenantDbManager(mgr: TenantDbManager): void {\n   340→    this.tenantDbManager = mgr;\n   341→  }\n   342→\n   343→  async setMasterKey(masterKeyHex: string): Promise<void> {\n   344→    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n   345→  }\n   346→\n   347→  setTenantKeyManager(mgr: TenantKeyManager): void {\n   348→    this.tenantKeyManager = mgr;\n   349→  }\n   350→\n   351→  setAuditLog(log: AuditLog): void {\n   352→    this.auditLog = log;\n   353→  }\n   354→\n   355→  /** Resolve the database for a given projectId via tenant DB manager. */\n   356→  private resolveDb(projectId?: string): Database.Database | null {\n   357→    if (this.tenantDbManager && projectId) {\n   358→      return this.tenantDbManager.getTenantDb(projectId);\n   359→    }\n   360→    return null;\n   361→  }\n   362→\n   363→  /** Resolve the database for an in-flight execution by its ID. */\n   364→  private resolveDbForExecution(executionId: string): Database.Database | null {\n   365→    const projectId = this.executionTenant.get(executionId);\n   366→    return this.resolveDb(projectId);\n   367→  }\n   368→\n   369→  /**\n   370→   * Emit a single structured log entry for every execution state transition.\n   371→   * Creates a queryable timeline: grep for \"Execution state transition\" to see\n   372→   * the full lifecycle of any execution.\n   373→   */\n   374→  private logTransition(opts: {\n   375→    executionId: string;\n   376→    previousState: ExecutionStatus | null;\n   377→    newState: ExecutionStatus;\n   378→    trigger: TransitionTrigger;\n   379→    workerId?: string;\n   380→    personaId?: string;\n   381→    queueWaitMs?: number;\n   382→    disconnectRetries?: number;\n   383→    errorMessage?: string;\n   384→  }): void {\n   385→    this.logger.info({\n   386→      executionId: opts.executionId,\n   387→      previousState: opts.previousState,\n   388→      newState: opts.newState,\n   389→      trigger: opts.trigger,\n   390→      ...(opts.workerId ? { workerId: opts.workerId } : {}),\n   391→      ...(opts.personaId ? { personaId: opts.personaId } : {}),\n   392→      ...(opts.queueWaitMs !== undefined ? { queueWaitMs: opts.queueWaitMs } : {}),\n   393→      ...(opts.disconnectRetries !== undefined ? { disconnectRetries: opts.disconnectRetries } : {}),\n   394→      ...(opts.errorMessage ? { errorMessage: opts.errorMessage } : {}),\n   395→    }, 'Execution state transition');\n   396→  }\n   397→\n   398→  /**\n   399→   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   400→   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   401→   */\n   402→  private async decryptWithAudit(\n   403→    payload: EncryptedPayload,\n   404→    tenantId: string,\n   405→    resourceId: string,\n   406→    logContext: Record<string, unknown>,\n   407→    logMessage: string,\n   408→  ): Promise<string | undefined> {\n   409→    const decryptKey = this.tenantKeyManager\n   410→      ? await this.tenantKeyManager.getKey(tenantId)\n   411→      : this.masterKey;\n   412→    if (!decryptKey) return undefined;\n   413→\n   414→    try {\n   415→      const decrypted = decrypt(payload, decryptKey, { tenantId, credentialId: resourceId, resourceType: 'credential' });\n   416→      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n   417→      return decrypted;\n   418→    } catch (err) {\n   419→      const reason = err instanceof DecryptionError ? err.message : (err instanceof Error ? err.message : String(err));\n   420→      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n   421→      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: { reason } }); } catch { /* logged inside record() */ }\n   422→      return undefined;\n   423→    }\n   424→  }\n   425→\n   426→  submit(request: ExecRequest): void {\n   427→    this.logger.info({\n   428→      executionId: request.executionId,\n   429→      personaId: request.personaId,\n   430→      ...(request.eventId ? { eventId: request.eventId } : {}),\n   431→    }, 'Execution submitted');\n   432→\n   433→    // Track which tenant owns this execution (for callback DB resolution)\n   434→    const projectId = request.projectId || 'default';\n   435→    this.executionTenant.set(request.executionId, projectId);\n   436→\n   437→    // Create DB record immediately\n   438→    const submitDb = this.resolveDb(projectId);\n   439→    if (submitDb) {\n   440→      try {\n   441→        db.createExecution(submitDb, {\n   442→          id: request.executionId,\n   443→          personaId: request.personaId,\n   444→          inputData: request.prompt,\n   445→          projectId,\n   446→          eventId: request.eventId ?? null,\n   447→        });\n   448→      } catch (err) {\n   449→        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n   450→      }\n   451→    }\n   452→\n   453→    this.logTransition({\n   454→      executionId: request.executionId,\n   455→      previousState: null,\n   456→      newState: 'queued',\n   457→      trigger: 'submit',\n   458→      personaId: request.personaId,\n   459→      disconnectRetries: 0,\n   460→    });\n   461→\n   462→    this.queue.push({ request, receivedAt: Date.now() });\n   463→    this.processQueue();\n   464→  }\n   465→\n   466→  private async processQueue(): Promise<void> {\n   467→    // Guard: only one processQueue loop runs at a time to prevent concurrent\n   468→    // calls from racing on getIdleWorker()/assign() and double-claiming a worker.\n   469→    if (this.dispatching) return;\n   470→    this.dispatching = true;\n   471→    try {\n   472→      while (this.queue.length > 0) {\n   473→        const workerId = this.pool.getIdleWorker();\n   474→        if (!workerId) {\n   475→          this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n   476→          return;\n   477→        }\n   478→\n   479→        const item = this.queue.shift()!;\n   480→        await this.dispatchToWorker(workerId, item.request, item.receivedAt);\n   481→      }\n   482→    } finally {\n   483→      this.dispatching = false;\n   484→    }\n   485→  }\n   486→\n   487→  /** Exposes decryptWithAudit as the Decryptor interface for pipeline stages. */\n   488→  private getDecryptor(): Decryptor {\n   489→    return {\n   490→      decrypt: (payload, tenantId, resourceId, logContext, logMessage) =>\n   491→        this.decryptWithAudit(payload, tenantId, resourceId, logContext, logMessage),\n   492→    };\n   493→  }\n   494→\n   495→  /** Lazily initialise the ExecutionPreparer (depends on mutable setter state). */\n   496→  private ensurePreparer(): ExecutionPreparer {\n   497→    if (!this.preparer) {\n   498→      this.preparer = new ExecutionPreparer(\n   499→        (projectId) => this.resolveDb(projectId),\n   500→        this.getDecryptor(),\n   501→        this.logger,\n   502→      );\n   503→    }\n   504→    return this.preparer;\n   505→  }\n   506→\n   507→  private async dispatchToWorker(workerId: string, request: ExecRequest, queuedAt?: number): Promise<void> {\n   508→    const dispatchStartMs = Date.now();\n   509→    const queueWaitMs = queuedAt !== undefined ? dispatchStartMs - queuedAt : undefined;\n   510→\n   511→    // Stage 1: Resolve token (stays in Dispatcher)\n   512→    const tokenStartMs = Date.now();\n   513→    const token = await resolveToken(this.oauth, this.tokenManager);\n   514→    const tokenResolveMs = Date.now() - tokenStartMs;\n   515→    if (!token) {\n   516→      this.logger.error({ executionId: request.executionId, tokenResolveMs }, 'No Claude token available, re-queuing execution');\n   517→      this.queue.unshift({ request, receivedAt: Date.now() });\n   518→      return;\n   519→    }\n   520→\n   521→    // Stages 2-4: Persona resolution, payload assembly, assignment building\n   522→    const prepareStartMs = Date.now();\n   523→    const assignment = await this.ensurePreparer().prepare(request, token);\n   524→    const prepareDurationMs = Date.now() - prepareStartMs;\n   525→    const tenantId = request.projectId || 'default';\n   526→    const dispatchDb = this.resolveDb(tenantId);\n   527→\n   528→    // Track in-memory for real-time streaming (preserve retry count across re-dispatches)\n   529→    const prevRetries = this.active.get(request.executionId)?.disconnectRetries ?? 0;\n   530→    this.active.set(request.executionId, {\n   531→      workerId,\n   532→      startedAt: Date.now(),\n   533→      output: [],\n   534→      status: 'running',\n   535→      request,\n   536→      disconnectRetries: prevRetries,\n   537→    });\n   538→\n   539→    // Mark running in DB\n   540→    if (dispatchDb) {\n   541→      try {\n   542→        db.updateExecution(dispatchDb, request.executionId, {\n   543→          status: 'running',\n   544→          startedAt: new Date().toISOString(),\n   545→        });\n   546→      } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:running' }, 'Failed to mark execution as running in DB'); }\n   547→    }\n   548→\n   549→    const sent = this.pool.assign(workerId, assignment);\n   550→    const totalDispatchMs = Date.now() - dispatchStartMs;\n   551→    if (!sent) {\n   552→      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n   553→      this.active.delete(request.executionId);\n   554→      if (dispatchDb) {\n   555→        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:queued' }, 'Failed to re-queue execution in DB after assign failure'); }\n   556→      }\n   557→      this.logTransition({\n   558→        executionId: request.executionId,\n   559→        previousState: 'running',\n   560→        newState: 'queued',\n   561→        trigger: 'assign-failure',\n   562→        workerId,\n   563→        personaId: request.personaId,\n   564→        disconnectRetries: prevRetries,\n   565→      });\n   566→      this.queue.unshift({ request, receivedAt: Date.now() });\n   567→      this.processQueue();\n   568→    } else {\n   569→      this.logTransition({\n   570→        executionId: request.executionId,\n   571→        previousState: 'queued',\n   572→        newState: 'running',\n   573→        trigger: 'dispatch',\n   574→        workerId,\n   575→        personaId: request.personaId,\n   576→        queueWaitMs,\n   577→        disconnectRetries: prevRetries,\n   578→      });\n   579→    }\n   580→\n   581→    // Emit dispatch latency metrics for observability\n   582→    this.logger.info({\n   583→      executionId: request.executionId,\n   584→      personaId: request.personaId,\n   585→      workerId,\n   586→      queueWaitMs,\n   587→      tokenResolveMs,\n   588→      prepareDurationMs,\n   589→      totalDispatchMs,\n   590→    }, 'Dispatch latency');\n   591→  }\n   592→\n   593→  cancelExecution(executionId: string): boolean {\n   594→    const exec = this.active.get(executionId);\n   595→    if (!exec || exec.status !== 'running') return false;\n   596→\n   597→    return this.pool.send(exec.workerId, {\n   598→      type: 'cancel',\n   599→      executionId,\n   600→    });\n   601→  }\n   602→\n   603→  getQueueLength(): number {\n   604→    return this.queue.length;\n   605→  }\n   606→\n   607→  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n   608→    return Array.from(this.active.entries())\n   609→      .filter(([, e]) => e.status === 'running')\n   610→      .map(([executionId, e]) => ({\n   611→        executionId,\n   612→        workerId: e.workerId,\n   613→        startedAt: e.startedAt,\n   614→      }));\n   615→  }\n   616→\n   617→  /**\n   618→   * Get execution state. Tries in-memory first (for real-time output),\n   619→   * then falls back to DB for completed/historical executions.\n   620→   */\n   621→  getExecution(executionId: string): ActiveExecution | null {\n   622→    // Check in-memory active executions first\n   623→    const active = this.active.get(executionId);\n   624→    if (active) return active;\n   625→\n   626→    const execDb = this.resolveDbForExecution(executionId);\n   627→    if (execDb) {\n   628→      const dbExec = db.getExecution(execDb, executionId);\n   629→      if (dbExec) {\n   630→        return {\n   631→          workerId: '',\n   632→          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n   633→          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n   634→          status: dbExec.status as ActiveExecution['status'],\n   635→          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n   636→          durationMs: dbExec.durationMs ?? undefined,\n   637→          sessionId: dbExec.claudeSessionId ?? undefined,\n   638→          totalCostUsd: dbExec.costUsd ?? undefined,\n   639→        };\n   640→      }\n   641→    }\n   642→\n   643→    return null;\n   644→  }\n   645→\n   646→  getExecutionOutput(executionId: string): string[] | null {\n   647→    const exec = this.getExecution(executionId);\n   648→    return exec?.output ?? null;\n   649→  }\n   650→\n   651→  /** Shared handler for stdout/stderr output chunks. */\n   652→  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n   653→    const line = prefix ? `${prefix}${chunk}` : chunk;\n   654→\n   655→    const exec = this.active.get(executionId);\n   656→    if (exec) {\n   657→      exec.output.push(line);\n   658→    }\n   659→\n   660→    this.bufferOutput(executionId, line + '\\n');\n   661→\n   662→    // Forward stdout to Kafka (stderr is not forwarded)\n   663→    if (!prefix) {\n   664→      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n   665→        executionId,\n   666→        chunk,\n   667→        timestamp,\n   668→      }), executionId).catch(err => {\n   669→        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n   670→      });\n   671→    }\n   672→  }\n   673→\n   674→  /** Buffer an output chunk for batched DB write. */\n   675→  private bufferOutput(executionId: string, chunk: string): void {\n   676→    let buf = this.outputBuffers.get(executionId);\n   677→    if (!buf) {\n   678→      buf = [];\n   679→      this.outputBuffers.set(executionId, buf);\n   680→    }\n   681→    buf.push(chunk);\n   682→  }\n   683→\n   684→  /** Flush buffered output for a specific execution to DB. */\n   685→  private flushOutputForExecution(executionId: string): void {\n   686→    const buf = this.outputBuffers.get(executionId);\n   687→    if (!buf || buf.length === 0) return;\n   688→\n   689→    const combined = buf.join('');\n   690→    this.outputBuffers.delete(executionId);\n   691→\n   692→    const outputDb = this.resolveDbForExecution(executionId);\n   693→    if (outputDb) {\n   694→      try { db.appendOutput(outputDb, executionId, combined); } catch (err) { this.logger.warn({ err, executionId, op: 'appendOutput' }, 'Failed to flush buffered output to DB'); }\n   695→    }\n   696→  }\n   697→\n   698→  /** Flush all buffered output across all executions to DB. */\n   699→  private flushOutputBuffers(): void {\n   700→    for (const executionId of this.outputBuffers.keys()) {\n   701→      this.flushOutputForExecution(executionId);\n   702→    }\n   703→  }\n   704→\n   705→  shutdown(): void {\n   706→    clearInterval(this.outputFlushTimer);\n   707→    this.flushOutputBuffers();\n   708→  }\n   709→}\n   710→"}]},"parent_tool_use_id":"toolu_016SGayCjxtc2mgzmwb8cBfB","session_id":"64cd9914-080b-4c5f-8e7c-a4c26f3db306","uuid":"0258f38b-b206-4705-889a-f45ad3a03ab0","timestamp":"2026-03-18T18:16:26.222Z"}
