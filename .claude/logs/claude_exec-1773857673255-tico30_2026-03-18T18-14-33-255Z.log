[2026-03-18T18:16:33.594Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H7iDS4XYj6YGT3V5HPdUd5","type":"tool_result","content":"     1→// ---------------------------------------------------------------------------\n     2→// Dispatch pipeline — composable stages for worker dispatch\n     3→//\n     4→// Each stage is a standalone async function with typed inputs/outputs,\n     5→// independently testable without mocking the entire Dispatcher.\n     6→//\n     7→// Pipeline: ResolveToken → ResolvePersona → AssemblePayload → BuildAssignment\n     8→// ---------------------------------------------------------------------------\n     9→\n    10→import type { ExecAssign, ExecRequest, NetworkPolicy, Persona, PersonaToolDefinition, EncryptedPayload } from '@dac-cloud/shared';\n    11→import { assemblePrompt, resolveEnvOverrides, toEncryptedPayload, parseNetworkPolicy } from '@dac-cloud/shared';\n    12→import type Database from 'better-sqlite3';\n    13→import type { TokenManager } from './tokenManager.js';\n    14→import type { OAuthManager } from './oauth.js';\n    15→import type { Logger } from 'pino';\n    16→import * as db from './db/index.js';\n    17→\n    18→// ========================== Stage result types =============================\n    19→\n    20→export interface TokenResult {\n    21→  claudeToken: string;\n    22→}\n    23→\n    24→export interface PersonaResolution {\n    25→  persona: Persona | null;\n    26→  tools: PersonaToolDefinition[];\n    27→  credentialHints: string[];\n    28→  credentialEnv: Record<string, string>;\n    29→  inferenceEnvSet: Record<string, string>;\n    30→  inferenceEnvRemove: string[];\n    31→}\n    32→\n    33→export interface AssembledPayload {\n    34→  prompt: string;\n    35→  env: Record<string, string>;\n    36→  networkPolicy: NetworkPolicy | undefined;\n    37→  maxBudgetUsd: number | null;\n    38→  maxTurns: number | null;\n    39→}\n    40→\n    41→// ========================= Dependency interfaces ===========================\n    42→\n    43→/** Minimal decryption capability — abstracts master/tenant key resolution. */\n    44→export interface Decryptor {\n    45→  decrypt(\n    46→    payload: EncryptedPayload,\n    47→    tenantId: string,\n    48→    resourceId: string,\n    49→    logContext: Record<string, unknown>,\n    50→    logMessage: string,\n    51→  ): Promise<string | undefined>;\n    52→}\n    53→\n    54→// =========================== Stage 1: Token ================================\n    55→\n    56→export async function resolveToken(\n    57→  oauth: OAuthManager | null,\n    58→  tokenManager: TokenManager,\n    59→): Promise<TokenResult | null> {\n    60→  let claudeToken: string | null = null;\n    61→\n    62→  if (oauth?.hasTokens()) {\n    63→    claudeToken = await oauth.getValidAccessToken();\n    64→    if (claudeToken) {\n    65→      tokenManager.storeClaudeToken(claudeToken);\n    66→    }\n    67→  }\n    68→\n    69→  if (!claudeToken) {\n    70→    claudeToken = tokenManager.getClaudeToken();\n    71→  }\n    72→\n    73→  return claudeToken ? { claudeToken } : null;\n    74→}\n    75→\n    76→// ========================== Stage 2: Persona ===============================\n    77→\n    78→export async function resolvePersona(\n    79→  dispatchDb: Database.Database | null,\n    80→  personaId: string,\n    81→  tenantId: string,\n    82→  decryptor: Decryptor,\n    83→  logger: Logger,\n    84→): Promise<PersonaResolution> {\n    85→  const empty: PersonaResolution = {\n    86→    persona: null,\n    87→    tools: [],\n    88→    credentialHints: [],\n    89→    credentialEnv: {},\n    90→    inferenceEnvSet: {},\n    91→    inferenceEnvRemove: [],\n    92→  };\n    93→\n    94→  if (!dispatchDb) return empty;\n    95→\n    96→  const persona = db.getPersona(dispatchDb, personaId);\n    97→  if (!persona) return empty;\n    98→\n    99→  const tools = db.getToolsForPersona(dispatchDb, persona.id);\n   100→  const creds = db.listCredentialsForPersona(dispatchDb, persona.id);"}]},"parent_tool_use_id":"toolu_016SGayCjxtc2mgzmwb8cBfB","session_id":"64cd9914-080b-4c5f-8e7c-a4c26f3db306","uuid":"118585c5-0146-4d7c-8867-fd6c82620ace","timestamp":"2026-03-18T18:16:33.514Z"}
