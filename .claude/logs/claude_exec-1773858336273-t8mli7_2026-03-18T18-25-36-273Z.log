EVICT_CHECK_MS);\n    48→  }\n    49→\n    50→  /**\n    51→   * Register a callback invoked when a new tenant is first registered.\n    52→   */\n    53→  setTenantCreatedCallback(cb: TenantCreatedCallback): void {\n    54→    this.onTenantCreated = cb;\n    55→  }\n    56→\n    57→  getSystemDb(): Database.Database {\n    58→    return this.systemDb;\n    59→  }\n    60→\n    61→  /**\n    62→   * Get (or create) a tenant-specific database.\n    63→   * Automatically registers the tenant in system.db on first access.\n    64→   */\n    65→  getTenantDb(projectId: string): Database.Database {\n    66→    const cached = this.tenantDbs.get(projectId);\n    67→    if (cached) {\n    68→      cached.lastAccess = Date.now();\n    69→      return cached.db;\n    70→    }\n    71→\n    72→    // Create/open tenant DB\n    73→    const hash = this.hashProjectId(projectId);\n    74→    const dbPath = path.join(this.tenantsDir, `${hash}.db`);\n    75→    const db = initTenantDb(dbPath, this.logger);\n    76→\n    77→    this.tenantDbs.set(projectId, { db, lastAccess: Date.now() });\n    78→\n    79→    // Register in system DB if not already present\n    80→    this.registerTenant(projectId);\n    81→\n    82→    this.logger.info({ projectId, dbPath }, 'Tenant database opened');\n    83→    return db;\n    84→  }\n    85→\n    86→  /**\n    87→   * List all registered tenant IDs from the system DB.\n    88→   */\n    89→  listTenantIds(): string[] {\n    90→    const rows = this.systemDb\n    91→      .prepare('SELECT id FROM tenants ORDER BY id')\n    92→      .all() as Array<{ id: string }>;\n    93→    return rows.map(r => r.id);\n    94→  }\n    95→\n    96→  /**\n    97→   * Execute a function against every tenant's database.\n    98→   * Opens DBs as needed (and caches them).\n    99→   */\n   100→  forEachTenant(fn: (db: Database.Database, projectId: string) => void): void {\n   101→    const ids = this.listTenantIds();\n   102→    for (const id of ids) {\n   103→    