em-wide metrics aggregation failed');\n   134→  }\n   135→}\n   136→\n   137→/**\n   138→ * Map-reduce step: read daily_metrics from every tenant DB and write\n   139→ * a system-wide summary to the system_daily_metrics table in system.db.\n   140→ * Replaces rows wholesale each run so the system view is always consistent.\n   141→ */\n   142→function aggregateSystemMetrics(\n   143→  tenantDbManager: TenantDbManager,\n   144→  logger: Logger,\n   145→): void {\n   146→  const systemDb = tenantDbManager.getSystemDb();\n   147→  const tenantIds = tenantDbManager.listTenantIds();\n   148→\n   149→  // Accumulate per-day totals across all tenants\n   150→  const dayMap = new Map<string, {\n   151→    total_executions: number;\n   152→    completed: number;\n   153→    failed: number;\n   154→    total_cost_usd: number;\n   155→    total_duration_ms: number;\n   156→    tenant_count: number;\n   157→  }>();\n   158→\n   159→  for (const projectId of tenantIds) {\n   160→    try {\n   161→      const db = tenantDbManager.getTenantDb(projectId);\n   162→      const rows = db.prepare(\n   163→        'SELECT date, total_executions, completed, failed, total_cost_usd, total_duration_ms FROM daily_metrics',\n   164→      ).all() as Array<{\n   165→        date: string;\n   166→        total_executions: number;\n   167→        completed: number;\n   168→        failed: number;\n   169→        total_cost_usd: number;\n   170→        total_duration_ms: number;\n   171→      }>;\n   172→\n   173→      for (const row of rows) {\n   174→        const existing = dayMap.get(row.date);\n   175→        if (existing) {\n   176→          existing.total_executions += row.total_executions;\n   177→          existing.completed += row.completed;\n   178→          existing.failed += row.failed;\n   179→          existing.total_cost_usd += row.total_cost_usd;\n   180→          existing.total_duration_ms += row.total_duration_ms;\n   181→          existing.tenant_count += 1;\n   182→        } else {\n   183→          dayMap.set(row.date, {\n   184→            total_executions: row.total_executions,\n   185→            completed: row.completed,\n   186→            failed: row.failed,\n   187→            total_cost_usd: row.total_cost_usd,\n   188→            total_duration_ms: row.total_duration_ms,\n   189→            tenant_count: 1,\n   190→          });\n   191→        }\n   192→      }\n   193→    } catch (err) {\n   194→      logger.warn({ err, projectId }, 'Failed to read metrics for tenant during aggregation');\n   195→    }\n   196→  }\n   197→\n   198→  if (dayMap.size === 0) return;\n   199→\n   200→  // Write aggregated metrics in a single transaction\n   201→  const now = new Date().toISOString();\n   202→  systemDb.transaction(() => {\n   203→    const upsert = systemDb.prepare(`\n   204→      INSERT INTO system_daily_metrics\n   205→        (date, total_executions, completed, failed, total_cost_usd, total_duration_ms, tenant_count, aggregated_at)\n   206→      VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n   207→      ON CONFLICT(date) DO UPDATE SET\n   208→        total_executions = excluded.total_executions,\n   209→        completed = excluded.completed,\n   210→        failed = excluded.failed,\n   211→        total_cost_usd = excluded.total_cost_usd,\n   212→        total_duration_ms = excluded.total_duration_ms,\n   213→        tenant_count = excluded.tenant_count,\n   214→        aggregated_at = excluded.aggregated_at\n   215→    `);\n   216→    for (const [date, m] of dayMap) {\n   217→      upsert.run(date, m.total_executions, m.completed, m.failed, m.total_cost_usd, m.total_duration_ms, m.tenant_count, now);\n   218→    }\n   219→  })();\n   220→\n   221→  logger.info({ days: dayMap.size, tenants: tenantIds.length }, 'System-wide metrics aggregation complete');\n   222→}\n   223→"}]},"parent_tool_use_id":null,"session_id":"637eb800-1367-4262-ba14-f65a42727d0a","uuid":"939dcbf7-c1d8-45e5-ace3-587d52e810e8","timestamp":"2026-03-18T18:25:48.910Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\retention.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport { RetentionPolicy } from './retentionPolicy.js';\n\n// ── Declarative retention policies for tenant tables ────────────────────\n// Each policy is parameterised by its TABLE_REGISTRY spec; the shared\n// RetentionPolicy class handles safety-fraction checks and chunked deletes.\n\nconst execPolicy = new RetentionPolicy({\n  table: 'persona_executions',\n  deleteFilter: \"status IN ('completed', 'failed', 'cancelled')\",\n});\n\nconst eventsPolicy = new RetentionPolicy({\n  table: 'persona_events',\n  deleteFilter: \"status NOT IN ('pending', 'processing', 'partial-retry')\",\n});\n\nconst stuckEventsPolicy = new RetentionPolicy({\n  table: 'persona_events',\n  deleteFilter: \"status IN ('pending', 'processing', 'partial-retry')\",\n});\n\n/** Yield the event loop so concurrent reads/writes can proceed between tenants. */\nfunction yieldTick(): Promise<void> {\n  return new Promise((resolve) => setImmediate(resolve));\n}\n\n/** How often we check whether it's time for the daily run (60 seconds). */\nconst SCHEDULE_CHECK_MS = 60_000;\n\n/** system_kv key used to persist the last successful run date (UTC). */\nconst LAST_RUN_KEY = 'retention_last_run_date';\n\n/** Return today's UTC date as YYYY-MM-DD. */\nfunction utcToday(): string {\n  return new Date().toISOString().slice(0, 10);\n}\n\n/** Read the last-run UTC date from system_kv, or null if never run. */\nfunction getLastRunDate(tenantDbManager: TenantDbManager): string | null {\n  const row = tenantDbManager.getSystemDb().prepare(\n    'SELECT value FROM system_kv WHERE key = ?',\n  ).get(LAST_RUN_KEY) as { value: string } | undefined;\n  return row?.value ?? null;\n}\n\n/** Persist the current UTC date as the last-run date. */\nfunction setLastRunDate(tenantDbManager: TenantDbManager, date: string): void {\n  tenantDbManager.getSystemDb().prepare(\n    'INSERT INTO system_kv (key, value) VALUES (?, ?) ON CONFLICT(key) DO UPDATE SET value = excluded.value',\n  ).run(LAST_RUN_KEY, date);\n}\n\n/**\n * Daily retention job: purge old executions/events and aggregate daily metrics.\n *\n * Uses a 60-second wall-clock poll instead of a drifting 24-hour setInterval.\n * The last successful run date is persisted in system_kv so the job runs\n * exactly once per UTC calendar day regardless of restarts or event-loop delays.\n */\nexport function startRetentionJob(\n  tenantDbManager: TenantDbManager,\n  retentionDays: number,\n  logger: Logger,\n): NodeJS.Timeout {\n  logger.info({ retentionDays }, 'Retention job scheduled (wall-clock daily)');\n\n  let running = false;\n\n  async function tick(): Promise<void> {\n    if (running) return;\n\n    const today = utcToday();\n    const lastRun = getLastRunDate(tenantDbManager);\n\n    if (lastRun === today) return; // already ran today\n\n    running = true;\n    logger.info({ today, lastRun }, 'Retention job triggered');\n    try {\n      await runRetention(tenantDbManager, retentionDays, logger);\n      setLastRunDate(tenantDbManager, today);\n      logger.info({ today }, 'Retention job completed, next run tomorrow');\n    } catch (err) {\n      logger.error({ err }, 'Retention job failed — will retry next tick');\n    } finally {\n      running = false;\n    }\n  }\n\n  // First check shortly after startup, then every 60 seconds\n  setTimeout(() => tick(), 5000);\n\n  return setInterval(() => {\n    tick();\n  }, SCHEDULE_CHECK_MS);\n}\n\nasync function runRetention(\n  tenantDbManager: TenantDbManager,\n  retentionDays: number,\n  logger: Logger,\n): Promise<void> {\n  const cutoff = new Date(Date.now() - retentionDays * 86_400_000).toISOString();\n  const stuckCutoff = new Date(Date.now() - retentionDays * 7 * 86_400_000).toISOString();\n\n  const tenantIds = tenantDbManager.listTenantIds();\n  for (const projectId of tenantIds) {\n    try {\n      const db = tenantDbManager.getTenantDb(projectId);\n      const ctx = { projectId };\n\n      const purgedExecutions = await execPolicy.purge(db, cutoff, logger, ctx);\n      const purgedEvents = await eventsPolicy.purge(db, cutoff, logger, ctx);\n      const purgedStuckEvents = await stuckEventsPolicy.purge(db, stuckCutoff, logger, ctx);\n\n      if (purgedExecutions > 0 || purgedEvents > 0 || purgedStuckEvents > 0) {\n        logger.info({ projectId, purgedExecutions, purgedEvents, purgedStuckEvents }, 'Retention cleanup complete');\n      }\n    } catch (err) {\n      logger.error({ err, projectId }, 'Retention cleanup failed for tenant');\n    }\n    // Yield between tenants so the event loop stays responsive\n    await yieldTick();\n  }\n\n  // ── Reduce phase: aggregate all tenant metrics into system.db ──\n  try {\n    aggregateSystemMetrics(tenantDbManager, logger);\n  } catch (err) {\n    logger.error({ err }, 'System-wide metrics aggregation failed');\n  }\n}\n\n/**\n * Map-reduce step: read daily_metrics from every tenant DB and write\n * a system-wide summary to the system_daily_metrics table in system.db.\n * Replaces rows wholesale each run so the system view is always consistent.\n */\nfunction aggregateSystemMetrics(\n  tenantDbManager: TenantDbManager,\n  logger: Logger,\n): void {\n  const systemDb = tenantDbManager.getSystemDb();\n  const tenantIds = tenantDbManager.listTenantIds();\n\n  // Accumulate per-day totals across all tenants\n  const dayMap = new Map<string, {\n    total_executions: number;\n    completed: number;\n    failed: number;\n    total_cost_usd: number;\n    total_duration_ms: number;\n    tenant_count: number;\n  }>();\n\n  for (const projectId of tenantIds) {\n    try {\n      const db = tenantDbManager.getTenantDb(projectId);\n      const rows = db.prepare(\n        'SELECT date, total_executions, completed, failed, total_cost_usd, total_duration_ms FROM daily_metrics',\n      ).all() as Array<{\n        date: string;\n        total_executions: number;\n        completed: number;\n        failed: number;\n        total_cost_usd: number;\n        total_duration_ms: number;\n      }>;\n\n      for (const row of rows) {\n        const existing = dayMap.get(row.date);\n        if (existing) {\n          existing.total_executions += row.total_executions;\n          existing.completed += row.completed;\n          existing.failed += row.failed;\n          existing.total_cost_usd += row.total_cost_usd;\n          existing.total_duration_ms += row.total_duration_ms;\n          existing.tenant_count += 1;\n        } else {\n          dayMap.set(row.date, {\n            total_executions: row.total_executions,\n            completed: row.completed,\n            failed: row.failed,\n            total_cost_usd: row.total_cost_usd,\n            total_duration_ms: row.total_duration_ms,\n            tenant_count: 1,\n          });\n        }\n      }\n    } catch (err) {\n      logger.warn({ err, projectId }, 'Failed to read metrics for tenant during aggregation');\n    }\n  }\n\n  if (dayMap.size === 0) return;\n\n  // Write aggregated metrics in a single transaction\n  const now = new Date().toISOString();\n  systemDb.transaction(() => {\n    const upsert = systemDb.prepare(`\n      INSERT INTO system_daily_metrics\n        (date, total_executions, completed, failed, total_cost_usd, total_duration_ms, tenant_count, aggregated_at)\n      VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n      ON CONFLICT(date) DO UPDATE SET\n        total_executions = excluded.total_executions,\n        completed = excluded.completed,\n        failed = excluded.failed,\n        total_cost_usd = excluded.total_cost_usd,\n        total_duration_ms = excluded.total_duration_ms,\n        tenant_count = excluded.tenant_count,\n        aggregated_at = excluded.aggregated_at\n    `);\n    for (const [date, m] of dayMap) {\n      upsert.run(date, m.total_executions, m.completed, m.failed, m.total_cost_usd, m.total_duration_ms, m.tenant_count, now);\n    }\n  })();\n\n  logger.info({ days: dayMap.size, tenants: tenantIds.length }, 'System-wide metrics aggregation complete');\n}\n","numLines":223,"startLine":1,"totalLines":223}}}
