[2026-03-18T18:25:56.720Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L2UXq1fiu7BS36derRDVnv","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import { getTableSpec } from '@dac-cloud/shared';\n     4→import type { TableRetentionSpec } from '@dac-cloud/shared';\n     5→\n     6→/** Default rows deleted per chunk to keep individual lock durations short (~50ms). */\n     7→const DEFAULT_CHUNK_SIZE = 5000;\n     8→\n     9→/** Yield the event loop so concurrent reads/writes can proceed between batches. */\n    10→function yieldTick(): Promise<void> {\n    11→  return new Promise((resolve) => setImmediate(resolve));\n    12→}\n    13→\n    14→/** Configuration for a single table's retention policy. */\n    15→export interface RetentionPolicyConfig {\n    16→  /** Table name — must exist in TABLE_REGISTRY. */\n    17→  table: string;\n    18→  /** Override chunk size (default 5000). */\n    19→  chunkSize?: number;\n    20→  /** Additional SQL WHERE fragment appended after the cutoff condition (e.g. \"AND status IN ('completed')\"). */\n    21→  deleteFilter?: string;\n    22→}\n    23→\n    24→/**\n    25→ * Declarative retention policy for a single table.\n    26→ *\n    27→ * Encapsulates the common purge algorithm: compute cutoff → safety-fraction\n    28→ * check → chunked delete with event-loop yields.  Each table registers its\n    29→ * lifecycle in TABLE_REGISTRY; this class reads the spec at construction time\n    30→ * so bug fixes and safety improvements apply everywhere at once.\n    31→ */\n    32→export class RetentionPolicy {\n    33→  readonly table: string;\n    34→  readonly timestampColumn: string;\n    35→  readonly maxPurgeFraction: number;\n    36→  private readonly chunkSize: number;\n    37→  private readonly deleteFilter: string;\n    38→\n    39→  constructor(config: RetentionPolicyConfig) {\n    40→    const spec: TableRetentionSpec | undefined = getTableSpec(config.table);\n    41→    if (!spec) throw new Error(`Table \"${config.table}\" not found in TABLE_REGISTRY`);\n    42→\n    43→    this.table = spec.table;\n    44→    this.timestampColumn = spec.timestampColumn;\n    45→    this.maxPurgeFraction = spec.maxPurgeFraction ?? 0.8;\n    46→    this.chunkSize = config.chunkSize ?? DEFAULT_CHUNK_SIZE;\n    47→    this.deleteFilter = config.deleteFilter ?? '';\n    48→  }\n    49→\n    50→  /**\n    51→   * Purge rows older than `cutoff` from the given database.\n    52→   *\n    53→   * 1. Count total rows and purgeable candidates.\n    54→   * 2. Abort if candidates/total exceeds the safety-fraction cap.\n    55→   * 3. Delete in chunks of `chunkSize`, yielding the event loop between batches.\n    56→   *\n    57→   * Returns the number of rows deleted.\n    58→   */\n    59→  async purge(\n    60→    db: Database.Database,\n    61→    cutoff: string,\n    62→    logger: Logger,\n    63→    context?: Record<string, unknown>,\n    64→  ): Promise<number> {\n    65→    const filter = this.deleteFilter ? ` AND ${this.deleteFilter}` : '';\n    66→\n    67→    // Pre-purge sanity check\n    68→    const total = (db.prepare(\n    69→      `SELECT COUNT(*) as cnt FROM ${this.table}`,\n    70→    ).get() as { cnt: number }).cnt;\n    71→\n    72→    const candidates = (db.prepare(\n    73→      `SELECT COUNT(*) as cnt FROM ${this.table} WHERE ${this.timestampColumn} < ?${filter}`,\n    74→    ).get(cutoff) as { cnt: number }).cnt;\n    75→\n    76→    if (total > 0 && candidates / total > this.maxPurgeFraction) {\n    77→      logger.error(\n    78→        { table: this.table, total, candidates, cutoff, maxFraction: this.maxPurgeFraction, ...context },\n    79→        'Purge aborted: deletion would exceed safety cap',\n    80→      );\n    81→      return 0;\n    82→    }\n    83→\n    84→    // Chunked delete with event-loop yields\n    85→    const deleteStmt = db.prepare(\n    86→      `DELETE FROM ${this.table} WHERE rowid IN (SELECT rowid FROM ${this.table} WHERE ${this.timestampColumn} < ?${filter} LIMIT ?)`,\n    87→    );\n    88→    let totalDeleted = 0;\n    89→    while (true) {\n    90→      const result = deleteStmt.run(cutoff, this.chunkSize);\n    91→      totalDeleted += result.changes;\n    92→      if (result.changes < this.chunkSize) break;\n    93→      await yieldTick();\n    94→    }\n    95→    return totalDeleted;\n    96→  }\n    97→}\n    98→"}]},"parent_tool_use_id":null,"session_id":"637eb800-1367-4262-ba14-f65a42727d0a","uuid":"f7f15b3c-4279-4653-bd69-1b4dedb0d440","timestamp":"2026-03-18T18:25:56.329Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\retentionPolicy.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport { getTableSpec } from '@dac-cloud/shared';\nimport type { TableRetentionSpec } from '@dac-cloud/shared';\n\n/** Default rows deleted per chunk to keep individual lock durations short (~50ms). */\nconst DEFAULT_CHUNK_SIZE = 5000;\n\n/** Yield the event loop so concurrent reads/writes can proceed between batches. */\nfunction yieldTick(): Promise<void> {\n  return new Promise((resolve) => setImmediate(resolve));\n}\n\n/** Configuration for a single table's retention policy. */\nexport interface RetentionPolicyConfig {\n  /** Table name — must exist in TABLE_REGISTRY. */\n  table: string;\n  /** Override chunk size (default 5000). */\n  chunkSize?: number;\n  /** Additional SQL WHERE fragment appended after the cutoff condition (e.g. \"AND status IN ('completed')\"). */\n  deleteFilter?: string;\n}\n\n/**\n * Declarative retention policy for a single table.\n *\n * Encapsulates the common purge algorithm: compute cutoff → safety-fraction\n * check → chunked delete with event-loop yields.  Each table registers its\n * lifecycle in TABLE_REGISTRY; this class reads the spec at construction time\n * so bug fixes and safety improvements apply everywhere at once.\n */\nexport class RetentionPolicy {\n  readonly table: string;\n  readonly timestampColumn: string;\n  readonly maxPurgeFraction: number;\n  private readonly chunkSize: number;\n  private readonly deleteFilter: string;\n\n  constructor(config: RetentionPolicyConfig) {\n    const spec: TableRetentionSpec | undefined = getTableSpec(config.table);\n    if (!spec) throw new Error(`Table \"${config.table}\" not found in TABLE_REGISTRY`);\n\n    this.table = spec.table;\n    this.timestampColumn = spec.timestampColumn;\n    this.maxPurgeFraction = spec.maxPurgeFraction ?? 0.8;\n    this.chunkSize = config.chunkSize ?? DEFAULT_CHUNK_SIZE;\n    this.deleteFilter = config.deleteFilter ?? '';\n  }\n\n  /**\n   * Purge rows older than `cutoff` from the given database.\n   *\n   * 1. Count total rows and purgeable candidates.\n   * 2. Abort if candidates/total exceeds the safety-fraction cap.\n   * 3. Delete in chunks of `chunkSize`, yielding the event loop between batches.\n   *\n   * Returns the number of rows deleted.\n   */\n  async purge(\n    db: Database.Database,\n    cutoff: string,\n    logger: Logger,\n    context?: Record<string, unknown>,\n  ): Promise<number> {\n    const filter = this.deleteFilter ? ` AND ${this.deleteFilter}` : '';\n\n    // Pre-purge sanity check\n    const total = (db.prepare(\n      `SELECT COUNT(*) as cnt FROM ${this.table}`,\n    ).get() as { cnt: number }).cnt;\n\n    const candidates = (db.prepare(\n      `SELECT COUNT(*) as cnt FROM ${this.table} WHERE ${this.timestampColumn} < ?${filter}`,\n    ).get(cutoff) as { cnt: number }).cnt;\n\n    if (total > 0 && candidates / total > this.maxPurgeFraction) {\n      logger.error(\n        { table: this.table, total, candidates, cutoff, maxFraction: this.maxPurgeFraction, ...context },\n        'Purge aborted: deletion would exceed safety cap',\n      );\n      return 0;\n    }\n\n    // Chunked delete with event-loop yields\n    const deleteStmt = db.prepare(\n      `DELETE FROM ${this.table} WHERE rowid IN (SELECT rowid FROM ${this.table} WHERE ${this.timestampColumn} < ?${filter} LIMIT ?)`,\n    );\n    let totalDeleted = 0;\n    while (true) {\n      const result = deleteStmt.run(cutoff, this.chunkSize);\n      totalDeleted += result.changes;\n      if (result.changes < this.chunkSize) break;\n      await yieldTick();\n    }\n    return totalDeleted;\n  }\n}\n","numLines":98,"startLine":1,"totalLines":98}}}
