[2026-03-18T11:36:30.914Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E4STsb7DzmdsiwQ3DdHzpm","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    11→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    12→import type { TenantDbManager } from './tenantDbManager.js';\n    13→import type { TenantKeyManager } from './tenantKeyManager.js';\n    14→import type { AuditLog } from './auditLog.js';\n    15→import type { Logger } from 'pino';\n    16→import * as db from './db/index.js';\n    17→import { readBody, json } from './httpUtils.js';\n    18→\n    19→export function createHttpApi(\n    20→  auth: Auth,\n    21→  dispatcher: Dispatcher,\n    22→  pool: WorkerPool,\n    23→  tokenManager: TokenManager,\n    24→  oauth: OAuthManager,\n    25→  logger: Logger,\n    26→  database?: Database.Database,\n    27→  tenantDbManager?: TenantDbManager,\n    28→  tenantKeyManager?: TenantKeyManager,\n    29→  auditLog?: AuditLog,\n    30→): http.Server {\n    31→  const server = http.createServer(async (req, res) => {\n    32→    // Security headers\n    33→    res.setHeader('X-Content-Type-Options', 'nosniff');\n    34→\n    35→    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    36→    const origin = req.headers.origin ?? '';\n    37→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    38→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    39→    if (isAdminRoute) {\n    40→      // Admin routes: only allow same-origin requests (no CORS wildcard)\n    41→      if (origin && origin === allowedOrigin) {\n    42→        res.setHeader('Access-Control-Allow-Origin', origin);\n    43→      }\n    44→      // If no match, omit the header entirely — browser blocks the request\n    45→    } else {\n    46→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    47→    }\n    48→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    49→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n    50→\n    51→    if (req.method === 'OPTIONS') {\n    52→      res.writeHead(204);\n    53→      res.end();\n    54→      return;\n    55→    }\n    56→\n    57→    const url = req.url || '/';\n    58→    const [pathname, queryString] = url.split('?');\n    59→    const route = parseRoute(pathname ?? '');\n    60→\n    61→    // Unauthenticated endpoints\n    62→    if (pathname === '/health' && req.method === 'GET') {\n    63→      handleHealth(res, pool, oauth);\n    64→      return;\n    65→    }\n    66→\n    67→    // Auth check for everything else — dual auth (API key + optional JWT)\n    68→    const ctx = auth.validateAndExtractContext(req);\n    69→    if (!ctx) {\n    70→      res.writeHead(401, { 'Content-Type': 'application/json' });\n    71→      res.end(JSON.stringify({ error: 'Unauthorized' }));\n    72→      return;\n    73→    }\n    74→\n    75→    // Helper: project scoping (admin sees all, user sees own project)\n    76→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n    77→\n    78→    // Resolve tenant-specific database when available\n    79→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n    80→      if (tenantDbManager && projectId) {\n    81→        return tenantDbManager.getTenantDb(projectId);\n    82→      }\n    83→      return database;\n    84→    };\n    85→    const tenantDb = resolveDatabase(ctx.projectId);\n    86→\n    87→    try {\n    88→      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n    89→      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n    90→        if (requireAdmin(ctx, res)) return;\n    91→        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n    92→        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n    93→        return;\n    94→      }\n    95→      // --- Persona CRUD ---\n    96→      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n    97→        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n    98→      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n    99→        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   100→        const persona = createPersonaWithDefaults({\n   101→          ...body,\n   102→          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   103→        });\n   104→        db.upsertPersona(tenantDb, persona);\n   105→        json(res, 201, persona);\n   106→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n   107→        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n   108→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n   109→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   110→        if (!persona) return;\n   111→        const body = JSON.parse(await readBody(req)) as { toolId: string };\n   112→        db.linkTool(tenantDb, route.id, body.toolId);\n   113→        json(res, 200, { linked: true });\n   114→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n   115→        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id), scopedProjectId, res);\n   116→        if (!hydrated) return;\n   117→        json(res, 200, hydrated);\n   118→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n   119→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   120→        if (!persona) return;\n   121→        json(res, 200, persona);\n   122→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   123→        db.deletePersona(tenantDb, route.id, scopedProjectId);\n   124→        json(res, 200, { deleted: true });\n   125→      }\n   126→      // --- Tool Definitions ---\n   127→      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n   128→        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   129→        const tool = createToolDefinitionWithDefaults(body);\n   130→        db.upsertToolDefinition(tenantDb, tool);\n   131→        json(res, 201, tool);\n   132→      }\n   133→      // --- Credentials ---\n   134→      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n   135→        const body = JSON.parse(await readBody(req));\n   136→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   137→        // Reject oversized plaintext before synchronous encryption blocks the event loop\n   138→        if (body.plaintext && typeof body.plaintext === 'string' && body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   139→          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   140→          return;\n   141→        }\n   142→        // Server-side encryption with per-tenant key when plaintext secret is provided\n   143→        if (body.plaintext && tenantKeyManager) {\n   144→          const tenantId = body.projectId || ctx.projectId || 'default';\n   145→          const key = await tenantKeyManager.getKey(tenantId);\n   146→          const encrypted = encrypt(body.plaintext, key);\n   147→          body.encryptedData = encrypted.encrypted;\n   148→          body.iv = encrypted.iv;\n   149→          body.tag = encrypted.tag;\n   150→          delete body.plaintext;\n   151→          // Audit after creation below\n   152→        }\n   153→        const cred = db.createCredential(tenantDb, body);\n   154→        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n   155→        json(res, 201, cred);\n   156→      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   157→        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n   158→        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   159→        json(res, 200, { deleted: true });\n   160→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n   161→        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n   162→        // Strip encrypted data from response\n   163→        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   164→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n   165→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   166→        if (!persona) return;\n   167→        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   168→        db.linkCredential(tenantDb, route.id, body.credentialId);\n   169→        json(res, 200, { linked: true });\n   170→      }\n   171→      // --- Event Subscriptions ---\n   172→      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n   173→        const body = JSON.parse(await readBody(req));\n   174→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   175→        const missing: string[] = [];\n   176→        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   177→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   178→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   179→        const sub = db.createSubscription(tenantDb, body);\n   180→        json(res, 201, sub);\n   181→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   182→        const body = JSON.parse(await readBody(req));\n   183→        db.updateSubscription(tenantDb, route.id, body);\n   184→        const updated = db.getSubscription(tenantDb, route.id);\n   185→        json(res, 200, updated);\n   186→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   187→        db.deleteSubscription(tenantDb, route.id);\n   188→        json(res, 200, { deleted: true });\n   189→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n   190→        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n   191→      }\n   192→      // --- Triggers (delegated to triggerHttpHandlers) ---\n   193→      else if (route && tenantDb && (\n   194→        route.resource === 'triggers' ||\n   195→        (route.resource === 'personas' && route.subResource === 'triggers')\n   196→      )) {\n   197→        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n   198→        return;\n   199→      }\n   200→      // --- Events ---\n   201→      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n   202→        const params = new URLSearchParams(queryString || '');\n   203→        const events = db.listEvents(tenantDb, {\n   204→          eventType: params.get('eventType') ?? undefined,\n   205→          status: params.get('status') ?? undefined,\n   206→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   207→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   208→          projectId: scopedProjectId,\n   209→        });\n   210→        json(res, 200, events);\n   211→      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n   212→        const body = JSON.parse(await readBody(req));\n   213→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   214→        const missing: string[] = [];\n   215→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   216→        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   217→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   218→        const event = db.publishEvent(tenantDb, body);\n   219→        json(res, 201, event);\n   220→      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   221→        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n   222→        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n   223→        if (updated) {\n   224→          json(res, 200, updated);\n   225→        } else {\n   226→          res.writeHead(404, { 'Content-Type': 'application/json' });\n   227→          res.end(JSON.stringify({ error: 'Event not found' }));\n   228→        }\n   229→      }\n   230→      // --- Webhooks ---\n   231→      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n   232→        const personaId = route.id;\n   233→        const body = await readBody(req);\n   234→        const event = db.publishEvent(tenantDb, {\n   235→          eventType: 'webhook_received',\n   236→          sourceType: 'webhook',\n   237→          sourceId: personaId,\n   238→          targetPersonaId: personaId,\n   239→          payload: body,\n   240→        });\n   241→        json(res, 201, event);\n   242→      }\n   243→      // --- GitLab Webhook ---\n   244→      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n   245→        const body = await readBody(req);\n   246→        let parsed: Record<string, unknown> = {};\n   247→        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   248→        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   249→        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   250→        const event = db.publishEvent(tenantDb, {\n   251→          eventType: `gitlab_${objectKind}`,\n   252→          sourceType: 'gitlab',\n   253→          sourceId: projectPath ?? null,\n   254→          payload: body,\n   255→        });\n   256→        json(res, 201, event);\n   257→      }\n   258→      // --- Executions ---\n   259→      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n   260→        const params = new URLSearchParams(queryString || '');\n   261→        const executions = db.listExecutions(tenantDb, {\n   262→          personaId: params.get('personaId') ?? undefined,\n   263→          status: params.get('status') ?? undefined,\n   264→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   265→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   266→          projectId: scopedProjectId,\n   267→        });\n   268→        json(res, 200, executions);\n   269→      }\n   270→      // --- Existing execution endpoints ---\n   271→      else if (pathname === '/api/status' && req.method === 'GET') {\n   272→        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   273→      } else if (pathname === '/api/execute' && req.method === 'POST') {\n   274→        await handleExecute(req, res, dispatcher, logger, ctx);\n   275→      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n   276→        handleCancelExecution(res, dispatcher, route.id);\n   277→      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n   278→        const executionId = route.id;\n   279→        const params = new URLSearchParams(queryString || '');\n   280→        const offset = parseInt(params.get('offset') || '0', 10);\n   281→        handleGetExecution(res, dispatcher, executionId, offset);\n   282→      }\n   283→      // --- Admin-only routes ---\n   284→      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n   285→        if (requireAdmin(ctx, res)) return;\n   286→        if (tenantDbManager) {\n   287→          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   288→        } else if (database) {\n   289→          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   290→        } else {\n   291→          json(res, 200, { projectIds: [] });\n   292→        }\n   293→      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n   294→        if (requireAdmin(ctx, res)) return;\n   295→        if (tenantDbManager) {\n   296→          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   297→          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   298→          json(res, 200, allPersonas);\n   299→        } else if (database) {\n   300→          json(res, 200, db.listPersonasSummary(database));\n   301→        } else {\n   302→          json(res, 200, []);\n   303→        }\n   304→      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n   305→        if (requireAdmin(ctx, res)) return;\n   306→        const params = new URLSearchParams(queryString || '');\n   307→        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   308→        if (tenantDbManager) {\n   309→          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   310→          tenantDbManager.forEachTenant((tDb) => {\n   311→            allExecs.push(...db.listExecutions(tDb, { limit }));\n   312→          });\n   313→          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   314→          json(res, 200, allExecs.slice(0, limit));\n   315→        } else if (database) {\n   316→          json(res, 200, db.listExecutions(database, {\n   317→            limit,\n   318→            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   319→          }));\n   320→        } else {\n   321→          json(res, 200, []);\n   322→        }\n   323→      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n   324→        if (requireAdmin(ctx, res)) return;\n   325→        if (!auditLog) { json(res, 200, []); return; }\n   326→        const params = new URLSearchParams(queryString || '');\n   327→        json(res, 200, auditLog.query({\n   328→          tenantId: params.get('tenantId') ?? undefined,\n   329→          action: params.get('action') ?? undefined,\n   330→          since: params.get('since') ?? undefined,\n   331→          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   332→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   333→        }));\n   334→      } else {\n   335→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   336→        res.end(JSON.stringify({ error: 'Not found' }));\n   337→      }\n   338→    } catch (err) {\n   339→      if (err instanceof Error && err.message === 'Payload too large') {\n   340→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   341→        res.end(JSON.stringify({ error: 'Payload too large' }));\n   342→        return;\n   343→      }\n   344→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   345→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   346→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n   347→        return;\n   348→      }\n   349→      logger.error({ err, url }, 'HTTP handler error');\n   350→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   351→      res.end(JSON.stringify({ error: 'Internal server error' }));\n   352→    }\n   353→  });\n   354→\n   355→  return server;\n   356→}\n   357→\n   358→interface ParsedRoute {\n   359→  resource: string;\n   360→  id?: string;\n   361→  subResource?: string;\n   362→}\n   363→\n   364→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n   365→function parseRoute(pathname: string): ParsedRoute | null {\n   366→  if (!pathname.startsWith('/api/')) return null;\n   367→  const segments = pathname.slice(5).split('/').filter(Boolean);\n   368→  if (segments.length === 0) return null;\n   369→  return {\n   370→    resource: segments[0]!,\n   371→    id: segments[1],\n   372→    subResource: segments[2],\n   373→  };\n   374→}\n   375→\n   376→/**\n   377→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   378→ * Returns the entity on success, or null after sending a 404 response.\n   379→ */\n   380→function withScopedEntity<T extends { projectId?: string | null }>(\n   381→  entity: T | undefined,\n   382→  scopedProjectId: string | undefined,\n   383→  res: http.ServerResponse,\n   384→): T | null {\n   385→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   386→    json(res, 404, { error: 'Not found' });\n   387→    return null;\n   388→  }\n   389→  return entity;\n   390→}\n   391→\n   392→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   393→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   394→  if (ctx.authType !== 'admin') {\n   395→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   396→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   397→    return true;\n   398→  }\n   399→  return false;\n   400→}\n   401→\n   402→// --- Existing handlers ---\n   403→\n   404→function handleHealth(res: http.ServerResponse, pool: WorkerPool, oauth: OAuthManager): void {\n   405→  const counts = pool.getWorkerCount();\n   406→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   407→  res.end(JSON.stringify({\n   408→    status: 'ok',\n   409→    workers: counts,\n   410→    hasSubscription: oauth.hasTokens(),\n   411→    timestamp: Date.now(),\n   412→  }));\n   413→}\n   414→\n   415→function handleStatus(\n   416→  res: http.ServerResponse,\n   417→  pool: WorkerPool,\n   418→  dispatcher: Dispatcher,\n   419→  tokenManager: TokenManager,\n   420→  oauth: OAuthManager,\n   421→): void {\n   422→  const oauthTokens = oauth.getTokens();\n   423→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   424→  res.end(JSON.stringify({\n   425→    workers: pool.getWorkers(),\n   426→    workerCounts: pool.getWorkerCount(),\n   427→    queueLength: dispatcher.getQueueLength(),\n   428→    activeExecutions: dispatcher.getActiveExecutions(),\n   429→    hasClaudeToken: tokenManager.hasToken(),\n   430→    oauth: {\n   431→      connected: oauth.hasTokens(),\n   432→      scopes: oauthTokens?.scopes || [],\n   433→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   434→    },\n   435→  }));\n   436→}\n   437→\n   438→async function handleExecute(\n   439→  req: http.IncomingMessage,\n   440→  res: http.ServerResponse,\n   441→  dispatcher: Dispatcher,\n   442→  logger: Logger,\n   443→  ctx?: RequestContext,\n   444→): Promise<void> {\n   445→  const body = await readBody(req);\n   446→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   447→\n   448→  try {\n   449→    parsed = JSON.parse(body);\n   450→  } catch {\n   451→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   452→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   453→    return;\n   454→  }\n   455→\n   456→  if (!parsed.prompt) {\n   457→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   458→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   459→    return;\n   460→  }\n   461→\n   462→  const request: ExecRequest = {\n   463→    executionId: nanoid(),\n   464→    personaId: parsed.personaId || 'manual',\n   465→    prompt: parsed.prompt,\n   466→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   467→    config: {\n   468→      timeoutMs: parsed.timeoutMs || 300_000,\n   469→    },\n   470→  };\n   471→\n   472→  dispatcher.submit(request);\n   473→\n   474→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   475→\n   476→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   477→  res.end(JSON.stringify({\n   478→    executionId: request.executionId,\n   479→    status: 'queued',\n   480→  }));\n   481→}\n   482→\n   483→function handleGetExecution(\n   484→  res: http.ServerResponse,\n   485→  dispatcher: Dispatcher,\n   486→  executionId: string,\n   487→  offset: number = 0,\n   488→): void {\n   489→  const exec = dispatcher.getExecution(executionId);\n   490→\n   491→  if (!exec) {\n   492→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   493→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   494→    return;\n   495→  }\n   496→\n   497→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   498→\n   499→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   500→  res.end(JSON.stringify({\n   501→    executionId,\n   502→    status: exec.status,\n   503→    outputLines: exec.output.length,\n   504→    output,\n   505→    durationMs: exec.durationMs,\n   506→    sessionId: exec.sessionId,\n   507→    totalCostUsd: exec.totalCostUsd,\n   508→  }));\n   509→}\n   510→\n   511→function handleCancelExecution(\n   512→  res: http.ServerResponse,\n   513→  dispatcher: Dispatcher,\n   514→  executionId: string,\n   515→): void {\n   516→  const cancelled = dispatcher.cancelExecution(executionId);\n   517→\n   518→  if (!cancelled) {\n   519→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   520→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   521→    return;\n   522→  }\n   523→\n   524→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   525→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   526→}\n   527→\n   528→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\n   529→const MAX_QUERY_LIMIT = 500;\n   530→const MAX_QUERY_OFFSET = 100_000;\n   531→\n   532→/** Parse an integer query param and clamp it to safe bounds. */\n   533→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   534→  if (!value) return defaultValue;\n   535→  const parsed = parseInt(value, 10);\n   536→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   537→  return Math.min(parsed, max);\n   538→}\n   539→"}]},"parent_tool_use_id":"toolu_01GAanv3ZUwLhFKCbmwQr7dA","session_id":"efe0d03e-8d66-4f31-bfdd-beb02c765aa8","uuid":"dc2803bb-3566-48fc-8c6b-f773b3038bc8","timestamp":"2026-03-18T11:36:30.835Z"}
