ing; serviceType: string; encryptedData: string; iv: string; tag: string; metadata?: string | null; projectId?: string;\n    41→}): PersonaCredential {\n    42→  const now = new Date().toISOString();\n    43→  const id = nanoid();\n    44→  const projectId = input.projectId ?? 'default';\n    45→  const metadata = input.metadata ?? null;\n    46→  stmt(db,`\n    47→    INSERT INTO persona_credentials (id, project_id, name, service_type, encrypted_data, iv, tag, metadata, created_at, updated_at)\n    48→    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n    49→  `).run(id, projectId, input.name, input.serviceType, input.encryptedData, input.iv, input.tag, metadata, now, now);\n    50→  return {\n    51→    id,\n    52→    projectId,\n    53→    name: input.name,\n    54→    serviceType: input.serviceType,\n    55→    encryptedData: input.encryptedData,\n    56→    iv: input.iv,\n    57→    tag: input.tag,\n    58→    metadata,\n    59→    lastUsedAt: null,\n    60→    createdAt: now,\n    61→    updatedAt: now,\n    62→  };\n    63→}\n    64→\n    65→export function getCredential(db: Database.Database, id: string): PersonaCredential | undefined {\n    66→  const row = stmt(db,'SELECT * FROM persona_credentials WHERE id = ?').get(id) as Record<string, unknown> | undefined;\n    67→  return row ? rowToCredential(row) : undefined;\n    68→}\n    69→\n    70→export function listCredentialsForPersona(db: Database.Database, personaId: string): PersonaCredential[] {\n    71→  const rows = stmt(db,`\n    72→    SELECT c.* FROM persona_credentials c\n    73→    JOIN persona_credential_links cl ON cl.credential_id = c.id\n    74→    WHERE cl.persona_id = ?\n    75→  `).all(personaId) as Record<string, unknown>[];\n    76→  return rows.map(rowToCredential);\n    77→}\n    78→\n    79→export function linkCredential(db: Database.Database, personaId: string, credentialId: string): void {\n    80→  stmt(db,'INSERT OR IGNORE INTO persona_credential_links (persona_id, credential_id) VALUES (?, ?)').run(personaId, credentialId);\n    81→}\n    82→\n    83→export function deleteCredential(db: Database.Database, id: string, projectId?: string): number {\n    84→  if (projectId) {\n    85→    const result = stmt(db,'DELETE FROM persona_credentials WHERE id = ? AND project_id = ?').run(id, projectId);\n    86→    return result.changes;\n    87→  }\n    88→  const result = stmt(db,'DELETE FROM persona_credentials WHERE id = ?').run(id);\n    89→  return result.changes;\n    90→}\n    91→"}]},"parent_tool_use_id":"toolu_01GAanv3ZUwLhFKCbmwQr7dA","session_id":"efe0d03e-8d66-4f31-bfdd-beb02c765aa8","uuid":"ba64b5d2-e24f-47a2-bb51-a3bc224d057b","timestamp":"2026-03-18T11:36:33.313Z"}
