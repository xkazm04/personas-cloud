,  // Optional: use OAuth flow if not provided\n    57→    teamApiKey: required('TEAM_API_KEY'),\n    58→    workerToken: required('WORKER_TOKEN'),\n    59→    kafkaBrokers,\n    60→    kafkaUsername: process.env['KAFKA_USERNAME'] || '',\n    61→    kafkaPassword: process.env['KAFKA_PASSWORD'] || '',\n    62→    kafkaEnabled: kafkaBrokers.length > 0,\n    63→    supabaseJwtSecret: process.env['SUPABASE_JWT_SECRET'] || '',\n    64→    wsPort: parseInt(optional('WS_PORT', '8443'), 10),\n    65→    httpPort: parseInt(optional('HTTP_PORT', '3001'), 10),\n    66→    // TLS\n    67→    tlsEnabled: process.env['TLS_ENABLED'] !== 'false',\n    68→    tlsCertPath: process.env['TLS_CERT_PATH'] || '',\n    69→    tlsKeyPath: process.env['TLS_KEY_PATH'] || '',\n    70→    tlsCaPath: process.env['TLS_CA_PATH'] || '',\n    71→    tlsRequireClientCert: process.env['TLS_REQUIRE_CLIENT_CERT'] === 'true',\n    72→    // Output scrubbing\n    73→    scrubberEnabled: process.env['SCRUBBER_ENABLED'] !== 'false',\n    74→    // Audit\n    75→    auditDbPath: process.env['AUDIT_DB_PATH'] || path.join(dataDir, 'audit.db'),\n    76→    auditRetentionDays: parseInt(process.env['AUDIT_RETENTION_DAYS'] || '90', 10),\n    77→    // Retention\n    78→    retentionDays: parseInt(process.env['RETENTION_DAYS'] || '30', 10),\n    79→    metricsRetentionDays: parseInt(process.env['METRICS_RETENTION_DAYS'] || '365', 10),\n    80→    // Data directory\n    81→    dataDir,\n    82→    // Worker verification\n    83→    allowedImageDigests: (process.env['ALLOWED_IMAGE_DIGESTS'] || '').split(',').map(s => s.trim()).filter(Boolean),\n    84→    rejectUnverifiedWorkers: process.env['REJECT_UNVERIFIED_WORKERS'] === 'true',\n    85→  };\n    86→}\n    87→"}]},"parent_tool_use_id":"toolu_01GAanv3ZUwLhFKCbmwQr7dA","session_id":"efe0d03e-8d66-4f31-bfdd-beb02c765aa8","uuid":"cd3478df-81a2-4846-8ed9-fb555fbac47d","timestamp":"2026-03-18T11:36:30.362Z"}
