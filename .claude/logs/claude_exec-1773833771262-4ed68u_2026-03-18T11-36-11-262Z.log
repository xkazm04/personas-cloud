[2026-03-18T11:36:33.823Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014pTsoYWf97fS4TvEdMGBVd","type":"tool_result","content":"     1→import fs from 'node:fs';\n     2→import fsp from 'node:fs/promises';\n     3→import path from 'node:path';\n     4→import os from 'node:os';\n     5→import crypto from 'node:crypto';\n     6→import type { Logger } from 'pino';\n     7→\n     8→export interface InjectedCredentials {\n     9→  /** Path to the tmpfs-backed credential file */\n    10→  credentialFilePath: string;\n    11→  /** Environment variable key pointing to the file */\n    12→  envPointerKey: string;\n    13→  /** Call to delete the credential file */\n    14→  cleanup(): Promise<void>;\n    15→}\n    16→\n    17→/** File name prefix used for all credential temp files. */\n    18→const CRED_FILE_PREFIX = 'dac-creds-';\n    19→\n    20→/** Max age (ms) before an orphaned credential file is swept on startup. */\n    21→const ORPHAN_MAX_AGE_MS = 2 * 60 * 1000; // 2 minutes\n    22→\n    23→/**\n    24→ * Registry of credential file paths created by this process.\n    25→ * Used by the exit handler to synchronously remove files on crash.\n    26→ */\n    27→const activeCredentialFiles = new Set<string>();\n    28→\n    29→/** Whether the process exit handler has been installed. */\n    30→let exitHandlerInstalled = false;\n    31→\n    32→/**\n    33→ * Returns the directories where credential files may be written.\n    34→ */\n    35→function credentialDirs(): string[] {\n    36→  const dirs: string[] = [os.tmpdir()];\n    37→  if (process.platform === 'linux' && fs.existsSync('/dev/shm')) {\n    38→    dirs.push('/dev/shm');\n    39→  }\n    40→  return dirs;\n    41→}\n    42→\n    43→/**\n    44→ * Install a synchronous process exit handler that removes any credential\n    45→ * files still tracked in the registry. This covers cases where the process\n    46→ * exits abnormally (uncaughtException, unhandledRejection) but the event\n    47→ * loop is still alive long enough to fire the 'exit' event.\n    48→ *\n    49→ * Call once during worker startup.\n    50→ */\n    51→export function installCredentialExitHandler(logger: Logger): void {\n    52→  if (exitHandlerInstalled) return;\n    53→  exitHandlerInstalled = true;\n    54→\n    55→  process.on('exit', () => {\n    56→    for (const filePath of activeCredentialFiles) {\n    57→      try {\n    58→        fs.unlinkSync(filePath);\n    59→        // Logger may not flush during 'exit', but try anyway\n    60→        logger.debug({ credentialFile: filePath }, 'Credential file removed by exit handler');\n    61→      } catch {\n    62→        // Best-effort — file may already be gone\n    63→      }\n    64→    }\n    65→  });\n    66→}\n    67→\n    68→/**\n    69→ * Scan credential temp directories for orphaned `dac-creds-*` files older\n    70→ * than ORPHAN_MAX_AGE_MS and remove them. Intended to be called once during\n    71→ * worker startup before any executions begin.\n    72→ */\n    73→export async function sweepOrphanedCredentialFiles(logger: Logger): Promise<number> {\n    74→  const now = Date.now();\n    75→  let swept = 0;\n    76→\n    77→  for (const dir of credentialDirs()) {\n    78→    let entries: string[];\n    79→    try {\n    80→      entries = await fsp.readdir(dir);\n    81→    } catch {\n    82→      continue; // directory inaccessible\n    83→    }\n    84→\n    85→    for (const entry of entries) {\n    86→      if (!entry.startsWith(CRED_FILE_PREFIX)) continue;\n    87→\n    88→      const fullPath = path.join(dir, entry);\n    89→      try {\n    90→        const stat = await fsp.stat(fullPath);\n    91→        if (now - stat.mtimeMs > ORPHAN_MAX_AGE_MS) {\n    92→          await fsp.unlink(fullPath);\n    93→          swept++;\n    94→          logger.warn({ credentialFile: fullPath, ageMs: now - stat.mtimeMs }, 'Swept orphaned credential file');\n    95→        }\n    96→      } catch {\n    97→        // File disappeared between readdir and stat/unlink — fine\n    98→      }\n    99→    }\n   100→  }\n   101→\n   102→  if (swept > 0) {\n   103→    logger.info({ swept }, 'Orphaned credential file sweep complete');\n   104→  }\n   105→\n   106→  return swept;\n   107→}\n   108→\n   109→/**\n   110→ * Write credentials to a temporary file (preferring tmpfs/ramfs) instead of\n   111→ * injecting them as environment variables. This prevents credential exposure\n   112→ * via /proc/pid/environ or `ps auxe`.\n   113→ *\n   114→ * Returns the file path and a cleanup function. The child process receives\n   115→ * the DAC_CREDENTIALS_FILE env var pointing to the file.\n   116→ */\n   117→export async function injectCredentialsViaFile(\n   118→  env: Record<string, string>,\n   119→  executionId: string,\n   120→  logger: Logger,\n   121→): Promise<InjectedCredentials> {\n   122→  // Prefer /dev/shm (tmpfs, never hits disk) on Linux\n   123→  let tmpBase: string;\n   124→  if (process.platform === 'linux' && fs.existsSync('/dev/shm')) {\n   125→    tmpBase = '/dev/shm';\n   126→  } else {\n   127→    tmpBase = os.tmpdir();\n   128→  }\n   129→\n   130→  const randomSuffix = crypto.randomBytes(8).toString('hex');\n   131→  const credFilePath = path.join(tmpBase, `${CRED_FILE_PREFIX}${executionId}-${randomSuffix}.json`);\n   132→\n   133→  // Collect credential env vars into the file\n   134→  const credentials: Record<string, string> = {};\n   135→  const credentialKeys: string[] = [];\n   136→\n   137→  for (const [key, value] of Object.entries(env)) {\n   138→    // Credential env vars follow the CONNECTOR_* pattern or are well-known secret keys\n   139→    if (\n   140→      key.startsWith('CONNECTOR_') ||\n   141→      key === 'ANTHROPIC_API_KEY' ||\n   142→      key.includes('TOKEN') ||\n   143→      key.includes('SECRET') ||\n   144→      key.includes('PASSWORD') ||\n   145→      key.includes('API_KEY')\n   146→    ) {\n   147→      credentials[key] = value;\n   148→      credentialKeys.push(key);\n   149→    }\n   150→  }\n   151→\n   152→  // Write credential file asynchronously\n   153→  await fsp.writeFile(credFilePath, JSON.stringify(credentials), { mode: 0o600 });\n   154→\n   155→  // Track the file so exit handler can clean it up on crash\n   156→  activeCredentialFiles.add(credFilePath);\n   157→\n   158→  // Remove credential keys from the env dict (they'll be read from file instead)\n   159→  for (const key of credentialKeys) {\n   160→    delete env[key];\n   161→  }\n   162→\n   163→  logger.debug({\n   164→    executionId,\n   165→    credentialFile: credFilePath,\n   166→    credentialCount: credentialKeys.length,\n   167→    onTmpfs: tmpBase === '/dev/shm',\n   168→  }, 'Credentials written to temporary file');\n   169→\n   170→  return {\n   171→    credentialFilePath: credFilePath,\n   172→    envPointerKey: 'DAC_CREDENTIALS_FILE',\n   173→    async cleanup() {\n   174→      activeCredentialFiles.delete(credFilePath);\n   175→      try {\n   176→        await fsp.unlink(credFilePath);\n   177→        logger.debug({ credentialFile: credFilePath }, 'Credential file cleaned up');\n   178→      } catch (err) {\n   179→        // File may already be gone (e.g. sandbox cleanup removed it first)\n   180→        if ((err as NodeJS.ErrnoException).code !== 'ENOENT') {\n   181→          logger.warn({ err, credentialFile: credFilePath }, 'Failed to cleanup credential file');\n   182→        }\n   183→      }\n   184→    },\n   185→  };\n   186→}\n   187→"}]},"parent_tool_use_id":"toolu_01GAanv3ZUwLhFKCbmwQr7dA","session_id":"efe0d03e-8d66-4f31-bfdd-beb02c765aa8","uuid":"07d23771-f8d9-494e-bdd6-24a2f5bb0f6b","timestamp":"2026-03-18T11:36:33.745Z"}
