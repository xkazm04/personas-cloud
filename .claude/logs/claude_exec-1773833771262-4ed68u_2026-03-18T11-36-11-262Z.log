tity?: string;\n    56→  instructions?: string;\n    57→  toolGuidance?: string;\n    58→  examples?: string;\n    59→  errorHandling?: string;\n    60→  customSections?: Array<{ title?: string; label?: string; name?: string; key?: string; content?: string }>;\n    61→  webSearch?: string;\n    62→}\n    63→\n    64→// ---------------------------------------------------------------------------\n    65→// Inference profiles\n    66→// ---------------------------------------------------------------------------\n    67→\n    68→export type InferenceProvider = 'claude' | 'ollama' | 'litellm' | 'openai-compatible' | 'custom';\n    69→\n    70→export interface InferenceProviderEnvMapping {\n    71→  envVar: string;\n    72→  source: 'baseUrl' | 'authToken' | 'model';\n    73→}\n    74→\n    75→export interface InferenceProfile {\n    76→  id: string;\n    77→  projectId: string;\n    78→  name: string;\n    79→  provider: InferenceProvider;\n    80→  model?: string;\n    81→  baseUrl?: string;\n    82→  authTokenEncrypted?: string;\n    83→  authTokenIv?: string;\n    84→  authTokenTag?: string;\n    85→  envMappings: InferenceProviderEnvMapping[];\n    86→  removeEnvKeys?: string[];\n    87→  isPreset: boolean;\n    88→  createdAt: string;\n    89→  updatedAt: string;\n    90→}\n    91→\n    92→export interface PersonaCredential {\n    93→  id: string;\n    94→  projectId?: string;\n    95→  name: string;\n    96→  serviceType: string;\n    97→  encryptedData: string;\n    98→  iv: string;\n    99→  tag: string;\n   100→  metadata: string | null;\n   101→  lastUsedAt: string | null;\n   102→  createdAt: string;\n   103→  updatedAt: string;\n   104→}\n   105→\n   106→export interface PersonaEvent {\n   107→  id: string;\n   108→  projectId: string;\n   109→  eventType: string;\n   110→  sourceType: string;\n   111→  sourceId: string | null;\n   112→  targetPersonaId: string | null;\n   113→  payload: string | null;\n   114→  status: string;\n   115→  errorMessage: string | null;\n   116→  processedAt: string | null;\n   117→  useCaseId: string | null;\n   118→  createdAt: string;\n   119→}\n   120→\n   121→export interface PersonaEventSubscription {\n   122→  id: string;\n   123→  personaId: string;\n   124→  eventType: string;\n   125→  sourceFilter: string | null;\n   126→  enabled: boolean;\n   127→  useCaseId: string | null;\n   128→  createdAt: string;\n   129→  updatedAt: string;\n   130→}\n   131→\n   132→// ---------------------------------------------------------------------------\n   133→// Trigger config discriminated union\n   134→// ---------------------------------------------------------------------------\n   135→\n   136→export type TriggerType = 'manual' | 'schedule' | 'polling' | 'webhook' | 'chain';\n   137→\n   138→interface TriggerConfigBase {\n   139→  event_type?: string;\n   140→  payload?: unknown;\n   141→}\n   142→\n   143→export interface ScheduleTriggerConfig extends TriggerConfigBase {\n   144→  kind: 'schedule';\n   145→  cron?: string;\n   146→  interval_seconds?: number;\n   147→}\n   148→\n   149→export interface ManualTriggerConfig extends TriggerConfigBase {\n   150→  kind: 'manual';\n   151→}\n   152→\n   153→export interface PollingTriggerConfig extends TriggerConfigBase {\n   154→  kind: 'polling';\n   155→  poll_url?: string;\n   156→  poll_interval_seconds?: number;\n   157→}\n   158→\n   159→export interface WebhookTriggerConfig extends TriggerConfigBase {\n   160→  kind: 'webhook';\n   161→  url?: string;\n   162→  secret?: string;\n   163→}\n   164→\n   165→export interface ChainTriggerConfig extends TriggerConfigBase {\n   166→  kind: 'chain';\n   167→  source_persona_id?: string;\n   168→  source_event_type?: string;\n   169→}\n   170→\n   171→export type TriggerConfig =\n   172→  | ScheduleTriggerConfig\n   173→  | ManualTriggerConfig\n   174→  | PollingTriggerConfig\n   175→  | WebhookTriggerConfig\n   176→  | ChainTriggerConfig;\n   177→\n   178→export interface PersonaTrigger {\n   179→  id: string;\n   180→  personaId: string;\n   181→  triggerType: TriggerType;\n   182→  config: string | null;\n   183→  enabled: boolean;\n   184→  lastTriggeredAt: string | null;\n   185→  nextTriggerAt: string | null;\n   186→  useCaseId: string | null;\n   187→  createdAt: string;\n   188→  updatedAt: string;\n   189→}\n   190→\n   191→/** Fully hydrated persona with all related entities. */\n   192→export interface HydratedPersona extends Persona {\n   193→  tools: PersonaToolDefinition[];\n   194→  credentials: Omit<PersonaCredential, 'encryptedData' | 'iv' | 'tag'>[];\n   195→  subscriptions: PersonaEventSubscription[];\n   196→  triggers: PersonaTrigger[];\n   197→}\n   198→\n   199→export interface PersonaExecution {\n   200→  id: string;\n   201→  projectId?: string;\n   202→  personaId: string;\n   203→  triggerId: string | null;\n   204→  useCaseId: string | null;\n   205→  status: string;\n   206→  inputData: string | null;\n   207→  outputData: string | null;\n   208→  claudeSessionId: string | null;\n   209→  modelUsed: string | null;\n   210→  inputTokens: number;\n   211→  outputTokens: number;\n   212→  costUsd: number;\n   213→  errorMessage: string | null;\n   214→  durationMs: number | null;\n   215→  retryOfExecutionId: string | null;\n   216→  retryCount: number;\n   217→  startedAt: string | null;\n   218→  completedAt: string | null;\n   219→  createdAt: string;\n   220→}\n   221→\n   222→// ---------------------------------------------------------------------------\n   223→// Execution request — produced to Kafka by Vibeman, consumed by orchestrator\n   224→// ---------------------------------------------------------------------------\n   225→\n   226→export interface ExecRequest {\n   227→  executionId: string;\n   228→  personaId: string;\n   229→  prompt: string;\n   230→  projectId?: string;\n   231→  credentialIds?: string[];\n   232→  inputData?: unknown;\n   233→  config: {\n   234→    timeoutMs: number;\n   235→    maxConcurrent?: number;\n   236→  };\n   237→  triggerId?: string;\n   238→  triggerType?: string;\n   239→}\n   240→\n   241→// Execution result — produced to Kafka by orchestrator\n   242→export interface ExecResult {\n   243→  executionId: string;\n   244→  personaId: string;\n   245→  status: 'completed' | 'failed' | 'cancelled';\n   246→  exitCode: number;\n   247→  durationMs: number;\n   248→  sessionId?: string;\n   249→  totalCostUsd?: number;\n   250→  error?: string;\n   251→}\n   252→\n   253→// Worker info as tracked by orchestrator\n   254→export interface WorkerInfo {\n   255→  workerId: string;\n   256→  status: 'connecting' | 'idle' | 'executing' | 'disconnected';\n   257→  version: string;\n   258→  capabilities: string[];\n   259→  currentExecutionId?: string;\n   260→  connectedAt: number;\n   261→  lastHeartbeat: number;\n   262→  imageDigest?: string;\n   263→  claudeCliVersion?: string;\n   264→  verified: boolean;\n   265→}\n   266→\n   267→// Execution output chunk — produced to Kafka for Vibeman SSE consumption\n   268→export interface OutputChunk {\n   269→  executionId: string;\n   270→  chunk: string;\n   271→  timestamp: number;\n   272→}\n   273→\n   274→// Persona event — forwarded from worker to Kafka event bus\n   275→export interface PersonaCloudEvent {\n   276→  executionId: string;\n   277→  personaId: string;\n   278→  eventType: 'manual_review' | 'user_message' | 'persona_action' | 'emit_event';\n   279→  payload: unknown;\n   280→  timestamp: number;\n   281→}\n   282→\n   283→// Execution progress (ephemeral — tracked in-memory + Kafka only)\n   284→export interface ProgressInfo {\n   285→  phase: string;\n   286→  percent: number;\n   287→  detail?: string;\n   288→  updatedAt: number;\n   289→}\n   290→\n   291→// Kafka topic names\n   292→export const TOPICS = {\n   293→  EXEC_REQUESTS: 'persona.exec.v1',\n   294→  EXEC_OUTPUT: 'persona.output.v1',\n   295→  EXEC_LIFECYCLE: 'persona.lifecycle.v1',\n   296→  EXEC_PROGRESS: 'persona.progress.v1',\n   297→  EVENTS: 'persona.events.v1',\n   298→  DLQ: 'persona.dlq.v1',\n   299→} as const;\n   300→\n   301→// Protocol version\n   302→export const PROTOCOL_VERSION = '0.2.0';\n   303→"}]},"parent_tool_use_id":"toolu_01GAanv3ZUwLhFKCbmwQr7dA","session_id":"efe0d03e-8d66-4f31-bfdd-beb02c765aa8","uuid":"4c04d104-2382-4565-97f9-17ca74fca88f","timestamp":"2026-03-18T11:36:30.358Z"}
