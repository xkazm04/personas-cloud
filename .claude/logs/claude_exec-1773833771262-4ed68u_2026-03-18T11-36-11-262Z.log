 body.iv = encrypted.iv;\n   167→        body.tag = encrypted.tag;\n   168→        delete body.plaintext;\n   169→\n   170→        const cred = db.createCredential(tenantDb, body);\n   171→        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n   172→        json(res, 201, cred);\n   173→      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   174→        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n   175→        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   176→        json(res, 200, { deleted: true });\n   177→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n   178→        const creds = db.listCredentialsForPersona(tenantDb, route.id);"}]},"parent_tool_use_id":null,"session_id":"efe0d03e-8d66-4f31-bfdd-beb02c765aa8","uuid":"4032dde1-04da-4191-b60a-1d75f1c7c82b","timestamp":"2026-03-18T11:38:14.646Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n\n        // Require plaintext — clients must never supply pre-encrypted data\n        if (!body.plaintext || typeof body.plaintext !== 'string') {\n          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n          return;\n        }\n\n        // Reject oversized plaintext before synchronous encryption blocks the event loop\n        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n          return;\n        }\n\n        // Encryption is mandatory — reject if the key manager is unavailable\n        if (!tenantKeyManager) {\n          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n          return;\n        }\n\n        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n        delete body.encryptedData;\n        delete body.iv;\n        delete body.tag;\n\n        // Server-side encryption with per-tenant key\n        const tenantId = body.projectId || ctx.projectId || 'default';\n        const key = await tenantKeyManager.getKey(tenantId);\n        const encrypted = encrypt(body.plaintext, key);\n        body.encryptedData = encrypted.encrypted;\n        body.iv = encrypted.iv;\n        body.tag = encrypted.tag;\n        delete body.plaintext;\n\n        const cred = db.createCredential(tenantDb, body);\n        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n        json(res, 201, cred);\n      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n        const creds = db.listCredentialsForPersona(tenantDb, route.id);","numLines":45,"startLine":134,"totalLines":556}}}
