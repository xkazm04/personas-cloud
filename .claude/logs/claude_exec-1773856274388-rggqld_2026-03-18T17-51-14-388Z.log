[2026-03-18T17:52:14.974Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XHdeB8hkSkB5D5BXh4bDQE","type":"tool_result","content":"     1→import { type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type PhaseTimings, type EncryptedPayload, TOPICS, decrypt, DecryptionError, deriveMasterKeyAsync } from '@dac-cloud/shared';\n     2→import type Database from 'better-sqlite3';\n     3→import type { WorkerPool } from './workerPool.js';\n     4→import type { TokenManager } from './tokenManager.js';\n     5→import type { OAuthManager } from './oauth.js';\n     6→import type { KafkaClient } from './kafka.js';\n     7→import type { TenantDbManager } from './tenantDbManager.js';\n     8→import type { TenantKeyManager } from './tenantKeyManager.js';\n     9→import type { AuditLog } from './auditLog.js';\n    10→import type { Logger } from 'pino';\n    11→import * as db from './db/index.js';\n    12→import { resolveToken, ExecutionPreparer, type Decryptor } from './dispatchPipeline.js';\n    13→\n    14→interface QueuedExecution {\n    15→  request: ExecRequest;\n    16→  receivedAt: number;\n    17→}\n    18→\n    19→// Maximum number of times an execution will be re-queued after worker disconnect\n    20→const MAX_DISCONNECT_RETRIES = 2;\n    21→\n    22→// In-memory tracking for active executions (real-time output streaming)\n    23→interface ActiveExecution {\n    24→  workerId: string;\n    25→  startedAt: number;\n    26→  output: string[];\n    27→  status: 'running' | 'completed' | 'failed' | 'cancelled';\n    28→  progress?: ProgressInfo;\n    29→  completedAt?: number;\n    30→  exitCode?: number;\n    31→  durationMs?: number;\n    32→  sessionId?: string;\n    33→  totalCostUsd?: number;\n    34→  phaseTimings?: PhaseTimings;\n    35→  /** Original request kept for re-queuing on worker disconnect. Only present for in-flight executions. */\n    36→  request?: ExecRequest;\n    37→  /** How many times this execution has been re-queued after a worker disconnect. */\n    38→  disconnectRetries?: number;\n    39→}\n    40→\n    41→const OUTPUT_FLUSH_INTERVAL_MS = 500;\n    42→\n    43→export class Dispatcher {\n    44→  private queue: QueuedExecution[] = [];\n    45→  // In-memory map for real-time output + cancel routing (active executions only)\n    46→  private active = new Map<string, ActiveExecution>();\n    47→  private tenantDbManager: TenantDbManager | null = null;\n    48→  private masterKey: Buffer | null = null;\n    49→  private tenantKeyManager: TenantKeyManager | null = null;\n    50→  private auditLog: AuditLog | null = null;\n    51→  private preparer: ExecutionPreparer | null = null;\n    52→  // Maps executionId → projectId for DB resolution during callbacks\n    53→  private executionTenant = new Map<string, string>();\n    54→  // Batched output buffers: executionId → pending chunks\n    55→  private outputBuffers = new Map<string, string[]>();\n    56→  private outputFlushTimer: NodeJS.Timeout;\n    57→  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n    58→  private dispatching = false;\n    59→\n    60→  constructor(\n    61→    private pool: WorkerPool,\n    62→    private tokenManager: TokenManager,\n    63→    private oauth: OAuthManager | null,\n    64→    private kafka: KafkaClient,\n    65→    private logger: Logger,\n    66→  ) {\n    67→    // Periodic flush of batched output to DB\n    68→    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n    69→\n    70→    // When a worker becomes ready, try to dispatch queued work\n    71→    this.pool.on('worker-ready', () => {\n    72→      this.processQueue();\n    73→    });\n    74→\n    75→    // When a worker connects, try to dispatch\n    76→    this.pool.on('worker-connected', () => {\n    77→      this.processQueue();\n    78→    });\n    79→\n    80→    // Track stdout for execution output\n    81→    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n    82→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    83→    });\n    84→\n    85→    // Track stderr for debugging failed executions\n    86→    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n    87→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n    88→      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    89→    });\n    90→\n    91→    // Handle execution completion\n    92→    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n    93→      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n    94→        executionId: msg.executionId,\n    95→        status: msg.status,\n    96→        exitCode: msg.exitCode,\n    97→        durationMs: msg.durationMs,\n    98→        sessionId: msg.sessionId,\n    99→        totalCostUsd: msg.totalCostUsd,\n   100→        ...(msg.phaseTimings ? { phaseTimings: msg.phaseTimings } : {}),\n   101→      }), msg.executionId).catch(err => {\n   102→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n   103→      });\n   104→\n   105→      // Flush any remaining buffered output before persisting completion\n   106→      this.flushOutputForExecution(msg.executionId);\n   107→\n   108→      // Update in-memory\n   109→      const exec = this.active.get(msg.executionId);\n   110→      if (exec) {\n   111→        exec.status = msg.status;\n   112→        exec.completedAt = Date.now();\n   113→        exec.exitCode = msg.exitCode;\n   114→        exec.durationMs = msg.durationMs;\n   115→        exec.sessionId = msg.sessionId;\n   116→        exec.totalCostUsd = msg.totalCostUsd;\n   117→        exec.phaseTimings = msg.phaseTimings;\n   118→        // Remove from active after a short delay (allow polling to pick up final state)\n   119→        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n   120→      }\n   121→\n   122→      // Persist to DB\n   123→      const completeDb = this.resolveDbForExecution(msg.executionId);\n   124→      if (completeDb) {\n   125→        try {\n   126→          db.updateExecution(completeDb, msg.executionId, {\n   127→            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n   128→            completedAt: new Date().toISOString(),\n   129→            durationMs: msg.durationMs,\n   130→            claudeSessionId: msg.sessionId,\n   131→            costUsd: msg.totalCostUsd ?? 0,\n   132→          });\n   133→        } catch (err) {\n   134→          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n   135→        }\n   136→      }\n   137→\n   138→      // Clean up tenant mapping after completion delay\n   139→      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n   140→\n   141→      // Process next queued item\n   142→      this.processQueue();\n   143→    });\n   144→\n   145→    // Track execution progress\n   146→    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n   147→      const exec = this.active.get(msg.executionId);\n   148→      if (exec) {\n   149→        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n   150→      }\n   151→      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n   152→        executionId: msg.executionId,\n   153→        phase: msg.phase,\n   154→        percent: msg.percent,\n   155→        detail: msg.detail,\n   156→        timestamp: msg.timestamp,\n   157→      }), msg.executionId).catch(err => {\n   158→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n   159→      });\n   160→    });\n   161→\n   162→    // Forward persona events to Kafka\n   163→    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n   164→      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n   165→        executionId: msg.executionId,\n   166→        eventType: msg.eventType,\n   167→        payload: msg.payload,\n   168→        timestamp: Date.now(),\n   169→      }), msg.executionId).catch(err => {\n   170→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n   171→      });\n   172→    });\n   173→\n   174→    // Handle worker busy nack — re-queue the rejected execution\n   175→    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n   176→      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n   177→      const exec = this.active.get(msg.executionId);\n   178→      if (exec?.request) {\n   179→        const request = exec.request;\n   180→        this.active.delete(msg.executionId);\n   181→        // Mark as queued in DB\n   182→        const reqDb = this.resolveDbForExecution(msg.executionId);\n   183→        if (reqDb) {\n   184→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack'); }\n   185→        }\n   186→        this.queue.unshift({ request, receivedAt: Date.now() });\n   187→        this.processQueue();\n   188→      } else {\n   189→        // Fallback: reconstruct from DB if request was not stored (should not happen)\n   190→        this.active.delete(msg.executionId);\n   191→        const projectId = this.executionTenant.get(msg.executionId) || 'default';\n   192→        const reqDb = this.resolveDb(projectId);\n   193→        if (reqDb) {\n   194→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack fallback'); }\n   195→        }\n   196→        const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n   197→        if (dbExec) {\n   198→          this.queue.unshift({\n   199→            request: {\n   200→              executionId: msg.executionId,\n   201→              personaId: dbExec.personaId,\n   202→              prompt: dbExec.inputData || '',\n   203→              projectId,\n   204→              config: { timeoutMs: 300_000 },\n   205→            },\n   206→            receivedAt: Date.now(),\n   207→          });\n   208→          this.processQueue();\n   209→        }\n   210→      }\n   211→    });\n   212→\n   213→    // Handle worker disconnect during execution — re-queue if retries remain\n   214→    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n   215→      if (executionId) {\n   216→        const exec = this.active.get(executionId);\n   217→        const retries = exec?.disconnectRetries ?? 0;\n   218→\n   219→        if (exec?.request && retries < MAX_DISCONNECT_RETRIES) {\n   220→          // Re-queue for retry\n   221→          const nextRetry = retries + 1;\n   222→          this.logger.warn({ executionId, retry: nextRetry, maxRetries: MAX_DISCONNECT_RETRIES }, 'Worker disconnected during execution, re-queuing');\n   223→\n   224→          // Clear the active entry so dispatchToWorker can create a fresh one\n   225→          this.active.delete(executionId);\n   226→\n   227→          // Mark as queued in DB\n   228→          const disconnDb = this.resolveDbForExecution(executionId);\n   229→          if (disconnDb) {\n   230→            try {\n   231→              db.updateExecution(disconnDb, executionId, {\n   232→                status: 'queued',\n   233→                errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n   234→              });\n   235→            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on worker disconnect re-queue'); }\n   236→          }\n   237→\n   238→          // Temporarily store the retry count so dispatchToWorker picks it up\n   239→          const request = exec.request;\n   240→          // Create a placeholder active entry to carry retry count across re-dispatch\n   241→          this.active.set(executionId, {\n   242→            workerId: '',\n   243→            startedAt: 0,\n   244→            output: [],\n   245→            status: 'running',\n   246→            request,\n   247→            disconnectRetries: nextRetry,\n   248→          });\n   249→\n   250→          this.queue.unshift({ request, receivedAt: Date.now() });\n   251→          this.processQueue();\n   252→        } else {\n   253→          // Retries exhausted or no request stored — permanent failure\n   254→          this.logger.error({ executionId, retries }, 'Worker disconnected during execution, retries exhausted');\n   255→          if (exec) {\n   256→            exec.status = 'failed';\n   257→            exec.completedAt = Date.now();\n   258→            setTimeout(() => this.active.delete(executionId), 30_000);\n   259→          }\n   260→\n   261→          const disconnDb = this.resolveDbForExecution(executionId);\n   262→          if (disconnDb) {\n   263→            try {\n   264→              db.updateExecution(disconnDb, executionId, {\n   265→                status: 'failed',\n   266→                errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n   267→                completedAt: new Date().toISOString(),\n   268→              });\n   269→            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:failed' }, 'Failed to persist execution failure on worker disconnect'); }\n   270→          }\n   271→          this.executionTenant.delete(executionId);\n   272→\n   273→          this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   274→            executionId,\n   275→            status: 'failed',\n   276→            error: 'Worker disconnected (retries exhausted)',\n   277→            durationMs: 0,\n   278→          }), executionId).catch(err => { this.logger.warn({ err, executionId, op: 'kafka:exec_lifecycle' }, 'Failed to produce disconnect failure lifecycle to Kafka'); });\n   279→        }\n   280→      }\n   281→    });\n   282→  }\n   283→\n   284→  setTenantDbManager(mgr: TenantDbManager): void {\n   285→    this.tenantDbManager = mgr;\n   286→  }\n   287→\n   288→  async setMasterKey(masterKeyHex: string): Promise<void> {\n   289→    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n   290→  }\n   291→\n   292→  setTenantKeyManager(mgr: TenantKeyManager): void {\n   293→    this.tenantKeyManager = mgr;\n   294→  }\n   295→\n   296→  setAuditLog(log: AuditLog): void {\n   297→    this.auditLog = log;\n   298→  }\n   299→\n   300→  /** Resolve the database for a given projectId via tenant DB manager. */\n   301→  private resolveDb(projectId?: string): Database.Database | null {\n   302→    if (this.tenantDbManager && projectId) {\n   303→      return this.tenantDbManager.getTenantDb(projectId);\n   304→    }\n   305→    return null;\n   306→  }\n   307→\n   308→  /** Resolve the database for an in-flight execution by its ID. */\n   309→  private resolveDbForExecution(executionId: string): Database.Database | null {\n   310→    const projectId = this.executionTenant.get(executionId);\n   311→    return this.resolveDb(projectId);\n   312→  }\n   313→\n   314→  /**\n   315→   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   316→   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   317→   */\n   318→  private async decryptWithAudit(\n   319→    payload: EncryptedPayload,\n   320→    tenantId: string,\n   321→    resourceId: string,\n   322→    logContext: Record<string, unknown>,\n   323→    logMessage: string,\n   324→  ): Promise<string | undefined> {\n   325→    const decryptKey = this.tenantKeyManager\n   326→      ? await this.tenantKeyManager.getKey(tenantId)\n   327→      : this.masterKey;\n   328→    if (!decryptKey) return undefined;\n   329→\n   330→    try {\n   331→      const decrypted = decrypt(payload, decryptKey, { tenantId, credentialId: resourceId, resourceType: 'credential' });\n   332→      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n   333→      return decrypted;\n   334→    } catch (err) {\n   335→      const reason = err instanceof DecryptionError ? err.message : (err instanceof Error ? err.message : String(err));\n   336→      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n   337→      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: { reason } }); } catch { /* logged inside record() */ }\n   338→      return undefined;\n   339→    }\n   340→  }\n   341→\n   342→  submit(request: ExecRequest): void {\n   343→    this.logger.info({\n   344→      executionId: request.executionId,\n   345→      personaId: request.personaId,\n   346→      ...(request.eventId ? { eventId: request.eventId } : {}),\n   347→    }, 'Execution submitted');\n   348→\n   349→    // Track which tenant owns this execution (for callback DB resolution)\n   350→    const projectId = request.projectId || 'default';\n   351→    this.executionTenant.set(request.executionId, projectId);\n   352→\n   353→    // Create DB record immediately\n   354→    const submitDb = this.resolveDb(projectId);\n   355→    if (submitDb) {\n   356→      try {\n   357→        db.createExecution(submitDb, {\n   358→          id: request.executionId,\n   359→          personaId: request.personaId,\n   360→          inputData: request.prompt,\n   361→          projectId,\n   362→          eventId: request.eventId ?? null,\n   363→        });\n   364→      } catch (err) {\n   365→        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n   366→      }\n   367→    }\n   368→\n   369→    this.queue.push({ request, receivedAt: Date.now() });\n   370→    this.processQueue();\n   371→  }\n   372→\n   373→  private async processQueue(): Promise<void> {\n   374→    // Guard: only one processQueue loop runs at a time to prevent concurrent\n   375→    // calls from racing on getIdleWorker()/assign() and double-claiming a worker.\n   376→    if (this.dispatching) return;\n   377→    this.dispatching = true;\n   378→    try {\n   379→      while (this.queue.length > 0) {\n   380→        const workerId = this.pool.getIdleWorker();\n   381→        if (!workerId) {\n   382→          this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n   383→          return;\n   384→        }\n   385→\n   386→        const item = this.queue.shift()!;\n   387→        await this.dispatchToWorker(workerId, item.request);\n   388→      }\n   389→    } finally {\n   390→      this.dispatching = false;\n   391→    }\n   392→  }\n   393→\n   394→  /** Exposes decryptWithAudit as the Decryptor interface for pipeline stages. */\n   395→  private getDecryptor(): Decryptor {\n   396→    return {\n   397→      decrypt: (payload, tenantId, resourceId, logContext, logMessage) =>\n   398→        this.decryptWithAudit(payload, tenantId, resourceId, logContext, logMessage),\n   399→    };\n   400→  }\n   401→\n   402→  /** Lazily initialise the ExecutionPreparer (depends on mutable setter state). */\n   403→  private ensurePreparer(): ExecutionPreparer {\n   404→    if (!this.preparer) {\n   405→      this.preparer = new ExecutionPreparer(\n   406→        (projectId) => this.resolveDb(projectId),\n   407→        this.getDecryptor(),\n   408→        this.logger,\n   409→      );\n   410→    }\n   411→    return this.preparer;\n   412→  }\n   413→\n   414→  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n   415→    // Stage 1: Resolve token (stays in Dispatcher)\n   416→    const token = await resolveToken(this.oauth, this.tokenManager);\n   417→    if (!token) {\n   418→      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n   419→      this.queue.unshift({ request, receivedAt: Date.now() });\n   420→      return;\n   421→    }\n   422→\n   423→    // Stages 2-4: Persona resolution, payload assembly, assignment building\n   424→    const assignment = await this.ensurePreparer().prepare(request, token);\n   425→    const tenantId = request.projectId || 'default';\n   426→    const dispatchDb = this.resolveDb(tenantId);\n   427→\n   428→    // Track in-memory for real-time streaming (preserve retry count across re-dispatches)\n   429→    const prevRetries = this.active.get(request.executionId)?.disconnectRetries ?? 0;\n   430→    this.active.set(request.executionId, {\n   431→      workerId,\n   432→      startedAt: Date.now(),\n   433→      output: [],\n   434→      status: 'running',\n   435→      request,\n   436→      disconnectRetries: prevRetries,\n   437→    });\n   438→\n   439→    // Mark running in DB\n   440→    if (dispatchDb) {\n   441→      try {\n   442→        db.updateExecution(dispatchDb, request.executionId, {\n   443→          status: 'running',\n   444→          startedAt: new Date().toISOString(),\n   445→        });\n   446→      } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:running' }, 'Failed to mark execution as running in DB'); }\n   447→    }\n   448→\n   449→    const sent = this.pool.assign(workerId, assignment);\n   450→    if (!sent) {\n   451→      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n   452→      this.active.delete(request.executionId);\n   453→      if (dispatchDb) {\n   454→        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:queued' }, 'Failed to re-queue execution in DB after assign failure'); }\n   455→      }\n   456→      this.queue.unshift({ request, receivedAt: Date.now() });\n   457→      this.processQueue();\n   458→    } else {\n   459→      this.logger.info({\n   460→        workerId,\n   461→        executionId: request.executionId,\n   462→        personaId: request.personaId,\n   463→        ...(request.eventId ? { eventId: request.eventId } : {}),\n   464→      }, 'Execution dispatched to worker');\n   465→    }\n   466→  }\n   467→\n   468→  cancelExecution(executionId: string): boolean {\n   469→    const exec = this.active.get(executionId);\n   470→    if (!exec || exec.status !== 'running') return false;\n   471→\n   472→    return this.pool.send(exec.workerId, {\n   473→      type: 'cancel',\n   474→      executionId,\n   475→    });\n   476→  }\n   477→\n   478→  getQueueLength(): number {\n   479→    return this.queue.length;\n   480→  }\n   481→\n   482→  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n   483→    return Array.from(this.active.entries())\n   484→      .filter(([, e]) => e.status === 'running')\n   485→      .map(([executionId, e]) => ({\n   486→        executionId,\n   487→        workerId: e.workerId,\n   488→        startedAt: e.startedAt,\n   489→      }));\n   490→  }\n   491→\n   492→  /**\n   493→   * Get execution state. Tries in-memory first (for real-time output),\n   494→   * then falls back to DB for completed/historical executions.\n   495→   */\n   496→  getExecution(executionId: string): ActiveExecution | null {\n   497→    // Check in-memory active executions first\n   498→    const active = this.active.get(executionId);\n   499→    if (active) return active;\n   500→\n   501→    const execDb = this.resolveDbForExecution(executionId);\n   502→    if (execDb) {\n   503→      const dbExec = db.getExecution(execDb, executionId);\n   504→      if (dbExec) {\n   505→        return {\n   506→          workerId: '',\n   507→          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n   508→          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n   509→          status: dbExec.status as ActiveExecution['status'],\n   510→          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n   511→          durationMs: dbExec.durationMs ?? undefined,\n   512→          sessionId: dbExec.claudeSessionId ?? undefined,\n   513→          totalCostUsd: dbExec.costUsd ?? undefined,\n   514→        };\n   515→      }\n   516→    }\n   517→\n   518→    return null;\n   519→  }\n   520→\n   521→  getExecutionOutput(executionId: string): string[] | null {\n   522→    const exec = this.getExecution(executionId);\n   523→    return exec?.output ?? null;\n   524→  }\n   525→\n   526→  /** Shared handler for stdout/stderr output chunks. */\n   527→  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n   528→    const line = prefix ? `${prefix}${chunk}` : chunk;\n   529→\n   530→    const exec = this.active.get(executionId);\n   531→    if (exec) {\n   532→      exec.output.push(line);\n   533→    }\n   534→\n   535→    this.bufferOutput(executionId, line + '\\n');\n   536→\n   537→    // Forward stdout to Kafka (stderr is not forwarded)\n   538→    if (!prefix) {\n   539→      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n   540→        executionId,\n   541→        chunk,\n   542→        timestamp,\n   543→      }), executionId).catch(err => {\n   544→        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n   545→      });\n   546→    }\n   547→  }\n   548→\n   549→  /** Buffer an output chunk for batched DB write. */\n   550→  private bufferOutput(executionId: string, chunk: string): void {\n   551→    let buf = this.outputBuffers.get(executionId);\n   552→    if (!buf) {\n   553→      buf = [];\n   554→      this.outputBuffers.set(executionId, buf);\n   555→    }\n   556→    buf.push(chunk);\n   557→  }\n   558→\n   559→  /** Flush buffered output for a specific execution to DB. */\n   560→  private flushOutputForExecution(executionId: string): void {\n   561→    const buf = this.outputBuffers.get(executionId);\n   562→    if (!buf || buf.length === 0) return;\n   563→\n   564→    const combined = buf.join('');\n   565→    this.outputBuffers.delete(executionId);\n   566→\n   567→    const outputDb = this.resolveDbForExecution(executionId);\n   568→    if (outputDb) {\n   569→      try { db.appendOutput(outputDb, executionId, combined); } catch (err) { this.logger.warn({ err, executionId, op: 'appendOutput' }, 'Failed to flush buffered output to DB'); }\n   570→    }\n   571→  }\n   572→\n   573→  /** Flush all buffered output across all executions to DB. */\n   574→  private flushOutputBuffers(): void {\n   575→    for (const executionId of this.outputBuffers.keys()) {\n   576→      this.flushOutputForExecution(executionId);\n   577→    }\n   578→  }\n   579→\n   580→  shutdown(): void {\n   581→    clearInterval(this.outputFlushTimer);\n   582→    this.flushOutputBuffers();\n   583→  }\n   584→}\n   585→"}]},"parent_tool_use_id":null,"session_id":"27ac07f9-8903-458a-a3a2-560c623a88fe","uuid":"4c25795f-9426-4156-99d1-c32af6621edc","timestamp":"2026-03-18T17:52:14.715Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\dispatcher.ts","content":"import { type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type PhaseTimings, type EncryptedPayload, TOPICS, decrypt, DecryptionError, deriveMasterKeyAsync } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { resolveToken, ExecutionPreparer, type Decryptor } from './dispatchPipeline.js';\n\ninterface QueuedExecution {\n  request: ExecRequest;\n  receivedAt: number;\n}\n\n// Maximum number of times an execution will be re-queued after worker disconnect\nconst MAX_DISCONNECT_RETRIES = 2;\n\n// In-memory tracking for active executions (real-time output streaming)\ninterface ActiveExecution {\n  workerId: string;\n  startedAt: number;\n  output: string[];\n  status: 'running' | 'completed' | 'failed' | 'cancelled';\n  progress?: ProgressInfo;\n  completedAt?: number;\n  exitCode?: number;\n  durationMs?: number;\n  sessionId?: string;\n  totalCostUsd?: number;\n  phaseTimings?: PhaseTimings;\n  /** Original request kept for re-queuing on worker disconnect. Only present for in-flight executions. */\n  request?: ExecRequest;\n  /** How many times this execution has been re-queued after a worker disconnect. */\n  disconnectRetries?: number;\n}\n\nconst OUTPUT_FLUSH_INTERVAL_MS = 500;\n\nexport class Dispatcher {\n  private queue: QueuedExecution[] = [];\n  // In-memory map for real-time output + cancel routing (active executions only)\n  private active = new Map<string, ActiveExecution>();\n  private tenantDbManager: TenantDbManager | null = null;\n  private masterKey: Buffer | null = null;\n  private tenantKeyManager: TenantKeyManager | null = null;\n  private auditLog: AuditLog | null = null;\n  private preparer: ExecutionPreparer | null = null;\n  // Maps executionId → projectId for DB resolution during callbacks\n  private executionTenant = new Map<string, string>();\n  // Batched output buffers: executionId → pending chunks\n  private outputBuffers = new Map<string, string[]>();\n  private outputFlushTimer: NodeJS.Timeout;\n  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n  private dispatching = false;\n\n  constructor(\n    private pool: WorkerPool,\n    private tokenManager: TokenManager,\n    private oauth: OAuthManager | null,\n    private kafka: KafkaClient,\n    private logger: Logger,\n  ) {\n    // Periodic flush of batched output to DB\n    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n\n    // When a worker becomes ready, try to dispatch queued work\n    this.pool.on('worker-ready', () => {\n      this.processQueue();\n    });\n\n    // When a worker connects, try to dispatch\n    this.pool.on('worker-connected', () => {\n      this.processQueue();\n    });\n\n    // Track stdout for execution output\n    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    });\n\n    // Track stderr for debugging failed executions\n    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    });\n\n    // Handle execution completion\n    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n        executionId: msg.executionId,\n        status: msg.status,\n        exitCode: msg.exitCode,\n        durationMs: msg.durationMs,\n        sessionId: msg.sessionId,\n        totalCostUsd: msg.totalCostUsd,\n        ...(msg.phaseTimings ? { phaseTimings: msg.phaseTimings } : {}),\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n      });\n\n      // Flush any remaining buffered output before persisting completion\n      this.flushOutputForExecution(msg.executionId);\n\n      // Update in-memory\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.status = msg.status;\n        exec.completedAt = Date.now();\n        exec.exitCode = msg.exitCode;\n        exec.durationMs = msg.durationMs;\n        exec.sessionId = msg.sessionId;\n        exec.totalCostUsd = msg.totalCostUsd;\n        exec.phaseTimings = msg.phaseTimings;\n        // Remove from active after a short delay (allow polling to pick up final state)\n        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n      }\n\n      // Persist to DB\n      const completeDb = this.resolveDbForExecution(msg.executionId);\n      if (completeDb) {\n        try {\n          db.updateExecution(completeDb, msg.executionId, {\n            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n            completedAt: new Date().toISOString(),\n            durationMs: msg.durationMs,\n            claudeSessionId: msg.sessionId,\n            costUsd: msg.totalCostUsd ?? 0,\n          });\n        } catch (err) {\n          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n        }\n      }\n\n      // Clean up tenant mapping after completion delay\n      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n\n      // Process next queued item\n      this.processQueue();\n    });\n\n    // Track execution progress\n    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n      }\n      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n        executionId: msg.executionId,\n        phase: msg.phase,\n        percent: msg.percent,\n        detail: msg.detail,\n        timestamp: msg.timestamp,\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n      });\n    });\n\n    // Forward persona events to Kafka\n    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n        executionId: msg.executionId,\n        eventType: msg.eventType,\n        payload: msg.payload,\n        timestamp: Date.now(),\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n      });\n    });\n\n    // Handle worker busy nack — re-queue the rejected execution\n    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n      const exec = this.active.get(msg.executionId);\n      if (exec?.request) {\n        const request = exec.request;\n        this.active.delete(msg.executionId);\n        // Mark as queued in DB\n        const reqDb = this.resolveDbForExecution(msg.executionId);\n        if (reqDb) {\n          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack'); }\n        }\n        this.queue.unshift({ request, receivedAt: Date.now() });\n        this.processQueue();\n      } else {\n        // Fallback: reconstruct from DB if request was not stored (should not happen)\n        this.active.delete(msg.executionId);\n        const projectId = this.executionTenant.get(msg.executionId) || 'default';\n        const reqDb = this.resolveDb(projectId);\n        if (reqDb) {\n          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack fallback'); }\n        }\n        const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n        if (dbExec) {\n          this.queue.unshift({\n            request: {\n              executionId: msg.executionId,\n              personaId: dbExec.personaId,\n              prompt: dbExec.inputData || '',\n              projectId,\n              config: { timeoutMs: 300_000 },\n            },\n            receivedAt: Date.now(),\n          });\n          this.processQueue();\n        }\n      }\n    });\n\n    // Handle worker disconnect during execution — re-queue if retries remain\n    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n      if (executionId) {\n        const exec = this.active.get(executionId);\n        const retries = exec?.disconnectRetries ?? 0;\n\n        if (exec?.request && retries < MAX_DISCONNECT_RETRIES) {\n          // Re-queue for retry\n          const nextRetry = retries + 1;\n          this.logger.warn({ executionId, retry: nextRetry, maxRetries: MAX_DISCONNECT_RETRIES }, 'Worker disconnected during execution, re-queuing');\n\n          // Clear the active entry so dispatchToWorker can create a fresh one\n          this.active.delete(executionId);\n\n          // Mark as queued in DB\n          const disconnDb = this.resolveDbForExecution(executionId);\n          if (disconnDb) {\n            try {\n              db.updateExecution(disconnDb, executionId, {\n                status: 'queued',\n                errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n              });\n            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on worker disconnect re-queue'); }\n          }\n\n          // Temporarily store the retry count so dispatchToWorker picks it up\n          const request = exec.request;\n          // Create a placeholder active entry to carry retry count across re-dispatch\n          this.active.set(executionId, {\n            workerId: '',\n            startedAt: 0,\n            output: [],\n            status: 'running',\n            request,\n            disconnectRetries: nextRetry,\n          });\n\n          this.queue.unshift({ request, receivedAt: Date.now() });\n          this.processQueue();\n        } else {\n          // Retries exhausted or no request stored — permanent failure\n          this.logger.error({ executionId, retries }, 'Worker disconnected during execution, retries exhausted');\n          if (exec) {\n            exec.status = 'failed';\n            exec.completedAt = Date.now();\n            setTimeout(() => this.active.delete(executionId), 30_000);\n          }\n\n          const disconnDb = this.resolveDbForExecution(executionId);\n          if (disconnDb) {\n            try {\n              db.updateExecution(disconnDb, executionId, {\n                status: 'failed',\n                errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n                completedAt: new Date().toISOString(),\n              });\n            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:failed' }, 'Failed to persist execution failure on worker disconnect'); }\n          }\n          this.executionTenant.delete(executionId);\n\n          this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n            executionId,\n            status: 'failed',\n            error: 'Worker disconnected (retries exhausted)',\n            durationMs: 0,\n          }), executionId).catch(err => { this.logger.warn({ err, executionId, op: 'kafka:exec_lifecycle' }, 'Failed to produce disconnect failure lifecycle to Kafka'); });\n        }\n      }\n    });\n  }\n\n  setTenantDbManager(mgr: TenantDbManager): void {\n    this.tenantDbManager = mgr;\n  }\n\n  async setMasterKey(masterKeyHex: string): Promise<void> {\n    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n  }\n\n  setTenantKeyManager(mgr: TenantKeyManager): void {\n    this.tenantKeyManager = mgr;\n  }\n\n  setAuditLog(log: AuditLog): void {\n    this.auditLog = log;\n  }\n\n  /** Resolve the database for a given projectId via tenant DB manager. */\n  private resolveDb(projectId?: string): Database.Database | null {\n    if (this.tenantDbManager && projectId) {\n      return this.tenantDbManager.getTenantDb(projectId);\n    }\n    return null;\n  }\n\n  /** Resolve the database for an in-flight execution by its ID. */\n  private resolveDbForExecution(executionId: string): Database.Database | null {\n    const projectId = this.executionTenant.get(executionId);\n    return this.resolveDb(projectId);\n  }\n\n  /**\n   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   */\n  private async decryptWithAudit(\n    payload: EncryptedPayload,\n    tenantId: string,\n    resourceId: string,\n    logContext: Record<string, unknown>,\n    logMessage: string,\n  ): Promise<string | undefined> {\n    const decryptKey = this.tenantKeyManager\n      ? await this.tenantKeyManager.getKey(tenantId)\n      : this.masterKey;\n    if (!decryptKey) return undefined;\n\n    try {\n      const decrypted = decrypt(payload, decryptKey, { tenantId, credentialId: resourceId, resourceType: 'credential' });\n      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n      return decrypted;\n    } catch (err) {\n      const reason = err instanceof DecryptionError ? err.message : (err instanceof Error ? err.message : String(err));\n      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: { reason } }); } catch { /* logged inside record() */ }\n      return undefined;\n    }\n  }\n\n  submit(request: ExecRequest): void {\n    this.logger.info({\n      executionId: request.executionId,\n      personaId: request.personaId,\n      ...(request.eventId ? { eventId: request.eventId } : {}),\n    }, 'Execution submitted');\n\n    // Track which tenant owns this execution (for callback DB resolution)\n    const projectId = request.projectId || 'default';\n    this.executionTenant.set(request.executionId, projectId);\n\n    // Create DB record immediately\n    const submitDb = this.resolveDb(projectId);\n    if (submitDb) {\n      try {\n        db.createExecution(submitDb, {\n          id: request.executionId,\n          personaId: request.personaId,\n          inputData: request.prompt,\n          projectId,\n          eventId: request.eventId ?? null,\n        });\n      } catch (err) {\n        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n      }\n    }\n\n    this.queue.push({ request, receivedAt: Date.now() });\n    this.processQueue();\n  }\n\n  private async processQueue(): Promise<void> {\n    // Guard: only one processQueue loop runs at a time to prevent concurrent\n    // calls from racing on getIdleWorker()/assign() and double-claiming a worker.\n    if (this.dispatching) return;\n    this.dispatching = true;\n    try {\n      while (this.queue.length > 0) {\n        const workerId = this.pool.getIdleWorker();\n        if (!workerId) {\n          this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n          return;\n        }\n\n        const item = this.queue.shift()!;\n        await this.dispatchToWorker(workerId, item.request);\n      }\n    } finally {\n      this.dispatching = false;\n    }\n  }\n\n  /** Exposes decryptWithAudit as the Decryptor interface for pipeline stages. */\n  private getDecryptor(): Decryptor {\n    return {\n      decrypt: (payload, tenantId, resourceId, logContext, logMessage) =>\n        this.decryptWithAudit(payload, tenantId, resourceId, logContext, logMessage),\n    };\n  }\n\n  /** Lazily initialise the ExecutionPreparer (depends on mutable setter state). */\n  private ensurePreparer(): ExecutionPreparer {\n    if (!this.preparer) {\n      this.preparer = new ExecutionPreparer(\n        (projectId) => this.resolveDb(projectId),\n        this.getDecryptor(),\n        this.logger,\n      );\n    }\n    return this.preparer;\n  }\n\n  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n    // Stage 1: Resolve token (stays in Dispatcher)\n    const token = await resolveToken(this.oauth, this.tokenManager);\n    if (!token) {\n      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      return;\n    }\n\n    // Stages 2-4: Persona resolution, payload assembly, assignment building\n    const assignment = await this.ensurePreparer().prepare(request, token);\n    const tenantId = request.projectId || 'default';\n    const dispatchDb = this.resolveDb(tenantId);\n\n    // Track in-memory for real-time streaming (preserve retry count across re-dispatches)\n    const prevRetries = this.active.get(request.executionId)?.disconnectRetries ?? 0;\n    this.active.set(request.executionId, {\n      workerId,\n      startedAt: Date.now(),\n      output: [],\n      status: 'running',\n      request,\n      disconnectRetries: prevRetries,\n    });\n\n    // Mark running in DB\n    if (dispatchDb) {\n      try {\n        db.updateExecution(dispatchDb, request.executionId, {\n          status: 'running',\n          startedAt: new Date().toISOString(),\n        });\n      } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:running' }, 'Failed to mark execution as running in DB'); }\n    }\n\n    const sent = this.pool.assign(workerId, assignment);\n    if (!sent) {\n      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n      this.active.delete(request.executionId);\n      if (dispatchDb) {\n        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:queued' }, 'Failed to re-queue execution in DB after assign failure'); }\n      }\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      this.processQueue();\n    } else {\n      this.logger.info({\n        workerId,\n        executionId: request.executionId,\n        personaId: request.personaId,\n        ...(request.eventId ? { eventId: request.eventId } : {}),\n      }, 'Execution dispatched to worker');\n    }\n  }\n\n  cancelExecution(executionId: string): boolean {\n    const exec = this.active.get(executionId);\n    if (!exec || exec.status !== 'running') return false;\n\n    return this.pool.send(exec.workerId, {\n      type: 'cancel',\n      executionId,\n    });\n  }\n\n  getQueueLength(): number {\n    return this.queue.length;\n  }\n\n  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n    return Array.from(this.active.entries())\n      .filter(([, e]) => e.status === 'running')\n      .map(([executionId, e]) => ({\n        executionId,\n        workerId: e.workerId,\n        startedAt: e.startedAt,\n      }));\n  }\n\n  /**\n   * Get execution state. Tries in-memory first (for real-time output),\n   * then falls back to DB for completed/historical executions.\n   */\n  getExecution(executionId: string): ActiveExecution | null {\n    // Check in-memory active executions first\n    const active = this.active.get(executionId);\n    if (active) return active;\n\n    const execDb = this.resolveDbForExecution(executionId);\n    if (execDb) {\n      const dbExec = db.getExecution(execDb, executionId);\n      if (dbExec) {\n        return {\n          workerId: '',\n          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n          status: dbExec.status as ActiveExecution['status'],\n          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n          durationMs: dbExec.durationMs ?? undefined,\n          sessionId: dbExec.claudeSessionId ?? undefined,\n          totalCostUsd: dbExec.costUsd ?? undefined,\n        };\n      }\n    }\n\n    return null;\n  }\n\n  getExecutionOutput(executionId: string): string[] | null {\n    const exec = this.getExecution(executionId);\n    return exec?.output ?? null;\n  }\n\n  /** Shared handler for stdout/stderr output chunks. */\n  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n    const line = prefix ? `${prefix}${chunk}` : chunk;\n\n    const exec = this.active.get(executionId);\n    if (exec) {\n      exec.output.push(line);\n    }\n\n    this.bufferOutput(executionId, line + '\\n');\n\n    // Forward stdout to Kafka (stderr is not forwarded)\n    if (!prefix) {\n      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n        executionId,\n        chunk,\n        timestamp,\n      }), executionId).catch(err => {\n        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n      });\n    }\n  }\n\n  /** Buffer an output chunk for batched DB write. */\n  private bufferOutput(executionId: string, chunk: string): void {\n    let buf = this.outputBuffers.get(executionId);\n    if (!buf) {\n      buf = [];\n      this.outputBuffers.set(executionId, buf);\n    }\n    buf.push(chunk);\n  }\n\n  /** Flush buffered output for a specific execution to DB. */\n  private flushOutputForExecution(executionId: string): void {\n    const buf = this.outputBuffers.get(executionId);\n    if (!buf || buf.length === 0) return;\n\n    const combined = buf.join('');\n    this.outputBuffers.delete(executionId);\n\n    const outputDb = this.resolveDbForExecution(executionId);\n    if (outputDb) {\n      try { db.appendOutput(outputDb, executionId, combined); } catch (err) { this.logger.warn({ err, executionId, op: 'appendOutput' }, 'Failed to flush buffered output to DB'); }\n    }\n  }\n\n  /** Flush all buffered output across all executions to DB. */\n  private flushOutputBuffers(): void {\n    for (const executionId of this.outputBuffers.keys()) {\n      this.flushOutputForExecution(executionId);\n    }\n  }\n\n  shutdown(): void {\n    clearInterval(this.outputFlushTimer);\n    this.flushOutputBuffers();\n  }\n}\n","numLines":585,"startLine":1,"totalLines":585}}}
