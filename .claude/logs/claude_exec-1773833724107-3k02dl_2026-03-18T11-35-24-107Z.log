[2026-03-18T11:35:45.135Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TLJLyVRisa3oDMV8AvYREL","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import { matchEvent, assemblePrompt } from '@dac-cloud/shared';\n     4→import type { ExecRequest, EventMatch, PersonaEvent } from '@dac-cloud/shared';\n     5→import { nanoid } from 'nanoid';\n     6→import * as db from './db/index.js';\n     7→import type { Dispatcher } from './dispatcher.js';\n     8→import type { TenantDbManager } from './tenantDbManager.js';\n     9→\n    10→/** Default threshold (seconds) for the periodic stale-event reaper. */\n    11→const STALE_EVENT_REAPER_SECONDS = 120;\n    12→/** Run the reaper every N ticks (at 2s interval, 30 ticks = ~60s). */\n    13→const REAPER_TICK_INTERVAL = 30;\n    14→\n    15→/**\n    16→ * Recover events orphaned in 'processing' state from a prior crash.\n    17→ * Call once at startup before the tick loop begins.\n    18→ */\n    19→function recoverOrphanedEvents(\n    20→  database: Database.Database | null,\n    21→  logger: Logger,\n    22→  tenantDbManager?: TenantDbManager,\n    23→): void {\n    24→  if (tenantDbManager) {\n    25→    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    26→      const count = db.resetAllProcessingEvents(tenantDb);\n    27→      if (count > 0) {\n    28→        logger.warn({ projectId, count }, 'Reset orphaned processing events to pending at startup');\n    29→      }\n    30→    });\n    31→  } else if (database) {\n    32→    const count = db.resetAllProcessingEvents(database);\n    33→    if (count > 0) {\n    34→      logger.warn({ count }, 'Reset orphaned processing events to pending at startup');\n    35→    }\n    36→  }\n    37→}\n    38→\n    39→/**\n    40→ * Periodic reaper: reset events stuck in 'processing' longer than the threshold.\n    41→ * Guards against edge cases during normal