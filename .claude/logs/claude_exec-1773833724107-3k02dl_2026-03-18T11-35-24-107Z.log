[2026-03-18T11:35:36.233Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012moshyY6wnfUWUPdtQkrSc","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import * as db from './db/index.js';\n     4→import type { TenantDbManager } from './tenantDbManager.js';\n     5→\n     6→/**\n     7→ * Start the trigger scheduler loop.\n     8→ * Supports both tenant-isolated DBs (via TenantDbManager) and legacy single DB.\n     9→ */\n    10→export function startTriggerScheduler(\n    11→  database: Database.Database | null,\n    12→  logger: Logger,\n    13→  interval: number = 5000,\n    14→  tenantDbManager?: TenantDbManager,\n    15→): NodeJS.Timeout {\n    16→  logger.info({ intervalMs: interval, tenantIsolated: !!tenantDbManager }, 'Trigger scheduler started');\n    17→\n    18→  return setInterval(() => {\n    19→    try {\n    20→      if (tenantDbManager) {\n    21→        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    22→          try {\n    23→            triggerSchedulerTick(tenantDb, logger, projectId);\n    24→          } catch (err) {\n    25→            logger.error({ err, projectId }, 'Trigger scheduler tick failed for tenant');\n    26→          }\n    27→        });\n    28→      } else if (database) {\n    29→        triggerSchedulerTick(database, logger);\n    30→      }\n    31→    } catch (err) {\n    32→      logger.error({ err }, 'Trigger scheduler tick failed');\n    33→    }\n    34→  }, interval);\n    35→}\n    36→\n    37→function triggerSchedulerTick(\n    38→  database: Database.Database,\n    39→  logger: Logger,\n    40→  projectId?: string,\n    41→): void {\n    42→  const triggers = db.getDueTriggersWithPersona(database);\n    43→  if (triggers.length === 0) return;\n    44→\n    45→  for (const trigger of triggers) {\n    46→    // Skip polling triggers (handled separately if needed)\n    47→    if (trigger.triggerType === 'polling') continue;\n    48→\n    49→    try {\n    50→      // Use pre-parsed typed config — no JSON.parse in the hot path\n    51→      const parsedConfig = trigger.parsedConfig;\n    52→\n    53→      let eventType = 'trigger_fired';\n    54→      let payload: string | null = null;\n    55→      if (parsedConfig) {\n    56→        if (parsedConfig.event_type) eventType = parsedConfig.event_type;\n    57→        if (parsedConfig.payload) payload = JSON.stringify(parsedConfig.payload);\n    58→      }\n    59→\n    60→      // Skip triggers for deleted or disabled personas (persona info from JOIN)\n    61→      if (trigger.personaProjectId == null) {\n    62→        logger.warn({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona not found (deleted?)');\n    63→        continue;\n    64→      }\n    65→      if (!trigger.personaEnabled) {\n    66→        logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');\n    67→        continue;\n    68→      }\n    69→\n    70→      const triggerProjectId = projectId ?? trigger.personaProjectId;\n    71→\n    72→      // Publish event to bus\n    73→      db.publishEvent(database, {\n    74→        eventType,\n    75→        sourceType: 'trigger',\n    76→        sourceId: trigger.id,\n    77→        targetPersonaId: trigger.personaId,\n    78→        projectId: triggerProjectId,\n    79→        useCaseId: trigger.useCaseId,\n    80→        payload,\n    81→      });\n    82→\n    83→      // Compute next trigger time using already-parsed config\n    84→      const now = new Date().toISOString();\n    85→      const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);\n    86→\n    87→      db.updateTriggerTimings(database, trigger.id, now, nextTriggerAt);\n    88→\n    89→      logger.info({\n    90→        triggerId: trigger.id,\n    91→        personaId: trigger.personaId,\n    92→        eventType,\n    93→        nextTriggerAt,\n    94→      }, 'Trigger fired');\n    95→    } catch (err) {\n    96→      logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');\n    97→    }\n    98→  }\n    99→}\n   100→"}]},"parent_tool_use_id":null,"session_id":"3cd1de78-183a-4853-ace9-82025cbb64fe","uuid":"68595954-f7e2-4681-833f-32a31f361075","timestamp":"2026-03-18T11:35:35.982Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\triggerScheduler.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\n\n/**\n * Start the trigger scheduler loop.\n * Supports both tenant-isolated DBs (via TenantDbManager) and legacy single DB.\n */\nexport function startTriggerScheduler(\n  database: Database.Database | null,\n  logger: Logger,\n  interval: number = 5000,\n  tenantDbManager?: TenantDbManager,\n): NodeJS.Timeout {\n  logger.info({ intervalMs: interval, tenantIsolated: !!tenantDbManager }, 'Trigger scheduler started');\n\n  return setInterval(() => {\n    try {\n      if (tenantDbManager) {\n        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n          try {\n            triggerSchedulerTick(tenantDb, logger, projectId);\n          } catch (err) {\n            logger.error({ err, projectId }, 'Trigger scheduler tick failed for tenant');\n          }\n        });\n      } else if (database) {\n        triggerSchedulerTick(database, logger);\n      }\n    } catch (err) {\n      logger.error({ err }, 'Trigger scheduler tick failed');\n    }\n  }, interval);\n}\n\nfunction triggerSchedulerTick(\n  database: Database.Database,\n  logger: Logger,\n  projectId?: string,\n): void {\n  const triggers = db.getDueTriggersWithPersona(database);\n  if (triggers.length === 0) return;\n\n  for (const trigger of triggers) {\n    // Skip polling triggers (handled separately if needed)\n    if (trigger.triggerType === 'polling') continue;\n\n    try {\n      // Use pre-parsed typed config — no JSON.parse in the hot path\n      const parsedConfig = trigger.parsedConfig;\n\n      let eventType = 'trigger_fired';\n      let payload: string | null = null;\n      if (parsedConfig) {\n        if (parsedConfig.event_type) eventType = parsedConfig.event_type;\n        if (parsedConfig.payload) payload = JSON.stringify(parsedConfig.payload);\n      }\n\n      // Skip triggers for deleted or disabled personas (persona info from JOIN)\n      if (trigger.personaProjectId == null) {\n        logger.warn({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona not found (deleted?)');\n        continue;\n      }\n      if (!trigger.personaEnabled) {\n        logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');\n        continue;\n      }\n\n      const triggerProjectId = projectId ?? trigger.personaProjectId;\n\n      // Publish event to bus\n      db.publishEvent(database, {\n        eventType,\n        sourceType: 'trigger',\n        sourceId: trigger.id,\n        targetPersonaId: trigger.personaId,\n        projectId: triggerProjectId,\n        useCaseId: trigger.useCaseId,\n        payload,\n      });\n\n      // Compute next trigger time using already-parsed config\n      const now = new Date().toISOString();\n      const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);\n\n      db.updateTriggerTimings(database, trigger.id, now, nextTriggerAt);\n\n      logger.info({\n        triggerId: trigger.id,\n        personaId: trigger.personaId,\n        eventType,\n        nextTriggerAt,\n      }, 'Trigger fired');\n    } catch (err) {\n      logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');\n    }\n  }\n}\n","numLines":100,"startLine":1,"totalLines":100}}}
