→    cause: unknown,\n    50→  ) {\n    51→    super(`Audit write failed for action \"${entry.action}\"`);\n    52→    this.name = 'AuditWriteError';\n    53→    this.cause = cause;\n    54→  }\n    55→}\n    56→\n    57→export interface AuditEntry {\n    58→  action: string;\n    59→  tenantId?: string;\n    60→  actor?: string;\n    61→  resourceType?: string;\n    62→  resourceId?: string;\n    63→  detail?: string;\n    64→  ipAddress?: string;\n    65→}\n    66→\n    67→/** Row shape returned by audit_events queries. */\n    68→export interface AuditEvent {\n    69→  id: number;\n    70→  timestamp: string;\n    71→  action: string;\n    72→  tenant_id: string | null;\n    73→  actor: string | null;\n    74→  resource_type: string | null;\n    75→  resource_id: string | null;\n    76→  detail: string | null;\n    77→  ip_address: string | null;\n    78→  prev_hash: string | null;\n    79→}\n    80→\n    81→/** Result of verifying the audit hash chain. */\n    82→export interface ChainVerifyResult {\n    83→  valid: boolean;\n    84→  verifiedCount: number;\n    85→  brokenAtId?: number;\n    86→}\n    87→\n    88→/** Max entries buffered before an automatic flush. */\n    89→const BUFFER_FLUSH_SIZE = 50;\n    90→/** Interval (ms) between timer-based flushes. */\n    91→const BUFFER_FLUSH_INTERVAL_MS = 100;\n    92→\n    93→interface BufferedEntry {\n    94→  timestamp: string;\n    95→  action: string;\n    96→  tenantId: string | null;\n    97→  actor: string | null;\n    98→  resourceType: string | null;\n    99→  resourceId: string | null;\n   100→  detail: string | null;\n   101→  ipAddress: string | null;\n   102→}\n   103→\n   104→export class AuditLog {\n   105→  private db: Database.Database;\n   106→  private insertStmt: Database.Statement;\n   107→  private queryStmtCache = new Map<string, Database.Statement>();\n   108→  private buffer: BufferedEntry[] = [];\n   109→  private flushTimer: NodeJS.Timeout | null = null;\n   110→  private batchInsert: (entries: BufferedEntry[], hashes: string[]) => void;\n   111→  private lastHash: string;\n   112→\n   113→  constructor(\n   114→    dbPath: string,\n   115→    private logger: Logger,\n   116→  ) {\n   117→    this.db = new Database(dbPath);\n   118→    this.db.pragma('journal_mode = WAL');\n   119→    this.db.exec(AUDIT_SCHEMA);\n   120→\n   121→    // Migration: add prev_hash column to existing databases that lack it\n   122→    const cols = this.db.pragma('table_info(audit_events)') as { name: string }[];\n   123→    if (!cols.some((c) => c.name === 'prev_hash')) {\n   124→      this.db.exec('ALTER TABLE audit_events ADD COLUMN prev_hash TEXT');\n   125→    }\n   126→\n   127→    this.insertStmt = this.db.prepare(\n   128→      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address, prev_hash) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',\n   129→    );\n   130→\n   131→    // Initialize chain from last stored hash (or genesis for empty / pre-chain DBs)\n   132→    const lastRow = this.db.prepare(\n   133→      'SELECT prev_hash FROM audit_events WHERE prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n   134→    ).get() as { prev_hash: string } | undefined;\n   135→    this.lastHash = lastRow?.prev_hash ?? GENESIS_HASH;\n   136→\n   137→    // Wrap N inserts in a single transaction — one fsync instead of N\n   138→    const stmt = this.insertStmt;\n   139→    this.batchInsert = this.db.transaction((entries: BufferedEntry[], hashes: string[]) => {\n   140→      for (let i = 0; i < entries.length; i++) {\n   141→        const e = entries[i];\n   142→        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress, hashes[i]);\n   143→      }\n   144→    });\n   145→\n   146→    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n   147→\n   148→    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled, hash-chain active)');\n   149→  }\n   150→\n   151→  /** Expose the underlying database for use by RetentionPolicy. */\n   152→  getDb(): Database.Database {\n   153→    return this.db;\n   154→  }\n   155→\n   156→  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n   157→  countEvents(before?: string): number {\n   158→    const stmt = before\n   159→      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n   160→      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n   161→    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n   162→    return row.cnt;\n   163→  }\n   164→\n   165→  /**\n   166→   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   167→   * yielding the event loop between batches so concurrent DB operations\n   168→   * are not starved during large purges.\n   169→   */\n   170→  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n   171→    const deleteChunk = this.db.prepare(\n   172→      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n   173→    );\n   174→    let totalDeleted = 0;\n   175→    while (true) {\n   176→      const result = deleteChunk.run(cutoff, chunkSize);\n   177→      totalDeleted += result.changes;\n   178→      if (result.changes < chunkSize) break;\n   179→      await new Promise<void>((resolve) => setImmediate(resolve));\n   180→    }\n   181→    return totalDeleted;\n   182→  }\n   183→\n   184→  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n   185→  record(entry: AuditEntry): void {\n   186→    this.buffer.push({\n   187→      timestamp: new Date().toISOString(),\n   188→      action: entry.action,\n   189→      tenantId: entry.tenantId ?? null,\n   190→      actor: entry.actor ?? null,\n   191→      resourceType: entry.resourceType ?? null,\n   192→      resourceId: entry.resourceId ?? null,\n   193→      detail: entry.detail ?? null,\n   194→      ipAddress: entry.ipAddress ?? null,\n   195→    });\n   196→    if (this.buffer.length >= BUFFER_FLUSH_SIZE) {\n   197→      this.flush();\n   198→    }\n   199→  }\n   200→\n   201→  /** Flush buffered entries to SQLite in a single transaction, computing chain hashes. */\n   202→  flush(): void {\n   203→    if (this.buffer.length === 0) return;\n   204→    const batch = this.buffer;\n   205→    this.buffer = [];\n   206→\n   207→    // Compute chain hashes for the batch\n   208→    const hashes: string[] = [];\n   209→    let prevHash = this.lastHash;\n   210→    for (const entry of batch) {\n   211→      prevHash = computeChainHash(prevHash, entry);\n   212→      hashes.push(prevHash);\n   213→    }\n   214→\n   215→    try {\n   216→      this.batchInsert(batch, hashes);\n   217→      this.lastHash = prevHash;\n   218→    } catch (err) {\n   219→      this.logger.error({ err, count: batch.length }, 'Audit batch write failed — audit trail gap');\n   220→    }\n   221→  }\n   222→\n   223→  /** Query audit events with optional filters. */\n   224→  query(opts?: {\n   225→    tenantId?: string;\n   226→    action?: string;\n   227→    since?: string;\n   228→    limit?: number;\n   229→    offset?: number;\n   230→  }): AuditEvent[] {\n   231→    const params: unknown[] = [];\n   232→    const clauses: string[] = [];\n   233→    const keyParts: string[] = [];\n   234→\n   235→    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n   236→    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n   237→    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n   238→\n   239→    const key = keyParts.join('-') || 'none';\n   240→    let stmt = this.queryStmtCache.get(key);\n   241→    if (!stmt) {\n   242→      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   243→      stmt = this.db.prepare(\n   244→        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n   245→      );\n   246→      this.queryStmtCache.set(key, stmt);\n   247→    }\n   248→\n   249→    const limit = opts?.limit ?? 100;\n   250→    const offset = opts?.offset ?? 0;\n   251→\n   252→    return stmt.all(...params, limit, offset) as AuditEvent[];\n   253→  }\n   254→\n   255→  /**\n   256→   * Verify the integrity of the audit hash chain.\n   257→   * Iterates all chained rows and checks that each hash is consistent with\n   258→   * its predecessor. Pre-chain rows (migrated without prev_hash) are skipped.\n   259→   * If rows were purged, the chain will break at the first remaining row\n   260→   * — this is by design (deletions are detectable).\n   261→   */\n   262→  verify(): ChainVerifyResult {\n   263→    this.flush(); // ensure all buffered entries are persisted\n   264→    const iter = this.db.prepare('SELECT * FROM audit_events ORDER BY id ASC').iterate();\n   265→\n   266→    let prevHash = GENESIS_HASH;\n   267→    let verifiedCount = 0;\n   268→\n   269→    for (const raw of iter) {\n   270→      const row = raw as AuditEvent;\n   271→      if (row.prev_hash === null) continue; // pre-chain row\n   272→\n   273→      const expected = computeChainHash(prevHash, {\n   274→        timestamp: row.timestamp,\n   275→        action: row.action,\n   276→        tenantId: row.tenant_id,\n   277→        actor: row.actor,\n   278→        resourceType: row.resource_type,\n   279→        resourceId: row.resource_id,\n   280→        detail: row.detail,\n   281→        ipAddress: row.ip_address,\n   282→      });\n   283→\n   284→      if (row.prev_hash !== expected) {\n   285→        return { valid: false, verifiedCount, brokenAtId: row.id };\n   286→      }\n   287→\n   288→      prevHash = row.prev_hash;\n   289→      verifiedCount++;\n   290→    }\n   291→\n   292→    return { valid: true, verifiedCount };\n   293→  }\n   294→\n   295→  close(): void {\n   296→    if (this.flushTimer) {\n   297→      clearInterval(this.flushTimer);\n   298→      this.flushTimer = null;\n   299→    }\n   300→    this.flush();\n   301→    try { this.db.close(); } catch { /* best effort */ }\n   302→  }\n   303→}\n   304→"}]},"parent_tool_use_id":null,"session_id":"f188d125-8db6-4907-a2dd-273e8cf82b64","uuid":"6f4f8708-f535-42f6-b20b-8988a86b68b6","timestamp":"2026-03-18T17:46:45.335Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\auditLog.ts","content":"import crypto from 'node:crypto';\nimport Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\n\n/** SHA-256 hash chain genesis value (64 hex zeros). */\nconst GENESIS_HASH = '0'.repeat(64);\n\n/**\n * Compute a chain hash: SHA-256(previousHash + deterministic JSON of entry fields).\n * Each entry's hash commits to the entire chain history before it.\n */\nfunction computeChainHash(prevHash: string, entry: BufferedEntry): string {\n  const payload = prevHash + JSON.stringify([\n    entry.timestamp,\n    entry.action,\n    entry.tenantId,\n    entry.actor,\n    entry.resourceType,\n    entry.resourceId,\n    entry.detail,\n    entry.ipAddress,\n  ]);\n  return crypto.createHash('sha256').update(payload).digest('hex');\n}\n\nconst AUDIT_SCHEMA = `\nCREATE TABLE IF NOT EXISTS audit_events (\n  id INTEGER PRIMARY KEY AUTOINCREMENT,\n  timestamp TEXT NOT NULL,\n  action TEXT NOT NULL,\n  tenant_id TEXT,\n  actor TEXT,\n  resource_type TEXT,\n  resource_id TEXT,\n  detail TEXT,\n  ip_address TEXT,\n  prev_hash TEXT\n);\nCREATE INDEX IF NOT EXISTS idx_audit_ts ON audit_events(timestamp);\nCREATE INDEX IF NOT EXISTS idx_audit_tenant_action_ts ON audit_events(tenant_id, action, timestamp);\nDROP INDEX IF EXISTS idx_audit_tenant_ts;\nDROP INDEX IF EXISTS idx_audit_action;\n`;\n\n/** Thrown when an audit event fails to persist — signals an audit trail gap. */\nexport class AuditWriteError extends Error {\n  constructor(\n    public readonly entry: AuditEntry,\n    cause: unknown,\n  ) {\n    super(`Audit write failed for action \"${entry.action}\"`);\n    this.name = 'AuditWriteError';\n    this.cause = cause;\n  }\n}\n\nexport interface AuditEntry {\n  action: string;\n  tenantId?: string;\n  actor?: string;\n  resourceType?: string;\n  resourceId?: string;\n  detail?: string;\n  ipAddress?: string;\n}\n\n/** Row shape returned by audit_events queries. */\nexport interface AuditEvent {\n  id: number;\n  timestamp: string;\n  action: string;\n  tenant_id: string | null;\n  actor: string | null;\n  resource_type: string | null;\n  resource_id: string | null;\n  detail: string | null;\n  ip_address: string | null;\n  prev_hash: string | null;\n}\n\n/** Result of verifying the audit hash chain. */\nexport interface ChainVerifyResult {\n  valid: boolean;\n  verifiedCount: number;\n  brokenAtId?: number;\n}\n\n/** Max entries buffered before an automatic flush. */\nconst BUFFER_FLUSH_SIZE = 50;\n/** Interval (ms) between timer-based flushes. */\nconst BUFFER_FLUSH_INTERVAL_MS = 100;\n\ninterface BufferedEntry {\n  timestamp: string;\n  action: string;\n  tenantId: string | null;\n  actor: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  detail: string | null;\n  ipAddress: string | null;\n}\n\nexport class AuditLog {\n  private db: Database.Database;\n  private insertStmt: Database.Statement;\n  private queryStmtCache = new Map<string, Database.Statement>();\n  private buffer: BufferedEntry[] = [];\n  private flushTimer: NodeJS.Timeout | null = null;\n  private batchInsert: (entries: BufferedEntry[], hashes: string[]) => void;\n  private lastHash: string;\n\n  constructor(\n    dbPath: string,\n    private logger: Logger,\n  ) {\n    this.db = new Database(dbPath);\n    this.db.pragma('journal_mode = WAL');\n    this.db.exec(AUDIT_SCHEMA);\n\n    // Migration: add prev_hash column to existing databases that lack it\n    const cols = this.db.pragma('table_info(audit_events)') as { name: string }[];\n    if (!cols.some((c) => c.name === 'prev_hash')) {\n      this.db.exec('ALTER TABLE audit_events ADD COLUMN prev_hash TEXT');\n    }\n\n    this.insertStmt = this.db.prepare(\n      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address, prev_hash) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',\n    );\n\n    // Initialize chain from last stored hash (or genesis for empty / pre-chain DBs)\n    const lastRow = this.db.prepare(\n      'SELECT prev_hash FROM audit_events WHERE prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n    ).get() as { prev_hash: string } | undefined;\n    this.lastHash = lastRow?.prev_hash ?? GENESIS_HASH;\n\n    // Wrap N inserts in a single transaction — one fsync instead of N\n    const stmt = this.insertStmt;\n    this.batchInsert = this.db.transaction((entries: BufferedEntry[], hashes: string[]) => {\n      for (let i = 0; i < entries.length; i++) {\n        const e = entries[i];\n        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress, hashes[i]);\n      }\n    });\n\n    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n\n    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled, hash-chain active)');\n  }\n\n  /** Expose the underlying database for use by RetentionPolicy. */\n  getDb(): Database.Database {\n    return this.db;\n  }\n\n  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n  countEvents(before?: string): number {\n    const stmt = before\n      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n    return row.cnt;\n  }\n\n  /**\n   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   * yielding the event loop between batches so concurrent DB operations\n   * are not starved during large purges.\n   */\n  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n    const deleteChunk = this.db.prepare(\n      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n    );\n    let totalDeleted = 0;\n    while (true) {\n      const result = deleteChunk.run(cutoff, chunkSize);\n      totalDeleted += result.changes;\n      if (result.changes < chunkSize) break;\n      await new Promise<void>((resolve) => setImmediate(resolve));\n    }\n    return totalDeleted;\n  }\n\n  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n  record(entry: AuditEntry): void {\n    this.buffer.push({\n      timestamp: new Date().toISOString(),\n      action: entry.action,\n      tenantId: entry.tenantId ?? null,\n      actor: entry.actor ?? null,\n      resourceType: entry.resourceType ?? null,\n      resourceId: entry.resourceId ?? null,\n      detail: entry.detail ?? null,\n      ipAddress: entry.ipAddress ?? null,\n    });\n    if (this.buffer.length >= BUFFER_FLUSH_SIZE) {\n      this.flush();\n    }\n  }\n\n  /** Flush buffered entries to SQLite in a single transaction, computing chain hashes. */\n  flush(): void {\n    if (this.buffer.length === 0) return;\n    const batch = this.buffer;\n    this.buffer = [];\n\n    // Compute chain hashes for the batch\n    const hashes: string[] = [];\n    let prevHash = this.lastHash;\n    for (const entry of batch) {\n      prevHash = computeChainHash(prevHash, entry);\n      hashes.push(prevHash);\n    }\n\n    try {\n      this.batchInsert(batch, hashes);\n      this.lastHash = prevHash;\n    } catch (err) {\n      this.logger.error({ err, count: batch.length }, 'Audit batch write failed — audit trail gap');\n    }\n  }\n\n  /** Query audit events with optional filters. */\n  query(opts?: {\n    tenantId?: string;\n    action?: string;\n    since?: string;\n    limit?: number;\n    offset?: number;\n  }): AuditEvent[] {\n    const params: unknown[] = [];\n    const clauses: string[] = [];\n    const keyParts: string[] = [];\n\n    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n\n    const key = keyParts.join('-') || 'none';\n    let stmt = this.queryStmtCache.get(key);\n    if (!stmt) {\n      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n      stmt = this.db.prepare(\n        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n      );\n      this.queryStmtCache.set(key, stmt);\n    }\n\n    const limit = opts?.limit ?? 100;\n    const offset = opts?.offset ?? 0;\n\n    return stmt.all(...params, limit, offset) as AuditEvent[];\n  }\n\n  /**\n   * Verify the integrity of the audit hash chain.\n   * Iterates all chained rows and checks that each hash is consistent with\n   * its predecessor. Pre-chain rows (migrated without prev_hash) are skipped.\n   * If rows were purged, the chain will break at the first remaining row\n   * — this is by design (deletions are detectable).\n   */\n  verify(): ChainVerifyResult {\n    this.flush(); // ensure all buffered entries are persisted\n    const iter = this.db.prepare('SELECT * FROM audit_events ORDER BY id ASC').iterate();\n\n    let prevHash = GENESIS_HASH;\n    let verifiedCount = 0;\n\n    for (const raw of iter) {\n      const row = raw as AuditEvent;\n      if (row.prev_hash === null) continue; // pre-chain row\n\n      const expected = computeChainHash(prevHash, {\n        timestamp: row.timestamp,\n        action: row.action,\n        tenantId: row.tenant_id,\n        actor: row.actor,\n        resourceType: row.resource_type,\n        resourceId: row.resource_id,\n        detail: row.detail,\n        ipAddress: row.ip_address,\n      });\n\n      if (row.prev_hash !== expected) {\n        return { valid: false, verifiedCount, brokenAtId: row.id };\n      }\n\n      prevHash = row.prev_hash;\n      verifiedCount++;\n    }\n\n    return { valid: true, verifiedCount };\n  }\n\n  close(): void {\n    if (this.flushTimer) {\n      clearInterval(this.flushTimer);\n      this.flushTimer = null;\n    }\n    this.flush();\n    try { this.db.close(); } catch { /* best effort */ }\n  }\n}\n","numLines":304,"startLine":1,"totalLines":304}}}
