[2026-03-18T17:45:52.927Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013fPbnJ9F1mZyfHqrVs13wU","type":"tool_result","content":"     1→import type { AuditLog, AuditEntry } from './auditLog.js';\n     2→\n     3→/**\n     4→ * Converts an event-map value (either a tuple of args or a listener function)\n     5→ * to an audit-mapper that receives the same args and returns an AuditEntry.\n     6→ */\n     7→type AuditMapperFor<T> =\n     8→  T extends (...args: infer A) => any ? (...args: A) => AuditEntry\n     9→  : T extends any[] ? (...args: T) => AuditEntry\n    10→  : (...args: any[]) => AuditEntry;\n    11→\n    12→/**\n    13→ * Minimal interface for anything with a typed `on` method\n    14→ * (Node EventEmitter, WorkerPool, etc.).\n    15→ *\n    16→ * @typeParam EventMap - maps event names to listener signatures (function-based\n    17→ *   like WorkerPoolEvents) or argument tuples (Node EventEmitter-style like\n    18→ *   TenantKeyEvents).\n    19→ */\n    20→export interface Auditable<EventMap extends Record<string, any> = Record<string, (...args: any[]) => void>> {\n    21→  on<K extends string & keyof EventMap>(event: K, listener: (...args: any[]) => void): any;\n    22→}\n    23→\n    24→/**\n    25→ * Declarative audit policy: maps emitter events to AuditEntry projections.\n    26→ *\n    27→ * Instead of manually wiring `.on()` calls per emitter, declare a mapping\n    28→ * object and call `attach()`. New emitters plug in with one line.\n    29→ */\n    30→export class AuditPolicy {\n    31→  constructor(private auditLog: AuditLog) {}\n    32→\n    33→  /**\n    34→   * Subscribe to all events in `mappings` on the given emitter.\n    35→   *\n    36→   * Supply the emitter's event-map as a type parameter to get compile-time\n    37→   * enforcement that mapping keys are valid event names and mapper args\n    38→   * match the event's listener signature.\n    39→   */\n    40→  attach<EventMap extends Record<string, any>>(\n    41→    emitter: Auditable<EventMap>,\n    42→    mappings: { [K in string & keyof EventMap]?: AuditMapperFor<EventMap[K]> },\n    43→  ): this {\n    44→    for (const [event, mapper] of Object.entries(mappings)) {\n    45→      emitter.on(event as string & keyof EventMap, (...args: any[]) => {\n    46→        try {\n    47→          this.auditLog.record((mapper as (...a: any[]) => AuditEntry)(...args));\n    48→        } catch {\n    49→          // AuditLog.record() already logs at error level with full payload.\n    50→          // Swallow here to prevent crashing the emitter's listener chain.\n    51→        }\n    52→      });\n    53→    }\n    54→    return this;\n    55→  }\n    56→}\n    57→"}]},"parent_tool_use_id":"toolu_01F8XpUXvGqk53c183D2DE7Z","session_id":"f188d125-8db6-4907-a2dd-273e8cf82b64","uuid":"f87cb676-0a10-40b4-a662-64686b8c0149","timestamp":"2026-03-18T17:45:52.845Z"}
