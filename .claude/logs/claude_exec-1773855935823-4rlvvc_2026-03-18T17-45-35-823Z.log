nDays}`,\n    39→      );\n    40→    }\n    41→  }\n    42→\n    43→  /** Delete audit events older than retentionDays with volume safety cap. */\n    44→  async purgeOld(): Promise<number> {\n    45→    const cutoff = new Date(Date.now() - this.retentionDays * 86_400_000).toISOString();\n    46→\n    47→    // Pre-purge sanity check: refuse to delete more than MAX_PURGE_FRACTION of all rows\n    48→    const total = this.auditLog.countEvents();\n    49→    const candidates = this.auditLog.countEvents(cutoff);\n    50→\n    51→    if (total > 0 && candidates / total > MAX_PURGE_FRACTION) {\n    52→      this.logger.error(\n    53→        { total, candidates, cutoff, maxFraction: MAX_PURGE_FRACTION },\n    54→        'Audit purge aborted: deletion would exceed safety cap',\n    55→      );\n    56→      return 0;\n    57→    }\n    58→\n    59→    const totalDeleted = await this.auditLog.purgeOlderThan(cutoff, PURGE_CHUNK_SIZE);\n    60→    if (totalDeleted > 0) {\n    61→      this.logger.info({ purged: totalDeleted, cutoff }, 'Purged old audit events');\n    62→    }\n    63→    return totalDeleted;\n    64→  }\n    65→\n    66→  /** Start daily purge timer. Returns the timer for cleanup. */\n    67→  startDailyPurge(): NodeJS.Timeout {\n    68→    this.purgeTimer = setInterval(() => {\n    69→      this.purgeOld().catch((err) => {\n    70→        this.logger.error({ err }, 'Audit purge failed');\n    71→      });\n    72→    }, 24 * 60 * 60 * 1000);\n    73→    return this.purgeTimer;\n    74→  }\n    75→\n    76→  close(): void {\n    77→    if (this.purgeTimer) clearInterval(this.purgeTimer);\n    78→  }\n    79→}\n    80→"}]},"parent_tool_use_id":"toolu_01F8XpUXvGqk53c183D2DE7Z","session_id":"f188d125-8db6-4907-a2dd-273e8cf82b64","uuid":"86ab001c-b8b4-43ce-aa9c-5e1578ab3045","timestamp":"2026-03-18T17:45:57.003Z"}
