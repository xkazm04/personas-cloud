[2026-03-18T17:46:47.197Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CE2cU4TxEPpmdQg5vjDvqk","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import type { KafkaClient } from './kafka.js';\n    11→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    12→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    13→import type { TenantDbManager } from './tenantDbManager.js';\n    14→import type { TenantKeyManager } from './tenantKeyManager.js';\n    15→import type { AuditLog } from './auditLog.js';\n    16→import type { EventProcessorHealth } from './eventProcessor.js';\n    17→import type { Logger } from 'pino';\n    18→import * as db from './db/index.js';\n    19→import { readBody, json } from './httpUtils.js';\n    20→\n    21→export function createHttpApi(\n    22→  auth: Auth,\n    23→  dispatcher: Dispatcher,\n    24→  pool: WorkerPool,\n    25→  tokenManager: TokenManager,\n    26→  oauth: OAuthManager,\n    27→  logger: Logger,\n    28→  database?: Database.Database,\n    29→  tenantDbManager?: TenantDbManager,\n    30→  tenantKeyManager?: TenantKeyManager,\n    31→  auditLog?: AuditLog,\n    32→  getEventProcessorHealth?: () => EventProcessorHealth,\n    33→  kafka?: KafkaClient,\n    34→  onEventPublished?: () => void,\n    35→): http.Server {\n    36→  const server = http.createServer(async (req, res) => {\n    37→    // Request correlation ID — threads through all logs and error responses\n    38→    const reqId = nanoid();\n    39→    const reqLogger = logger.child({ reqId });\n    40→    res.setHeader('X-Request-Id', reqId);\n    41→\n    42→    // Security headers\n    43→    res.setHeader('X-Content-Type-Options', 'nosniff');\n    44→\n    45→    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    46→    const origin = req.headers.origin ?? '';\n    47→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    48→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    49→    if (isAdminRoute) {\n    50→      // Admin routes: only allow same-origin requests (no CORS wildcard)\n    51→      if (origin && origin === allowedOrigin) {\n    52→        res.setHeader('Access-Control-Allow-Origin', origin);\n    53→      }\n    54→      // If no match, omit the header entirely — browser blocks the request\n    55→    } else {\n    56→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    57→    }\n    58→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    59→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n    60→\n    61→    if (req.method === 'OPTIONS') {\n    62→      res.writeHead(204);\n    63→      res.end();\n    64→      return;\n    65→    }\n    66→\n    67→    const url = req.url || '/';\n    68→    const [pathname, queryString] = url.split('?');\n    69→    const route = parseRoute(pathname ?? '');\n    70→\n    71→    // Unauthenticated endpoints\n    72→    if (pathname === '/health' && req.method === 'GET') {\n    73→      await handleHealth(res, pool, dispatcher, oauth, getEventProcessorHealth, database, tenantDbManager, kafka);\n    74→      return;\n    75→    }\n    76→\n    77→    // Auth check for everything else — dual auth (API key + optional JWT)\n    78→    const ctx = auth.validateAndExtractContext(req);\n    79→    if (!ctx) {\n    80→      res.writeHead(401, { 'Content-Type': 'application/json' });\n    81→      res.end(JSON.stringify({ error: 'Unauthorized', reqId }));\n    82→      return;\n    83→    }\n    84→\n    85→    // Helper: project scoping (admin sees all, user sees own project)\n    86→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n    87→\n    88→    // Resolve tenant-specific database when available\n    89→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n    90→      if (tenantDbManager && projectId) {\n    91→        return tenantDbManager.getTenantDb(projectId);\n    92→      }\n    93→      return database;\n    94→    };\n    95→    const tenantDb = resolveDatabase(ctx.projectId);\n    96→\n    97→    try {\n    98→      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n    99→      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n   100→        if (requireAdmin(ctx, res)) return;\n   101→        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, reqLogger);\n   102→        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n   103→        return;\n   104→      }\n   105→      // --- Persona CRUD ---\n   106→      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n   107→        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n   108→      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n   109→        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   110→        const persona = createPersonaWithDefaults({\n   111→          ...body,\n   112→          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   113→        });\n   114→        db.upsertPersona(tenantDb, persona);\n   115→        try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: persona.id }); } catch { /* logged inside record() */ }\n   116→        reqLogger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   117→        json(res, 201, persona);\n   118→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n   119→        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n   120→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n   121→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   122→        if (!persona) return;\n   123→        const body = JSON.parse(await readBody(req)) as { toolId: string };\n   124→        db.linkTool(tenantDb, route.id, body.toolId);\n   125→        try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id, detail: JSON.stringify({ toolId: body.toolId }) }); } catch { /* logged inside record() */ }\n   126→        reqLogger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   127→        json(res, 200, { linked: true });\n   128→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n   129→        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, reqLogger), scopedProjectId, res);\n   130→        if (!hydrated) return;\n   131→        json(res, 200, hydrated);\n   132→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n   133→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   134→        if (!persona) return;\n   135→        json(res, 200, persona);\n   136→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   137→        db.deletePersona(tenantDb, route.id, scopedProjectId);\n   138→        try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id }); } catch { /* logged inside record() */ }\n   139→        reqLogger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   140→        json(res, 200, { deleted: true });\n   141→      }\n   142→      // --- Tool Definitions ---\n   143→      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n   144→        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   145→        const tool = createToolDefinitionWithDefaults(body);\n   146→        db.upsertToolDefinition(tenantDb, tool);\n   147→        try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', resourceType: 'toolDefinition', resourceId: tool.id }); } catch { /* logged inside record() */ }\n   148→        reqLogger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   149→        json(res, 201, tool);\n   150→      }\n   151→      // --- Credentials ---\n   152→      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n   153→        const body = JSON.parse(await readBody(req));\n   154→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   155→\n   156→        // Require plaintext — clients must never supply pre-encrypted data\n   157→        if (!body.plaintext || typeof body.plaintext !== 'string') {\n   158→          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   159→          return;\n   160→        }\n   161→\n   162→        // Reject oversized plaintext before synchronous encryption blocks the event loop\n   163→        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   164→          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   165→          return;\n   166→        }\n   167→\n   168→        // Encryption is mandatory — reject if the key manager is unavailable\n   169→        if (!tenantKeyManager) {\n   170→          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   171→          return;\n   172→        }\n   173→\n   174→        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n   175→        delete body.encryptedData;\n   176→        delete body.iv;\n   177→        delete body.tag;\n   178→\n   179→        // Server-side encryption with per-tenant key\n   180→        const tenantId = body.projectId || ctx.projectId || 'default';\n   181→        const key = await tenantKeyManager.getKey(tenantId);\n   182→        const encrypted = encrypt(body.plaintext, key);\n   183→        body.encryptedData = encrypted.encrypted;\n   184→        body.iv = encrypted.iv;\n   185→        body.tag = encrypted.tag;\n   186→        delete body.plaintext;\n   187→\n   188→        const cred = db.createCredential(tenantDb, body);\n   189→        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n   190→        reqLogger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   191→        json(res, 201, cred);\n   192→      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   193→        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n   194→        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   195→        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   196→        reqLogger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   197→        json(res, 200, { deleted: true });\n   198→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n   199→        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n   200→        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   201→        // Strip encrypted data from response\n   202→        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   203→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n   204→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   205→        if (!persona) return;\n   206→        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   207→        db.linkCredential(tenantDb, route.id, body.credentialId);\n   208→        try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id, detail: JSON.stringify({ credentialId: body.credentialId }) }); } catch { /* logged inside record() */ }\n   209→        reqLogger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route.id, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   210→        json(res, 200, { linked: true });\n   211→      }\n   212→      // --- Event Subscriptions ---\n   213→      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n   214→        const body = JSON.parse(await readBody(req));\n   215→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   216→        const missing: string[] = [];\n   217→        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   218→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   219→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   220→        const sub = db.createSubscription(tenantDb, body);\n   221→        try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: sub.id, detail: JSON.stringify({ personaId: body.personaId, eventType: body.eventType }) }); } catch { /* logged inside record() */ }\n   222→        json(res, 201, sub);\n   223→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   224→        const body = JSON.parse(await readBody(req));\n   225→        db.updateSubscription(tenantDb, route.id, body);\n   226→        const updated = db.getSubscription(tenantDb, route.id);\n   227→        try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: route.id }); } catch { /* logged inside record() */ }\n   228→        json(res, 200, updated);\n   229→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   230→        db.deleteSubscription(tenantDb, route.id);\n   231→        try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: route.id }); } catch { /* logged inside record() */ }\n   232→        json(res, 200, { deleted: true });\n   233→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n   234→        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n   235→      }\n   236→      // --- Triggers (delegated to triggerHttpHandlers) ---\n   237→      else if (route && tenantDb && (\n   238→        route.resource === 'triggers' ||\n   239→        (route.resource === 'personas' && route.subResource === 'triggers')\n   240→      )) {\n   241→        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n   242→        return;\n   243→      }\n   244→      // --- Events ---\n   245→      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n   246→        const params = new URLSearchParams(queryString || '');\n   247→        const events = db.listEvents(tenantDb, {\n   248→          eventType: params.get('eventType') ?? undefined,\n   249→          status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n   250→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   251→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   252→          projectId: scopedProjectId,\n   253→        });\n   254→        json(res, 200, events);\n   255→      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n   256→        const body = JSON.parse(await readBody(req));\n   257→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   258→        const missing: string[] = [];\n   259→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   260→        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   261→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   262→        const event = db.publishEvent(tenantDb, body);\n   263→        onEventPublished?.();\n   264→        json(res, 201, event);\n   265→      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   266→        const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n   267→        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n   268→        if (updated) {\n   269→          json(res, 200, updated);\n   270→        } else {\n   271→          res.writeHead(404, { 'Content-Type': 'application/json' });\n   272→          res.end(JSON.stringify({ error: 'Event not found' }));\n   273→        }\n   274→      }\n   275→      // --- Webhooks ---\n   276→      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n   277→        const personaId = route.id;\n   278→        const body = await readBody(req);\n   279→        const event = db.publishEvent(tenantDb, {\n   280→          eventType: 'webhook_received',\n   281→          sourceType: 'webhook',\n   282→          sourceId: personaId,\n   283→          targetPersonaId: personaId,\n   284→          payload: body,\n   285→        });\n   286→        onEventPublished?.();\n   287→        json(res, 201, event);\n   288→      }\n   289→      // --- GitLab Webhook ---\n   290→      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n   291→        const body = await readBody(req);\n   292→        let parsed: Record<string, unknown> = {};\n   293→        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   294→        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   295→        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   296→        const event = db.publishEvent(tenantDb, {\n   297→          eventType: `gitlab_${objectKind}`,\n   298→          sourceType: 'gitlab',\n   299→          sourceId: projectPath ?? null,\n   300→          payload: body,\n   301→        });\n   302→        onEventPublished?.();\n   303→        json(res, 201, event);\n   304→      }\n   305→      // --- Executions ---\n   306→      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n   307→        const params = new URLSearchParams(queryString || '');\n   308→        const executions = db.listExecutions(tenantDb, {\n   309→          personaId: params.get('personaId') ?? undefined,\n   310→          status: params.get('status') ?? undefined,\n   311→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   312→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   313→          projectId: scopedProjectId,\n   314→        });\n   315→        json(res, 200, executions);\n   316→      }\n   317→      // --- Existing execution endpoints ---\n   318→      else if (pathname === '/api/status' && req.method === 'GET') {\n   319→        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   320→      } else if (pathname === '/api/execute' && req.method === 'POST') {\n   321→        await handleExecute(req, res, dispatcher, reqLogger, ctx);\n   322→      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n   323→        handleCancelExecution(res, dispatcher, route.id);\n   324→      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n   325→        const executionId = route.id;\n   326→        const params = new URLSearchParams(queryString || '');\n   327→        const offset = parseInt(params.get('offset') || '0', 10);\n   328→        handleGetExecution(res, dispatcher, executionId, offset);\n   329→      }\n   330→      // --- Admin-only routes ---\n   331→      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n   332→        if (requireAdmin(ctx, res)) return;\n   333→        if (tenantDbManager) {\n   334→          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   335→        } else if (database) {\n   336→          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   337→        } else {\n   338→          json(res, 200, { projectIds: [] });\n   339→        }\n   340→      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n   341→        if (requireAdmin(ctx, res)) return;\n   342→        if (tenantDbManager) {\n   343→          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   344→          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   345→          json(res, 200, allPersonas);\n   346→        } else if (database) {\n   347→          json(res, 200, db.listPersonasSummary(database));\n   348→        } else {\n   349→          json(res, 200, []);\n   350→        }\n   351→      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n   352→        if (requireAdmin(ctx, res)) return;\n   353→        const params = new URLSearchParams(queryString || '');\n   354→        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   355→        if (tenantDbManager) {\n   356→          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   357→          tenantDbManager.forEachTenant((tDb) => {\n   358→            allExecs.push(...db.listExecutions(tDb, { limit }));\n   359→          });\n   360→          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   361→          json(res, 200, allExecs.slice(0, limit));\n   362→        } else if (database) {\n   363→          json(res, 200, db.listExecutions(database, {\n   364→            limit,\n   365→            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   366→          }));\n   367→        } else {\n   368→          json(res, 200, []);\n   369→        }\n   370→      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n   371→        if (requireAdmin(ctx, res)) return;\n   372→        if (!auditLog) { json(res, 200, []); return; }\n   373→        const params = new URLSearchParams(queryString || '');\n   374→        json(res, 200, auditLog.query({\n   375→          tenantId: params.get('tenantId') ?? undefined,\n   376→          action: params.get('action') ?? undefined,\n   377→          since: params.get('since') ?? undefined,\n   378→          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   379→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   380→        }));\n   381→      } else {\n   382→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   383→        res.end(JSON.stringify({ error: 'Not found', reqId }));\n   384→      }\n   385→    } catch (err) {\n   386→      if (err instanceof Error && err.message === 'Payload too large') {\n   387→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   388→        res.end(JSON.stringify({ error: 'Payload too large', reqId }));\n   389→        return;\n   390→      }\n   391→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   392→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   393→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists', reqId }));\n   394→        return;\n   395→      }\n   396→      reqLogger.error({ err, url }, 'HTTP handler error');\n   397→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   398→      res.end(JSON.stringify({ error: 'Internal server error', reqId }));\n   399→    }\n   400→  });\n   401→\n   402→  return server;\n   403→}\n   404→\n   405→interface ParsedRoute {\n   406→  resource: string;\n   407→  id?: string;\n   408→  subResource?: string;\n   409→}\n   410→\n   411→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n   412→function parseRoute(pathname: string): ParsedRoute | null {\n   413→  if (!pathname.startsWith('/api/')) return null;\n   414→  const segments = pathname.slice(5).split('/').filter(Boolean);\n   415→  if (segments.length === 0) return null;\n   416→  return {\n   417→    resource: segments[0]!,\n   418→    id: segments[1],\n   419→    subResource: segments[2],\n   420→  };\n   421→}\n   422→\n   423→/**\n   424→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   425→ * Returns the entity on success, or null after sending a 404 response.\n   426→ */\n   427→function withScopedEntity<T extends { projectId?: string | null }>(\n   428→  entity: T | undefined,\n   429→  scopedProjectId: string | undefined,\n   430→  res: http.ServerResponse,\n   431→): T | null {\n   432→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   433→    json(res, 404, { error: 'Not found' });\n   434→    return null;\n   435→  }\n   436→  return entity;\n   437→}\n   438→\n   439→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   440→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   441→  if (ctx.authType !== 'admin') {\n   442→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   443→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   444→    return true;\n   445→  }\n   446→  return false;\n   447→}\n   448→\n   449→// --- Existing handlers ---\n   450→\n   451→/** Heartbeat age (ms) beyond which a worker is considered stale. */\n   452→const STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n   453→\n   454→async function handleHealth(\n   455→  res: http.ServerResponse,\n   456→  pool: WorkerPool,\n   457→  dispatcher: Dispatcher,\n   458→  oauth: OAuthManager,\n   459→  getEventProcessorHealth?: () => EventProcessorHealth,\n   460→  database?: Database.Database,\n   461→  tenantDbManager?: TenantDbManager,\n   462→  kafka?: KafkaClient,\n   463→): Promise<void> {\n   464→  // Track per-dependency status for overall verdict\n   465→  const issues: string[] = [];\n   466→\n   467→  // --- Workers ---\n   468→  const counts = pool.getWorkerCount();\n   469→  const workers = pool.getWorkers();\n   470→  const now = Date.now();\n   471→  const staleWorkers = workers\n   472→    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n   473→    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n   474→\n   475→  if (staleWorkers.length > 0) {\n   476→    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n   477→  }\n   478→\n   479→  // --- Database ---\n   480→  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n   481→  if (database) {\n   482→    try {\n   483→      database.prepare('SELECT 1').get();\n   484→      dbHealth.status = 'ok';\n   485→    } catch {\n   486→      dbHealth.status = 'error';\n   487→      issues.push('database unreachable');\n   488→    }\n   489→  }\n   490→  if (tenantDbManager) {\n   491→    try {\n   492→      const tenantIds = tenantDbManager.listTenantIds();\n   493→      dbHealth.tenantCount = tenantIds.length;\n   494→      // If no shared database, tenant DB manager is the primary DB layer\n   495→      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n   496→    } catch {\n   497→      dbHealth.tenantCount = -1;\n   498→      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n   499→      issues.push('tenant DB listing failed');\n   500→    }\n   501→  }\n   502→\n   503→  // --- Kafka ---\n   504→  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n   505→  if (kafka) {\n   506→    const kh = await kafka.checkHealth();\n   507→    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n   508→    if (kh.status === 'error') {\n   509→      issues.push(`kafka: ${kh.detail || 'error'}`);\n   510→    }\n   511→  }\n   512→\n   513→  // --- Queue ---\n   514→  const queueDepth = dispatcher.getQueueLength();\n   515→  const activeExecutions = dispatcher.getActiveExecutions().length;\n   516→\n   517→  // --- Event processor ---\n   518→  let eventProcessorHealth: EventProcessorHealth | undefined;\n   519→  if (getEventProcessorHealth) {\n   520→    eventProcessorHealth = getEventProcessorHealth();\n   521→  }\n   522→\n   523→  // --- Overall verdict ---\n   524→  let verdict: 'healthy' | 'degraded' | 'unhealthy';\n   525→  if (issues.some(i => i.includes('database unreachable') || i.includes('kafka: '))) {\n   526→    verdict = 'unhealthy';\n   527→  } else if (issues.length > 0) {\n   528→    verdict = 'degraded';\n   529→  } else {\n   530→    verdict = 'healthy';\n   531→  }\n   532→\n   533→  const body: Record<string, unknown> = {\n   534→    status: verdict,\n   535→    timestamp: Date.now(),\n   536→    dependencies: {\n   537→      database: dbHealth,\n   538→      kafka: kafkaHealth,\n   539→      workers: {\n   540→        ...counts,\n   541→        staleWorkers: staleWorkers.length > 0 ? staleWorkers : undefined,\n   542→      },\n   543→    },\n   544→    queue: {\n   545→      depth: queueDepth,\n   546→      activeExecutions,\n   547→    },\n   548→    hasSubscription: oauth.hasTokens(),\n   549→  };\n   550→\n   551→  if (eventProcessorHealth) {\n   552→    (body.dependencies as Record<string, unknown>).eventProcessor = eventProcessorHealth;\n   553→  }\n   554→\n   555→  if (issues.length > 0) {\n   556→    body.issues = issues;\n   557→  }\n   558→\n   559→  const httpStatus = verdict === 'unhealthy' ? 503 : 200;\n   560→  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n   561→  res.end(JSON.stringify(body));\n   562→}\n   563→\n   564→function handleStatus(\n   565→  res: http.ServerResponse,\n   566→  pool: WorkerPool,\n   567→  dispatcher: Dispatcher,\n   568→  tokenManager: TokenManager,\n   569→  oauth: OAuthManager,\n   570→): void {\n   571→  const oauthTokens = oauth.getTokens();\n   572→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   573→  res.end(JSON.stringify({\n   574→    workers: pool.getWorkers(),\n   575→    workerCounts: pool.getWorkerCount(),\n   576→    workerPoolMetrics: pool.getMetrics(),\n   577→    queueLength: dispatcher.getQueueLength(),\n   578→    activeExecutions: dispatcher.getActiveExecutions(),\n   579→    hasClaudeToken: tokenManager.hasToken(),\n   580→    oauth: {\n   581→      connected: oauth.hasTokens(),\n   582→      scopes: oauthTokens?.scopes || [],\n   583→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   584→    },\n   585→  }));\n   586→}\n   587→\n   588→async function handleExecute(\n   589→  req: http.IncomingMessage,\n   590→  res: http.ServerResponse,\n   591→  dispatcher: Dispatcher,\n   592→  logger: Logger,\n   593→  ctx?: RequestContext,\n   594→): Promise<void> {\n   595→  const body = await readBody(req);\n   596→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   597→\n   598→  try {\n   599→    parsed = JSON.parse(body);\n   600→  } catch {\n   601→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   602→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   603→    return;\n   604→  }\n   605→\n   606→  if (!parsed.prompt) {\n   607→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   608→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   609→    return;\n   610→  }\n   611→\n   612→  const request: ExecRequest = {\n   613→    executionId: nanoid(),\n   614→    personaId: parsed.personaId || 'manual',\n   615→    prompt: parsed.prompt,\n   616→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   617→    config: {\n   618→      timeoutMs: parsed.timeoutMs || 300_000,\n   619→    },\n   620→  };\n   621→\n   622→  dispatcher.submit(request);\n   623→\n   624→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   625→\n   626→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   627→  res.end(JSON.stringify({\n   628→    executionId: request.executionId,\n   629→    status: 'queued',\n   630→  }));\n   631→}\n   632→\n   633→function handleGetExecution(\n   634→  res: http.ServerResponse,\n   635→  dispatcher: Dispatcher,\n   636→  executionId: string,\n   637→  offset: number = 0,\n   638→): void {\n   639→  const exec = dispatcher.getExecution(executionId);\n   640→\n   641→  if (!exec) {\n   642→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   643→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   644→    return;\n   645→  }\n   646→\n   647→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   648→\n   649→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   650→  res.end(JSON.stringify({\n   651→    executionId,\n   652→    status: exec.status,\n   653→    outputLines: exec.output.length,\n   654→    output,\n   655→    durationMs: exec.durationMs,\n   656→    sessionId: exec.sessionId,\n   657→    totalCostUsd: exec.totalCostUsd,\n   658→    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n   659→  }));\n   660→}\n   661→\n   662→function handleCancelExecution(\n   663→  res: http.ServerResponse,\n   664→  dispatcher: Dispatcher,\n   665→  executionId: string,\n   666→): void {\n   667→  const cancelled = dispatcher.cancelExecution(executionId);\n   668→\n   669→  if (!cancelled) {\n   670→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   671→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   672→    return;\n   673→  }\n   674→\n   675→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   676→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   677→}\n   678→\n   679→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\n   680→const MAX_QUERY_LIMIT = 500;\n   681→const MAX_QUERY_OFFSET = 100_000;\n   682→\n   683→/** Parse an integer query param and clamp it to safe bounds. */\n   684→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   685→  if (!value) return defaultValue;\n   686→  const parsed = parseInt(value, 10);\n   687→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   688→  return Math.min(parsed, max);\n   689→}\n   690→"}]},"parent_tool_use_id":null,"session_id":"f188d125-8db6-4907-a2dd-273e8cf82b64","uuid":"7cd6948c-def2-4cf3-ba1f-9bad233596ca","timestamp":"2026-03-18T17:46:46.682Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { EventProcessorHealth } from './eventProcessor.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  kafka?: KafkaClient,\n  onEventPublished?: () => void,\n): http.Server {\n  const server = http.createServer(async (req, res) => {\n    // Request correlation ID — threads through all logs and error responses\n    const reqId = nanoid();\n    const reqLogger = logger.child({ reqId });\n    res.setHeader('X-Request-Id', reqId);\n\n    // Security headers\n    res.setHeader('X-Content-Type-Options', 'nosniff');\n\n    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    const origin = req.headers.origin ?? '';\n    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    if (isAdminRoute) {\n      // Admin routes: only allow same-origin requests (no CORS wildcard)\n      if (origin && origin === allowedOrigin) {\n        res.setHeader('Access-Control-Allow-Origin', origin);\n      }\n      // If no match, omit the header entirely — browser blocks the request\n    } else {\n      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    }\n    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n\n    if (req.method === 'OPTIONS') {\n      res.writeHead(204);\n      res.end();\n      return;\n    }\n\n    const url = req.url || '/';\n    const [pathname, queryString] = url.split('?');\n    const route = parseRoute(pathname ?? '');\n\n    // Unauthenticated endpoints\n    if (pathname === '/health' && req.method === 'GET') {\n      await handleHealth(res, pool, dispatcher, oauth, getEventProcessorHealth, database, tenantDbManager, kafka);\n      return;\n    }\n\n    // Auth check for everything else — dual auth (API key + optional JWT)\n    const ctx = auth.validateAndExtractContext(req);\n    if (!ctx) {\n      res.writeHead(401, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Unauthorized', reqId }));\n      return;\n    }\n\n    // Helper: project scoping (admin sees all, user sees own project)\n    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n\n    // Resolve tenant-specific database when available\n    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n      if (tenantDbManager && projectId) {\n        return tenantDbManager.getTenantDb(projectId);\n      }\n      return database;\n    };\n    const tenantDb = resolveDatabase(ctx.projectId);\n\n    try {\n      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n        if (requireAdmin(ctx, res)) return;\n        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, reqLogger);\n        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n        return;\n      }\n      // --- Persona CRUD ---\n      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n        const persona = createPersonaWithDefaults({\n          ...body,\n          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n        });\n        db.upsertPersona(tenantDb, persona);\n        try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: persona.id }); } catch { /* logged inside record() */ }\n        reqLogger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n        json(res, 201, persona);\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { toolId: string };\n        db.linkTool(tenantDb, route.id, body.toolId);\n        try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id, detail: JSON.stringify({ toolId: body.toolId }) }); } catch { /* logged inside record() */ }\n        reqLogger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n        json(res, 200, { linked: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, reqLogger), scopedProjectId, res);\n        if (!hydrated) return;\n        json(res, 200, hydrated);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        json(res, 200, persona);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deletePersona(tenantDb, route.id, scopedProjectId);\n        try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id }); } catch { /* logged inside record() */ }\n        reqLogger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n        json(res, 200, { deleted: true });\n      }\n      // --- Tool Definitions ---\n      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n        const tool = createToolDefinitionWithDefaults(body);\n        db.upsertToolDefinition(tenantDb, tool);\n        try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', resourceType: 'toolDefinition', resourceId: tool.id }); } catch { /* logged inside record() */ }\n        reqLogger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n        json(res, 201, tool);\n      }\n      // --- Credentials ---\n      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n\n        // Require plaintext — clients must never supply pre-encrypted data\n        if (!body.plaintext || typeof body.plaintext !== 'string') {\n          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n          return;\n        }\n\n        // Reject oversized plaintext before synchronous encryption blocks the event loop\n        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n          return;\n        }\n\n        // Encryption is mandatory — reject if the key manager is unavailable\n        if (!tenantKeyManager) {\n          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n          return;\n        }\n\n        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n        delete body.encryptedData;\n        delete body.iv;\n        delete body.tag;\n\n        // Server-side encryption with per-tenant key\n        const tenantId = body.projectId || ctx.projectId || 'default';\n        const key = await tenantKeyManager.getKey(tenantId);\n        const encrypted = encrypt(body.plaintext, key);\n        body.encryptedData = encrypted.encrypted;\n        body.iv = encrypted.iv;\n        body.tag = encrypted.tag;\n        delete body.plaintext;\n\n        const cred = db.createCredential(tenantDb, body);\n        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n        reqLogger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n        json(res, 201, cred);\n      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n        reqLogger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n        // Strip encrypted data from response\n        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n        db.linkCredential(tenantDb, route.id, body.credentialId);\n        try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route.id, detail: JSON.stringify({ credentialId: body.credentialId }) }); } catch { /* logged inside record() */ }\n        reqLogger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route.id, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n        json(res, 200, { linked: true });\n      }\n      // --- Event Subscriptions ---\n      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const sub = db.createSubscription(tenantDb, body);\n        try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: sub.id, detail: JSON.stringify({ personaId: body.personaId, eventType: body.eventType }) }); } catch { /* logged inside record() */ }\n        json(res, 201, sub);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        db.updateSubscription(tenantDb, route.id, body);\n        const updated = db.getSubscription(tenantDb, route.id);\n        try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: route.id }); } catch { /* logged inside record() */ }\n        json(res, 200, updated);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deleteSubscription(tenantDb, route.id);\n        try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: route.id }); } catch { /* logged inside record() */ }\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n      }\n      // --- Triggers (delegated to triggerHttpHandlers) ---\n      else if (route && tenantDb && (\n        route.resource === 'triggers' ||\n        (route.resource === 'personas' && route.subResource === 'triggers')\n      )) {\n        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n        return;\n      }\n      // --- Events ---\n      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const events = db.listEvents(tenantDb, {\n          eventType: params.get('eventType') ?? undefined,\n          status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, events);\n      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const event = db.publishEvent(tenantDb, body);\n        onEventPublished?.();\n        json(res, 201, event);\n      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n        if (updated) {\n          json(res, 200, updated);\n        } else {\n          res.writeHead(404, { 'Content-Type': 'application/json' });\n          res.end(JSON.stringify({ error: 'Event not found' }));\n        }\n      }\n      // --- Webhooks ---\n      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n        const personaId = route.id;\n        const body = await readBody(req);\n        const event = db.publishEvent(tenantDb, {\n          eventType: 'webhook_received',\n          sourceType: 'webhook',\n          sourceId: personaId,\n          targetPersonaId: personaId,\n          payload: body,\n        });\n        onEventPublished?.();\n        json(res, 201, event);\n      }\n      // --- GitLab Webhook ---\n      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n        const body = await readBody(req);\n        let parsed: Record<string, unknown> = {};\n        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n        const event = db.publishEvent(tenantDb, {\n          eventType: `gitlab_${objectKind}`,\n          sourceType: 'gitlab',\n          sourceId: projectPath ?? null,\n          payload: body,\n        });\n        onEventPublished?.();\n        json(res, 201, event);\n      }\n      // --- Executions ---\n      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const executions = db.listExecutions(tenantDb, {\n          personaId: params.get('personaId') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, executions);\n      }\n      // --- Existing execution endpoints ---\n      else if (pathname === '/api/status' && req.method === 'GET') {\n        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n      } else if (pathname === '/api/execute' && req.method === 'POST') {\n        await handleExecute(req, res, dispatcher, reqLogger, ctx);\n      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n        handleCancelExecution(res, dispatcher, route.id);\n      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n        const executionId = route.id;\n        const params = new URLSearchParams(queryString || '');\n        const offset = parseInt(params.get('offset') || '0', 10);\n        handleGetExecution(res, dispatcher, executionId, offset);\n      }\n      // --- Admin-only routes ---\n      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n        } else if (database) {\n          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n        } else {\n          json(res, 200, { projectIds: [] });\n        }\n      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n          json(res, 200, allPersonas);\n        } else if (database) {\n          json(res, 200, db.listPersonasSummary(database));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        const params = new URLSearchParams(queryString || '');\n        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n        if (tenantDbManager) {\n          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n          tenantDbManager.forEachTenant((tDb) => {\n            allExecs.push(...db.listExecutions(tDb, { limit }));\n          });\n          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n          json(res, 200, allExecs.slice(0, limit));\n        } else if (database) {\n          json(res, 200, db.listExecutions(database, {\n            limit,\n            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          }));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (!auditLog) { json(res, 200, []); return; }\n        const params = new URLSearchParams(queryString || '');\n        json(res, 200, auditLog.query({\n          tenantId: params.get('tenantId') ?? undefined,\n          action: params.get('action') ?? undefined,\n          since: params.get('since') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        }));\n      } else {\n        res.writeHead(404, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Not found', reqId }));\n      }\n    } catch (err) {\n      if (err instanceof Error && err.message === 'Payload too large') {\n        res.writeHead(413, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Payload too large', reqId }));\n        return;\n      }\n      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n        res.writeHead(409, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists', reqId }));\n        return;\n      }\n      reqLogger.error({ err, url }, 'HTTP handler error');\n      res.writeHead(500, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Internal server error', reqId }));\n    }\n  });\n\n  return server;\n}\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\n/**\n * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n * Returns the entity on success, or null after sending a 404 response.\n */\nfunction withScopedEntity<T extends { projectId?: string | null }>(\n  entity: T | undefined,\n  scopedProjectId: string | undefined,\n  res: http.ServerResponse,\n): T | null {\n  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n    json(res, 404, { error: 'Not found' });\n    return null;\n  }\n  return entity;\n}\n\n/** Returns true (and sends 403) if the caller is NOT an admin. */\nfunction requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n  if (ctx.authType !== 'admin') {\n    res.writeHead(403, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Admin access required' }));\n    return true;\n  }\n  return false;\n}\n\n// --- Existing handlers ---\n\n/** Heartbeat age (ms) beyond which a worker is considered stale. */\nconst STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n\nasync function handleHealth(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  oauth: OAuthManager,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  kafka?: KafkaClient,\n): Promise<void> {\n  // Track per-dependency status for overall verdict\n  const issues: string[] = [];\n\n  // --- Workers ---\n  const counts = pool.getWorkerCount();\n  const workers = pool.getWorkers();\n  const now = Date.now();\n  const staleWorkers = workers\n    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n\n  if (staleWorkers.length > 0) {\n    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n  }\n\n  // --- Database ---\n  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n  if (database) {\n    try {\n      database.prepare('SELECT 1').get();\n      dbHealth.status = 'ok';\n    } catch {\n      dbHealth.status = 'error';\n      issues.push('database unreachable');\n    }\n  }\n  if (tenantDbManager) {\n    try {\n      const tenantIds = tenantDbManager.listTenantIds();\n      dbHealth.tenantCount = tenantIds.length;\n      // If no shared database, tenant DB manager is the primary DB layer\n      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n    } catch {\n      dbHealth.tenantCount = -1;\n      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n      issues.push
[2026-03-18T17:46:47.197Z] [STDOUT] ('tenant DB listing failed');\n    }\n  }\n\n  // --- Kafka ---\n  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n  if (kafka) {\n    const kh = await kafka.checkHealth();\n    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n    if (kh.status === 'error') {\n      issues.push(`kafka: ${kh.detail || 'error'}`);\n    }\n  }\n\n  // --- Queue ---\n  const queueDepth = dispatcher.getQueueLength();\n  const activeExecutions = dispatcher.getActiveExecutions().length;\n\n  // --- Event processor ---\n  let eventProcessorHealth: EventProcessorHealth | undefined;\n  if (getEventProcessorHealth) {\n    eventProcessorHealth = getEventProcessorHealth();\n  }\n\n  // --- Overall verdict ---\n  let verdict: 'healthy' | 'degraded' | 'unhealthy';\n  if (issues.some(i => i.includes('database unreachable') || i.includes('kafka: '))) {\n    verdict = 'unhealthy';\n  } else if (issues.length > 0) {\n    verdict = 'degraded';\n  } else {\n    verdict = 'healthy';\n  }\n\n  const body: Record<string, unknown> = {\n    status: verdict,\n    timestamp: Date.now(),\n    dependencies: {\n      database: dbHealth,\n      kafka: kafkaHealth,\n      workers: {\n        ...counts,\n        staleWorkers: staleWorkers.length > 0 ? staleWorkers : undefined,\n      },\n    },\n    queue: {\n      depth: queueDepth,\n      activeExecutions,\n    },\n    hasSubscription: oauth.hasTokens(),\n  };\n\n  if (eventProcessorHealth) {\n    (body.dependencies as Record<string, unknown>).eventProcessor = eventProcessorHealth;\n  }\n\n  if (issues.length > 0) {\n    body.issues = issues;\n  }\n\n  const httpStatus = verdict === 'unhealthy' ? 503 : 200;\n  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify(body));\n}\n\nfunction handleStatus(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n): void {\n  const oauthTokens = oauth.getTokens();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    workers: pool.getWorkers(),\n    workerCounts: pool.getWorkerCount(),\n    workerPoolMetrics: pool.getMetrics(),\n    queueLength: dispatcher.getQueueLength(),\n    activeExecutions: dispatcher.getActiveExecutions(),\n    hasClaudeToken: tokenManager.hasToken(),\n    oauth: {\n      connected: oauth.hasTokens(),\n      scopes: oauthTokens?.scopes || [],\n      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n    },\n  }));\n}\n\nasync function handleExecute(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  ctx?: RequestContext,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.prompt) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n    return;\n  }\n\n  const request: ExecRequest = {\n    executionId: nanoid(),\n    personaId: parsed.personaId || 'manual',\n    prompt: parsed.prompt,\n    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n    config: {\n      timeoutMs: parsed.timeoutMs || 300_000,\n    },\n  };\n\n  dispatcher.submit(request);\n\n  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n\n  res.writeHead(202, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId: request.executionId,\n    status: 'queued',\n  }));\n}\n\nfunction handleGetExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n  offset: number = 0,\n): void {\n  const exec = dispatcher.getExecution(executionId);\n\n  if (!exec) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found' }));\n    return;\n  }\n\n  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId,\n    status: exec.status,\n    outputLines: exec.output.length,\n    output,\n    durationMs: exec.durationMs,\n    sessionId: exec.sessionId,\n    totalCostUsd: exec.totalCostUsd,\n    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n  }));\n}\n\nfunction handleCancelExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n): void {\n  const cancelled = dispatcher.cancelExecution(executionId);\n\n  if (!cancelled) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n    return;\n  }\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n}\n\nconst MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\nconst MAX_QUERY_LIMIT = 500;\nconst MAX_QUERY_OFFSET = 100_000;\n\n/** Parse an integer query param and clamp it to safe bounds. */\nfunction clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n  if (!value) return defaultValue;\n  const parsed = parseInt(value, 10);\n  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n  return Math.min(parsed, max);\n}\n","numLines":690,"startLine":1,"totalLines":690}}}
