    36→  request?: ExecRequest;\n    37→  /** How many times this execution has been re-queued after a worker disconnect. */\n    38→  disconnectRetries?: number;\n    39→}\n    40→\n    41→const OUTPUT_FLUSH_INTERVAL_MS = 500;\n    42→\n    43→export class Dispatcher {\n    44→  private queue: QueuedExecution[] = [];\n    45→  // In-memory map for real-time output + cancel routing (active executions only)\n    46→  private active = new Map<string, ActiveExecution>();\n    47→  private tenantDbManager: TenantDbManager | null = null;\n    48→  private masterKey: Buffer | null = null;\n    49→  private tenantKeyManager: TenantKeyManager | null = null;\n    50→  private auditLog: AuditLog | null = null;\n    51→  private preparer: ExecutionPreparer | null = null;\n    52→  // Maps executionId → projectId for DB resolution during callbacks\n    53→  private executionTenant = new Map<string, string>();\n    54→  // Batched output buffers: executionId → pending chunks\n    55→  private outputBuffers = new Map<string, string[]>();\n    56→  private outputFlushTimer: NodeJS.Timeout;\n    57→  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n    58→  private dispatching = false;\n    59→\n    60→  constructor(\n    61→    private pool: WorkerPool,\n    62→    private tokenManager: TokenManager,\n    63→    private oauth: OAuthManager | null,\n    64→    private kafka: KafkaClient,\n    65→    private logger: Logger,\n    66→  ) {\n    67→    // Periodic flush of batched output to DB\n    68→    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n    69→\n    70→    // When a worker becomes ready, try to dispatch queued work\n    71→    this.pool.on('worker-ready', () => {\n    72→      this.processQueue();\n    73→    });\n    74→\n    75→    // When a worker connects, try to dispatch\n    76→    this.pool.on('worker-connected', () => {\n    77→      this.processQueue();\n    78→    });\n    79→\n    80→    // Track stdout for execution output\n    81→    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n    82→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    83→    });\n    84→\n    85→    // Track stderr for debugging failed executions\n    86→    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n    87→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n    88→      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    89→    });\n    90→\n    91→    // Handle execution completion\n    92→    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n    93→      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n    94→        executionId: msg.executionId,\n    95→        status: msg.status,\n    96→        exitCode: msg.exitCode,\n    97→        durationMs: msg.durationMs,\n    98→        sessionId: msg.sessionId,\n    99→        totalCostUsd: msg.totalCostUsd,\n   100→        ...(msg.phaseTimings ? { phaseTimings: msg.phaseTimings } : {}),\n   101→      }), msg.executionId).catch(err => {\n   102→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n   103→      });\n   104→\n   105→      // Flush any remaining buffered output before persisting completion\n   106→      this.flushOutputForExecution(msg.executionId);\n   107→\n   108→      // Update in-memory\n   109→      const exec = this.active.get(msg.executionId);\n   110→      if (exec) {\n   111→        exec.status = msg.status;\n   112→        exec.completedAt = Date.now();\n   113→        exec.exitCode = msg.exitCode;\n   114→        exec.durationMs = msg.durationMs;\n   115→        exec.sessionId = msg.sessionId;\n   116→        exec.totalCostUsd = msg.totalCostUsd;\n   117→        exec.phaseTimings = msg.phaseTimings;\n   118→        // Remove from active after a short delay (al