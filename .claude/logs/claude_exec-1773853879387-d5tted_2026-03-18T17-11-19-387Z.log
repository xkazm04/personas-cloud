atus = 'pending' AND (retry_after IS NULL OR retry_after <= datetime('now'))\",\n   153→  ).get() as { cnt: number };\n   154→  return row.cnt;\n   155→}\n   156→\n   157→export function getOldestPendingEventCreatedAt(db: Database.Database): string | null {\n   158→  const row = stmt(db,\n   159→    \"SELECT created_at FROM persona_events WHERE status = 'pending' AND (retry_after IS NULL OR retry_after <= datetime('now')) ORDER BY created_at ASC LIMIT 1\",\n   160→  ).get() as { created_at: string } | undefined;\n   161→  return row?.created_at ?? null;\n   162→}\n   163→\n   164→// ---------------------------------------------------------------------------\n   165→// Event Subscriptions CRUD\n   166→// ---------------------------------------------------------------------------\n   167→\n   168→export function createSubscription(db: Database.Database, input: {\n   169→  personaId: string; eventType: string; sourceFilter?: string | null; enabled?: boolean; useCaseId?: string | null; projectId?: string;\n   170→}): PersonaEventSubscription {\n   171→  const now = new Date().toISOString();\n   172→  const id = nanoid();\n   173→  const sourceFilter = input.sourceFilter ?? null;\n   174→  const enabled = input.enabled !== false;\n   175→  const useCaseId = input.useCaseId ?? null;\n   176→  stmt(db,`\n   177→    INSERT INTO persona_event_subscriptions (id, project_id, persona_id, event_type, source_filter, enabled, use_case_id, created_at, updated_at)\n   178→    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n   179→  `).run(id, input.projectId ?? 'default', input.personaId, input.eventType, sourceFilter, enabled ? 1 : 0, useCaseId, now, now);\n   180→  return {\n   181→    id,\n   182→    personaId: input.personaId,\n   183→    eventType: input.eventType,\n   184→    sourceFilter,\n   185→    enabled,\n   186→    useCaseId,\n   187→    createdAt: now,\n   188→    updatedAt: now,\n   189→  };\n   190→}\n   191→\n   192→export function getSubscription(db: Database.Database, id: str