naEvent[] {\n    81→  const rows = stmt(db,\n    82→    \"SELECT * FROM persona_events WHERE status = 'pending' AND (retry_after IS NULL OR retry_after <= datetime('now')) ORDER BY created_at LIMIT ?\",\n    83→  ).all(limit) as Record<string, unknown>[];\n    84→  return rows.map(rowToEvent);\n    85→}\n    86→\n    87→export function listEvents(db: Database.Database, opts?: {\n    88→  eventType?: string; status?: string; projectId?: string; limit?: number; offset?: number;\n    89→}): PersonaEvent[] {\n    90→  const { sql: where, params } = buildWhereClause(\n    91→    { eventType: opts?.eventType, status: opts?.status, projectId: opts?.projectId },\n    92→    { eventType: 'event_type', status: 'status', projectId: 'project_id' },\n    93→  );\n    94→  const limit = opts?.limit ?? 50;\n    95→  const offset = opts?.offset ?? 0;\n    96→  const rows = stmt(db,`SELECT * FROM persona_events ${where} ORDER BY created_at DESC LIMIT ? OFFSET ?`).all(...params, limit, offset) as Record<string, unknown>[];\n    97→  return rows.map(rowToEvent);\n    98→}\n    99→\n   100→export function updateEventStatus(db: Database.Database, id: string, status: string, errorMessage?: string | null): void {\n   101→  const now = new Date().toISOString();\n   102→  stmt(db,'UPDATE persona_events SET status = ?, error_message = ?, processed_at = ? WHERE id = ?').run(status, errorMessage ?? null, now, id);\n   103→}\n   104→\n   105→/**\n   106→ * Reset events stuck in 'processing' state back to 'pending'.\n   107→ * Events with processed_at older than maxAgeSeconds are considered stale (orphaned by a crash).\n   108→ * Returns the number of events reset.\n   109→ */\n   110→export function resetStaleProcessingEvents(db: Database.Database, maxAgeSeconds: number): number {\n   111→  const cutoff = new Date(Date.now() - maxAgeSeconds * 1000).toISOString();\n   112→  const result = stmt(db,\n   113→    \"UPDATE persona_events SET status = 'pending', processed_at = NULL WHERE status = 'pro