[2026-03-18T17:14:12.718Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YJXqc38LnxBiyaMghNGYFj","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import { getTableSpec, isMetrizable, isEphemeral } from '@dac-cloud/shared';\n     4→import type { MetrizableTableSpec, EphemeralTableSpec } from '@dac-cloud/shared';\n     5→import type { TenantDbManager } from './tenantDbManager.js';\n     6→\n     7→// Validate registry classification at import time — if someone changes the\n     8→// registry without updating this module the build still passes but the runtime\n     9→// assertion catches the mismatch immediately.\n    10→const execSpec = getTableSpec('persona_executions');\n    11→const eventsSpec = getTableSpec('persona_events');\n    12→if (!execSpec || !isMetrizable(execSpec)) {\n    13→  throw new Error('persona_executions must be registered as metrizable in TABLE_REGISTRY');\n    14→}\n    15→if (!eventsSpec || !isEphemeral(eventsSpec)) {\n    16→  throw new Error('persona_events must be registered as ephemeral in TABLE_REGISTRY');\n    17→}\n    18→\n    19→/** Maximum fraction of rows a single purge cycle may delete (safety cap). */\n    20→const EXEC_MAX_PURGE_FRACTION = (execSpec as MetrizableTableSpec).maxPurgeFraction ?? 0.8;\n    21→const EVENTS_MAX_PURGE_FRACTION = (eventsSpec as EphemeralTableSpec).maxPurgeFraction ?? 0.8;\n    22→\n    23→/** Rows deleted per chunk to keep individual lock durations short (~50ms). */\n    24→const PURGE_CHUNK_SIZE = 5000;\n    25→\n    26→/** Yield the event loop so concurrent reads/writes can proceed between batches. */\n    27→function yieldTick(): Promise<void> {\n    28→  return new Promise((resolve) => setImmediate(resolve));\n    29→}\n    30→\n    31→/** How often we check whether it's time for the daily run (60 seconds). */\n    32→const SCHEDULE_CHECK_MS = 60_000;\n    33→\n    34→/** system_kv key used to persist the last successful run date (UTC). */\n    35→const LAST_RUN_KEY = 'retention_last_run_date';\n    36→\n    37→/** Return today's UTC date as YYYY-MM-DD. */\n    38→function utcToday(): string {\n    39→  return new Date().toISOString().slice(0, 10);\n    40→}\n    41→\n    42→/** Read the last-run UTC date from system_kv, or null if never run. */\n    43→function getLastRunDate(tenantDbManager: TenantDbManager): string | null {\n    44→  const row = tenantDbManager.getSystemDb().prepare(\n    45→    'SELECT value FROM system_kv WHERE key = ?',\n    46→  ).get(LAST_RUN_KEY) as { value: string } | undefined;\n    47→  return row?.value ?? null;\n    48→}\n    49→\n    50→/** Persist the current UTC date as the last-run date. */\n    51→function setLastRunDate(tenantDbManager: TenantDbManager, date: string): void {\n    52→  tenantDbManager.getSystemDb().prepare(\n    53→    'INSERT INTO system_kv (key, value) VALUES (?, ?) ON CONFLICT(key) DO UPDATE SET value = excluded.value',\n    54→  ).run(LAST_RUN_KEY, date);\n    55→}\n    56→\n    57→/**\n    58→ * Daily retention job: purge old executions/events and aggregate daily metrics.\n    59→ *\n    60→ * Uses a 60-second wall-clock poll instead of a drifting 24-hour setInterval.\n    61→ * The last successful run date is persisted in system_kv so the job runs\n    62→ * exactly once per UTC calendar day regardless of restarts or event-loop delays.\n    63→ */\n    64→export function startRetentionJob(\n    65→  tenantDbManager: TenantDbManager,\n    66→  retentionDays: number,\n    67→  logger: Logger,\n    68→): NodeJS.Timeout {\n    69→  logger.info({ retentionDays }, 'Retention job scheduled (wall-clock daily)');\n    70→\n    71→  let running = false;\n    72→\n    73→  async function tick(): Promise<void> {\n    74→    if (running) return;\n    75→\n    76→    const today = utcToday();\n    77→    const lastRun = getLastRunDate(tenantDbManager);\n    78→\n    79→    if (lastRun === today) return; // already ran today\n    80→\n    81→    running = true;\n    82→    logger.info({ today, lastRun }, 'Retention job triggered');\n    83→    try {\n    84→      await runRetention(tenantDbManager, retentionDays, logger);\n    85→      setLastRunDate(tenantDbManager, today);\n    86→      logger.info({ today }, 'Retention job completed, next run tomorrow');\n    87→    } catch (err) {\n    88→      logger.error({ err }, 'Retention job failed — will retry next tick');\n    89→    } finally {\n    90→      running = false;\n    91→    }\n    92→  }\n    93→\n    94→  // First check shortly after startup, then every 60 seconds\n    95→  setTimeout(() => tick(), 5000);\n    96→\n    97→  return setInterval(() => {\n    98→    tick();\n    99→  }, SCHEDULE_CHECK_MS);\n   100→}\n   101→\n   102→/**\n   103→ * Delete rows in chunks of PURGE_CHUNK_SIZE, yielding the event loop between\n   104→ * batches so other DB operations are not starved.\n   105→ */\n   106→async function chunkedDelete(db: Database.Database, sql: string, params: unknown[]): Promise<number> {\n   107→  const stmt = db.prepare(sql);\n   108→  let totalDeleted = 0;\n   109→  while (true) {\n   110→    const result = stmt.run(...params, PURGE_CHUNK_SIZE);\n   111→    totalDeleted += result.changes;\n   112→    if (result.changes < PURGE_CHUNK_SIZE) break;\n   113→    await yieldTick();\n   114→  }\n   115→  return totalDeleted;\n   116→}\n   117→\n   118→async function runRetention(\n   119→  tenantDbManager: TenantDbManager,\n   120→  retentionDays: number,\n   121→  logger: Logger,\n   122→): Promise<void> {\n   123→  const cutoff = new Date(Date.now() - retentionDays * 86_400_000).toISOString();\n   124→\n   125→  const tenantIds = tenantDbManager.listTenantIds();\n   126→  for (const projectId of tenantIds) {\n   127→    try {\n   128→      const db = tenantDbManager.getTenantDb(projectId);\n   129→      await runTenantRetention(db, projectId, cutoff, retentionDays, logger);\n   130→    } catch (err) {\n   131→      logger.error({ err, projectId }, 'Retention cleanup failed for tenant');\n   132→    }\n   133→    // Yield between tenants so the event loop stays responsive\n   134→    await yieldTick();\n   135→  }\n   136→\n   137→  // ── Reduce phase: aggregate all tenant metrics into system.db ──\n   138→  try {\n   139→    aggregateSystemMetrics(tenantDbManager, logger);\n   140→  } catch (err) {\n   141→    logger.error({ err }, 'System-wide metrics aggregation failed');\n   142→  }\n   143→}\n   144→\n   145→/**\n   146→ * Map-reduce step: read daily_metrics from every tenant DB and write\n   147→ * a system-wide summary to the system_daily_metrics table in system.db.\n   148→ * Replaces rows wholesale each run so the system view is always consistent.\n   149→ */\n   150→function aggregateSystemMetrics(\n   151→  tenantDbManager: TenantDbManager,\n   152→  logger: Logger,\n   153→): void {\n   154→  const systemDb = tenantDbManager.getSystemDb();\n   155→  const tenantIds = tenantDbManager.listTenantIds();\n   156→\n   157→  // Accumulate per-day totals across all tenants\n   158→  const dayMap = new Map<string, {\n   159→    total_executions: number;\n   160→    completed: number;\n   161→    failed: number;\n   162→    total_cost_usd: number;\n   163→    total_duration_ms: number;\n   164→    tenant_count: number;\n   165→  }>();\n   166→\n   167→  for (const projectId of tenantIds) {\n   168→    try {\n   169→      const db = tenantDbManager.getTenantDb(projectId);\n   170→      const rows = db.prepare(\n   171→        'SELECT date, total_executions, completed, failed, total_cost_usd, total_duration_ms FROM daily_metrics',\n   172→      ).all() as Array<{\n   173→        date: string;\n   174→        total_executions: number;\n   175→        completed: number;\n   176→        failed: number;\n   177→        total_cost_usd: number;\n   178→        total_duration_ms: number;\n   179→      }>;\n   180→\n   181→      for (const row of rows) {\n   182→        const existing = dayMap.get(row.date);\n   183→        if (existing) {\n   184→          existing.total_executions += row.total_executions;\n   185→          existing.completed += row.completed;\n   186→          existing.failed += row.failed;\n   187→          existing.total_cost_usd += row.total_cost_usd;\n   188→          existing.total_duration_ms += row.total_duration_ms;\n   189→          existing.tenant_count += 1;\n   190→        } else {\n   191→          dayMap.set(row.date, {\n   192→            total_executions: row.total_executions,\n   193→            completed: row.completed,\n   194→            failed: row.failed,\n   195→            total_cost_usd: row.total_cost_usd,\n   196→            total_duration_ms: row.total_duration_ms,\n   197→            tenant_count: 1,\n   198→          });\n   199→        }\n   200→      }\n   201→    } catch (err) {\n   202→      logger.warn({ err, projectId }, 'Failed to read metrics for tenant during aggregation');\n   203→    }\n   204→  }\n   205→\n   206→  if (dayMap.size === 0) return;\n   207→\n   208→  // Write aggregated metrics in a single transaction\n   209→  const now = new Date().toISOString();\n   210→  systemDb.transaction(() => {\n   211→    const upsert = systemDb.prepare(`\n   212→      INSERT INTO system_daily_metrics\n   213→        (date, total_executions, completed, failed, total_cost_usd, total_duration_ms, tenant_count, aggregated_at)\n   214→      VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n   215→      ON CONFLICT(date) DO UPDATE SET\n   216→        total_executions = excluded.total_executions,\n   217→        completed = excluded.completed,\n   218→        failed = excluded.failed,\n   219→        total_cost_usd = excluded.total_cost_usd,\n   220→        total_duration_ms = excluded.total_duration_ms,\n   221→        tenant_count = excluded.tenant_count,\n   222→        aggregated_at = excluded.aggregated_at\n   223→    `);\n   224→    for (const [date, m] of dayMap) {\n   225→      upsert.run(date, m.total_executions, m.completed, m.failed, m.total_cost_usd, m.total_duration_ms, m.tenant_count, now);\n   226→    }\n   227→  })();\n   228→\n   229→  logger.info({ days: dayMap.size, tenants: tenantIds.length }, 'System-wide metrics aggregation complete');\n   230→}\n   231→\n   232→async function runTenantRetention(\n   233→  db: Database.Database,\n   234→  projectId: string,\n   235→  cutoff: string,\n   236→  retentionDays: number,\n   237→  logger: Logger,\n   238→): Promise<void> {\n   239→  // ── Batched index scan: collect purgeable execution rowids in chunks ──\n   240→  // Both the aggregation (Step 1) and the delete (Step 2) operate on\n   241→  // this pre-collected set instead of scanning persona_executions twice.\n   242→  // The collection itself is batched to avoid holding a write lock while\n   243→  // inserting millions of rowids after a long retention gap.\n   244→  db.exec('CREATE TEMP TABLE IF NOT EXISTS _ret_ids (id INTEGER PRIMARY KEY)');\n   245→  db.prepare('DELETE FROM _ret_ids').run();\n   246→  {\n   247→    const collectStmt = db.prepare(`\n   248→      INSERT INTO _ret_ids (id)\n   249→      SELECT rowid FROM persona_executions\n   250→      WHERE rowid > ? AND created_at < ? AND status IN ('completed', 'failed', 'cancelled')\n   251→      ORDER BY rowid\n   252→      LIMIT ?\n   253→    `);\n   254→    let cursor = 0;\n   255→    while (true) {\n   256→      const result = collectStmt.run(cursor, cutoff, PURGE_CHUNK_SIZE);\n   257→      if (result.changes === 0) break;\n   258→      const maxRow = db.prepare('SELECT MAX(id) as m FROM _ret_ids').get() as { m: number };\n   259→      cursor = maxRow.m;\n   260→      if (result.changes < PURGE_CHUNK_SIZE) break;\n   261→      await yieldTick();\n   262→    }\n   263→  }\n   264→\n   265→  // ── Step 1: Aggregate metrics in a short transaction ──────────────\n   266→  // Watermark-based: each source row is counted exactly once, so the\n   267→  // additive upsert is safe even if a previous run crashed mid-delete.\n   268→  // No heavy deletes here — lock duration is brief.\n   269→  const aggregatedDays = db.transaction(() => {\n   270→    const watermarkRow = db.prepare(\n   271→      \"SELECT last_rowid FROM retention_watermark WHERE key = 'executions'\",\n   272→    ).get() as { last_rowid: number } | undefined;\n   273→    const lastRowid = watermarkRow?.last_rowid ?? 0;\n   274→\n   275→    // Max rowid above the watermark (reads temp table only, no main-table scan)\n   276→    const maxRow = db.prepare(\n   277→      'SELECT MAX(id) as max_rowid FROM _ret_ids WHERE id > ?',\n   278→    ).get(lastRowid) as { max_rowid: number | null } | undefined;\n   279→    const newWatermark = maxRow?.max_rowid ?? lastRowid;\n   280→\n   281→    // Aggregate only never-before-counted rows. The JOIN fetches data columns\n   282→    // via direct rowid B-tree lookups rather than a redundant index range scan.\n   283→    const rows = db.prepare(`\n   284→      SELECT\n   285→        date(pe.created_at) as day,\n   286→        COUNT(*) as total,\n   287→        SUM(CASE WHEN pe.status = 'completed' THEN 1 ELSE 0 END) as completed,\n   288→        SUM(CASE WHEN pe.status = 'failed' THEN 1 ELSE 0 END) as failed,\n   289→        COALESCE(SUM(pe.cost_usd), 0) as cost,\n   290→        COALESCE(SUM(pe.duration_ms), 0) as duration\n   291→      FROM _ret_ids r\n   292→      JOIN persona_executions pe ON pe.rowid = r.id\n   293→      WHERE r.id > ?\n   294→      GROUP BY date(pe.created_at)\n   295→    `).all(lastRowid) as Array<{ day: string; total: number; completed: number; failed: number; cost: number; duration: number }>;\n   296→\n   297→    const upsertStmt = db.prepare(`\n   298→      INSERT INTO daily_metrics (date, total_executions, completed, failed, total_cost_usd, total_duration_ms)\n   299→      VALUES (?, ?, ?, ?, ?, ?)\n   300→      ON CONFLICT(date) DO UPDATE SET\n   301→        total_executions = total_executions + excluded.total_executions,\n   302→        completed = completed + excluded.completed,\n   303→        failed = failed + excluded.failed,\n   304→        total_cost_usd = total_cost_usd + excluded.total_cost_usd,\n   305→        total_duration_ms = total_duration_ms + excluded.total_duration_ms\n   306→    `);\n   307→    for (const row of rows) {\n   308→      upsertStmt.run(row.day, row.total, row.completed, row.failed, row.cost, row.duration);\n   309→    }\n   310→\n   311→    db.prepare(`\n   312→      INSERT INTO retention_watermark (key, last_rowid) VALUES ('executions', ?)\n   313→      ON CONFLICT(key) DO UPDATE SET last_rowid = excluded.last_rowid\n   314→    `).run(newWatermark);\n   315→\n   316→    return rows.length;\n   317→  })();\n   318→\n   319→  // ── Step 2: Delete execution rows using pre-collected rowids ──────\n   320→  // Pre-purge sanity check: refuse to delete more than EXEC_MAX_PURGE_FRACTION of all rows\n   321→  const execTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_executions').get() as { cnt: number };\n   322→  const execCandidateRow = db.prepare('SELECT COUNT(*) as cnt FROM _ret_ids').get() as { cnt: number };\n   323→\n   324→  let purgedExecutions = 0;\n   325→  if (execTotalRow.cnt > 0 && execCandidateRow.cnt / execTotalRow.cnt > EXEC_MAX_PURGE_FRACTION) {\n   326→    logger.error(\n   327→      { projectId, total: execTotalRow.cnt, candidates: execCandidateRow.cnt, cutoff, maxFraction: EXEC_MAX_PURGE_FRACTION },\n   328→      'Execution purge aborted: deletion would exceed safety cap',\n   329→    );\n   330→  } else {\n   331→    // Each chunk is its own implicit transaction (~50ms lock), with event-loop\n   332→    // yields between chunks so concurrent operations can proceed.\n   333→    const deleteStmt = db.prepare(\n   334→      'DELETE FROM persona_executions WHERE rowid IN (SELECT id FROM _ret_ids LIMIT ?)',\n   335→    );\n   336→    const trimStmt = db.prepare(\n   337→      'DELETE FROM _ret_ids WHERE id IN (SELECT id FROM _ret_ids LIMIT ?)',\n   338→    );\n   339→    while (true) {\n   340→      const result = deleteStmt.run(PURGE_CHUNK_SIZE);\n   341→      purgedExecutions += result.changes;\n   342→      trimStmt.run(PURGE_CHUNK_SIZE);\n   343→      if (result.changes < PURGE_CHUNK_SIZE) break;\n   344→      await yieldTick();\n   345→    }\n   346→  }\n   347→\n   348→  // ── Step 3: Purge old events in batched chunks ────────────────────\n   349→  // Pre-purge sanity check for events\n   350→  const eventsTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_events').get() as { cnt: number };\n   351→  const eventsCandidateRow = db.prepare(\n   352→    \"SELECT COUNT(*) as cnt FROM persona_events WHERE created_at < ?\",\n   353→  ).get(cutoff) as { cnt: number };\n   354→\n   355→  let purgedEvents = 0;\n   356→  let purgedStuckEvents = 0;\n   357→  if (eventsTotalRow.cnt > 0 && eventsCandidateRow.cnt / eventsTotalRow.cnt > EVENTS_MAX_PURGE_FRACTION) {\n   358→    logger.error(\n   359→      { projectId, total: eventsTotalRow.cnt, candidates: eventsCandidateRow.cnt, cutoff, maxFraction: EVENTS_MAX_PURGE_FRACTION },\n   360→      'Event purge aborted: deletion would exceed safety cap',\n   361→    );\n   362→  } else {\n   363→    purgedEvents = await chunkedDelete(\n   364→      db,\n   365→      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status NOT IN ('pending', 'processing') LIMIT ?)\",\n   366→      [cutoff],\n   367→    );\n   368→\n   369→    // Safety net: purge stuck pending/processing events older than 7x retentionDays.\n   370→    const stuckCutoff = new Date(Date.now() - retentionDays * 7 * 86_400_000).toISOString();\n   371→    purgedStuckEvents = await chunkedDelete(\n   372→      db,\n   373→      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status IN ('pending', 'processing') LIMIT ?)\",\n   374→      [stuckCutoff],\n   375→    );\n   376→  }\n   377→\n   378→  if (purgedExecutions > 0 || purgedEvents > 0 || purgedStuckEvents > 0) {\n   379→    logger.info({\n   380→      projectId,\n   381→      purgedExecutions,\n   382→      purgedEvents,\n   383→      purgedStuckEvents,\n   384→      aggregatedDays,\n   385→    }, 'Retention cleanup complete');\n   386→  }\n   387→}\n   388→"}]},"parent_tool_use_id":null,"session_id":"3557cb6e-ae5f-4c9b-abbc-8aa3f1b3f2e1","uuid":"81f1d11f-3507-42fd-a76a-a96b4641cee0","timestamp":"2026-03-18T17:14:12.618Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\retention.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport { getTableSpec, isMetrizable, isEphemeral } from '@dac-cloud/shared';\nimport type { MetrizableTableSpec, EphemeralTableSpec } from '@dac-cloud/shared';\nimport type { TenantDbManager } from './tenantDbManager.js';\n\n// Validate registry classification at import time — if someone changes the\n// registry without updating this module the build still passes but the runtime\n// assertion catches the mismatch immediately.\nconst execSpec = getTableSpec('persona_executions');\nconst eventsSpec = getTableSpec('persona_events');\nif (!execSpec || !isMetrizable(execSpec)) {\n  throw new Error('persona_executions must be registered as metrizable in TABLE_REGISTRY');\n}\nif (!eventsSpec || !isEphemeral(eventsSpec)) {\n  throw new Error('persona_events must be registered as ephemeral in TABLE_REGISTRY');\n}\n\n/** Maximum fraction of rows a single purge cycle may delete (safety cap). */\nconst EXEC_MAX_PURGE_FRACTION = (execSpec as MetrizableTableSpec).maxPurgeFraction ?? 0.8;\nconst EVENTS_MAX_PURGE_FRACTION = (eventsSpec as EphemeralTableSpec).maxPurgeFraction ?? 0.8;\n\n/** Rows deleted per chunk to keep individual lock durations short (~50ms). */\nconst PURGE_CHUNK_SIZE = 5000;\n\n/** Yield the event loop so concurrent reads/writes can proceed between batches. */\nfunction yieldTick(): Promise<void> {\n  return new Promise((resolve) => setImmediate(resolve));\n}\n\n/** How often we check whether it's time for the daily run (60 seconds). */\nconst SCHEDULE_CHECK_MS = 60_000;\n\n/** system_kv key used to persist the last successful run date (UTC). */\nconst LAST_RUN_KEY = 'retention_last_run_date';\n\n/** Return today's UTC date as YYYY-MM-DD. */\nfunction utcToday(): string {\n  return new Date().toISOString().slice(0, 10);\n}\n\n/** Read the last-run UTC date from system_kv, or null if never run. */\nfunction getLastRunDate(tenantDbManager: TenantDbManager): string | null {\n  const row = tenantDbManager.getSystemDb().prepare(\n    'SELECT value FROM system_kv WHERE key = ?',\n  ).get(LAST_RUN_KEY) as { value: string } | undefined;\n  return row?.value ?? null;\n}\n\n/** Persist the current UTC date as the last-run date. */\nfunction setLastRunDate(tenantDbManager: TenantDbManager, date: string): void {\n  tenantDbManager.getSystemDb().prepare(\n    'INSERT INTO system_kv (key, value) VALUES (?, ?) ON CONFLICT(key) DO UPDATE SET value = excluded.value',\n  ).run(LAST_RUN_KEY, date);\n}\n\n/**\n * Daily retention job: purge old executions/events and aggregate daily metrics.\n *\n * Uses a 60-second wall-clock poll instead of a drifting 24-hour setInterval.\n * The last successful run date is persisted in system_kv so the job runs\n * exactly once per UTC calendar day regardless of restarts or event-loop delays.\n */\nexport function startRetentionJob(\n  tenantDbManager: TenantDbManager,\n  retentionDays: number,\n  logger: Logger,\n): NodeJS.Timeout {\n  logger.info({ retentionDays }, 'Retention job scheduled (wall-clock daily)');\n\n  let running = false;\n\n  async function tick(): Promise<void> {\n    if (running) return;\n\n    const today = utcToday();\n    const lastRun = getLastRunDate(tenantDbManager);\n\n    if (lastRun === today) return; // already ran today\n\n    running = true;\n    logger.info({ today, lastRun }, 'Retention job triggered');\n    try {\n      await runRetention(tenantDbManager, retentionDays, logger);\n      setLastRunDate(tenantDbManager, today);\n      logger.info({ today }, 'Retention job completed, next run tomorrow');\n    } catch (err) {\n      logger.error({ err }, 'Retention job failed — will retry next tick');\n    } finally {\n      running = false;\n    }\n  }\n\n  // First check shortly after startup, then every 60 seconds\n  setTimeout(() => tick(), 5000);\n\n  return setInterval(() => {\n    tick();\n  }, SCHEDULE_CHECK_MS);\n}\n\n/**\n * Delete rows in chunks of PURGE_CHUNK_SIZE, yielding the event loop between\n * batches so other DB operations are not starved.\n */\nasync function chunkedDelete(db: Database.Database, sql: string, params: unknown[]): Promise<number> {\n  const stmt = db.prepare(sql);\n  let totalDeleted = 0;\n  while (true) {\n    const result = stmt.run(...params, PURGE_CHUNK_SIZE);\n    totalDeleted += result.changes;\n    if (result.changes < PURGE_CHUNK_SIZE) break;\n    await yieldTick();\n  }\n  return totalDeleted;\n}\n\nasync function runRetention(\n  tenantDbManager: TenantDbManager,\n  retentionDays: number,\n  logger: Logger,\n): Promise<void> {\n  const cutoff = new Date(Date.now() - retentionDays * 86_400_000).toISOString();\n\n  const tenantIds = tenantDbManager.listTenantIds();\n  for (const projectId of tenantIds) {\n    try {\n      const db = tenantDbManager.getTenantDb(projectId);\n      await runTenantRetention(db, projectId, cutoff, retentionDays, logger);\n    } catch (err) {\n      logger.error({ err, projectId }, 'Retention cleanup failed for tenant');\n    }\n    // Yield between tenants so the event loop stays responsive\n    await yieldTick();\n  }\n\n  // ── Reduce phase: aggregate all tenant metrics into system.db ──\n  try {\n    aggregateSystemMetrics(tenantDbManager, logger);\n  } catch (err) {\n    logger.error({ err }, 'System-wide metrics aggregation failed');\n  }\n}\n\n/**\n * Map-reduce step: read daily_metrics from every tenant DB and write\n * a system-wide summary to the system_daily_metrics table in system.db.\n * Replaces rows wholesale each run so the system view is always consistent.\n */\nfunction aggregateSystemMetrics(\n  tenantDbManager: TenantDbManager,\n  logger: Logger,\n): void {\n  const systemDb = tenantDbManager.getSystemDb();\n  const tenantIds = tenantDbManager.listTenantIds();\n\n  // Accumulate per-day totals across all tenants\n  const dayMap = new Map<string, {\n    total_executions: number;\n    completed: number;\n    failed: number;\n    total_cost_usd: number;\n    total_duration_ms: number;\n    tenant_count: number;\n  }>();\n\n  for (const projectId of tenantIds) {\n    try {\n      const db = tenantDbManager.getTenantDb(projectId);\n      const rows = db.prepare(\n        'SELECT date, total_executions, completed, failed, total_cost_usd, total_duration_ms FROM daily_metrics',\n      ).all() as Array<{\n        date: string;\n        total_executions: number;\n        completed: number;\n        failed: number;\n        total_cost_usd: number;\n        total_duration_ms: number;\n      }>;\n\n      for (const row of rows) {\n        const existing = dayMap.get(row.date);\n        if (existing) {\n          existing.total_executions += row.total_executions;\n          existing.completed += row.completed;\n          existing.failed += row.failed;\n          existing.total_cost_usd += row.total_cost_usd;\n          existing.total_duration_ms += row.total_duration_ms;\n          existing.tenant_count += 1;\n        } else {\n          dayMap.set(row.date, {\n            total_executions: row.total_executions,\n            completed: row.completed,\n            failed: row.failed,\n            total_cost_usd: row.total_cost_usd,\n            total_duration_ms: row.total_duration_ms,\n            tenant_count: 1,\n          });\n        }\n      }\n    } catch (err) {\n      logger.warn({ err, projectId }, 'Failed to read metrics for tenant during aggregation');\n    }\n  }\n\n  if (dayMap.size === 0) return;\n\n  // Write aggregated metrics in a single transaction\n  const now = new Date().toISOString();\n  systemDb.transaction(() => {\n    const upsert = systemDb.prepare(`\n      INSERT INTO system_daily_metrics\n        (date, total_executions, completed, failed, total_cost_usd, total_duration_ms, tenant_count, aggregated_at)\n      VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n      ON CONFLICT(date) DO UPDATE SET\n        total_executions = excluded.total_executions,\n        completed = excluded.completed,\n        failed = excluded.failed,\n        total_cost_usd = excluded.total_cost_usd,\n        total_duration_ms = excluded.total_duration_ms,\n        tenant_count = excluded.tenant_count,\n        aggregated_at = excluded.aggregated_at\n    `);\n    for (const [date, m] of dayMap) {\n      upsert.run(date, m.total_executions, m.completed, m.failed, m.total_cost_usd, m.total_duration_ms, m.tenant_count, now);\n    }\n  })();\n\n  logger.info({ days: dayMap.size, tenants: tenantIds.length }, 'System-wide metrics aggregation complete');\n}\n\nasync function runTenantRetention(\n  db: Database.Database,\n  projectId: string,\n  cutoff: string,\n  retentionDays: number,\n  logger: Logger,\n): Promise<void> {\n  // ── Batched index scan: collect purgeable execution rowids in chunks ──\n  // Both the aggregation (Step 1) and the delete (Step 2) operate on\n  // this pre-collected set instead of scanning persona_executions twice.\n  // The collection itself is batched to avoid holding a write lock while\n  // inserting millions of rowids after a long retention gap.\n  db.exec('CREATE TEMP TABLE IF NOT EXISTS _ret_ids (id INTEGER PRIMARY KEY)');\n  db.prepare('DELETE FROM _ret_ids').run();\n  {\n    const collectStmt = db.prepare(`\n      INSERT INTO _ret_ids (id)\n      SELECT rowid FROM persona_executions\n      WHERE rowid > ? AND created_at < ? AND status IN ('completed', 'failed', 'cancelled')\n      ORDER BY rowid\n      LIMIT ?\n    `);\n    let cursor = 0;\n    while (true) {\n      const result = collectStmt.run(cursor, cutoff, PURGE_CHUNK_SIZE);\n      if (result.changes === 0) break;\n      const maxRow = db.prepare('SELECT MAX(id) as m FROM _ret_ids').get() as { m: number };\n      cursor = maxRow.m;\n      if (result.changes < PURGE_CHUNK_SIZE) break;\n      await yieldTick();\n    }\n  }\n\n  // ── Step 1: Aggregate metrics in a short transaction ──────────────\n  // Watermark-based: each source row is counted exactly once, so the\n  // additive upsert is safe even if a previous run crashed mid-delete.\n  // No heavy deletes here — lock duration is brief.\n  const aggregatedDays = db.transaction(() => {\n    const watermarkRow = db.prepare(\n      \"SELECT last_rowid FROM retention_watermark WHERE key = 'executions'\",\n    ).get() as { last_rowid: number } | undefined;\n    const lastRowid = watermarkRow?.last_rowid ?? 0;\n\n    // Max rowid above the watermark (reads temp table only, no main-table scan)\n    const maxRow = db.prepare(\n      'SELECT MAX(id) as max_rowid FROM _ret_ids WHERE id > ?',\n    ).get(lastRowid) as { max_rowid: number | null } | undefined;\n    const newWatermark = maxRow?.max_rowid ?? lastRowid;\n\n    // Aggregate only never-before-counted rows. The JOIN fetches data columns\n    // via direct rowid B-tree lookups rather than a redundant index range scan.\n    const rows = db.prepare(`\n      SELECT\n        date(pe.created_at) as day,\n        COUNT(*) as total,\n        SUM(CASE WHEN pe.status = 'completed' THEN 1 ELSE 0 END) as completed,\n        SUM(CASE WHEN pe.status = 'failed' THEN 1 ELSE 0 END) as failed,\n        COALESCE(SUM(pe.cost_usd), 0) as cost,\n        COALESCE(SUM(pe.duration_ms), 0) as duration\n      FROM _ret_ids r\n      JOIN persona_executions pe ON pe.rowid = r.id\n      WHERE r.id > ?\n      GROUP BY date(pe.created_at)\n    `).all(lastRowid) as Array<{ day: string; total: number; completed: number; failed: number; cost: number; duration: number }>;\n\n    const upsertStmt = db.prepare(`\n      INSERT INTO daily_metrics (date, total_executions, completed, failed, total_cost_usd, total_duration_ms)\n      VALUES (?, ?, ?, ?, ?, ?)\n      ON CONFLICT(date) DO UPDATE SET\n        total_executions = total_executions + excluded.total_executions,\n        completed = completed + excluded.completed,\n        failed = failed + excluded.failed,\n        total_cost_usd = total_cost_usd + excluded.total_cost_usd,\n        total_duration_ms = total_duration_ms + excluded.total_duration_ms\n    `);\n    for (const row of rows) {\n      upsertStmt.run(row.day, row.total, row.completed, row.failed, row.cost, row.duration);\n    }\n\n    db.prepare(`\n      INSERT INTO retention_watermark (key, last_rowid) VALUES ('executions', ?)\n      ON CONFLICT(key) DO UPDATE SET last_rowid = excluded.last_rowid\n    `).run(newWatermark);\n\n    return rows.length;\n  })();\n\n  // ── Step 2: Delete execution rows using pre-collected rowids ──────\n  // Pre-purge sanity check: refuse to delete more than EXEC_MAX_PURGE_FRACTION of all rows\n  const execTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_executions').get() as { cnt: number };\n  const execCandidateRow = db.prepare('SELECT COUNT(*) as cnt FROM _ret_ids').get() as { cnt: number };\n\n  let purgedExecutions = 0;\n  if (execTotalRow.cnt > 0 && execCandidateRow.cnt / execTotalRow.cnt > EXEC_MAX_PURGE_FRACTION) {\n    logger.error(\n      { projectId, total: execTotalRow.cnt, candidates: execCandidateRow.cnt, cutoff, maxFraction: EXEC_MAX_PURGE_FRACTION },\n      'Execution purge aborted: deletion would exceed safety cap',\n    );\n  } else {\n    // Each chunk is its own implicit transaction (~50ms lock), with event-loop\n    // yields between chunks so concurrent operations can proceed.\n    const deleteStmt = db.prepare(\n      'DELETE FROM persona_executions WHERE rowid IN (SELECT id FROM _ret_ids LIMIT ?)',\n    );\n    const trimStmt = db.prepare(\n      'DELETE FROM _ret_ids WHERE id IN (SELECT id FROM _ret_ids LIMIT ?)',\n    );\n    while (true) {\n      const result = deleteStmt.run(PURGE_CHUNK_SIZE);\n      purgedExecutions += result.changes;\n      trimStmt.run(PURGE_CHUNK_SIZE);\n      if (result.changes < PURGE_CHUNK_SIZE) break;\n      await yieldTick();\n    }\n  }\n\n  // ── Step 3: Purge old events in batched chunks ────────────────────\n  // Pre-purge sanity check for events\n  const eventsTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_events').get() as { cnt: number };\n  const eventsCandidateRow = db.prepare(\n    \"SELECT COUNT(*) as cnt FROM persona_events WHERE created_at < ?\",\n  ).get(cutoff) as { cnt: number };\n\n  let purgedEvents = 0;\n  let purgedStuckEvents = 0;\n  if (eventsTotalRow.cnt > 0 && eventsCandidateRow.cnt / eventsTotalRow.cnt > EVENTS_MAX_PURGE_FRACTION) {\n    logger.error(\n      { projectId, total: eventsTotalRow.cnt, candidates: eventsCandidateRow.cnt, cutoff, maxFraction: EVENTS_MAX_PURGE_FRACTION },\n      'Event purge aborted: deletion would exceed safety cap',\n    );\n  } else {\n    purgedEvents = await chunkedDelete(\n      db,\n      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status NOT IN ('pending', 'processing') LIMIT ?)\",\n      [cutoff],\n    );\n\n    // Safety net: purge stuck pending/processing events older than 7x retentionDays.\n    const stuckCutoff = new Date(Date.now() - retentionDays * 7 * 86_400_000).toISOString();\n    purgedStuckEvents = await chunkedDelete(\n      db,\n      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status IN ('pending', 'processing') LIMIT ?)\",\n      [stuckCutoff],\n    );\n  }\n\n  if (purgedExecutions > 0 || purgedEvents > 0 || purgedStuckEvents > 0) {\n    logger.info({\n      projectId,\n      purgedExecutions,\n      purgedEvents,\n      purgedStuckEvents,\n      aggregatedDays,\n    }, 'Retention cleanup complete');\n  }\n}\n","numLines":388,"startLine":1,"totalLines":388}}}
