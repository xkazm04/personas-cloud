[2026-03-18T12:17:51.779Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012wm5C4ig1SvHRAco1VPrxc","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import { matchEvent, assemblePrompt } from '@dac-cloud/shared';\n     4→import type { ExecRequest, EventMatch, PersonaEvent } from '@dac-cloud/shared';\n     5→import { nanoid } from 'nanoid';\n     6→import * as db from './db/index.js';\n     7→import type { Dispatcher } from './dispatcher.js';\n     8→import type { TenantDbManager } from './tenantDbManager.js';\n     9→\n    10→/** Default threshold (seconds) for the periodic stale-event reaper. */\n    11→const STALE_EVENT_REAPER_SECONDS = 120;\n    12→/** Run the reaper every N ticks (at 2s interval, 30 ticks = ~60s). */\n    13→const REAPER_TICK_INTERVAL = 30;\n    14→\n    15→/**\n    16→ * Recover events orphaned in 'processing' state from a prior crash.\n    17→ * Call once at startup before the tick loop begins.\n    18→ */\n    19→function recoverOrphanedEvents(\n    20→  database: Database.Database | null,\n    21→  logger: Logger,\n    22→  tenantDbManager?: TenantDbManager,\n    23→): void {\n    24→  if (tenantDbManager) {\n    25→    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    26→      const count = db.resetAllProcessingEvents(tenantDb);\n    27→      if (count > 0) {\n    28→        logger.warn({ projectId, count }, 'Reset orphaned processing events to pending at startup');\n    29→      }\n    30→    });\n    31→  } else if (database) {\n    32→    const count = db.resetAllProcessingEvents(database);\n    33→    if (count > 0) {\n    34→      logger.warn({ count }, 'Reset orphaned processing events to pending at startup');\n    35→    }\n    36→  }\n    37→}\n    38→\n    39→/**\n    40→ * Periodic reaper: reset events stuck in 'processing' longer than the threshold.\n    41→ * Guards against edge cases during normal operation.\n    42→ */\n    43→function reapStaleEvents(\n    44→  database: Database.Database | null,\n    45→  logger: Logger,\n    46→  tenantDbManager?: TenantDbManager,\n    47→): void {\n    48→  if (tenantDbManager) {\n    49→    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    50→      const count = db.resetStaleProcessingEvents(tenantDb, STALE_EVENT_REAPER_SECONDS);\n    51→      if (count > 0) {\n    52→        logger.warn({ projectId, count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    53→      }\n    54→    });\n    55→  } else if (database) {\n    56→    const count = db.resetStaleProcessingEvents(database, STALE_EVENT_REAPER_SECONDS);\n    57→    if (count > 0) {\n    58→      logger.warn({ count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    59→    }\n    60→  }\n    61→}\n    62→\n    63→/**\n    64→ * Start the event processing loop.\n    65→ * Supports both tenant-isolated DBs (via TenantDbManager) and legacy single DB.\n    66→ */\n    67→export function startEventProcessor(\n    68→  database: Database.Database | null,\n    69→  dispatcher: Dispatcher,\n    70→  logger: Logger,\n    71→  interval: number = 2000,\n    72→  tenantDbManager?: TenantDbManager,\n    73→): NodeJS.Timeout {\n    74→  // At startup, reset any events orphaned in 'processing' from a prior crash\n    75→  recoverOrphanedEvents(database, logger, tenantDbManager);\n    76→\n    77→  logger.info({ intervalMs: interval, tenantIsolated: !!tenantDbManager }, 'Event processor started');\n    78→\n    79→  let tickCount = 0;\n    80→\n    81→  return setInterval(() => {\n    82→    try {\n    83→      tickCount++;\n    84→\n    85→      // Periodically reap stale processing events as a safety net\n    86→      if (tickCount % REAPER_TICK_INTERVAL === 0) {\n    87→        reapStaleEvents(database, logger, tenantDbManager);\n    88→      }\n    89→\n    90→      if (tenantDbManager) {\n    91→        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    92→          eventBusTick(tenantDb, dispatcher, logger, projectId);\n    93→        });\n    94→      } else if (database) {\n    95→        eventBusTick(database, dispatcher, logger);\n    96→      }\n    97→    } catch (err) {\n    98→      logger.error({ err }, 'Event processor tick failed');\n    99→    }\n   100→  }, interval);\n   101→}\n   102→\n   103→function eventBusTick(\n   104→  database: Database.Database,\n   105→  dispatcher: Dispatcher,\n   106→  logger: Logger,\n   107→  projectId?: string,\n   108→): void {\n   109→  const events = db.getPendingEvents(database, 50);\n   110→  if (events.length === 0) return;\n   111→\n   112→  // Collect dispatch requests to fire *after* the transaction commits so that\n   113→  // the dispatcher never sees stale DB state.\n   114→  const pendingDispatches: ExecRequest[] = [];\n   115→\n   116→  // Wrap all DB reads/writes in a single transaction to avoid per-statement\n   117→  // fsync overhead (up to 100 individual commits per tick otherwise).\n   118→  database.transaction(() => {\n   119→    // Cache subscription lookups per unique (eventType, projectId) to avoid\n   120→    // redundant DB queries when the same event type fires multiple times in a batch.\n   121→    const subsCache = new Map<string, ReturnType<typeof db.getSubscriptionsByEventType>>();\n   122→\n   123→    // Phase 1: Mark events as processing, compute matches, collect unique persona IDs.\n   124→    const eventMatches: Array<{ event: PersonaEvent; matches: EventMatch[] }> = [];\n   125→    const allPersonaIds = new Set<string>();\n   126→\n   127→    for (const event of events) {\n   128→      db.updateEventStatus(database, event.id, 'processing');\n   129→\n   130→      const cacheKey = `${event.eventType}\\0${event.projectId}`;\n   131→      let subs = subsCache.get(cacheKey);\n   132→      if (subs === undefined) {\n   133→        subs = db.getSubscriptionsByEventType(database, event.eventType, event.projectId);\n   134→        subsCache.set(cacheKey, subs);\n   135→      }\n   136→      const matches = matchEvent(event, subs);\n   137→\n   138→      if (matches.length === 0) {\n   139→        db.updateEventStatus(database, event.id, 'skipped');\n   140→        continue;\n   141→      }\n   142→\n   143→      eventMatches.push({ event, matches });\n   144→      for (const match of matches) {\n   145→        allPersonaIds.add(match.personaId);\n   146→      }\n   147→    }\n   148→\n   149→    if (allPersonaIds.size === 0) return;\n   150→\n   151→    // Phase 2: Batch-fetch personas, tools, and running counts (2-3 queries total).\n   152→    const personaIds = [...allPersonaIds];\n   153→    const personaMap = db.getPersonasByIds(database, personaIds);\n   154→    const toolsMap = db.getToolsForPersonaIds(database, personaIds);\n   155→    const runningMap = db.countRunningExecutionsByPersonaIds(database, personaIds);\n   156→\n   157→    // Phase 3: Dispatch using Map lookups instead of per-match queries.\n   158→    // Track persona slots claimed within this tick to prevent over-dispatch.\n   159→    const claimed = new Map<string, number>();\n   160→\n   161→    for (const { event, matches } of eventMatches) {\n   162→      let delivered = 0;\n   163→      let failed = 0;\n   164→      let throttled = 0;\n   165→\n   166→      for (const match of matches) {\n   167→        try {\n   168→          const persona = personaMap.get(match.personaId);\n   169→          if (!persona) {\n   170→            logger.warn({ personaId: match.personaId, eventId: event.id }, 'Persona not found for event match');\n   171→            failed++;\n   172→            continue;\n   173→          }\n   174→\n   175→          // Check concurrency (in-tick claims + batched DB count)\n   176→          const tickClaimed = claimed.get(persona.id) ?? 0;\n   177→          const running = runningMap.get(persona.id) ?? 0;\n   178→          if (running + tickCl