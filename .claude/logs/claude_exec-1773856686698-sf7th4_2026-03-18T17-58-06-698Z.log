[2026-03-18T17:58:14.310Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PmCbVzvNhVGTADUm6Qa81b","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import type { KafkaClient } from './kafka.js';\n    11→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    12→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    13→import type { TenantDbManager } from './tenantDbManager.js';\n    14→import type { TenantKeyManager } from './tenantKeyManager.js';\n    15→import type { AuditLog, AuditAction } from './auditLog.js';\n    16→import type { EventProcessorHealth } from './eventProcessor.js';\n    17→import type { Logger } from 'pino';\n    18→import * as db from './db/index.js';\n    19→import { readBody, json } from './httpUtils.js';\n    20→\n    21→// --- Route types ---\n    22→\n    23→interface ParsedRoute {\n    24→  resource: string;\n    25→  id?: string;\n    26→  subResource?: string;\n    27→}\n    28→\n    29→type RouteHandler = (\n    30→  req: http.IncomingMessage,\n    31→  res: http.ServerResponse,\n    32→  ctx: RequestContext,\n    33→  route: ParsedRoute | null,\n    34→  queryString: string | undefined,\n    35→  tenantDb: Database.Database | undefined,\n    36→  scopedProjectId: string | undefined,\n    37→  reqLogger: Logger,\n    38→) => Promise<void> | void;\n    39→\n    40→interface RouteEntry {\n    41→  handler: RouteHandler;\n    42→  needsDb?: boolean;\n    43→  adminOnly?: boolean;\n    44→}\n    45→\n    46→/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\n    47→function resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n    48→  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n    49→}\n    50→\n    51→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n    52→function parseRoute(pathname: string): ParsedRoute | null {\n    53→  if (!pathname.startsWith('/api/')) return null;\n    54→  const segments = pathname.slice(5).split('/').filter(Boolean);\n    55→  if (segments.length === 0) return null;\n    56→  return {\n    57→    resource: segments[0]!,\n    58→    id: segments[1],\n    59→    subResource: segments[2],\n    60→  };\n    61→}\n    62→\n    63→export function createHttpApi(\n    64→  auth: Auth,\n    65→  dispatcher: Dispatcher,\n    66→  pool: WorkerPool,\n    67→  tokenManager: TokenManager,\n    68→  oauth: OAuthManager,\n    69→  logger: Logger,\n    70→  database?: Database.Database,\n    71→  tenantDbManager?: TenantDbManager,\n    72→  tenantKeyManager?: TenantKeyManager,\n    73→  auditLog?: AuditLog,\n    74→  getEventProcessorHealth?: () => EventProcessorHealth,\n    75→  kafka?: KafkaClient,\n    76→  onEventPublished?: () => void,\n    77→): http.Server {\n    78→\n    79→  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n    80→  const exactRoutes = new Map<string, RouteEntry>();\n    81→\n    82→  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n    83→  for (const [path, method] of [\n    84→    ['/api/oauth/authorize', 'POST'],\n    85→    ['/api/oauth/callback', 'POST'],\n    86→    ['/api/oauth/status', 'GET'],\n    87→    ['/api/oauth/refresh', 'POST'],\n    88→    ['/api/oauth/disconnect', 'DELETE'],\n    89→    ['/api/token', 'POST'],\n    90→  ] as const) {\n    91→    exactRoutes.set(`${method}:${path}`, {\n    92→      adminOnly: true,\n    93→      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n    94→        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger);\n    95→      },\n    96→    });\n    97→  }\n    98→\n    99→  exactRoutes.set('GET:/api/status', {\n   100→    handler: (_req, res) => {\n   101→      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   102→    },\n   103→  });\n   104→\n   105→  exactRoutes.set('POST:/api/execute', {\n   106→    handler: async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   107→      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n   108→    },\n   109→  });\n   110→\n   111→  exactRoutes.set('POST:/api/gitlab/webhook', {\n   112→    needsDb: true,\n   113→    handler: async (req, res, _ctx, _route, _qs, tenantDb) => {\n   114→      const body = await readBody(req);\n   115→      let parsed: Record<string, unknown> = {};\n   116→      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   117→      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   118→      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   119→      const event = db.publishEvent(tenantDb!, {\n   120→        eventType: `gitlab_${objectKind}`,\n   121→        sourceType: 'gitlab',\n   122→        sourceId: projectPath ?? null,\n   123→        payload: body,\n   124→      });\n   125→      onEventPublished?.();\n   126→      json(res, 201, event);\n   127→    },\n   128→  });\n   129→\n   130→  // Admin routes\n   131→  exactRoutes.set('GET:/api/admin/users', {\n   132→    adminOnly: true,\n   133→    handler: (_req, res) => {\n   134→      if (tenantDbManager) {\n   135→        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   136→      } else if (database) {\n   137→        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   138→      } else {\n   139→        json(res, 200, { projectIds: [] });\n   140→      }\n   141→    },\n   142→  });\n   143→\n   144→  exactRoutes.set('GET:/api/admin/personas', {\n   145→    adminOnly: true,\n   146→    handler: (_req, res) => {\n   147→      if (tenantDbManager) {\n   148→        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   149→        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   150→        json(res, 200, allPersonas);\n   151→      } else if (database) {\n   152→        json(res, 200, db.listPersonasSummary(database));\n   153→      } else {\n   154→        json(res, 200, []);\n   155→      }\n   156→    },\n   157→  });\n   158→\n   159→  exactRoutes.set('GET:/api/admin/executions', {\n   160→    adminOnly: true,\n   161→    handler: (_req, res, _ctx, _route, queryString) => {\n   162→      const params = new URLSearchParams(queryString || '');\n   163→      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   164→      if (tenantDbManager) {\n   165→        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   166→        tenantDbManager.forEachTenant((tDb) => {\n   167→          allExecs.push(...db.listExecutions(tDb, { limit }));\n   168→        });\n   169→        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   170→        json(res, 200, allExecs.slice(0, limit));\n   171→      } else if (database) {\n   172→        json(res, 200, db.listExecutions(database, {\n   173→          limit,\n   174→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   175→        }));\n   176→      } else {\n   177→        json(res, 200, []);\n   178→      }\n   179→    },\n   180→  });\n   181→\n   182→  exactRoutes.set('GET:/api/admin/audit', {\n   183→    adminOnly: true,\n   184→    handler: (_req, res, _ctx, _route, queryString) => {\n   185→      if (!auditLog) { json(res, 200, []); return; }\n   186→      const params = new URLSearchParams(queryString || '');\n   187→      json(res, 200, auditLog.query({\n   188→        tenantId: params.get('tenantId') ?? undefined,\n   189→        action: (params.get('action') ?? undefined) as AuditAction | undefined,\n   190→        since: params.get('since') ?? undefined,\n   191→        limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   192→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   193→      }));\n   194→    },\n   195→  });\n   196→\n   197→  // ── Resource route table (O(1) lookup by `METHOD:resource[:id][:sub]`) ──\n   198→  const resourceRoutes = new Map<string, RouteEntry>();\n   199→\n   200→  // --- Persona CRUD ---\n   201→  resourceRoutes.set(resourceKey('GET', 'personas', false), {\n   202→    needsDb: true,\n   203→    handler: (_req, res, _ctx, _route, _qs, tenantDb, scopedProjectId) => {\n   204→      json(res, 200, db.listPersonasSummary(tenantDb!, scopedProjectId));\n   205→    },\n   206→  });\n   207→\n   208→  resourceRoutes.set(resourceKey('POST', 'personas', false), {\n   209→    needsDb: true,\n   210→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   211→      const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   212→      const persona = createPersonaWithDefaults({\n   213→        ...body,\n   214→        projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   215→      });\n   216→      db.upsertPersona(tenantDb!, persona);\n   217→      try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: persona.id }); } catch { /* logged inside record() */ }\n   218→      reqLogger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   219→      json(res, 201, persona);\n   220→    },\n   221→  });\n   222→\n   223→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'tools'), {\n   224→    needsDb: true,\n   225→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   226→      json(res, 200, db.getToolsForPersona(tenantDb!, route!.id!));\n   227→    },\n   228→  });\n   229→\n   230→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'tools'), {\n   231→    needsDb: true,\n   232→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   233→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   234→      if (!persona) return;\n   235→      const body = JSON.parse(await readBody(req)) as { toolId: string };\n   236→      db.linkTool(tenantDb!, route!.id!, body.toolId);\n   237→      try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route!.id!, detail: { toolId: body.toolId } }); } catch { /* logged inside record() */ }\n   238→      reqLogger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route!.id!, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   239→      json(res, 200, { linked: true });\n   240→    },\n   241→  });\n   242→\n   243→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'full'), {\n   244→    needsDb: true,\n   245→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   246→      const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb!, route!.id!, reqLogger), scopedProjectId, res);\n   247→      if (!hydrated) return;\n   248→      json(res, 200, hydrated);\n   249→    },\n   250→  });\n   251→\n   252→  resourceRoutes.set(resourceKey('GET', 'personas', true), {\n   253→    needsDb: true,\n   254→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId) => {\n   255→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   256→      if (!persona) return;\n   257→      json(res, 200, persona);\n   258→    },\n   259→  });\n   260→\n   261→  resourceRoutes.set(resourceKey('DELETE', 'personas', true), {\n   262→    needsDb: true,\n   263→    handler: (_req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   264→      db.deletePersona(tenantDb!, route!.id!, scopedProjectId);\n   265→      try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route!.id! }); } catch { /* logged inside record() */ }\n   266→      reqLogger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   267→      json(res, 200, { deleted: true });\n   268→    },\n   269→  });\n   270→\n   271→  // --- Persona sub-resources: credentials ---\n   272→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'credentials'), {\n   273→    needsDb: true,\n   274→    handler: (_req, res, ctx, route, _qs, tenantDb) => {\n   275→      const creds = db.listCredentialsForPersona(tenantDb!, route!.id!);\n   276→      try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route!.id! }); } catch { /* logged inside record() */ }\n   277→      json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   278→    },\n   279→  });\n   280→\n   281→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'credentials'), {\n   282→    needsDb: true,\n   283→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   284→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   285→      if (!persona) return;\n   286→      const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   287→      db.linkCredential(tenantDb!, route!.id!, body.credentialId);\n   288→      try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', resourceType: 'persona', resourceId: route!.id!, detail: { credentialId: body.credentialId } }); } catch { /* logged inside record() */ }\n   289→      reqLogger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route!.id!, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   290→      json(res, 200, { linked: true });\n   291→    },\n   292→  });\n   293→\n   294→  // --- Persona sub-resources: subscriptions ---\n   295→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'subscriptions'), {\n   296→    needsDb: true,\n   297→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   298→      json(res, 200, db.listSubscriptionsForPersona(tenantDb!, route!.id!));\n   299→    },\n   300→  });\n   301→\n   302→  // --- Tool Definitions ---\n   303→  resourceRoutes.set(resourceKey('POST', 'tool-definitions', false), {\n   304→    needsDb: true,\n   305→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   306→      const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   307→      const tool = createToolDefinitionWithDefaults(body);\n   308→      db.upsertToolDefinition(tenantDb!, tool);\n   309→      try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', resourceType: 'toolDefinition', resourceId: tool.id }); } catch { /* logged inside record() */ }\n   310→      reqLogger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   311→      json(res, 201, tool);\n   312→    },\n   313→  });\n   314→\n   315→  // --- Credentials ---\n   316→  resourceRoutes.set(resourceKey('POST', 'credentials', false), {\n   317→    needsDb: true,\n   318→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   319→      const body = JSON.parse(await readBody(req));\n   320→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   321→\n   322→      if (!body.plaintext || typeof body.plaintext !== 'string') {\n   323→        json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   324→        return;\n   325→      }\n   326→      if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   327→        json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   328→        return;\n   329→      }\n   330→      if (!tenantKeyManager) {\n   331→        json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   332→        return;\n   333→      }\n   334→\n   335→      delete body.encryptedData;\n   336→      delete body.iv;\n   337→      delete body.tag;\n   338→\n   339→      const tenantId = body.projectId || ctx.projectId || 'default';\n   340→      const key = await tenantKeyManager.getKey(tenantId);\n   341→      const encrypted = encrypt(body.plaintext, key);\n   342→      body.encryptedData = encrypted.encrypted;\n   343→      body.iv = encrypted.iv;\n   344→      body.tag = encrypted.tag;\n   345→      delete body.plaintext;\n   346→\n   347→      const cred = db.createCredential(tenantDb!, body);\n   348→      try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n   349→      reqLogger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   350→      json(res, 201, cred);\n   351→    },\n   352→  });\n   353→\n   354→  resourceRoutes.set(resourceKey('DELETE', 'credentials', true), {\n   355→    needsDb: true,\n   356→    handler: (_req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   357→      const changes = db.deleteCredential(tenantDb!, route!.id!, scopedProjectId);\n   358→      if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   359→      try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route!.id! }); } catch { /* logged inside record() */ }\n   360→      reqLogger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   361→      json(res, 200, { deleted: true });\n   362→    },\n   363→  });\n   364→\n   365→  // --- Event Subscriptions ---\n   366→  resourceRoutes.set(resourceKey('POST', 'subscriptions', false), {\n   367→    needsDb: true,\n   368→    handler: async (req, res, ctx, _route, _qs, tenantDb) => {\n   369→      const body = JSON.parse(await readBody(req));\n   370→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   371→      const missing: string[] = [];\n   372→      if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   373→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   374→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   375→      const sub = db.createSubscription(tenantDb!, body);\n   376→      try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: sub.id, detail: { personaId: body.personaId, eventType: body.eventType } }); } catch { /* logged inside record() */ }\n   377→      json(res, 201, sub);\n   378→    },\n   379→  });\n   380→\n   381→  resourceRoutes.set(resourceKey('PUT', 'subscriptions', true), {\n   382→    needsDb: true,\n   383→    handler: async (req, res, ctx, route, _qs, tenantDb) => {\n   384→      const body = JSON.parse(await readBody(req));\n   385→      db.updateSubscription(tenantDb!, route!.id!, body);\n   386→      const updated = db.getSubscription(tenantDb!, route!.id!);\n   387→      try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: route!.id! }); } catch { /* logged inside record() */ }\n   388→      json(res, 200, updated);\n   389→    },\n   390→  });\n   391→\n   392→  resourceRoutes.set(resourceKey('DELETE', 'subscriptions', true), {\n   393→    needsDb: true,\n   394→    handler: (_req, res, ctx, route, _qs, tenantDb) => {\n   395→      db.deleteSubscription(tenantDb!, route!.id!);\n   396→      try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', resourceType: 'subscription', resourceId: route!.id! }); } catch { /* logged inside record() */ }\n   397→      json(res, 200, { deleted: true });\n   398→    },\n   399→  });\n   400→\n   401→  // --- Triggers (delegated to triggerHttpHandlers) ---\n   402→  const triggerHandler: RouteHandler = async (req, res, ctx, route, _qs, tenantDb) => {\n   403→    await handleTriggerRoute(route!, req.method!, req, res, tenantDb!, ctx);\n   404→  };\n   405→  resourceRoutes.set(resourceKey('POST', 'triggers', false), { needsDb: true, handler: triggerHandler });\n   406→  resourceRoutes.set(resourceKey('PUT', 'triggers', true), { needsDb: true, handler: triggerHandler });\n   407→  resourceRoutes.set(resourceKey('DELETE', 'triggers', true), { needsDb: true, handler: triggerHandler });\n   408→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'triggers'), { needsDb: true, handler: triggerHandler });\n   409→\n   410→  // --- Events ---\n   411→  resourceRoutes.set(resourceKey('GET', 'events', false), {\n   412→    needsDb: true,\n   413→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   414→      const params = new URLSearchParams(queryString || '');\n   415→      const events = db.listEvents(tenantDb!, {\n   416→        eventType: params.get('eventType') ?? undefined,\n   417→        status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n   418→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   419→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   420→        projectId: scopedProjectId,\n   421→      });\n   422→      json(res, 200, events);\n   423→    },\n   424→  });\n   425→\n   426→  resourceRoutes.set(resourceKey('POST', 'events', false), {\n   427→    needsDb: true,\n   428→    handler: async (req, res, ctx, _route, _qs, tenantDb) => {\n   429→      const body = JSON.parse(await readBody(req));\n   430→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   431→      const missing: string[] = [];\n   432→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   433→      if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   434→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   435→      const event = db.publishEvent(tenantDb!, body);\n   436→      onEventPublished?.();\n   437→      json(res, 201, event);\n   438→    },\n   439→  });\n   440→\n   441→  resourceRoutes.set(resourceKey('PUT', 'events', true), {\n   442→    needsDb: true,\n   443→    handler: async (req, res, _ctx, route, _qs, tenantDb) => {\n   444→      const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n   445→      const updated = db.updateEventWithMetadata(tenantDb!, route!.id!, body.status, body.metadata);\n   446→      if (updated) {\n   447→        json(res, 200, updated);\n   448→      } else {\n   449→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   450→        res.end(JSON.stringify({ error: 'Event not found' }));\n   451→      }\n   452→    },\n   453→  });\n   454→\n   455→  // --- Webhooks ---\n   456→  resourceRoutes.set(resourceKey('POST', 'webhooks', true), {\n   457→    needsDb: true,\n   458→    handler: async (req, res, _ctx, route, _qs, tenantDb) => {\n   459→      const personaId = route!.id!;\n   460→      const body = await readBody(req);\n   461→      const event = db.publishEvent(tenantDb!, {\n   462→        eventType: 'webhook_received',\n   463→        sourceType: 'webhook',\n   464→        sourceId: personaId,\n   465→        targetPersonaId: personaId,\n   466→        payload: body,\n   467→      });\n   468→      onEventPublished?.();\n   469→      json(res, 201, event);\n   470→    },\n   471→  });\n   472→\n   473→  // --- Executions ---\n   474→  resourceRoutes.set(resourceKey('GET', 'executions', false), {\n   475→    needsDb: true,\n   476→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   477→      const params = new URLSearchParams(queryString || '');\n   478→      const executions = db.listExecutions(tenantDb!, {\n   479→        personaId: params.get('personaId') ?? undefined,\n   480→        status: params.get('status') ?? undefined,\n   481→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   482→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   483→        projectId: scopedProjectId,\n   484→      });\n   485→      json(res, 200, executions);\n   486→    },\n   487→  });\n   488→\n   489→  resourceRoutes.set(resourceKey('POST', 'executions', true, 'cancel'), {\n   490→    handler: (_req, res, _ctx, route) => {\n   491→      handleCancelExecution(res, dispatcher, route!.id!);\n   492→    },\n   493→  });\n   494→\n   495→  resourceRoutes.set(resourceKey('GET', 'executions', true), {\n   496→    handler: (_req, res, _ctx, route, queryString) => {\n   497→      const params = new URLSearchParams(queryString || '');\n   498→      const offset = parseInt(params.get('offset') || '0', 10);\n   499→      handleGetExecution(res, dispatcher, route!.id!, offset);\n   500→    },\n   501→  });\n   502→\n   503→  // ── Request handler ──\n   504→  const server = http.createServer(async (req, res) => {\n   505→    // Request correlation ID\n   506→    const reqId = nanoid();\n   507→    const reqLogger = logger.child({ reqId });\n   508→    res.setHeader('X-Request-Id', reqId);\n   509→\n   510→    // Security headers\n   511→    res.setHeader('X-Content-Type-Options', 'nosniff');\n   512→\n   513→    // CORS headers\n   514→    const origin = req.headers.origin ?? '';\n   515→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n   516→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n   517→    if (isAdminRoute) {\n   518→      if (origin && origin === allowedOrigin) {\n   519→        res.setHeader('Access-Control-Allow-Origin', origin);\n   520→      }\n   521→    } else {\n   522→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n   523→    }\n   524→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n   525→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n   526→\n   527→    if (req.method === 'OPTIONS') {\n   528→      res.writeHead(204);\n   529→      res.end();\n   530→      return;\n   531→    }\n   532→\n   533→    const url = req.url || '/';\n   534→    const [pathname, queryString] = url.split('?');\n   535→    const route = parseRoute(pathname ?? '');\n   536→\n   537→    // Unauthenticated endpoint\n   538→    if (pathname === '/health' && req.method === 'GET') {\n   539→      await handleHealth(res, pool, dispatcher, oauth, getEventProcessorHealth, database, tenantDbManager, kafka);\n   540→      return;\n   541→    }\n   542→\n   543→    // Auth check\n   544→    const ctx = auth.validateAndExtractContext(req);\n   545→    if (!ctx) {\n   546→      res.writeHead(401, { 'Content-Type': 'application/json' });\n   547→      res.end(JSON.stringify({ error: 'Unauthorized', reqId }));\n   548→      return;\n   549→    }\n   550→\n   551→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n   552→\n   553→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n   554→      if (tenantDbManager && projectId) {\n   555→        return tenantDbManager.getTenantDb(projectId);\n   556→      }\n   557→      return database;\n   558→    };\n   559→    const tenantDb = resolveDatabase(ctx.projectId);\n   560→\n   561→    try {\n   562→      // O(1) exact-path lookup\n   563→      const exactEntry = exactRoutes.get(`${req.method}:${pathname}`);\n   564→      if (exactEntry) {\n   565→        if (exactEntry.adminOnly && requireAdmin(ctx, res)) return;\n   566→        if (exactEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   567→        await exactEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   568→        return;\n   569→      }\n   570→\n   571→      // O(1) resource-route lookup\n   572→      if (route) {\n   573→        const resKey = resourceKey(req.method!, route.resource, !!route.id, route.subResource);\n   574→        const resEntry = resourceRoutes.get(resKey);\n   575→        if (resEntry) {\n   576→          if (resEntry.adminOnly && requireAdmin(ctx, res)) return;\n   577→          if (resEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   578→          await resEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   579→          return;\n   580→        }\n   581→      }\n   582→\n   583→      // No matching route\n   584→      json(res, 404, { error: 'Not found', reqId });\n   585→    } catch (err) {\n   586→      if (err instanceof Error && err.message === 'Payload too large') {\n   587→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   588→        res.end(JSON.stringify({ error: 'Payload too large', reqId }));\n   589→        return;\n   590→      }\n   591→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   592→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   593→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists', reqId }));\n   594→        return;\n   595→      }\n   596→      reqLogger.error({ err, url }, 'HTTP handler error');\n   597→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   598→      res.end(JSON.stringify({ error: 'Internal server error', reqId }));\n   599→    }\n   600→  });\n   601→\n   602→  return server;\n   603→}\n   604→\n   605→/**\n   606→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   607→ * Returns the entity on success, or null after sending a 404 response.\n   608→ */\n   609→function withScopedEntity<T extends { projectId?: string | null }>(\n   610→  entity: T | undefined,\n   611→  scopedProjectId: string | undefined,\n   612→  res: http.ServerResponse,\n   613→): T | null {\n   614→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   615→    json(res, 404, { error: 'Not found' });\n   616→    return null;\n   617→  }\n   618→  return entity;\n   619→}\n   620→\n   621→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   622→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   623→  if (ctx.authType !== 'admin') {\n   624→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   625→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   626→    return true;\n   627→  }\n   628→  return false;\n   629→}\n   630→\n   631→// --- Existing handlers ---\n   632→\n   633→/** Heartbeat age (ms) beyond which a worker is considered stale. */\n   634→const STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n   635→\n   636→async function handleHealth(\n   637→  res: http.ServerResponse,\n   638→  pool: WorkerPool,\n   639→  dispatcher: Dispatcher,\n   640→  oauth: OAuthManager,\n   641→  getEventProcessorHealth?: () => EventProcessorHealth,\n   642→  database?: Database.Database,\n   643→  tenantDbManager?: TenantDbManager,\n   644→  kafka?: KafkaClient,\n   645→): Promise<void> {\n   646→  const issues: string[] = [];\n   647→\n   648→  const counts = pool.getWorkerCount();\n   649→  const workers = pool.getWorkers();\n   650→  const now = Date.now();\n   651→  const staleWorkers = workers\n   652→    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n   653→    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n   654→\n   655→  if (staleWorkers.length > 0) {\n   656→    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n   657→  }\n   658→\n   659→  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n   660→  if (database) {\n   661→    try {\n   662→      database.prepare('SELECT 1').get();\n   663→      dbHealth.status = 'ok';\n   664→    } catch {\n   665→      dbHealth.status = 'error';\n   666→      issues.push('database unreachable');\n   667→    }\n   668→  }\n   669→  if (tenantDbManager) {\n   670→    try {\n   671→      const tenantIds = tenantDbManager.listTenantIds();\n   672→      dbHealth.tenantCount = tenantIds.length;\n   673→      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n   674→    } catch {\n   675→      dbHealth.tenantCount = -1;\n   676→      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n   677→      issues.push('tenant DB listing failed');\n   678→    }\n   679→  }\n   680→\n   681→  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n   682→  if (kafka) {\n   683→    const kh = await kafka.checkHealth();\n   684→    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n   685→    if (kh.status === 'error') {\n   686→      issues.push(`kafka: ${kh.detail || 'error'}`);\n   687→    }\n   688→  }\n   689→\n   690→  const queueDepth = dispatcher.getQueueLength();\n   691→  const activeExecutions = dispatcher.getActiveExecutions().length;\n   692→\n   693→  let eventProcessorHealth: EventProcessorHealth | undefined;\n   694→  if (getEventProcessorHealth) {\n   695→    eventProcessorHealth = getEventProcessorHealth();\n   696→  }\n   697→\n   698→  let verdict: 'healthy' | 'degraded' | 'unhealthy';\n   699→  if (issues.some(i => i.includes('database unreachable') || i.includes('kafka: '))) {\n   700→    verdict = 'unhealthy';\n   701→  } else if (issues.length > 0) {\n   702→    verdict = 'degraded';\n   703→  } else {\n   704→    verdict = 'healthy';\n   705→  }\n   706→\n   707→  const body: Record<string, unknown> = {\n   708→    status: verdict,\n   709→    timestamp: Date.now(),\n   710→    dependencies: {\n   711→      database: dbHealth,\n   712→      kafka: kafkaHealth,\n   713→      workers: {\n   714→        ...counts,\n   715→        staleWorkers: staleWorkers.length > 0 ? staleWorkers : undefined,\n   716→      },\n   717→    },\n   718→    queue: {\n   719→      depth: queueDepth,\n   720→      activeExecutions,\n   721→    },\n   722→    hasSubscription: oauth.hasTokens(),\n   723→  };\n   724→\n   725→  if (eventProcessorHealth) {\n   726→    (body.dependencies as Record<string, unknown>).eventProcessor = eventProcessorHealth;\n   727→  }\n   728→\n   729→  if (issues.length > 0) {\n   730→    body.issues = issues;\n   731→  }\n   732→\n   733→  const httpStatus = verdict === 'unhealthy' ? 503 : 200;\n   734→  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n   735→  res.end(JSON.stringify(body));\n   736→}\n   737→\n   738→function handleStatus(\n   739→  res: http.ServerResponse,\n   740→  pool: WorkerPool,\n   741→  dispatcher: Dispatcher,\n   742→  tokenManager: TokenManager,\n   743→  oauth: OAuthManager,\n   744→): void {\n   745→  const oauthTokens = oauth.getTokens();\n   746→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   747→  res.end(JSON.stringify({\n   748→    workers: pool.getWorkers(),\n   749→    workerCounts: pool.getWorkerCount(),\n   750→    workerPoolMetrics: pool.getMetrics(),\n   751→    queueLength: dispatcher.getQueueLength(),\n   752→    activeExecutions: dispatcher.getActiveExecutions(),\n   753→    hasClaudeToken: tokenManager.hasToken(),\n   754→    oauth: {\n   755→      connected: oauth.hasTokens(),\n   756→      scopes: oauthTokens?.scopes || [],\n   757→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   758→    },\n   759→  }));\n   760→}\n   761→\n   762→async function handleExecute(\n   763→  req: http.IncomingMessage,\n   764→  res: http.ServerResponse,\n   765→  dispatcher: Dispatcher,\n   766→  logger: Logger,\n   767→  ctx?: RequestContext,\n   768→): Promise<void> {\n   769→  const body = await readBody(req);\n   770→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   771→\n   772→  try {\n   773→    parsed = JSON.parse(body);\n   774→  } catch {\n   775→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   776→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   777→    return;\n   778→  }\n   779→\n   780→  if (!parsed.prompt) {\n   781→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   782→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   783→    return;\n   784→  }\n   785→\n   786→  const request: ExecRequest = {\n   787→    executionId: nanoid(),\n   788→    personaId: parsed.personaId || 'manual',\n   789→    prompt: parsed.prompt,\n   790→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   791→    config: {\n   792→      timeoutMs: parsed.timeoutMs || 300_000,\n   793→    },\n   794→  };\n   795→\n   796→  dispatcher.submit(request);\n   797→\n   798→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   799→\n   800→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   801→  res.end(JSON.stringify({\n   802→    executionId: request.executionId,\n   803→    status: 'queued',\n   804→  }));\n   805→}\n   806→\n   807→function handleGetExecution(\n   808→  res: http.ServerResponse,\n   809→  dispatcher: Dispatcher,\n   810→  executionId: string,\n   811→  offset: number = 0,\n   812→): void {\n   813→  const exec = dispatcher.getExecution(executionId);\n   814→\n   815→  if (!exec) {\n   816→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   817→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   818→    return;\n   819→  }\n   820→\n   821→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   822→\n   823→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   824→  res.end(JSON.stringify({\n   825→    executionId,\n   826→    status: exec.status,\n   827→    outputLines: exec.output.length,\n   828→    output,\n   829→    durationMs: exec.durationMs,\n   830→    sessionId: exec.sessionId,\n   831→    totalCostUsd: exec.totalCostUsd,\n   832→    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n   833→  }));\n   834→}\n   835→\n   836→function handleCancelExecution(\n   837→  res: http.ServerResponse,\n   838→  dispatcher: Dispatcher,\n   839→  executionId: string,\n   840→): void {\n   841→  const cancelled = dispatcher.cancelExecution(executionId);\n   842→\n   843→  if (!cancelled) {\n   844→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   845→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   846→    return;\n   847→  }\n   848→\n   849→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   850→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   851→}\n   852→\n   853→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB\n   854→const MAX_QUERY_LIMIT = 500;\n   855→const MAX_QUERY_OFFSET = 100_000;\n   856→\n   857→/** Parse an integer query param and clamp it to safe bounds. */\n   858→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   859→  if (!value) return defaultValue;\n   860→  const parsed = parseInt(value, 10);\n   861→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   862→  return Math.min(parsed, max);\n   863→}\n   864→"}]},"parent_tool_use_id":null,"session_id":"948d9045-ea93-46a7-8122-690f7d81d624","uuid":"67e2f792-34e6-4f4e-a371-ae8df91edbb4","timestamp":"2026-03-18T17:58:14.213Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog, AuditAction } from './auditLog.js';\nimport type { EventProcessorHealth } from './eventProcessor.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\n// --- Route types ---\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\ntype RouteHandler = (\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  ctx: RequestContext,\n  route: ParsedRoute | null,\n  queryString: string | undefined,\n  tenantDb: Database.Database | undefined,\n  scopedProjectId: string | undefined,\n  reqLogger: Logger,\n) => Promise<void> | void;\n\ninterface RouteEntry {\n  handler: RouteHandler;\n  needsDb?: boolean;\n  adminOnly?: boolean;\n}\n\n/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\nfunction resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  kafka?: KafkaClient,\n  onEventPublished?: () => void,\n): http.Server {\n\n  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n  const exactRoutes = new Map<string, RouteEntry>();\n\n  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n  for (const [path, method] of [\n    ['/api/oauth/authorize', 'POST'],\n    ['/api/oauth/callback', 'POST'],\n    ['/api/oauth/status', 'GET'],\n    ['/api/oauth/refresh', 'POST'],\n    ['/api/oauth/disconnect', 'DELETE'],\n    ['/api/token', 'POST'],\n  ] as const) {\n    exactRoutes.set(`${method}:${path}`, {\n      adminOnly: true,\n      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger);\n      },\n    });\n  }\n\n  exactRoutes.set('GET:/api/status', {\n    handler: (_req, res) => {\n      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n    },\n  });\n\n  exactRoutes.set('POST:/api/execute', {\n    handler: async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n    },\n  });\n\n  exactRoutes.set('POST:/api/gitlab/webhook', {\n    needsDb: true,\n    handler: async (req, res, _ctx, _route, _qs, tenantDb) => {\n      const body = await readBody(req);\n      let parsed: Record<string, unknown> = {};\n      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n      const event = db.publishEvent(tenantDb!, {\n        eventType: `gitlab_${objectKind}`,\n        sourceType: 'gitlab',\n        sourceId: projectPath ?? null,\n        payload: body,\n      });\n      onEventPublished?.();\n      json(res, 201, event);\n    },\n  });\n\n  // Admin routes\n  exactRoutes.set('GET:/api/admin/users', {\n    adminOnly: true,\n    handler: (_req, res) => {\n      if (tenantDbManager) {\n        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n      } else if (database) {\n        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n      } else {\n        json(res, 200, { projectIds: [] });\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/personas', {\n    adminOnly: true,\n    handler: (_req, res) => {\n      if (tenantDbManager) {\n        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n        json(res, 200, allPersonas);\n      } else if (database) {\n        json(res, 200, db.listPersonasSummary(database));\n      } else {\n        json(res, 200, []);\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/executions', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      const params = new URLSearchParams(queryString || '');\n      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n      if (tenantDbManager) {\n        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n        tenantDbManager.forEachTenant((tDb) => {\n          allExecs.push(...db.listExecutions(tDb, { limit }));\n        });\n        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n        json(res, 200, allExecs.slice(0, limit));\n      } else if (database) {\n        json(res, 200, db.listExecutions(database, {\n          limit,\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        }));\n      } else {\n        json(res, 200, []);\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/audit', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      if (!auditLog) { json(res, 200, []); return; }\n      const params = new URLSearchParams(queryString || '');\n      json(res, 200, auditLog.query({\n        tenantId: params.get('tenantId') ?? undefined,\n        action: (params.get('action') ?? undefined) as AuditAction | undefined,\n        since: params.get('since') ?? undefined,\n        limit: 