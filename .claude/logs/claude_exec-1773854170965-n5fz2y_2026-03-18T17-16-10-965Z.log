apsedMs };\n}\n\n/**\n * Async variant of deriveTenantKey — offloads PBKDF2 to libuv thread pool.\n * Returns timing info alongside the key so callers can log PBKDF2 slowdowns.\n */\nexport async function deriveTenantKeyAsync(masterSecret: string, tenantId: string): Promise<KeyDerivationResult> {\n  const start = performance.now();\n  const key = await pbkdf2(masterSecret, `dac-tenant-v1:${tenantId}`, PBKDF2_ITERATIONS, KEY_LENGTH, 'sha256');\n  const elapsedMs = performance.now() - start;\n  if (elapsedMs >= PBKDF2_SLOW_THRESHOLD_MS) {\n    process.emitWarning(\n      `PBKDF2 deriveTenantKeyAsync took ${Math.round(elapsedMs)}ms for tenant=${tenantId} (threshold=${PBKDF2_SLOW_THRESHOLD_MS}ms)`,\n      'PerformanceWarning',\n    );\n  }\n  return { key, elapsedMs };\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":270,"cache_read_input_tokens":45064,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":270},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"abb2edfa-6fdd-45ae-860f-b3674aede5b3","uuid":"9aafcc17-3401-4a9f-8565-f336ef04aedf"}
