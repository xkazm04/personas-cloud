[2026-03-18T17:16:34.080Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LLrRoGDNZJSBEaGK8FGo8g","type":"tool_result","content":"     1→#!/usr/bin/env node\n     2→/**\n     3→ * Rotate the master encryption key: re-encrypt all tenant credentials.\n     4→ *\n     5→ * Usage:\n     6→ *   MASTER_KEY=old_key NEW_MASTER_KEY=new_key npx tsx packages/orchestrator/src/cli/rotate-key.ts [dataDir]\n     7→ *\n     8→ * What it does:\n     9→ *   1. Derives old per-tenant keys from MASTER_KEY\n    10→ *   2. Derives new per-tenant keys from NEW_MASTER_KEY\n    11→ *   3. For each tenant DB, decrypts all credentials with old key, re-encrypts with new key\n    12→ *   4. Updates the encrypted_data/iv/tag in place\n    13→ *\n    14→ * After running, update MASTER_KEY in your environment to NEW_MASTER_KEY.\n    15→ */\n    16→import path from 'node:path';\n    17→import pino from 'pino';\n    18→import { deriveTenantKeyAsync, decrypt, encrypt, toEncryptedPayload } from '@dac-cloud/shared';\n    19→import { TenantDbManager } from '../tenantDbManager.js';\n    20→\n    21→const logger = pino({ level: 'info' });\n    22→\n    23→const oldMasterKey = process.env['MASTER_KEY'];\n    24→const newMasterKey = process.env['NEW_MASTER_KEY'];\n    25→const dataDir = process.argv[2] || path.join(process.cwd(), 'data');\n    26→\n    27→if (!oldMasterKey || !newMasterKey) {\n    28→  console.error('Error: Both MASTER_KEY and NEW_MASTER_KEY environment variables are required.');\n    29→  process.exit(1);\n    30→}\n    31→\n    32→if (oldMasterKey === newMasterKey) {\n    33→  console.error('Error: NEW_MASTER_KEY must differ from MASTER_KEY.');\n    34→  process.exit(1);\n    35→}\n    36→\n    37→async function main() {\n    38→  logger.info({ dataDir }, 'Starting key rotation');\n    39→\n    40→  const mgr = new TenantDbManager(dataDir, logger);\n    41→  const tenantIds = mgr.listTenantIds();\n    42→\n    43→  logger.info({ tenantCount: tenantIds.length }, 'Found tenants');\n    44→\n    45→  let totalRotated = 0;\n    46→  let totalFailed = 0;\n    47→\n    48→  for (const tenantId of tenantIds) {\n    49→    const db = mgr.getTenantDb(tenantId);\n    50→    const oldKey = await deriveTenantKeyAsync(oldMasterKey!, tenantId);\n    51→    const newKey = await deriveTenantKeyAsync(newMasterKey!, tenantId);\n    52→\n    53→    const creds = db.prepare('SELECT id, name, encrypted_data AS encryptedData, iv, tag FROM persona_credentials').all() as Array<{\n    54→      id: string; name: string; encryptedData: string; iv: string; tag: string;\n    55→    }>;\n    56→\n    57→    if (creds.length === 0) continue;\n    58→\n    59→    logger.info({ tenantId, credentialCount: creds.length }, 'Rotating credentials');\n    60→\n    61→    const updateStmt = db.prepare(\n    62→      'UPDATE persona_credentials SET encrypted_data = ?, iv = ?, tag = ?, updated_at = ? WHERE id = ?',\n    63→    );\n    64→\n    65→    const rotateAll = db.transaction(() => {\n    66→      for (const cred of creds) {\n    67→        try {\n    68→          const plaintext = decrypt(toEncryptedPayload(cred), oldKey);\n    69→          const newPayload = encrypt(plaintext, newKey);\n    70→\n    71→          updateStmt.run(\n    72→            newPayload.encrypted,\n    73→            newPayload.iv,\n    74→            newPayload.tag,\n    75→            new Date().toISOString(),\n    76→            cred.id,\n    77→          );\n    78→          totalRotated++;\n    79→        } catch (err) {\n    80→          logger.error({ err, tenantId, credentialId: cred.id, credentialName: cred.name }, 'Failed to rotate credential');\n    81→          totalFailed++;\n    82→        }\n    83→      }\n    84→    });\n    85→\n    86→    rotateAll();\n    87→  }\n    88→\n    89→  console.log('\\n=== Key Rotation Summary ===');\n    90→  console.log(`Tenants processed: ${tenantIds.length}`);\n    91→  console.log(`Credentials rotated: ${totalRotated}`);\n    92→  console.log(`Credentials failed: ${totalFailed}`);\n    93→  if (totalFailed === 0) {\n    94→    console.log('\\nAll credentials rotated successfully.');\n    95→    console.log('Update MASTER_KEY in your environment to the new value.\\n');\n    96→  } else {\n    97→    console.log('\\nSome credentials failed to rotate. Investigate before updating MASTER_KEY.\\n');\n    98→  }\n    99→\n   100→  mgr.close();\n   101→}\n   102→\n   103→main().catch((err) => {\n   104→  logger.fatal({ err }, 'Key rotation failed');\n   105→  process.exit(1);\n   106→});\n   107→"}]},"parent_tool_use_id":null,"session_id":"abb2edfa-6fdd-45ae-860f-b3674aede5b3","uuid":"6cf955f2-ecec-4de7-9209-eb305e43c1ec","timestamp":"2026-03-18T17:16:33.911Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\cli\\rotate-key.ts","content":"#!/usr/bin/env node\n/**\n * Rotate the master encryption key: re-encrypt all tenant credentials.\n *\n * Usage:\n *   MASTER_KEY=old_key NEW_MASTER_KEY=new_key npx tsx packages/orchestrator/src/cli/rotate-key.ts [dataDir]\n *\n * What it does:\n *   1. Derives old per-tenant keys from MASTER_KEY\n *   2. Derives new per-tenant keys from NEW_MASTER_KEY\n *   3. For each tenant DB, decrypts all credentials with old key, re-encrypts with new key\n *   4. Updates the encrypted_data/iv/tag in place\n *\n * After running, update MASTER_KEY in your environment to NEW_MASTER_KEY.\n */\nimport path from 'node:path';\nimport pino from 'pino';\nimport { deriveTenantKeyAsync, decrypt, encrypt, toEncryptedPayload } from '@dac-cloud/shared';\nimport { TenantDbManager } from '../tenantDbManager.js';\n\nconst logger = pino({ level: 'info' });\n\nconst oldMasterKey = process.env['MASTER_KEY'];\nconst newMasterKey = process.env['NEW_MASTER_KEY'];\nconst dataDir = process.argv[2] || path.join(process.cwd(), 'data');\n\nif (!oldMasterKey || !newMasterKey) {\n  console.error('Error: Both MASTER_KEY and NEW_MASTER_KEY environment variables are required.');\n  process.exit(1);\n}\n\nif (oldMasterKey === newMasterKey) {\n  console.error('Error: NEW_MASTER_KEY must differ from MASTER_KEY.');\n  process.exit(1);\n}\n\nasync function main() {\n  logger.info({ dataDir }, 'Starting key rotation');\n\n  const mgr = new TenantDbManager(dataDir, logger);\n  const tenantIds = mgr.listTenantIds();\n\n  logger.info({ tenantCount: tenantIds.length }, 'Found tenants');\n\n  let totalRotated = 0;\n  let totalFailed = 0;\n\n  for (const tenantId of tenantIds) {\n    const db = mgr.getTenantDb(tenantId);\n    const oldKey = await deriveTenantKeyAsync(oldMasterKey!, tenantId);\n    const newKey = await deriveTenantKeyAsync(newMasterKey!, tenantId);\n\n    const creds = db.prepare('SELECT id, name, encrypted_data AS encryptedData, iv, tag FROM persona_credentials').all() as Array<{\n      id: string; name: string; encryptedData: string; iv: string; tag: string;\n    }>;\n\n    if (creds.length === 0) continue;\n\n    logger.info({ tenantId, credentialCount: creds.length }, 'Rotating credentials');\n\n    const updateStmt = db.prepare(\n      'UPDATE persona_credentials SET encrypted_data = ?, iv = ?, tag = ?, updated_at = ? WHERE id = ?',\n    );\n\n    const rotateAll = db.transaction(() => {\n      for (const cred of creds) {\n        try {\n          const plaintext = decrypt(toEncryptedPayload(cred), oldKey);\n          const newPayload = encrypt(plaintext, newKey);\n\n          updateStmt.run(\n            newPayload.encrypted,\n            newPayload.iv,\n            newPayload.tag,\n            new Date().toISOString(),\n            cred.id,\n          );\n          totalRotated++;\n        } catch (err) {\n          logger.error({ err, tenantId, credentialId: cred.id, credentialName: cred.name }, 'Failed to rotate credential');\n          totalFailed++;\n        }\n      }\n    });\n\n    rotateAll();\n  }\n\n  console.log('\\n=== Key Rotation Summary ===');\n  console.log(`Tenants processed: ${tenantIds.length}`);\n  console.log(`Credentials rotated: ${totalRotated}`);\n  console.log(`Credentials failed: ${totalFailed}`);\n  if (totalFailed === 0) {\n    console.log('\\nAll credentials rotated successfully.');\n    console.log('Update MASTER_KEY in your environment to the new value.\\n');\n  } else {\n    console.log('\\nSome credentials failed to rotate. Investigate before updating MASTER_KEY.\\n');\n  }\n\n  mgr.close();\n}\n\nmain().catch((err) => {\n  logger.fatal({ err }, 'Key rotation failed');\n  process.exit(1);\n});\n","numLines":107,"startLine":1,"totalLines":107}}}
