[2026-03-18T17:16:32.526Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HP5dNRbVn5P7eQ4UJzL683","type":"tool_result","content":"     1→// ---------------------------------------------------------------------------\n     2→// Dispatch pipeline — composable stages for worker dispatch\n     3→//\n     4→// Each stage is a standalone async function with typed inputs/outputs,\n     5→// independently testable without mocking the entire Dispatcher.\n     6→//\n     7→// Pipeline: ResolveToken → ResolvePersona → AssemblePayload → BuildAssignment\n     8→// ---------------------------------------------------------------------------\n     9→\n    10→import type { ExecAssign, ExecRequest, InferenceProfile, NetworkPolicy, Persona, PersonaCredential, PersonaToolDefinition, EncryptedPayload } from '@dac-cloud/shared';\n    11→import { assemblePrompt, resolveEnvOverrides, toEncryptedPayload, parseNetworkPolicy } from '@dac-cloud/shared';\n    12→import type Database from 'better-sqlite3';\n    13→import type { TokenManager } from './tokenManager.js';\n    14→import type { OAuthManager } from './oauth.js';\n    15→import type { TenantKeyManager } from './tenantKeyManager.js';\n    16→import type { AuditLog } from './auditLog.js';\n    17→import type { Logger } from 'pino';\n    18→import * as db from './db/index.js';\n    19→\n    20→// ========================== Stage result types =============================\n    21→\n    22→export interface TokenResult {\n    23→  claudeToken: string;\n    24→}\n    25→\n    26→export interface PersonaResolution {\n    27→  persona: Persona | null;\n    28→  tools: PersonaToolDefinition[];\n    29→  credentialHints: string[];\n    30→  credentialEnv: Record<string, string>;\n    31→  inferenceEnvSet: Record<string, string>;\n    32→  inferenceEnvRemove: string[];\n    33→}\n    34→\n    35→export interface AssembledPayload {\n    36→  prompt: string;\n    37→  env: Record<string, string>;\n    38→  networkPolicy: NetworkPolicy | undefined;\n    39→  maxBudgetUsd: number | null;\n    40→  maxTurns: number | null;\n    41→}\n    42→\n    43→// ========================= Dependency interfaces ===========================\n    44→\n    45→/** Minimal decryption capability — abstracts master/tenant key resolution. */\n    46→export interface Decryptor {\n    47→  decrypt(\n    48→    payload: EncryptedPayload,\n    49→    tenantId: string,\n    50→    resourceId: string,\n    51→    logContext: Record<string, unknown>,\n    52→    logMessage: string,\n    53→  ): Promise<string | undefined>;\n    54→}\n    55→\n    56→// =========================== Stage 1: Token ================================\n    57→\n    58→export async function resolveToken(\n    59→  oauth: OAuthManager | null,\n    60→  tokenManager: TokenManager,\n    61→): Promise<TokenResult | null> {\n    62→  let claudeToken: string | null = null;\n    63→\n    64→  if (oauth?.hasTokens()) {\n    65→    claudeToken = await oauth.getValidAccessToken();\n    66→    if (claudeToken) {\n    67→      tokenManager.storeClaudeToken(claudeToken);\n    68→    }\n    69→  }\n    70→\n    71→  if (!claudeToken) {\n    72→    claudeToken = tokenManager.getClaudeToken();\n    73→  }\n    74→\n    75→  return claudeToken ? { claudeToken } : null;\n    76→}\n    77→\n    78→// ========================== Stage 2: Persona ===============================\n    79→\n    80→export async function resolvePersona(\n    81→  dispatchDb: Database.Database | null,\n    82→  personaId: string,\n    83→  tenantId: string,\n    84→  decryptor: Decryptor,\n    85→  logger: Logger,\n    86→): Promise<PersonaResolution> {\n    87→  const empty: PersonaResolution = {\n    88→    persona: null,\n    89→    tools: [],\n    90→    credentialHints: [],\n    91→    credentialEnv: {},\n    92→    inferenceEnvSet: {},\n    93→    inferenceEnvRemove: [],\n    94→  };\n    95→\n    96→  if (!dispatchDb) return empty;\n    97→\n    98→  const persona = db.getPersona(dispatchDb, personaId);\n    99→  if (!persona) return empty;\n   100→\n   101→  const tools = db.getToolsForPersona(dispatchDb, persona.id);\n   102→  const creds = db.listCredentialsForPersona(dispatchDb, persona.id);\n   103→\n   104→  // Decrypt credentials\n   105→  const credentialHints: string[] = [];\n   106→  const credentialEnv: Record<string, string> = {};\n   107→\n   108→  for (const cred of creds) {\n   109→    const envName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   110→    credentialHints.push(envName);\n   111→\n   112→    const decrypted = await decryptor.decrypt(\n   113→      toEncryptedPayload(cred),\n   114→      tenantId,\n   115→      cred.id,\n   116→      { credentialId: cred.id, credentialName: cred.name },\n   117→      'Failed to decrypt credential',\n   118→    );\n   119→\n   120→    if (decrypted !== undefined) {\n   121→      try {\n   122→        const fields = JSON.parse(decrypted) as Record<string, string>;\n   123→        for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n   124→          const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   125→          credentialEnv[fieldEnvName] = String(fieldValue);\n   126→        }\n   127→      } catch {\n   128→        credentialEnv[envName] = decrypted;\n   129→      }\n   130→    }\n   131→  }\n   132→\n   133→  // Resolve inference profile env overrides\n   134→  let inferenceEnvSet: Record<string, string> = {};\n   135→  let inferenceEnvRemove: string[] = [];\n   136→\n   137→  if (persona.inferenceProfileId) {\n   138→    const inferenceProfile = db.getInferenceProfile(dispatchDb, persona.inferenceProfileId);\n   139→    if (inferenceProfile) {\n   140→      let decryptedAuthToken: string | undefined;\n   141→      if (inferenceProfile.authTokenEncrypted && inferenceProfile.authTokenIv && inferenceProfile.authTokenTag) {\n   142→        