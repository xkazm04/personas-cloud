[2026-03-18T17:16:21.583Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AfMUgY4SKWTRR38m5oMptY","type":"tool_result","content":"     1→import crypto from 'node:crypto';\n     2→import { promisify } from 'node:util';\n     3→\n     4→const pbkdf2 = promisify(crypto.pbkdf2);\n     5→\n     6→const ALGORITHM = 'aes-256-gcm';\n     7→const IV_LENGTH = 16;\n     8→const AUTH_TAG_LENGTH = 16;\n     9→const KEY_LENGTH = 32;\n    10→const PBKDF2_ITERATIONS = 100_000;\n    11→const SALT = 'dac-cloud-credentials-v1';\n    12→\n    13→export interface EncryptedPayload {\n    14→  encrypted: string; // hex\n    15→  iv: string;        // hex\n    16→  tag: string;       // hex (GCM auth tag)\n    17→}\n    18→\n    19→/**\n    20→ * Derive the master encryption key from a secret using PBKDF2.\n    21→ * Uses the libuv thread pool so the event loop stays responsive.\n    22→ */\n    23→export function deriveMasterKeyAsync(secret: string): Promise<Buffer> {\n    24→  return pbkdf2(secret, SALT, PBKDF2_ITERATIONS, KEY_LENGTH, 'sha256');\n    25→}\n    26→\n    27→export function encrypt(plaintext: string, masterKey: Buffer): EncryptedPayload {\n    28→  const iv = crypto.randomBytes(IV_LENGTH);\n    29→  const cipher = crypto.createCipheriv(ALGORITHM, masterKey, iv, {\n    30→    authTagLength: AUTH_TAG_LENGTH,\n    31→  });\n    32→\n    33→  let encrypted = cipher.update(plaintext, 'utf8', 'hex');\n    34→  encrypted += cipher.final('hex');\n    35→  const tag = cipher.getAuthTag().toString('hex');\n    36→\n    37→  return {\n    38→    encrypted,\n    39→    iv: iv.toString('hex'),\n    40→    tag,\n    41→  };\n    42→}\n    43→\n    44→/**\n    45→ * Thrown when AES-GCM decryption fails (bad key, tampered ciphertext, or corrupted data).\n    46→ * Carries identity context so callers can produce diagnostic logs and audit events.\n    47→ */\n    48→export class DecryptionError extends Error {\n    49→  constructor(\n    50→    public readonly cause: unknown,\n    51→    public readonly context: { credentialId?: string; tenantId?: string; resourceType?: string },\n    52→  ) {\n    53→    const parts: string[] = ['AES-GCM decryption failed'];\n    54→    if (context.tenantId) parts.push(`tenant=${context.tenantId}`);\n    55→    if (context.credentialId) parts.push(`credential=${context.credentialId}`);\n    56→    if (context.resourceType) parts.push(`resource=${context.resourceType}`);\n    57→    super(parts.join(' '));\n    58→    this.name = 'DecryptionError';\n    59→  }\n    60→}\n    61→\n    62→/**\n    63→ * Convert a credential row (encryptedData/iv/tag) to the EncryptedPayload shape\n    64→ * expected by decrypt(). Bridges the DB column naming and the crypto interface.\n    65→ */\n    66→export function toEncryptedPayload(cred: { encryptedData: string; iv: string; tag: string }): EncryptedPayload {\n    67→  return { encrypted: cred.encryptedData, iv: cred.iv, tag: cred.tag };\n    68→}\n    69→\n    70→export function decrypt(payload: EncryptedPayload, masterKey: Buffer): string {\n    71→  const iv = Buffer.from(payload.iv, 'hex');\n    72→  const tag = Buffer.from(payload.tag, 'hex');\n    73→  const decipher = crypto.createDecipheriv(ALGORITHM, masterKey, iv, {\n    74→    authTagLength: AUTH_TAG_LENGTH,\n    75→  });\n    76→  decipher.setAuthTag(tag);\n    77→\n    78→  let decrypted = decipher.update(payload.encrypted, 'hex', 'utf8');\n    79→  decrypted += decipher.final('utf8');\n    80→  return decrypted;\n    81→}\n    82→\n    83→/**\n    84→ * Derive a per-tenant encryption key from the master secret.\n    85→ * Uses a tenant-specific salt to ensure each tenant gets a unique key.\n    86→ */\n    87→export function deriveTenantKey(masterSecret: string, tenantId: string): Buffer {\n    88→  return crypto.pbkdf2Sync(\n    89→    masterSecret,\n    90→    `dac-tenant-v1:${tenantId}`,\n    91→    PBKDF2_ITERATIONS,\n    92→    KEY_LENGTH,\n    93→    'sha256',\n    94→  );\n    95→}\n    96→\n    97→/**\n    98→ * Async variant of deriveTenantKey — offloads PBKDF2 to libuv thread pool.\n    99→ */\n   100→export function deriveTenantKeyAsync(masterSecret: string, tenantId: string): Promise<Buffer> {\n   101→  return pbkdf2(masterSecret, `dac-tenant-v1:${tenantId}`, PBKDF2_ITERATIONS, KEY_LENGTH, 'sha256');\n   102→}\n   103→\n   104→export function generateApiKey(): string {\n   105→  return `dac_${crypto.randomBytes(24).toString('hex')}`;\n   106→}\n   107→\n   108→export function hashApiKey(key: string): string {\n   109→  return crypto.createHash('sha256').update(key).digest('hex');\n   110→}\n   111→"}]},"parent_tool_use_id":null,"session_id":"abb2edfa-6fdd-45ae-860f-b3674aede5b3","uuid":"d4cb9008-6dcd-44cb-af20-637f94c4c759","timestamp":"2026-03-18T17:16:21.321Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\shared\\src\\crypto.ts","content":"import crypto from 'node:crypto';\nimport { promisify } from 'node:util';\n\nconst pbkdf2 = promisify(crypto.pbkdf2);\n\nconst ALGORITHM = 'aes-256-gcm';\nconst IV_LENGTH = 16;\nconst AUTH_TAG_LENGTH = 16;\nconst KEY_LENGTH = 32;\nconst PBKDF2_ITERATIONS = 100_000;\nconst SALT = 'dac-cloud-credentials-v1';\n\nexport interface EncryptedPayload {\n  encrypted: string; // hex\n  iv: string;        // hex\n  tag: string;       // hex (GCM auth tag)\n}\n\n/**\n * Derive the master encryption key from a secret using PBKDF2.\n * Uses the libuv thread pool so the event loop stays responsive.\n */\nexport function deriveMasterKeyAsync(secret: string): Promise<Buffer> {\n  return pbkdf2(secret, SALT, PBKDF2_ITERATIONS, KEY_LENGTH, 'sha256');\n}\n\nexport function encrypt(plaintext: string, masterKey: Buffer): EncryptedPayload {\n  const iv = crypto.randomBytes(IV_LENGTH);\n  const cipher = crypto.createCipheriv(ALGORITHM, masterKey, iv, {\n    authTagLength: AUTH_TAG_LENGTH,\n  });\n\n  let encrypted = cipher.update(plaintext, 'utf8', 'hex');\n  encrypted += cipher.final('hex');\n  const tag = cipher.getAuthTag().toString('hex');\n\n  return {\n    encrypted,\n    iv: iv.toString('hex'),\n    tag,\n  };\n}\n\n/**\n * Thrown when AES-GCM decryption fails (bad key, tampered ciphertext, or corrupted data).\n * Carries identity context so callers can produce diagnostic logs and audit events.\n */\nexport class DecryptionError extends Error {\n  constructor(\n    public readonly cause: unknown,\n    public readonly context: { credentialId?: string; tenantId?: string; resourceType?: string },\n  ) {\n    const parts: string[] = ['AES-GCM decryption failed'];\n    if (context.tenantId) parts.push(`tenant=${context.tenantId}`);\n    if (context.credentialId) parts.push(`credential=${context.credentialId}`);\n    if (context.resourceType) parts.push(`resource=${context.resourceType}`);\n    super(parts.join(' '));\n    this.name = 'DecryptionError';\n  }\n}\n\n/**\n * Convert a credential row (encryptedData/iv/tag) to the EncryptedPayload shape\n * expected by decrypt(). Bridges the DB column naming and the crypto interface.\n */\nexport function toEncryptedPayload(cred: { encryptedData: string; iv: string; tag: string }): EncryptedPayload {\n  return { encrypted: cred.encryptedData, iv: cred.iv, tag: cred.tag };\n}\n\nexport function decrypt(payload: EncryptedPayload, masterKey: Buffer): string {\n  const iv = Buffer.from(payload.iv, 'hex');\n  const tag = Buffer.from(payload.tag, 'hex');\n  const decipher = crypto.createDecipheriv(ALGORITHM, masterKey, iv, {\n    authTagLength: AUTH_TAG_LENGTH,\n  });\n  decipher.setAuthTag(tag);\n\n  let decrypted = decipher.update(payload.encrypted, 'hex', 'utf8');\n  decrypted += decipher.final('utf8');\n  return decrypted;\n}\n\n/**\n * Derive a per-tenant encryption key from the master secret.\n * Uses a tenant-specific salt to ensure each tenant gets a unique key.\n */\nexport function deriveTenantKey(masterSecret: string, tenantId: string): Buffer {\n  return crypto.pbkdf2Sync(\n    masterSecret,\n    `dac-tenant-v1:${tenantId}`,\n    PBKDF2_ITERATIONS,\n    KEY_LENGTH,\n    'sha256',\n  );\n}\n\n/**\n * Async variant of deriveTenantKey — offloads PBKDF2 to libuv thread pool.\n */\nexport function deriveTenantKeyAsync(masterSecret: string, tenantId: string): Promise<Buffer> {\n  return pbkdf2(masterSecret, `dac-tenant-v1:${tenantId}`, PBKDF2_ITERATIONS, KEY_LENGTH, 'sha256');\n}\n\nexport function generateApiKey(): string {\n  return `dac_${crypto.randomBytes(24).toString('hex')}`;\n}\n\nexport function hashApiKey(key: string): string {\n  return crypto.createHash('sha256').update(key).digest('hex');\n}\n","numLines":111,"startLine":1,"totalLines":111}}}
