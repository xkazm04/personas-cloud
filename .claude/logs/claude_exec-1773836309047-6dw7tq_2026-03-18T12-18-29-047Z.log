[2026-03-18T12:18:38.140Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AvuWC2sNSrRLRcpNrEHJVJ","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    11→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    12→import type { TenantDbManager } from './tenantDbManager.js';\n    13→import type { TenantKeyManager } from './tenantKeyManager.js';\n    14→import type { AuditLog } from './auditLog.js';\n    15→import type { Logger } from 'pino';\n    16→import * as db from './db/index.js';\n    17→import { readBody, json } from './httpUtils.js';\n    18→\n    19→export function createHttpApi(\n    20→  auth: Auth,\n    21→  dispatcher: Dispatcher,\n    22→  pool: WorkerPool,\n    23→  tokenManager: TokenManager,\n    24→  oauth: OAuthManager,\n    25→  logger: Logger,\n    26→  database?: Database.Database,\n    27→  tenantDbManager?: TenantDbManager,\n    28→  tenantKeyManager?: TenantKeyManager,\n    29→  auditLog?: AuditLog,\n    30→): http.Server {\n    31→  const server = http.createServer(async (req, res) => {\n    32→    // Security headers\n    33→    res.setHeader('X-Content-Type-Options', 'nosniff');\n    34→\n    35→    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    36→    const origin = req.headers.origin ?? '';\n    37→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    38→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    39→    if (isAdminRoute) {\n    40→      // Admin routes: only allow same-origin requests (no CORS wildcard)\n    41→      if (origin && origin === allowedOrigin) {\n    42→        res.setHeader('Access-Control-Allow-Origin', origin);\n    43→      }\n    44→      // If no match, omit the header entirely — browser blocks the request\n    45→    } else {\n    46→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    47→    }\n    48→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    49→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n    50→\n    51→    if (req.method === 'OPTIONS') {\n    52→      res.writeHead(204);\n    53→      res.end();\n    54→      return;\n    55→    }\n    56→\n    57→    const url = req.url || '/';\n    58→    const [pathname, queryString] = url.split('?');\n    59→    const route = parseRoute(pathname ?? '');\n    60→\n    61→    // Unauthenticated endpoints\n    62→    if (pathname === '/health' && req.method === 'GET') {\n    63→      handleHealth(res, pool, oauth);\n    64→      return;\n    65→    }\n    66→\n    67→    // Auth check for everything else — dual auth (API key + optional JWT)\n    68→    const ctx = auth.validateAndExtractContext(req);\n    69→    if (!ctx) {\n    70→      res.writeHead(401, { 'Content-Type': 'application/json' });\n    71→      res.end(JSON.stringify({ error: 'Unauthorized' }));\n    72→      return;\n    73→    }\n    74→\n    75→    // Helper: project scoping (admin sees all, user sees own project)\n    76→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n    77→\n    78→    // Resolve tenant-specific database when available\n    79→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n    80→      if (tenantDbManager && projectId) {\n    81→        return tenantDbManager.getTenantDb(projectId);\n    82→      }\n    83→      return database;\n    84→    };\n    85→    const tenantDb = resolveDatabase(ctx.projectId);\n    86→\n    87→    try {\n    88→      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n    89→      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n    90→        if (requireAdmin(ctx, res)) return;\n    91→        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n    92→        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n    93→        return;\n    94→      }\n    95→      // --- Persona CRUD ---\n    96→      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n    97→        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n    98→      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n    99→        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   100→        const persona = createPersonaWithDefaults({\n   101→          ...body,\n   102→          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   103→        });\n   104→        db.upsertPersona(tenantDb, persona);\n   105→        json(res, 201, persona);\n   106→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n   107→        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n   108→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n   109→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   110→        if (!persona) return;\n   111→        const body = JSON.parse(await readBody(req)) as { toolId: string };\n   112→        db.linkTool(tenantDb, route.id, body.toolId);\n   113→        json(res, 200, { linked: true });\n   114→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n   115→        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id), scopedProjectId, res);\n   116→        if (!hydrated) return;\n   117→        json(res, 200, hydrated);\n   118→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n   119→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   120→        if (!persona) return;\n   121→        json(res, 200, persona);\n   122→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   123→        db.deletePersona(tenantDb, route.id, scopedProjectId);\n   124→        json(res, 200, { deleted: true });\n   125→      }\n   126→      // --- Tool Definitions ---\n   127→      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n   128→        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   129→        const tool = createToolDefinitionWithDefaults(body);\n   130→        db.upsertToolDefinition(tenantDb, tool);\n   131→        json(res, 201, tool);\n   132→      }\n   133→      // --- Credentials ---\n   134→      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n   135→        const body = JSON.parse(await readBody(req));\n   136→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   137→\n   138→        // Require plaintext — clients must never supply pre-encrypted data\n   139→        if (!body.plaintext || typeof body.plaintext !== 'string') {\n   140→          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   141→          return;\n   142→        }\n   143→\n   144→        // Reject oversized plaintext before synchronous encryption blocks the event loop\n   145→        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   146→          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   147→          return;\n   148→        }\n   149→\n   150→        // Encryption is mandatory — reject if the key manager is unavailable\n   151→        if (!tenantKeyManager) {\n   152→          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   153→          return;\n   154→        }\n   155→\n   156→        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n   157→        delete body.encryptedData;\n   158→        delete body.iv;\n   159→        delete body.tag;\n   160→\n   161→        // Server-side encryption with per-tenant key\n   162→        const tenantId = body.projectId || ctx.projectId || 'default';\n   163→        const key = await tenantKeyManager.getKey(tenantId);\n   164→        const encrypted = encrypt(body.plaintext, key);\n   165→        body.encryptedData = encrypted.encrypted;\n   166→        body.iv = encrypted.iv;\n   167→        body.tag = encrypted.tag;\n   168→        delete body.plaintext;\n   169→\n   170→        const cred = db.createCredential(tenantDb, body);\n   171→        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n   172→        json(res, 201, cred);\n   173→      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   174→        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n   175→        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   176→        json(res, 200, { deleted: true });\n   177→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n   178→        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n   179→        // Strip encrypted data from response\n   180→        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   181→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n   182→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   183→        if (!persona) return;\n   184→        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   185→        db.linkCredential(tenantDb, route.id, body.credentialId);\n   186→        json(res, 200, { linked: true });\n   187→      }\n   188→      // --- Event Subscriptions ---\n   189→      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n   190→        const body = JSON.parse(await readBody(req));\n   191→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   192→        const missing: string[] = [];\n   193→        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   194→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   195→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   196→        const sub = db.createSubscription(tenantDb, body);\n   197→        json(res, 201, sub);\n   198→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   199→        const body = JSON.parse(await readBody(req));\n   200→        db.updateSubscription(tenantDb, route.id, body);\n   201→        const updated = db.getSubscription(tenantDb, route.id);\n   202→        json(res, 200, updated);\n   203→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   204→        db.deleteSubscription(tenantDb, route.id);\n   205→        json(res, 200, { deleted: true });\n   206→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n   207→        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n   208→      }\n   209→      // --- Triggers (delegated to triggerHttpHandlers) ---\n   210→      else if (route && tenantDb && (\n   211→        route.resource === 'triggers' ||\n   212→        (route.resource === 'personas' && route.subResource === 'triggers')\n   213→      )) {\n   214→        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n   215→        return;\n   216→      }\n   217→      // --- Events ---\n   218→      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n   219→        const params = new URLSearchParams(queryString || '');\n   220→        const events = db.listEvents(tenantDb, {\n   221→          eventType: params.get('eventType') ?? undefined,\n   222→          status: params.get('status') ?? undefined,\n   223→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   224→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   225→          projectId: scopedProjectId,\n   226→        });\n   227→        json(res, 200, events);\n   228→      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n   229→        const body = JSON.parse(await readBody(req));\n   230→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   231→        const missing: string[] = [];\n   232→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   233→        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   234→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   235→        const event = db.publishEvent(tenantDb, body);\n   236→        json(res, 201, event);\n   237→      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   238→        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n   239→        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n   240→        if (updated) {\n   241→          json(res, 200, updated);\n   242→        } else {\n   243→          res.writeHead(404, { 'Content-Type': 'application/json' });\n   244→          res.end(JSON.stringify({ error: 'Event not found' }));\n   245→        }\n   246→      }\n   247→      // --- Webhooks ---\n   248→      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n   249→        const personaId = route.id;\n   250→        const body = await readBody(req);\n   251→        const event = db.publishEvent(tenantDb, {\n   252→          eventType: 'webhook_received',\n   253→          sourceType: 'webhook',\n   254→          sourceId: personaId,\n   255→          targetPersonaId: personaId,\n   256→          payload: body,\n   257→        });\n   258→        json(res, 201, event);\n   259→      }\n   260→      // --- GitLab Webhook ---\n   261→      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n   262→        const body = await readBody(req);\n   263→        let parsed: Record<string, unknown> = {};\n   264→        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   265→        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   266→        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   267→        const event = db.publishEvent(tenantDb, {\n   268→          eventType: `gitlab_${objectKind}`,\n   269→          sourceType: 'gitlab',\n   270→          sourceId: projectPath ?? null,\n   271→          payload: body,\n   272→        });\n   273→        json(res, 201, event);\n   274→      }\n   275→      // --- Executions ---\n   276→      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n   277→        const params = new URLSearchParams(queryString || '');\n   278→        const executions = db.listExecutions(tenantDb, {\n   279→          personaId: params.get('personaId') ?? undefined,\n   280→          status: params.get('status') ?? undefined,\n   281→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   282→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   283→          projectId: scopedProjectId,\n   284→        });\n   285→        json(res, 200, executions);\n   286→      }\n   287→      // --- Existing execution endpoints ---\n   288→      else if (pathname === '/api/status' && req.method === 'GET') {\n   289→        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   290→      } else if (pathname === '/api/execute' && req.method === 'POST') {\n   291→        await handleExecute(req, res, dispatcher, logger, ctx);\n   292→      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n   293→        handleCancelExecution(res, dispatcher, route.id);\n   294→      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n   295→        const executionId = route.id;\n   296→        const params = new URLSearchParams(queryString || '');\n   297→        const offset = parseInt(params.get('offset') || '0', 10);\n   298→        handleGetExecution(res, dispatcher, executionId, offset);\n   299→      }\n   300→      // --- Admin-only routes ---\n   301→      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n   302→        if (requireAdmin(ctx, res)) return;\n   303→        if (tenantDbManager) {\n   304→          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   305→        } else if (database) {\n   306→          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   307→        } else {\n   308→          json(res, 200, { projectIds: [] });\n   309→        }\n   310→      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n   311→        if (requireAdmin(ctx, res)) return;\n   312→        if (tenantDbManager) {\n   313→          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   314→          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   315→          json(res, 200, allPersonas);\n   316→        } else if (database) {\n   317→          json(res, 200, db.listPersonasSummary(database));\n   318→        } else {\n   319→          json(res, 200, []);\n   320→        }\n   321→      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n   322→        if (requireAdmin(ctx, res)) return;\n   323→        const params = new URLSearchParams(queryString || '');\n   324→        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   325→        if (tenantDbManager) {\n   326→          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   327→          tenantDbManager.forEachTenant((tDb) => {\n   328→            allExecs.push(...db.listExecutions(tDb, { limit }));\n   329→          });\n   330→          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   331→          json(res, 200, allExecs.slice(0, limit));\n   332→        } else if (database) {\n   333→          json(res, 200, db.listExecutions(database, {\n   334→            limit,\n   335→            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   336→          }));\n   337→        } else {\n   338→          json(res, 200, []);\n   339→        }\n   340→      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n   341→        if (requireAdmin(ctx, res)) return;\n   342→        if (!auditLog) { json(res, 200, []); return; }\n   343→        const params = new URLSearchParams(queryString || '');\n   344→        json(res, 200, auditLog.query({\n   345→          tenantId: params.get('tenantId') ?? undefined,\n   346→          action: params.get('action') ?? undefined,\n   347→          since: params.get('since') ?? undefined,\n   348→          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   349→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   350→        }));\n   351→      } else {\n   352→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   353→        res.end(JSON.stringify({ error: 'Not found' }));\n   354→      }\n   355→    } catch (err) {\n   356→      if (err instanceof Error && err.message === 'Payload too large') {\n   357→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   358→        res.end(JSON.stringify({ error: 'Payload too large' }));\n   359→        return;\n   360→      }\n   361→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   362→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   363→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n   364→        return;\n   365→      }\n   366→      logger.error({ err, url }, 'HTTP handler error');\n   367→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   368→      res.end(JSON.stringify({ error: 'Internal server error' }));\n   369→    }\n   370→  });\n   371→\n   372→  return server;\n   373→}\n   374→\n   375→interface ParsedRoute {\n   376→  resource: string;\n   377→  id?: string;\n   378→  subResource?: string;\n   379→}\n   380→\n   381→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n   382→function parseRoute(pathname: string): ParsedRoute | null {\n   383→  if (!pathname.startsWith('/api/')) return null;\n   384→  const segments = pathname.slice(5).split('/').filter(Boolean);\n   385→  if (segments.length === 0) return null;\n   386→  return {\n   387→    resource: segments[0]!,\n   388→    id: segments[1],\n   389→    subResource: segments[2],\n   390→  };\n   391→}\n   392→\n   393→/**\n   394→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   395→ * Returns the entity on success, or null after sending a 404 response.\n   396→ */\n   397→function withScopedEntity<T extends { projectId?: string | null }>(\n   398→  entity: T | undefined,\n   399→  scopedProjectId: string | undefined,\n   400→  res: http.ServerResponse,\n   401→): T | null {\n   402→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   403→    json(res, 404, { error: 'Not found' });\n   404→    return null;\n   405→  }\n   406→  return entity;\n   407→}\n   408→\n   409→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   410→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   411→  if (ctx.authType !== 'admin') {\n   412→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   413→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   414→    return true;\n   415→  }\n   416→  return false;\n   417→}\n   418→\n   419→// --- Existing handlers ---\n   420→\n   421→function handleHealth(res: http.ServerResponse, pool: WorkerPool, oauth: OAuthManager): void {\n   422→  const counts = pool.getWorkerCount();\n   423→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   424→  res.end(JSON.stringify({\n   425→    status: 'ok',\n   426→    workers: counts,\n   427→    hasSubscription: oauth.hasTokens(),\n   428→    timestamp: Date.now(),\n   429→  }));\n   430→}\n   431→\n   432→function handleStatus(\n   433→  res: http.ServerResponse,\n   434→  pool: WorkerPool,\n   435→  dispatcher: Dispatcher,\n   436→  tokenManager: TokenManager,\n   437→  oauth: OAuthManager,\n   438→): void {\n   439→  const oauthTokens = oauth.getTokens();\n   440→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   441→  res.end(JSON.stringify({\n   442→    workers: pool.getWorkers(),\n   443→    workerCounts: pool.getWorkerCount(),\n   444→    queueLength: dispatcher.getQueueLength(),\n   445→    activeExecutions: dispatcher.getActiveExecutions(),\n   446→    hasClaudeToken: tokenManager.hasToken(),\n   447→    oauth: {\n   448→      connected: oauth.hasTokens(),\n   449→      scopes: oauthTokens?.scopes || [],\n   450→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   451→    },\n   452→  }));\n   453→}\n   454→\n   455→async function handleExecute(\n   456→  req: http.IncomingMessage,\n   457→  res: http.ServerResponse,\n   458→  dispatcher: Dispatcher,\n   459→  logger: Logger,\n   460→  ctx?: RequestContext,\n   461→): Promise<void> {\n   462→  const body = await readBody(req);\n   463→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   464→\n   465→  try {\n   466→    parsed = JSON.parse(body);\n   467→  } catch {\n   468→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   469→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   470→    return;\n   471→  }\n   472→\n   473→  if (!parsed.prompt) {\n   474→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   475→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   476→    return;\n   477→  }\n   478→\n   479→  const request: ExecRequest = {\n   480→    executionId: nanoid(),\n   481→    personaId: parsed.personaId || 'manual',\n   482→    prompt: parsed.prompt,\n   483→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   484→    config: {\n   485→      timeoutMs: parsed.timeoutMs || 300_000,\n   486→    },\n   487→  };\n   488→\n   489→  dispatcher.submit(request);\n   490→\n   491→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   492→\n   493→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   494→  res.end(JSON.stringify({\n   495→    executionId: request.executionId,\n   496→    status: 'queued',\n   497→  }));\n   498→}\n   499→\n   500→function handleGetExecution(\n   501→  res: http.ServerResponse,\n   502→  dispatcher: Dispatcher,\n   503→  executionId: string,\n   504→  offset: number = 0,\n   505→): void {\n   506→  const exec = dispatcher.getExecution(executionId);\n   507→\n   508→  if (!exec) {\n   509→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   510→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   511→    return;\n   512→  }\n   513→\n   514→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   515→\n   516→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   517→  res.end(JSON.stringify({\n   518→    executionId,\n   519→    status: exec.status,\n   520→    outputLines: exec.output.length,\n   521→    output,\n   522→    durationMs: exec.durationMs,\n   523→    sessionId: exec.sessionId,\n   524→    totalCostUsd: exec.totalCostUsd,\n   525→  }));\n   526→}\n   527→\n   528→function handleCancelExecution(\n   529→  res: http.ServerResponse,\n   530→  dispatcher: Dispatcher,\n   531→  executionId: string,\n   532→): void {\n   533→  const cancelled = dispatcher.cancelExecution(executionId);\n   534→\n   535→  if (!cancelled) {\n   536→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   537→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   538→    return;\n   539→  }\n   540→\n   541→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   542→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   543→}\n   544→\n   545→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\n   546→const MAX_QUERY_LIMIT = 500;\n   547→const MAX_QUERY_OFFSET = 100_000;\n   548→\n   549→/** Parse an integer query param and clamp it to safe bounds. */\n   550→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   551→  if (!value) return defaultValue;\n   552→  const parsed = parseInt(value, 10);\n   553→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   554→  return Math.min(parsed, max);\n   555→}\n   556→"}]},"parent_tool_use_id":null,"session_id":"103d2ce2-a27b-48ee-89c7-1e160a818075","uuid":"a96c869a-b5c8-4469-a68c-04d9a6497461","timestamp":"2026-03-18T12:18:38.057Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n): http.Server {\n  const server = http.createServer(async (req, res) => {\n    // Security headers\n    res.setHeader('X-Content-Type-Options', 'nosniff');\n\n    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    const origin = req.headers.origin ?? '';\n    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    if (isAdminRoute) {\n      // Admin routes: only allow same-origin requests (no CORS wildcard)\n      if (origin && origin === allowedOrigin) {\n        res.setHeader('Access-Control-Allow-Origin', origin);\n      }\n      // If no match, omit the header entirely — browser blocks the request\n    } else {\n      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    }\n    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n\n    if (req.method === 'OPTIONS') {\n      res.writeHead(204);\n      res.end();\n      return;\n    }\n\n    const url = req.url || '/';\n    const [pathname, queryString] = url.split('?');\n    const route = parseRoute(pathname ?? '');\n\n    // Unauthenticated endpoints\n    if (pathname === '/health' && req.method === 'GET') {\n      handleHealth(res, pool, oauth);\n      return;\n    }\n\n    // Auth check for everything else — dual auth (API key + optional JWT)\n    const ctx = auth.validateAndExtractContext(req);\n    if (!ctx) {\n      res.writeHead(401, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Unauthorized' }));\n      return;\n    }\n\n    // Helper: project scoping (admin sees all, user sees own project)\n    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n\n    // Resolve tenant-specific database when available\n    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n      if (tenantDbManager && projectId) {\n        return tenantDbManager.getTenantDb(projectId);\n      }\n      return database;\n    };\n    const tenantDb = resolveDatabase(ctx.projectId);\n\n    try {\n      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n        if (requireAdmin(ctx, res)) return;\n        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n        return;\n      }\n      // --- Persona CRUD ---\n      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n        const persona = createPersonaWithDefaults({\n          ...body,\n          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n        });\n        db.upsertPersona(tenantDb, persona);\n        json(res, 201, persona);\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { toolId: string };\n        db.linkTool(tenantDb, route.id, body.toolId);\n        json(res, 200, { linked: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!hydrated) return;\n        json(res, 200, hydrated);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        json(res, 200, persona);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deletePersona(tenantDb, route.id, scopedProjectId);\n        json(res, 200, { deleted: true });\n      }\n      // --- Tool Definitions ---\n      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n        const tool = createToolDefinitionWithDefaults(body);\n        db.upsertToolDefinition(tenantDb, tool);\n        json(res, 201, tool);\n      }\n      // --- Credentials ---\n      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n\n        // Require plaintext — clients must never supply pre-encrypted data\n        if (!body.plaintext || typeof body.plaintext !== 'string') {\n          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n          return;\n        }\n\n        // Reject oversized plaintext before synchronous encryption blocks the event loop\n        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n          return;\n        }\n\n        // Encryption is mandatory — reject if the key manager is unavailable\n        if (!tenantKeyManager) {\n          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n          return;\n        }\n\n        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n        delete body.encryptedData;\n        delete body.iv;\n        delete body.tag;\n\n        // Server-side encryption with per-tenant key\n        const tenantId = body.projectId || ctx.projectId || 'default';\n        const key = await tenantKeyManager.getKey(tenantId);\n        const encrypted = encrypt(body.plaintext, key);\n        body.encryptedData = encrypted.encrypted;\n        body.iv = encrypted.iv;\n        body.tag = encrypted.tag;\n        delete body.plaintext;\n\n        const cred = db.createCredential(tenantDb, body);\n        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n        json(res, 201, cred);\n      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n        // Strip encrypted data from response\n        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n        db.linkCredential(tenantDb, route.id, body.credentialId);\n        json(res, 200, { linked: true });\n      }\n      // --- Event Subscriptions ---\n      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const sub = db.createSubscription(tenantDb, body);\n        json(res, 201, sub);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        db.updateSubscription(tenantDb, route.id, body);\n        const updated = db.getSubscription(tenantDb, route.id);\n        json(res, 200, updated);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deleteSubscription(tenantDb, route.id);\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n      }\n      // --- Triggers (delegated to triggerHttpHandlers) ---\n      else if (route && tenantDb && (\n        route.resource === 'triggers' ||\n        (route.resource === 'personas' && route.subResource === 'triggers')\n      )) {\n        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n        return;\n      }\n      // --- Events ---\n      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const events = db.listEvents(tenantDb, {\n          eventType: params.get('eventType') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, events);\n      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const event = db.publishEvent(tenantDb, body);\n        json(res, 201, event);\n      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n        if (updated) {\n          json(res, 200, updated);\n        } else {\n          res.writeHead(404, { 'Content-Type': 'application/json' });\n          res.end(JSON.stringify({ error: 'Event not found' }));\n        }\n      }\n      // --- Webhooks ---\n      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n        const personaId = route.id;\n        const body = await readBody(req);\n        const event = db.publishEvent(tenantDb, {\n          eventType: 'webhook_received',\n          sourceType: 'webhook',\n          sourceId: personaId,\n          targetPersonaId: personaId,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- GitLab Webhook ---\n      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n        const body = await readBody(req);\n        let parsed: Record<string, unknown> = {};\n        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n        const event = db.publishEvent(tenantDb, {\n          eventType: `gitlab_${objectKind}`,\n          sourceType: 'gitlab',\n          sourceId: projectPath ?? null,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- Executions ---\n      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const executions = db.listExecutions(tenantDb, {\n          personaId: params.get('personaId') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, executions);\n      }\n      // --- Existing execution endpoints ---\n      else if (pathname === '/api/status' && req.method === 'GET') {\n        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n      } else if (pathname === '/api/execute' && req.method === 'POST') {\n        await handleExecute(req, res, dispatcher, logger, ctx);\n      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n        handleCancelExecution(res, dispatcher, route.id);\n      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n        const executionId = route.id;\n        const params = new URLSearchParams(queryString || '');\n        const offset = parseInt(params.get('offset') || '0', 10);\n        handleGetExecution(res, dispatcher, executionId, offset);\n      }\n      // --- Admin-only routes ---\n      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n        } else if (database) {\n          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n        } else {\n          json(res, 200, { projectIds: [] });\n        }\n      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n          json(res, 200, allPersonas);\n        } else if (database) {\n          json(res, 200, db.listPersonasSummary(database));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        const params = new URLSearchParams(queryString || '');\n        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n        if (tenantDbManager) {\n          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n          tenantDbManager.forEachTenant((tDb) => {\n            allExecs.push(...db.listExecutions(tDb, { limit }));\n          });\n          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n          json(res, 200, allExecs.slice(0, limit));\n        } else if (database) {\n          json(res, 200, db.listExecutions(database, {\n            limit,\n            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          }));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (!auditLog) { json(res, 200, []); return; }\n        const params = new URLSearchParams(queryString || '');\n        json(res, 200, auditLog.query({\n          tenantId: params.get('tenantId') ?? undefined,\n          action: params.get('action') ?? undefined,\n          since: params.get('since') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        }));\n      } else {\n        res.writeHead(404, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Not found' }));\n      }\n    } catch (err) {\n      if (err instanceof Error && err.message === 'Payload too large') {\n        res.writeHead(413, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Payload too large' }));\n        return;\n      }\n      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n        res.writeHead(409, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n        return;\n      }\n      logger.error({ err, url }, 'HTTP handler error');\n      res.writeHead(500, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Internal server error' }));\n    }\n  });\n\n  return server;\n}\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\n/**\n * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n * Returns the entity on success, or null after sending a 404 response.\n */\nfunction withScopedEntity<T extends { projectId?: string | null }>(\n  entity: T | undefined,\n  scopedProjectId: string | undefined,\n  res: http.ServerResponse,\n): T | null {\n  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n    json(res, 404, { error: 'Not found' });\n    return null;\n  }\n  return entity;\n}\n\n/** Returns true (and sends 403) if the caller is NOT an admin. */\nfunction requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n  if (ctx.authType !== 'admin') {\n    res.writeHead(403, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Admin access required' }));\n    return true;\n  }\n  return false;\n}\n\n// --- Existing handlers ---\n\nfunction handleHealth(res: http.ServerResponse, pool: WorkerPool, oauth: OAuthManager): void {\n  const counts = pool.getWorkerCount();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    status: 'ok',\n    workers: counts,\n    hasSubscription: oauth.hasTokens(),\n    timestamp: Date.now(),\n  }));\n}\n\nfunction handleStatus(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n): void {\n  const oauthTokens = oauth.getTokens();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    workers: pool.getWorkers(),\n    workerCounts: pool.getWorkerCount(),\n    queueLength: dispatcher.getQueueLength(),\n    activeExecutions: dispatcher.getActiveExecutions(),\n    hasClaudeToken: tokenManager.hasToken(),\n    oauth: {\n      connected: oauth.hasTokens(),\n      scopes: oauthTokens?.scopes || [],\n      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n    },\n  }));\n}\n\nasync function handleExecute(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  ctx?: RequestContext,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.prompt) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n    return;\n  }\n\n  const request: ExecRequest = {\n    executionId: nanoid(),\n    personaId: parsed.personaId || 'manual',\n    prompt: parsed.prompt,\n    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n    config: {\n      timeoutMs: parsed.timeoutMs || 300_000,\n    },\n  };\n\n  dispatcher.submit(request);\n\n  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n\n  res.writeHead(202, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId: request.executionId,\n    status: 'queued',\n  }));\n}\n\nfunction handleGetExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n  offset: number = 0,\n): void {\n  const exec = dispatcher.getExecution(executionId);\n\n  if (!exec) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found' }));\n    return;\n  }\n\n  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId,\n    status: exec.status,\n    outputLines: exec.output.length,\n    output,\n    durationMs: exec.durationMs,\n    sessionId: exec.sessionId,\n    totalCostUsd: exec.totalCostUsd,\n  }));\n}\n\nfunction handleCancelExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n): void {\n  const cancelled = dispatcher.cancelExecution(executionId);\n\n  if (!cancelled) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n    return;\n  }\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n}\n\nconst MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\nconst MAX_QUERY_LIMIT = 500;\nconst MAX_QUERY_OFFSET = 100_000;\n\n/** Parse an integer query param and clamp it to safe bounds. */\nfunction clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n  if (!value) return defaultValue;\n  const parsed = parseInt(value, 10);\n  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n  return Math.min(parsed, max);\n}\n","numLines":556,"startLine":1,"totalLines":556}}}
