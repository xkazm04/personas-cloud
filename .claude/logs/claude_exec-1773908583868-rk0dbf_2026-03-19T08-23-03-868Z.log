[2026-03-19T08:23:24.528Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SbPxKH2XB62Re4wa1GqXcN","type":"tool_result","content":"     1→import { randomBytes, createHash } from 'node:crypto';\n     2→import type { Logger } from 'pino';\n     3→import type { AuditLog } from './auditLog.js';\n     4→\n     5→// Anthropic OAuth constants (from Claude Code CLI)\n     6→const OAUTH_AUTHORIZE_URL = 'https://claude.ai/oauth/authorize';\n     7→const OAUTH_TOKEN_URL = 'https://console.anthropic.com/v1/oauth/token';\n     8→const OAUTH_REVOKE_URL = 'https://console.anthropic.com/v1/oauth/revoke';\n     9→const CLIENT_ID = '9d1c250a-e61b-44d9-88ed-5944d1962f5e';\n    10→const REDIRECT_URI = 'https://console.anthropic.com/oauth/code/callback';\n    11→const SCOPES = 'org:create_api_key user:profile user:inference';\n    12→\n    13→export interface OAuthTokens {\n    14→  accessToken: string;\n    15→  refreshToken: string;\n    16→  expiresAt: number;    // unix ms\n    17→  scopes: string[];\n    18→}\n    19→\n    20→// ---------------------------------------------------------------------------\n    21→// OAuth error classification\n    22→// ---------------------------------------------------------------------------\n    23→\n    24→/** Classified OAuth error types for pattern detection and alerting. */\n    25→export type OAuthErrorType =\n    26→  | 'invalid_grant'   // refresh token consumed/expired — user must re-authenticate\n    27→  | 'rate_limited'    // 429 — back off and retry\n    28→  | 'server_error'    // 5xx — transient, retry with backoff\n    29→  | 'network_error'   // fetch threw (DNS, timeout, connection refused) — transient\n    30→  | 'invalid_request'; // 400 — likely a bug in request construction\n    31→\n    32→export interface OAuthError {\n    33→  errorType: OAuthErrorType;\n    34→  status?: number;       // HTTP status when available\n    35→  message: string;       // human-readable summary\n    36→  transient: boolean;    // true = self-healing, false = requires intervention\n    37→  raw?: string;          // raw error body (truncated)\n    38→}\n    39→\n    40→/**\n    41→ * Classify an HTTP error response from the OAuth token endpoint.\n    42→ */\n    43→function classifyHttpError(status: number, body: string): OAuthError {\n    44→  const truncated = body.length > 512 ? body.slice(0, 512) + '…' : body;\n    45→\n    46→  // 401 or body contains invalid_grant → refresh token consumed/expired\n    47→  if (status === 401 || /invalid_grant/i.test(body)) {\n    48→    return {\n    49→      errorType: 'invalid_grant',\n    50→      status,\n    51→      message: 'Refresh token expired or consumed — user must re-authenticate',\n    52→      transient: false,\n    53→      raw: truncated,\n    54→    };\n    55→  }\n    56→\n    57→  // 429 → rate limited\n    58→  if (status === 429) {\n    59→    return {\n    60→      errorType: 'rate_limited',\n    61→      status,\n    62→      message: 'Rate limited by OAuth provider — back off and retry',\n    63→      transient: true,\n    64→      raw: truncated,\n    65→    };\n    66→  }\n    67→\n    68→  // 5xx → server error (transient)\n    69→  if (status >= 500) {\n    70→    return {\n    71→      errorType: 'server_error',\n    72→      status,\n    73→      message: `OAuth provider returned ${status} — transient server error`,\n    74→      transient: true,\n    75→      raw: truncated,\n    76→    };\n    77→  }\n    78→\n    79→  // 400 or other 4xx → invalid request (likely a bug)\n    80→  return {\n    81→    errorType: 'invalid_request',\n    82→    status,\n    83→    message: `OAuth request rejected with ${status} — check request parameters`,\n    84→    transient: false,\n    85→    raw: truncated,\n    86→  };\n    87→}\n    88→\n    89→/**\n    90→ * Classify a network-level error (fetch threw before receiving a response).\n    91→ */\n    92→function classifyNetworkError(err: unknown): OAuthError {\n    93→  const message = err instanceof Error ? err.message : String(err);\n    94→  return {\n    95→    errorType: 'network_error',\n    96→    message: `Network error: ${message}`,\n    97→    transient: true,\n    98→  };\n    99→}\n   100→\n   101→/** Result of postTokenEndpoint: either tokens or a classified error. */\n   102→export type TokenEndpointResult =\n   103→  | { ok: true; tokens: OAuthTokens }\n   104→  | { ok: false; error: OAuthError };\n   105→\n   106→export interface OAuthState {\n   107→  state: string;\n   108→  codeVerifier: string;\n   109→  createdAt: number;\n   110→  expiresAt: number;    // unix ms, 10 minute window\n   111→}\n   112→\n   113→export class OAuthManager {\n   114→  private pendingStates = new Map<string, OAuthState>();\n   115→  private tokens: OAuthTokens | null = null;\n   116→  private refreshPromise: Promise<TokenEndpointResult> | null = null;\n   117→  private sweepTimer: ReturnType<typeof setInterval> | null = null;\n   118→  private auditLog?: AuditLog;\n   119→  private expiryWarningMs = 30 * 60 * 1000; // default 30 minutes\n   120→  private expiryWarningEmitted = false;\n   121→\n   122→  private static readonly DEFAULT_SCOPES = ['user:inference', 'user:profile'];\n   123→\n   124→  constructor(private logger: Logger) {\n   125→    // Sweep expired pending states every 60 seconds\n   126→    this.sweepTimer = setInterval(() => this.sweepExpiredStates(), 60_000);\n   127→    this.sweepTimer.unref();\n   128→  }\n   129→\n   130→  /**\n   131→   * Wire in the audit log and configurable expiry warning threshold.\n   132→   * Called after construction once the audit log is available.\n   133→   */\n   134→  setAuditLog(auditLog: AuditLog, warningMinutes?: number): void {\n   135→    this.auditLog = auditLog;\n   136→    if (warningMinutes !== undefined && warningMinutes > 0) {\n   137→      this.expiryWarningMs = warningMinutes * 60 * 1000;\n   138→    }\n   139→  }\n   140→\n   141→  private sweepExpiredStates(): void {\n   142→    const now = Date.now();\n   143→    let swept = 0;\n   144→    for (const [key, entry] of this.pendingStates) {\n   145→      if (now > entry.expiresAt) {\n   146→        this.pendingStates.delete(key);\n   147→        swept++;\n   148→      }\n   149→    }\n   150→    if (swept > 0) {\n   151→      this.logger.debug({ swept, remaining: this.pendingStates.size }, 'Swept expired OAuth states');\n   152→    }\n   153→  }\n   154→\n   155→  /**\n   156→   * POST to the OAuth token endpoint, parse the response, and map to OAuthTokens.\n   157→   * Callers supply only the grant-specific body fields and a scope fallback.\n   158→   * Returns a discriminated result with classified error info on failure.\n   159→   */\n   160→  private async postTokenEndpoint(\n   161→    body: Record<string, string>,\n   162→    fallbackScopes: string[],\n   163→    context: string,\n   164→  ): Promise<TokenEndpointResult> {\n   165→    try {\n   166→      const response = await fetch(OAUTH_TOKEN_URL, {\n   167→        method: 'POST',\n   168→        headers: {\n   169→          'Content-Type': 'application/json',\n   170→          'Accept': 'application/json',\n   171→        },\n   172→        body: JSON.stringify(body),\n   173→      });\n   174→\n   175→      if (!response.ok) {\n   176→        const errorText = await response.text();\n   177→        const classified = classifyHttpError(response.status, errorText);\n   178→        this.logger.error(\n   179→          { status: response.status, errorType: classified.errorType, transient: classified.transient },\n   180→          `OAuth ${context} failed: ${classified.message}`,\n   181→        );\n   182→        try {\n   183→          this.auditLog?.record({\n   184→            action: 'oauth:token_error',\n   185→            resourceType: 'oauth',\n   186→            detail: { errorType: classified.errorType, status: response.status, transient: classified.transient, context },\n   187→          });\n   188→        } catch { /* logged inside record() */ }\n   189→        return { ok: false, error: classified };\n   190→      }\n   191→\n   192→      const data = await response.json() as {\n   193→        access_token: string;\n   194→        refresh_token: string;\n   195→        expires_in: number;\n   196→        scope?: string;\n   197→      };\n   198→\n   199→      return {\n   200→        ok: true,\n   201→        tokens: {\n   202→          accessToken: data.access_token,\n   203→          refreshToken: data.refresh_token,\n   204→          expiresAt: Date.now() + data.expires_in * 1000,\n   205→          scopes: data.scope ? data.scope.split(' ') : fallbackScopes,\n   206→        },\n   207→      };\n   208→    } catch (err) {\n   209→      const classified = classifyNetworkError(err);\n   210→      this.logger.error(\n   211→        { err, errorType: classified.errorType, transient: classified.transient },\n   212→        `OAuth ${context} failed: ${classified.message}`,\n   213→      );\n   214→      try {\n   215→        this.auditLog?.record({\n   216→          action: 'oauth:token_error',\n   217→          resourceType: 'oauth',\n   218→          detail: { errorType: classified.errorType, transient: classified.transient, context },\n   219→        });\n   220→      } catch { /* logged inside record() */ }\n   221→      return { ok: false, error: classified };\n   222→    }\n   223→  }\n   224→\n   225→  /**\n   226→   * Step 1: Generate the authorization URL for the user to visit.\n   227→   * Returns the URL and stores PKCE state internally.\n   228→   */\n   229→  generateAuthUrl(): { url: string; state: string } {\n   230→    const state = randomBytes(32).toString('hex');\n   231→    const codeVerifier = randomBytes(32).toString('base64url');\n   232→    const codeChallenge = createHash('sha256')\n   233→      .update(codeVerifier)\n   234→      .digest('base64url');\n   235→\n   236→    const oauthState: OAuthState = {\n   237→      state,\n   238→      codeVerifier,\n   239→      createdAt: Date.now(),\n   240→      expiresAt: Date.now() + 10 * 60 * 1000, // 10 minutes\n   241→    };\n   242→\n   243→    this.pendingStates.set(state, oauthState);\n   244→\n   245→    const params = new URLSearchParams({\n   246→      code: 'true',\n   247→      client_id: CLIENT_ID,\n   248→      response_type: 'code',\n   249→      redirect_uri: REDIRECT_URI,\n   250→      scope: SCOPES,\n   251→      code_challenge: codeChallenge,\n   252→      code_challenge_method: 'S256',\n   253→      state,\n   254→    });\n   255→\n   256→    const url = `${OAUTH_AUTHORIZE_URL}?${params.toString()}`;\n   257→\n   258→    this.logger.info('Generated OAuth authorization URL');\n   259→    return { url, state };\n   260→  }\n   261→\n   262→  /**\n   263→   * Step 2: Exchange the authorization code for tokens.\n   264→   * Called after user completes the OAuth flow and provides the code.\n   265→   */\n   266→  async exchangeCode(authorizationCode: string, state: string): Promise<TokenEndpointResult> {\n   267→    // Validate state\n   268→    const pending = this.pendingStates.get(state);\n   269→    if (!pending) {\n   270→      this.logger.error('OAuth state not found or already consumed');\n   271→      return { ok: false, error: { errorType: 'invalid_request', message: 'OAuth state not found or already consumed', transient: false } };\n   272→    }\n   273→\n   274→    if (Date.now() > pending.expiresAt) {\n   275→      this.logger.error('OAuth state expired');\n   276→      this.pendingStates.delete(state);\n   277→      return { ok: false, error: { errorType: 'invalid_request', message: 'OAuth state expired', transient: false } };\n   278→    }\n   279→\n   280→    const cleanedCode = authorizationCode.split('#')[0]?.split('&')[0] ?? authorizationCode;\n   281→\n   282→    const result = await this.postTokenEndpoint(\n   283→      {\n   284→        grant_type: 'authorization_code',\n   285→        client_id: CLIENT_ID,\n   286→        code: cleanedCode,\n   287→        redirect_uri: REDIRECT_URI,\n   288→        code_verifier: pending.codeVerifier,\n   289→        state: pending.state,\n   290→      },\n   291→      OAuthManager.DEFAULT_SCOPES,\n   292→      'token exchange',\n   293→    );\n   294→\n   295→    this.pendingStates.delete(state);\n   296→\n   297→    if (result.ok) {\n   298→      this.tokens = result.tokens;\n   299→      this.logger.info({\n   300→        scopes: this.tokens.scopes,\n   301→        expiresAt: new Date(this.tokens.expiresAt).toISOString(),\n   302→      }, 'OAuth token exchange successful');\n   303→    }\n   304→\n   305→    return result;\n   306→  }\n   307→\n   308→  /**\n   309→   * Refresh the access token using the refresh token.\n   310→   * Called automatically before dispatching if token is near expiry.\n   311→   * Uses promise dedup so concurrent callers share one in-flight refresh,\n   312→   * preventing single-use rotating refresh tokens from being consumed twice.\n   313→   */\n   314→  async refreshAccessToken(): Promise<TokenEndpointResult> {\n   315→    if (!this.tokens) {\n   316→      this.logger.error('No tokens to refresh');\n   317→      return { ok: false, error: { errorType: 'invalid_request', message: 'No tokens to refresh', transient: false } };\n   318→    }\n   319→\n   320→    if (this.refreshPromise) {\n   321→      return this.refreshPromise;\n   322→    }\n   323→\n   324→    this.refreshPromise = this.executeRefresh().finally(() => {\n   325→      this.refreshPromise = null;\n   326→    });\n   327→    return this.refreshPromise;\n   328→  }\n   329→\n   330→  private async executeRefresh(): Promise<TokenEndpointResult> {\n   331→    const previousScopes = this.tokens!.scopes;\n   332→\n   333→    // Refresh tokens are single-use rotation — store the new one\n   334→    const result = await this.postTokenEndpoint(\n   335→      {\n   336→        grant_type: 'refresh_token',\n   337→        client_id: CLIENT_ID,\n   338→        refresh_token: this.tokens!.refreshToken,\n   339→      },\n   340→      previousScopes,\n   341→      'token refresh',\n   342→    );\n   343→\n   344→    if (result.ok) {\n   345→      this.tokens = result.tokens;\n   346→      this.logger.info({\n   347→        expiresAt: new Date(this.tokens.expiresAt).toISOString(),\n   348→      }, 'OAuth token refreshed');\n   349→      try { this.auditLog?.record({ action: 'oauth:refresh', resourceType: 'oauth', detail: { expiresAt: new Date(this.tokens.expiresAt).toISOString() } }); } catch { /* logged inside record() */ }\n   350→    } else {\n   351→      try { this.auditLog?.record({ action: 'oauth:refresh_failed', resourceType: 'oauth', detail: { reason: result.error.message, errorType: result.error.errorType } }); } catch { /* logged inside record() */ }\n   352→    }\n   353→\n   354→    return result;\n   355→  }\n   356→\n   357→  /**\n   358→   * Get a valid access token, refreshing if necessary.\n   359→   * Returns null if no tokens available or refresh fails.\n   360→   */\n   361→  async getValidAccessToken(): Promise<string | null> {\n   362→    if (!this.tokens) return null;\n   363→\n   364→    const now = Date.now();\n   365→    const remainingMs = this.tokens.expiresAt - now;\n   366→\n   367→    // Emit token:expiring_soon once per token when within the warning threshold\n   368→    if (remainingMs > 0 && remainingMs <= this.expiryWarningMs && !this.expiryWarningEmitted) {\n   369→      this.expiryWarningEmitted = true;\n   370→      try {\n   371→        this.auditLog?.record({\n   372→          action: 'token:expiring_soon',\n   373→          resourceType: 'oauth',\n   374→          detail: {\n   375→            expiresAt: new Date(this.tokens.expiresAt).toISOString(),\n   376→            remainingMinutes: Math.round(remainingMs / 60_000),\n   377→          },\n   378→        });\n   379→      } catch { /* logged inside record() */ }\n   380→      this.logger.warn({ remainingMinutes: Math.round(remainingMs / 60_000) }, 'OAuth token expiring soon');\n   381→    }\n   382→\n   383→    // Refresh if within 10 minutes of expiry\n   384→    const TEN_MINUTES = 10 * 60 * 1000;\n   385→    if (now > this.tokens.expiresAt - TEN_MINUTES) {\n   386→      this.logger.info('Access token near expiry, refreshing...');\n   387→      const result = await this.refreshAccessToken();\n   388→      if (!result.ok) return null;\n   389→      // Reset expiry warning flag after successful refresh\n   390→      this.expiryWarningEmitted = false;\n   391→    }\n   392→\n   393→    return this.tokens.accessToken;\n   394→  }\n   395→\n   396→  /**\n   397→   * Load tokens directly (e.g. from encrypted storage on startup).\n   398→   */\n   399→  loadTokens(tokens: OAuthTokens): void {\n   400→    this.tokens = tokens;\n   401→    this.logger.info({\n   402→      expiresAt: new Date(tokens.expiresAt).toISOString(),\n   403→      scopes: tokens.scopes,\n   404→    }, 'OAuth tokens loaded');\n   405→  }\n   406→\n   407→  /**\n   408→   * Get current tokens for persistence/encryption.\n   409→   */\n   410→  getTokens(): OAuthTokens | null {\n   411→    return this.tokens ? { ...this.tokens } : null;\n   412→  }\n   413→\n   414→  hasTokens(): boolean {\n   415→    return this.tokens !== null;\n   416→  }\n   417→\n   418→  /**\n   419→   * Revoke tokens on the Anthropic server (RFC 7009) then clear local state.\n   420→   * Best-effort: local state is always cleared even if revocation fails.\n   421→   */\n   422→  async revokeAndClearTokens(): Promise<{ revoked: boolean }> {\n   423→    const tokensToRevoke = this.tokens;\n   424→    // Clear local state immediately so the caller never stays \"connected\"\n   425→    this.tokens = null;\n   426→    this.pendingStates.clear();\n   427→\n   428→    if (!tokensToRevoke) {\n   429→      this.logger.info('No tokens to revoke, local state cleared');\n   430→      return { revoked: false };\n   431→    }\n   432→\n   433→    let revoked = false;\n   434→    // Revoke the refresh token first (invalidates the grant); then the access token.\n   435→    for (const { token, hint } of [\n   436→      { token: tokensToRevoke.refreshToken, hint: 'refresh_token' },\n   437→      { token: tokensToRevoke.accessToken, hint: 'access_token' },\n   438→    ] as const) {\n   439→      try {\n   440→        const response = await fetch(OAUTH_REVOKE_URL, {\n   441→          method: 'POST',\n   442→          headers: { 'Content-Type': 'application/json' },\n   443→          body: JSON.stringify({\n   444→            client_id: CLIENT_ID,\n   445→            token,\n   446→            token_type_hint: hint,\n   447→          }),\n   448→        });\n   449→        // RFC 7009 §2.2: the server responds with 200 even if the token was already invalid\n   450→        if (response.ok) {\n   451→          this.logger.info({ hint }, 'OAuth token revoked on server');\n   452→          revoked = true;\n   453→        } else {\n   454→          const errorText = await response.text();\n   455→          this.logger.warn({ hint, status: response.status, error: errorText }, 'OAuth token revocation returned non-OK');\n   456→        }\n   457→      } catch (err) {\n   458→        this.logger.warn({ err, hint }, 'OAuth token revocation request failed');\n   459→      }\n   460→    }\n   461→\n   462→    this.logger.info({ revoked }, 'OAuth disconnect complete, local tokens cleared');\n   463→    return { revoked };\n   464→  }\n   465→\n   466→  clearTokens(): void {\n   467→    this.tokens = null;\n   468→    this.pendingStates.clear();\n   469→    this.logger.info('OAuth tokens cleared');\n   470→  }\n   471→\n   472→  /**\n   473→   * Stop the background sweep timer. Call on shutdown.\n   474→   */\n   475→  dispose(): void {\n   476→    if (this.sweepTimer) {\n   477→      clearInterval(this.sweepTimer);\n   478→      this.sweepTimer = null;\n   479→    }\n   480→  }\n   481→}\n   482→"}]},"parent_tool_use_id":null,"session_id":"238ad404-ea3b-4d8d-9a1e-37ff9f6188d0","uuid":"54c5898c-c0cf-4323-8c67-1b8ef503766e","timestamp":"2026-03-19T08:23:24.138Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\oauth.ts","content":"import { randomBytes, createHash } from 'node:crypto';\nimport type { Logger } from 'pino';\nimport type { AuditLog } from './auditLog.js';\n\n// Anthropic OAuth constants (from Claude Code CLI)\nconst OAUTH_AUTHORIZE_URL = 'https://claude.ai/oauth/authorize';\nconst OAUTH_TOKEN_URL = 'https://console.anthropic.com/v1/oauth/token';\nconst OAUTH_REVOKE_URL = 'https://console.anthropic.com/v1/oauth/revoke';\nconst CLIENT_ID = '9d1c250a-e61b-44d9-88ed-5944d1962f5e';\nconst REDIRECT_URI = 'https://console.anthropic.com/oauth/code/callback';\nconst SCOPES = 'org:create_api_key user:profile user:inference';\n\nexport interface OAuthTokens {\n  accessToken: string;\n  refreshToken: string;\n  expiresAt: number;    // unix ms\n  scopes: string[];\n}\n\n// ---------------------------------------------------------------------------\n// OAuth error classification\n// ---------------------------------------------------------------------------\n\n/** Classified OAuth error types for pattern detection and alerting. */\nexport type OAuthErrorType =\n  | 'invalid_grant'   // refresh token consumed/expired — user must re-authenticate\n  | 'rate_limited'    // 429 — back off and retry\n  | 'server_error'    // 5xx — transient, retry with backoff\n  | 'network_error'   // fetch threw (DNS, timeout, connection refused) — transient\n  | 'invalid_request'; // 400 — likely a bug in request construction\n\nexport interface OAuthError {\n  errorType: OAuthErrorType;\n  status?: number;       // HTTP status when available\n  message: string;       // human-readable summary\n  transient: boolean;    // true = self-healing, false = requires intervention\n  raw?: string;          // raw error body (truncated)\n}\n\n/**\n * Classify an HTTP error response from the OAuth token endpoint.\n */\nfunction classifyHttpError(status: number, body: string): OAuthError {\n  const truncated = body.length > 512 ? body.slice(0, 512) + '…' : body;\n\n  // 401 or body contains invalid_grant → refresh token consumed/expired\n  if (status === 401 || /invalid_grant/i.test(body)) {\n    return {\n      errorType: 'invalid_grant',\n      status,\n      message: 'Refresh token expired or consumed — user must re-authenticate',\n      transient: false,\n      raw: truncated,\n    };\n  }\n\n  // 429 → rate limited\n  if (status === 429) {\n    return {\n      errorType: 'rate_limited',\n      status,\n      message: 'Rate limited by OAuth provider — back off and retry',\n      transient: true,\n      raw: truncated,\n    };\n  }\n\n  // 5xx → server error (transient)\n  if (status >= 500) {\n    return {\n      errorType: 'server_error',\n      status,\n      message: `OAuth provider returned ${status} — transient server error`,\n      transient: true,\n      raw: truncated,\n    };\n  }\n\n  // 400 or other 4xx → invalid request (likely a bug)\n  return {\n    errorType: 'invalid_request',\n    status,\n    message: `OAuth request rejected with ${status} — check request parameters`,\n    transient: false,\n    raw: truncated,\n  };\n}\n\n/**\n * Classify a network-level error (fetch threw before receiving a response).\n */\nfunction classifyNetworkError(err: unknown): OAuthError {\n  const message = err instanceof Error ? err.message : String(err);\n  return {\n    errorType: 'network_error',\n    message: `Network error: ${message}`,\n    transient: true,\n  };\n}\n\n/** Result of postTokenEndpoint: either tokens or a classified error. */\nexport type TokenEndpointResult =\n  | { ok: true; tokens: OAuthTokens }\n  | { ok: false; error: OAuthError };\n\nexport interface OAuthState {\n  state: string;\n  codeVerifier: string;\n  createdAt: number;\n  expiresAt: number;    // unix ms, 10 minute window\n}\n\nexport class OAuthManager {\n  private pendingStates = new Map<string, OAuthState>();\n  private tokens: OAuthTokens | null = null;\n  private refreshPromise: Promise<TokenEndpointResult> | null = null;\n  private sweepTimer: ReturnType<typeof setInterval> | null = null;\n  private auditLog?: AuditLog;\n  private expiryWarningMs = 30 * 60 * 1000; // default 30 minutes\n  private expiryWarningEmitted = false;\n\n  private static readonly DEFAULT_SCOPES = ['user:inference', 'user:profile'];\n\n  constructor(private logger: Logger) {\n    // Sweep expired pending states every 60 seconds\n    this.sweepTimer = setInterval(() => this.sweepExpiredStates(), 60_000);\n    this.sweepTimer.unref();\n  }\n\n  /**\n   * Wire in the audit log and configurable expiry warning threshold.\n   * Called after construction once the audit log is available.\n   */\n  setAuditLog(auditLog: AuditLog, warningMinutes?: number): void {\n    this.auditLog = auditLog;\n    if (warningMinutes !== undefined && warningMinutes > 0) {\n      this.expiryWarningMs = warningMinutes * 60 * 1000;\n    }\n  }\n\n  private sweepExpiredStates(): void {\n    const now = Date.now();\n    let swept = 0;\n    for (const [key, entry] of this.pendingStates) {\n      if (now > entry.expiresAt) {\n        this.pendingStates.delete(key);\n        swept++;\n      }\n    }\n    if (swept > 0) {\n      this.logger.debug({ swept, remaining: this.pendingStates.size }, 'Swept expired OAuth states');\n    }\n  }\n\n  /**\n   * POST to the OAuth token endpoint, parse the response, and map to OAuthTokens.\n   * Callers supply only the grant-specific body fields and a scope fallback.\n   * Returns a discriminated result with classified error info on failure.\n   */\n  private async postTokenEndpoint(\n    body: Record<string, string>,\n    fallbackScopes: string[],\n    context: string,\n  ): Promise<TokenEndpointResult> {\n    try {\n      const response = await fetch(OAUTH_TOKEN_URL, {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          'Accept': 'application/json',\n        },\n        body: JSON.stringify(body),\n      });\n\n      if (!response.ok) {\n        const errorText = await response.text();\n        const classified = classifyHttpError(response.status, errorText);\n        this.logger.error(\n          { status: response.status, errorType: classified.errorType, transient: classified.transient },\n          `OAuth ${context} failed: ${classified.message}`,\n        );\n        try {\n          this.auditLog?.record({\n            action: 'oauth:token_error',\n            resourceType: 'oauth',\n            detail: { errorType: classified.errorType, status: response.status, transient: classified.transient, context },\n          });\n        } catch { /* logged inside record() */ }\n        return { ok: false, error: classified };\n      }\n\n      const data = await response.json() as {\n        access_token: string;\n        refresh_token: string;\n        expires_in: number;\n        scope?: string;\n      };\n\n      return {\n        ok: true,\n        tokens: {\n          accessToken: data.access_token,\n          refreshToken: data.refresh_token,\n          expiresAt: Date.now() + data.expires_in * 1000,\n          scopes: data.scope ? data.scope.split(' ') : fallbackScopes,\n        },\n      };\n    } catch (err) {\n      const classified = classifyNetworkError(err);\n      this.logger.error(\n        { err, errorType: classified.errorType, transient: classified.transient },\n        `OAuth ${context} failed: ${classified.message}`,\n      );\n      try {\n        this.auditLog?.record({\n          action: 'oauth:token_error',\n          resourceType: 'oauth',\n          detail: { errorType: classified.errorType, transient: classified.transient, context },\n        });\n      } catch { /* logged inside record() */ }\n      return { ok: false, error: classified };\n    }\n  }\n\n  /**\n   * Step 1: Generate the authorization URL for the user to visit.\n   * Returns the URL and stores PKCE state internally.\n   */\n  generateAuthUrl(): { url: string; state: string } {\n    const state = randomBytes(32).toString('hex');\n    const codeVerifier = randomBytes(32).toString('base64url');\n    const codeChallenge = createHash('sha256')\n      .update(codeVerifier)\n      .digest('base64url');\n\n    const oauthState: OAuthState = {\n      state,\n      codeVerifier,\n      createdAt: Date.now(),\n      expiresAt: Date.now() + 10 * 60 * 1000, // 10 minutes\n    };\n\n    this.pendingStates.set(state, oauthState);\n\n    const params = new URLSearchParams({\n      code: 'true',\n      client_id: CLIENT_ID,\n      response_type: 'code',\n      redirect_uri: REDIRECT_URI,\n      scope: SCOPES,\n      code_challenge: codeChallenge,\n      code_challenge_method: 'S256',\n      state,\n    });\n\n    const url = `${OAUTH_AUTHORIZE_URL}?${params.toString()}`;\n\n    this.logger.info('Generated OAuth authorization URL');\n    return { url, state };\n  }\n\n  /**\n   * Step 2: Exchange the authorization code for tokens.\n   * Called after user completes the OAuth flow and provides the code.\n   */\n  async exchangeCode(authorizationCode: string, state: string): Promise<TokenEndpointResult> {\n    // Validate state\n    const pending = this.pendingStates.get(state);\n    if (!pending) {\n      this.logger.error('OAuth state not found or already consumed');\n      return { ok: false, error: { errorType: 'invalid_request', message: 'OAuth state not found or already consumed', transient: false } };\n    }\n\n    if (Date.now() > pending.expiresAt) {\n      this.logger.error('OAuth state expired');\n      this.pendingStates.delete(state);\n      return { ok: false, error: { errorType: 'invalid_request', message: 'OAuth state expired', transient: false } };\n    }\n\n    const cleanedCode = authorizationCode.split('#')[0]?.split('&')[0] ?? authorizationCode;\n\n    const result = await this.postTokenEndpoint(\n      {\n        grant_type: 'authorization_code',\n        client_id: CLIENT_ID,\n        code: cleanedCode,\n        redirect_uri: REDIRECT_URI,\n        code_verifier: pending.codeVerifier,\n        state: pending.state,\n      },\n      OAuthManager.DEFAULT_SCOPES,\n      'token exchange',\n    );\n\n    this.pendingStates.delete(state);\n\n    if (result.ok) {\n      this.tokens = result.tokens;\n      this.logger.info({\n        scopes: this.tokens.scopes,\n        expiresAt: new Date(this.tokens.expiresAt).toISOString(),\n      }, 'OAuth token exchange successful');\n    }\n\n    return result;\n  }\n\n  /**\n   * Refresh the access token using the refresh token.\n   * Called automatically before dispatching if token is near expiry.\n   * Uses promise dedup so concurrent callers share one in-flight refresh,\n   * preventing single-use rotating refresh tokens from being consumed twice.\n   */\n  async refreshAccessToken(): Promise<TokenEndpointResult> {\n    if (!this.tokens) {\n      this.logger.error('No tokens to refresh');\n      return { ok: false, error: { errorType: 'invalid_request', message: 'No tokens to refresh', transient: false } };\n    }\n\n    if (this.refreshPromise) {\n      return this.refreshPromise;\n    }\n\n    this.refreshPromise = this.executeRefresh().finally(() => {\n      this.refreshPromise = null;\n    });\n    return this.refreshPromise;\n  }\n\n  private async executeRefresh(): Promise<TokenEndpointResult> {\n    const previousScopes = this.tokens!.scopes;\n\n    // Refresh tokens are single-use rotation — store the new one\n    const result = await this.postTokenEndpoint(\n      {\n        grant_type: 'refresh_token',\n        client_id: CLIENT_ID,\n        refresh_token: this.tokens!.refreshToken,\n      },\n      previousScopes,\n      'token refresh',\n    );\n\n    if (result.ok) {\n      this.tokens = result.tokens;\n      this.logger.info({\n        expiresAt: new Date(this.tokens.expiresAt).toISOString(),\n      }, 'OAuth token refreshed');\n      try { this.auditLog?.record({ action: 'oauth:refresh', resourceType: 'oauth', detail: { expiresAt: new Date(this.tokens.expiresAt).toISOString() } }); } catch { /* logged inside record() */ }\n    } else {\n      try { this.auditLog?.record({ action: 'oauth:refresh_failed', resourceType: 'oauth', detail: { reason: result.error.message, errorType: result.error.errorType } }); } catch { /* logged inside record() */ }\n    }\n\n    return result;\n  }\n\n  /**\n   * Get a valid access token, refreshing if necessary.\n   * Returns null if no tokens available or refresh fails.\n   */\n  async getValidAccessToken(): Promise<string | null> {\n    if (!this.tokens) return null;\n\n    const now = Date.now();\n    const remainingMs = this.tokens.expiresAt - now;\n\n    // Emit token:expiring_soon once per token when within the warning threshold\n    if (remainingMs > 0 && remainingMs <= this.expiryWarningMs && !this.expiryWarningEmitted) {\n      this.expiryWarningEmitted = true;\n      try {\n        this.auditLog?.record({\n          action: 'token:expiring_soon',\n          resourceType: 'oauth',\n          detail: {\n            expiresAt: new Date(this.tokens.expiresAt).toISOString(),\n            remainingMinutes: Math.round(remainingMs / 60_000),\n          },\n        });\n      } catch { /* logged inside record() */ }\n      this.logger.warn({ remainingMinutes: Math.round(remainingMs / 60_000) }, 'OAuth token expiring soon');\n    }\n\n    // Refresh if within 10 minutes of expiry\n    const TEN_MINUTES = 10 * 60 * 1000;\n    if (now > this.tokens.expiresAt - TEN_MINUTES) {\n      this.logger.info('Access token near expiry, refreshing...');\n      const result = await this.refreshAccessToken();\n      if (!result.ok) return null;\n      // Reset expiry warning flag after successful refresh\n      this.expiryWarningEmitted = false;\n    }\n\n    return this.tokens.accessToken;\n  }\n\n  /**\n   * Load tokens directly (e.g. from encrypted storage on startup).\n   */\n  loadTokens(tokens: OAuthTokens): void {\n    this.tokens = tokens;\n    this.logger.info({\n      expiresAt: new Date(tokens.expiresAt).toISOString(),\n      scopes: tokens.scopes,\n    }, 'OAuth tokens loaded');\n  }\n\n  /**\n   * Get current tokens for persistence/encryption.\n   */\n  getTokens(): OAuthTokens | null {\n    return this.tokens ? { ...this.tokens } : null;\n  }\n\n  hasTokens(): boolean {\n    return this.tokens !== null;\n  }\n\n  /**\n   * Revoke tokens on the Anthropic server (RFC 7009) then clear local state.\n   * Best-effort: local state is always cleared even if revocation fails.\n   */\n  async revokeAndClearTokens(): Promise<{ revoked: boolean }> {\n    const tokensToRevoke = this.tokens;\n    // Clear local state immediately so the caller never stays \"connected\"\n    this.tokens = null;\n    this.pendingStates.clear();\n\n    if (!tokensToRevoke) {\n      this.logger.info('No tokens to revoke, local state cleared');\n      return { revoked: false };\n    }\n\n    let revoked = false;\n    // Revoke the refresh token first (invalidates the grant); then the access token.\n    for (const { token, hint } of [\n      { token: tokensToRevoke.refreshToken, hint: 'refresh_token' },\n      { token: tokensToRevoke.accessToken, hint: 'access_token' },\n    ] as const) {\n      try {\n        const response = await fetch(OAUTH_REVOKE_URL, {\n          method: 'POST',\n          headers: { 'Content-Type': 'application/json' },\n          body: JSON.stringify({\n            client_id: CLIENT_ID,\n            token,\n            token_type_hint: hint,\n          }),\n        });\n        // RFC 7009 §2.2: the server responds with 200 even if the token was already invalid\n        if (response.ok) {\n          this.logger.info({ hint }, 'OAuth token revoked on server');\n          revoked = true;\n        } else {\n          const errorText = await response.text();\n          this.logger.warn({ hint, status: response.status, error: errorText }, 'OAuth token revocation returned non-OK');\n        }\n      } catch (err) {\n        this.logger.warn({ err, hint }, 'OAuth token revocation request failed');\n      }\n    }\n\n    this.logger.info({ revoked }, 'OAuth disconnect complete, local tokens cleared');\n    return { revoked };\n  }\n\n  clearTokens(): void {\n    this.tokens = null;\n    this.pendingStates.clear();\n    this.logger.info('OAuth tokens cleared');\n  }\n\n  /**\n   * Stop the background sweep timer. Call on shutdown.\n   */\n  dispose(): void {\n    if (this.sweepTimer) {\n      clearInterval(this.sweepTimer);\n      this.sweepTimer = null;\n    }\n  }\n}\n","numLines":482,"startLine":1,"totalLines":482}}}
