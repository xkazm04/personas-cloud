,  // Optional: use OAuth flow if not provided\n    57→    teamApiKey: required('TEAM_API_KEY'),\n    58→    workerToken: required('WORKER_TOKEN'),\n    59→    kafkaBrokers,\n    60→    kafkaUsername: process.env['KAFKA_USERNAME'] || '',\n    61→    kafkaPassword: process.env['KAFKA_PASSWORD'] || '',\n    62→    kafkaEnabled: kafkaBrokers.length > 0,\n    63→    supabaseJwtSecret: process.env['SUPABASE_JWT_SECRET'] || '',\n    64→    wsPort: parseInt(optional('WS_PORT', '8443'), 10),\n    65→    httpPort: parseInt(optional('HTTP_PORT', '3001'), 10),\n    66→    // TLS\n    67→    tlsEnabled: process.env['TLS_ENABLED'] !== 'false',\n    68→    tlsCertPath: process.env['TLS_CERT_PATH'] || '',\n    69→    tlsKeyPath: process.env['TLS_KEY_PATH'] || '',\n    70→    tlsCaPath: process.env['TLS_CA_PATH'] || '',\n    71→    tlsRequireClientCert: process.env['TLS_REQUIRE_CLIENT_CERT'] === 'true',\n    72→    // Output scrubbing\n    73→    scrubberEnabled: process.env['SCRUBBER_ENABLED'] !== 'false',\n    74→    // Audit\n    75→    auditDbPath: process.env['AUDIT_DB_PATH'] || path.join(dataDir, 'audit.db'),\n    76→    auditRetentionDays: parseInt(process.env['AUDIT_RETENTION_DAYS'] || '90', 10),\n    77→    // Retention\n    78→    retentionDays: parseInt(process.env['RETENTION_DAYS'] || '30', 10),\n    79→    metricsRetentionDays: parseInt(process.env['METRICS_RETENTION_DAYS'] || '365', 10),\n    80→    // Data directory\n    81→    dataDir,\n    82→    // Worker verification\n    83→    allowedImageDigests: (process.env['ALLOWED_IMAGE_DIGESTS'] || '').split(',').map(s => s.trim()).filter(Boolean),\n    84→    rejectUnverifiedWorkers: process.env['REJECT_UNVERIFIED_WORKERS'] === 'true',\n    85→  };\n    86→}\n    87→"}]},"parent_tool_use_id":null,"session_id":"adf496b3-ac51-4f38-86e9-3023c5ab424c","uuid":"f1938dc8-8232-46ca-8d4e-00abde6520a2","timestamp":"2026-03-18T11:42:53.924Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\config.ts","content":"import 'dotenv/config';\nimport path from 'node:path';\n\nexport interface OrchestratorConfig {\n  masterKey: string;\n  claudeToken: string;\n  teamApiKey: string;\n  workerToken: string;\n  kafkaBrokers: string;\n  kafkaUsername: string;\n  kafkaPassword: string;\n  kafkaEnabled: boolean;\n  supabaseJwtSecret: string;\n  wsPort: number;\n  httpPort: number;\n  // TLS\n  tlsEnabled: boolean;\n  tlsCertPath: string;\n  tlsKeyPath: string;\n  tlsCaPath: string;\n  tlsRequireClientCert: boolean;\n  // Output scrubbing\n  scrubberEnabled: boolean;\n  // Audit\n  auditDbPath: string;\n  auditRetentionDays: number;\n  // Retention\n  retentionDays: number;\n  metricsRetentionDays: number;\n  // Data directory\n  dataDir: string;\n  // Worker verification\n  allowedImageDigests: string[];\n  rejectUnverifiedWorkers: boolean;\n}\n\nfunction required(name: string): string {\n  const value = process.env[name];\n  if (!value) {\n    throw new Error(`Missing required environment variable: ${name}`);\n  }\n  return value;\n}\n\nfunction optional(name: string, fallback: string): string {\n  return process.env[name] || fallback;\n}\n\nexport function loadConfig(): OrchestratorConfig {\n  const kafkaBrokers = process.env['KAFKA_BROKERS'] || '';\n\n  const dataDir = process.env['DAC_DATA_DIR'] || path.join(process.cwd(), 'data');\n\n  return {\n    masterKey: required('MASTER_KEY'),\n    claudeToken: process.env['CLAUDE_TOKEN'] || '',  // Optional: use OAuth flow if not provided\n    teamApiKey: required('TEAM_API_KEY'),\n    workerToken: required('WORKER_TOKEN'),\n    kafkaBrokers,\n    kafkaUsername: process.env['KAFKA_USERNAME'] || '',\n    kafkaPassword: process.env['KAFKA_PASSWORD'] || '',\n    kafkaEnabled: kafkaBrokers.length > 0,\n    supabaseJwtSecret: process.env['SUPABASE_JWT_SECRET'] || '',\n    wsPort: parseInt(optional('WS_PORT', '8443'), 10),\n    httpPort: parseInt(optional('HTTP_PORT', '3001'), 10),\n    // TLS\n    tlsEnabled: process.env['TLS_ENABLED'] !== 'false',\n    tlsCertPath: process.env['TLS_CERT_PATH'] || '',\n    tlsKeyPath: process.env['TLS_KEY_PATH'] || '',\n    tlsCaPath: process.env['TLS_CA_PATH'] || '',\n    tlsRequireClientCert: process.env['TLS_REQUIRE_CLIENT_CERT'] === 'true',\n    // Output scrubbing\n    scrubberEnabled: process.env['SCRUBBER_ENABLED'] !== 'false',\n    // Audit\n    auditDbPath: process.env['AUDIT_DB_PATH'] || path.join(dataDir, 'audit.db'),\n    auditRetentionDays: parseInt(process.env['AUDIT_RETENTION_DAYS'] || '90', 10),\n    // Retention\n    retentionDays: parseInt(process.env['RETENTION_DAYS'] || '30', 10),\n    metricsRetentionDays: parseInt(process.env['METRICS_RETENTION_DAYS'] || '365', 10),\n    // Data directory\n    dataDir,\n    // Worker verification\n    allowedImageDigests: (process.env['ALLOWED_IMAGE_DIGESTS'] || '').split(',').map(s => s.trim()).filter(Boolean),\n    rejectUnverifiedWorkers: process.env['REJECT_UNVERIFIED_WORKERS'] === 'true',\n  };\n}\n","numLines":87,"startLine":1,"totalLines":87}}}
