[2026-03-18T17:42:34.863Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017L96a1hXxCXs9s34VkAnvs","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import * as db from './db/index.js';\n     4→import type { TenantDbManager } from './tenantDbManager.js';\n     5→\n     6→/**\n     7→ * Start the trigger scheduler loop.\n     8→ * Supports both tenant-isolated DBs (via TenantDbManager) and legacy single DB.\n     9→ */\n    10→export function startTriggerScheduler(\n    11→  database: Database.Database | null,\n    12→  logger: Logger,\n    13→  interval: number = 5000,\n    14→  tenantDbManager?: TenantDbManager,\n    15→  onEventPublished?: () => void,\n    16→): NodeJS.Timeout {\n    17→  logger.info({ intervalMs: interval, tenantIsolated: !!tenantDbManager }, 'Trigger scheduler started');\n    18→\n    19→  return setInterval(() => {\n    20→    try {\n    21→      if (tenantDbManager) {\n    22→        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    23→          try {\n    24→            triggerSchedulerTick(tenantDb, logger, projectId, onEventPublished);\n    25→          } catch (err) {\n    26→            logger.error({ err, projectId }, 'Trigger scheduler tick failed for tenant');\n    27→          }\n    28→        });\n    29→      } else if (database) {\n    30→        triggerSchedulerTick(database, logger, undefined, onEventPublished);\n    31→      }\n    32→    } catch (err) {\n    33→      logger.error({ err }, 'Trigger scheduler tick failed');\n    34→    }\n    35→  }, interval);\n    36→}\n    37→\n    38→function triggerSchedulerTick(\n    39→  database: Database.Database,\n    40→  logger: Logger,\n    41→  projectId?: string,\n    42→  onEventPublished?: () => void,\n    43→): void {\n    44→  const triggers = db.getDueTriggersWithPersona(database);\n    45→  if (triggers.length === 0) return;\n    46→\n    47→  for (const trigger of triggers) {\n    48→    // Skip polling triggers (handled separately if needed)\n    49→    if (trigger.triggerType === 'polling') continue;\n    50→\n    51→    try {\n    52→      // Use pre-parsed typed config — no JSON.parse in the hot path\n    53→      const parsedConfig = trigger.parsedConfig;\n    54→\n    55→      let eventType = 'trigger_fired';\n    56→      let payload: string | null = null;\n    57→      if (parsedConfig) {\n    58→        if (parsedConfig.event_type) eventType = parsedConfig.event_type;\n    59→        if (parsedConfig.payload) payload = JSON.stringify(parsedConfig.payload);\n    60→      }\n    61→\n    62→      // Skip triggers for deleted or disabled personas (persona info from JOIN)\n    63→      if (trigger.personaProjectId == null) {\n    64→        logger.warn({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona not found (deleted?)');\n    65→        continue;\n    66→      }\n    67→      if (!trigger.personaEnabled) {\n    68→        logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');\n    69→        continue;\n    70→      }\n    71→\n    72→      const triggerProjectId = projectId ?? trigger.personaProjectId;\n    73→\n    74→      // Publish event to bus\n    75→      db.publishEvent(database, {\n    76→        eventType,\n    77→        sourceType: 'trigger',\n    78→        sourceId: trigger.id,\n    79→        targetPersonaId: trigger.personaId,\n    80→        projectId: triggerProjectId,\n    81→        useCaseId: trigger.useCaseId,\n    82→        payload,\n    83→      });\n    84→      onEventPublished?.();\n    85→\n    86→      // Compute next trigger time using already-parsed config\n    87→      const now = new Date().toISOString();\n    88→      const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);\n    89→\n    90→      db.updateTriggerTimings(database, trigger.id, now, nextTriggerAt);\n    91→\n    92→      logger.info({\n    93→        triggerId: trigger.id,\n    94→        personaId: trigger.personaId,\n    95→        eventType,\n    96→        nextTriggerAt,\n    97→      }, 'Trigger fired');\n    98→    } catch (err) {\n    99→      logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');\n   100→    }\n   101→  }\n   102→}\n   103→"}]},"parent_tool_use_id":null,"session_id":"94edd138-b98e-445e-81f3-4541be0bd2e3","uuid":"91b73044-9c89-4afd-9a7f-2b034caf51cb","timestamp":"2026-03-18T17:42:34.021Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\triggerScheduler.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\n\n/**\n * Start the trigger scheduler loop.\n * Supports both tenant-isolated DBs (via TenantDbManager) and legacy single DB.\n */\nexport function startTriggerScheduler(\n  database: Database.Database | null,\n  logger: Logger,\n  interval: number = 5000,\n  tenantDbManager?: TenantDbManager,\n  onEventPublished?: () => void,\n): NodeJS.Timeout {\n  logger.info({ intervalMs: interval, tenantIsolated: !!tenantDbManager }, 'Trigger scheduler started');\n\n  return setInterval(() => {\n    try {\n      if (tenantDbManager) {\n        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n          try {\n            triggerSchedulerTick(tenantDb, logger, projectId, onEventPublished);\n          } catch (err) {\n            logger.error({ err, projectId }, 'Trigger scheduler tick failed for tenant');\n          }\n        });\n      } else if (database) {\n        triggerSchedulerTick(database, logger, undefined, onEventPublished);\n      }\n    } catch (err) {\n      logger.error({ err }, 'Trigger scheduler tick failed');\n    }\n  }, interval);\n}\n\nfunction triggerSchedulerTick(\n  database: Database.Database,\n  logger: Logger,\n  projectId?: string,\n  onEventPublished?: () => void,\n): void {\n  const triggers = db.getDueTriggersWithPersona(database);\n  if (triggers.length === 0) return;\n\n  for (const trigger of triggers) {\n    // Skip polling triggers (handled separately if needed)\n    if (trigger.triggerType === 'polling') continue;\n\n    try {\n      // Use pre-parsed typed config — no JSON.parse in the hot path\n      const parsedConfig = trigger.parsedConfig;\n\n      let eventType = 'trigger_fired';\n      let payload: string | null = null;\n      if (parsedConfig) {\n        if (parsedConfig.event_type) eventType = parsedConfig.event_type;\n        if (parsedConfig.payload) payload = JSON.stringify(parsedConfig.payload);\n      }\n\n      // Skip triggers for deleted or disabled personas (persona info from JOIN)\n      if (trigger.personaProjectId == null) {\n        logger.warn({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona not found (deleted?)');\n        continue;\n      }\n      if (!trigger.personaEnabled) {\n        logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');\n        continue;\n      }\n\n      const triggerProjectId = projectId ?? trigger.personaProjectId;\n\n      // Publish event to bus\n      db.publishEvent(database, {\n        eventType,\n        sourceType: 'trigger',\n        sourceId: trigger.id,\n        targetPersonaId: trigger.personaId,\n        projectId: triggerProjectId,\n        useCaseId: trigger.useCaseId,\n        payload,\n      });\n      onEventPublished?.();\n\n      // Compute next trigger time using already-parsed config\n      const now = new Date().toISOString();\n      const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);\n\n      db.updateTriggerTimings(database, trigger.id, now, nextTriggerAt);\n\n      logger.info({\n        triggerId: trigger.id,\n        personaId: trigger.personaId,\n        eventType,\n        nextTriggerAt,\n      }, 'Trigger fired');\n    } catch (err) {\n      logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');\n    }\n  }\n}\n","numLines":103,"startLine":1,"totalLines":103}}}
