[2026-03-18T17:34:49.673Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JMdEZQvWed8bJYbXJNZ75C","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import fs from 'node:fs';\n     3→import path from 'node:path';\n     4→import crypto from 'node:crypto';\n     5→import type { Logger } from 'pino';\n     6→import { initTenantDb, initSystemDb } from './db/index.js';\n     7→\n     8→interface CachedDb {\n     9→  db: Database.Database;\n    10→  lastAccess: number;\n    11→}\n    12→\n    13→const IDLE_EVICT_MS = 10 * 60 * 1000; // 10 minutes\n    14→const EVICT_CHECK_MS = 60 * 1000;     // check every 1 minute\n    15→\n    16→/**\n    17→ * Manages per-tenant SQLite databases with connection pooling.\n    18→ *\n    19→ * Layout:\n    20→ *   {dataDir}/system.db           — tenant registry\n    21→ *   {dataDir}/tenants/{hash}.db   — per-tenant data\n    22→ *\n    23→ * The hash is derived from the projectId to produce safe filenames.\n    24→ */\n    25→export type TenantCreatedCallback = (tenantId: string) => void;\n    26→\n    27→export class TenantDbManager {\n    28→  private systemDb: Database.Database;\n    29→  private tenantDbs = new Map<string, CachedDb>();\n    30→  private tenantsDir: string;\n    31→  private evictTimer: NodeJS.Timeout;\n    32→  private onTenantCreated: TenantCreatedCallback | null = null;\n    33→\n    34→  constructor(\n    35→    private dataDir: string,\n    36→    private logger: Logger,\n    37→  ) {\n    38→    fs.mkdirSync(dataDir, { recursive: true });\n    39→    this.tenantsDir = path.join(dataDir, 'tenants');\n    40→    fs.mkdirSync(this.tenantsDir, { recursive: true });\n    41→\n    42→    // Initialize system DB\n    43→    const systemDbPath = path.join(dataDir, 'system.db');\n    44→    this.systemDb = initSystemDb(systemDbPath, logger);\n    45→\n    46→    // Idle eviction loop\n    47→    this.evictTimer = setInterval(() => this.evictIdle(), EVICT_CHECK_MS);\n    48→  }\n    49→\n    50→  /**\n    51→   * Register a callback invoked when a new tenant is first registered.\n    52→   */\n    53→  setTenantCreatedCallback(cb: TenantCreatedCallback): void {\n    54→    this.onTenantCreated = cb;\n    55→  }\n    56→\n    57→  getSystemDb(): Database.Database {\n    58→    return this.systemDb;\n    59→  }\n    60→\n    61→  /**\n    62→   * Get (or create) a tenant-specific database.\n    63→   * Automatically registers the tenant in system.db on first access.\n    64→   */\n    65→  getTenantDb(projectId: string): Database.Database {\n    66→    const cached = this.tenantDbs.get(projectId);\n    67→    if (cached) {\n    68→      cached.lastAccess = Date.now();\n    69→      return cached.db;\n    70→    }\n    71→\n    72→    // Create/open tenant DB\n    73→    const hash = this.hashProjectId(projectId);\n    74→    const dbPath = path.join(this.tenantsDir, `${hash}.db`);\n    75→    const db = initTenantDb(dbPath, this.logger);\n    76→\n    77→    this.tenantDbs.set(projectId, { db, lastAccess: Date.now() });\n    78→\n    79→    // Register in system DB if not already present\n    80→    this.registerTenant(projectId);\n    81→\n    82→    this.logger.info({ projectId, dbPath }, 'Tenant database opened');\n    83→    return db;\n    84→  }\n    85→\n    86→  /**\n    87→   * List all registered tenant IDs from the system DB.\n    88→   */\n    89→  listTenantIds(): string[] {\n    90→    const rows = this.systemDb\n    91→      .prepare('SELECT id FROM tenants ORDER BY id')\n    92→      .all() as Array<{ id: string }>;\n    93→    return rows.map(r => r.id);\n    94→  }\n    95→\n    96→  /**\n    97→   * Execute a function against every tenant's database.\n    98→   * Opens DBs as needed (and caches them).\n    99→   */\n   100→  forEachTenant(fn: (db: Database.Database, projectId: string) => void): void {\n   101→    const ids = this.listTenantIds();\n   102→    for (const id of ids) {\n   103→      try {\n   104→        const db = this.getTenantDb(id);\n   105→        fn(db, id);\n   106→      } catch (err) {\n   107→        this.logger.error({ err, projectId: id }, 'Error processing tenant');\n   108→      }\n   109→    }\n   110→  }\n   111→\n   112→  /**\n   113→   * Close all database connections and stop eviction timer.\n   114→   */\n   115→  close(): void {\n   116→    clearInterval(this.evictTimer);\n   117→\n   118→    for (const [projectId, cached] of this.tenantDbs) {\n   119→      try {\n   120→        cached.db.close();\n   121→        this.logger.debug({ projectId }, 'Tenant database closed');\n   122→      } catch { /* best effort */ }\n   123→    }\n   124→    this.tenantDbs.clear();\n   125→\n   126→    try {\n   127→      this.systemDb.close();\n   128→    } catch { /* best effort */ }\n   129→  }\n   130→\n   131→  private registerTenant(projectId: string): void {\n   132→    const existing = this.systemDb\n   133→      .prepare('SELECT id FROM tenants WHERE id = ?')\n   134→      .get(projectId);\n   135→\n   136→    if (!existing) {\n   137→      this.systemDb\n   138→        .prepare('INSERT INTO tenants (id, created_at) VALUES (?, ?)')\n   139→        .run(projectId, new Date().toISOString());\n   140→      this.logger.info({ projectId }, 'Tenant registered in system DB');\n   141→      this.onTenantCreated?.(projectId);\n   142→    }\n   143→  }\n   144→\n   145→  private hashProjectId(projectId: string): string {\n   146→    return crypto.createHash('sha256').update(projectId).digest('hex').slice(0, 16);\n   147→  }\n   148→\n   149→  private evictIdle(): void {\n   150→    const now = Date.now();\n   151→    for (const [projectId, cached] of this.tenantDbs) {\n   152→      if (now - cached.lastAccess > IDLE_EVICT_MS) {\n   153→        try {\n   154→          cached.db.close();\n   155→          this.tenantDbs.delete(projectId);\n   156→          this.logger.debug({ projectId }, 'Evicted idle tenant database');\n   157→        } catch (err) {\n   158→          this.logger.warn({ err, projectId }, 'Failed to evict tenant database');\n   159→        }\n   160→      }\n   161→    }\n   162→  }\n   163→}\n   164→"}]},"parent_tool_use_id":"toolu_019H9AKvJpr2AwrJL9WNJXAn","session_id":"6514e5c3-f34b-45a0-bfca-f77eb10eda6a","uuid":"6737a884-029e-4c46-8ca0-731729e32cd5","timestamp":"2026-03-18T17:34:49.594Z"}
