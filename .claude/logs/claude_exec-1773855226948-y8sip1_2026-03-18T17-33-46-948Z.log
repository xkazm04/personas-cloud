w.duration);\n    }\n\n    db.prepare(`\n      INSERT INTO retention_watermark (key, last_rowid) VALUES ('executions', ?)\n      ON CONFLICT(key) DO UPDATE SET last_rowid = excluded.last_rowid\n    `).run(newWatermark);\n\n    return rows.length;\n  })();\n\n  // ── Step 2: Delete execution rows using pre-collected rowids ──────","newString":"  // ── Batched index scan: collect purgeable execution rowids in chunks ──\n  // The delete step operates on this pre-collected set.  Metrics are\n  // recorded incrementally in updateExecution() on terminal status\n  // transitions, so no aggregation is needed here.\n  db.exec('CREATE TEMP TABLE IF NOT EXISTS _ret_ids (id INTEGER PRIMARY KEY)');\n  db.prepare('DELETE FROM _ret_ids').run();\n  {\n    const collectStmt = db.prepare(`\n      INSERT INTO _ret_ids (id)\n      SELECT rowid FROM persona_executions\n      WHERE rowid > ? AND created_at < ? AND status IN ('completed', 'failed', 'cancelled')\n      ORDER BY rowid\n      LIMIT ?\n    `);\n    let cursor = 0;\n    while (true) {\n      const result = collectStmt.run(cursor, cutoff, PURGE_CHUNK_SIZE);\n      if (result.changes === 0) break;\n      const maxRow = db.prepare('SELECT MAX(id) as m FROM _ret_ids').get() as { m: number };\n      cursor = maxRow.m;\n      if (result.changes < PURGE_CHUNK_SIZE) break;\n      await yieldTick();\n    }\n  }\n\n  // ── Step 1: Delete execution rows using pre-collected rowids ──────","originalFile":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport { getTableSpec, isMetrizable, isEphemeral } from '@dac-cloud/shared';\nimport type { MetrizableTableSpec, EphemeralTableSpec } from '@dac-cloud/shared';\nimport type { TenantDbManager } from './tenantDbManager.js';\n\n// Validate registry classification at import time — if someone changes the\n// registry without updating this module the build still passes but the runtime\n// assertion catches the mismatch immediately.\nconst execSpec = getTableSpec('persona_executions');\nconst eventsSpec = getTableSpec('persona_events');\nif (!execSpec || !isMetrizable(execSpec)) {\n  throw new Error('persona_executions must be registered as metrizable in TABLE_REGISTRY');\n}\nif (!eventsSpec || !isEphemeral(eventsSpec)) {\n  throw new Error('persona_events must be registered as ephemeral in TABLE_REGISTRY');\n}\n\n/** Maximum fraction of rows a single purge cycle may delete (safety cap). */\nconst EXEC_MAX_PURGE_FRACTION = (execSpec as MetrizableTableSpec).maxPurgeFraction ?? 0.8;\nconst EVENTS_MAX_PURGE_FRACTION = (eventsSpec as EphemeralTableSpec).maxPurgeFraction ?? 0.8;\n\n/** Rows deleted per chunk to keep individual lock durations short (~50ms). */\nconst PURGE_CHUNK_SIZE = 5000;\n\n/** Yield the event loop so concurrent reads/writes can proceed between batches. */\nfunction yieldTick(): Promise<void> {\n  return new Promise((resolve) => setImmediate(resolve));\n}\n\n/** How often we check whether it's time for the daily run (60 seconds). */\nconst SCHEDULE_CHECK_MS = 60_000;\n\n/** system_kv key used to persist the last successful run date (UTC). */\nconst LAST_RUN_KEY = 'retention_last_run_date';\n\n/** Return today's UTC date as YYYY-MM-DD. */\nfunction utcToday(): string {\n  return new Date().toISOString().slice(0, 10);\n}\n\n/** Read the last-run UTC date from system_kv, or null if never run. */\nfunction getLastRunDate(tenantDbManager: TenantDbManager): string | null {\n  const row = tenantDbManager.getSystemDb().prepare(\n    'SELECT value FROM system_kv WHERE key = ?',\n  ).get(LAST_RUN_KEY) as { value: string } | undefined;\n  return row?.value ?? null;\n}\n\n/** Persist the current UTC date as the last-run date. */\nfunction setLastRunDate(tenantDbManager: TenantDbManager, date: string): void {\n  tenantDbManager.getSystemDb().prepare(\n    'INSERT INTO system_kv (key, value) VALUES (?, ?) ON CONFLICT(key) DO UPDATE SET value = excluded.value',\n  ).run(LAST_RUN_KEY, date);\n}\n\n/**\n * Daily retention job: purge old executions/events and aggregate daily metrics.\n *\n * Uses a 60-second wall-clock poll instead of a drifting 24-hour setInterval.\n * The last successful run date is persisted in system_kv so the job runs\n * exactly once per UTC calendar day regardless of restarts or event-loop delays.\n */\nexport function startRetentionJob(\n  tenantDbManager: TenantDbManager,\n  retentionDays: number,\n  logger: Logger,\n): NodeJS.Timeout {\n  logger.info({ retentionDays }, 'Retention job scheduled (wall-clock daily)');\n\n  let running = false;\n\n  async function tick(): Promise<void> {\n    if (running) return;\n\n    const today = utcToday();\n    const lastRun = getLastRunDate(tenantDbManager);\n\n    if (lastRun === today) return; // already ran today\n\n    running = true;\n    logger.info({ today, lastRun }, 'Retention job triggered');\n    try {\n      await runRetention(tenantDbManager, retentionDays, logger);\n      setLastRunDate(tenantDbManager, today);\n      logger.info({ today }, 'Retention job completed, next run tomorrow');\n    } catch (err) {\n      logger.error({ err }, 'Retention job failed — will retry next tick');\n    } finally {\n      running = false;\n    }\n  }\n\n  // First check shortly after startup, then every 60 seconds\n  setTimeout(() => tick(), 5000);\n\n  return setInterval(() => {\n    tick();\n  }, SCHEDULE_CHECK_MS);\n}\n\n/**\n * Delete rows in chunks of PURGE_CHUNK_SIZE, yielding the event loop between\n * batches so other DB operations are not starved.\n */\nasync function chunkedDelete(db: Database.Database, sql: string, params: unknown[]): Promise<number> {\n  const stmt = db.prepare(sql);\n  let totalDeleted = 0;\n  while (true) {\n    const result = stmt.run(...params, PURGE_CHUNK_SIZE);\n    totalDeleted += result.changes;\n    if (result.changes < PURGE_CHUNK_SIZE) break;\n    await yieldTick();\n  }\n  return totalDeleted;\n}\n\nasync function runRetention(\n  tenantDbManager: TenantDbManager,\n  retentionDays: number,\n  logger: Logger,\n): Promise<void> {\n  const cutoff = new Date(Date.now() - retentionDays * 86_400_000).toISOString();\n\n  const tenantIds = tenantDbManager.listTenantIds();\n  for (const projectId of tenantIds) {\n    try {\n      const db = tenantDbManager.getTenantDb(projectId);\n      await runTenantRetention(db, projectId, cutoff, retentionDays, logger);\n    } catch (err) {\n      logger.error({ err, projectId }, 'Retention cleanup failed for tenant');\n    }\n    // Yield between tenants so the event loop stays responsive\n    await yieldTick();\n  }\n\n  // ── Reduce phase: aggregate all tenant metrics into system.db ──\n  try {\n    aggregateSystemMetrics(tenantDbManager, logger);\n  } catch (err) {\n    logger.error({ err }, 'System-wide metrics aggregation failed');\n  }\n}\n\n/**\n * Map-reduce step: read daily_metrics from every tenant DB and write\n * a system-wide summary to the system_daily_metrics table in system.db.\n * Replaces rows wholesale each run so the system view is always consistent.\n */\nfunction aggregateSystemMetrics(\n  tenantDbManager: TenantDbManager,\n  logger: Logger,\n): void {\n  const systemDb = tenantDbManager.getSystemDb();\n  const tenantIds = tenantDbManager.listTenantIds();\n\n  // Accumulate per-day totals across all tenants\n  const dayMap = new Map<string, {\n    total_executions: number;\n    completed: number;\n    failed: number;\n    total_cost_usd: number;\n    total_duration_ms: number;\n    tenant_count: number;\n  }>();\n\n  for (const projectId of tenantIds) {\n    try {\n      const db = tenantDbManager.getTenantDb(projectId);\n      const rows = db.prepare(\n        'SELECT date, total_executions, completed, failed, total_cost_usd, total_duration_ms FROM daily_metrics',\n      ).all() as Array<{\n        date: string;\n        total_executions: number;\n        completed: number;\n        failed: number;\n        total_cost_usd: number;\n        total_duration_ms: number;\n      }>;\n\n      for (const row of rows) {\n        const existing = dayMap.get(row.date);\n        if (existing) {\n          existing.total_executions += row.total_executions;\n          existing.completed += row.completed;\n          existing.failed += row.failed;\n          existing.total_cost_usd += row.total_cost_usd;\n          existing.total_duration_ms += row.total_duration_ms;\n          existing.tenant_count += 1;\n        } else {\n          dayMap.set(row.date, {\n            total_executions: row.total_executions,\n            completed: row.completed,\n            failed: row.failed,\n            total_cost_usd: row.total_cost_usd,\n            total_duration_ms: row.total_duration_ms,\n            tenant_count: 1,\n          });\n        }\n      }\n    } catch (err) {\n      logger.warn({ err, projectId }, 'Failed to read metrics for tenant during aggregation');\n    }\n  }\n\n  if (dayMap.size === 0) return;\n\n  // Write aggregated metrics in a single transaction\n  const now = new Date().toISOString();\n  systemDb.transaction(() => {\n    const upsert = systemDb.prepare(`\n      INSERT INTO system_daily_metrics\n        (date, total_executions, completed, failed, total_cost_usd, total_duration_ms, tenant_count, aggregated_at)\n      VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n      ON CONFLICT(date) DO UPDATE SET\n        total_executions = excluded.total_executions,\n        completed = excluded.completed,\n        failed = excluded.failed,\n        total_cost_usd = excluded.total_cost_usd,\n        total_duration_ms = excluded.total_duration_ms,\n        tenant_count = excluded.tenant_count,\n        aggregated_at = excluded.aggregated_at\n    `);\n    for (const [date, m] of dayMap) {\n      upsert.run(date, m.total_executions, m.completed, m.failed, m.total_cost_usd, m.total_duration_ms, m.tenant_count, now);\n    }\n  })();\n\n  logger.info({ days: dayMap.size, tenants: tenantIds.length }, 'System-wide metrics aggregation complete');\n}\n\nasync function runTenantRetention(\n  db: Database.Database,\n  projectId: string,\n  cutoff: string,\n  retentionDays: number,\n  logger: Logger,\n): Promise<void> {\n  // ── Batched index scan: collect purgeable execution rowids in chunks ──\n  // Both the aggregation (Step 1) and the delete (Step 2) operate on\n  // this pre-collected set instead of scanning persona_executions twice.\n  // The collection itself is batched to avoid holding a write lock while\n  // inserting millions of rowids after a long retention gap.\n  db.exec('CREATE TEMP TABLE IF NOT EXISTS _ret_ids (id INTEGER PRIMARY KEY)');\n  db.prepare('DELETE FROM _ret_ids').run();\n  {\n    const collectStmt = db.prepare(`\n      INSERT INTO _ret_ids (id)\n      SELECT rowid FROM persona_executions\n      WHERE rowid > ? AND created_at < ? AND status IN ('completed', 'failed', 'cancelled')\n      ORDER BY rowid\n      LIMIT ?\n    `);\n    let cursor = 0;\n    while (true) {\n      const result = collectStmt.run(cursor, cutoff, PURGE_CHUNK_SIZE);\n      if (result.changes === 0) break;\n      const maxRow = db.prepare('SELECT MAX(id) as m FROM _ret_ids').get() as { m: number };\n      cursor = maxRow.m;\n      if (result.changes < PURGE_CHUNK_SIZE) break;\n      await yieldTick();\n    }\n  }\n\n  // ── Step 1: Aggregate metrics in a short transaction ──────────────\n  // Watermark-based: each source row is counted exactly once, so the\n  // additive upsert is safe even if a previous run crashed mid-delete.\n  // No heavy deletes here — lock duration is brief.\n  const aggregatedDays = db.transaction(() => {\n    const watermarkRow = db.prepare(\n      \"SELECT last_rowid FROM retention_watermark WHERE key = 'executions'\",\n    ).get() as { last_rowid: number } | undefined;\n    const lastRowid = watermarkRow?.last_rowid ?? 0;\n\n    // Max rowid above the watermark (reads temp table only, no main-table scan)\n    const maxRow = db.prepare(\n      'SELECT MAX(id) as max_rowid FROM _ret_ids WHERE id > ?',\n    ).get(lastRowid) as { max_rowid: number | null } | undefined;\n    const newWatermark = maxRow?.max_rowid ?? lastRowid;\n\n    // Aggregate only never-before-counted rows. The JOIN fetches data columns\n    // via direct rowid B-tree lookups rather than a redundant index range scan.\n    const rows = db.prepare(`\n      SELECT\n        date(pe.created_at) as day,\n        COUNT(*) as total,\n        SUM(CASE WHEN pe.status = 'completed' THEN 1 ELSE 0 END) as completed,\n        SUM(CASE WHEN pe.status = 'failed' THEN 1 ELSE 0 END) as failed,\n        COALESCE(SUM(pe.cost_usd), 0) as cost,\n        COALESCE(SUM(pe.duration_ms), 0) as duration\n      FROM _ret_ids r\n      JOIN persona_executions pe ON pe.rowid = r.id\n      WHERE r.id > ?\n      GROUP BY date(pe.created_at)\n    `).all(lastRowid) as Array<{ day: string; total: number; completed: number; failed: number; cost: number; duration: number }>;\n\n    const upsertStmt = db.prepare(`\n      INSERT INTO daily_metrics (date, total_executions, completed, failed, total_cost_usd, total_duration_ms)\n      VALUES (?, ?, ?, ?, ?, ?)\n      ON CONFLICT(date) DO UPDATE SET\n        total_executions = total_executions + excluded.total_executions,\n        completed = completed + excluded.completed,\n        failed = failed + excluded.failed,\n        total_cost_usd = total_cost_usd + excluded.total_cost_usd,\n        total_duration_ms = total_duration_ms + excluded.total_duration_ms\n    `);\n    for (const row of rows) {\n      upsertStmt.run(row.day, row.total, row.completed, row.failed, row.cost, row.duration);\n    }\n\n    db.prepare(`\n      INSERT INTO retention_watermark (key, last_rowid) VALUES ('executions', ?)\n      ON CONFLICT(key) DO UPDATE SET last_rowid = excluded.last_rowid\n    `).run(newWatermark);\n\n    return rows.length;\n  })();\n\n  // ── Step 2: Delete execution rows using pre-collected rowids ──────\n  // Pre-purge sanity check: refuse to delete more than EXEC_MAX_PURGE_FRACTION of all rows\n  const execTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_executions').get() as { cnt: number };\n  const execCandidateRow = db.prepare('SELECT COUNT(*) as cnt FROM _ret_ids').get() as { cnt: number };\n\n  let purgedExecutions = 0;\n  if (execTotalRow.cnt > 0 && execCandidateRow.cnt / execTotalRow.cnt > EXEC_MAX_PURGE_FRACTION) {\n    logger.error(\n      { projectId, total: execTotalRow.cnt, candidates: execCandidateRow.cnt, cutoff, maxFraction: EXEC_MAX_PURGE_FRACTION },\n      'Execution purge aborted: deletion would exceed safety cap',\n    );\n  } else {\n    // Each chunk is its own implicit transaction (~50ms lock), with event-loop\n    // yields between chunks so concurrent operations can proceed.\n    const deleteStmt = db.prepare(\n      'DELETE FROM persona_executions WHERE rowid IN (SELECT id FROM _ret_ids LIMIT ?)',\n    );\n    const trimStmt = db.prepare(\n      'DELETE FROM _ret_ids WHERE id IN (SELECT id FROM _ret_ids LIMIT ?)',\n    );\n    while (true) {\n      const result = deleteStmt.run(PURGE_CHUNK_SIZE);\n      purgedExecutions += result.changes;\n      trimStmt.run(PURGE_CHUNK_SIZE);\n      if (result.changes < PURGE_CHUNK_SIZE) break;\n      await yieldTick();\n    }\n  }\n\n  // ── Step 3: Purge old events in batched chunks ────────────────────\n  // Pre-purge sanity check for events\n  const eventsTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_events').get() as { cnt: number };\n  const eventsCandidateRow = db.prepare(\n    \"SELECT COUNT(*) as cnt FROM persona_events WHERE created_at < ?\",\n  ).get(cutoff) as { cnt: number };\n\n  let purgedEvents = 0;\n  let purgedStuckEvents = 0;\n  if (eventsTotalRow.cnt > 0 && eventsCandidateRow.cnt / eventsTotalRow.cnt > EVENTS_MAX_PURGE_FRACTION) {\n    logger.error(\n      { projectId, total: eventsTotalRow.cnt, candidates: eventsCandidateRow.cnt, cutoff, maxFraction: EVENTS_MAX_PURGE_FRACTION },\n      'Event purge aborted: deletion would exceed safety cap',\n    );\n  } else {\n    purgedEvents = await chunkedDelete(\n      db,\n      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status NOT IN ('pending', 'processing', 'partial-retry') LIMIT ?)\",\n      [cutoff],\n    );\n\n    // Safety net: purge stuck pending/processing/partial-retry events older than 7x retentionDays.\n    const stuckCutoff = new Date(Date.now() - retentionDays * 7 * 86_400_000).toISOString();\n    purgedStuckEvents = await chunkedDelete(\n      db,\n      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status IN ('pending', 'processing', 'partial-retry') LIMIT ?)\",\n      [stuckCutoff],\n    );\n  }\n\n  if (purgedExecutions > 0 || purgedEvents > 0 || purgedStuckEvents > 0) {\n    logger.info({\n      projectId,\n      purgedExecutions,\n      purgedEvents,\n      purgedStuckEvents,\n      aggregatedDays,\n    }, 'Retention cleanup complete');\n  }\n}\n","structuredPatch":[{"oldStart":237,"oldLines":10,"newStart":237,"newLines":9,"lines":["   logger: Logger,"," ): Promise<void> {","   // ── Batched index scan: collect purgeable execution rowids in chunks ──","-  // Both the aggregation (Step 1) and the delete (Step 2) operate on","-  // this pre-collected set instead of scanning persona_executions twice.","-  // The collection itself is batched to avoid holding a write lock while","-  // inserting millions of rowids after a long retention gap.","+  // The delete step operates on this pre-collected set.  Metrics are","+  // recorded incrementally in updateExecution() on terminal status","+  // transitions, so no aggregation is needed here.","   db.exec('CREATE TEMP TABLE IF NOT EXISTS _ret_ids (id INTEGER PRIMARY KEY)');","   db.prepare('DELETE FROM _ret_ids').run();","   {"]},{"oldStart":262,"oldLines":61,"newStart":261,"newLines":7,"lines":["     }","   }"," ","-  // ── Step 1: Aggregate metrics in a short transaction ──────────────","-  // Watermark-based: each source row i