   269→  let purgedExecutions = 0;\n   270→  if (execTotalRow.cnt > 0 && execCandidateRow.cnt / execTotalRow.cnt > EXEC_MAX_PURGE_FRACTION) {\n   271→    logger.error(\n   272→      { projectId, total: execTotalRow.cnt, candidates: execCandidateRow.cnt, cutoff, maxFraction: EXEC_MAX_PURGE_FRACTION },\n   273→      'Execution purge aborted: deletion would exceed safety cap',\n   274→    );\n   275→  } else {\n   276→    // Each chunk is its own implicit transaction (~50ms lock), with event-loop\n   277→    // yields between chunks so concurrent operations can proceed.\n   278→    const deleteStmt = db.prepare(\n   279→      'DELETE FROM persona_executions WHERE rowid IN (SELECT id FROM _ret_ids LIMIT ?)',\n   280→    );\n   281→    const trimStmt = db.prepare(\n   282→      'DELETE FROM _ret_ids WHERE id IN (SELECT id FROM _ret_ids LIMIT ?)',\n   283→    );\n   284→    while (true) {\n   285→      const result = deleteStmt.run(PURGE_CHUNK_SIZE);\n   286→      purgedExecutions += result.changes;\n   287→      trimStmt.run(PURGE_CHUNK_SIZE);\n   288→      if (result.changes < PURGE_CHUNK_SIZE) break;\n   289→      await yieldTick();\n   290→    }\n   291→  }\n   292→\n   293→  // ── Step 2: Purge old events in batched chunks ────────────────────\n   294→  // Pre-purge sanity check for events\n   295→  const eventsTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_events').get() as { cnt: number };\n   296→  const eventsCandidateRow = db.prepare(\n   297→    \"SELECT COUNT(*) as cnt FROM persona_events WHERE created_at < ?\",\n   298→  ).get(cutoff) as { cnt: number };\n   299→\n   300→  let purgedEvents = 0;\n   301→  let purgedStuckEvents = 0;\n   302→  if (eventsTotalRow.cnt > 0 && eventsCandidateRow.cnt / eventsTotalRow.cnt > EVENTS_MAX_PURGE_FRACTION) {\n   303→    logger.error(\n   304→      { projectId, total: eventsTotalRow.cnt, candidates: eventsCandidateRow.cnt, cutoff, maxFraction: EVENTS_MAX_PURGE_FRACTION },\n   305→      'Event purge aborted: deletion would exceed safety cap',\n   306→    );\n   307→  } else {\n   308→    purgedEvents = await chunkedDelete(\n   309→      db,\n   310→      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status NOT IN ('pending', 'processing', 'partial-retry') LIMIT ?)\",\n   311→      [cutoff],\n   312→    );\n   313→\n   314→    // Safety net: purge stuck pending/processing/partial-retry events older than 7x retentionDays.\n   315→    const stuckCutoff = new Date(Date.now() - retentionDays * 7 * 86_400_000).toISOString();\n   316→    purgedStuckEvents = await chunkedDelete(\n   317→      db,\n   318→      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status IN ('pending', 'processing', 'partial-retry') LIMIT ?)\",\n   319→      [stuckCutoff],\n   320→    );\n   321→  }\n   322→\n   323→  if (purgedExecutions > 0 || purgedEvents > 0 || purgedStuckEvents > 0) {\n   324→    logger.info({\n   325→      projectId,\n   326→      purgedExecutions,\n   327→      purgedEvents,\n   328→      purgedStuckEvents,\n   329→    }, 'Retention cleanup complete');\n   330→  }\n   331→}"}]},"parent_tool_use_id":null,"session_id":"6514e5c3-f34b-45a0-bfca-f77eb10eda6a","uuid":"86f6a2e3-333c-4575-9395-f0c3b32cf1a4","timestamp":"2026-03-18T17:37:55.183Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\retention.ts","content":"async function runTenantRetention(\n  db: Database.Database,\n  projectId: string,\n  cutoff: string,\n  retentionDays: number,\n  logger: Logger,\n): Promise<void> {\n  // ── Batched index scan: collect purgeable execution rowids in chunks ──\n  // The delete step operates on this pre-collected set.  Metrics are\n  // recorded incrementally in updateExecution() on terminal status\n  // transitions, so no aggregation is needed here.\n  db.exec('CREATE TEMP TABLE IF NOT EXISTS _ret_ids (id INTEGER PRIMARY KEY)');\n  db.prepare('DELETE FROM _ret_ids').run();\n  {\n    const collectStmt = db.prepare(`\n      INSERT INTO _ret_ids (id)\n      SELECT rowid FROM persona_executions\n      WHERE rowid > ? AND created_at < ? AND status IN ('completed', 'failed', 'cancelled')\n      ORDER BY rowid\n      LIMIT ?\n    `);\n    let cursor = 0;\n    while (true) {\n      const result = collectStmt.run(cursor, cutoff, PURGE_CHUNK_SIZE);\n      if (result.changes === 0) break;\n      const maxRow = db.prepare('SELECT MAX(id) as m FROM _ret_ids').get() as { m: number };\n      cursor = maxRow.m;\n      if (result.changes < PURGE_CHUNK_SIZE) break;\n      await yieldTick();\n    }\n  }\n\n  // ── Step 1: Delete execution rows using pre-collected rowids ──────\n  // Pre-purge sanity check: refuse to delete more than EXEC_MAX_PURGE_FRACTION of all rows\n  const execTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_executions').get() as { cnt: number };\n  const execCandidateRow = db.prepare('SELECT COUNT(*) as cnt FROM _ret_ids').get() as { cnt: number };\n\n  let purgedExecutions = 0;\n  if (execTotalRow.cnt > 0 && execCandidateRow.cnt / execTotalRow.cnt > EXEC_MAX_PURGE_FRACTION) {\n    logger.error(\n      { projectId, total: execTotalRow.cnt, candidates: execCandidateRow.cnt, cutoff, maxFraction: EXEC_MAX_PURGE_FRACTION },\n      'Execution purge aborted: deletion would exceed safety cap',\n    );\n  } else {\n    // Each chunk is its own implicit transaction (~50ms lock), with event-loop\n    // yields between chunks so concurrent operations can proceed.\n    const deleteStmt = db.prepare(\n      'DELETE FROM persona_executions WHERE rowid IN (SELECT id FROM _ret_ids LIMIT ?)',\n    );\n    const trimStmt = db.prepare(\n      'DELETE FROM _ret_ids WHERE id IN (SELECT id FROM _ret_ids LIMIT ?)',\n    );\n    while (true) {\n      const result = deleteStmt.run(PURGE_CHUNK_SIZE);\n      purgedExecutions += result.changes;\n      trimStmt.run(PURGE_CHUNK_SIZE);\n      if (result.changes < PURGE_CHUNK_SIZE) break;\n      await yieldTick();\n    }\n  }\n\n  // ── Step 2: Purge old events in batched chunks ────────────────────\n  // Pre-purge sanity check for events\n  const eventsTotalRow = db.prepare('SELECT COUNT(*) as cnt FROM persona_events').get() as { cnt: number };\n  const eventsCandidateRow = db.prepare(\n    \"SELECT COUNT(*) as cnt FROM persona_events WHERE created_at < ?\",\n  ).get(cutoff) as { cnt: number };\n\n  let purgedEvents = 0;\n  let purgedStuckEvents = 0;\n  if (eventsTotalRow.cnt > 0 && eventsCandidateRow.cnt / eventsTotalRow.cnt > EVENTS_MAX_PURGE_FRACTION) {\n    logger.error(\n      { projectId, total: eventsTotalRow.cnt, candidates: eventsCandidateRow.cnt, cutoff, maxFraction: EVENTS_MAX_PURGE_FRACTION },\n      'Event purge aborted: deletion would exceed safety cap',\n    );\n  } else {\n    purgedEvents = await chunkedDelete(\n      db,\n      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status NOT IN ('pending', 'processing', 'partial-retry') LIMIT ?)\",\n      [cutoff],\n    );\n\n    // Safety net: purge stuck pending/processing/partial-retry events older than 7x retentionDays.\n    const stuckCutoff = new Date(Date.now() - retentionDays * 7 * 86_400_000).toISOString();\n    purgedStuckEvents = await chunkedDelete(\n      db,\n      \"DELETE FROM persona_events WHERE rowid IN (SELECT rowid FROM persona_events WHERE created_at < ? AND status IN ('pending', 'processing', 'partial-retry') LIMIT ?)\",\n      [stuckCutoff],\n    );\n  }\n\n  if (purgedExecutions > 0 || purgedEvents > 0 || purgedStuckEvents > 0) {\n    logger.info({\n      projectId,\n      purgedExecutions,\n      purgedEvents,\n      purgedStuckEvents,\n    }, 'Retention cleanup complete');\n  }\n}","numLines":100,"startLine":232,"totalLines":332}}}
