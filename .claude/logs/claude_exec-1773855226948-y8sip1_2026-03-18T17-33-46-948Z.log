[2026-03-18T17:34:51.684Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YBKcAg7qmrYYjXwPyeo7QW","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import { nanoid } from 'nanoid';\n     3→import { CronExpressionParser } from 'cron-parser';\n     4→import { z } from 'zod';\n     5→import type { PersonaTrigger, TriggerType, TriggerConfig } from '@dac-cloud/shared';\n     6→import { stmt, createRowMapper, mergeEnabled, mergeUpdate } from './_helpers.js';\n     7→\n     8→// ---------------------------------------------------------------------------\n     9→// Row mapper\n    10→// ---------------------------------------------------------------------------\n    11→\n    12→export const rowToTrigger = createRowMapper<PersonaTrigger>({\n    13→  id: { col: 'id' },\n    14→  personaId: { col: 'persona_id' },\n    15→  triggerType: { col: 'trigger_type' },\n    16→  config: { col: 'config', nullable: true },\n    17→  enabled: { col: 'enabled', bool: true },\n    18→  lastTriggeredAt: { col: 'last_triggered_at', nullable: true },\n    19→  nextTriggerAt: { col: 'next_trigger_at', nullable: true },\n    20→  useCaseId: { col: 'use_case_id', nullable: true },\n    21→  createdAt: { col: 'created_at' },\n    22→  updatedAt: { col: 'updated_at' },\n    23→});\n    24→\n    25→// ---------------------------------------------------------------------------\n    26→// Trigger config — Zod schemas & discriminated union\n    27→// ---------------------------------------------------------------------------\n    28→\n    29→const triggerConfigBase = z.object({\n    30→  event_type: z.string().optional(),\n    31→  payload: z.unknown().optional(),\n    32→});\n    33→\n    34→const scheduleTriggerConfigSchema = triggerConfigBase.extend({\n    35→  kind: z.literal('schedule'),\n    36→  cron: z.string().optional(),\n    37→  interval_seconds: z.number().positive().optional(),\n    38→});\n    39→\n    40→const manualTriggerConfigSchema = triggerConfigBase.extend({\n    41→  kind: z.literal('manual'),\n    42→});\n    43→\n    44→const pollingTriggerConfigSchema = triggerConfigBase.extend({\n    45→  kind: z.literal('polling'),\n    46→  poll_url: z.string().optional(),\n    47→  poll_interval_seconds: z.number().positive().optional(),\n    48→});\n    49→\n    50→const webhookTriggerConfigSchema = triggerConfigBase.extend({\n    51→  kind: z.literal('webhook'),\n    52→  url: z.string().optional(),\n    53→  secret: z.string().optional(),\n    54→});\n    55→\n    56→const chainTriggerConfigSchema = triggerConfigBase.extend({\n    57→  kind: z.literal('chain'),\n    58→  source_persona_id: z.string().optional(),\n    59→  source_event_type: z.string().optional(),\n    60→});\n    61→\n    62→const triggerConfigSchema = z.discriminatedUnion('kind', [\n    63→  scheduleTriggerConfigSchema,\n    64→  manualTriggerConfigSchema,\n    65→  pollingTriggerConfigSchema,\n    66→  webhookTriggerConfigSchema,\n    67→  chainTriggerConfigSchema,\n    68→]);\n    69→\n    70→const VALID_TRIGGER_TYPES = new Set<TriggerType>(['manual', 'schedule', 'polling', 'webhook', 'chain']);\n    71→\n    72→function coerceTriggerType(raw: string): TriggerType {\n    73→  if (!VALID_TRIGGER_TYPES.has(raw as TriggerType)) {\n    74→    throw new Error(`Invalid trigger type: ${raw}`);\n    75→  }\n    76→  return raw as TriggerType;\n    77→}\n    78→\n    79→/**\n    80→ * Validate and parse a raw config JSON string into a typed TriggerConfig.\n    81→ * If `triggerType` is provided, the `kind` discriminant is injected automatically\n    82→ * so callers don't need to include it in the stored JSON.\n    83→ */\n    84→export function parseTriggerConfig(\n    85→  config: string | null,\n    86→  triggerType?: TriggerType,\n    87→): TriggerConfig | null {\n    88→  if (!config) return null;\n    89→  try {\n    90→    const raw = JSON.parse(config) as Record<string, unknown>;\n    91→    // Inject `kind` from triggerType when not present in the JSON\n    92→    if (triggerType && !raw.kind) {\n    93→      raw.kind = triggerType;\n    94→    }\n    95→    return triggerConfigSchema.parse(raw);\n    96→  } catch {\n    97→    return null;\n    98→  }\n    99→}\n   100→"}]},"parent_tool_use_id":"toolu_019H9AKvJpr2AwrJL9WNJXAn","session_id":"6514e5c3-f34b-45a0-bfca-f77eb10eda6a","uuid":"21d620f3-c93b-4b19-9dda-9235c0cc4fa5","timestamp":"2026-03-18T17:34:51.588Z"}
