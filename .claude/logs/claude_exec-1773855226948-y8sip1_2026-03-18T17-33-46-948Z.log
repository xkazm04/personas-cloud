 TEXT NOT NULL,\n   109→  updated_at TEXT NOT NULL\n   110→);\n   111→\n   112→CREATE TABLE IF NOT EXISTS persona_tools (\n   113→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   114→  tool_id TEXT NOT NULL REFERENCES persona_tool_definitions(id) ON DELETE CASCADE,\n   115→  PRIMARY KEY (persona_id, tool_id)\n   116→);\n   117→\n   118→CREATE TABLE IF NOT EXISTS persona_credentials (\n   119→  id TEXT PRIMARY KEY,\n   120→  project_id TEXT NOT NULL DEFAULT 'default',\n   121→  name TEXT NOT NULL,\n   122→  service_type TEXT NOT NULL,\n   123→  encrypted_data TEXT NOT NULL,\n   124→  iv TEXT NOT NULL,\n   125→  tag TEXT NOT NULL,\n   126→  metadata TEXT,\n   127→  last_used_at TEXT,\n   128→  created_at TEXT NOT NULL,\n   129→  updated_at TEXT NOT NULL\n   130→);\n   131→\n   132→CREATE TABLE IF NOT EXISTS persona_credential_links (\n   133→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   134→  credential_id TEXT NOT NULL REFERENCES persona_credentials(id) ON DELETE CASCADE,\n   135→  PRIMARY KEY (persona_id, credential_id)\n   136→);\n   137→\n   138→CREATE TABLE IF NOT EXISTS persona_events (\n   139→  id TEXT PRIMARY KEY,\n   140→  project_id TEXT NOT NULL DEFAULT 'default',\n   141→  event_type TEXT NOT NULL,\n   142→  source_type TEXT NOT NULL,\n   143→  source_id TEXT,\n   144→  target_persona_id TEXT,\n   145→  payload TEXT,\n   146→  status TEXT NOT NULL DEFAULT 'pending' CHECK(status IN ('pending','processing','delivered','skipped','failed','partial','partial-retry')),\n   147→  error_message TEXT,\n   148→  processed_at TEXT,\n   149→  use_case_id TEXT,\n   150→  retry_after TEXT,\n   151→  retry_count INTEGER NOT NULL DEFAULT 0,\n   152→  created_at TEXT NOT NULL\n   153→);\n   154→CREATE INDEX IF NOT EXISTS idx_pe_status ON persona_events(status);\n   155→CREATE INDEX IF NOT EXISTS idx_pe_created_status ON persona_events(created_at, status);\n   156→\n   157→CREATE TABLE IF NOT EXISTS persona_event_subscriptions (\n   158→  id TEXT PRIMARY KEY,\n   159→  project_id TEXT NOT NULL DEFAULT 'default',\n   160→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   161→  event_type TEXT NOT NULL,\n   162→  source_filter TEXT,\n   163→  enabled INTEGER NOT NULL DEFAULT 1,\n   164→  use_case_id TEXT,\n   165→  created_at TEXT NOT NULL,\n   166→  updated_at TEXT NOT NULL\n   167→);\n   168→CREATE INDEX IF NOT EXISTS idx_pes_event_type ON persona_event_subscriptions(event_type, enabled);\n   169→\n   170→CREATE TABLE IF NOT EXISTS persona_triggers (\n   171→  id TEXT PRIMARY KEY,\n   172→  project_id TEXT NOT NULL DEFAULT 'default',\n   173→  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n   174→  trigger_type TEXT NOT NULL CHECK(trigger_type IN ('manual','schedule','polling','webhook','chain')),\n   175→  config TEXT,\n   176→  enabled INTEGER NOT NULL DEFAULT 1,\n   177→  last_triggered_at TEXT,\n   178→  next_trigger_at TEXT,\n   179→  use_case_id TEXT,\n   180→  created_at TEXT NOT NULL,\n   181→  updated_at TEXT NOT NULL\n   182→);\n   183→CREATE INDEX IF NOT EXISTS idx_pt_due ON persona_triggers(enabled, next_trigger_at);\n   184→\n   185→CREATE TABLE IF NOT EXISTS persona_executions (\n   186→  id TEXT PRIMARY KEY,\n   187→  project_id TEXT NOT NULL DEFAULT 'default',\n   188→  persona_id TEXT NOT NULL,\n   189→  trigger_id TEXT,\n   190→  use_case_id TEXT,\n   191→  status TEXT NOT NULL DEFAULT 'queued' CHECK(status IN ('queued','running','completed','failed','cancelled')),\n   192→  input_data TEXT,\n   193→  output_data TEXT,\n   194→  claude_session_id TEXT,\n   195→  model_used TEXT,\n   196→  input_tokens INTEGER DEFAULT 0,\n   197→  output_tokens INTEGER DEFAULT 0,\n   198→  cost_usd REAL DEFAULT 0,\n   199→  error_message TEXT,\n   200→  duration_ms INTEGER,\n   201→  retry_of_execution_id TEXT,\n   202→  retry_count INTEGER DEFAULT 0,\n   203→  started_at TEXT,\n   204→  completed_at TEXT,\n   205→  created_at TEXT NOT NULL\n   206→);\n   207→CREATE INDEX IF NOT EXISTS idx_pex_persona ON persona_executions(persona_id);\n   208→CREATE INDEX IF NOT EXISTS idx_pex_status ON persona_executions(status);\n   209→CREATE INDEX IF NOT EXISTS idx_pex_created_status ON persona_executions(created_at, status);\n   210→\n   211→${DAILY_METRICS_TABLE}\n   212→\n   213→${INFERENCE_PROFILES_TABLE}\n   214→`;\n   215→\n   216→// ---------------------------------------------------------------------------\n   217→// Migrations (legacy single-db)\n   218→// ---------------------------------------------------------------------------\n   219→\n   220→function runLegacyMigrations(db: Database.Database, logger: Logger): void {\n   221→  const tablesToMigrate = [\n   222→    'persona_credentials',\n   223→    'persona_event_subscriptions',\n   224→    'persona_triggers',\n   225→    'persona_executions',\n   226→  ];\n   227→\n   228→  for (const table of tablesToMigrate) {\n   229→    const columns = stmt(db,`PRAGMA table_info(${table})`).all() as Array<{ name: string }>;\n   230→    const hasProjectId = columns.some(c => c.name === 'project_id');\n   231→    if (!hasProjectId) {\n   232→      db.exec(`ALTER TABLE ${table} ADD COLUMN project_id TEXT NOT NULL DEFAULT 'default'`);\n   233→      logger.info({ table }, 'Migration: added project_id column');\n   234→    }\n   235→  }\n   236→\n   237→  db.exec(`\n   238→    CREATE INDEX IF NOT EXISTS idx_personas_project ON personas(project_id);\n   239→    CREATE INDEX IF NOT EXISTS idx_pe_project ON persona_events(project_id);\n   240→    CREATE INDEX IF NOT EXISTS idx_pcred_project ON persona_credentials(project_id);\n   241→    CREATE INDEX IF NOT EXISTS idx_pes_project ON persona_event_subscriptions(project_id);\n   242→    CREATE INDEX IF NOT EXISTS idx_pes_event_type ON persona_event_subscriptions(event_type, enabled);\n   243→    CREATE INDEX IF NOT EXISTS idx_pt_project ON persona_triggers(project_id);\n   244→    DROP INDEX IF EXISTS idx_pt_next_trigger;\n   245→    CREATE INDEX IF NOT EXISTS idx_pt_due ON persona_triggers(enabled, next_trigger_at);\n   246→    CREATE INDEX IF NOT EXISTS idx_pex_project ON persona_executions(project_id);\n   247→  `);\n   248→\n   249→  // Add inference_profile_id to personas if missing\n   250→  const personaCols = stmt(db,'PRAGMA table_info(personas)').all() as Array<{ name: string }>;\n   251→  if (!personaCols.some(c => c.name === 'inference_profile_id')) {\n   252→    db.exec('ALTER TABLE personas ADD COLUMN inference_profile_id TEXT');\n   253→    logger.info('Migration: added inference_profile_id to personas');\n   254→  }\n   255→  if (!personaCols.some(c => c.name === 'network_policy')) {\n   256→    db.exec('ALTER TABLE personas ADD COLUMN network_policy TEXT');\n   257→    logger.info('Migration: added network_policy to personas');\n   258→  }\n   259→\n   260→  // Create inference_profiles table if missing\n   261→  db.exec(INFERENCE_PROFILES_TABLE);\n   262→\n   263→  // Add retry_after and retry_count to persona_events if missing\n   264→  const eventCols = stmt(db,'PRAGMA table_info(persona_events)').all() as Array<{ name: string }>;\n   265→  if (!eventCols.some(c => c.name === 'retry_after')) {\n   266→    db.exec('ALTER TABLE persona_events ADD COLUMN retry_after TEXT');\n   267→    logger.info('Migration: added retry_after to persona_events');\n   268→  }\n   269→  if (!eventCols.some(c => c.name === 'retry_count')) {\n   270→    db.exec('ALTER TABLE persona_events ADD COLUMN retry_count INTEGER NOT NULL DEFAULT 0');\n   271→    logger.info('Migration: added retry_count to persona_events');\n   272→  }\n   273→}\n   274→\n   275→// ---------------------------------------------------------------------------\n   276→// Initialization\n   277→// ---------------------------------------------------------------------------\n   278→\n   279→/** Legacy: initialize a single monolithic database (used by migration script). */\n   280→export function initDb(dbPath: string, logger: Logger): Database.Database {\n   281→  const db = new Database(dbPath);\n   282→  db.pragma('journal_mode = WAL');\n   283→  db.pragma('foreign_keys = ON');\n   284→\n   285→  db.exec(SHARED_TABLES);\n   286→  runLegacyMigrations(db, logger);\n   287→  logger.info({ dbPath }, 'Database initialized (legacy single-db)');\n   288→  return db;\n   289→}\n   290→\n   291→/** Initialize the system-level database (tenant registry). */\n   292→export function initSystemDb(dbPath: string, logger: Logger): Database.Database {\n   293→  const db = new Database(dbPath);\n   294→  db.pragma('journal_mode = WAL');\n   295→  db.pragma('foreign_keys = ON');\n   296→\n   297→  db.exec(SYSTEM_SCHEMA);\n   298→  logger.info({ dbPath }, 'System database initialized');\n   299→  return db;\n   300→}\n   301→\n   302→/** Initialize a per-tenant database. */\n   303→export function initTenantDb(dbPath: string, logger: Logger): Database.Database {\n   304→  const db = new Database(dbPath);\n   305→  db.pragma('journal_mode = WAL');\n   306→  db.pragma('foreign_keys = ON');\n   307→\n   308→  db.exec(SHARED_TABLES);\n   309→  runTenantMigrations(db, logger);\n   310→  logger.info({ dbPath }, 'Tenant database initialized');\n   311→  return db;\n   312→}\n   313→\n   314→/** Migrations applied to per-tenant databases. */\n   315→function runTenantMigrations(db: Database.Database, logger: Logger): void {\n   316→  const eventCols = stmt(db,'PRAGMA table_info(persona_events)').all() as Array<{ name: string }>;\n   317→  if (!eventCols.some(c => c.name === 'retry_after')) {\n   318→    db.exec('ALTER TABLE persona_events ADD COLUMN retry_after TEXT');\n   319→    logger.info('Tenant migration: added retry_after to persona_events');\n   320→  }\n   321→  if (!eventCols.some(c => c.name === 'retry_count')) {\n   322→    db.exec('ALTER TABLE persona_events ADD COLUMN retry_count INTEGER NOT NULL DEFAULT 0');\n   323→    logger.info('Tenant migration: added retry_count to persona_events');\n   324→  }\n   325→}\n   326→"}]},"parent_tool_use_id":null,"session_id":"6514e5c3-f34b-45a0-bfca-f77eb10eda6a","uuid":"2b0e9fc2-204b-4a23-9003-427914c13eff","timestamp":"2026-03-18T17:35:22.766Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\db\\schema.ts","content":"import Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport { stmt } from './_helpers.js';\n\n// ---------------------------------------------------------------------------\n// System schema (tenant registry)\n// ---------------------------------------------------------------------------\n\nconst SYSTEM_SCHEMA = `\nCREATE TABLE IF NOT EXISTS tenants (\n  id TEXT PRIMARY KEY,\n  name TEXT,\n  created_at TEXT NOT NULL\n);\n\nCREATE TABLE IF NOT EXISTS system_daily_metrics (\n  date TEXT NOT NULL,\n  total_executions INTEGER DEFAULT 0,\n  completed INTEGER DEFAULT 0,\n  failed INTEGER DEFAULT 0,\n  total_cost_usd REAL DEFAULT 0,\n  total_duration_ms INTEGER DEFAULT 0,\n  tenant_count INTEGER DEFAULT 0,\n  aggregated_at TEXT NOT NULL,\n  PRIMARY KEY (date)\n);\n\nCREATE TABLE IF NOT EXISTS system_kv (\n  key TEXT PRIMARY KEY,\n  value TEXT NOT NULL\n);\n`;\n\nconst INFERENCE_PROFILES_TABLE = `\nCREATE TABLE IF NOT EXISTS inference_profiles (\n  id TEXT PRIMARY KEY,\n  project_id TEXT NOT NULL DEFAULT 'default',\n  name TEXT NOT NULL,\n  provider TEXT NOT NULL,\n  model TEXT,\n  base_url TEXT,\n  auth_token_encrypted TEXT,\n  auth_token_iv TEXT,\n  auth_token_tag TEXT,\n  env_mappings TEXT NOT NULL DEFAULT '[]',\n  remove_env_keys TEXT NOT NULL DEFAULT '[]',\n  is_preset INTEGER NOT NULL DEFAULT 0,\n  created_at TEXT NOT NULL,\n  updated_at TEXT NOT NULL\n);\n`;\n\nconst DAILY_METRICS_TABLE = `\nCREATE TABLE IF NOT EXISTS daily_metrics (\n  date TEXT NOT NULL,\n  total_executions INTEGER DEFAULT 0,\n  completed INTEGER DEFAULT 0,\n  failed INTEGER DEFAULT 0,\n  total_cost_usd REAL DEFAULT 0,\n  total_duration_ms INTEGER DEFAULT 0,\n  PRIMARY KEY (date)\n);\n\nCREATE TABLE IF NOT EXISTS retention_watermark (\n  key TEXT PRIMARY KEY DEFAULT 'executions',\n  last_rowid INTEGER NOT NULL DEFAULT 0\n);\n`;\n\n// ---------------------------------------------------------------------------\n// Shared entity tables (used by both legacy single-db and per-tenant dbs)\n// ---------------------------------------------------------------------------\n\nconst SHARED_TABLES = `\nCREATE TABLE IF NOT EXISTS personas (\n  id TEXT PRIMARY KEY,\n  project_id TEXT NOT NULL DEFAULT 'default',\n  name TEXT NOT NULL,\n  description TEXT,\n  system_prompt TEXT NOT NULL DEFAULT '',\n  structured_prompt TEXT,\n  icon TEXT,\n  color TEXT,\n  enabled INTEGER NOT NULL DEFAULT 1,\n  max_concurrent INTEGER NOT NULL DEFAULT 1,\n  timeout_ms INTEGER NOT NULL DEFAULT 300000,\n  inference_profile_id TEXT,\n  network_policy TEXT,\n  max_budget_usd REAL,\n  max_turns INTEGER,\n  design_context TEXT,\n  group_id TEXT,\n  created_at TEXT NOT NULL,\n  updated_at TEXT NOT NULL\n);\n\nCREATE TABLE IF NOT EXISTS persona_tool_definitions (\n  id TEXT PRIMARY KEY,\n  name TEXT NOT NULL UNIQUE,\n  category TEXT NOT NULL,\n  description TEXT NOT NULL,\n  script_path TEXT NOT NULL DEFAULT '',\n  input_schema TEXT,\n  output_schema TEXT,\n  requires_credential_type TEXT,\n  implementation_guide TEXT,\n  is_builtin INTEGER NOT NULL DEFAULT 0,\n  created_at TEXT NOT NULL,\n  updated_at TEXT NOT NULL\n);\n\nCREATE TABLE IF NOT EXISTS persona_tools (\n  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n  tool_id TEXT NOT NULL REFERENCES persona_tool_definitions(id) ON DELETE CASCADE,\n  PRIMARY KEY (persona_id, tool_id)\n);\n\nCREATE TABLE IF NOT EXISTS persona_credentials (\n  id TEXT PRIMARY KEY,\n  project_id TEXT NOT NULL DEFAULT 'default',\n  name TEXT NOT NULL,\n  service_type TEXT NOT NULL,\n  encrypted_data TEXT NOT NULL,\n  iv TEXT NOT NULL,\n  tag TEXT NOT NULL,\n  metadata TEXT,\n  last_used_at TEXT,\n  created_at TEXT NOT NULL,\n  updated_at TEXT NOT NULL\n);\n\nCREATE TABLE IF NOT EXISTS persona_credential_links (\n  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n  credential_id TEXT NOT NULL REFERENCES persona_credentials(id) ON DELETE CASCADE,\n  PRIMARY KEY (persona_id, credential_id)\n);\n\nCREATE TABLE IF NOT EXISTS persona_events (\n  id TEXT PRIMARY KEY,\n  project_id TEXT NOT NULL DEFAULT 'default',\n  event_type TEXT NOT NULL,\n  source_type TEXT NOT NULL,\n  source_id TEXT,\n  target_persona_id TEXT,\n  payload TEXT,\n  status TEXT NOT NULL DEFAULT 'pending' CHECK(status IN ('pending','processing','delivered','skipped','failed','partial','partial-retry')),\n  error_message TEXT,\n  processed_at TEXT,\n  use_case_id TEXT,\n  retry_after TEXT,\n  retry_count INTEGER NOT NULL DEFAULT 0,\n  created_at TEXT NOT NULL\n);\nCREATE INDEX IF NOT EXISTS idx_pe_status ON persona_events(status);\nCREATE INDEX IF NOT EXISTS idx_pe_created_status ON persona_events(created_at, status);\n\nCREATE TABLE IF NOT EXISTS persona_event_subscriptions (\n  id TEXT PRIMARY KEY,\n  project_id TEXT NOT NULL DEFAULT 'default',\n  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n  event_type TEXT NOT NULL,\n  source_filter TEXT,\n  enabled INTEGER NOT NULL DEFAULT 1,\n  use_case_id TEXT,\n  created_at TEXT NOT NULL,\n  updated_at TEXT NOT NULL\n);\nCREATE INDEX IF NOT EXISTS idx_pes_event_type ON persona_event_subscriptions(event_type, enabled);\n\nCREATE TABLE IF NOT EXISTS persona_triggers (\n  id TEXT PRIMARY KEY,\n  project_id TEXT NOT NULL DEFAULT 'default',\n  persona_id TEXT NOT NULL REFERENCES personas(id) ON DELETE CASCADE,\n  trigger_type TEXT NOT NULL CHECK(trigger_type IN ('manual','schedule','polling','webhook','chain')),\n  config TEXT,\n  enabled INTEGER NOT NULL DEFAULT 1,\n  last_triggered_at TEXT,\n  next_trigger_at TEXT,\n  use_case_id TEXT,\n  created_at TEXT NOT NULL,\n  updated_at TEXT NOT NULL\n);\nCREATE INDEX IF NOT EXISTS idx_pt_due ON persona_triggers(enabled, next_trigger_at);\n\nCREATE TABLE IF NOT EXISTS persona_executions (\n  id TEXT PRIMARY KEY,\n  project_id TEXT NOT NULL DEFAULT 'default',\n  persona_id TEXT NOT NULL,\n  trigger_id TEXT,\n  use_case_id TEXT,\n  status TEXT NOT NULL DEFAULT 'queued' CHECK(status IN ('queued','running','completed','failed','cancelled')),\n  input_data TEXT,\n  output_data TEXT,\n  claude_session_id TEXT,\n  model_used TEXT,\n  input_tokens INTEGER DEFAULT 0,\n  output_tokens INTEGER DEFAULT 0,\n  cost_usd REAL DEFAULT 0,\n  error_message TEXT,\n  duration_ms INTEGER,\n  retry_of_execution_id TEXT,\n  retry_count INTEGER DEFAULT 0,\n  started_at TEXT,\n  completed_at TEXT,\n  created_at TEXT NOT NULL\n);\nCREATE INDEX IF NOT EXISTS idx_pex_persona ON persona_executions(persona_id);\nCREATE INDEX IF NOT EXISTS idx_pex_status ON persona_executions(status);\nCREATE INDEX IF NOT EXISTS idx_pex_created_status ON persona_executions(created_at, status);\n\n${DAILY_METRICS_TABLE}\n\n${INFERENCE_PROFILES_TABLE}\n`;\n\n// ---------------------------------------------------------------------------\n// Migrations (legacy single-db)\n// ---------------------------------------------------------------------------\n\nfunction runLegacyMigrations(db: Database.Database, logger: Logger): void {\n  const tablesToMigrate = [\n    'persona_credentials',\n    'persona_event_subscriptions',\n    'persona_triggers',\n    'persona_executions',\n  ];\n\n  for (const table of tablesToMigrate) {\n    const columns = stmt(db,`PRAGMA table_info(${table})`).all() as Array<{ name: string }>;\n    const hasProjectId = columns.some(c => c.name === 'project_id');\n    if (!hasProjectId) {\n      db.exec(`ALTER TABLE ${table} ADD COLUMN project_id TEXT NOT NULL DEFAULT 'default'`);\n      logger.info({ table }, 'Migration: added project_id column');\n    }\n  }\n\n  db.exec(`\n    CREATE INDEX IF NOT EXISTS idx_personas_project ON personas(project_id);\n    CREATE INDEX IF NOT EXISTS idx_pe_project ON persona_events(project_id);\n    CREATE INDEX IF NOT EXISTS idx_pcred_project ON persona_credentials(project_id);\n    CREATE INDEX IF NOT EXISTS idx_pes_project ON persona_event_subscriptions(project_id);\n    CREATE INDEX IF NOT EXISTS idx_pes_event_type ON persona_event_subscriptions(event_type, enabled);\n    CREATE INDEX IF NOT EXISTS idx_pt_project ON persona_triggers(project_id);\n    DROP INDEX IF EXISTS idx_pt_next_trigger;\n    CREATE INDEX IF NOT EXISTS idx_pt_due ON persona_triggers(enabled, next_trigger_at);\n    CREATE INDEX IF NOT EXISTS idx_pex_project ON persona_executions(project_id);\n  `);\n\n  // Add inference_profile_id to personas if missing\n  const personaCols = stmt(db,'PRAGMA table_info(personas)').all() as Array<{ name: string }>;\n  if (!personaCols.some(c => c.name === 'inference_profile_id')) {\n    db.exec('ALTER TABLE personas ADD COLUMN inference_profile_id TEXT');\n    logger.info('Migration: added inference_profile_id to personas');\n  }\n  if (!personaCols.some(c => c.name === 'network_policy')) {\n    db.exec('ALTER TABLE personas ADD COLUMN network_policy TEXT');\n    logger.info('Migration: added network_policy to personas');\n  }\n\n  // Create inference_profiles table if missing\n  db.exec(INFERENCE_PROFILES_TABLE);\n\n  // Add retry_after and retry_count to persona_events if missing\n  const eventCols = stmt(db,'PRAGMA table_info(persona_events)').all() as Array<{ name: string }>;\n  if (!eventCols.some(c => c.name === 'retry_after')) {\n    db.exec('ALTER TABLE persona_events ADD COLUMN retry_after TEXT');\n    logger.info('Migration: added retry_after to persona_events');\n  }\n  if (!eventCols.some(c => c.name === 'retry_count')) {\n    db.exec('ALTER TABLE persona_events ADD COLUMN retry_count INTEGER NOT NULL DEFAULT 0');\n    logger.info('Migration: added retry_count to persona_events');\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Initialization\n// ---------------------------------------------------------------------------\n\n/** Legacy: initialize a single monolithic database (used by migration script). */\nexport function initDb(dbPath: string, logger: Logger): Database.Database {\n  const db = new Database(dbPath);\n  db.pragma('journal_mode = WAL');\n  db.pragma('foreign_keys = ON');\n\n  db.exec(SHARED_TABLES);\n  runLegacyMigrations(db, logger);\n  logger.info({ dbPath }, 'Database initialized (legacy single-db)');\n  return db;\n}\n\n/** Initialize the system-level database (tenant registry). */\nexport function initSystemDb(dbPath: string, logger: Logger): Database.Database {\n  const db = new Database(dbPath);\n  db.pragma('journal_mode = WAL');\n  db.pragma('foreign_keys = ON');\n\n  db.exec(SYSTEM_SCHEMA);\n  logger.info({ dbPath }, 'System database initialized');\n  return db;\n}\n\n/** Initialize a per-tenant database. */\nexport function initTenantDb(dbPath: string, logger: Logger): Database.Database {\n  const db = new Database(dbPath);\n  db.pragma('journal_mode = WAL');\n  db.pragma('foreign_keys = ON');\n\n  db.exec(SHARED_TABLES);\n  runTenantMigrations(db, logger);\n  logger.info({ dbPath }, 'Tenant database initialized');\n  return db;\n}\n\n/** Migrations applied to per-tenant databases. */\nfunction runTenantMigrations(db: Database.Database, logger: Logger): void {\n  const eventCols = stmt(db,'PRAGMA table_info(persona_events)').all() as Array<{ name: string }>;\n  if (!eventCols.some(c => c.name === 'retry_after')) {\n    db.exec('ALTER TABLE persona_events ADD COLUMN retry_after TEXT');\n    logger.info('Tenant migration: added retry_after to persona_events');\n  }\n  if (!eventCols.some(c => c.name === 'retry_count')) {\n    db.exec('ALTER TABLE persona_events ADD COLUMN retry_count INTEGER NOT NULL DEFAULT 0');\n    logger.info('Tenant migration: added retry_count to persona_events');\n  }\n}\n","numLines":326,"startLine":1,"totalLines":326}}}
