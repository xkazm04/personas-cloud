[2026-03-19T08:15:25.157Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FNxK6Nbu2TARgcyaMxKbY8","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import * as db from './db/index.js';\n     4→import { TriggerHeap, type HeapEntry } from './triggerHeap.js';\n     5→import type { TenantDbManager } from './tenantDbManager.js';\n     6→\n     7→const MIN_DELAY_MS = 100;\n     8→const MAX_DELAY_MS = 60_000;\n     9→const HEARTBEAT_INTERVAL_MS = 60_000;\n    10→\n    11→export interface SchedulerMetrics {\n    12→  heap_size: number;\n    13→  next_due_at: string | null;\n    14→  triggers_fired_total: number;\n    15→  triggers_missed_total: number;\n    16→  avg_tick_latency_ms: number;\n    17→  last_tick_at: string | null;\n    18→}\n    19→\n    20→export interface TriggerSchedulerHandle {\n    21→  /** Stop the scheduler. */\n    22→  close(): void;\n    23→  /** Nudge the scheduler to re-evaluate immediately (e.g. after trigger create/update). */\n    24→  nudge(): void;\n    25→  /** Push or update a trigger in the heap after CRUD. */\n    26→  heapPush(triggerId: string, tenantId: string, nextTriggerAt: string | null): void;\n    27→  /** Remove a trigger from the heap (e.g. after delete or disable). */\n    28→  heapRemove(triggerId: string): void;\n    29→  /** Return current scheduler metrics for observability. */\n    30→  getMetrics(): SchedulerMetrics;\n    31→}\n    32→\n    33→/**\n    34→ * Start the heap-driven trigger scheduler.\n    35→ *\n    36→ * On startup the scheduler loads all enabled triggers from the DB into an\n    37→ * in-memory min-heap keyed by next_trigger_at.  On each tick it pops entries\n    38→ * whose time has passed, fires them, and pushes the updated next-fire times\n    39→ * back into the heap.  The DB remains the source of truth — the heap is a\n    40→ * hot-path cache that eliminates full table scans.\n    41→ */\n    42→export function startTriggerScheduler(\n    43→  database: Database.Database | null,\n    44→  logger: Logger,\n    45→  _interval?: number, // kept for signature compat; ignored\n    46→  tenantDbManager?: TenantDbManager,\n    47→  onEventPublished?: () => void,\n    48→): TriggerSchedulerHandle {\n    49→  let timer: ReturnType<typeof setTimeout> | null = null;\n    50→  let heartbeatTimer: ReturnType<typeof setInterval> | null = null;\n    51→  let stopped = false;\n    52→  const heap = new TriggerHeap();\n    53→\n    54→  // ---- Metrics accumulators ----\n    55→  let triggersFiredTotal = 0;\n    56→  let triggersMissedTotal = 0;\n    57→  let tickCount = 0;\n    58→  let tickLatencySum = 0;\n    59→  let lastTickAt: number | null = null;\n    60→\n    61→  // ---- Heap bootstrap: load all enabled triggers from DB ----\n    62→  buildHeap(heap, database, tenantDbManager, logger);\n    63→\n    64→  logger.info(\n    65→    { heapSize: heap.size, minDelayMs: MIN_DELAY_MS, maxDelayMs: MAX_DELAY_MS, tenantIsolated: !!tenantDbManager },\n    66→    'Heap-driven trigger scheduler started',\n    67→  );\n    68→\n    69→  function scheduleTick(delayMs: number): void {\n    70→    if (stopped) return;\n    71→    timer = setTimeout(tick, delayMs);\n    72→  }\n    73→\n    74→  function tick(): void {\n    75→    if (stopped) return;\n    76→    const tickStart = Date.now();\n    77→    try {\n    78→      const now = tickStart;\n    79→      const due = heap.popDue(now);\n    80→\n    81→      if (due.length > 0) {\n    82→        // Count missed triggers (due more than 60 s ago)\n    83→        for (const entry of due) {\n    84→          if (now - entry.nextTriggerAt > MAX_DELAY_MS) {\n    85→            triggersMissedTotal++;\n    86→          }\n    87→        }\n    88→        const firedCount = fireDueEntries(due, database, tenantDbManager, heap, logger, onEventPublished);\n    89→        triggersFiredTotal += firedCount;\n    90→      }\n    91→    } catch (err) {\n    92→      logger.error({ err }, 'Trigger scheduler tick failed');\n    93→    }\n    94→\n    95→    // Track tick latency\n    96→    const tickEnd = Date.now();\n    97→    tickCount++;\n    98→    tickLatencySum += tickEnd - tickStart;\n    99→    lastTickAt = tickEnd;\n   100→\n   101→    // Schedule next tick based on heap peek\n   102→    const delayMs = computeNextDelay(heap);\n   103→    scheduleTick(delayMs);\n   104→  }\n   105→\n   106→  // Kick off the first tick immediately\n   107→  scheduleTick(0);\n   108→\n   109→  // ---- Heartbeat log every 60 seconds ----\n   110→  heartbeatTimer = setInterval(() => {\n   111→    if (stopped) return;\n   112→    const top = heap.peek();\n   113→    logger.info({\n   114→      heap_size: heap.size,\n   115→      next_due_at: top ? new Date(top.nextTriggerAt).toISOString() : null,\n   116→      triggers_fired_total: triggersFiredTotal,\n   117→      triggers_missed_total: triggersMissedTotal,\n   118→      avg_tick_latency_ms: tickCount > 0 ? Math.round(tickLatencySum / tickCount * 100) / 100 : 0,\n   119→      last_tick_at: lastTickAt ? new Date(lastTickAt).toISOString() : null,\n   120→    }, 'Scheduler heartbeat');\n   121→  }, HEARTBEAT_INTERVAL_MS);\n   122→\n   123→  return {\n   124→    close() {\n   125→      stopped = true;\n   126→      if (timer != null) {\n   127→        clearTimeout(timer);\n   128→        timer = null;\n   129→      }\n   130→      if (heartbeatTimer != null) {\n   131→        clearInterval(heartbeatTimer);\n   132→        heartbeatTimer = null;\n   133→      }\n   134→    },\n   135→    nudge() {\n   136→      if (stopped) return;\n   137→      if (timer != null) {\n   138→        clearTimeout(timer);\n   139→        timer = null;\n   140→      }\n   141→      scheduleTick(0);\n   142→    },\n   143→    heapPush(triggerId: string, tenantId: string, nextTriggerAt: string | null) {\n   144→      if (!nextTriggerAt) {\n   145→        heap.remove(triggerId);\n   146→        return;\n   147→      }\n   148→      heap.push({ triggerId, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });\n   149→    },\n   150→    heapRemove(triggerId: string) {\n   151→      heap.remove(triggerId);\n   152→    },\n   153→    getMetrics(): SchedulerMetrics {\n   154→      const top = heap.peek();\n   155→      return {\n   156→        heap_size: heap.size,\n   157→        next_due_at: top ? new Date(top.nextTriggerAt).toISOString() : null,\n   158→        triggers_fired_total: triggersFiredTotal,\n   159→        triggers_missed_total: triggersMissedTotal,\n   160→        avg_tick_latency_ms: tickCount > 0 ? Math.round(tickLatencySum / tickCount * 100) / 100 : 0,\n   161→        last_tick_at: lastTickAt ? new Date(lastTickAt).toISOString() : null,\n   162→      };\n   163→    },\n   164→  };\n   165→}\n   166→\n   167→// ---------------------------------------------------------------------------\n   168→// Heap bootstrap — load all enabled triggers from every tenant DB\n   169→// ---------------------------------------------------------------------------\n   170→\n   171→function buildHeap(\n   172→  heap: TriggerHeap,\n   173→  database: Database.Database | null,\n   174→  tenantDbManager: TenantDbManager | undefined,\n   175→  logger: Logger,\n   176→): void {\n   177→  heap.clear();\n   178→\n   179→  if (tenantDbManager) {\n   180→    const tenantIds = tenantDbManager.listTenantIds();\n   181→    for (const tenantId of tenantIds) {\n   182→      try {\n   183→        const tenantDb = tenantDbManager.getTenantDb(tenantId);\n   184→        loadDbIntoHeap(heap, tenantDb, tenantId);\n   185→      } catch (err) {\n   186→        logger.error({ err, tenantId }, 'Failed to load triggers for tenant into heap');\n   187→      }\n   188→    }\n   189→  } else if (database) {\n   190→    loadDbIntoHeap(heap, database, 'default');\n   191→  }\n   192→}\n   193→\n   194→function loadDbIntoHeap(heap: TriggerHeap, dbConn: Database.Database, tenantId: string): void {\n   195→  const rows = db.loadEnabledTriggerTimes(dbConn);\n   196→  for (const row of rows) {\n   197→    heap.push({\n   198→      triggerId: row.id,\n   199→      tenantId,\n   200→      nextTriggerAt: new Date(row.nextTriggerAt).getTime(),\n   201→    });\n   202→  }\n   203→}\n   204→\n   205→// ---------------------------------------------------------------------------\n   206→// Compute next delay from the heap (O(1) peek)\n   207→// ---------------------------------------------------------------------------\n   208→\n   209→function computeNextDelay(heap: TriggerHeap): number {\n   210→  const top = heap.peek();\n   211→  if (!top) return MAX_DELAY_MS;\n   212→  const deltaMs = top.nextTriggerAt - Date.now();\n   213→  return Math.min(MAX_DELAY_MS, Math.max(MIN_DELAY_MS, deltaMs));\n   214→}\n   215→\n   216→// ---------------------------------------------------------------------------\n   217→// Fire due triggers — batch-fetch from DB by ID, then process\n   218→// ---------------------------------------------------------------------------\n   219→\n   220→function fireDueEntries(\n   221→  due: HeapEntry[],\n   222→  database: Database.Database | null,\n   223→  tenantDbManager: TenantDbManager | undefined,\n   224→  heap: TriggerHeap,\n   225→  logger: Logger,\n   226→  onEventPublished?: () => void,\n   227→): number {\n   228→  let firedCount = 0;\n   229→  // Group by tenantId so we hit each DB once with a batch query\n   230→  const byTenant = new Map<string, HeapEntry[]>();\n   231→  for (const entry of due) {\n   232→    let list = byTenant.get(entry.tenantId);\n   233→    if (!list) {\n   234→      list = [];\n   235→      byTenant.set(entry.tenantId, list);\n   236→    }\n   237→    list.push(entry);\n   238→  }\n   239→\n   240→  for (const [tenantId, entries] of byTenant) {\n   241→    try {\n   242→      const tenantDb = tenantDbManager\n   243→        ? tenantDbManager.getTenantDb(tenantId)\n   244→        : database;\n   245→      if (!tenantDb) continue;\n   246→\n   247→      const ids = entries.map(e => e.triggerId);\n   248→      const triggers = db.getTriggersByIdsWithPersona(tenantDb, ids);\n   249→\n   250→      for (const trigger of triggers) {\n   251→        // Skip polling triggers\n   252→        if (trigger.triggerType === 'polling') continue;\n   253→\n   254→        try {\n   255→          const parsedConfig = trigger.parsedConfig;\n   256→          let eventType = 'trigger_fired';\n   257→          let payload: string | null = null;\n   258→          if (parsedConfig) {\n   259→            if (parsedConfig.event_type) eventType = parsedConfig.event_type;\n   260→            if (parsedConfig.payload) payload = JSON.stringify(parsedConfig.payload);\n   261→          }\n   262→\n   263→          // Skip triggers for deleted or disabled personas\n   264→          if (trigger.personaProjectId == null) {\n   265→            logger.warn({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona not found (deleted?)');\n   266→            continue;\n   267→          }\n   268→          if (!trigger.personaEnabled) {\n   269→            logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');\n   270→            continue;\n   271→          }\n   272→\n   273→          const triggerProjectId = tenantId !== 'default' ? tenantId : trigger.personaProjectId;\n   274→\n   275→          // Publish event\n   276→          const publishedEvent = db.publishEvent(tenantDb, {\n   277→            eventType,\n   278→            sourceType: 'trigger',\n   279→            sourceId: trigger.id,\n   280→            targetPersonaId: trigger.personaId,\n   281→            projectId: triggerProjectId,\n   282→            useCaseId: trigger.useCaseId,\n   283→            payload,\n   284→          });\n   285→          onEventPublished?.();\n   286→\n   287→          // Record fire history\n   288→          db.recordTriggerFire(tenantDb, {\n   289→            triggerId: trigger.id,\n   290→            eventId: publishedEvent.id,\n   291→          });\n   292→\n   293→          // Compute next trigger time and update DB\n   294→          const now = new Date().toISOString();\n   295→          const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);\n   296→          db.updateTriggerTimings(tenantDb, trigger.id, now, nextTriggerAt);\n   297→\n   298→          // Push updated time back into heap\n   299→          if (nextTriggerAt) {\n   300→            heap.push({ triggerId: trigger.id, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });\n   301→          }\n   302→\n   303→          logger.info({\n   304→            triggerId: trigger.id,\n   305→            personaId: trigger.personaId,\n   306→            eventType,\n   307→            nextTriggerAt,\n   308→          }, 'Trigger fired');\n   309→          firedCount++;\n   310→        } catch (err) {\n   311→          logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');\n   312→        }\n   313→      }\n   314→    } catch (err) {\n   315→      logger.error({ err, tenantId }, 'Trigger scheduler tick failed for tenant');\n   316→    }\n   317→  }\n   318→  return firedCount;\n   319→}\n   320→"}]},"parent_tool_use_id":null,"session_id":"4c343ef4-c6b6-46db-bafa-7e39119894bb","uuid":"b9b0bd51-1be0-4305-a650-878a0573a1be","timestamp":"2026-03-19T08:15:25.070Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\triggerScheduler.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { TriggerHeap, type HeapEntry } from './triggerHeap.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\n\nconst MIN_DELAY_MS = 100;\nconst MAX_DELAY_MS = 60_000;\nconst HEARTBEAT_INTERVAL_MS = 60_000;\n\nexport interface SchedulerMetrics {\n  heap_size: number;\n  next_due_at: string | null;\n  triggers_fired_total: number;\n  triggers_missed_total: number;\n  avg_tick_latency_ms: number;\n  last_tick_at: string | null;\n}\n\nexport interface TriggerSchedulerHandle {\n  /** Stop the scheduler. */\n  close(): void;\n  /** Nudge the scheduler to re-evaluate immediately (e.g. after trigger create/update). */\n  nudge(): void;\n  /** Push or update a trigger in the heap after CRUD. */\n  heapPush(triggerId: string, tenantId: string, nextTriggerAt: string | null): void;\n  /** Remove a trigger from the heap (e.g. after delete or disable). */\n  heapRemove(triggerId: string): void;\n  /** Return current scheduler metrics for observability. */\n  getMetrics(): SchedulerMetrics;\n}\n\n/**\n * Start the heap-driven trigger scheduler.\n *\n * On startup the scheduler loads all enabled triggers from the DB into an\n * in-memory min-heap keyed by next_trigger_at.  On each tick it pops entries\n * whose time has passed, fires them, and pushes the updated next-fire times\n * back into the heap.  The DB remains the source of truth — the heap is a\n * hot-path cache that eliminates full table scans.\n */\nexport function startTriggerScheduler(\n  database: Database.Database | null,\n  logger: Logger,\n  _interval?: number, // kept for signature compat; ignored\n  tenantDbManager?: TenantDbManager,\n  onEventPublished?: () => void,\n): TriggerSchedulerHandle {\n  let timer: ReturnType<typeof setTimeout> | null = null;\n  let heartbeatTimer: ReturnType<typeof setInterval> | null = null;\n  let stopped = false;\n  const heap = new TriggerHeap();\n\n  // ---- Metrics accumulators ----\n  let triggersFiredTotal = 0;\n  let triggersMissedTotal = 0;\n  let tickCount = 0;\n  let tickLatencySum = 0;\n  let lastTickAt: number | null = null;\n\n  // ---- Heap bootstrap: load all enabled triggers from DB ----\n  buildHeap(heap, database, tenantDbManager, logger);\n\n  logger.info(\n    { heapSize: heap.size, minDelayMs: MIN_DELAY_MS, maxDelayMs: MAX_DELAY_MS, tenantIsolated: !!tenantDbManager },\n    'Heap-driven trigger scheduler started',\n  );\n\n  function scheduleTick(delayMs: number): void {\n    if (stopped) return;\n    timer = setTimeout(tick, delayMs);\n  }\n\n  function tick(): void {\n    if (stopped) return;\n    const tickStart = Date.now();\n    try {\n      const now = tickStart;\n      const due = heap.popDue(now);\n\n      if (due.length > 0) {\n        // Count missed triggers (due more than 60 s ago)\n        for (const entry of due) {\n          if (now - entry.nextTriggerAt > MAX_DELAY_MS) {\n            triggersMissedTotal++;\n          }\n        }\n        const firedCount = fireDueEntries(due, database, tenantDbManager, heap, logger, onEventPublished);\n        triggersFiredTotal += firedCount;\n      }\n    } catch (err) {\n      logger.error({ err }, 'Trigger scheduler tick failed');\n    }\n\n    // Track tick latency\n    const tickEnd = Date.now();\n    tickCount++;\n    tickLatencySum += tickEnd - tickStart;\n    lastTickAt = tickEnd;\n\n    // Schedule next tick based on heap peek\n    const delayMs = computeNextDelay(heap);\n    scheduleTick(delayMs);\n  }\n\n  // Kick off the first tick immediately\n  scheduleTick(0);\n\n  // ---- Heartbeat log every 60 seconds ----\n  heartbeatTimer = setInterval(() => {\n    if (stopped) return;\n    const top = heap.peek();\n    logger.info({\n      heap_size: heap.size,\n      next_due_at: top ? new Date(top.nextTriggerAt).toISOString() : null,\n      triggers_fired_total: triggersFiredTotal,\n      triggers_missed_total: triggersMissedTotal,\n      avg_tick_latency_ms: tickCount > 0 ? Math.round(tickLatencySum / tickCount * 100) / 100 : 0,\n      last_tick_at: lastTickAt ? new Date(lastTickAt).toISOString() : null,\n    }, 'Scheduler heartbeat');\n  }, HEARTBEAT_INTERVAL_MS);\n\n  return {\n    close() {\n      stopped = true;\n      if (timer != null) {\n        clearTimeout(timer);\n        timer = null;\n      }\n      if (heartbeatTimer != null) {\n        clearInterval(heartbeatTimer);\n        heartbeatTimer = null;\n      }\n    },\n    nudge() {\n      if (stopped) return;\n      if (timer != null) {\n        clearTimeout(timer);\n        timer = null;\n      }\n      scheduleTick(0);\n    },\n    heapPush(triggerId: string, tenantId: string, nextTriggerAt: string | null) {\n      if (!nextTriggerAt) {\n        heap.remove(triggerId);\n        return;\n      }\n      heap.push({ triggerId, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });\n    },\n    heapRemove(triggerId: string) {\n      heap.remove(triggerId);\n    },\n    getMetrics(): SchedulerMetrics {\n      const top = heap.peek();\n      return {\n        heap_size: heap.size,\n        next_due_at: top ? new Date(top.nextTriggerAt).toISOString() : null,\n        triggers_fired_total: triggersFiredTotal,\n        triggers_missed_total: triggersMissedTotal,\n        avg_tick_latency_ms: tickCount > 0 ? Math.round(tickLatencySum / tickCount * 100) / 100 : 0,\n        last_tick_at: lastTickAt ? new Date(lastTickAt).toISOString() : null,\n      };\n    },\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Heap bootstrap — load all enabled triggers from every tenant DB\n// ---------------------------------------------------------------------------\n\nfunction buildHeap(\n  heap: TriggerHeap,\n  database: Database.Database | null,\n  tenantDbManager: TenantDbManager | undefined,\n  logger: Logger,\n): void {\n  heap.clear();\n\n  if (tenantDbManager) {\n    const tenantIds = tenantDbManager.listTenantIds();\n    for (const tenantId of tenantIds) {\n      try {\n        const tenantDb = tenantDbManager.getTenantDb(tenantId);\n        loadDbIntoHeap(heap, tenantDb, tenantId);\n      } catch (err) {\n        logger.error({ err, tenantId }, 'Failed to load triggers for tenant into heap');\n      }\n    }\n  } else if (database) {\n    loadDbIntoHeap(heap, database, 'default');\n  }\n}\n\nfunction loadDbIntoHeap(heap: TriggerHeap, dbConn: Database.Database, tenantId: string): void {\n  const rows = db.loadEnabledTriggerTimes(dbConn);\n  for (const row of rows) {\n    heap.push({\n      triggerId: row.id,\n      tenantId,\n      nextTriggerAt: new Date(row.nextTriggerAt).getTime(),\n    });\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Compute next delay from the heap (O(1) peek)\n// ---------------------------------------------------------------------------\n\nfunction computeNextDelay(heap: TriggerHeap): number {\n  const top = heap.peek();\n  if (!top) return MAX_DELAY_MS;\n  const deltaMs = top.nextTriggerAt - Date.now();\n  return Math.min(MAX_DELAY_MS, Math.max(MIN_DELAY_MS, deltaMs));\n}\n\n// ---------------------------------------------------------------------------\n// Fire due triggers — batch-fetch from DB by ID, then process\n// ---------------------------------------------------------------------------\n\nfunction fireDueEntries(\n  due: HeapEntry[],\n  database: Database.Database | null,\n  tenantDbManager: TenantDbManager | undefined,\n  heap: TriggerHeap,\n  logger: Logger,\n  onEventPublished?: () => void,\n): number {\n  let firedCount = 0;\n  // Group by tenantId so we hit each DB once with a batch query\n  const byTenant = new Map<string, HeapEntry[]>();\n  for (const entry of due) {\n    let list = byTenant.get(entry.tenantId);\n    if (!list) {\n      list = [];\n      byTenant.set(entry.tenantId, list);\n    }\n    list.push(entry);\n  }\n\n  for (const [tenantId, entries] of byTenant) {\n    try {\n      const tenantDb = tenantDbManager\n        ? tenantDbManager.getTenantDb(tenantId)\n        : database;\n      if (!tenantDb) continue;\n\n      const ids = entries.map(e => e.triggerId);\n      const triggers = db.getTriggersByIdsWithPersona(tenantDb, ids);\n\n      for (const trigger of triggers) {\n        // Skip polling triggers\n        if (trigger.triggerType === 'polling') continue;\n\n        try {\n          const parsedConfig = trigger.parsedConfig;\n          let eventType = 'trigger_fired';\n          let payload: string | null = null;\n          if (parsedConfig) {\n            if (parsedConfig.event_type) eventType = parsedConfig.event_type;\n            if (parsedConfig.payload) payload = JSON.stringify(parsedConfig.payload);\n          }\n\n          // Skip triggers for deleted or disabled personas\n          if (trigger.personaProjectId == null) {\n            logger.warn({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona not found (deleted?)');\n            continue;\n          }\n          if (!trigger.personaEnabled) {\n            logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');\n            continue;\n          }\n\n          const triggerProjectId = tenantId !== 'default' ? tenantId : trigger.personaProjectId;\n\n          // Publish event\n          const publishedEvent = db.publishEvent(tenantDb, {\n            eventType,\n            sourceType: 'trigger',\n            sourceId: trigger.id,\n            targetPersonaId: trigger.personaId,\n            projectId: triggerProjectId,\n            useCaseId: trigger.useCaseId,\n            payload,\n          });\n          onEventPublished?.();\n\n          // Record fire history\n          db.recordTriggerFire(tenantDb, {\n            triggerId: trigger.id,\n            eventId: publishedEvent.id,\n          });\n\n          // Compute next trigger time and update DB\n          const now = new Date().toISOString();\n          const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);\n          db.updateTriggerTimings(tenantDb, trigger.id, now, nextTriggerAt);\n\n          // Push updated time back into heap\n          if (nextTriggerAt) {\n            heap.push({ triggerId: trigger.id, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });\n          }\n\n          logger.info({\n            triggerId: trigger.id,\n            personaId: trigger.personaId,\n            eventType,\n            nextTriggerAt,\n          }, 'Trigger fired');\n          firedCount++;\n        } catch (err) {\n          logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');\n        }\n      }\n    } catch (err) {\n      logger.error({ err, tenantId }, 'Trigger scheduler tick failed for tenant');\n    }\n  }\n  return firedCount;\n}\n","numLines":320,"startLine":1,"totalLines":320}}}
[2026-03-19T08:15:25.457Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XzfAK7nVWxPE9TxFjAqwX6","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher, SubmitResult } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import type { KafkaClient } from './kafka.js';\n    11→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    12→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    13→import type { TriggerSchedulerHandle } from './triggerScheduler.js';\n    14→import type { TenantDbManager } from './tenantDbManager.js';\n    15→import type { TenantKeyManager } from './tenantKeyManager.js';\n    16→import type { AuditLog, AuditEntry, AuditAction } from './auditLog.js';\n    17→import type { EventProcessorHealth } from './eventProcessor.js';\n    18→import type { Logger } from 'pino';\n    19→import * as db from './db/index.js';\n    20→import { readBody, json } from './httpUtils.js';\n    21→\n    22→// --- Route types ---\n    23→\n    24→interface ParsedRoute {\n    25→  resource: string;\n    26→  id?: string;\n    27→  subResource?: string;\n    28→}\n    29→\n    30→type RouteHandler = (\n    31→  req: http.IncomingMessage,\n    32→  res: http.ServerResponse,\n    33→  ctx: RequestContext,\n    34→  route: ParsedRoute | null,\n    35→  queryString: string | undefined,\n    36→  tenantDb: Database.Database | undefined,\n    37→  scopedProjectId: string | undefined,\n    38→  reqLogger: Logger,\n    39→) => Promise<void> | void;\n    40→\n    41→interface RouteEntry {\n    42→  handler: RouteHandler;\n    43→  needsDb?: boolean;\n    44→  adminOnly?: boolean;\n    45→}\n    46→\n    47→/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\n    48→function resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n    49→  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n    50→}\n    51→\n    52→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n    53→function parseRoute(pathname: string): ParsedRoute | null {\n    54→  if (!pathname.startsWith('/api/')) return null;\n    55→  const segments = pathname.slice(5).split('/').filter(Boolean);\n    56→  if (segments.length === 0) return null;\n    57→  return {\n    58→    resource: segments[0]!,\n    59→    id: segments[1],\n    60→    subResource: segments[2],\n    61→  };\n    62→}\n    63→\n    64→export function createHttpApi(\n    65→  auth: Auth,\n    66→  dispatcher: Dispatcher,\n    67→  pool: WorkerPool,\n    68→  tokenManager: TokenManager,\n    69→  oauth: OAuthManager,\n    70→  logger: Logger,\n    71→  database?: Database.Database,\n    72→  tenantDbManager?: TenantDbManager,\n    73→  tenantKeyManager?: TenantKeyManager,\n    74→  auditLog?: AuditLog,\n    75→  getEventProcessorHealth?: () => EventProcessorHealth,\n    76→  kafka?: KafkaClient,\n    77→  onEventPublished?: () => void,\n    78→  triggerScheduler?: TriggerSchedulerHandle,\n    79→): http.Server {\n    80→\n    81→  /** Wrap a mutation handler to emit an audit event on successful response. */\n    82→  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    83→    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n    84→      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n    85→      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n    86→        try {\n    87→          auditLog.record({\n    88→            action,\n    89→            tenantId: ctx.projectId || 'default',\n    90→            actor: ctx.userEmail || ctx.projectId,\n    91→            resourceType,\n    92→            resourceId: route?.id,\n    93→            ipAddress: req.socket.remoteAddress,\n    94→          } as AuditEntry);\n    95→        } catch { /* logged inside record() */ }\n    96→      }\n    97→    };\n    98→  }\n    99→\n   100→  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n   101→  const exactRoutes = new Map<string, RouteEntry>();\n   102→\n   103→  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n   104→  for (const [path, method] of [\n   105→    ['/api/oauth/authorize', 'POST'],\n   106→    ['/api/oauth/callback', 'POST'],\n   107→    ['/api/oauth/status', 'GET'],\n   108→    ['/api/oauth/refresh', 'POST'],\n   109→    ['/api/oauth/disconnect', 'DELETE'],\n   110→    ['/api/token', 'POST'],\n   111→  ] as const) {\n   112→    exactRoutes.set(`${method}:${path}`, {\n   113→      adminOnly: true,\n   114→      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   115→        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger, auditLog);\n   116→      },\n   117→    });\n   118→  }\n   119→\n   120→  exactRoutes.set('GET:/api/status', {\n   121→    handler: (_req, res) => {\n   122→      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   123→    },\n   124→  });\n   125→\n   126→  exactRoutes.set('POST:/api/execute', {\n   127→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   128→      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n   129→    }, 'execution:submit', 'execution'),\n   130→  });\n   131→\n   132→  exactRoutes.set('POST:/api/gitlab/webhook', {\n   133→    needsDb: true,\n   134→    handler: withHttpAudit(async (req, res, _ctx, _route, _qs, tenantDb) => {\n   135→      const body = await readBody(req);\n   136→      let parsed: Record<string, unknown> = {};\n   137→      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   138→      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   139→      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   140→      const event = db.publishEvent(tenantDb!, {\n   141→        eventType: `gitlab_${objectKind}`,\n   142→        sourceType: 'gitlab',\n   143→        sourceId: projectPath ?? null,\n   144→        payload: body,\n   145→      });\n   146→      onEventPublished?.();\n   147→      json(res, 201, event);\n   148→    }, 'event:publish', 'event'),\n   149→  });\n   150→\n   151→  // Admin routes\n   152→  exactRoutes.set('GET:/api/admin/users', {\n   153→    adminOnly: true,\n   154→    handler: (_req, res) => {\n   155→      if (tenantDbManager) {\n   156→        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   157→      } else if (database) {\n   158→        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   159→      } else {\n   160→        json(res, 200, { projectIds: [] });\n   161→      }\n   162→    },\n   163→  });\n   164→\n   165→  exactRoutes.set('GET:/api/admin/personas', {\n   166→    adminOnly: true,\n   167→    handler: (_req, res) => {\n   168→      if (tenantDbManager) {\n   169→        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   170→        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   171→        json(res, 200, allPersonas);\n   172→      } else if (database) {\n   173→        json(res, 200, db.listPersonasSummary(database));\n   174→      } else {\n   175→        json(res, 200, []);\n   176→      }\n   177→    },\n   178→  });\n   179→\n   180→  exactRoutes.set('GET:/api/admin/executions', {\n   181→    adminOnly: true,\n   182→    handler: (_req, res, _ctx, _route, queryString) => {\n   183→      const params = new URLSearchParams(queryString || '');\n   184→      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   185→      if (tenantDbManager) {\n   186→        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   187→        tenantDbManager.forEachTenant((tDb) => {\n   188→          allExecs.push(...db.listExecutions(tDb, { limit }));\n   189→        });\n   190→        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   191→        json(res, 200, allExecs.slice(0, limit));\n   192→      } else if (database) {\n   193→        json(res, 200, db.listExecutions(database, {\n   194→          limit,\n   195→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   196→        }));\n   197→      } else {\n   198→        json(res, 200, []);\n   199→      }\n   200→    },\n   201→  });\n   202→\n   203→  exactRoutes.set('GET:/api/admin/audit', {\n   204→    adminOnly: true,\n   205→    handler: (_req, res, _ctx, _route, queryString) => {\n   206→      if (!auditLog) { json(res, 200, []); return; }\n   207→      const params = new URLSearchParams(queryString || '');\n   208→      json(res, 200, auditLog.query({\n   209→        tenantId: params.get('tenantId') ?? undefined,\n   210→        action: (params.get('action') ?? undefined) as AuditAction | undefined,\n   211→        since: params.get('since') ?? undefined,\n   212→        until: params.get('until') ?? undefined,\n   213→        actor: params.get('actor') ?? undefined,\n   214→        resourceType: params.get('resourceType') ?? undefined,\n   215→        resourceId: params.get('resourceId') ?? undefined,\n   216→        limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   217→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   218→      }));\n   219→    },\n   220→  });\n   221→\n   222→  exactRoutes.set('GET:/api/admin/audit/stats', {\n   223→    adminOnly: true,\n   224→    handler: (_req, res, _ctx, _route, queryString) => {\n   225→      if (!auditLog) { json(res, 200, { byAction: [], byTenant: [], topActors: [], trend: [] }); return; }\n   226→      const params = new URLSearchParams(queryString || '');\n   227→      const bucket = params.get('bucket') === 'hour' ? 'hour' : 'day';\n   228→      json(res, 200, auditLog.stats({\n   229→        tenantId: params.get('tenantId') ?? undefined,\n   230→        since: params.get('since') ?? undefined,\n   231→        until: params.get('until') ?? undefined,\n   232→        bucket,\n   233→      }));\n   234→    },\n   235→  });\n   236→\n   237→  exactRoutes.set('POST:/api/admin/audit/verify', {\n   238→    adminOnly: true,\n   239→    handler: async (req, res) => {\n   240→      if (!auditLog) { json(res, 200, { valid: true, verifiedCount: 0 }); return; }\n   241→      const body = await readBody(req);\n   242→      let opts: { since?: string; until?: string } | undefined;\n   243→      if (body) {\n   244→        try {\n   245→          const parsed = JSON.parse(body) as { since?: string; until?: string };\n   246→          if (parsed.since || parsed.until) opts = { since: parsed.since, until: parsed.until };\n   247→        } catch { /* empty body or non-JSON — verify entire chain */ }\n   248→      }\n   249→      json(res, 200, auditLog.verify(opts));\n   250→    },\n   251→  });\n   252→\n   253→  // ── Resource route table (O(1) lookup by `METHOD:resource[:id][:sub]`) ──\n   254→  const resourceRoutes = new Map<string, RouteEntry>();\n   255→\n   256→  // --- Persona CRUD ---\n   257→  resourceRoutes.set(resourceKey('GET', 'personas', false), {\n   258→    needsDb: true,\n   259→    handler: (_req, res, _ctx, _route, _qs, tenantDb, scopedProjectId) => {\n   260→      json(res, 200, db.listPersonasSummary(tenantDb!, scopedProjectId));\n   261→    },\n   262→  });\n   263→\n   264→  resourceRoutes.set(resourceKey('POST', 'personas', false), {\n   265→    needsDb: true,\n   266→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   267→      const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   268→      const persona = createPersonaWithDefaults({\n   269→        ...body,\n   270→        projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   271→      });\n   272→      db.upsertPersona(tenantDb!, persona);\n   273→      try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: persona.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   274→      reqLogger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   275→      json(res, 201, persona);\n   276→    },\n   277→  });\n   278→\n   279→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'tools'), {\n   280→    needsDb: true,\n   281→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   282→      json(res, 200, db.getToolsForPersona(tenantDb!, route!.id!));\n   283→    },\n   284→  });\n   285→\n   286→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'tools'), {\n   287→    needsDb: true,\n   288→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   289→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   290→      if (!persona) return;\n   291→      const body = JSON.parse(await readBody(req)) as { toolId: string };\n   292→      db.linkTool(tenantDb!, route!.id!, body.toolId);\n   293→      try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { toolId: body.toolId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   294→      reqLogger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route!.id!, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   295→      json(res, 200, { linked: true });\n   296→    },\n   297→  });\n   298→\n   299→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'full'), {\n   300→    needsDb: true,\n   301→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   302→      const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb!, route!.id!, reqLogger), scopedProjectId, res);\n   303→      if (!hydrated) return;\n   304→      json(res, 200, hydrated);\n   305→    },\n   306→  });\n   307→\n   308→  resourceRoutes.set(resourceKey('GET', 'personas', true), {\n   309→    needsDb: true,\n   310→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId) => {\n   311→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   312→      if (!persona) return;\n   313→      json(res, 200, persona);\n   314→    },\n   315→  });\n   316→\n   317→  resourceRoutes.set(resourceKey('DELETE', 'personas', true), {\n   318→    needsDb: true,\n   319→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   320→      db.deletePersona(tenantDb!, route!.id!, scopedProjectId);\n   321→      try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   322→      reqLogger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   323→      json(res, 200, { deleted: true });\n   324→    },\n   325→  });\n   326→\n   327→  // --- Persona sub-resources: credentials ---\n   328→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'credentials'), {\n   329→    needsDb: true,\n   330→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   331→      const creds = db.listCredentialsForPersona(tenantDb!, route!.id!);\n   332→      try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   333→      json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   334→    },\n   335→  });\n   336→\n   337→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'credentials'), {\n   338→    needsDb: true,\n   339→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   340→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   341→      if (!persona) return;\n   342→      const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   343→      db.linkCredential(tenantDb!, route!.id!, body.credentialId);\n   344→      try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { credentialId: body.credentialId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   345→      reqLogger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route!.id!, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   346→      json(res, 200, { linked: true });\n   347→    },\n   348→  });\n   349→\n   350→  // --- Persona sub-resources: subscriptions ---\n   351→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'subscriptions'), {\n   352→    needsDb: true,\n   353→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   354→      json(res, 200, db.listSubscriptionsForPersona(tenantDb!, route!.id!));\n   355→    },\n   356→  });\n   357→\n   358→  // --- Tool Definitions ---\n   359→  resourceRoutes.set(resourceKey('POST', 'tool-definitions', false), {\n   360→    needsDb: true,\n   361→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   362→      const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   363→      const tool = createToolDefinitionWithDefaults(body);\n   364→      db.upsertToolDefinition(tenantDb!, tool);\n   365→      try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'toolDefinition', resourceId: tool.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   366→      reqLogger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   367→      json(res, 201, tool);\n   368→    },\n   369→  });\n   370→\n   371→  // --- Credentials ---\n   372→  resourceRoutes.set(resourceKey('POST', 'credentials', false), {\n   373→    needsDb: true,\n   374→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   375→      const body = JSON.parse(await readBody(req));\n   376→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   377→\n   378→      if (!body.plaintext || typeof body.plaintext !== 'string') {\n   379→        json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   380→        return;\n   381→      }\n   382→      if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   383→        json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   384→        return;\n   385→      }\n   386→      if (!tenantKeyManager) {\n   387→        json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   388→        return;\n   389→      }\n   390→\n   391→      delete body.encryptedData;\n   392→      delete body.iv;\n   393→      delete body.tag;\n   394→\n   395→      const tenantId = body.projectId || ctx.projectId || 'default';\n   396→      const key = await tenantKeyManager.getKey(tenantId);\n   397→      const encrypted = encrypt(body.plaintext, key);\n   398→      body.encryptedData = encrypted.encrypted;\n   399→      body.iv = encrypted.iv;\n   400→      body.tag = encrypted.tag;\n   401→      delete body.plaintext;\n   402→\n   403→      const cred = db.createCredential(tenantDb!, body);\n   404→      try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: cred.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   405→      reqLogger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   406→      json(res, 201, cred);\n   407→    },\n   408→  });\n   409→\n   410→  resourceRoutes.set(resourceKey('DELETE', 'credentials', true), {\n   411→    needsDb: true,\n   412→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   413→      const changes = db.deleteCredential(tenantDb!, route!.id!, scopedProjectId);\n   414→      if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   415→      try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   416→      reqLogger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   417→      json(res, 200, { deleted: true });\n   418→    },\n   419→  });\n   420→\n   421→  // --- Event Subscriptions ---\n   422→  resourceRoutes.set(resourceKey('POST', 'subscriptions', false), {\n   423→    needsDb: true,\n   424→    handler: async (req, res, ctx, _route, _qs, tenantDb) => {\n   425→      const body = JSON.parse(await readBody(req));\n   426→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   427→      const missing: string[] = [];\n   428→      if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   429→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   430→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   431→      const sub = db.createSubscription(tenantDb!, body);\n   432→      try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: sub.id, detail: { personaId: body.personaId, eventType: body.eventType }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   433→      json(res, 201, sub);\n   434→    },\n   435→  });\n   436→\n   437→  resourceRoutes.set(resourceKey('PUT', 'subscriptions', true), {\n   438→    needsDb: true,\n   439→    handler: async (req, res, ctx, route, _qs, tenantDb) => {\n   440→      const body = JSON.parse(await readBody(req));\n   441→      db.updateSubscription(tenantDb!, route!.id!, body);\n   442→      const updated = db.getSubscription(tenantDb!, route!.id!);\n   443→      try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   444→      json(res, 200, updated);\n   445→    },\n   446→  });\n   447→\n   448→  resourceRoutes.set(resourceKey('DELETE', 'subscriptions', true), {\n   449→    needsDb: true,\n   450→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   451→      db.deleteSubscription(tenantDb!, route!.id!);\n   452→      try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   453→      json(res, 200, { deleted: true });\n   454→    },\n   455→  });\n   456→\n   457→  // --- Triggers (delegated to triggerHttpHandlers) ---\n   458→  const triggerHandler: RouteHandler = async (req, res, ctx, route, _qs, tenantDb) => {\n   459→    await handleTriggerRoute(route!, req.method!, req, res, tenantDb!, ctx, triggerScheduler);\n   460→  };\n   461→  resourceRoutes.set(resourceKey('POST', 'triggers', false), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:create', 'trigger') });\n   462→  resourceRoutes.set(resourceKey('PUT', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:update', 'trigger') });\n   463→  resourceRoutes.set(resourceKey('DELETE', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:delete', 'trigger') });\n   464→  resourceRoutes.set(resourceKey('GET', 'triggers', true, 'history'), { needsDb: true, handler: triggerHandler });\n   465→  resourceRoutes.set(resourceKey('GET', 'triggers', true, 'stats'), { needsDb: true, handler: triggerHandler });\n   466→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'triggers'), { needsDb: true, handler: triggerHandler });\n   467→\n   468→  // --- Events ---\n   469→  resourceRoutes.set(resourceKey('GET', 'events', false), {\n   470→    needsDb: true,\n   471→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   472→      const params = new URLSearchParams(queryString || '');\n   473→      const events = db.listEvents(tenantDb!, {\n   474→        eventType: params.get('eventType') ?? undefined,\n   475→        status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n   476→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   477→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   478→        projectId: scopedProjectId,\n   479→      });\n   480→      json(res, 200, events);\n   481→    },\n   482→  });\n   483→\n   484→  resourceRoutes.set(resourceKey('POST', 'events', false), {\n   485→    needsDb: true,\n   486→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, tenantDb) => {\n   487→      const body = JSON.parse(await readBody(req));\n   488→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   489→      const missing: string[] = [];\n   490→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   491→      if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   492→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   493→      const event = db.publishEvent(tenantDb!, body);\n   494→      onEventPublished?.();\n   495→      json(res, 201, event);\n   496→    }, 'event:publish', 'event'),\n   497→  });\n   498→\n   499→  resourceRoutes.set(resourceKey('PUT', 'events', true), {\n   500→    needsDb: true,\n   501→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   502→      const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n   503→      const updated = db.updateEventWithMetadata(tenantDb!, route!.id!, body.status, body.metadata);\n   504→      if (updated) {\n   505→        json(res, 200, updated);\n   506→      } else {\n   507→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   508→        res.end(JSON.stringify({ error: 'Event not found' }));\n   509→      }\n   510→    }, 'event:update', 'event'),\n   511→  });\n   512→\n   513→  // --- Webhooks ---\n   514→  resourceRoutes.set(resourceKey('POST', 'webhooks', true), {\n   515→    needsDb: true,\n   516→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   517→      const personaId = route!.id!;\n   518→      const body = await readBody(req);\n   519→      const event = db.publishEvent(tenantDb!, {\n   520→        eventType: 'webhook_received',\n   521→        sourceType: 'webhook',\n   522→        sourceId: personaId,\n   523→        targetPersonaId: personaId,\n   524→        payload: body,\n   525→      });\n   526→      onEventPublished?.();\n   527→      json(res, 201, event);\n   528→    }, 'webhook:receive', 'webhook'),\n   529→  });\n   530→\n   531→  // --- Executions ---\n   532→  resourceRoutes.set(resourceKey('GET', 'executions', false), {\n   533→    needsDb: true,\n   534→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   535→      const params = new URLSearchParams(queryString || '');\n   536→      const executions = db.listExecutions(tenantDb!, {\n   537→        personaId: params.get('personaId') ?? undefined,\n   538→        status: params.get('status') ?? undefined,\n   539→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   540→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   541→        projectId: scopedProjectId,\n   542→      });\n   543→      json(res, 200, executions);\n   544→    },\n   545→  });\n   546→\n   547→  resourceRoutes.set(resourceKey('POST', 'executions', true, 'cancel'), {\n   548→    handler: (_req, res, _ctx, route) => {\n   549→      handleCancelExecution(res, dispatcher, route!.id!);\n   550→    },\n   551→  });\n   552→\n   553→  resourceRoutes.set(resourceKey('GET', 'executions', true), {\n   554→    handler: (_req, res, _ctx, route, queryString) => {\n   555→      const params = new URLSearchParams(queryString || '');\n   556→      const offset = parseInt(params.get('offset') || '0', 10);\n   557→      handleGetExecution(res, dispatcher, route!.id!, offset);\n   558→    },\n   559→  });\n   560→\n   561→  // ── Request handler ──\n   562→  const server = http.createServer(async (req, res) => {\n   563→    // Request correlation ID\n   564→    const reqId = nanoid();\n   565→    const reqLogger = logger.child({ reqId });\n   566→    res.setHeader('X-Request-Id', reqId);\n   567→\n   568→    // Security headers\n   569→    res.setHeader('X-Content-Type-Options', 'nosniff');\n   570→\n   571→    // CORS headers\n   572→    const origin = req.headers.origin ?? '';\n   573→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n   574→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n   575→    if (isAdminRoute) {\n   576→      if (origin && origin === allowedOrigin) {\n   577→        res.setHeader('Access-Control-Allow-Origin', origin);\n   578→      }\n   579→    } else {\n   580→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n   581→    }\n   582→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n   583→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n   584→\n   585→    if (req.method === 'OPTIONS') {\n   586→      res.writeHead(204);\n   587→      res.end();\n   588→      return;\n   589→    }\n   590→\n   591→    const url = req.url || '/';\n   592→    const [pathname, queryString] = url.split('?');\n   593→    const route = parseRoute(pathname ?? '');\n   594→\n   595→    // Unauthenticated endpoint\n   596→    if (pathname === '/health' && req.method === 'GET') {\n   597→      await handleHealth(res, pool, dispatcher, oauth, getEventProcessorHealth, database, tenantDbManager, kafka, triggerScheduler);\n   598→      return;\n   599→    }\n   600→\n   601→    // Auth check\n   602→    const ctx = auth.validateAndExtractContext(req);\n   603→    if (!ctx) {\n   604→      res.writeHead(401, { 'Content-Type': 'application/json' });\n   605→      res.end(JSON.stringify({ error: 'Unauthorized', reqId }));\n   606→      return;\n   607→    }\n   608→\n   609→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n   610→\n   611→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n   612→      if (tenantDbManager && projectId) {\n   613→        return tenantDbManager.getTenantDb(projectId);\n   614→      }\n   615→      return database;\n   616→    };\n   617→    const tenantDb = resolveDatabase(ctx.projectId);\n   618→\n   619→    try {\n   620→      // O(1) exact-path lookup\n   621→      const exactEntry = exactRoutes.get(`${req.method}:${pathname}`);\n   622→      if (exactEntry) {\n   623→        if (exactEntry.adminOnly && requireAdmin(ctx, res)) return;\n   624→        if (exactEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   625→        await exactEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   626→        return;\n   627→      }\n   628→\n   629→      // O(1) resource-route lookup\n   630→      if (route) {\n   631→        const resKey = resourceKey(req.method!, route.resource, !!route.id, route.subResource);\n   632→        const resEntry = resourceRoutes.get(resKey);\n   633→        if (resEntry) {\n   634→          if (resEntry.adminOnly && requireAdmin(ctx, res)) return;\n   635→          if (resEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   636→          await resEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   637→          return;\n   638→        }\n   639→      }\n   640→\n   641→      // No matching route\n   642→      json(res, 404, { error: 'Not found', reqId });\n   643→    } catch (err) {\n   644→      if (err instanceof Error && err.message === 'Payload too large') {\n   645→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   646→        res.end(JSON.stringify({ error: 'Payload too large', reqId }));\n   647→        return;\n   648→      }\n   649→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   650→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   651→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists', reqId }));\n   652→        return;\n   653→      }\n   654→      reqLogger.error({ err, url }, 'HTTP handler error');\n   655→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   656→      res.end(JSON.stringify({ error: 'Internal server error', reqId }));\n   657→    }\n   658→  });\n   659→\n   660→  return server;\n   661→}\n   662→\n   663→/**\n   664→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   665→ * Returns the entity on success, or null after sending a 404 response.\n   666→ */\n   667→function withScopedEntity<T extends { projectId?: string | null }>(\n   668→  entity: T | undefined,\n   669→  scopedProjectId: string | undefined,\n   670→  res: http.ServerResponse,\n   671→): T | null {\n   672→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   673→    json(res, 404, { error: 'Not found' });\n   674→    return null;\n   675→  }\n   676→  return entity;\n   677→}\n   678→\n   679→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   680→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   681→  if (ctx.authType !== 'admin') {\n   682→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   683→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   684→    return true;\n   685→  }\n   686→  return false;\n   687→}\n   688→\n   689→// --- Existing handlers ---\n   690→\n   691→/** Heartbeat age (ms) beyond which a worker is considered stale. */\n   692→const STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n   693→\n   694→async function handleHealth(\n   695→  res: http.ServerResponse,\n   696→  pool: WorkerPool,\n   697→  dispatcher: Dispatcher,\n   698→  oauth: OAuthManager,\n   699→  getEventProcessorHealth?: () => EventProcessorHealth,\n   700→  database?: Database.Database,\n   701→  tenantDbManager?: TenantDbManager,\n   702→  kafka?: KafkaClient,\n   703→  triggerScheduler?: TriggerSchedulerHandle,\n   704→): Promise<void> {\n   705→  const issues: string[] = [];\n   706→\n   707→  const counts = pool.getWorkerCount();\n   708→  const workers = pool.getWorkers();\n   709→  const now = Date.now();\n   710→  const staleWorkers = workers\n   711→    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n   712→    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n   713→\n   714→  if (staleWorkers.length > 0) {\n   715→    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n   716→  }\n   717→\n   718→  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n   719→  if (database) {\n   720→    try {\n   721→      database.prepare('SELECT 1').get();\n   722→      dbHealth.status = 'ok';\n   723→    } catch {\n   724→      dbHealth.status = 'error';\n   725→      issues.push('database unreachable');\n   726→    }\n   727→  }\n   728→  if (tenantDbManager) {\n   729→    try {\n   730→      const tenantIds = tenantDbManager.listTenantIds();\n   731→      dbHealth.tenantCount = tenantIds.length;\n   732→      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n   733→    } catch {\n   734→      dbHealth.tenantCount = -1;\n   735→      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n   736→      issues.push('tenant DB listing failed');\n   737→    }\n   738→  }\n   739→\n   740→  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n   741→  if (kafka) {\n   742→    const kh = await kafka.checkHealth();\n   743→    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n   744→    if (kh.status === 'error') {\n   745→      issues.push(`kafka: ${kh.detail || 'error'}`);\n   746→    }\n   747→  }\n   748→\n   749→  const queueDepth = dispatcher.getQueueLength();\n   750→  const activeExecutions = dispatcher.getActiveExecutions().length;\n   751→\n   752→  let eventProcessorHealth: EventProcessorHealth | undefined;\n   753→  if (getEventProcessorHealth) {\n   754→    eventProcessorHealth = getEventProcessorHealth();\n   755→  }\n   756→\n   757→  let verdict: 'healthy' | 'degraded' | 'unhealthy';\n   758→  if (issues.some(i => i.includes('database unreachable') || i.includes('kafka: '))) {\n   759→    verdict = 'unhealthy';\n   760→  } else if (issues.length > 0) {\n   761→    verdict = 'degraded';\n   762→  } else {\n   763→    verdict = 'healthy';\n   764→  }\n   765→\n   766→  const body: Record<string, unknown> = {\n   767→    status: verdict,\n   768→    timestamp: Date.now(),\n   769→    dependencies: {\n   770→      database: dbHealth,\n   771→      kafka: kafkaHealth,\n   772→      workers: {\n   773→        ...counts,\n   774→        staleWorkers: staleWorkers.length > 0 ? staleWorkers : undefined,\n   775→      },\n   776→    },\n   777→    queue: {\n   778→      depth: queueDepth,\n   779→      activeExecutions,\n   780→    },\n   781→    hasSubscription: oauth.hasTokens(),\n   782→  };\n   783→\n   784→  if (eventProcessorHealth) {\n   785→    (body.dependencies as Record<string, unknown>).eventProcessor = eventProcessorHealth;\n   786→  }\n   787→\n   788→  if (triggerScheduler) {\n   789→    (body as Record<string, unknown>).scheduler = triggerScheduler.getMetrics();\n   790→  }\n   791→\n   792→  if (issues.length > 0) {\n   793→    body.issues = issues;\n   794→  }\n   795→\n   796→  const httpStatus = verdict === 'unhealthy' ? 503 : 200;\n   797→  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n   798→  res.end(JSON.stringify(body));\n   799→}\n   800→\n   801→function handleStatus(\n   802→  res: http.ServerResponse,\n   803→  pool: WorkerPool,\n   804→  dispatcher: Dispatcher,\n   805→  tokenManager: TokenManager,\n   806→  oauth: OAuthManager,\n   807→): void {\n   808→  const oauthTokens = oauth.getTokens();\n   809→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   810→  res.end(JSON.stringify({\n   811→    workers: pool.getWorkers(),\n   812→    workerCounts: pool.getWorkerCount(),\n   813→    workerPoolMetrics: pool.getMetrics(),\n   814→    queueLength: dispatcher.getQueueLength(),\n   815→    activeExecutions: dispatcher.getActiveExecutions(),\n   816→    hasClaudeToken: tokenManager.hasToken(),\n   817→    oauth: {\n   818→      connected: oauth.hasTokens(),\n   819→      scopes: oauthTokens?.scopes || [],\n   820→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   821→    },\n   822→  }));\n   823→}\n   824→\n   825→async function handleExecute(\n   826→  req: http.IncomingMessage,\n   827→  res: http.ServerResponse,\n   828→  dispatcher: Dispatcher,\n   829→  logger: Logger,\n   830→  ctx?: RequestContext,\n   831→): Promise<void> {\n   832→  const body = await readBody(req);\n   833→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   834→\n   835→  try {\n   836→    parsed = JSON.parse(body);\n   837→  } catch {\n   838→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   839→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   840→    return;\n   841→  }\n   842→\n   843→  if (!parsed.prompt) {\n   844→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   845→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   846→    return;\n   847→  }\n   848→\n   849→  const request: ExecRequest = {\n   850→    executionId: nanoid(),\n   851→    personaId: parsed.personaId || 'manual',\n   852→    prompt: parsed.prompt,\n   853→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   854→    config: {\n   855→      timeoutMs: parsed.timeoutMs || 300_000,\n   856→    },\n   857→  };\n   858→\n   859→  const result: SubmitResult = dispatcher.submit(request);\n   860→\n   861→  if (!result.accepted) {\n   862→    logger.warn({ executionId: request.executionId, reason: result.reason }, 'Execution rejected by backpressure');\n   863→    res.writeHead(429, {\n   864→      'Content-Type': 'application/json',\n   865→      'Retry-After': String(result.retryAfterSeconds),\n   866→    });\n   867→    res.end(JSON.stringify({\n   868→      error: result.reason === 'tenant_quota_exceeded'\n   869→        ? 'Per-tenant queue quota exceeded'\n   870→        : 'Queue depth limit exceeded',\n   871→      retryAfterSeconds: result.retryAfterSeconds,\n   872→    }));\n   873→    return;\n   874→  }\n   875→\n   876→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   877→\n   878→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   879→  res.end(JSON.stringify({\n   880→    executionId: request.executionId,\n   881→    status: 'queued',\n   882→  }));\n   883→}\n   884→\n   885→function handleGetExecution(\n   886→  res: http.ServerResponse,\n   887→  dispatcher: Dispatcher,\n   888→  executionId: string,\n   889→  offset: number = 0,\n   890→): void {\n   891→  const exec = dispatcher.getExecution(executionId);\n   892→\n   893→  if (!exec) {\n   894→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   895→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   896→    return;\n   897→  }\n   898→\n   899→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   900→\n   901→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   902→  res.end(JSON.stringify({\n   903→    executionId,\n   904→    status: exec.status,\n   905→    outputLines: exec.output.length,\n   906→    output,\n   907→    durationMs: exec.durationMs,\n   908→    sessionId: exec.sessionId,\n   909→    totalCostUsd: exec.totalCostUsd,\n   910→    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n   911→  }));\n   912→}\n   913→\n   914→function handleCancelExecution(\n   915→  res: http.ServerResponse,\n   916→  dispatcher: Dispatcher,\n   917→  executionId: string,\n   918→): void {\n   919→  const cancelled = dispatcher.cancelExecution(executionId);\n   920→\n   921→  if (!cancelled) {\n   922→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   923→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   924→    return;\n   925→  }\n   926→\n   927→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   928→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   929→}\n   930→\n   931→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB\n   932→const MAX_QUERY_LIMIT = 500;\n   933→const MAX_QUERY_OFFSET = 100_000;\n   934→\n   935→/** Parse an integer query param and clamp it to safe bounds. */\n   936→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   937→  if (!value) return defaultValue;\n   938→  const parsed = parseInt(value, 10);\n   939→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   940→  return Math.min(parsed, max);\n   941→}\n   942→"}]},"parent_tool_use_id":null,"session_id":"4c343ef4-c6b6-46db-bafa-7e39119894bb","uuid":"687f619e-77f2-4694-88a4-34e20858756b","timestamp":"2026-03-19T08:15:25.372Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher, SubmitResult } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TriggerSchedulerHandle } from './triggerScheduler.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog, AuditEntry, AuditAction } from './auditLog.js';\nimport type { EventProcessorHealth } from './eventProcessor.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\n// --- Route types ---\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\ntype RouteHandler = (\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  ctx: RequestContext,\n  route: ParsedRoute | null,\n  queryString: string | undefined,\n  tenantDb: Database.Database | undefined,\n  scopedProjectId: string | undefined,\n  reqLogger: Logger,\n) => Promise<void> | void;\n\ninterface RouteEntry {\n  handler: RouteHandler;\n  needsDb?: boolean;\n  adminOnly?: boolean;\n}\n\n/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\nfunction resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  kafka?: KafkaClient,\n  onEventPublished?: () => void,\n  triggerScheduler?: TriggerSchedulerHandle,\n): http.Server {\n\n  /** Wrap a mutation handler to emit an audit event on successful response. */\n  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n        try {\n          auditLog.record({\n            action,\n            tenantId: ctx.projectId || 'default',\n            actor: ctx.userEmail || ctx.projectId,\n            resourceType,\n            resourceId: route?.id,\n            ipAddress: req.socket.remoteAddress,\n          } as AuditEntry);\n        } catch { /* logged inside record() */ }\n      }\n    };\n  }\n\n  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n  const exactRoutes = new Map<string, RouteEntry>();\n\n  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n  for (const [path, method] of [\n    ['/api/oauth/authorize', 'POST'],\n    ['/api/oauth/callback', 'POST'],\n    ['/api/oauth/status', 'GET'],\n    ['/api/oauth/refresh', 'POST'],\n    ['/api/oauth/disconnect', 'DELETE'],\n    ['/api/token', 'POST'],\n  ] as const) {\n    exactRoutes.set(`${method}:${path}`, {\n      adminOnly: true,\n      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger, auditLog);\n      },\n    });\n  }\n\n  exactRoutes.set('GET:/api/status', {\n    handler: (_req, res) => {\n      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n    },\n  });\n\n  exactRoutes.set('POST:/api/execute', {\n    handler: withHttpAudit(async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n    }, 'execution:submit', 'execution'),\n  });\n\n  exactRoutes.set('POST:/api/gitlab/webhook', {\n    needsDb: true,\n    handler: withHttpAudit(async (req, res, _ctx, _route, _qs, tenantDb) => {\n      const body = await readBody(req);\n      let parsed: Record<string, unknown> = {};\n      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n      const event = db.publishEvent(tenantDb!, {\n        eventType: `gitlab_${objectKind}`,\n        sourceType: 'gitlab',\n        sourceId: projectPath ?? null,\n        payload: body,\n      });\n      onEventPublished?.();\n      json(res, 201, event);\n    }, 'event:publish', 'event'),\n  });\n\n  // Admin routes\n  exactRoutes.set('GET:/api/admin/users', {\n    adminOnly: true,\n    handler: (_req, res) => {\n      if (tenantDbManager) {\n        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n      } else if (database) {\n        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n      } else {\n        json(res, 200, { projectIds: [] });\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/personas', {\n    adminOnly: true,\n    handler: (_req, res) => {\n      if (tenantDbManager) {\n        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n        json(res, 200, allPersonas);\n      } else if (database) {\n        json(res, 200, db.listPersonasSummary(database));\n      } else {\n        json(res, 200, []);\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/executions', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      const params = new URLSearchParams(queryString || '');\n      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n      if (tenantDbManager) {\n        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n        tenantDbManager.forEachTenant((tDb) => {\n          allExecs.push(...db.listExecutions(tDb, { limit }));\n        });\n        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n        json(res, 200, allExecs.slice(0, limit));\n      } else if (database) {\n        json(res, 200, db.listExecutions(database, {\n          limit,\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        }));\n      } else {\n        json(res, 200, []);\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/audit', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      if (!auditLog) { json(res, 200, []); return; }\n      const params = new URLSearchParams(queryString || '');\n      json(res, 200, auditLog.query({\n        tenantId: params.get('tenantId') ?? undefined,\n        action: (params.get('action') ?? undefined) as AuditAction | undefined,\n        since: params.get('since') ?? undefined,\n        until: params.get('until') ?? undefined,\n        actor: params.get('actor') ?? undefined,\n        resourceType: params.get('resourceType') ?? undefined,\n        resourceId: params.get('resourceId') ?? undefined,\n        limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n      }));\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/audit/stats', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      if (!auditLog) { json(res, 200, { byAction: [], byTenant: [], topActors: [], trend: [] }); return; }\n      const params = new URLSearchParams(queryString || '');\n      const bucket = params.get('bucket') === 'hour' ? 'hour' : 'day';\n      json(res, 200, auditLog.stats({\n        tenantId: params.get('tenantId') ?? undefined,\n        since: params.get('since') ?? undefined,\n        until: params.get('until') ?? undefined,\n        bucket,\n      }));\n    },\n  });\n\n  exactRoutes.set('POST:/api/admin/audit/verify', {\n    adminOnly: true,\n    handler: async (req, res) => {\n      if (!auditLog) { json(res, 200, { valid: true, verifiedCount: 0 }); return; }\n      const body = await readBody(req);\n      let opts: { since?: string; until?: string } | undefined;\n      if (body) {\n        try {\n          const parsed = JSON.parse(body) as { since?: string; until?: string };\n          if (parsed.since || parsed.until) opts = { since: parsed.since, until: parsed.until };\n        } catch { /* empty body or non-JSON — verify entire chain */ }\n      }\n      json(res, 200, auditLog.verify(opts));\n    },\n  });\n\n  // ── Resource route table (O(1) lookup by `METHOD:resource[:id][:sub]`) ──\n  const resourceRoutes = new Map<string, RouteEntry>();\n\n  // --- Persona CRUD ---\n  resourceRoutes.set(resourceKey('GET', 'personas', false), {\n    needsDb: true,\n    handler: (_req, res, _ctx, _route, _qs, tenantDb, scopedProjectId) => {\n      json(res, 200, db.listPersonasSummary(tenantDb!, scopedProjectId));\n    },\n  });\n\n  resourceRoutes.set(resourceKey('POST', 'personas', false), {\n    needsDb: true,\n    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n      const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n      const persona = createPersonaWithDefaults({\n        ...body,\n        projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n      });\n      db.upsertPersona(tenantDb!, persona);\n      try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: persona.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n      json(res, 201, persona);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'tools'), {\n    needsDb: true,\n    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n      json(res, 200, db.getToolsForPersona(tenantDb!, route!.id!));\n    },\n  });\n\n  resourceRoutes.set(resourceKey('POST', 'personas', true, 'tools'), {\n    needsDb: true,\n    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n      if (!persona) return;\n      const body = JSON.parse(await readBody(req)) as { toolId: string };\n      db.linkTool(tenantDb!, route!.id!, body.toolId);\n      try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { toolId: body.toolId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route!.id!, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n      json(res, 200, { linked: true });\n    },\n  });\n\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'full'), {\n    needsDb: true,\n    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb!, route!.id!, reqLogger), scopedProjectId, res);\n      if (!hydrated) return;\n      json(res, 200, hydrated);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('GET', 'personas', true), {\n    needsDb: true,\n    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId) => {\n      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n      if (!persona) return;\n      json(res, 200, persona);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('DELETE', 'personas', true), {\n    needsDb: true,\n    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      db.deletePersona(tenantDb!, route!.id!, scopedProjectId);\n      try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n      json(res, 200, { deleted: true });\n    },\n  });\n\n  // --- Persona sub-resources: credentials ---\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'credentials'), {\n    needsDb: true,\n    handler: (req, res, ctx, route, _qs, tenantDb) => {\n      const creds = db.listCredentialsForPersona(tenantDb!, route!.id!);\n      try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n    },\n  });\n\n  resourceRoutes.set(resourceKey('POST', 'personas', true, 'credentials'), {\n    needsDb: true,\n    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n      if (!persona) return;\n      const body = JSON.parse(await readBody(req)) as { credentialId: string };\n      db.linkCredential(tenantDb!, route!.id!, body.credentialId);\n      try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { credentialId: body.credentialId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route!.id!, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n      json(res, 200, { linked: true });\n    },\n  });\n\n  // --- Persona sub-resources: subscriptions ---\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'subscriptions'), {\n    needsDb: true,\n    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n      json(res, 200, db.listSubscriptionsForPersona(tenantDb!, route!.id!));\n    },\n  });\n\n  // --- Tool Definitions ---\n  resourceRoutes.set(resourceKey('POST', 'tool-definitions', false), {\n    needsDb: true,\n    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n      const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n      const tool = createToolDefinitionWithDefaults(body);\n      db.upsertToolDefinition(tenantDb!, tool);\n      try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'toolDefinition', resourceId: tool.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n      json(res, 201, tool);\n    },\n  });\n\n  // --- Credentials ---\n  resourceRoutes.set(resourceKey('POST', 'credentials', false), {\n    needsDb: true,\n    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n      const body = JSON.parse(await readBody(req));\n      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n\n      if (!body.plaintext || typeof body.plaintext !== 'string') {\n        json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n        return;\n      }\n      if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n        json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n        return;\n      }\n      if (!tenantKeyManager) {\n        json(re
[2026-03-19T08:15:25.458Z] [STDOUT] s, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n        return;\n      }\n\n      delete body.encryptedData;\n      delete body.iv;\n      delete body.tag;\n\n      const tenantId = body.projectId || ctx.projectId || 'default';\n      const key = await tenantKeyManager.getKey(tenantId);\n      const encrypted = encrypt(body.plaintext, key);\n      body.encryptedData = encrypted.encrypted;\n      body.iv = encrypted.iv;\n      body.tag = encrypted.tag;\n      delete body.plaintext;\n\n      const cred = db.createCredential(tenantDb!, body);\n      try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: cred.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n      json(res, 201, cred);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('DELETE', 'credentials', true), {\n    needsDb: true,\n    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      const changes = db.deleteCredential(tenantDb!, route!.id!, scopedProjectId);\n      if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n      try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n      json(res, 200, { deleted: true });\n    },\n  });\n\n  // --- Event Subscriptions ---\n  resourceRoutes.set(resourceKey('POST', 'subscriptions', false), {\n    needsDb: true,\n    handler: async (req, res, ctx, _route, _qs, tenantDb) => {\n      const body = JSON.parse(await readBody(req));\n      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n      const missing: string[] = [];\n      if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n      const sub = db.createSubscription(tenantDb!, body);\n      try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: sub.id, detail: { personaId: body.personaId, eventType: body.eventType }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      json(res, 201, sub);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('PUT', 'subscriptions', true), {\n    needsDb: true,\n    handler: async (req, res, ctx, route, _qs, tenantDb) => {\n      const body = JSON.parse(await readBody(req));\n      db.updateSubscription(tenantDb!, route!.id!, body);\n      const updated = db.getSubscription(tenantDb!, route!.id!);\n      try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      json(res, 200, updated);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('DELETE', 'subscriptions', true), {\n    needsDb: true,\n    handler: (req, res, ctx, route, _qs, tenantDb) => {\n      db.deleteSubscription(tenantDb!, route!.id!);\n      try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      json(res, 200, { deleted: true });\n    },\n  });\n\n  // --- Triggers (delegated to triggerHttpHandlers) ---\n  const triggerHandler: RouteHandler = async (req, res, ctx, route, _qs, tenantDb) => {\n    await handleTriggerRoute(route!, req.method!, req, res, tenantDb!, ctx, triggerScheduler);\n  };\n  resourceRoutes.set(resourceKey('POST', 'triggers', false), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:create', 'trigger') });\n  resourceRoutes.set(resourceKey('PUT', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:update', 'trigger') });\n  resourceRoutes.set(resourceKey('DELETE', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:delete', 'trigger') });\n  resourceRoutes.set(resourceKey('GET', 'triggers', true, 'history'), { needsDb: true, handler: triggerHandler });\n  resourceRoutes.set(resourceKey('GET', 'triggers', true, 'stats'), { needsDb: true, handler: triggerHandler });\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'triggers'), { needsDb: true, handler: triggerHandler });\n\n  // --- Events ---\n  resourceRoutes.set(resourceKey('GET', 'events', false), {\n    needsDb: true,\n    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n      const params = new URLSearchParams(queryString || '');\n      const events = db.listEvents(tenantDb!, {\n        eventType: params.get('eventType') ?? undefined,\n        status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        projectId: scopedProjectId,\n      });\n      json(res, 200, events);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('POST', 'events', false), {\n    needsDb: true,\n    handler: withHttpAudit(async (req, res, ctx, _route, _qs, tenantDb) => {\n      const body = JSON.parse(await readBody(req));\n      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n      const missing: string[] = [];\n      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n      if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n      const event = db.publishEvent(tenantDb!, body);\n      onEventPublished?.();\n      json(res, 201, event);\n    }, 'event:publish', 'event'),\n  });\n\n  resourceRoutes.set(resourceKey('PUT', 'events', true), {\n    needsDb: true,\n    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n      const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n      const updated = db.updateEventWithMetadata(tenantDb!, route!.id!, body.status, body.metadata);\n      if (updated) {\n        json(res, 200, updated);\n      } else {\n        res.writeHead(404, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Event not found' }));\n      }\n    }, 'event:update', 'event'),\n  });\n\n  // --- Webhooks ---\n  resourceRoutes.set(resourceKey('POST', 'webhooks', true), {\n    needsDb: true,\n    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n      const personaId = route!.id!;\n      const body = await readBody(req);\n      const event = db.publishEvent(tenantDb!, {\n        eventType: 'webhook_received',\n        sourceType: 'webhook',\n        sourceId: personaId,\n        targetPersonaId: personaId,\n        payload: body,\n      });\n      onEventPublished?.();\n      json(res, 201, event);\n    }, 'webhook:receive', 'webhook'),\n  });\n\n  // --- Executions ---\n  resourceRoutes.set(resourceKey('GET', 'executions', false), {\n    needsDb: true,\n    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n      const params = new URLSearchParams(queryString || '');\n      const executions = db.listExecutions(tenantDb!, {\n        personaId: params.get('personaId') ?? undefined,\n        status: params.get('status') ?? undefined,\n        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        projectId: scopedProjectId,\n      });\n      json(res, 200, executions);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('POST', 'executions', true, 'cancel'), {\n    handler: (_req, res, _ctx, route) => {\n      handleCancelExecution(res, dispatcher, route!.id!);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('GET', 'executions', true), {\n    handler: (_req, res, _ctx, route, queryString) => {\n      const params = new URLSearchParams(queryString || '');\n      const offset = parseInt(params.get('offset') || '0', 10);\n      handleGetExecution(res, dispatcher, route!.id!, offset);\n    },\n  });\n\n  // ── Request handler ──\n  const server = http.createServer(async (req, res) => {\n    // Request correlation ID\n    const reqId = nanoid();\n    const reqLogger = logger.child({ reqId });\n    res.setHeader('X-Request-Id', reqId);\n\n    // Security headers\n    res.setHeader('X-Content-Type-Options', 'nosniff');\n\n    // CORS headers\n    const origin = req.headers.origin ?? '';\n    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    if (isAdminRoute) {\n      if (origin && origin === allowedOrigin) {\n        res.setHeader('Access-Control-Allow-Origin', origin);\n      }\n    } else {\n      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    }\n    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n\n    if (req.method === 'OPTIONS') {\n      res.writeHead(204);\n      res.end();\n      return;\n    }\n\n    const url = req.url || '/';\n    const [pathname, queryString] = url.split('?');\n    const route = parseRoute(pathname ?? '');\n\n    // Unauthenticated endpoint\n    if (pathname === '/health' && req.method === 'GET') {\n      await handleHealth(res, pool, dispatcher, oauth, getEventProcessorHealth, database, tenantDbManager, kafka, triggerScheduler);\n      return;\n    }\n\n    // Auth check\n    const ctx = auth.validateAndExtractContext(req);\n    if (!ctx) {\n      res.writeHead(401, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Unauthorized', reqId }));\n      return;\n    }\n\n    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n\n    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n      if (tenantDbManager && projectId) {\n        return tenantDbManager.getTenantDb(projectId);\n      }\n      return database;\n    };\n    const tenantDb = resolveDatabase(ctx.projectId);\n\n    try {\n      // O(1) exact-path lookup\n      const exactEntry = exactRoutes.get(`${req.method}:${pathname}`);\n      if (exactEntry) {\n        if (exactEntry.adminOnly && requireAdmin(ctx, res)) return;\n        if (exactEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n        await exactEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n        return;\n      }\n\n      // O(1) resource-route lookup\n      if (route) {\n        const resKey = resourceKey(req.method!, route.resource, !!route.id, route.subResource);\n        const resEntry = resourceRoutes.get(resKey);\n        if (resEntry) {\n          if (resEntry.adminOnly && requireAdmin(ctx, res)) return;\n          if (resEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n          await resEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n          return;\n        }\n      }\n\n      // No matching route\n      json(res, 404, { error: 'Not found', reqId });\n    } catch (err) {\n      if (err instanceof Error && err.message === 'Payload too large') {\n        res.writeHead(413, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Payload too large', reqId }));\n        return;\n      }\n      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n        res.writeHead(409, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists', reqId }));\n        return;\n      }\n      reqLogger.error({ err, url }, 'HTTP handler error');\n      res.writeHead(500, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Internal server error', reqId }));\n    }\n  });\n\n  return server;\n}\n\n/**\n * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n * Returns the entity on success, or null after sending a 404 response.\n */\nfunction withScopedEntity<T extends { projectId?: string | null }>(\n  entity: T | undefined,\n  scopedProjectId: string | undefined,\n  res: http.ServerResponse,\n): T | null {\n  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n    json(res, 404, { error: 'Not found' });\n    return null;\n  }\n  return entity;\n}\n\n/** Returns true (and sends 403) if the caller is NOT an admin. */\nfunction requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n  if (ctx.authType !== 'admin') {\n    res.writeHead(403, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Admin access required' }));\n    return true;\n  }\n  return false;\n}\n\n// --- Existing handlers ---\n\n/** Heartbeat age (ms) beyond which a worker is considered stale. */\nconst STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n\nasync function handleHealth(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  oauth: OAuthManager,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  kafka?: KafkaClient,\n  triggerScheduler?: TriggerSchedulerHandle,\n): Promise<void> {\n  const issues: string[] = [];\n\n  const counts = pool.getWorkerCount();\n  const workers = pool.getWorkers();\n  const now = Date.now();\n  const staleWorkers = workers\n    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n\n  if (staleWorkers.length > 0) {\n    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n  }\n\n  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n  if (database) {\n    try {\n      database.prepare('SELECT 1').get();\n      dbHealth.status = 'ok';\n    } catch {\n      dbHealth.status = 'error';\n      issues.push('database unreachable');\n    }\n  }\n  if (tenantDbManager) {\n    try {\n      const tenantIds = tenantDbManager.listTenantIds();\n      dbHealth.tenantCount = tenantIds.length;\n      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n    } catch {\n      dbHealth.tenantCount = -1;\n      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n      issues.push('tenant DB listing failed');\n    }\n  }\n\n  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n  if (kafka) {\n    const kh = await kafka.checkHealth();\n    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n    if (kh.status === 'error') {\n      issues.push(`kafka: ${kh.detail || 'error'}`);\n    }\n  }\n\n  const queueDepth = dispatcher.getQueueLength();\n  const activeExecutions = dispatcher.getActiveExecutions().length;\n\n  let eventProcessorHealth: EventProcessorHealth | undefined;\n  if (getEventProcessorHealth) {\n    eventProcessorHealth = getEventProcessorHealth();\n  }\n\n  let verdict: 'healthy' | 'degraded' | 'unhealthy';\n  if (issues.some(i => i.includes('database unreachable') || i.includes('kafka: '))) {\n    verdict = 'unhealthy';\n  } else if (issues.length > 0) {\n    verdict = 'degraded';\n  } else {\n    verdict = 'healthy';\n  }\n\n  const body: Record<string, unknown> = {\n    status: verdict,\n    timestamp: Date.now(),\n    dependencies: {\n      database: dbHealth,\n      kafka: kafkaHealth,\n      workers: {\n        ...counts,\n        staleWorkers: staleWorkers.length > 0 ? staleWorkers : undefined,\n      },\n    },\n    queue: {\n      depth: queueDepth,\n      activeExecutions,\n    },\n    hasSubscription: oauth.hasTokens(),\n  };\n\n  if (eventProcessorHealth) {\n    (body.dependencies as Record<string, unknown>).eventProcessor = eventProcessorHealth;\n  }\n\n  if (triggerScheduler) {\n    (body as Record<string, unknown>).scheduler = triggerScheduler.getMetrics();\n  }\n\n  if (issues.length > 0) {\n    body.issues = issues;\n  }\n\n  const httpStatus = verdict === 'unhealthy' ? 503 : 200;\n  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify(body));\n}\n\nfunction handleStatus(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n): void {\n  const oauthTokens = oauth.getTokens();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    workers: pool.getWorkers(),\n    workerCounts: pool.getWorkerCount(),\n    workerPoolMetrics: pool.getMetrics(),\n    queueLength: dispatcher.getQueueLength(),\n    activeExecutions: dispatcher.getActiveExecutions(),\n    hasClaudeToken: tokenManager.hasToken(),\n    oauth: {\n      connected: oauth.hasTokens(),\n      scopes: oauthTokens?.scopes || [],\n      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n    },\n  }));\n}\n\nasync function handleExecute(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  ctx?: RequestContext,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.prompt) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n    return;\n  }\n\n  const request: ExecRequest = {\n    executionId: nanoid(),\n    personaId: parsed.personaId || 'manual',\n    prompt: parsed.prompt,\n    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n    config: {\n      timeoutMs: parsed.timeoutMs || 300_000,\n    },\n  };\n\n  const result: SubmitResult = dispatcher.submit(request);\n\n  if (!result.accepted) {\n    logger.warn({ executionId: request.executionId, reason: result.reason }, 'Execution rejected by backpressure');\n    res.writeHead(429, {\n      'Content-Type': 'application/json',\n      'Retry-After': String(result.retryAfterSeconds),\n    });\n    res.end(JSON.stringify({\n      error: result.reason === 'tenant_quota_exceeded'\n        ? 'Per-tenant queue quota exceeded'\n        : 'Queue depth limit exceeded',\n      retryAfterSeconds: result.retryAfterSeconds,\n    }));\n    return;\n  }\n\n  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n\n  res.writeHead(202, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId: request.executionId,\n    status: 'queued',\n  }));\n}\n\nfunction handleGetExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n  offset: number = 0,\n): void {\n  const exec = dispatcher.getExecution(executionId);\n\n  if (!exec) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found' }));\n    return;\n  }\n\n  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId,\n    status: exec.status,\n    outputLines: exec.output.length,\n    output,\n    durationMs: exec.durationMs,\n    sessionId: exec.sessionId,\n    totalCostUsd: exec.totalCostUsd,\n    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n  }));\n}\n\nfunction handleCancelExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n): void {\n  const cancelled = dispatcher.cancelExecution(executionId);\n\n  if (!cancelled) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n    return;\n  }\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n}\n\nconst MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB\nconst MAX_QUERY_LIMIT = 500;\nconst MAX_QUERY_OFFSET = 100_000;\n\n/** Parse an integer query param and clamp it to safe bounds. */\nfunction clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n  if (!value) return defaultValue;\n  const parsed = parseInt(value, 10);\n  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n  return Math.min(parsed, max);\n}\n","numLines":942,"startLine":1,"totalLines":942}}}
