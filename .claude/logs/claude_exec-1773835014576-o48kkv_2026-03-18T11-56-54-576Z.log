orkerBusy {\n    66→  type: 'busy';\n    67→  executionId: string;\n    68→  reason: string;\n    69→}\n    70→\n    71→export type WorkerMessage =\n    72→  | WorkerHello\n    73→  | WorkerReady\n    74→  | ExecStdout\n    75→  | ExecStderr\n    76→  | ExecComplete\n    77→  | WorkerEvent\n    78→  | ExecProgress\n    79→  | WorkerHeartbeat\n    80→  | WorkerBusy;\n    81→\n    82→// --- Orchestrator → Worker ---\n    83→\n    84→export interface OrchestratorAck {\n    85→  type: 'ack';\n    86→  workerId: string;\n    87→  sessionToken: string;\n    88→}\n    89→\n    90→export interface ExecAssign {\n    91→  type: 'assign';\n    92→  executionId: string;\n    93→  personaId: string;\n    94→  prompt: string;\n    95→  env: Record<string, string>;\n    96→  config: {\n    97→    timeoutMs: number;\n    98→    maxOutputBytes: number;\n    99→    networkPolicy?: import('./networkPolicy.js').NetworkPolicy;\n   100→    maxBudgetUsd?: number;\n   101→    maxTurns?: number;\n   102→  };\n   103→}\n   104→\n   105→export interface ExecCancel {\n   106→  type: 'cancel';\n   107→  executionId: string;\n   108→}\n   109→\n   110→export interface OrchestratorShutdown {\n   111→  type: 'shutdown';\n   112→  reason: string;\n   113→  gracePeriodMs: number;\n   114→}\n   115→\n   116→export interface OrchestratorHeartbeat {\n   117→  type: 'heartbeat';\n   118→  timestamp: number;\n   119→}\n   120→\n   121→export type OrchestratorMessage =\n   122→  | OrchestratorAck\n   123→  | ExecAssign\n   124→  | ExecCancel\n   125→  | OrchestratorShutdown\n   126→  | OrchestratorHeartbeat;\n   127→\n   128→// --- Runtime validators ---\n   129→\n   130→function isObj(v: unknown): v is Record<string, unknown> {\n   131→  return typeof v === 'object' && v !== null && !Array.isArray(v);\n   132→}\n   133→\n   134→function hasStr(o: Record<string, unknown>, k: string): boolean {\n   135→  return typeof o[k] === 'string';\n   136→}\n   137→\n   138→function hasNum(o: Record<string, unknown>, k: string): boolean {\n   139→  return typeof o[k] === 'number';\n   140→}\n   141→\n   142→function hasStrArr(o: Record<string, unknown>, k: string): boolean {\n   143→  return Array.isArray(o[k]) && (o[k] as unknown[]).every(v => typeof v === 'string');\n   144→}\n   145→\n   146→export function validateWorkerMessage(msg: unknown): WorkerMessage | null {\n   147→  if (!isObj(msg) || !hasStr(msg, 'type')) return null;\n   148→  const m = msg as Record<string, unknown> & { type: string };\n   149→  switch (m.type) {\n   150→    case 'hello':\n   151→      return hasStr(m, 'workerId') && hasStr(m, 'version') && hasStrArr(m, 'capabilities')\n   152→        ? (m as unknown as WorkerHello) : null;\n   153→    case 'ready':\n   154→      return m as unknown as WorkerReady;\n   155→    case 'stdout':\n   156→    case 'stderr':\n   157→      return hasStr(m, 'executionId') && hasStr(m, 'chunk') && hasNum(m, 'timestamp')\n   158→        ? (m as unknown as ExecStdout & ExecStderr) : null;\n   159→    case 'complete':\n   160→      return hasStr(m, 'executionId') && hasStr(m, 'status') && hasNum(m, 'exitCode') && hasNum(m, 'durationMs')\n   161→        ? (m as unknown as ExecComplete) : null;\n   162→    case 'event':\n   163→      return hasStr(m, 'executionId') && hasStr(m, 'eventType') && 'payload' in m\n   164→        ? (m as unknown as WorkerEvent) : null;\n   165→    case 'progress':\n   166→      return hasStr(m, 'executionId') && hasStr(m, 'phase') && hasNum(m, 'percent') && hasNum(m, 'timestamp')\n   167→        ? (m as unknown as ExecProgress) : null;\n   168→    case 'heartbeat':\n   169→      return hasNum(m, 'timestamp') ? (m as unknown as WorkerHeartbeat) : null;\n   170→    case 'busy':\n   171→      return hasStr(m, 'executionId') && hasStr(m, 'reason')\n   172→        ? (m as unknown as WorkerBusy) : null;\n   173→    default:\n   174→      return null;\n   175→  }\n   176→}\n   177→\n   178→export function validateOrchestratorMessage(msg: unknown): Orchestr