[2026-03-18T11:57:05.047Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RqQKgkZUU3MJLAMT2tcJeQ","type":"tool_result","content":"     1→import { type ExecAssign, type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type InferenceProfile, type NetworkPolicy, type EncryptedPayload, TOPICS, assemblePrompt, decrypt, deriveMasterKeyAsync, toEncryptedPayload, resolveEnvOverrides, parseNetworkPolicy } from '@dac-cloud/shared';\n     2→import type Database from 'better-sqlite3';\n     3→import type { WorkerPool } from './workerPool.js';\n     4→import type { TokenManager } from './tokenManager.js';\n     5→import type { OAuthManager } from './oauth.js';\n     6→import type { KafkaClient } from './kafka.js';\n     7→import type { TenantDbManager } from './tenantDbManager.js';\n     8→import type { TenantKeyManager } from './tenantKeyManager.js';\n     9→import type { AuditLog } from './auditLog.js';\n    10→import type { Logger } from 'pino';\n    11→import * as db from './db/index.js';\n    12→\n    13→interface QueuedExecution {\n    14→  request: ExecRequest;\n    15→  receivedAt: number;\n    16→}\n    17→\n    18→// Maximum number of times an execution will be re-queued after worker disconnect\n    19→const MAX_DISCONNECT_RETRIES = 2;\n    20→\n    21→// In-memory tracking for active executions (real-time output streaming)\n    22→interface ActiveExecution {\n    23→  workerId: string;\n    24→  startedAt: number;\n    25→  output: string[];\n    26→  status: 'running' | 'completed' | 'failed' | 'cancelled';\n    27→  progress?: ProgressInfo;\n    28→  completedAt?: number;\n    29→  exitCode?: number;\n    30→  durationMs?: number;\n    31→  sessionId?: string;\n    32→  totalCostUsd?: number;\n    33→  /** Original request kept for re-queuing on worker disconnect. Only present for in-flight executions. */\n    34→  request?: ExecRequest;\n    35→  /** How many times this execution has been re-queued after a worker disconnect. */\n    36→  disconnectRetries?: number;\n    37→}\n    38→\n    39→const OUTPUT_FLUSH_INTERVAL_MS = 500;\n    40→\n    41→export class Dispatcher {\n    42→  private queue: QueuedExecution[] = [];\n    43→  // In-memory map for real-time output + cancel routing (active executions only)\n    44→  private active = new Map<string, ActiveExecution>();\n    45→  private tenantDbManager: TenantDbManager | null = null;\n    46→  private masterKey: Buffer | null = null;\n    47→  private tenantKeyManager: TenantKeyManager | null = null;\n    48→  private auditLog: AuditLog | null = null;\n    49→  // Maps executionId → projectId for DB resolution during callbacks\n    50→  private executionTenant = new Map<string, string>();\n    51→  // Batched output buffers: executionId → pending chunks\n    52→  private outputBuffers = new Map<string, string[]>();\n    53→  private outputFlushTimer: NodeJS.Timeout;\n    54→  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n    55→  private dispatching = false;\n    56→\n    57→  constructor(\n    58→    private pool: WorkerPool,\n    59→    private tokenManager: TokenManager,\n    60→    private oauth: OAuthManager | null,\n    61→    private kafka: KafkaClient,\n    62→    private logger: Logger,\n    63→  ) {\n    64→    // Periodic flush of batched output to DB\n    65→    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n    66→\n    67→    // When a worker becomes ready, try to dispatch queued work\n    68→    this.pool.on('worker-ready', () => {\n    69→      this.processQueue();\n    70→    });\n    71→\n    72→    // When a worker connects, try to dispatch\n    73→    this.pool.on('worker-connected', () => {\n    74→      this.processQueue();\n    75→    });\n    76→\n    77→    // Track stdout for execution output\n    78→    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n    79→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    80→    });\n    81→\n    82→    // Track stderr for debugging failed executions\n    83→    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n    84→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n    85→      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    86→    });\n    87→\n    88→    // Handle execution completion\n    89→    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n    90→      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n    91→        executionId: msg.executionId,\n    92→        status: msg.status,\n    93→        exitCode: msg.exitCode,\n    94→        durationMs: msg.durationMs,\n    95→        sessionId: msg.sessionId,\n    96→        totalCostUsd: msg.totalCostUsd,\n    97→      }), msg.executionId).catch(err => {\n    98→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n    99→      });\n   100→\n   101→      // Flush any remaining buffered output before persisting completion\n   102→      this.flushOutputForExecution(msg.executionId);\n   103→\n   104→      // Update in-memory\n   105→      const exec = this.active.get(msg.executionId);\n   106→      if (exec) {\n   107→        exec.status = msg.status;\n   108→        exec.completedAt = Date.now();\n   109→        exec.exitCode = msg.exitCode;\n   110→        exec.durationMs = msg.durationMs;\n   111→        exec.sessionId = msg.sessionId;\n   112→        exec.totalCostUsd = msg.totalCostUsd;\n   113→        // Remove from active after a short delay (allow polling to pick up final state)\n   114→        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n   115→      }\n   116→\n   117→      // Persist to DB\n   118→      const completeDb = this.resolveDbForExecution(msg.executionId);\n   119→      if (completeDb) {\n   120→        try {\n   121→          db.updateExecution(completeDb, msg.executionId, {\n   122→            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n   123→            completedAt: new Date().toISOString(),\n   124→            durationMs: msg.durationMs,\n   125→            claudeSessionId: msg.sessionId,\n   126→            costUsd: msg.totalCostUsd ?? 0,\n   127→          });\n   128→        } catch (err) {\n   129→          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n   130→        }\n   131→      }\n   132→\n   133→      // Clean up tenant mapping after completion delay\n   134→      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n   135→\n   136→      // Process next queued item\n   137→      this.processQueue();\n   138→    });\n   139→\n   140→    // Track execution progress\n   141→    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n   142→      const exec = this.active.get(msg.executionId);\n   143→      if (exec) {\n   144→        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n   145→      }\n   146→      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n   147→        executionId: msg.executionId,\n   148→        phase: msg.phase,\n   149→        percent: msg.percent,\n   150→        detail: msg.detail,\n   151→        timestamp: msg.timestamp,\n   152→      }), msg.executionId).catch(err => {\n   153→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n   154→      });\n   155→    });\n   156→\n   157→    // Forward persona events to Kafka\n   158→    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n   159→      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n   160→        executionId: msg.executionId,\n   161→        eventType: msg.eventType,\n   162→        payload: msg.payload,\n   163→        timestamp: Date.now(),\n   164→      }), msg.executionId).catch(err => {\n   165→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n   166→      });\n   167→    });\n   168→\n   169→    // Handle worker busy nack — re-queue the rejected execution\n   170→    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n   171→      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n   172→      const exec = this.active.get(msg.executionId);\n   173→      if (exec?.request) {\n   174→        const request = exec.request;\n   175→        this.active.delete(msg.executionId);\n   176→        // Mark as queued in DB\n   177→        const reqDb = this.resolveDbForExecution(msg.executionId);\n   178→        if (reqDb) {\n   179→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch { /* best effort */ }\n   180→        }\n   181→        this.queue.unshift({ request, receivedAt: Date.now() });\n   182→        this.processQueue();\n   183→      } else {\n   184→        // Fallback: reconstruct from DB if request was not stored (should not happen)\n   185→        this.active.delete(msg.executionId);\n   186→        const projectId = this.executionTenant.get(msg.executionId) || 'default';\n   187→        const reqDb = this.resolveDb(projectId);\n   188→        if (reqDb) {\n   189→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch { /* best effort */ }\n   190→        }\n   191→        const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n   192→        if (dbExec) {\n   193→          this.queue.unshift({\n   194→            request: {\n   195→              executionId: msg.executionId,\n   196→              personaId: dbExec.personaId,\n   197→              prompt: dbExec.inputData || '',\n   198→              projectId,\n   199→              config: { timeoutMs: 300_000 },\n   200→            },\n   201→            receivedAt: Date.now(),\n   202→          });\n   203→          this.processQueue();\n   204→        }\n   205→      }\n   206→    });\n   207→\n   208→    // Handle worker disconnect during execution — re-queue if retries remain\n   209→    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n   210→      if (executionId) {\n   211→        const exec = this.active.get(executionId);\n   212→        const retries = exec?.disconnectRetries ?? 0;\n   213→\n   214→        if (exec?.request && retries < MAX_DISCONNECT_RETRIES) {\n   215→          // Re-queue for retry\n   216→          const nextRetry = retries + 1;\n   217→          this.logger.warn({ executionId, retry: nextRetry, maxRetries: MAX_DISCONNECT_RETRIES }, 'Worker disconnected during execution, re-queuing');\n   218→\n   219→          // Clear the active entry so dispatchToWorker can create a fresh one\n   220→          this.active.delete(executionId);\n   221→\n   222→          // Mark as queued in DB\n   223→          const disconnDb = this.resolveDbForExecution(executionId);\n   224→          if (disconnDb) {\n   225→            try {\n   226→              db.updateExecution(disconnDb, executionId, {\n   227→                status: 'queued',\n   228→                errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n   229→              });\n   230→            } catch { /* best effort */ }\n   231→          }\n   232→\n   233→          // Temporarily store the retry count so dispatchToWorker picks it up\n   234→          const request = exec.request;\n   235→          // Create a placeholder active entry to carry retry count across re-dispatch\n   236→          this.active.set(executionId, {\n   237→            workerId: '',\n   238→            startedAt: 0,\n   239→            output: [],\n   240→            status: 'running',\n   241→            request,\n   242→            disconnectRetries: nextRetry,\n   243→          });\n   244→\n   245→          this.queue.unshift({ request, receivedAt: Date.now() });\n   246→          this.processQueue();\n   247→        } else {\n   248→          // Retries exhausted or no request stored — permanent failure\n   249→          this.logger.error({ executionId, retries }, 'Worker disconnected during execution, retries exhausted');\n   250→          if (exec) {\n   251→            exec.status = 'failed';\n   252→            exec.completedAt = Date.now();\n   253→            setTimeout(() => this.active.delete(executionId), 30_000);\n   254→          }\n   255→\n   256→          const disconnDb = this.resolveDbForExecution(executionId);\n   257→          if (disconnDb) {\n   258→            try {\n   259→              db.updateExecution(disconnDb, executionId, {\n   260→                status: 'failed',\n   261→                errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n   262→                completedAt: new Date().toISOString(),\n   263→              });\n   264→            } catch { /* best effort */ }\n   265→          }\n   266→          this.executionTenant.delete(executionId);\n   267→\n   268→          this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   269→            executionId,\n   270→            status: 'failed',\n   271→            error: 'Worker disconnected (retries exhausted)',\n   272→            durationMs: 0,\n   273→          }), executionId).catch(() => {});\n   274→        }\n   275→      }\n   276→    });\n   277→  }\n   278→\n   279→  setTenantDbManager(mgr: TenantDbManager): void {\n   280→    this.tenantDbManager = mgr;\n   281→  }\n   282→\n   283→  async setMasterKey(masterKeyHex: string): Promise<void> {\n   284→    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n   285→  }\n   286→\n   287→  setTenantKeyManager(mgr: TenantKeyManager): void {\n   288→    this.tenantKeyManager = mgr;\n   289→  }\n   290→\n   291→  setAuditLog(log: AuditLog): void {\n   292→    this.auditLog = log;\n   293→  }\n   294→\n   295→  /** Resolve the database for a given projectId via tenant DB manager. */\n   296→  private resolveDb(projectId?: string): Database.Database | null {\n   297→    if (this.tenantDbManager && projectId) {\n   298→      return this.tenantDbManager.getTenantDb(projectId);\n   299→    }\n   300→    return null;\n   301→  }\n   302→\n   303→  /** Resolve the database for an in-flight execution by its ID. */\n   304→  private resolveDbForExecution(executionId: string): Database.Database | null {\n   305→    const projectId = this.executionTenant.get(executionId);\n   306→    return this.resolveDb(projectId);\n   307→  }\n   308→\n   309→  /**\n   310→   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   311→   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   312→   */\n   313→  private async decryptWithAudit(\n   314→    payload: EncryptedPayload,\n   315→    tenantId: string,\n   316→    resourceId: string,\n   317→    logContext: Record<string, unknown>,\n   318→    logMessage: string,\n   319→  ): Promise<string | undefined> {\n   320→    const decryptKey = this.tenantKeyManager\n   321→      ? await this.tenantKeyManager.getKey(tenantId)\n   322→      : this.masterKey;\n   323→    if (!decryptKey) return undefined;\n   324→\n   325→    try {\n   326→      const decrypted = decrypt(payload, decryptKey);\n   327→      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n   328→      return decrypted;\n   329→    } catch (err) {\n   330→      const reason = err instanceof Error ? err.message : String(err);\n   331→      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n   332→      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: reason }); } catch { /* logged inside record() */ }\n   333→      return undefined;\n   334→    }\n   335→  }\n   336→\n   337→  submit(request: ExecRequest): void {\n   338→    this.logger.info({\n   339→      executionId: request.executionId,\n   340→      personaId: request.personaId,\n   341→    }, 'Execution submitted');\n   342→\n   343→    // Track which tenant owns this execution (for callback DB resolution)\n   344→    const projectId = request.projectId || 'default';\n   345→    this.executionTenant.set(request.executionId, projectId);\n   346→\n   347→    // Create DB record immediately\n   348→    const submitDb = this.resolveDb(projectId);\n   349→    if (submitDb) {\n   350→      try {\n   351→        db.createExecution(submitDb, {\n   352→          id: request.executionId,\n   353→          personaId: request.personaId,\n   354→          inputData: request.prompt,\n   355→          projectId,\n   356→        });\n   357→      } catch (err) {\n   358→        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n   359→      }\n   360→    }\n   361→\n   362→    this.queue.push({ request, receivedAt: Date.now() });\n   363→    this.processQueue();\n   364→  }\n   365→\n   366→  private async processQueue(): Promise<void> {\n   367→    // Guard: only one processQueue loop runs at a time to prevent concurrent\n   368→    // calls from racing on getIdleWorker()/assign() and double-claiming a worker.\n   369→    if (this.dispatching) return;\n   370→    this.dispatching = true;\n   371→    try {\n   372→      while (this.queue.length > 0) {\n   373→        const workerId = this.pool.getIdleWorker();\n   374→        if (!workerId) {\n   375→          this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n   376→          return;\n   377→        }\n   378→\n   379→        const item = this.queue.shift()!;\n   380→        await this.dispatchToWorker(workerId, item.request);\n   381→      }\n   382→    } finally {\n   383→      this.dispatching = false;\n   384→    }\n   385→  }\n   386→\n   387→  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n   388→    // Try to get a fresh token via OAuth (auto-refreshes if near expiry)\n   389→    let claudeToken: string | null = null;\n   390→    if (this.oauth?.hasTokens()) {\n   391→      claudeToken = await this.oauth.getValidAccessToken();\n   392→      if (claudeToken) {\n   393→        this.tokenManager.storeClaudeToken(claudeToken);\n   394→      }\n   395→    }\n   396→    // Fallback to stored token\n   397→    if (!claudeToken) {\n   398→      claudeToken = this.tokenManager.getClaudeToken();\n   399→    }\n   400→    if (!claudeToken) {\n   401→      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n   402→      this.queue.unshift({ request, receivedAt: Date.now() });\n   403→      return;\n   404→    }\n   405→\n   406→    // Build environment variables for the worker\n   407→    const env: Record<string, string> = {\n   408→      ANTHROPIC_API_KEY: claudeToken,\n   409→    };\n   410→\n   411→    // If persona exists in DB, assemble prompt from persona config and inject credentials\n   412→    let prompt = request.prompt;\n   413→    const dispatchDb = this.resolveDb(request.projectId || 'default');\n   414→    const persona = dispatchDb ? db.getPersona(dispatchDb, request.personaId) : null;\n   415→    if (dispatchDb) {\n   416→      if (persona) {\n   417→        const tools = db.getToolsForPersona(dispatchDb, persona.id);\n   418→        const creds = db.listCredentialsForPersona(dispatchDb, persona.id);\n   419→\n   420→        // Decrypt credentials and inject as env vars\n   421→        const credentialHints: string[] = [];\n   422→        const tenantId = request.projectId || 'default';\n   423→        for (const cred of creds) {\n   424→          const envName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   425→          credentialHints.push(envName);\n   426→\n   427→          const decrypted = await this.decryptWithAudit(\n   428→            toEncryptedPayload(cred),\n   429→            tenantId,\n   430→            cred.id,\n   431→            { credentialId: cred.id, credentialName: cred.name },\n   432→            'Failed to decrypt credential',\n   433→          );\n   434→          if (decrypted !== undefined) {\n   435→            // Try to parse as JSON with multiple fields\n   436→            try {\n   437→              const fields = JSON.parse(decrypted) as Record<string, string>;\n   438→              for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n   439→                const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   440→                env[fieldEnvName] = String(fieldValue);\n   441→              }\n   442→            } catch {\n   443→              // Not JSON — inject as single value\n   444→              env[envName] = decrypted;\n   445→            }\n   446→          }\n   447→        }\n   448→\n   449→        const inputData = request.inputData ? (request.inputData as Record<string, unknown>) : undefined;\n   450→        prompt = assemblePrompt(persona, tools, inputData, credentialHints.length > 0 ? credentialHints : undefined);\n   451→\n   452→        // Apply inference profile or legacy model profile env overrides\n   453→        let inferenceProfile: InferenceProfile | undefined;\n   454→        if (persona.inferenceProfileId) {\n   455→          inferenceProfile = db.getInferenceProfile(dispatchDb, persona.inferenceProfileId);\n   456→        }\n   457→        if (inferenceProfile) {\n   458→          // Decrypt auth token first so resolveEnvOverrides can map it to env vars\n   459→          let decryptedAuthToken: string | undefined;\n   460→          if (inferenceProfile.authTokenEncrypted && inferenceProfile.authTokenIv && inferenceProfile.authTokenTag) {\n   461→            decryptedAuthToken = await this.decryptWithAudit(\n   462→              { encrypted: inferenceProfile.authTokenEncrypted, iv: inferenceProfile.authTokenIv, tag: inferenceProfile.authTokenTag },\n   463→              tenantId,\n   464→              `inference-profile:${inferenceProfile.id}`,\n   465→              { profileId: inferenceProfile.id },\n   466→              'Failed to decrypt inference profile auth token',\n   467→            );\n   468→          }\n   469→          const overrides = resolveEnvOverrides(inferenceProfile, decryptedAuthToken);\n   470→          for (const [k, v] of Object.entries(overrides.set)) env[k] = v;\n   471→          for (const k of overrides.remove) delete env[k];\n   472→        }\n   473→\n   474→        this.logger.info({ personaId: persona.id, toolCount: tools.length, credCount: creds.length }, 'Assembled prompt from DB persona');\n   475→      }\n   476→    }\n   477→\n   478→    // Resolve network policy from persona config\n   479→    let networkPolicy: NetworkPolicy | undefined;\n   480→    if (persona?.networkPolicy) {\n   481→      networkPolicy = parseNetworkPolicy(persona.networkPolicy) ?? undefined;\n   482→    }\n   483→\n   484→    const assignment: ExecAssign = {\n   485→      type: 'assign',\n   486→      executionId: request.executionId,\n   487→      personaId: request.personaId,\n   488→      prompt,\n   489→      env,\n   490→      config: {\n   491→        timeoutMs: request.config.timeoutMs || 300_000,\n   492→        maxOutputBytes: 10 * 1024 * 1024, // 10MB\n   493→        ...(networkPolicy ? { networkPolicy } : {}),\n   494→        ...(persona?.maxBudgetUsd ? { maxBudgetUsd: persona.maxBudgetUsd } : {}),\n   495→        ...(persona?.maxTurns ? { maxTurns: persona.maxTurns } : {}),\n   496→      },\n   497→    };\n   498→\n   499→    // Track in-memory for real-time streaming (preserve retry count across re-dispatches)\n   500→    const prevRetries = this.active.get(request.executionId)?.disconnectRetries ?? 0;\n   501→    this.active.set(request.executionId, {\n   502→      workerId,\n   503→      startedAt: Date.now(),\n   504→      output: [],\n   505→      status: 'running',\n   506→      request,\n   507→      disconnectRetries: prevRetries,\n   508→    });\n   509→\n   510→    // Mark running in DB\n   511→    if (dispatchDb) {\n   512→      try {\n   513→        db.updateExecution(dispatchDb, request.executionId, {\n   514→          status: 'running',\n   515→          startedAt: new Date().toISOString(),\n   516→        });\n   517→      } catch { /* best effort */ }\n   518→    }\n   519→\n   520→    const sent = this.pool.assign(workerId, assignment);\n   521→    if (!sent) {\n   522→      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n   523→      this.active.delete(request.executionId);\n   524→      if (dispatchDb) {\n   525→        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch { /* best effort */ }\n   526→      }\n   527→      // Re-queue and retry dispatch — another idle worker may be available\n   528→      this.queue.unshift({ request, receivedAt: Date.now() });\n   529→      this.processQueue();\n   530→    } else {\n   531→      this.logger.info({\n   532→        workerId,\n   533→        executionId: request.executionId,\n   534→        personaId: request.personaId,\n   535→      }, 'Execution dispatched to worker');\n   536→    }\n   537→  }\n   538→\n   539→  cancelExecution(executionId: string): boolean {\n   540→    const exec = this.active.get(executionId);\n   541→    if (!exec || exec.status !== 'running') return false;\n   542→\n   543→    return this.pool.send(exec.workerId, {\n   544→      type: 'cancel',\n   545→      executionId,\n   546→    });\n   547→  }\n   548→\n   549→  getQueueLength(): number {\n   550→    return this.queue.length;\n   551→  }\n   552→\n   553→  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n   554→    return Array.from(this.active.entries())\n   555→      .filter(([, e]) => e.status === 'running')\n   556→      .map(([executionId, e]) => ({\n   557→        executionId,\n   558→        workerId: e.workerId,\n   559→        startedAt: e.startedAt,\n   560→      }));\n   561→  }\n   562→\n   563→  /**\n   564→   * Get execution state. Tries in-memory first (for real-time output),\n   565→   * then falls back to DB for completed/historical executions.\n   566→   */\n   567→  getExecution(executionId: string): ActiveExecution | null {\n   568→    // Check in-memory active executions first\n   569→    const active = this.active.get(executionId);\n   570→    if (active) return active;\n   571→\n   572→    const execDb = this.resolveDbForExecution(executionId);\n   573→    if (execDb) {\n   574→      const dbExec = db.getExecution(execDb, executionId);\n   575→      if (dbExec) {\n   576→        return {\n   577→          workerId: '',\n   578→          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n   579→          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n   580→          status: dbExec.status as ActiveExecution['status'],\n   581→          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n   582→          durationMs: dbExec.durationMs ?? undefined,\n   583→          sessionId: dbExec.claudeSessionId ?? undefined,\n   584→          totalCostUsd: dbExec.costUsd ?? undefined,\n   585→        };\n   586→      }\n   587→    }\n   588→\n   589→    return null;\n   590→  }\n   591→\n   592→  getExecutionOutput(executionId: string): string[] | null {\n   593→    const exec = this.getExecution(executionId);\n   594→    return exec?.output ?? null;\n   595→  }\n   596→\n   597→  /** Shared handler for stdout/stderr output chunks. */\n   598→  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n   599→    const line = prefix ? `${prefix}${chunk}` : chunk;\n   600→\n   601→    const exec = this.active.get(executionId);\n   602→    if (exec) {\n   603→      exec.output.push(line);\n   604→    }\n   605→\n   606→    this.bufferOutput(executionId, line + '\\n');\n   607→\n   608→    // Forward stdout to Kafka (stderr is not forwarded)\n   609→    if (!prefix) {\n   610→      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n   611→        executionId,\n   612→        chunk,\n   613→        timestamp,\n   614→      }), executionId).catch(err => {\n   615→        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n   616→      });\n   617→    }\n   618→  }\n   619→\n   620→  /** Buffer an output chunk for batched DB write. */\n   621→  private bufferOutput(executionId: string, chunk: string): void {\n   622→    let buf = this.outputBuffers.get(executionId);\n   623→    if (!buf) {\n   624→      buf = [];\n   625→      this.outputBuffers.set(executionId, buf);\n   626→    }\n   627→    buf.push(chunk);\n   628→  }\n   629→\n   630→  /** Flush buffered output for a specific execution to DB. */\n   631→  private flushOutputForExecution(executionId: string): void {\n   632→    const buf = this.outputBuffers.get(executionId);\n   633→    if (!buf || buf.length === 0) return;\n   634→\n   635→    const combined = buf.join('');\n   636→    this.outputBuffers.delete(executionId);\n   637→\n   638→    const outputDb = this.resolveDbForExecution(executionId);\n   639→    if (outputDb) {\n   640→      try { db.appendOutput(outputDb, executionId, combined); } catch { /* best effort */ }\n   641→    }\n   642→  }\n   643→\n   644→  /** Flush all buffered output across all executions to DB. */\n   645→  private flushOutputBuffers(): void {\n   646→    for (const executionId of this.outputBuffers.keys()) {\n   647→      this.flushOutputForExecution(executionId);\n   648→    }\n   649→  }\n   650→\n   651→  shutdown(): void {\n   652→    clearInterval(this.outputFlushTimer);\n   653→    this.flushOutputBuffers();\n   654→  }\n   655→}\n   656→"}]},"parent_tool_use_id":null,"session_id":"a98dd510-3145-4e13-a658-c8990d01d642","uuid":"5eb5287a-cd99-4146-8b8e-0b2032446ccb","timestamp":"2026-03-18T11:57:04.618Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\dispatcher.ts","content":"import { type ExecAssign, type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type InferenceProfile, type NetworkPolicy, type EncryptedPayload, TOPICS, assemblePrompt, decrypt, deriveMasterKeyAsync, toEncryptedPayload, resolveEnvOverrides, parseNetworkPolicy } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\n\ninterface QueuedExecution {\n  request: ExecRequest;\n  receivedAt: number;\n}\n\n// Maximum number of times an execution will be re-queued after worker disconnect\nconst MAX_DISCONNECT_RETRIES = 2;\n\n// In-memory tracking for active executions (real-time output streaming)\ninterface ActiveExecution {\n  workerId: string;\n  startedAt: number;\n  output: string[];\n  status: 'running' | 'completed' | 'failed' | 'cancelled';\n  progress?: ProgressInfo;\n  completedAt?: number;\n  exitCode?: number;\n  durationMs?: number;\n  sessionId?: string;\n  totalCostUsd?: number;\n  /** Original request kept for re-queuing on worker disconnect. Only present for in-flight executions. */\n  request?: ExecRequest;\n  /** How many times this execution has been re-queued after a worker disconnect. */\n  disconnectRetries?: number;\n}\n\nconst OUTPUT_FLUSH_INTERVAL_MS = 500;\n\nexport class Dispatcher {\n  private queue: QueuedExecution[] = [];\n  // In-memory map for real-time output + cancel routing (active executions only)\n  private active = new Map<string, ActiveExecution>();\n  private tenantDbManager: TenantDbManager | null = null;\n  private masterKey: Buffer | null = null;\n  private tenantKeyManager: TenantKeyManager | null = null;\n  private auditLog: AuditLog | null = null;\n  // Maps executionId → projectId for DB resolution during callbacks\n  private executionTenant = new Map<string, string>();\n  // Batched output buffers: executionId → pending chunks\n  private outputBuffers = new Map<string, string[]>();\n  private outputFlushTimer: NodeJS.Timeout;\n  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n  private dispatching = false;\n\n  constructor(\n    private pool: WorkerPool,\n    private tokenManager: TokenManager,\n    private oauth: OAuthManager | null,\n    private kafka: KafkaClient,\n    private logger: Logger,\n  ) {\n    // Periodic flush of batched output to DB\n    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n\n    // When a worker becomes ready, try to dispatch queued work\n    this.pool.on('worker-ready', () => {\n      this.processQueue();\n    });\n\n    // When a worker connects, try to dispatch\n    this.pool.on('worker-connected', () => {\n      this.processQueue();\n    });\n\n    // Track stdout for execution output\n    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    });\n\n    // Track stderr for debugging failed executions\n    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    });\n\n    // Handle execution completion\n    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n        executionId: msg.executionId,\n        status: msg.status,\n        exitCode: msg.exitCode,\n        durationMs: msg.durationMs,\n        sessionId: msg.sessionId,\n        totalCostUsd: msg.totalCostUsd,\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n      });\n\n      // Flush any remaining buffered output before persisting completion\n      this.flushOutputForExecution(msg.executionId);\n\n      // Update in-memory\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.status = msg.status;\n        exec.completedAt = Date.now();\n        exec.exitCode = msg.exitCode;\n        exec.durationMs = msg.durationMs;\n        exec.sessionId = msg.sessionId;\n        exec.totalCostUsd = msg.totalCostUsd;\n        // Remove from active after a short delay (allow polling to pick up final state)\n        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n      }\n\n      // Persist to DB\n      const completeDb = this.resolveDbForExecution(msg.executionId);\n      if (completeDb) {\n        try {\n          db.updateExecution(completeDb, msg.executionId, {\n            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n            completedAt: new Date().toISOString(),\n            durationMs: msg.durationMs,\n            claudeSessionId: msg.sessionId,\n            costUsd: msg.totalCostUsd ?? 0,\n          });\n        } catch (err) {\n          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n        }\n      }\n\n      // Clean up tenant mapping after completion delay\n      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n\n      // Process next queued item\n      this.processQueue();\n    });\n\n    // Track execution progress\n    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n      }\n      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n        executionId: msg.executionId,\n        phase: msg.phase,\n        percent: msg.percent,\n        detail: msg.detail,\n        timestamp: msg.timestamp,\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n      });\n    });\n\n    // Forward persona events to Kafka\n    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n        executionId: msg.executionId,\n        eventType: msg.eventType,\n        payload: msg.payload,\n        timestamp: Date.now(),\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n      });\n    });\n\n    // Handle worker busy nack — re-queue the rejected execution\n    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n      const exec = this.active.get(msg.executionId);\n      if (exec?.request) {\n        const request = exec.request;\n        this.active.delete(msg.executionId);\n        // Mark as queued in DB\n        const reqDb = this.resolveDbForExecution(msg.executionId);\n        if (reqDb) {\n          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch { /* best effort */ }\n        }\n        this.queue.unshift({ request, receivedAt: Date.now() });\n        this.processQueue();\n      } else {\n        // Fallback: reconstruct from DB if request was not stored (should not happen)\n        this.active.delete(msg.executionId);\n        const projectId = this.executionTenant.get(msg.executionId) || 'default';\n        const reqDb = this.resolveDb(projectId);\n        if (reqDb) {\n          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch { /* best effort */ }\n        }\n        const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n        if (dbExec) {\n          this.queue.unshift({\n            request: {\n              executionId: msg.executionId,\n              personaId: dbExec.personaId,\n              prompt: dbExec.inputData || '',\n              projectId,\n              config: { timeoutMs: 300_000 },\n            },\n            receivedAt: Date.now(),\n          });\n          this.processQueue();\n        }\n      }\n    });\n\n    // Handle worker disconnect during execution — re-queue if retries remain\n    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n      if (executionId) {\n        const exec = this.active.get(executionId);\n        const retries = exec?.disconnectRetries ?? 0;\n\n        if (exec?.request && retries < MAX_DISCONNECT_RETRIES) {\n          // Re-queue for retry\n          const nextRetry = retries + 1;\n          this.logger.warn({ executionId, retry: nextRetry, maxRetries: MAX_DISCONNECT_RETRIES }, 'Worker disconnected during execution, re-queuing');\n\n          // Clear the active entry so dispatchToWorker can create a fresh one\n          this.active.delete(executionId);\n\n          // Mark as queued in DB\n          const disconnDb = this.resolveDbForExecution(executionId);\n          if (disconnDb) {\n            try {\n              db.updateExecution(disconnDb, executionId, {\n                status: 'queued',\n                errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n              });\n            } catch { /* best effort */ }\n          }\n\n          // Temporarily store the retry count so dispatchToWorker picks it up\n          const request = exec.request;\n          // Create a placeholder active entry to carry retry count across re-dispatch\n          this.active.set(executionId, {\n            workerId: '',\n            startedAt: 0,\n            output: [],\n            status: 'running',\n            request,\n            disconnectRetries: nextRetry,\n          });\n\n          this.queue.unshift({ request, receivedAt: Date.now() });\n          this.processQueue();\n        } else {\n          // Retries exhausted or no request stored — permanent failure\n          this.logger.error({ executionId, retries }, 'Worker disconnected during execution, retries exhausted');\n          if (exec) {\n            exec.status = 'failed';\n            exec.completedAt = Date.now();\n            setTimeout(() => this.active.delete(executionId), 30_000);\n          }\n\n          const disconnDb = this.resolveDbForExecution(executionId);\n          if (disconnDb) {\n            try {\n              db.updateExecution(disconnDb, executionId, {\n                status: 'failed',\n                errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n                completedAt: new Date().toISOString(),\n              });\n            } catch { /* best effort */ }\n          }\n          this.executionTenant.delete(executionId);\n\n          this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n            executionId,\n            status: 'failed',\n            error: 'Worker disconnected (retries exhausted)',\n            durationMs: 0,\n          }), executionId).catch(() => {});\n        }\n      }\n    });\n  }\n\n  setTenantDbManager(mgr: TenantDbManager): void {\n    this.tenantDbManager = mgr;\n  }\n\n  async setMasterKey(masterKeyHex: string): Promise<void> {\n    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n  }\n\n  setTenantKeyManager(mgr: TenantKeyManager): void {\n    this.tenantKeyManager = mgr;\n  }\n\n  setAuditLog(log: AuditLog): void {\n    this.auditLog = log;\n  }\n\n  /** Resolve the database for a given projectId via tenant DB manager. */\n  private resolveDb(projectId?: string): Database.Database | null {\n    if (this.tenantDbManager && projectId) {\n      return this.tenantDbManager.getTenantDb(projectId);\n    }\n    return null;\n  }\n\n  /** Resolve the database for an in-flight execution by its ID. */\n  private resolveDbForExecution(executionId: string): Database.Database | null {\n    const projectId = this.executionTenant.get(executionId);\n    return this.resolveDb(projectId);\n  }\n\n  /**\n   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   */\n  private async decryptWithAudit(\n    payload: EncryptedPayload,\n    tenantId: string,\n    resourceId: string,\n    logContext: Record<string, unknown>,\n    logMessage: string,\n  ): Promise<string | undefined> {\n    const decryptKey = this.tenantKeyManager\n      ? await this.tenantKeyManager.getKey(tenantId)\n      : this.masterKey;\n    if (!decryptKey) return undefined;\n\n    try {\n      const decrypted = decrypt(payload, decryptKey);\n      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n      return decrypted;\n    } catch (err) {\n      const reason = err instanceof Error ? err.message : String(err);\n      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: reason }); } catch { /* logged inside record() */ }\n      return undefined;\n    }\n  }\n\n  submit(request: ExecRequest): void {\n    this.logger.info({\n      executionId: request.executionId,\n      personaId: request.personaId,\n    }, 'Execution submitted');\n\n    // Track which tenant owns this execution (for callback DB resolution)\n    const projectId = request.projectId || 'default';\n    this.executionTenant.set(request.executionId, projectId);\n\n    // Create DB record immediately\n    const submitDb = this.resolveDb(projectId);\n    if (submitDb) {\n      try {\n        db.createExecution(submitDb, {\n          id: request.executionId,\n          personaId: request.personaId,\n          inputData: request.prompt,\n          projectId,\n        });\n      } catch (err) {\n        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n      }\n    }\n\n    this.queue.push({ request, receivedAt: Date.now() });\n    this.processQueue();\n  }\n\n  private async processQueue(): Promise<void> {\n    // Guard: only one processQueue loop runs at a time to prevent concurrent\n    // calls from racing on getIdleWorker()/assign() and double-claiming a worker.\n    if (this.dispatching) return;\n    this.dispatching = true;\n    try {\n      while (this.queue.length > 0) {\n        const workerId = this.pool.getIdleWorker();\n        if (!workerId) {\n          this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n          return;\n        }\n\n        const item = this.queue.shift()!;\n        await this.dispatchToWorker(workerId, item.request);\n      }\n    } finally {\n      this.dispatching = false;\n    }\n  }\n\n  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n    // Try to get a fresh token via OAuth (auto-refreshes if near expiry)\n    let claudeToken: string | null = null;\n    if (this.oauth?.hasTokens()) {\n      claudeToken = await this.oauth.getValidAccessToken();\n      if (claudeToken) {\n        this.tokenManager.storeClaudeToken(claudeToken);\n      }\n    }\n    // Fallback to stored token\n    if (!claudeToken) {\n      claudeToken = this.tokenManager.getClaudeToken();\n    }\n    if (!claudeToken) {\n      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      return;\n    }\n\n    // Build environment variables for the worker\n    const env: Record<string, string> = {\n      ANTHROPIC_API_KEY: claudeToken,\n    };\n\n    // If persona exists in DB, assemble prompt from persona config and inject credentials\n    let prompt = request.prompt;\n    const dispatchDb = this.resolveDb(request.projectId || 'default');\n    const persona = dispatchDb ? db.getPersona(dispatchDb, request.personaId) : null;\n    if (dispatchDb) {\n      if (persona) {\n        const tools = db.getToolsForPersona(dispatchDb, persona.id);\n        const creds = db.listCredentialsForPersona(dispatchDb, persona.id);\n\n        // Decrypt credentials and inject as env vars\n        const credentialHints: string[] = [];\n        const tenantId = request.projectId || 'default';\n        for (const cred of creds) {\n          const envName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n          credentialHints.push(envName);\n\n          const decrypted = await this.decryptWithAudit(\n            toEncryptedPayload(cred),\n            tenantId,\n            cred.id,\n            { credentialId: cred.id, credentialName: cred.name },\n            'Failed to decrypt credential',\n          );\n          if (decrypted !== undefined) {\n            // Try to parse as JSON with multiple fields\n            try {\n              const fields = JSON.parse(decrypted) as Record<string, string>;\n              for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n                const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n                env[fieldEnvName] = String(fieldValue);\n              }\n            } catch {\n              // Not JSON — inject as single value\n              env[envName] = decrypted;\n            }\n          }\n        }\n\n        const inputData = request.inputData ? (request.inputData as Record<string, unknown>) : undefined;\n        prompt = assemblePrompt(persona, tools, inputData, credentialHints.length > 0 ? credentialHints : undefined);\n\n        // Apply inference profile or legacy model profile env overrides\n        let inferenceProfile: InferenceProfile | undefined;\n        if (persona.inferenceProfileId) {\n          inferenceProfile = db.getInferenceProfile(dispatchDb, persona.inferenceProfileId);\n        }\n        if (inferenceProfile) {\n          // Decrypt auth token first so resolveEnvOverrides can map it to env vars\n          let decryptedAuthToken: string | undefined;\n          if (inferenceProfile.authTokenEncrypted && inferenceProfile.authTokenIv && inferenceProfile.authTokenTag) {\n            decryptedAuthToken = await this.decryptWithAudit(\n              { encrypted: inferenceProfile.authTokenEncrypted, iv: inferenceProfile.authTokenIv, tag: inferenceProfile.authTokenTag },\n              tenantId,\n              `inference-profile:${inferenceProfile.id}`,\n              { profileId: inferenceProfile.id },\n              'Failed to decrypt inference profile auth token',\n            );\n          }\n          const overrides = resolveEnvOverrides(inferenceProfile, decryptedAuthToken);\n          for (const [k, v] of Object.entries(overrides.set)) env[k] = v;\n          for (const k of overrides.remove) delete env[k];\n        }\n\n        this.logger.info({ personaId: persona.id, toolCount: tools.length, credCount: creds.length }, 'Assembled prompt from DB persona');\n      }\n    }\n\n    // Resolve network policy from persona config\n    let networkPolicy: NetworkPolicy | undefined;\n    if (persona?.networkPolicy) {\n      networkPolicy = parseNetworkPolicy(persona.networkPolicy) ?? undefined;\n    }\n\n    const assignment: ExecAssign = {\n      type: 'assign',\n      executionId: request.executionId,\n      personaId: request.personaId,\n      prompt,\n      env,\n      config: {\n        timeoutMs: request.config.timeoutMs || 300_000,\n        maxOutputBytes: 10 * 1024 * 1024, // 10MB\n        ...(networkPolicy ? { networkPolicy } : {}),\n        ...(persona?.maxBudgetUsd ? { maxBudgetUsd: persona.maxBudgetUsd } : {}),\n        ...(persona?.maxTurns ? { maxTurns: persona.maxTurns } : {}),\n      },\n    };\n\n    // Track in-memory for real-time streaming (preserve retry count across re-dispatches)\n    const prevRetries = this.active.get(request.executionId)?.disconnectRetries ?? 0;\n    this.active.set(request.executionId, {\n      workerId,\n      startedAt: Date.now(),\n      output: [],\n      status: 'running',\n      request,\n      disconnectRetries: prevRetries,\n    });\n\n    // Mark running in DB\n    if (dispatchDb) {\n      try {\n        db.updateExecution(dispatchDb, request.executionId, {\n          status: 'running',\n          startedAt: new Date().toISOString(),\n        });\n      } catch { /* best effort */ }\n    }\n\n    const sent = this.pool.assign(workerId, assignment);\n    if (!sent) {\n      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n      this.active.delete(request.executionId);\n      if (dispatchDb) {\n        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch { /* best effort */ }\n      }\n      // Re-queue and retry dispatch — another idle worker may be available\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      this.processQueue();\n    } else {\n      this.logger.info({\n        workerId,\n        executionId: request.executionId,\n        personaId: request.personaId,\n      }, 'Execution dispatched to worker');\n    }\n  }\n\n  cancelExecution(executionId: string): boolean {\n    const exec = this.active.get(executionId);\n    if (!exec || exec.status !== 'running') return false;\n\n    return this.pool.send(exec.workerId, {\n      type: 'cancel',\n      executionId,\n    });\n  }\n\n  getQueueLength(): number {\n    return this.queue.length;\n  }\n\n  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n    return Array.from(this.active.entries())\n      .filter(([, e]) => e.status === 'running')\n      .map(([executionId, e]) => ({\n        executionId,\n        workerId: e.workerId,\n        startedAt: e.startedAt,\n      }));\n  }\n\n  /**\n   * Get execution state. Tries in-memory first (for real-time output),\n   * then falls back to DB for completed/historical executions.\n   */\n  getExecution(executionId: string): ActiveExecution | null {\n    // Check in-memory active executions first\n    const active = this.active.get(executionId);\n    if (active) return active;\n\n    const execDb = this.resolveDbForExecution(executionId);\n    if (execDb) {\n      const dbExec = db.getExecution(execDb, executionId);\n      if (dbExec) {\n        return {\n          workerId: '',\n          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n          status: dbExec.status as ActiveExecution['status'],\n          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n          durationMs: dbExec.durationMs ?? undefined,\n          sessionId: dbExec.claudeSessionId ?? undefined,\n          totalCostUsd: dbExec.costUsd ?? undefined,\n        };\n      }\n    }\n\n    return null;\n  }\n\n  getExecutionOutput(executionId: string): string[] | null {\n    const exec = this.getExecution(executionId);\n    return exec?.output ?? null;\n  }\n\n  /** Shared handler for stdout/stderr output chunks. */\n  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n    const line = prefix ? `${prefix}${chunk}` : chunk;\n\n    const exec = this.active.get(executionId);\n    if (exec) {\n      exec.output.push(line);\n    }\n\n    this.bufferOutput(executionId, line + '\\n');\n\n    // Forward stdout to Kafka (stderr is not forwarded)\n    if (!prefix) {\n      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n        executionId,\n        chunk,\n        timestamp,\n      }), executionId).catch(err => {\n        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n      });\n    }\n  }\n\n  /** Buffer an output chunk for batched DB write. */\n  private bufferOutput(executionId: string, chunk: string): void {\n    let buf = this.outputBuffers.get(executionId);\n    if (!buf) {\n      buf = [];\n      this.outputBuffers.set(executionId, buf);\n    }\n    buf.push(chunk);\n  }\n\n  /** Flush buffered output for a specific execution to DB. */\n  private flushOutputForExecution(executionId: string): void {\n    const buf = this.outputBuffers.get(executionId);\n    if (!buf || buf.length === 0) return;\n\n    const combined = buf.join('');\n    this.outputBuffers.delete(executionId);\n\n    const outputDb = this.resolveDbForExecution(executionId);\n    if (outputDb) {\n      try { db.appendOutput(outputDb, executionId, combined); } catch { /* best effort */ }\n    }\n  }\n\n  /** Flush all buffered output across all executions to DB. */\n  private flushOutputBuffers(): void {\n    for (const executionId of this.outputBuffers.keys()) {\n      this.flushOutputForExecution(executionId);\n    }\n  }\n\n  shutdown(): void {\n    clearInterval(this.outputFlushTimer);\n    this.flushOutputBuffers();\n  }\n}\n","numLines":656,"startLine":1,"totalLines":656}}}
