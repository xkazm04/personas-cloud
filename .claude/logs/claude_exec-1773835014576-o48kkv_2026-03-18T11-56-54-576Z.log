[2026-03-18T11:57:12.704Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SdwYHNJQi2XZ3ty2koUR9Y","type":"tool_result","content":"     1→import type { ChildProcess } from 'node:child_process';\n     2→import { spawn } from 'node:child_process';\n     3→import type { ExecAssign } from '@dac-cloud/shared';\n     4→import { LineBuffer, extractStreamEvents } from './parser.js';\n     5→import { prepareSandbox, cleanupSandbox, type SandboxConfig } from './sandbox.js';\n     6→import { startFilterProxy, type ProxyHandle } from './networkProxy.js';\n     7→import { injectCredentialsViaFile, type InjectedCredentials } from './credentialInjector.js';\n     8→import { parseNetworkPolicy } from '@dac-cloud/shared';\n     9→import type { Logger } from 'pino';\n    10→\n    11→export interface ExecutorCallbacks {\n    12→  onStdout(chunk: string, timestamp: number): void;\n    13→  onStderr(chunk: string, timestamp: number): void;\n    14→  onEvent(eventType: 'manual_review' | 'user_message' | 'persona_action' | 'emit_event', payload: unknown): void;\n    15→  onProgress(phase: string, percent: number, detail?: string): void;\n    16→  onComplete(status: 'completed' | 'failed' | 'cancelled', exitCode: number, durationMs: number, sessionId?: string, totalCostUsd?: number): void;\n    17→}\n    18→\n    19→export class Executor {\n    20→  private childProcess: ChildProcess | null = null;\n    21→  private killed = false;\n    22→  private sessionId: string | undefined;\n    23→  private totalCostUsd: number | undefined;\n    24→\n    25→  /**\n    26→   * Resolves when the current execution (including its finally-block cleanup)\n    27→   * finishes.  Null when idle.\n    28→   */\n    29→  private executionDone: Promise<void> | null = null;\n    30→\n    31→  constructor(private logger: Logger) {}\n    32→\n    33→  /**\n    34→   * Returns a promise that resolves once the in-flight execution's cleanup\n    35→   * (sandbox removal, credential deletion, proxy teardown) has finished.\n    36→   * If no execution is active, resolves immediately.\n    37→   *\n    38→   * An optional `timeoutMs` ensures the caller is never blocked forever\n    39→   * (defaults to 10 s).\n    40→   */\n    41→  waitForCleanup(timeoutMs = 10_000): Promise<void> {\n    42→    if (!this.executionDone) return Promise.resolve();\n    43→\n    44→    return Promise.race([\n    45→      this.executionDone,\n    46→      new Promise<void>((resolve) => setTimeout(resolve, timeoutMs)),\n    47→    ]);\n    48→  }\n    49→\n    50→  private processStdoutLine(line: string, callbacks: ExecutorCallbacks): void {\n    51→    callbacks.onStdout(line, Date.now());\n    52→\n    53→    const streamEvents = extractStreamEvents(line, this.logger);\n    54→    if (streamEvents.sessionId) this.sessionId = streamEvents.sessionId;\n    55→    if (streamEvents.totalCostUsd) this.totalCostUsd = streamEvents.totalCostUsd;\n    56→    for (const event of streamEvents.personaEvents) {\n    57→      callbacks.onEvent(event.eventType, event.payload);\n    58→    }\n    59→    if (streamEvents.progress) {\n    60→      callbacks.onProgress(streamEvents.progress.phase, streamEvents.progress.percent, streamEvents.progress.detail);\n    61→    }\n    62→  }\n    63→\n    64→  /** Returns true if an execution is currently in progress. */\n    65→  isBusy(): boolean {\n    66→    return this.childProcess !== null;\n    67→  }\n    68→\n    69→  async execute(assignment: ExecAssign, callbacks: ExecutorCallbacks): Promise<void> {\n    70→    const run = this.doExecute(assignment, callbacks);\n    71→    this.executionDone = run.catch(() => {});   // swallow – callers handle errors via callbacks\n    72→    try {\n    73→      await run;\n    74→    } finally {\n    75→      this.executionDone = null;\n    76→    }\n    77→  }\n    78→\n    79→  private async doExecute(assignment: ExecAssign, callbacks: ExecutorCallbacks): Promise<void> {\n    80→    const startTime = Date.now();\n    81→    this.sessionId = undefined;\n    82→    this.totalCostUsd = undefined;\n    83→\n    84→    const netPolicy = assignment.config.networkPolicy ?? undefined;\n    85→    const sandboxConfig: SandboxConfig = {\n    86→      executionId: assignment.executionId,\n    87→      env: { ...assignment.env },\n    88→      networkAccess: !netPolicy, // full access only if no policy set\n    89→      networkPolicy: netPolicy,\n    90→      timeoutMs: assignment.config.timeoutMs,\n    91→      maxBudgetUsd: assignment.config.maxBudgetUsd,\n    92→      maxTurns: assignment.config.maxTurns,\n    93→    };\n    94→\n    95→    const sandbox = prepareSandbox(sandboxConfig, this.logger);\n    96→    let proxy: ProxyHandle | null = null;\n    97→    let injectedCreds: InjectedCredentials | null = null;\n    98→\n    99→    this.logger.info({\n   100→      executionId: assignment.executionId,\n   101→      personaId: assignment.personaId,\n   102→      sandboxDir: sandbox.sandboxDir,\n   103→      timeoutMs: assignment.config.timeoutMs,\n   104→    }, 'Starting execution');\n   105→\n   106→    try {\n   107→      // Start filtering proxy for allow-list network policies\n   108→      if (sandbox.proxyRequired && netPolicy) {\n   109→        proxy = await startFilterProxy(netPolicy, this.logger);\n   110→        const proxyUrl = `http://127.0.0.1:${proxy.port}`;\n   111→        sandbox.env['HTTP_PROXY'] = proxyUrl;\n   112→        sandbox.env['HTTPS_PROXY'] = proxyUrl;\n   113→        sandbox.env['http_proxy'] = proxyUrl;\n   114→        sandbox.env['https_proxy'] = proxyUrl;\n   115→        sandbox.env['NO_PROXY'] = '';\n   116→      }\n   117→\n   118→      // Inject credentials via async file write (unblocks event loop)\n   119→      injectedCreds = await injectCredentialsViaFile(sandbox.env, assignment.executionId, this.logger);\n   120→      sandbox.env[injectedCreds.envPointerKey] = injectedCreds.credentialFilePath;\n   121→\n   122→      this.childProcess = spawn(sandbox.command, sandbox.args, {\n   123→        cwd: sandbox.cwd,\n   124→        stdio: ['pipe', 'pipe', 'pipe'],\n   125→        env: sandbox.env,\n   126→      });\n   127→\n   128→      // Pipe prompt to stdin\n   129→      this.childProcess.stdin!.write(assignment.prompt);\n   130→      this.childProcess.stdin!.end();\n   131→\n   132→      // Set up timeout\n   133→      const timeoutHandle = setTimeout(() => {\n   134→        this.logger.warn({\n   135→          executionId: assignment.executionId,\n   136→          timeoutMs: assignment.config.timeoutMs,\n   137→        }, 'Execution timeout, killing process');\n   138→        this.kill();\n   139→      }, assignment.config.timeoutMs);\n   140→\n   141→      // Parse stdout\n   142→      const stdoutBuffer = new LineBuffer();\n   143→      this.childProcess.stdout!.on('data', (data: Buffer) => {\n   144→        const lines = stdoutBuffer.push(data.toString());\n   145→        for (const line of lines) {\n   146→          this.processStdoutLine(line, callbacks);\n   147→        }\n   148→      });\n   149→\n   150→      // Parse stderr\n   151→      const stderrBuffer = new LineBuffer();\n   152→      this.childProcess.stderr!.on('data', (data: Buffer) => {\n   153→        const lines = stderrBuffer.push(data.toString());\n   154→        for (const line of lines) {\n   155→          callbacks.onStderr(line, Date.now());\n   156→        }\n   157→      });\n   158→\n   159→      // Wait for process to exit\n   160→      const exitCode = await new Promise<number>((resolve) => {\n   161→        this.childProcess!.on('close', (code: number | null) => {\n   162→          clearTimeout(timeoutHandle);\n   163→          resolve(code ?? 1);\n   164→        });\n   165→\n   166→        this.childProcess!.on('error', (err: Error) => {\n   167→          clearTimeout(timeoutHandle);\n   168→          this.logger.error({ err, executionId: assignment.executionId }, 'Process spawn error');\n   169→          resolve(1);\n   170→        });\n   171→      });\n   172→\n   173→      // Flush remaining buffered data\n   174→      for (const line of stdoutBuffer.flush()) {\n   175→        this.processStdoutLine(line, callbacks);\n   176→      }\n   177→      for (const line of stderrBuffer.flush()) {\n   178→        callbacks.onStderr(line, Date.now());\n   179→      }\n   180→\n   181→      const durationMs = Date.now() - startTime;\n   182→      const status = this.killed ? 'cancelled' : (exitCode === 0 ? 'completed' : 'failed');\n   183→\n   184→      this.logger.info({\n   185→        executionId: assignment.executionId,\n   186→        exitCode,\n   187→        durationMs,\n   188→        status,\n   189→        sessionId: this.sessionId,\n   190→        totalCostUsd: this.totalCostUsd,\n   191→      }, 'Execution finished');\n   192→\n   193→      callbacks.onComplete(status, exitCode, durationMs, this.sessionId, this.totalCostUsd);\n   194→\n   195→    } finally {\n   196→      if (injectedCreds) await injectedCreds.cleanup();\n   197→      if (proxy) proxy.cleanup();\n   198→      cleanupSandbox(sandbox.sandboxDir, this.logger);\n   199→      this.childProcess = null;\n   200→      this.killed = false;\n   201→    }\n   202→  }\n   203→\n   204→  kill(): void {\n   205→    if (this.childProcess && !this.killed) {\n   206→      this.killed = true;\n   207→      this.childProcess.kill('SIGTERM');\n   208→\n   209→      // Force kill after 5 seconds\n   210→      setTimeout(() => {\n   211→        if (this.childProcess) {\n   212→          this.childProcess.kill('SIGKILL');\n   213→        }\n   214→      }, 5_000);\n   215→    }\n   216→  }\n   217→}\n   218→"}]},"parent_tool_use_id":null,"session_id":"a98dd510-3145-4e13-a658-c8990d01d642","uuid":"369728cc-7ff8-4a22-940a-df2fd64da2be","timestamp":"2026-03-18T11:57:12.257Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\worker\\src\\executor.ts","content":"import type { ChildProcess } from 'node:child_process';\nimport { spawn } from 'node:child_process';\nimport type { ExecAssign } from '@dac-cloud/shared';\nimport { LineBuffer, extractStreamEvents } from './parser.js';\nimport { prepareSandbox, cleanupSandbox, type SandboxConfig } from './sandbox.js';\nimport { startFilterProxy, type ProxyHandle } from './networkProxy.js';\nimport { injectCredentialsViaFile, type InjectedCredentials } from './credentialInjector.js';\nimport { parseNetworkPolicy } from '@dac-cloud/shared';\nimport type { Logger } from 'pino';\n\nexport interface ExecutorCallbacks {\n  onStdout(chunk: string, timestamp: number): void;\n  onStderr(chunk: string, timestamp: number): void;\n  onEvent(eventType: 'manual_review' | 'user_message' | 'persona_action' | 'emit_event', payload: unknown): void;\n  onProgress(phase: string, percent: number, detail?: string): void;\n  onComplete(status: 'completed' | 'failed' | 'cancelled', exitCode: number, durationMs: number, sessionId?: string, totalCostUsd?: number): void;\n}\n\nexport class Executor {\n  private childProcess: ChildProcess | null = null;\n  private killed = false;\n  private sessionId: string | undefined;\n  private totalCostUsd: number | undefined;\n\n  /**\n   * Resolves when the current execution (including its finally-block cleanup)\n   * finishes.  Null when idle.\n   */\n  private executionDone: Promise<void> | null = null;\n\n  constructor(private logger: Logger) {}\n\n  /**\n   * Returns a promise that resolves once the in-flight execution's cleanup\n   * (sandbox removal, credential deletion, proxy teardown) has finished.\n   * If no execution is active, resolves immediately.\n   *\n   * An optional `timeoutMs` ensures the caller is never blocked forever\n   * (defaults to 10 s).\n   */\n  waitForCleanup(timeoutMs = 10_000): Promise<void> {\n    if (!this.executionDone) return Promise.resolve();\n\n    return Promise.race([\n      this.executionDone,\n      new Promise<void>((resolve) => setTimeout(resolve, timeoutMs)),\n    ]);\n  }\n\n  private processStdoutLine(line: string, callbacks: ExecutorCallbacks): void {\n    callbacks.onStdout(line, Date.now());\n\n    const streamEvents = extractStreamEvents(line, this.logger);\n    if (streamEvents.sessionId) this.sessionId = streamEvents.sessionId;\n    if (streamEvents.totalCostUsd) this.totalCostUsd = streamEvents.totalCostUsd;\n    for (const event of streamEvents.personaEvents) {\n      callbacks.onEvent(event.eventType, event.payload);\n    }\n    if (streamEvents.progress) {\n      callbacks.onProgress(streamEvents.progress.phase, streamEvents.progress.percent, streamEvents.progress.detail);\n    }\n  }\n\n  /** Returns true if an execution is currently in progress. */\n  isBusy(): boolean {\n    return this.childProcess !== null;\n  }\n\n  async execute(assignment: ExecAssign, callbacks: ExecutorCallbacks): Promise<void> {\n    const run = this.doExecute(assignment, callbacks);\n    this.executionDone = run.catch(() => {});   // swallow – callers handle errors via callbacks\n    try {\n      await run;\n    } finally {\n      this.executionDone = null;\n    }\n  }\n\n  private async doExecute(assignment: ExecAssign, callbacks: ExecutorCallbacks): Promise<void> {\n    const startTime = Date.now();\n    this.sessionId = undefined;\n    this.totalCostUsd = undefined;\n\n    const netPolicy = assignment.config.networkPolicy ?? undefined;\n    const sandboxConfig: SandboxConfig = {\n      executionId: assignment.executionId,\n      env: { ...assignment.env },\n      networkAccess: !netPolicy, // full access only if no policy set\n      networkPolicy: netPolicy,\n      timeoutMs: assignment.config.timeoutMs,\n      maxBudgetUsd: assignment.config.maxBudgetUsd,\n      maxTurns: assignment.config.maxTurns,\n    };\n\n    const sandbox = prepareSandbox(sandboxConfig, this.logger);\n    let proxy: ProxyHandle | null = null;\n    let injectedCreds: InjectedCredentials | null = null;\n\n    this.logger.info({\n      executionId: assignment.executionId,\n      personaId: assignment.personaId,\n      sandboxDir: sandbox.sandboxDir,\n      timeoutMs: assignment.config.timeoutMs,\n    }, 'Starting execution');\n\n    try {\n      // Start filtering proxy for allow-list network policies\n      if (sandbox.proxyRequired && netPolicy) {\n        proxy = await startFilterProxy(netPolicy, this.logger);\n        const proxyUrl = `http://127.0.0.1:${proxy.port}`;\n        sandbox.env['HTTP_PROXY'] = proxyUrl;\n        sandbox.env['HTTPS_PROXY'] = proxyUrl;\n        sandbox.env['http_proxy'] = proxyUrl;\n        sandbox.env['https_proxy'] = proxyUrl;\n        sandbox.env['NO_PROXY'] = '';\n      }\n\n      // Inject credentials via async file write (unblocks event loop)\n      injectedCreds = await injectCredentialsViaFile(sandbox.env, assignment.executionId, this.logger);\n      sandbox.env[injectedCreds.envPointerKey] = injectedCreds.credentialFilePath;\n\n      this.childProcess = spawn(sandbox.command, sandbox.args, {\n        cwd: sandbox.cwd,\n        stdio: ['pipe', 'pipe', 'pipe'],\n        env: sandbox.env,\n      });\n\n      // Pipe prompt to stdin\n      this.childProcess.stdin!.write(assignment.prompt);\n      this.childProcess.stdin!.end();\n\n      // Set up timeout\n      const timeoutHandle = setTimeout(() => {\n        this.logger.warn({\n          executionId: assignment.executionId,\n          timeoutMs: assignment.config.timeoutMs,\n        }, 'Execution timeout, killing process');\n        this.kill();\n      }, assignment.config.timeoutMs);\n\n      // Parse stdout\n      const stdoutBuffer = new LineBuffer();\n      this.childProcess.stdout!.on('data', (data: Buffer) => {\n        const lines = stdoutBuffer.push(data.toString());\n        for (const line of lines) {\n          this.processStdoutLine(line, callbacks);\n        }\n      });\n\n      // Parse stderr\n      const stderrBuffer = new LineBuffer();\n      this.childProcess.stderr!.on('data', (data: Buffer) => {\n        const lines = stderrBuffer.push(data.toString());\n        for (const line of lines) {\n          callbacks.onStderr(line, Date.now());\n        }\n      });\n\n      // Wait for process to exit\n      const exitCode = await new Promise<number>((resolve) => {\n        this.childProcess!.on('close', (code: number | null) => {\n          clearTimeout(timeoutHandle);\n          resolve(code ?? 1);\n        });\n\n        this.childProcess!.on('error', (err: Error) => {\n          clearTimeout(timeoutHandle);\n          this.logger.error({ err, executionId: assignment.executionId }, 'Process spawn error');\n          resolve(1);\n        });\n      });\n\n      // Flush remaining buffered data\n      for (const line of stdoutBuffer.flush()) {\n        this.processStdoutLine(line, callbacks);\n      }\n      for (const line of stderrBuffer.flush()) {\n        callbacks.onStderr(line, Date.now());\n      }\n\n      const durationMs = Date.now() - startTime;\n      const status = this.killed ? 'cancelled' : (exitCode === 0 ? 'completed' : 'failed');\n\n      this.logger.info({\n        executionId: assignment.executionId,\n        exitCode,\n        durationMs,\n        status,\n        sessionId: this.sessionId,\n        totalCostUsd: this.totalCostUsd,\n      }, 'Execution finished');\n\n      callbacks.onComplete(status, exitCode, durationMs, this.sessionId, this.totalCostUsd);\n\n    } finally {\n      if (injectedCreds) await injectedCreds.cleanup();\n      if (proxy) proxy.cleanup();\n      cleanupSandbox(sandbox.sandboxDir, this.logger);\n      this.childProcess = null;\n      this.killed = false;\n    }\n  }\n\n  kill(): void {\n    if (this.childProcess && !this.killed) {\n      this.killed = true;\n      this.childProcess.kill('SIGTERM');\n\n      // Force kill after 5 seconds\n      setTimeout(() => {\n        if (this.childProcess) {\n          this.childProcess.kill('SIGKILL');\n        }\n      }, 5_000);\n    }\n  }\n}\n","numLines":218,