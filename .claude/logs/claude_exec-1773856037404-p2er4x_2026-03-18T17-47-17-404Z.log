[2026-03-18T17:47:32.271Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Va2EFYpNCivSqUZv6tWYVH","type":"tool_result","content":"     1→// ---------------------------------------------------------------------------\n     2→// Dispatch pipeline — composable stages for worker dispatch\n     3→//\n     4→// Each stage is a standalone async function with typed inputs/outputs,\n     5→// independently testable without mocking the entire Dispatcher.\n     6→//\n     7→// Pipeline: ResolveToken → ResolvePersona → AssemblePayload → BuildAssignment\n     8→// ---------------------------------------------------------------------------\n     9→\n    10→import type { ExecAssign, ExecRequest, NetworkPolicy, Persona, PersonaToolDefinition, EncryptedPayload } from '@dac-cloud/shared';\n    11→import { assemblePrompt, resolveEnvOverrides, toEncryptedPayload, parseNetworkPolicy } from '@dac-cloud/shared';\n    12→import type Database from 'better-sqlite3';\n    13→import type { TokenManager } from './tokenManager.js';\n    14→import type { OAuthManager } from './oauth.js';\n    15→import type { Logger } from 'pino';\n    16→import * as db from './db/index.js';\n    17→\n    18→// ========================== Stage result types =============================\n    19→\n    20→export interface TokenResult {\n    21→  claudeToken: string;\n    22→}\n    23→\n    24→export interface PersonaResolution {\n    25→  persona: Persona | null;\n    26→  tools: PersonaToolDefinition[];\n    27→  credentialHints: string[];\n    28→  credentialEnv: Record<string, string>;\n    29→  inferenceEnvSet: Record<string, string>;\n    30→  inferenceEnvRemove: string[];\n    31→}\n    32→\n    33→export interface AssembledPayload {\n    34→  prompt: string;\n    35→  env: Record<string, string>;\n    36→  networkPolicy: NetworkPolicy | undefined;\n    37→  maxBudgetUsd: number | null;\n    38→  maxTurns: number | null;\n    39→}\n    40→\n    41→// ========================= Dependency interfaces ===========================\n    42→\n    43→/** Minimal decryption capability — abstracts master/tenant key resolution. */\n    44→export interface Decryptor {\n    45→  decrypt(\n    46→    payload: EncryptedPayload,\n    47→    tenantId: string,\n    48→    resourceId: string,\n    49→    logContext: Record<string, unknown>,\n    50→    logMessage: string,\n    51→  ): Promise<string | undefined>;\n    52→}\n    53→\n    54→// =========================== Stage 1: Token ================================\n    55→\n    56→export async function resolveToken(\n    57→  oauth: OAuthManager | null,\n    58→  tokenManager: TokenManager,\n    59→): Promise<TokenResult | null> {\n    60→  let claudeToken: string | null = null;\n    61→\n    62→  if (oauth?.hasTokens()) {\n    63→    claudeToken = await oauth.getValidAccessToken();\n    64→    if (claudeToken) {\n    65→      tokenManager.storeClaudeToken(claudeToken);\n    66→    }\n    67→  }\n    68→\n    69→  if (!claudeToken) {\n    70→    claudeToken = tokenManager.getClaudeToken();\n    71→  }\n    72→\n    73→  return claudeToken ? { claudeToken } : null;\n    74→}\n    75→\n    76→// ========================== Stage 2: Persona ===============================\n    77→\n    78→export async function resolvePersona(\n    79→  dispatchDb: Database.Database | null,\n    80→  personaId: string,\n    81→  tenantId: string,\n    82→  decryptor: Decryptor,\n    83→  logger: Logger,\n    84→): Promise<PersonaResolution> {\n    85→  const empty: PersonaResolution = {\n    86→    persona: null,\n    87→    tools: [],\n    88→    credentialHints: [],\n    89→    credentialEnv: {},\n    90→    inferenceEnvSet: {},\n    91→    inferenceEnvRemove: [],\n    92→  };\n    93→\n    94→  if (!dispatchDb) return empty;\n    95→\n    96→  const persona = db.getPersona(dispatchDb, personaId);\n    97→  if (!persona) return empty;\n    98→\n    99→  const tools = db.getToolsForPersona(dispatchDb, persona.id);\n   100→  const creds = db.listCredentialsForPersona(dispatchDb, persona.id);\n   101→\n   102→  // Decrypt credentials\n   103→  const credentialHints: string[] = [];\n   104→  const credentialEnv: Record<string, string> = {};\n   105→\n   106→  for (const cred of creds) {\n   107→    const envName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   108→    credentialHints.push(envName);\n   109→\n   110→    const decrypted = await decryptor.decrypt(\n   111→      toEncryptedPayload(cred),\n   112→      tenantId,\n   113→      cred.id,\n   114→      { credentialId: cred.id, credentialName: cred.name },\n   115→      'Failed to decrypt credential',\n   116→    );\n   117→\n   118→    if (decrypted !== undefined) {\n   119→      try {\n   120→        const fields = JSON.parse(decrypted) as Record<string, string>;\n   121→        for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n   122→          const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   123→          credentialEnv[fieldEnvName] = String(fieldValue);\n   124→        }\n   125→      } catch {\n   126→        credentialEnv[envName] = decrypted;\n   127→      }\n   128→    }\n   129→  }\n   130→\n   131→  // Resolve inference profile env overrides\n   132→  let inferenceEnvSet: Record<string, string> = {};\n   133→  let inferenceEnvRemove: string[] = [];\n   134→\n   135→  if (persona.inferenceProfileId) {\n   136→    const inferenceProfile = db.getInferenceProfile(dispatchDb, persona.inferenceProfileId);\n   137→    if (inferenceProfile) {\n   138→      let decryptedAuthToken: string | undefined;\n   139→      if (inferenceProfile.authTokenEncrypted && inferenceProfile.authTokenIv && inferenceProfile.authTokenTag) {\n   140→        decryptedAuthToken = await decryptor.decrypt(\n   141→          { encrypted: inferenceProfile.authTokenEncrypted, iv: inferenceProfile.authTokenIv, tag: inferenceProfile.authTokenTag },\n   142→          tenantId,\n   143→          `inference-profile:${inferenceProfile.id}`,\n   144→          { profileId: inferenceProfile.id },\n   145→          'Failed to decrypt inference profile auth token',\n   146→        );\n   147→        decryptedAuthToken = decryptedAuthToken ?? undefined;\n   148→      }\n   149→      const overrides = resolveEnvOverrides(inferenceProfile, decryptedAuthToken);\n   150→      inferenceEnvSet = overrides.set;\n   151→      inferenceEnvRemove = overrides.remove;\n   152→    }\n   153→  }\n   154→\n   155→  logger.info({ personaId: persona.id, toolCount: tools.length, credCount: creds.length }, 'Assembled prompt from DB persona');\n   156→\n   157→  return { persona, tools, credentialHints, credentialEnv, inferenceEnvSet, inferenceEnvRemove };\n   158→}\n   159→\n   160→// ======================== Stage 3: Assemble ================================\n   161→\n   162→export function assemblePayload(\n   163→  request: ExecRequest,\n   164→  token: TokenResult,\n   165→  resolution: PersonaResolution,\n   166→): AssembledPayload {\n   167→  // Build env map: API key + credential env + inference overrides\n   168→  const env: Record<string, string> = {\n   169→    ANTHROPIC_API_KEY: token.claudeToken,\n   170→    ...resolution.credentialEnv,\n   171→    ...resolution.inferenceEnvSet,\n   172→  };\n   173→\n   174→  // Remove inference-specified keys\n   175→  for (const k of resolution.inferenceEnvRemove) {\n   176→    delete env[k];\n   177→  }\n   178→\n   179→  // Build prompt\n   180→  let prompt: string;\n   181→  if (resolution.persona) {\n   182→    const inputData = request.inputData ? (request.inputData as Record<string, unknown>) : undefined;\n   183→    prompt = assemblePrompt(\n   184→      resolution.persona,\n   185→      resolution.tools,\n   186→      inputData,\n   187→      resolution.credentialHints.length > 0 ? resolution.credentialHints : undefined,\n   188→    );\n   189→  } else {\n   190→    prompt = request.prompt;\n   191→  }\n   192→\n   193→  // Resolve network policy\n   194→  let networkPolicy: NetworkPolicy | undefined;\n   195→  if (resolution.persona?.networkPolicy) {\n   196→    networkPolicy = parseNetworkPolicy(resolution.persona.networkPolicy) ?? undefined;\n   197→  }\n   198→\n   199→  return {\n   200→    prompt,\n   201→    env,\n   202→    networkPolicy,\n   203→    maxBudgetUsd: resolution.persona?.maxBudgetUsd ?? null,\n   204→    maxTurns: resolution.persona?.maxTurns ?? null,\n   205→  };\n   206→}\n   207→\n   208→// =================== Stage 4: Build assignment =============================\n   209→\n   210→export function buildAssignment(\n   211→  request: ExecRequest,\n   212→  payload: AssembledPayload,\n   213→): ExecAssign {\n   214→  return {\n   215→    type: 'assign',\n   216→    executionId: request.executionId,\n   217→    personaId: request.personaId,\n   218→    prompt: payload.prompt,\n   219→    env: payload.env,\n   220→    config: {\n   221→      timeoutMs: request.config.timeoutMs || 300_000,\n   222→      maxOutputBytes: 10 * 1024 * 1024,\n   223→      ...(payload.networkPolicy ? { networkPolicy: payload.networkPolicy } : {}),\n   224→      ...(payload.maxBudgetUsd ? { maxBudgetUsd: payload.maxBudgetUsd } : {}),\n   225→      ...(payload.maxTurns ? { maxTurns: payload.maxTurns } : {}),\n   226→    },\n   227→  };\n   228→}\n   229→\n   230→// ============== ExecutionPreparer — stages 2-4 composed ====================\n   231→\n   232→/** Resolves a DB handle for a given project/tenant ID. */\n   233→export type DbResolver = (projectId?: string) => Database.Database | null;\n   234→\n   235→/**\n   236→ * Composes persona resolution, payload assembly, and assignment building\n   237→ * into a single prepare() call. Token acquisition and the actual send\n   238→ * remain in the Dispatcher.\n   239→ */\n   240→export class ExecutionPreparer {\n   241→  constructor(\n   242→    private resolveDb: DbResolver,\n   243→    private decryptor: Decryptor,\n   244→    private logger: Logger,\n   245→  ) {}\n   246→\n   247→  /**\n   248→   * Prepare an ExecAssign from a request and a pre-resolved token.\n   249→   * Pure enrichment — no side effects beyond DB reads and decryption.\n   250→   */\n   251→  async prepare(request: ExecRequest, token: TokenResult): Promise<ExecAssign> {\n   252→    const tenantId = request.projectId || 'default';\n   253→    const dispatchDb = this.resolveDb(tenantId);\n   254→\n   255→    const resolution = await resolvePersona(\n   256→      dispatchDb,\n   257→      request.personaId,\n   258→      tenantId,\n   259→      this.decryptor,\n   260→      this.logger,\n   261→    );\n   262→\n   263→    const payload = assemblePayload(request, token, resolution);\n   264→    return buildAssignment(request, payload);\n   265→  }\n   266→}\n   267→"}]},"parent_tool_use_id":null,"session_id":"3232ee93-5fbe-487f-b138-fe73f2dad6aa","uuid":"36da4127-2726-4e5e-85ee-c46562b806ea","timestamp":"2026-03-18T17:47:32.177Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\dispatchPipeline.ts","content":"// ---------------------------------------------------------------------------\n// Dispatch pipeline — composable stages for worker dispatch\n//\n// Each stage is a standalone async function with typed inputs/outputs,\n// independently testable without mocking the entire Dispatcher.\n//\n// Pipeline: ResolveToken → ResolvePersona → AssemblePayload → BuildAssignment\n// ---------------------------------------------------------------------------\n\nimport type { ExecAssign, ExecRequest, NetworkPolicy, Persona, PersonaToolDefinition, EncryptedPayload } from '@dac-cloud/shared';\nimport { assemblePrompt, resolveEnvOverrides, toEncryptedPayload, parseNetworkPolicy } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\n\n// ========================== Stage result types =============================\n\nexport interface TokenResult {\n  claudeToken: string;\n}\n\nexport interface PersonaResolution {\n  persona: Persona | null;\n  tools: PersonaToolDefinition[];\n  credentialHints: string[];\n  credentialEnv: Record<string, string>;\n  inferenceEnvSet: Record<string, string>;\n  inferenceEnvRemove: string[];\n}\n\nexport interface AssembledPayload {\n  prompt: string;\n  env: Record<string, string>;\n  networkPolicy: NetworkPolicy | undefined;\n  maxBudgetUsd: number | null;\n  maxTurns: number | null;\n}\n\n// ========================= Dependency interfaces ===========================\n\n/** Minimal decryption capability — abstracts master/tenant key resolution. */\nexport interface Decryptor {\n  decrypt(\n    payload: EncryptedPayload,\n    tenantId: string,\n    resourceId: string,\n    logContext: Record<string, unknown>,\n    logMessage: string,\n  ): Promise<string | undefined>;\n}\n\n// =========================== Stage 1: Token ================================\n\nexport async function resolveToken(\n  oauth: OAuthManager | null,\n  tokenManager: TokenManager,\n): Promise<TokenResult | null> {\n  let claudeToken: string | null = null;\n\n  if (oauth?.hasTokens()) {\n    claudeToken = await oauth.getValidAccessToken();\n    if (claudeToken) {\n      tokenManager.storeClaudeToken(claudeToken);\n    }\n  }\n\n  if (!claudeToken) {\n    claudeToken = tokenManager.getClaudeToken();\n  }\n\n  return claudeToken ? { claudeToken } : null;\n}\n\n// ========================== Stage 2: Persona ===============================\n\nexport async function resolvePersona(\n  dispatchDb: Database.Database | null,\n  personaId: string,\n  tenantId: string,\n  decryptor: Decryptor,\n  logger: Logger,\n): Promise<PersonaResolution> {\n  const empty: PersonaResolution = {\n    persona: null,\n    tools: [],\n    credentialHints: [],\n    credentialEnv: {},\n    inferenceEnvSet: {},\n    inferenceEnvRemove: [],\n  };\n\n  if (!dispatchDb) return empty;\n\n  const persona = db.getPersona(dispatchDb, personaId);\n  if (!persona) return empty;\n\n  const tools = db.getToolsForPersona(dispatchDb, persona.id);\n  const creds = db.listCredentialsForPersona(dispatchDb, persona.id);\n\n  // Decrypt credentials\n  const credentialHints: string[] = [];\n  const credentialEnv: Record<string, string> = {};\n\n  for (const cred of creds) {\n    const envName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n    credentialHints.push(envName);\n\n    const decrypted = await decryptor.decrypt(\n      toEncryptedPayload(cred),\n      tenantId,\n      cred.id,\n      { credentialId: cred.id, credentialName: cred.name },\n      'Failed to decrypt credential',\n    );\n\n    if (decrypted !== undefined) {\n      try {\n        const fields = JSON.parse(decrypted) as Record<string, string>;\n        for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n          const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n          credentialEnv[fieldEnvName] = String(fieldValue);\n        }\n      } catch {\n        credentialEnv[envName] = decrypted;\n      }\n    }\n  }\n\n  // Resolve inference profile env overrides\n  let inferenceEnvSet: Record<string, string> = {};\n  let inferenceEnvRemove: string[] = [];\n\n  if (persona.inferenceProfileId) {\n    const inferenceProfile = db.getInferenceProfile(dispatchDb, persona.inferenceProfileId);\n    if (inferenceProfile) {\n      let decryptedAuthToken: string | undefined;\n      if (inferenceProfile.authTokenEncrypted && inferenceProfile.authTokenIv && inferenceProfile.authTokenTag) {\n        decryptedAuthToken = await decryptor.decrypt(\n          { encrypted: inferenceProfile.authTokenEncrypted, iv: inferenceProfile.authTokenIv, tag: inferenceProfile.authTokenTag },\n          tenantId,\n          `inference-profile:${inferenceProfile.id}`,\n          { profileId: inferenceProfile.id },\n          'Failed to decrypt inference profile auth token',\n        );\n        decryptedAuthToken = decryptedAuthToken ?? undefined;\n      }\n      const overrides = resolveEnvOverrides(inferenceProfile, decryptedAuthToken);\n      inferenceEnvSet = overrides.set;\n      inferenceEnvRemove = overrides.remove;\n    }\n  }\n\n  logger.info({ personaId: persona.id, toolCount: tools.length, credCount: creds.length }, 'Assembled prompt from DB persona');\n\n  return { persona, tools, credentialHints, credentialEnv, inferenceEnvSet, inferenceEnvRemove };\n}\n\n// ======================== Stage 3: Assemble ================================\n\nexport function assemblePayload(\n  request: ExecRequest,\n  token: TokenResult,\n  resolution: PersonaResolution,\n): AssembledPayload {\n  // Build env map: API key + credential env + inference overrides\n  const env: Record<string, string> = {\n    ANTHROPIC_API_KEY: token.claudeToken,\n    ...resolution.credentialEnv,\n    ...resolution.inferenceEnvSet,\n  };\n\n  // Remove inference-specified keys\n  for (const k of resolution.inferenceEnvRemove) {\n    delete env[k];\n  }\n\n  // Build prompt\n  let prompt: string;\n  if (resolution.persona) {\n    const inputData = request.inputData ? (request.inputData as Record<string, unknown>) : undefined;\n    prompt = assemblePrompt(\n      resolution.persona,\n      resolution.tools,\n      inputData,\n      resolution.credentialHints.length > 0 ? resolution.credentialHints : undefined,\n    );\n  } else {\n    prompt = request.prompt;\n  }\n\n  // Resolve network policy\n  let networkPolicy: NetworkPolicy | undefined;\n  if (resolution.persona?.networkPolicy) {\n    networkPolicy = parseNetworkPolicy(resolution.persona.networkPolicy) ?? undefined;\n  }\n\n  return {\n    prompt,\n    env,\n    networkPolicy,\n    maxBudgetUsd: resolution.persona?.maxBudgetUsd ?? null,\n    maxTurns: resolution.persona?.maxTurns ?? null,\n  };\n}\n\n// =================== Stage 4: Build assignment =============================\n\nexport function buildAssignment(\n  request: ExecRequest,\n  payload: AssembledPayload,\n): ExecAssign {\n  return {\n    type: 'assign',\n    executionId: request.executionId,\n    personaId: request.personaId,\n    prompt: payload.prompt,\n    env: payload.env,\n    config: {\n      timeoutMs: request.config.timeoutMs || 300_000,\n      maxOutputBytes: 10 * 1024 * 1024,\n      ...(payload.networkPolicy ? { networkPolicy: payload.networkPolicy } : {}),\n      ...(payload.maxBudgetUsd ? { maxBudgetUsd: payload.maxBudgetUsd } : {}),\n      ...(payload.maxTurns ? { maxTurns: payload.maxTurns } : {}),\n    },\n  };\n}\n\n// ============== ExecutionPreparer — stages 2-4 composed ====================\n\n/** Resolves a DB handle for a given project/tenant ID. */\nexport type DbResolver = (projectId?: string) => Database.Database | null;\n\n/**\n * Composes persona resolution, payload assembly, and assignment building\n * into a single prepare() call. Token acquisition and the actual send\n * remain in the Dispatcher.\n */\nexport class ExecutionPreparer {\n  constructor(\n    private resolveDb: DbResolver,\n    private decryptor: Decryptor,\n    private logger: Logger,\n  ) {}\n\n  /**\n   * Prepare an ExecAssign from a request and a pre-resolved token.\n   * Pure enrichment — no side effects beyond DB reads and decryption.\n   */\n  async prepare(request: ExecRequest, token: TokenResult): Promise<ExecAssign> {\n    const tenantId = request.projectId || 'default';\n    const dispatchDb = this.resolveDb(tenantId);\n\n    const resolution = await resolvePersona(\n      dispatchDb,\n      request.personaId,\n      tenantId,\n      this.decryptor,\n      this.logger,\n    );\n\n    const payload = assemblePayload(request, token, resolution);\n    return buildAssignment(request, payload);\n  }\n}\n","numLines":267,"startLine":1,"totalLines":267}}}
