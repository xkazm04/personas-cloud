0→  });\n    41→\n    42→  server.on('connect', (req, clientSocket, head) => {\n    43→    const target = req.url ?? '';\n    44→    let host: string;\n    45→    let port: number;\n    46→\n    47→    // Parse CONNECT target, handling both IPv4 \"host:port\" and IPv6 \"[::1]:port\"\n    48→    if (target.startsWith('[')) {\n    49→      const closeBracket = target.indexOf(']');\n    50→      host = closeBracket > 0 ? target.slice(1, closeBracket) : '';\n    51→      const portStr = closeBracket > 0 ? target.slice(closeBracket + 2) : '';\n    52→      port = parseInt(portStr, 10) || 443;\n    53→    } else {\n    54→      const lastColon = target.lastIndexOf(':');\n    55→      host = lastColon > 0 ? target.slice(0, lastColon) : target;\n    56→      port = lastColon > 0 ? parseInt(target.slice(lastColon + 1), 10) || 443 : 443;\n    57→    }\n    58→\n    59→    if (!host || !isAllowed(policy, host, port)) {\n    60→      logger.warn({ host, port }, 'Proxy: blocked CONNECT');\n    61→      clientSocket.write('HTTP/1.1 403 Forbidden\\r\\n\\r\\n');\n    62→      clientSocket.destroy();\n    63→      return;\n    64→    }\n    65→\n    66→    const serverSocket = net.connect(port, host, () => {\n    67→      clientSocket.write('HTTP/1.1 200 Connection Established\\r\\n\\r\\n');\n    68→      serverSocket.write(head);\n    69→      serverSocket.pipe(clientSocket);\n    70→      clientSocket.pipe(serverSocket);\n    71→    });\n    72→\n    73→    activeSockets.add(clientSocket);\n    74→    activeSockets.add(serverSocket);\n    75→\n    76→    const removeSocket = (s: net.Socket | Duplex) => { activeSockets.delete(s); };\n    77→\n    78→    serverSocket.on('close', () => removeSocket(serverSocket));\n    79→    clientSocket.on('close', () => removeSocket(clientSocket));\n    80→\n    81→    serverSocket.on('error', (err) => {\n    82→      logger.error({ err, host, port }, 'Proxy: upstream connection error');\n    83→      clientSocket.destroy();\n    84→    });\n    85→\n    86→    clientSocket.on('error', () => {\n    87→      serverSocket.destroy();\n    88→    });\n    89→  });\n    90→\n    91→  return new Promise((resolve) => {\n    92→    server.listen(0, '127.0.0.1', () => {\n    93→      const addr = server.address() as net.AddressInfo;\n    94→      logger.info({ port: addr.port, mode: policy.mode, rules: policy.allowedHosts?.length ?? 0 }, 'Network filter proxy started');\n    95→      resolve({\n    96→        port: addr.port,\n    97→        cleanup: () => {\n    98→          for (const socket of activeSockets) {\n    99→            socket.destroy();\n   100→          }\n   101→          activeSockets.clear();\n   102→          server.close();\n   103→        },\n   104→      });\n   105→    });\n   106→  });\n   107→}\n   108→"}]},"parent_tool_use_id":null,"session_id":"25b033f0-6ed5-469c-a732-4ccf70c0c019","uuid":"32150428-6a1a-41b1-91ab-a9cb7e24ed23","timestamp":"2026-03-18T11:29:35.029Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\worker\\src\\networkProxy.ts","content":"// ---------------------------------------------------------------------------\n// Filtering HTTP CONNECT proxy for per-persona network policies\n// ---------------------------------------------------------------------------\n\nimport http from 'node:http';\nimport net from 'node:net';\nimport type { Duplex } from 'node:stream';\nimport type { Logger } from 'pino';\nimport { type NetworkPolicyRule, isAllowed, type NetworkPolicy } from '@dac-cloud/shared';\n\nexport interface ProxyHandle {\n  port: number;\n  cleanup: () => void;\n}\n\nexport async function startFilterProxy(\n  policy: NetworkPolicy,\n  logger: Logger,\n): Promise<ProxyHandle> {\n  const activeSockets = new Set<net.Socket | Duplex>();\n\n  const server = http.createServer((_req, res) => {\n    // Non-CONNECT requests through proxy — check and forward or reject\n    const url = _req.url;\n    if (!url) { res.writeHead(400).end(); return; }\n    try {\n      const parsed = new URL(url);\n      const port = parseInt(parsed.port, 10) || (parsed.protocol === 'https:' ? 443 : 80);\n      if (!isAllowed(policy, parsed.hostname, port)) {\n        logger.warn({ host: parsed.hostname, port }, 'Proxy: blocked non-CONNECT request');\n        res.writeHead(403, { 'Content-Type': 'text/plain' }).end('Blocked by network policy');\n        return;\n      }\n    } catch {\n      res.writeHead(400).end();\n      return;\n    }\n    // For allowed non-CONNECT, pass through (minimal — most traffic uses CONNECT)\n    res.writeHead(501).end('Direct proxy not supported, use CONNECT');\n  });\n\n  server.on('connect', (req, clientSocket, head) => {\n    const target = req.url ?? '';\n    let host: string;\n    let port: number;\n\n    // Parse CONNECT target, handling both IPv4 \"host:port\" and IPv6 \"[::1]:port\"\n    if (target.startsWith('[')) {\n      const closeBracket = target.indexOf(']');\n      host = closeBracket > 0 ? target.slice(1, closeBracket) : '';\n      const portStr = closeBracket > 0 ? target.slice(closeBracket + 2) : '';\n      port = parseInt(portStr, 10) || 443;\n    } else {\n      const lastColon = target.lastIndexOf(':');\n      host = lastColon > 0 ? target.slice(0, lastColon) : target;\n      port = lastColon > 0 ? parseInt(target.slice(lastColon + 1), 10) || 443 : 443;\n    }\n\n    if (!host || !isAllowed(policy, host, port)) {\n      logger.warn({ host, port }, 'Proxy: blocked CONNECT');\n      clientSocket.write('HTTP/1.1 403 Forbidden\\r\\n\\r\\n');\n      clientSocket.destroy();\n      return;\n    }\n\n    const serverSocket = net.connect(port, host, () => {\n      clientSocket.write('HTTP/1.1 200 Connection Established\\r\\n\\r\\n');\n      serverSocket.write(head);\n      serverSocket.pipe(clientSocket);\n      clientSocket.pipe(serverSocket);\n    });\n\n    activeSockets.add(clientSocket);\n    activeSockets.add(serverSocket);\n\n    const removeSocket = (s: net.Socket | Duplex) => { activeSockets.delete(s); };\n\n    serverSocket.on('close', () => removeSocket(serverSocket));\n    clientSocket.on('close', () => removeSocket(clientSocket));\n\n    serverSocket.on('error', (err) => {\n      logger.error({ err, host, port }, 'Proxy: upstream connection error');\n      clientSocket.destroy();\n    });\n\n    clientSocket.on('error', () => {\n      serverSocket.destroy();\n    });\n  });\n\n  return new Promise((resolve) => {\n    server.listen(0, '127.0.0.1', () => {\n      const addr = server.address() as net.AddressInfo;\n      logger.info({ port: addr.port, mode: policy.mode, rules: policy.allowedHosts?.length ?? 0 }, 'Network filter proxy started');\n      resolve({\n        port: addr.port,\n        cleanup: () => {\n          for (const socket of activeSockets) {\n            socket.destroy();\n          }\n          activeSockets.clear();\n          server.close();\n        },\n      });\n    });\n  });\n}\n","numLines":108,"startLine":1,"totalLines":108}}}
