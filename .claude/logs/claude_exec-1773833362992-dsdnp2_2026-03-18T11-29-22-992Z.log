col events and progress events (from assistant message content blocks)\n    43→  const message = parsed.message as Record<string, unknown> | undefined;\n    44→  if (parsed.type === 'assistant' && Array.isArray(message?.content)) {\n    45→    for (const block of message!.content as Array<Record<string, unknown>>) {\n    46→      if (block.type !== 'text' || typeof block.text !== 'string') continue;\n    47→\n    48→      const matches = block.text.match(JSON_BLOCK_PATTERN);\n    49→      if (!matches) continue;\n    50→\n    51→      for (const match of matches) {\n    52→        let obj: Record<string, unknown>;\n    53→        try { obj = JSON.parse(match); } catch { continue; }\n    54→\n    55→        for (const key of PROTOCOL_KEYS) {\n    56→          if (obj[key]) {\n    57→            result.personaEvents.push({ eventType: key, payload: obj[key] });\n    58→            logger.info({ eventType: key }, 'Detected persona protocol event');\n    59→          }\n    60→        }\n    61→\n    62→        if (!result.progress) {\n    63→          const prog = obj.progress as Record<string, unknown> | undefined;\n    64→          if (prog && typeof prog.phase === 'string' && typeof prog.percent === 'number') {\n    65→            logger.debug({ phase: prog.phase, percent: prog.percent }, 'Detected progress event');\n    66→            result.progress = {\n    67→              phase: prog.phase,\n    68→              percent: Math.max(0, Math.min(100, prog.percent)),\n    69→              detail: prog.detail as string | undefined,\n    70→              updatedAt: Date.now(),\n    71→            };\n    72→          }\n    73→        }\n    74→      }\n    75→    }\n    76→  }\n    77→\n    78→  return result;\n    79→}\n    80→\n    81→// Buffered line reader for streaming data\n    82→export class LineBuffer {\n    83→  private buffer = '';\n    84→\n    85→  push(chunk: string): string[] {\n    86→    this.buffer += chunk;\n    87→    const lines: string[] = [];\n    88→    let newlineIdx: number;\n    89→\n    90→    while ((newlineIdx = this.buffer.indexOf('\\n')) !== -1) {\n    91→      const line = this.buffer.slice(0, newlineIdx).trim();\n    92→      this.buffer = this.buffer.slice(newlineIdx + 1);\n    93→      if (line.length > 0) {\n    94→        lines.push(line);\n    95→      }\n    96→    }\n    97→\n    98→    return lines;\n    99→  }\n   100→\n   101→  flush(): string[] {\n   102→    const remaining = this.buffer.trim();\n   103→    this.buffer = '';\n   104→    return remaining.length > 0 ? [remaining] : [];\n   105→  }\n   106→}\n   107→"}]},"parent_tool_use_id":null,"session_id":"25b033f0-6ed5-469c-a732-4ccf70c0c019","uuid":"eb5d6c0f-6e4a-4d2a-8c88-3602f08a437d","timestamp":"2026-03-18T11:29:35.913Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\worker\\src\\parser.ts","content":"import type { Logger } from 'pino';\nimport type { ProgressInfo } from '@dac-cloud/shared';\n\nexport interface PersonaProtocolEvent {\n  eventType: 'manual_review' | 'user_message' | 'persona_action' | 'emit_event';\n  payload: unknown;\n}\n\nexport interface StreamEvents {\n  raw: string;\n  type?: string;\n  sessionId?: string;\n  totalCostUsd?: number;\n  personaEvents: PersonaProtocolEvent[];\n  progress: ProgressInfo | null;\n}\n\nconst PROTOCOL_KEYS = ['manual_review', 'user_message', 'persona_action', 'emit_event'] as const;\nconst JSON_BLOCK_PATTERN = /\\{[^{}]*(?:\\{[^{}]*\\}[^{}]*)*\\}/g;\n\n// Extract all structured artifacts from a single stream line in one JSON parse pass\nexport function extractStreamEvents(line: string, logger: Logger): StreamEvents {\n  const result: StreamEvents = { raw: line, personaEvents: [], progress: null };\n\n  let parsed: Record<string, unknown>;\n  try {\n    parsed = JSON.parse(line);\n  } catch {\n    return result; // raw text line — nothing to extract\n  }\n\n  result.type = parsed.type as string | undefined;\n\n  // Session ID and completion data (from top-level result messages)\n  if (parsed.session_id) result.sessionId = parsed.session_id as string;\n  const resultObj = parsed.result as Record<string, unknown> | undefined;\n  if (resultObj?.session_id) result.sessionId = resultObj.session_id as string;\n  if (parsed.type === 'result') {\n    result.totalCostUsd = (parsed.total_cost_usd ?? resultObj?.total_cost_usd) as number | undefined;\n  }\n\n  // Persona protocol events and progress events (from assistant message content blocks)\n  const message = parsed.message as Record<string, unknown> | undefined;\n  if (parsed.type === 'assistant' && Array.isArray(message?.content)) {\n    for (const block of message!.content as Array<Record<string, unknown>>) {\n      if (block.type !== 'text' || typeof block.text !== 'string') continue;\n\n      const matches = block.text.match(JSON_BLOCK_PATTERN);\n      if (!matches) continue;\n\n      for (const match of matches) {\n        let obj: Record<string, unknown>;\n        try { obj = JSON.parse(match); } catch { continue; }\n\n        for (const key of PROTOCOL_KEYS) {\n          if (obj[key]) {\n            result.personaEvents.push({ eventType: key, payload: obj[key] });\n            logger.info({ eventType: key }, 'Detected persona protocol event');\n          }\n        }\n\n        if (!result.progress) {\n          const prog = obj.progress as Record<string, unknown> | undefined;\n          if (prog && typeof prog.phase === 'string' && typeof prog.percent === 'number') {\n            logger.debug({ phase: prog.phase, percent: prog.percent }, 'Detected progress event');\n            result.progress = {\n              phase: prog.phase,\n              percent: Math.max(0, Math.min(100, prog.percent)),\n              detail: prog.detail as string | undefined,\n              updatedAt: Date.now(),\n            };\n          }\n        }\n      }\n    }\n  }\n\n  return result;\n}\n\n// Buffered line reader for streaming data\nexport class LineBuffer {\n  private buffer = '';\n\n  push(chunk: string): string[] {\n    this.buffer += chunk;\n    const lines: string[] = [];\n    let newlineIdx: number;\n\n    while ((newlineIdx = this.buffer.indexOf('\\n')) !== -1) {\n      const line = this.buffer.slice(0, newlineIdx).trim();\n      this.buffer = this.buffer.slice(newlineIdx + 1);\n      if (line.length > 0) {\n        lines.push(line);\n      }\n    }\n\n    return lines;\n  }\n\n  flush(): string[] {\n    const remaining = this.buffer.trim();\n    this.buffer = '';\n    return remaining.length > 0 ? [remaining] : [];\n  }\n}\n","numLines":107,"startLine":1,"totalLines":107}}}
