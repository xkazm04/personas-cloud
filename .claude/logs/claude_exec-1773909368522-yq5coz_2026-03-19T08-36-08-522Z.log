     let auditSizeBytes = 0;\n   199→      let auditRowCount = 0;\n   200→      try {\n   201→        const auditDb = auditLog.getDb();\n   202→        const sizeRow = auditDb.prepare('SELECT page_count * page_size AS size FROM pragma_page_count(), pragma_page_size()').get() as { size: number } | undefined;\n   203→        auditSizeBytes = sizeRow?.size ?? 0;\n   204→        const countRow = auditDb.prepare('SELECT COUNT(*) AS cnt FROM audit_events').get() as { cnt: number };\n   205→        auditRowCount = countRow.cnt;\n   206→      } catch { /* audit DB stats are best-effort */ }\n   207→\n   208→      const oldestAgeDays = dbHealth.oldestUnpurgedAgeMs !== null\n   209→        ? Math.round(dbHealth.oldestUnpurgedAgeMs / (1000 * 60 * 60 * 24) * 10) / 10\n   210→        : null;\n   211→\n   212→      logger.info({\n   213→        totalSizeMB: Math.round(dbHealth.totalSizeBytes / (1024 * 1024) * 100) / 100,\n   214→        auditSizeMB: Math.round(auditSizeBytes / (1024 * 1024) * 100) / 100,\n   215→        tenantCount: dbHealth.tenantCount,\n   216→        executionRows: dbHealth.totalExecutionRows,\n   217→        eventRows: dbHealth.totalEventRows,\n   218→        auditRows: auditRowCount,\n   219→        oldestUnpurgedDays: oldestAgeDays,\n   220→        retentionDays: config.retentionDays,\n   221→      }, 'DB health');\n   222→    } catch (err) {\n   223→      logger.warn({ err }, 'Failed to collect DB health stats');\n   224→    }\n   225→  }, 60_000);\n   226→\n   227→  // Graceful shutdown\n   228→  const shutdown = async () => {\n   229→    logger.info('Shutting down...');\n   230→    clearInterval(eventProcessor.timer);\n   231→    triggerScheduler.close();\n   232→    clearInterval(retentionJob.timer);\n   233→    dispatcher.shutdown();\n   234→    pool.shutdown();\n   235→    await kafka.disconnect();\n   236→    httpServer.close();\n   237→    tenantKeyManager.close();\n   238→    auditChainVerifier.close();\n   239→    auditRetention.close();\n   240→ 