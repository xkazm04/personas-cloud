string;\n    55→  authToken?: string;\n    56→}\n    57→\n    58→export interface PersonaCredential {\n    59→  id: string;\n    60→  projectId?: string;\n    61→  name: string;\n    62→  serviceType: string;\n    63→  encryptedData: string;\n    64→  iv: string;\n    65→  tag: string;\n    66→  metadata: string | null;\n    67→  lastUsedAt: string | null;\n    68→  createdAt: string;\n    69→  updatedAt: string;\n    70→}\n    71→\n    72→export interface PersonaEvent {\n    73→  id: string;\n    74→  projectId: string;\n    75→  eventType: string;\n    76→  sourceType: string;\n    77→  sourceId: string | null;\n    78→  targetPersonaId: string | null;\n    79→  payload: string | null;\n    80→  status: string;\n    81→  errorMessage: string | null;\n    82→  processedAt: string | null;\n    83→  useCaseId: string | null;\n    84→  createdAt: string;\n    85→}\n    86→\n    87→export interface PersonaEventSubscription {\n    88→  id: string;\n    89→  personaId: string;\n    90→  eventType: string;\n    91→  sourceFilter: string | null;\n    92→  enabled: boolean;\n    93→  useCaseId: string | null;\n    94→  createdAt: string;\n    95→  updatedAt: string;\n    96→}\n    97→\n    98→export interface PersonaTrigger {\n    99→  id: string;\n   100→  personaId: string;\n   101→  triggerType: string;\n   102→  config: string | null;\n   103→  enabled: boolean;\n   104→  lastTriggeredAt: string | null;\n   105→  nextTriggerAt: string | null;\n   106→  useCaseId: string | null;\n   107→  createdAt: string;\n   108→  updatedAt: string;\n   109→}\n   110→\n   111→export interface PersonaExecution {\n   112→  id: string;\n   113→  projectId?: string;\n   114→  personaId: string;\n   115→  triggerId: string | null;\n   116→  useCaseId: string | null;\n   117→  status: string;\n   118→  inputData: string | null;\n   119→  outputData: string | null;\n   120→  claudeSessionId: string | null;\n   121→  modelUsed: string | null;\n   122→  inputTokens: number;\n   123→  outputTok