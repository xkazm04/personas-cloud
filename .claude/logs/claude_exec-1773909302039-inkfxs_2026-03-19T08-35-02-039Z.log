[2026-03-19T08:35:15.602Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MimVFmBWXk4rkXWB8tFC3R","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher, SubmitResult } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import type { KafkaClient } from './kafka.js';\n    11→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    12→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    13→import type { TriggerSchedulerHandle } from './triggerScheduler.js';\n    14→import type { TenantDbManager } from './tenantDbManager.js';\n    15→import type { TenantKeyManager } from './tenantKeyManager.js';\n    16→import type { AuditLog, AuditEntry, AuditAction, AuditLogHealth } from './auditLog.js';\n    17→import type { EventProcessorHealth } from './eventProcessor.js';\n    18→import type { RetentionHealth } from './retention.js';\n    19→import type { Logger } from 'pino';\n    20→import * as db from './db/index.js';\n    21→import { readBody, json } from './httpUtils.js';\n    22→\n    23→// --- Route types ---\n    24→\n    25→interface ParsedRoute {\n    26→  resource: string;\n    27→  id?: string;\n    28→  subResource?: string;\n    29→}\n    30→\n    31→type RouteHandler = (\n    32→  req: http.IncomingMessage,\n    33→  res: http.ServerResponse,\n    34→  ctx: RequestContext,\n    35→  route: ParsedRoute | null,\n    36→  queryString: string | undefined,\n    37→  tenantDb: Database.Database | undefined,\n    38→  scopedProjectId: string | undefined,\n    39→  reqLogger: Logger,\n    40→) => Promise<void> | void;\n    41→\n    42→interface RouteEntry {\n    43→  handler: RouteHandler;\n    44→  needsDb?: boolean;\n    45→  adminOnly?: boolean;\n    46→}\n    47→\n    48→/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\n    49→function resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n    50→  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n    51→}\n    52→\n    53→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n    54→function parseRoute(pathname: string): ParsedRoute | null {\n    55→  if (!pathname.startsWith('/api/')) return null;\n    56→  const segments = pathname.slice(5).split('/').filter(Boolean);\n    57→  if (segments.length === 0) return null;\n    58→  return {\n    59→    resource: segments[0]!,\n    60→    id: segments[1],\n    61→    subResource: segments[2],\n    62→  };\n    63→}\n    64→\n    65→export function createHttpApi(\n    66→  auth: Auth,\n    67→  dispatcher: Dispatcher,\n    68→  pool: WorkerPool,\n    69→  tokenManager: TokenManager,\n    70→  oauth: OAuthManager,\n    71→  logger: Logger,\n    72→  database?: Database.Database,\n    73→  tenantDbManager?: TenantDbManager,\n    74→  tenantKeyManager?: TenantKeyManager,\n    75→  auditLog?: AuditLog,\n    76→  getEventProcessorHealth?: () => EventProcessorHealth,\n    77→  kafka?: KafkaClient,\n    78→  onEventPublished?: () => void,\n    79→  triggerScheduler?: TriggerSchedulerHandle,\n    80→  getRetentionHealth?: () => RetentionHealth,\n    81→): http.Server {\n    82→\n    83→  /** Wrap a mutation handler to emit an audit event on successful response. */\n    84→  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    85→    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n    86→      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n    87→      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n    88→        try {\n    89→          auditLog.record({\n    90→            action,\n    91→            tenantId: ctx.projectId || 'default',\n    92→            actor: ctx.userEmail || ctx.projectId,\n    93→            resourceType,\n    94→            resourceId: route?.id,\n    95→            ipAddress: req.socket.remoteAddress,\n    96→          } as AuditEntry);\n    97→        } catch { /* logged inside record() */ }\n    98→      }\n    99→    };\n   100→  }\n   101→\n   102→  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n   103→  const exactRoutes = new Map<string, RouteEntry>();\n   104→\n   105→  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n   106→  for (const [path, method] of [\n   107→    ['/api/oauth/authorize', 'POST'],\n   108→    ['/api/oauth/callback', 'POST'],\n   109→    ['/api/oauth/status', 'GET'],\n   110→    ['/api/oauth/refresh', 'POST'],\n   111→    ['/api/oauth/disconnect', 'DELETE'],\n   112→    ['/api/token', 'POST'],\n   113→  ] as const) {\n   114→    exactRoutes.set(`${method}:${path}`, {\n   115→      adminOnly: true,\n   116→      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   117→        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger, auditLog);\n   118→      },\n   119→    });\n   120→  }\n   121→\n   122→  exactRoutes.set('GET:/api/status', {\n   123→    handler: (_req, res) => {\n   124→      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   125→    },\n   126→  });\n   127→\n   128→  exactRoutes.set('POST:/api/execute', {\n   129→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   130→      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n   131→    }, 'execution:submit', 'execution'),\n   132→  });\n   133→\n   134→  exactRoutes.set('POST:/api/gitlab/webhook', {\n   135→    needsDb: true,\n   136→    handler: withHttpAudit(async (req, res, _ctx, _route, _qs, tenantDb) => {\n   137→      const body = await readBody(req);\n   138→      let parsed: Record<string, unknown> = {};\n   139→      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   140→      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   141→      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   142→      const event = db.publishEvent(tenantDb!, {\n   143→        eventType: `gitlab_${objectKind}`,\n   144→        sourceType: 'gitlab',\n   145→        sourceId: projectPath ?? null,\n   146→        payload: body,\n   147→      });\n   148→      onEventPublished?.();\n   149→      json(res, 201, event);\n   150→    }, 'event:publish', 'event'),\n   151→  });\n   152→\n   153→  // Admin routes\n   154→  exactRoutes.set('GET:/api/admin/users', {\n   155→    adminOnly: true,\n   156→    handler: (_req, res) => {\n   157→      if (tenantDbManager) {\n   158→        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   159→      } else if (database) {\n   160→        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   161→      } else {\n   162→        json(res, 200, { projectIds: [] });\n   163→      }\n   164→    },\n   165→  });\n   166→\n   167→  exactRoutes.set('GET:/api/admin/personas', {\n   168→    adminOnly: true,\n   169→    handler: (_req, res) => {\n   170→      if (tenantDbManager) {\n   171→        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   172→        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   173→        json(res, 200, allPersonas);\n   174→      } else if (database) {\n   175→        json(res, 200, db.listPersonasSummary(database));\n   176→      } else {\n   177→        json(res, 200, []);\n   178→      }\n   179→    },\n   180→  });\n   181→\n   182→  exactRoutes.set('GET:/api/admin/executions', {\n   183→    adminOnly: true,\n   184→    handler: (_req, res, _ctx, _route, queryString) => {\n   185→      const params = new URLSearchParams(queryString || '');\n   186→      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   187→      if (tenantDbManager) {\n   188→        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   189→        tenantDbManager.forEachTenant((tDb) => {\n   190→          allExecs.push(...db.listExecutions(tDb, { limit }));\n   191→        });\n   192→        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   193→        json(res, 200, allExecs.slice(0, limit));\n   194→      } else if (database) {\n   195→        json(res, 200, db.listExecutions(database, {\n   196→          limit,\n   197→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   198→        }));\n   199→      } else {\n   200→        json(res, 200, []);\n   201→      }\n   202→    },\n   203→  });\n   204→\n   205→  exactRoutes.set('GET:/api/admin/audit', {\n   206→    adminOnly: true,\n   207→    handler: (_req, res, _ctx, _route, queryString) => {\n   208→      if (!auditLog) { json(res, 200, []); return; }\n   209→      const params = new URLSearchParams(queryString || '');\n   210→      json(res, 200, auditLog.query({\n   211→        tenantId: params.get('tenantId') ?? undefined,\n   212→        action: (params.get('action') ?? undefined) as AuditAction | undefined,\n   213→        since: params.get('since') ?? undefined,\n   214→        until: params.get('until') ?? undefined,\n   215→        actor: params.get('actor') ?? undefined,\n   216→        resourceType: params.get('resourceType') ?? undefined,\n   217→        resourceId: params.get('resourceId') ?? undefined,\n   218→        limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   219→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   220→      }));\n   221→    },\n   222→  });\n   223→\n   224→  exactRoutes.set('GET:/api/admin/audit/stats', {\n   225→    adminOnly: true,\n   226→    handler: (_req, res, _ctx, _route, queryString) => {\n   227→      if (!auditLog) { json(res, 200, { byAction: [], byTenant: [], topActors: [], trend: [] }); return; }\n   228→      const params = new URLSearchParams(queryString || '');\n   229→      const bucket = params.get('bucket') === 'hour' ? 'hour' : 'day';\n   230→      json(res, 200, auditLog.stats({\n   231→        tenantId: params.get('tenantId') ?? undefined,\n   232→        since: params.get('since') ?? undefined,\n   233→        until: params.get('until') ?? undefined,\n   234→        bucket,\n   235→      }));\n   236→    },\n   237→  });\n   238→\n   239→  exactRoutes.set('POST:/api/admin/audit/verify', {\n   240→    adminOnly: true,\n   241→    handler: async (req, res) => {\n   242→      if (!auditLog) { json(res, 200, { valid: true, verifiedCount: 0 }); return; }\n   243→      const body = await readBody(req);\n   244→      let opts: { since?: string; until?: string } | undefined;\n   245→      if (body) {\n   246→        try {\n   247→          const parsed = JSON.parse(body) as { since?: string; until?: string };\n   248→          if (parsed.since || parsed.until) opts = { since: parsed.since, until: parsed.until };\n   249→        } catch { /* empty body or non-JSON — verify entire chain */ }\n   250→      }\n   251→      json(res, 200, auditLog.verify(opts));\n   252→    },\n   253→  });\n   254→\n   255→  // ── Resource route table (O(1) lookup by `METHOD:resource[:id][:sub]`) ──\n   256→  const resourceRoutes = new Map<string, RouteEntry>();\n   257→\n   258→  // --- Persona CRUD ---\n   259→  resourceRoutes.set(resourceKey('GET', 'personas', false), {\n   260→    needsDb: true,\n   261→    handler: (_req, res, _ctx, _route, _qs, tenantDb, scopedProjectId) => {\n   262→      json(res, 200, db.listPersonasSummary(tenantDb!, scopedProjectId));\n   263→    },\n   264→  });\n   265→\n   266→  resourceRoutes.set(resourceKey('POST', 'personas', false), {\n   267→    needsDb: true,\n   268→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   269→      const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   270→      const persona = createPersonaWithDefaults({\n   271→        ...body,\n   272→        projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   273→      });\n   274→      db.upsertPersona(tenantDb!, persona);\n   275→      try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: persona.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   276→      reqLogger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   277→      json(res, 201, persona);\n   278→    },\n   279→  });\n   280→\n   281→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'tools'), {\n   282→    needsDb: true,\n   283→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   284→      json(res, 200, db.getToolsForPersona(tenantDb!, route!.id!));\n   285→    },\n   286→  });\n   287→\n   288→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'tools'), {\n   289→    needsDb: true,\n   290→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   291→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   292→      if (!persona) return;\n   293→      const body = JSON.parse(await readBody(req)) as { toolId: string };\n   294→      db.linkTool(tenantDb!, route!.id!, body.toolId);\n   295→      try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { toolId: body.toolId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   296→      reqLogger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route!.id!, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   297→      json(res, 200, { linked: true });\n   298→    },\n   299→  });\n   300→\n   301→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'full'), {\n   302→    needsDb: true,\n   303→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   304→      const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb!, route!.id!, reqLogger), scopedProjectId, res);\n   305→      if (!hydrated) return;\n   306→      json(res, 200, hydrated);\n   307→    },\n   308→  });\n   309→\n   310→  resourceRoutes.set(resourceKey('GET', 'personas', true), {\n   311→    needsDb: true,\n   312→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId) => {\n   313→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   314→      if (!persona) return;\n   315→      json(res, 200, persona);\n   316→    },\n   317→  });\n   318→\n   319→  resourceRoutes.set(resourceKey('DELETE', 'personas', true), {\n   320→    needsDb: true,\n   321→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   322→      db.deletePersona(tenantDb!, route!.id!, scopedProjectId);\n   323→      try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   324→      reqLogger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   325→      json(res, 200, { deleted: true });\n   326→    },\n   327→  });\n   328→\n   329→  // --- Persona sub-resources: credentials ---\n   330→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'credentials'), {\n   331→    needsDb: true,\n   332→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   333→      const creds = db.listCredentialsForPersona(tenantDb!, route!.id!);\n   334→      try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   335→      json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   336→    },\n   337→  });\n   338→\n   339→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'credentials'), {\n   340→    needsDb: true,\n   341→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   342→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   343→      if (!persona) return;\n   344→      const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   345→      db.linkCredential(tenantDb!, route!.id!, body.credentialId);\n   346→      try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { credentialId: body.credentialId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   347→      reqLogger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route!.id!, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   348→      json(res, 200, { linked: true });\n   349→    },\n   350→  });\n   351→\n   352→  // --- Persona sub-resources: subscriptions ---\n   353→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'subscriptions'), {\n   354→    needsDb: true,\n   355→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   356→      json(res, 200, db.listSubscriptionsForPersona(tenantDb!, route!.id!));\n   357→    },\n   358→  });\n   359→\n   360→  // --- Tool Definitions ---\n   361→  resourceRoutes.set(resourceKey('POST', 'tool-definitions', false), {\n   362→    needsDb: true,\n   363→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   364→      const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   365→      const tool = createToolDefinitionWithDefaults(body);\n   366→      db.upsertToolDefinition(tenantDb!, tool);\n   367→      try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'toolDefinition', resourceId: tool.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   368→      reqLogger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   369→      json(res, 201, tool);\n   370→    },\n   371→  });\n   372→\n   373→  // --- Credentials ---\n   374→  resourceRoutes.set(resourceKey('POST', 'credentials', false), {\n   375→    needsDb: true,\n   376→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   377→      const body = JSON.parse(await readBody(req));\n   378→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   379→\n   380→      if (!body.plaintext || typeof body.plaintext !== 'string') {\n   381→        json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   382→        return;\n   383→      }\n   384→      if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   385→        json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   386→        return;\n   387→      }\n   388→      if (!tenantKeyManager) {\n   389→        json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   390→        return;\n   391→      }\n   392→\n   393→      delete body.encryptedData;\n   394→      delete body.iv;\n   395→      delete body.tag;\n   396→\n   397→      const tenantId = body.projectId || ctx.projectId || 'default';\n   398→      const key = await tenantKeyManager.getKey(tenantId);\n   399→      const encrypted = encrypt(body.plaintext, key);\n   400→      body.encryptedData = encrypted.encrypted;\n   401→      body.iv = encrypted.iv;\n   402→      body.tag = encrypted.tag;\n   403→      delete body.plaintext;\n   404→\n   405→      const cred = db.createCredential(tenantDb!, body);\n   406→      try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: cred.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   407→      reqLogger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   408→      json(res, 201, cred);\n   409→    },\n   410→  });\n   411→\n   412→  resourceRoutes.set(resourceKey('DELETE', 'credentials', true), {\n   413→    needsDb: true,\n   414→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   415→      const changes = db.deleteCredential(tenantDb!, route!.id!, scopedProjectId);\n   416→      if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   417→      try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   418→      reqLogger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   419→      json(res, 200, { deleted: true });\n   420→    },\n   421→  });\n   422→\n   423→  // --- Event Subscriptions ---\n   424→  resourceRoutes.set(resourceKey('POST', 'subscriptions', false), {\n   425→    needsDb: true,\n   426→    handler: async (req, res, ctx, _route, _qs, tenantDb) => {\n   427→      const body = JSON.parse(await readBody(req));\n   428→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   429→      const missing: string[] = [];\n   430→      if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   431→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   432→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   433→      const sub = db.createSubscription(tenantDb!, body);\n   434→      try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: sub.id, detail: { personaId: body.personaId, eventType: body.eventType }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   435→      json(res, 201, sub);\n   436→    },\n   437→  });\n   438→\n   439→  resourceRoutes.set(resourceKey('PUT', 'subscriptions', true), {\n   440→    needsDb: true,\n   441→    handler: async (req, res, ctx, route, _qs, tenantDb) => {\n   442→      const body = JSON.parse(await readBody(req));\n   443→      db.updateSubscription(tenantDb!, route!.id!, body);\n   444→      const updated = db.getSubscription(tenantDb!, route!.id!);\n   445→      try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   446→      json(res, 200, updated);\n   447→    },\n   448→  });\n   449→\n   450→  resourceRoutes.set(resourceKey('DELETE', 'subscriptions', true), {\n   451→    needsDb: true,\n   452→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   453→      db.deleteSubscription(tenantDb!, route!.id!);\n   454→      try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   455→      json(res, 200, { deleted: true });\n   456→    },\n   457→  });\n   458→\n   459→  // --- Triggers (delegated to triggerHttpHandlers) ---\n   460→  const triggerHandler: RouteHandler = async (req, res, ctx, route, _qs, tenantDb) => {\n   461→    await handleTriggerRoute(route!, req.method!, req, res, tenantDb!, ctx, triggerScheduler);\n   462→  };\n   463→  resourceRoutes.set(resourceKey('POST', 'triggers', false), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:create', 'trigger') });\n   464→  resourceRoutes.set(resourceKey('PUT', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:update', 'trigger') });\n   465→  resourceRoutes.set(resourceKey('DELETE', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:delete', 'trigger') });\n   466→  resourceRoutes.set(resourceKey('GET', 'triggers', true, 'history'), { needsDb: true, handler: triggerHandler });\n   467→  resourceRoutes.set(resourceKey('GET', 'triggers', true, 'stats'), { needsDb: true, handler: triggerHandler });\n   468→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'triggers'), { needsDb: true, handler: triggerHandler });\n   469→\n   470→  // --- Events ---\n   471→  resourceRoutes.set(resourceKey('GET', 'events', false), {\n   472→    needsDb: true,\n   473→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   474→      const params = new URLSearchParams(queryString || '');\n   475→      const events = db.listEvents(tenantDb!, {\n   476→        eventType: params.get('eventType') ?? undefined,\n   477→        status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n   478→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   479→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   480→        projectId: scopedProjectId,\n   481→      });\n   482→      json(res, 200, events);\n   483→    },\n   484→  });\n   485→\n   486→  resourceRoutes.set(resourceKey('POST', 'events', false), {\n   487→    needsDb: true,\n   488→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, tenantDb) => {\n   489→      const body = JSON.parse(await readBody(req));\n   490→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   491→      const missing: string[] = [];\n   492→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   493→      if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   494→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   495→      const event = db.publishEvent(tenantDb!, body);\n   496→      onEventPublished?.();\n   497→      json(res, 201, event);\n   498→    }, 'event:publish', 'event'),\n   499→  });\n   500→\n   501→  resourceRoutes.set(resourceKey('PUT', 'events', true), {\n   502→    needsDb: true,\n   503→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   504→      const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n   505→      const updated = db.updateEventWithMetadata(tenantDb!, route!.id!, body.status, body.metadata);\n   506→      if (updated) {\n   507→        json(res, 200, updated);\n   508→      } else {\n   509→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   510→        res.end(JSON.stringify({ error: 'Event not found' }));\n   511→      }\n   512→    }, 'event:update', 'event'),\n   513→  });\n   514→\n   515→  // --- Webhooks ---\n   516→  resourceRoutes.set(resourceKey('POST', 'webhooks', true), {\n   517→    needsDb: true,\n   518→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   519→      const personaId = route!.id!;\n   520→      const body = await readBody(req);\n   521→      const event = db.publishEvent(tenantDb!, {\n   522→        eventType: 'webhook_received',\n   523→        sourceType: 'webhook',\n   524→        sourceId: personaId,\n   525→        targetPersonaId: personaId,\n   526→        payload: body,\n   527→      });\n   528→      onEventPublished?.();\n   529→      json(res, 201, event);\n   530→    }, 'webhook:receive', 'webhook'),\n   531→  });\n   532→\n   533→  // --- Executions ---\n   534→  resourceRoutes.set(resourceKey('GET', 'executions', false), {\n   535→    needsDb: true,\n   536→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   537→      const params = new URLSearchParams(queryString || '');\n   538→      const executions = db.listExecutions(tenantDb!, {\n   539→        personaId: params.get('personaId') ?? undefined,\n   540→        status: params.get('status') ?? undefined,\n   541→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   542→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   543→        projectId: scopedProjectId,\n   544→      });\n   545→      json(res, 200, executions);\n   546→    },\n   547→  });\n   548→\n   549→  resourceRoutes.set(resourceKey('POST', 'executions', true, 'cancel'), {\n   550→    handler: (_req, res, _ctx, route) => {\n   551→      handleCancelExecution(res, dispatcher, route!.id!);\n   552→    },\n   553→  });\n   554→\n   555→  resourceRoutes.set(resourceKey('GET', 'executions', true), {\n   556→    handler: (_req, res, _ctx, route, queryString) => {\n   557→      const params = new URLSearchParams(queryString || '');\n   558→      const offset = parseInt(params.get('offset') || '0', 10);\n   559→      handleGetExecution(res, dispatcher, route!.id!, offset);\n   560→    },\n   561→  });\n   562→\n   563→  // ── Request handler ──\n   564→  const server = http.createServer(async (req, res) => {\n   565→    // Request correlation ID\n   566→    const reqId = nanoid();\n   567→    const reqLogger = logger.child({ reqId });\n   568→    res.setHeader('X-Request-Id', reqId);\n   569→\n   570→    // Security headers\n   571→    res.setHeader('X-Content-Type-Options', 'nosniff');\n   572→\n   573→    // CORS headers\n   574→    const origin = req.headers.origin ?? '';\n   575→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n   576→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n   577→    if (isAdminRoute) {\n   578→      if (origin && origin === allowedOrigin) {\n   579→        res.setHeader('Access-Control-Allow-Origin', origin);\n   580→      }\n   581→    } else {\n   582→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n   583→    }\n   584→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n   585→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n   586→\n   587→    if (req.method === 'OPTIONS') {\n   588→      res.writeHead(204);\n   589→      res.end();\n   590→      return;\n   591→    }\n   592→\n   593→    const url = req.url || '/';\n   594→    const [pathname, queryString] = url.split('?');\n   595→    const route = parseRoute(pathname ?? '');\n   596→\n   597→    // Unauthenticated endpoint\n   598→    if (pathname === '/health' && req.method === 'GET') {\n   599→      await handleHealth(res, pool, dispatcher, tokenManager, oauth, getEventProcessorHealth, database, tenantDbManager, kafka, triggerScheduler, auditLog, getRetentionHealth);\n   600→      return;\n   601→    }\n   602→\n   603→    // Auth check\n   604→    const ctx = auth.validateAndExtractContext(req);\n   605→    if (!ctx) {\n   606→      res.writeHead(401, { 'Content-Type': 'application/json' });\n   607→      res.end(JSON.stringify({ error: 'Unauthorized', reqId }));\n   608→      return;\n   609→    }\n   610→\n   611→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n   612→\n   613→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n   614→      if (tenantDbManager && projectId) {\n   615→        return tenantDbManager.getTenantDb(projectId);\n   616→      }\n   617→      return database;\n   618→    };\n   619→    const tenantDb = resolveDatabase(ctx.projectId);\n   620→\n   621→    try {\n   622→      // O(1) exact-path lookup\n   623→      const exactEntry = exactRoutes.get(`${req.method}:${pathname}`);\n   624→      if (exactEntry) {\n   625→        if (exactEntry.adminOnly && requireAdmin(ctx, res)) return;\n   626→        if (exactEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   627→        await exactEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   628→        return;\n   629→      }\n   630→\n   631→      // O(1) resource-route lookup\n   632→      if (route) {\n   633→        const resKey = resourceKey(req.method!, route.resource, !!route.id, route.subResource);\n   634→        const resEntry = resourceRoutes.get(resKey);\n   635→        if (resEntry) {\n   636→          if (resEntry.adminOnly && requireAdmin(ctx, res)) return;\n   637→          if (resEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   638→          await resEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   639→          return;\n   640→        }\n   641→      }\n   642→\n   643→      // No matching route\n   644→      json(res, 404, { error: 'Not found', reqId });\n   645→    } catch (err) {\n   646→      if (err instanceof Error && err.message === 'Payload too large') {\n   647→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   648→        res.end(JSON.stringify({ error: 'Payload too large', reqId }));\n   649→        return;\n   650→      }\n   651→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   652→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   653→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists', reqId }));\n   654→        return;\n   655→      }\n   656→      reqLogger.error({ err, url }, 'HTTP handler error');\n   657→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   658→      res.end(JSON.stringify({ error: 'Internal server error', reqId }));\n   659→    }\n   660→  });\n   661→\n   662→  return server;\n   663→}\n   664→\n   665→/**\n   666→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   667→ * Returns the entity on success, or null after sending a 404 response.\n   668→ */\n   669→function withScopedEntity<T extends { projectId?: string | null }>(\n   670→  entity: T | undefined,\n   671→  scopedProjectId: string | undefined,\n   672→  res: http.ServerResponse,\n   673→): T | null {\n   674→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   675→    json(res, 404, { error: 'Not found' });\n   676→    return null;\n   677→  }\n   678→  return entity;\n   679→}\n   680→\n   681→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   682→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   683→  if (ctx.authType !== 'admin') {\n   684→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   685→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   686→    return true;\n   687→  }\n   688→  return false;\n   689→}\n   690→\n   691→// --- Existing handlers ---\n   692→\n   693→/** Heartbeat age (ms) beyond which a worker is considered stale. */\n   694→const STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n   695→\n   696→async function handleHealth(\n   697→  res: http.ServerResponse,\n   698→  pool: WorkerPool,\n   699→  dispatcher: Dispatcher,\n   700→  tokenManager: TokenManager,\n   701→  oauth: OAuthManager,\n   702→  getEventProcessorHealth?: () => EventProcessorHealth,\n   703→  database?: Database.Database,\n   704→  tenantDbManager?: TenantDbManager,\n   705→  kafka?: KafkaClient,\n   706→  triggerScheduler?: TriggerSchedulerHandle,\n   707→  auditLog?: AuditLog,\n   708→  getRetentionHealth?: () => RetentionHealth,\n   709→): Promise<void> {\n   710→  const issues: string[] = [];\n   711→\n   712→  const counts = pool.getWorkerCount();\n   713→  const workers = pool.getWorkers();\n   714→  const now = Date.now();\n   715→  const staleWorkers = workers\n   716→    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n   717→    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n   718→\n   719→  if (staleWorkers.length > 0) {\n   720→    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n   721→  }\n   722→\n   723→  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n   724→  if (database) {\n   725→    try {\n   726→      database.prepare('SELECT 1').get();\n   727→      dbHealth.status = 'ok';\n   728→    } catch {\n   729→      dbHealth.status = 'error';\n   730→      issues.push('database unreachable');\n   731→    }\n   732→  }\n   733→  if (tenantDbManager) {\n   734→    try {\n   735→      const tenantIds = tenantDbManager.listTenantIds();\n   736→      dbHealth.tenantCount = tenantIds.length;\n   737→      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n   738→    } catch {\n   739→      dbHealth.tenantCount = -1;\n   740→      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n   741→      issues.push('tenant DB listing failed');\n   742→    }\n   743→  }\n   744→\n   745→  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n   746→  if (kafka) {\n   747→    const kh = await kafka.checkHealth();\n   748→    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n   749→    if (kh.status === 'error') {\n   750→      issues.push(`kafka: ${kh.detail || 'error'}`);\n   751→    }\n   752→  }\n   753→\n   754→  const queueDepth = dispatcher.getQueueLength();\n   755→  const activeExecutions = dispatcher.getActiveExecutions().length;\n   756→\n   757→  let eventProcessorHealth: EventProcessorHealth | undefined;\n   758→  if (getEventProcessorHealth) {\n   759→    eventProcessorHealth = getEventProcessorHealth();\n   760→  }\n   761→\n   762→  const tokenHealth = tokenManager.getHealth();\n   763→  if (tokenHealth.consecutiveDecryptionFailures > 0) {\n   764→    issues.push(`token decryption failures: ${tokenHealth.consecutiveDecryptionFailures} consecutive`);\n   765→  }\n   766→\n   767→  let verdict: 'healthy' | 'degraded' | 'unhealthy';\n   768→  if (issues.some(i => i.includes('database unreachable') || i.includes('kafka: '))) {\n   769→    verdict = 'unhealthy';\n   770→  } else if (issues.length > 0) {\n   771→    verdict = 'degraded';\n   772→  } else {\n   773→    verdict = 'healthy';\n   774→  }\n   775→\n   776→  const body: Record<string, unknown> = {\n   777→    status: verdict,\n   778→    timestamp: Date.now(),\n   779→    dependencies: {\n   780→      database: dbHealth,\n   781→      kafka: kafkaHealth,\n   782→      workers: {\n   783→        ...counts,\n   784→        staleWorkers: staleWorkers.length > 0 ? staleWorkers : undefined,\n   785→      },\n   786→      token: tokenHealth,\n   787→    },\n   788→    queue: {\n   789→      depth: queueDepth,\n   790→      activeExecutions,\n   791→    },\n   792→    hasSubscription: oauth.hasTokens(),\n   793→    oauthFunnel: oauth.getFunnelMetrics(),\n   794→    oauthErrors: oauth.getErrorMetrics(),\n   795→  };\n   796→\n   797→  if (eventProcessorHealth) {\n   798→    (body.dependencies as Record<string, unknown>).eventProcessor = eventProcessorHealth;\n   799→  }\n   800→\n   801→  if (triggerScheduler) {\n   802→    (body.dependencies as Record<string, unknown>).scheduler = triggerScheduler.getMetrics();\n   803→  }\n   804→\n   805→  if (auditLog) {\n   806→    const auditHealth = auditLog.getHealth();\n   807→    (body.dependencies as Record<string, unknown>).audit = auditHealth;\n   808→    if (auditHealth.droppedEvents > 0) {\n   809→      issues.push(`audit: ${auditHealth.droppedEvents} dropped events`);\n   810→    }\n   811→  }\n   812→\n   813→  if (getRetentionHealth) {\n   814→    const retHealth = getRetentionHealth();\n   815→    (body.dependencies as Record<string, unknown>).retention = retHealth;\n   816→    if (retHealth.totalErrors > 0) {\n   817→      issues.push(`retention: ${retHealth.totalErrors} total errors`);\n   818→    }\n   819→  }\n   820→\n   821→  if (issues.length > 0) {\n   822→    body.issues = issues;\n   823→  }\n   824→\n   825→  const httpStatus = verdict === 'unhealthy' ? 503 : 200;\n   826→  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n   827→  res.end(JSON.stringify(body));\n   828→}\n   829→\n   830→function handleStatus(\n   831→  res: http.ServerResponse,\n   832→  pool: WorkerPool,\n   833→  dispatcher: Dispatcher,\n   834→  tokenManager: TokenManager,\n   835→  oauth: OAuthManager,\n   836→): void {\n   837→  const oauthTokens = oauth.getTokens();\n   838→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   839→  res.end(JSON.stringify({\n   840→    workers: pool.getWorkers(),\n   841→    workerCounts: pool.getWorkerCount(),\n   842→    workerPoolMetrics: pool.getMetrics(),\n   843→    queueLength: dispatcher.getQueueLength(),\n   844→    activeExecutions: dispatcher.getActiveExecutions(),\n   845→    hasClaudeToken: tokenManager.hasToken(),\n   846→    oauth: {\n   847→      connected: oauth.hasTokens(),\n   848→      scopes: oauthTokens?.scopes || [],\n   849→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   850→    },\n   851→  }));\n   852→}\n   853→\n   854→async function handleExecute(\n   855→  req: http.IncomingMessage,\n   856→  res: http.ServerResponse,\n   857→  dispatcher: Dispatcher,\n   858→  logger: Logger,\n   859→  ctx?: RequestContext,\n   860→): Promise<void> {\n   861→  const body = await readBody(req);\n   862→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   863→\n   864→  try {\n   865→    parsed = JSON.parse(body);\n   866→  } catch {\n   867→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   868→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   869→    return;\n   870→  }\n   871→\n   872→  if (!parsed.prompt) {\n   873→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   874→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   875→    return;\n   876→  }\n   877→\n   878→  const request: ExecRequest = {\n   879→    executionId: nanoid(),\n   880→    personaId: parsed.personaId || 'manual',\n   881→    prompt: parsed.prompt,\n   882→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   883→    config: {\n   884→      timeoutMs: parsed.timeoutMs || 300_000,\n   885→    },\n   886→  };\n   887→\n   888→  const result: SubmitResult = dispatcher.submit(request);\n   889→\n   890→  if (!result.accepted) {\n   891→    logger.warn({ executionId: request.executionId, reason: result.reason }, 'Execution rejected by backpressure');\n   892→    res.writeHead(429, {\n   893→      'Content-Type': 'application/json',\n   894→      'Retry-After': String(result.retryAfterSeconds),\n   895→    });\n   896→    res.end(JSON.stringify({\n   897→      error: result.reason === 'tenant_quota_exceeded'\n   898→        ? 'Per-tenant queue quota exceeded'\n   899→        : 'Queue depth limit exceeded',\n   900→      retryAfterSeconds: result.retryAfterSeconds,\n   901→    }));\n   902→    return;\n   903→  }\n   904→\n   905→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   906→\n   907→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   908→  res.end(JSON.stringify({\n   909→    executionId: request.executionId,\n   910→    status: 'queued',\n   911→  }));\n   912→}\n   913→\n   914→function handleGetExecution(\n   915→  res: http.ServerResponse,\n   916→  dispatcher: Dispatcher,\n   917→  executionId: string,\n   918→  offset: number = 0,\n   919→): void {\n   920→  const exec = dispatcher.getExecution(executionId);\n   921→\n   922→  if (!exec) {\n   923→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   924→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   925→    return;\n   926→  }\n   927→\n   928→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   929→\n   930→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   931→  res.end(JSON.stringify({\n   932→    executionId,\n   933→    status: exec.status,\n   934→    outputLines: exec.output.length,\n   935→    output,\n   936→    durationMs: exec.durationMs,\n   937→    sessionId: exec.sessionId,\n   938→    totalCostUsd: exec.totalCostUsd,\n   939→    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n   940→  }));\n   941→}\n   942→\n   943→function handleCancelExecution(\n   944→  res: http.ServerResponse,\n   945→  dispatcher: Dispatcher,\n   946→  executionId: string,\n   947→): void {\n   948→  const cancelled = dispatcher.cancelExecution(executionId);\n   949→\n   950→  if (!cancelled) {\n   951→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   952→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   953→    return;\n   954→  }\n   955→\n   956→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   957→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   958→}\n   959→\n   960→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB\n   961→const MAX_QUERY_LIMIT = 500;\n   962→const MAX_QUERY_OFFSET = 100_000;\n   963→\n   964→/** Parse an integer query param and clamp it to safe bounds. */\n   965→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   966→  if (!value) return defaultValue;\n   967→  const parsed = parseInt(value, 10);\n   968→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   969→  return Math.min(parsed, max);\n   970→}\n   971→"}]},"parent_tool_use_id":null,"session_id":"672c8d83-f2b4-483b-892e-4cc58ad691ed","uuid":"6786582a-9e77-4a6d-ba5b-7538740ab6dc","timestamp":"2026-03-19T08:35:15.361Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher, SubmitResult } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TriggerSchedulerHandle } from './triggerScheduler.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog, AuditEntry, AuditAction, AuditLogHealth } from './auditLog.js';\nimport type { EventProcessorHealth } from './eventProcessor.js';\nimport type { RetentionHealth } from './retention.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\n// --- Route types ---\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\ntype RouteHandler = (\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  ctx: RequestContext,\n  route: ParsedRoute | null,\n  queryString: string | undefined,\n  tenantDb: Database.Database | undefined,\n  scopedProjectId: string | undefined,\n  reqLogger: Logger,\n) => Promise<void> | void;\n\ninterface RouteEntry {\n  handler: RouteHandler;\n  needsDb?: boolean;\n  adminOnly?: boolean;\n}\n\n/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\nfunction resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  kafka?: KafkaClient,\n  onEventPublished?: () => void,\n  triggerScheduler?: TriggerSchedulerHandle,\n  getRetentionHealth?: () => RetentionHealth,\n): http.Server {\n\n  /** Wrap a mutation handler to emit an audit event on successful response. */\n  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n        try {\n          auditLog.record({\n            action,\n            tenantId: ctx.projectId || 'default',\n            actor: ctx.userEmail || ctx.projectId,\n            resourceType,\n            resourceId: route?.id,\n            ipAddress: req.socket.remoteAddress,\n          } as AuditEntry);\n        } catch { /* logged inside record() */ }\n      }\n    };\n  }\n\n  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n  const exactRoutes = new Map<string, RouteEntry>();\n\n  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n  for (const [path, method] of [\n    ['/api/oauth/authorize', 'POST'],\n    ['/api/oauth/callback', 'POST'],\n    ['/api/oauth/status', 'GET'],\n    ['/api/oauth/refresh', 'POST'],\n    ['/api/oauth/disconnect', 'DELETE'],\n    ['/api/token', 'POST'],\n  ] as const) {\n    exactRoutes.set(`${method}:${path}`, {\n      adminOnly: true,\n      handler: async (req, res, _ctx, 