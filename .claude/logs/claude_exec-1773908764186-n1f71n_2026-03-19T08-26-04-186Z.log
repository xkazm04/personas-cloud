[2026-03-19T08:27:48.396Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QNLFKaQxVX9szbAXA9MX4a","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import * as db from './db/index.js';\n     4→import { TriggerHeap, type HeapEntry } from './triggerHeap.js';\n     5→import type { TenantDbManager } from './tenantDbManager.js';\n     6→\n     7→const MIN_DELAY_MS = 100;\n     8→const MAX_DELAY_MS = 60_000;\n     9→const HEARTBEAT_INTERVAL_MS = 60_000;\n    10→\n    11→export interface SchedulerMetrics {\n    12→  heap_size: number;\n    13→  next_due_at: string | null;\n    14→  triggers_fired_total: number;\n    15→  triggers_missed_total: number;\n    16→  avg_tick_latency_ms: number;\n    17→  last_tick_at: string | null;\n    18→}\n    19→\n    20→export interface TriggerSchedulerHandle {\n    21→  /** Stop the scheduler. */\n    22→  close(): void;\n    23→  /** Nudge the scheduler to re-evaluate immediately (e.g. after trigger create/update). */\n    24→  nudge(): void;\n    25→  /** Push or update a trigger in the heap after CRUD. */\n    26→  heapPush(triggerId: string, tenantId: string, nextTriggerAt: string | null): void;\n    27→  /** Remove a trigger from the heap (e.g. after delete or disable). */\n    28→  heapRemove(triggerId: string): void;\n    29→  /** Return current scheduler metrics for observability. */\n    30→  getMetrics(): SchedulerMetrics;\n    31→}\n    32→\n    33→/**\n    34→ * Start the heap-driven trigger scheduler.\n    35→ *\n    36→ * On startup the scheduler loads all enabled triggers from the DB into an\n    37→ * in-memory min-heap keyed by next_trigger_at.  On each tick it pops entries\n    38→ * whose time has passed, fires them, and pushes the updated next-fire times\n    39→ * back into the heap.  The DB remains the source of truth — the heap is a\n    40→ * hot-path cache that eliminates full table scans.\n    41→ */\n    42→export function startTriggerScheduler(\n    43→  database: Database.Database | null,\n    44→  logger: Logger,\n    45→  _interval?: number, // kept for signature compat; ignored\n    46→  tenantDbManager?: TenantDbManager,\n    47→  onEventPublished?: () => void,\n    48→): TriggerSchedulerHandle {\n    49→  let timer: ReturnType<typeof setTimeout> | null = null;\n    50→  let heartbeatTimer: ReturnType<typeof setInterval> | null = null;\n    51→  let stopped = false;\n    52→  const heap = new TriggerHeap();\n    53→\n    54→  // ---- Metrics accumulators ----\n    55→  let triggersFiredTotal = 0;\n    56→  let triggersMissedTotal = 0;\n    57→  let tickCount = 0;\n    58→  let tickLatencySum = 0;\n    59→  let lastTickAt: number | null = null;\n    60→  /** Per-tick missed counts since last heartbeat, for correlation. */\n    61→  let tickMissedCounts: number[] = [];\n    62→\n    63→  // ---- Heap bootstrap: load all enabled triggers from DB ----\n    64→  const bootstrap = buildHeap(heap, database, tenantDbManager, logger);\n    65→\n    66→  logger.info(\n    67→    { heapSize: heap.size, minDelayMs: MIN_DELAY_MS, maxDelayMs: MAX_DELAY_MS, tenantIsolated: !!tenantDbManager, bootstrapDurationMs: bootstrap.totalDurationMs },\n    68→    'Heap-driven trigger scheduler started',\n    69→  );\n    70→\n    71→  function scheduleTick(delayMs: number): void {\n    72→    if (stopped) return;\n    73→    timer = setTimeout(tick, delayMs);\n    74→  }\n    75→\n    76→  function tick(): void {\n    77→    if (stopped) return;\n    78→    const tickStart = Date.now();\n    79→    try {\n    80→      const now = tickStart;\n    81→      const due = heap.popDue(now);\n    82→\n    83→      if (due.length > 0) {\n    84→        const result = fireDueEntries(due, now, database, tenantDbManager, heap, logger, onEventPublished);\n    85→        triggersFiredTotal += result.fired;\n    86→        triggersMissedTotal += result.missed;\n    87→        if (result.missed > 0) {\n    88→          tickMissedCounts.push(result.missed);\n    89→        }\n    90→      }\n    91→    } catch (err) {\n    92→      logger.error({ err }, 'Trigger scheduler tick failed');\n    93→    }\n    94→\n    95→    // Track tick latency\n    96→    const tickEnd = Date.now();\n    97→    tickCount++;\n    98→    tickLatencySum += tickEnd - tickStart;\n    99→    lastTickAt = tickEnd;\n   100→\n   101→    // Schedule next tick based on heap peek\n   102→    const delayMs = computeNextDelay(heap);\n   103→    scheduleTick(delayMs);\n   104→  }\n   105→\n   106→  // Kick off the first tick immediately\n   107→  scheduleTick(0);\n   108→\n   109→  // ---- Heartbeat log every 60 seconds ----\n   110→  heartbeatTimer = setInterval(() => {\n   111→    if (stopped) return;\n   112→    const top = heap.peek();\n   113→    const missedSinceLastHeartbeat = tickMissedCounts.reduce((a, b) => a + b, 0);\n   114→    logger.info({\n   115→      heap_size: heap.size,\n   116→      next_due_at: top ? new Date(top.nextTriggerAt).toISOString() : null,\n   117→      triggers_fired_total: triggersFiredTotal,\n   118→      triggers_missed_total: triggersMissedTotal,\n   119→      triggers_missed_since_last_heartbeat: missedSinceLastHeartbeat,\n   120→      missed_per_tick: tickMissedCounts.length > 0 ? tickMissedCounts : undefined,\n   121→      avg_tick_latency_ms: tickCount > 0 ? Math.round(tickLatencySum / tickCount * 100) / 100 : 0,\n   122→      last_tick_at: lastTickAt ? new Date(lastTickAt).toISOString() : null,\n   123→    }, 'Scheduler heartbeat');\n   124→    tickMissedCounts = [];\n   125→  }, HEARTBEAT_INTERVAL_MS);\n   126→\n   127→  return {\n   128→    close() {\n   129→      stopped = true;\n   130→      if (timer != null) {\n   131→        clearTimeout(timer);\n   132→        timer = null;\n   133→      }\n   134→      if (heartbeatTimer != null) {\n   135→        clearInterval(heartbeatTimer);\n   136→        heartbeatTimer = null;\n   137→      }\n   138→    },\n   139→    nudge() {\n   140→      if (stopped) return;\n   141→      if (timer != null) {\n   142→        clearTimeout(timer);\n   143→        timer = null;\n   144→      }\n   145→      scheduleTick(0);\n   146→    },\n   147→    heapPush(triggerId: string, tenantId: string, nextTriggerAt: string | null) {\n   148→      if (!nextTriggerAt) {\n   149→        heap.remove(triggerId);\n   150→        return;\n   151→      }\n   152→      heap.push({ triggerId, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });\n   153→    },\n   154→    heapRemove(triggerId: string) {\n   155→      heap.remove(triggerId);\n   156→    },\n   157→    getMetrics(): SchedulerMetrics {\n   158→      const top = heap.peek();\n   159→      return {\n   160→        heap_size: heap.size,\n   161→        next_due_at: top ? new Date(top.nextTriggerAt).toISOString() : null,\n   162→        triggers_fired_total: triggersFiredTotal,\n   163→        triggers_missed_total: triggersMissedTotal,\n   164→        avg_tick_latency_ms: tickCount > 0 ? Math.round(tickLatencySum / tickCount * 100) / 100 : 0,\n   165→        last_tick_at: lastTickAt ? new Date(lastTickAt).toISOString() : null,\n   166→      };\n   167→    },\n   168→  };\n   169→}\n   170→\n   171→// ---------------------------------------------------------------------------\n   172→// Heap bootstrap — load all enabled triggers from every tenant DB\n   173→// ---------------------------------------------------------------------------\n   174→\n   175→interface BootstrapSummary {\n   176→  totalDurationMs: number;\n   177→  tenantCount: number;\n   178→  triggerCount: number;\n   179→  failedTenants: number;\n   180→}\n   181→\n   182→function buildHeap(\n   183→  heap: TriggerHeap,\n   184→  database: Database.Database | null,\n   185→  tenantDbManager: TenantDbManager | undefined,\n   186→  logger: Logger,\n   187→): BootstrapSummary {\n   188→  const startMs = Date.now();\n   189→  heap.clear();\n   190→\n   191→  let tenantCount = 0;\n   192→  let triggerCount = 0;\n   193→  let failedTenants = 0;\n   194→\n   195→  if (tenantDbManager) {\n   196→    const tenantIds = tenantDbManager.listTenantIds();\n   197→    for (const tenantId of tenantIds) {\n   198→      tenantCount++;\n   199→      const heapSizeBefore = heap.size;\n   200→      try {\n   201→        const tenantDb = tenantDbManager.getTenantDb(tenantId);\n   202→        const loaded = loadDbIntoHeap(heap, tenantDb, tenantId);\n   203→        triggerCount += loaded;\n   204→        logger.debug({ tenantId, triggerCount: loaded }, 'Loaded tenant triggers into heap');\n   205→      } catch (err) {\n   206→        const loadedBeforeFailure = heap.size - heapSizeBefore;\n   207→        failedTenants++;\n   208→        logger.error({ err, tenantId, triggersLoadedBeforeFailure: loadedBeforeFailure }, 'Failed to load triggers for tenant into heap');\n   209→      }\n   210→    }\n   211→  } else if (database) {\n   212→    tenantCount = 1;\n   213→    const loaded = loadDbIntoHeap(heap, database, 'default');\n   214→    triggerCount += loaded;\n   215→  }\n   216→\n   217→  const totalDurationMs = Date.now() - startMs;\n   218→  const summary: BootstrapSummary = { totalDurationMs, tenantCount, triggerCount, failedTenants };\n   219→  logger.info(summary, 'Heap bootstrap complete');\n   220→  return summary;\n   221→}\n   222→\n   223→function loadDbIntoHeap(heap: TriggerHeap, dbConn: Database.Database, tenantId: string): number {\n   224→  const rows = db.loadEnabledTriggerTimes(dbConn);\n   225→  for (const row of rows) {\n   226→    heap.push({\n   227→      triggerId: row.id,\n   228→      tenantId,\n   229→      nextTriggerAt: new Date(row.nextTriggerAt).getTime(),\n   230→    });\n   231→  }\n   232→  return rows.length;\n   233→}\n   234→\n   235→// ---------------------------------------------------------------------------\n   236→// Compute next delay from the heap (O(1) peek)\n   237→// ---------------------------------------------------------------------------\n   238→\n   239→function computeNextDelay(heap: TriggerHeap): number {\n   240→  const top = heap.peek();\n   241→  if (!top) return MAX_DELAY_MS;\n   242→  const deltaMs = top.nextTriggerAt - Date.now();\n   243→  return Math.min(MAX_DELAY_MS, Math.max(MIN_DELAY_MS, deltaMs));\n   244→}\n   245→\n   246→// ---------------------------------------------------------------------------\n   247→// Fire due triggers — batch-fetch from DB by ID, then process\n   248→// ---------------------------------------------------------------------------\n   249→\n   250→function fireDueEntries(\n   251→  due: HeapEntry[],\n   252→  tickNow: number,\n   253→  database: Database.Database | null,\n   254→  tenantDbManager: TenantDbManager | undefined,\n   255→  heap: TriggerHeap,\n   256→  logger: Logger,\n   257→  onEventPublished?: () => void,\n   258→): { fired: number; missed: number } {\n   259→  let firedCount = 0;\n   260→  let missedCount = 0;\n   261→\n   262→  // Build latency lookup from heap entries for missed-trigger detection\n   263→  const scheduledAtByTriggerId = new Map<string, number>();\n   264→  for (const entry of due) {\n   265→    scheduledAtByTriggerId.set(entry.triggerId, entry.nextTriggerAt);\n   266→  }\n   267→\n   268→  // Group by tenantId so we hit each DB once with a batch query\n   269→  const byTenant = new Map<string, HeapEntry[]>();\n   270→  for (const entry of due) {\n   271→    let list = byTenant.get(entry.tenantId);\n   272→    if (!list) {\n   273→      list = [];\n   274→      byTenant.set(entry.tenantId, list);\n   275→    }\n   276→    list.push(entry);\n   277→  }\n   278→\n   279→  for (const [tenantId, entries] of byTenant) {\n   280→    try {\n   281→      const tenantDb = tenantDbManager\n   282→        ? tenantDbManager.getTenantDb(tenantId)\n   283→        : database;\n   284→      if (!tenantDb) continue;\n   285→\n   286→      const ids = entries.map(e => e.triggerId);\n   287→      const triggers = db.getTriggersByIdsWithPersona(tenantDb, ids);\n   288→\n   289→      for (const trigger of triggers) {\n   290→        // Skip polling triggers\n   291→        if (trigger.triggerType === 'polling') continue;\n   292→\n   293→        // Detect missed trigger (due more than 60 s ago) and log with full context\n   294→        const scheduledAt = scheduledAtByTriggerId.get(trigger.id);\n   295→        if (scheduledAt !== undefined) {\n   296→          const latencyMs = tickNow - scheduledAt;\n   297→          if (latencyMs > MAX_DELAY_MS) {\n   298→            missedCount++;\n   299→            logger.warn({\n   300→              triggerId: trigger.id,\n   301→              tenantId,\n   302→              personaId: trigger.personaId,\n   303→              scheduledAt: new Date(scheduledAt).toISOString(),\n   304→              latencyMs,\n   305→            }, 'Missed trigger: fired late');\n   306→          }\n   307→        }\n   308→\n   309→        try {\n   310→          const parsedConfig = trigger.parsedConfig;\n   311→          let eventType = 'trigger_fired';\n   312→          let payload: string | null = null;\n   313→          if (parsedConfig) {\n   314→            if (parsedConfig.event_type) eventType = parsedConfig.event_type;\n   315→            if (parsedConfig.payload) payload = JSON.stringify(parsedConfig.payload);\n   316→          }\n   317→\n   318→          // Skip triggers for deleted or disabled personas\n   319→          if (trigger.personaProjectId == null) {\n   320→            logger.warn({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona not found (deleted?)');\n   321→            continue;\n   322→          }\n   323→          if (!trigger.personaEnabled) {\n   324→            logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');\n   325→            continue;\n   326→          }\n   327→\n   328→          const triggerProjectId = tenantId !== 'default' ? tenantId : trigger.personaProjectId;\n   329→\n   330→          // Publish event\n   331→          const publishedEvent = db.publishEvent(tenantDb, {\n   332→            eventType,\n   333→            sourceType: 'trigger',\n   334→            sourceId: trigger.id,\n   335→            targetPersonaId: trigger.personaId,\n   336→            projectId: triggerProjectId,\n   337→            useCaseId: trigger.useCaseId,\n   338→            payload,\n   339→          });\n   340→          onEventPublished?.();\n   341→\n   342→          // Record fire history\n   343→          db.recordTriggerFire(tenantDb, {\n   344→            triggerId: trigger.id,\n   345→            eventId: publishedEvent.id,\n   346→          });\n   347→\n   348→          // Compute next trigger time and update DB\n   349→          const now = new Date().toISOString();\n   350→          const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);\n   351→          db.updateTriggerTimings(tenantDb, trigger.id, now, nextTriggerAt);\n   352→\n   353→          // Push updated time back into heap\n   354→          if (nextTriggerAt) {\n   355→            heap.push({ triggerId: trigger.id, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });\n   356→          }\n   357→\n   358→          logger.info({\n   359→            triggerId: trigger.id,\n   360→            personaId: trigger.personaId,\n   361→            eventType,\n   362→            nextTriggerAt,\n   363→          }, 'Trigger fired');\n   364→          firedCount++;\n   365→        } catch (err) {\n   366→          logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');\n   367→        }\n   368→      }\n   369→    } catch (err) {\n   370→      logger.error({ err, tenantId }, 'Trigger scheduler tick failed for tenant');\n   371→    }\n   372→  }\n   373→  return { fired: firedCount, missed: missedCount };\n   374→}\n   375→"}]},"parent_tool_use_id":null,"session_id":"acbf59a6-3c18-480d-91c4-4e98855ebd2f","uuid":"07f5f67e-381e-4cae-a23b-78e4a1427a56","timestamp":"2026-03-19T08:27:47.954Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\triggerScheduler.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { TriggerHeap, type HeapEntry } from './triggerHeap.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\n\nconst MIN_DELAY_MS = 100;\nconst MAX_DELAY_MS = 60_000;\nconst HEARTBEAT_INTERVAL_MS = 60_000;\n\nexport interface SchedulerMetrics {\n  heap_size: number;\n  next_due_at: string | null;\n  triggers_fired_total: number;\n  triggers_missed_total: number;\n  avg_tick_latency_ms: number;\n  last_tick_at: string | null;\n}\n\nexport interface TriggerSchedulerHandle {\n  /** Stop the scheduler. */\n  close(): void;\n  /** Nudge the scheduler to re-evaluate immediately (e.g. after trigger create/update). */\n  nudge(): void;\n  /** Push or update a trigger in the heap after CRUD. */\n  heapPush(triggerId: string, tenantId: string, nextTriggerAt: string | null): void;\n  /** Remove a trigger from the heap (e.g. after delete or disable). */\n  heapRemove(triggerId: string): void;\n  /** Return current scheduler metrics for observability. */\n  getMetrics(): SchedulerMetrics;\n}\n\n/**\n * Start the heap-driven trigger scheduler.\n *\n * On startup the scheduler loads all enabled triggers from the DB into an\n * in-memory min-heap keyed by next_trigger_at.  On each tick it pops entries\n * whose time has passed, fires them, and pushes the updated next-fire times\n * back into the heap.  The DB remains the source of truth — the heap is a\n * hot-path cache that eliminates full table scans.\n */\nexport function startTriggerScheduler(\n  database: Database.Database | null,\n  logger: Logger,\n  _interval?: number, // kept for signature compat; ignored\n  tenantDbManager?: TenantDbManager,\n  onEventPublished?: () => void,\n): TriggerSchedulerHandle {\n  let timer: ReturnType<typeof setTimeout> | null = null;\n  let heartbeatTimer: ReturnType<typeof setInterval> | null = null;\n  let stopped = false;\n  const heap = new TriggerHeap();\n\n  // ---- Metrics accumulators ----\n  let triggersFiredTotal = 0;\n  let triggersMissedTotal = 0;\n  let tickCount = 0;\n  let tickLatencySum = 0;\n  let lastTickAt: number | null = null;\n  /** Per-tick missed counts since last heartbeat, for correlation. */\n  let tickMissedCounts: number[] = [];\n\n  // ---- Heap bootstrap: load all enabled triggers from DB ----\n  const bootstrap = buildHeap(heap, database, tenantDbManager, logger);\n\n  logger.info(\n    { heapSize: heap.size, minDelayMs: MIN_DELAY_MS, maxDelayMs: MAX_DELAY_MS, tenantIsolated: !!tenantDbManager, bootstrapDurationMs: bootstrap.totalDurationMs },\n    'Heap-driven trigger scheduler started',\n  );\n\n  function scheduleTick(delayMs: number): void {\n    if (stopped) return;\n    timer = setTimeout(tick, delayMs);\n  }\n\n  function tick(): void {\n    if (stopped) return;\n    const tickStart = Date.now();\n    try {\n      const now = tickStart;\n      const due = heap.popDue(now);\n\n      if (due.length > 0) {\n        const result = fireDueEntries(due, now, database, tenantDbManager, heap, logger, onEventPublished);\n        triggersFiredTotal += result.fired;\n        triggersMissedTotal += result.missed;\n        if (result.missed > 0) {\n          tickMissedCounts.push(result.missed);\n        }\n      }\n    } catch (err) {\n      logger.error({ err }, 'Trigger scheduler tick failed');\n    }\n\n    // Track tick latency\n    const tickEnd = Date.now();\n    tickCount++;\n    tickLatencySum += tickEnd - tickStart;\n    lastTickAt = tickEnd;\n\n    // Schedule next tick based on heap peek\n    const delayMs = computeNextDelay(heap);\n    scheduleTick(delayMs);\n  }\n\n  // Kick off the first tick immediately\n  scheduleTick(0);\n\n  // ---- Heartbeat log every 60 seconds ----\n  heartbeatTimer = setInterval(() => {\n    if (stopped) return;\n    const top = heap.peek();\n    const missedSinceLastHeartbeat = tickMissedCounts.reduce((a, b) => a + b, 0);\n    logger.info({\n      heap_size: heap.size,\n      next_due_at: top ? new Date(top.nextTriggerAt).toISOString() : null,\n      triggers_fired_total: triggersFiredTotal,\n      triggers_missed_total: triggersMissedTotal,\n      triggers_missed_since_last_heartbeat: missedSinceLastHeartbeat,\n      missed_per_tick: tickMissedCounts.length > 0 ? tickMissedCounts : undefined,\n      avg_tick_latency_ms: tickCount > 0 ? Math.round(tickLatencySum / tickCount * 100) / 100 : 0,\n      last_tick_at: lastTickAt ? new Date(lastTickAt).toISOString() : null,\n    }, 'Scheduler heartbeat');\n    tickMissedCounts = [];\n  }, HEARTBEAT_INTERVAL_MS);\n\n  return {\n    close() {\n      stopped = true;\n      if (timer != null) {\n        clearTimeout(timer);\n        timer = null;\n      }\n      if (heartbeatTimer != null) {\n        clearInterval(heartbeatTimer);\n        heartbeatTimer = null;\n      }\n    },\n    nudge() {\n      if (stopped) return;\n      if (timer != null) {\n        clearTimeout(timer);\n        timer = null;\n      }\n      scheduleTick(0);\n    },\n    heapPush(triggerId: string, tenantId: string, nextTriggerAt: string | null) {\n      if (!nextTriggerAt) {\n        heap.remove(triggerId);\n        return;\n      }\n      heap.push({ triggerId, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });\n    },\n    heapRemove(triggerId: string) {\n      heap.remove(triggerId);\n    },\n    getMetrics(): SchedulerMetrics {\n      const top = heap.peek();\n      return {\n        heap_size: heap.size,\n        next_due_at: top ? new Date(top.nextTriggerAt).toISOString() : null,\n        triggers_fired_total: triggersFiredTotal,\n        triggers_missed_total: triggersMissedTotal,\n        avg_tick_latency_ms: tickCount > 0 ? Math.round(tickLatencySum / tickCount * 100) / 100 : 0,\n        last_tick_at: lastTickAt ? new Date(lastTickAt).toISOString() : null,\n      };\n    },\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Heap bootstrap — load all enabled triggers from every tenant DB\n// ---------------------------------------------------------------------------\n\ninterface BootstrapSummary {\n  totalDurationMs: number;\n  tenantCount: number;\n  triggerCount: number;\n  failedTenants: number;\n}\n\nfunction buildHeap(\n  heap: TriggerHeap,\n  database: Database.Database | null,\n  tenantDbManager: TenantDbManager | undefined,\n  logger: Logger,\n): BootstrapSummary {\n  const startMs = Date.now();\n  heap.clear();\n\n  let tenantCount = 0;\n  let triggerCount = 0;\n  let failedTenants = 0;\n\n  if (tenantDbManager) {\n    const tenantIds = tenantDbManager.listTenantIds();\n    for (const tenantId of tenantIds) {\n      tenantCount++;\n      const heapSizeBefore = heap.size;\n      try {\n        const tenantDb = tenantDbManager.getTenantDb(tenantId);\n        const loaded = loadDbIntoHeap(heap, tenantDb, tenantId);\n        triggerCount += loaded;\n        logger.debug({ tenantId, triggerCount: loaded }, 'Loaded tenant triggers into heap');\n      } catch (err) {\n        const loadedBeforeFailure = heap.size - heapSizeBefore;\n        failedTenants++;\n        logger.error({ err, tenantId, triggersLoadedBeforeFailure: loadedBeforeFailure }, 'Failed to load triggers for tenant into heap');\n      }\n    }\n  } else if (database) {\n    tenantCount = 1;\n    const loaded = loadDbIntoHeap(heap, database, 'default');\n    triggerCount += loaded;\n  }\n\n  const totalDurationMs = Date.now() - startMs;\n  const summary: BootstrapSummary = { totalDurationMs, tenantCount, triggerCount, failedTenants };\n  logger.info(summary, 'Heap bootstrap complete');\n  return summary;\n}\n\nfunction loadDbIntoHeap(heap: TriggerHeap, dbConn: Database.Database, tenantId: string): number {\n  const rows = db.loadEnabledTriggerTimes(dbConn);\n  for (const row of rows) {\n    heap.push({\n      triggerId: row.id,\n      tenantId,\n      nextTriggerAt: new Date(row.nextTriggerAt).getTime(),\n    });\n  }\n  return rows.length;\n}\n\n// ---------------------------------------------------------------------------\n// Compute next delay from the heap (O(1) peek)\n// ---------------------------------------------------------------------------\n\nfunction computeNextDelay(heap: TriggerHeap): number {\n  const top = heap.peek();\n  if (!top) return MAX_DELAY_MS;\n  const deltaMs = top.nextTriggerAt - Date.now();\n  return Math.min(MAX_DELAY_MS, Math.max(MIN_DELAY_MS, deltaMs));\n}\n\n// ---------------------------------------------------------------------------\n// Fire due triggers — batch-fetch from DB by ID, then process\n// ---------------------------------------------------------------------------\n\nfunction fireDueEntries(\n  due: HeapEntry[],\n  tickNow: number,\n  database: Database.Database | null,\n  tenantDbManager: TenantDbManager | undefined,\n  heap: TriggerHeap,\n  logger: Logger,\n  onEventPublished?: () => void,\n): { fired: number; missed: number } {\n  let firedCount = 0;\n  let missedCount = 0;\n\n  // Build latency lookup from heap entries for missed-trigger detection\n  const scheduledAtByTriggerId = new Map<string, number>();\n  for (const entry of due) {\n    scheduledAtByTriggerId.set(entry.triggerId, entry.nextTriggerAt);\n  }\n\n  // Group by tenantId so we hit each DB once with a batch query\n  const byTenant = new Map<string, HeapEntry[]>();\n  for (const entry of due) {\n    let list = byTenant.get(entry.tenantId);\n    if (!list) {\n      list = [];\n      byTenant.set(entry.tenantId, list);\n    }\n    list.push(entry);\n  }\n\n  for (const [tenantId, entries] of byTenant) {\n    try {\n      const tenantDb = tenantDbManager\n        ? tenantDbManager.getTenantDb(tenantId)\n        : database;\n      if (!tenantDb) continue;\n\n      const ids = entries.map(e => e.triggerId);\n      const triggers = db.getTriggersByIdsWithPersona(tenantDb, ids);\n\n      for (const trigger of triggers) {\n        // Skip polling triggers\n        if (trigger.triggerType === 'polling') continue;\n\n        // Detect missed trigger (due more than 60 s ago) and log with full context\n        const scheduledAt = scheduledAtByTriggerId.get(trigger.id);\n        if (scheduledAt !== undefined) {\n          const latencyMs = tickNow - scheduledAt;\n          if (latencyMs > MAX_DELAY_MS) {\n            missedCount++;\n            logger.warn({\n              triggerId: trigger.id,\n              tenantId,\n              personaId: trigger.personaId,\n              scheduledAt: new Date(scheduledAt).toISOString(),\n              latencyMs,\n            }, 'Missed trigger: fired late');\n          }\n        }\n\n        try {\n          const parsedConfig = trigger.parsedConfig;\n          let eventType = 'trigger_fired';\n          let payload: string | null = null;\n          if (parsedConfig) {\n            if (parsedConfig.event_type) eventType = parsedConfig.event_type;\n            if (parsedConfig.payload) payload = JSON.stringify(parsedConfig.payload);\n          }\n\n          // Skip triggers for deleted or disabled personas\n          if (trigger.personaProjectId == null) {\n            logger.warn({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona not found (deleted?)');\n            continue;\n          }\n          if (!trigger.personaEnabled) {\n            logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');\n            continue;\n          }\n\n          const triggerProjectId = tenantId !== 'default' ? tenantId : trigger.personaProjectId;\n\n          // Publish event\n          const publishedEvent = db.publishEvent(tenantDb, {\n            eventType,\n            sourceType: 'trigger',\n            sourceId: trigger.id,\n            targetPersonaId: trigger.personaId,\n            projectId: triggerProjectId,\n            useCaseId: trigger.useCaseId,\n            payload,\n          });\n          onEventPublished?.();\n\n          // Record fire history\n          db.recordTriggerFire(tenantDb, {\n            triggerId: trigger.id,\n            eventId: publishedEvent.id,\n          });\n\n          // Compute next trigger time and update DB\n          const now = new Date().toISOString();\n          const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);\n          db.updateTriggerTimings(tenantDb, trigger.id, now, nextTriggerAt);\n\n          // Push updated time back into heap\n          if (nextTriggerAt) {\n            heap.push({ triggerId: trigger.id, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });\n          }\n\n          logger.info({\n            triggerId: trigger.id,\n            personaId: trigger.personaId,\n            eventType,\n            nextTriggerAt,\n          }, 'Trigger fired');\n          firedCount++;\n        } catch (err) {\n          logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');\n        }\n      }\n    } catch (err) {\n      logger.error({ err, tenantId }, 'Trigger scheduler tick failed for tenant');\n    }\n  }\n  return { fired: firedCount, missed: missedCount };\n}\n","numLines":375,"startLine":1,"totalLines":375}}}
