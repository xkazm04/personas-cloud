e = new Map<string, ActiveExecution>();\n    82→  private tenantDbManager: TenantDbManager | null = null;\n    83→  private masterKey: Buffer | null = null;\n    84→  private tenantKeyManager: TenantKeyManager | null = null;\n    85→  private auditLog: AuditLog | null = null;\n    86→  private preparer: ExecutionPreparer | null = null;\n    87→  // Maps executionId → projectId for DB resolution during callbacks\n    88→  private executionTenant = new Map<string, string>();\n    89→  // Batched output buffers: executionId → pending chunks\n    90→  private outputBuffers = new Map<string, string[]>();\n    91→  private outputFlushTimer: NodeJS.Timeout;\n    92→  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n    93→  private dispatching = false;\n    94→  // Backpressure state\n    95→  private backpressure: QueueBackpressureConfig;\n    96→  private tenantQueueCounts = new Map<string, number>();\n    97→  private currentThresholdLevel: ThresholdLevel = 'normal';\n    98→\n    99→  constructor(\n   100→    private pool: WorkerPool,\n   101→    private tokenManager: TokenManager,\n   102→    private oauth: OAuthManager | null,\n   103→    private kafka: KafkaClient,\n   104→    private logger: Logger,\n   105→    backpressureConfig?: Partial<QueueBackpressureConfig>,\n   106→  ) {\n   107→    this.backpressure = {\n   108→      maxQueueDepth: backpressureConfig?.maxQueueDepth ?? 1000,\n   109→      warningThreshold: backpressureConfig?.warningThreshold ?? 500,\n   110→      criticalThreshold: backpressureConfig?.criticalThreshold ?? 800,\n   111→      perTenantQuota: backpressureConfig?.perTenantQuota ?? 0,\n   112→      retryAfterSeconds: backpressureConfig?.retryAfterSeconds ?? 30,\n   113→    };\n   114→    // Periodic flush of batched output to DB\n   115→    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n   116→\n   117→    // When a worker becomes ready, try to dispatch queued work\n   118→    this.pool.on('worker-ready', () => {\n   119→      this.processQueue();\n   120→    });\n   121→\n   122→    // When a worker connects, try to dispatch\n   123→    this.pool.on('worker-connected', () => {\n   124→      this.processQueue();\n   125→    });\n   126→\n   127→    // Track stdout for execution output\n   128→    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n   129→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n   130→    });\n   131→\n   132→    // Track stderr for debugging failed executions\n   133→    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n   134→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n   135→      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n   136→    });\n   137→\n   138→    // Handle execution completion\n   139→    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n   140→      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   141→        executionId: msg.executionId,\n   142→        status: msg.status,\n   143→        exitCode: msg.exitCode,\n   144→        durationMs: msg.durationMs,\n   145→        sessionId: msg.sessionId,\n   146→        totalCostUsd: msg.totalCostUsd,\n   147→        ...(msg.phaseTimings ? { phaseTimings: msg.phaseTimings } : {}),\n   148→      }), msg.executionId).catch(err => {\n   149→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n   150→      });\n   151→\n   152→      // Flush any remaining buffered output before persisting completion\n   153→      this.flushOutputForExecution(msg.executionId);\n   154→\n   155→      // Update in-memory\n   156→      const exec = this.active.get(msg.executionId);\n   157→      const terminalStatus: ExecutionStatus = msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed';\n   158→      this.logTransition({\n   159→        executionId: msg.executionId,\n   160→        previousState: 'running',\n   161→        newState: terminalStatus,\n   162→        trigger: 'complete',\n   163→        workerId: exec?.workerId,\n   164→        disconnectRetries: exec?.disconnectRetries ?? 0,\n   165→      });\n   166→      if (exec) {\n   167→        exec.status = msg.status;\n   168→        exec.completedAt = Date.now();\n   169→        exec.exitCode = msg.exitCode;\n   170→        exec.durationMs = msg.durationMs;\n   171→        exec.sessionId = msg.sessionId;\n   172→        exec.totalCostUsd = msg.totalCostUsd;\n   173→        exec.phaseTimings = msg.phaseTimings;\n   174→        // Remove from active after a short delay (allow polling to pick up final state)\n   175→        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n   176→      }\n   177→\n   178→      // Persist to DB\n   179→      const completeDb = this.resolveDbForExecution(msg.executionId);\n   180→      if (completeDb) {\n   181→        try {\n   182→          db.updateExecution(completeDb, msg.executionId, {\n   183→            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n   184→            completedAt: new Date().toISOString(),\n   185→            durationMs: msg.durationMs,\n   186→            claudeSessionId: msg.sessionId,\n   187→            costUsd: msg.totalCostUsd ?? 0,\n   188→          });\n   189→        } catch (err) {\n   190→          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n   191→        }\n   192→      }\n   193→\n   194→      // Clean up tenant mapping after completion delay\n   195→      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n   196→\n   197→      // Process next queued item\n   198→      this.processQueue();\n   199→    });\n   200→\n   201→    // Track execution progress\n   202→    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n   203→      const exec = this.active.get(msg.executionId);\n   204→      if (exec) {\n   205→        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n   206→      }\n   207→      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n   208→        executionId: msg.executionId,\n   209→        phase: msg.phase,\n   210→        percent: msg.percent,\n   211→        detail: msg.detail,\n   212→        timestamp: msg.timestamp,\n   213→      }), msg.executionId).catch(err => {\n   214→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n   215→      });\n   216→    });\n   217→\n   218→    // Forward persona events to Kafka\n   219→    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n   220→      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n   221→        executionId: msg.executionId,\n   222→        eventType: msg.eventType,\n   223→        payload: msg.payload,\n   224→        timestamp: Date.now(),\n   225→      }), msg.executionId).catch(err => {\n   226→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n   227→      });\n   228→    });\n   229→\n   230→    // Handle worker busy nack — re-queue the rejected execution\n   231→    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n   232→      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n   233→      const exec = this.active.get(msg.executionId);\n   234→      if (exec?.request) {\n   235→        const request = exec.request;\n   236→        this.logTransition({\n   237→          executionId: msg.executionId,\n   238→          previousState: 'running',\n   239→          newState: 'queued',\n   240→          trigger: 'busy-nack',\n   241→          workerId: _workerId,\n   242→          personaId: request.personaId,\n   243→          disconnectRetries: exec.disconnectRetries ?? 0,\n   244→        });\n   245→        this.active.delete(msg.executionId);\n   246→        // Mark as queued in DB\n   247→        const reqDb = this.resolveDbForExecution(msg.executionId);\n   248→        if (reqDb) {\n   249→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack'); }\n   250→        }\n   251→        this.queue.unshift({ request, receivedAt: Date.now() });\n   252→        this.processQueue();\n   253→      } else {\n   254→        // Fallback: reconstruct from DB if request was not stored (should not happen)\n   255→        this.logTransition({\n   256→          executionId: msg.executionId,\n   257→          previousState: 'running',\n   258→          newState: 'queued',\n   259→          trigger: 'busy-nack',\n   260→          workerId: _workerId,\n   261→        });\n   262→        this.active.delete(msg.executionId);\n   263→        const projectId = this.executionTenant.get(msg.executionId) || 'default';\n   264→        const reqDb = this.resolveDb(projectId);\n   265→        if (reqDb) {\n   266→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack fallback'); }\n   267→        }\n   268→        const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n   269→        if (dbExec) {\n   270→          this.queue.unshift({\n   271→            request: {\n   272→              executionId: msg.executionId,\n   273→              personaId: dbExec.personaId,\n   274→              prompt: dbExec.inputData || '',\n   275→              projectId,\n   276→              config: { timeoutMs: 300_000 },\n   277→            },\n   278→            receivedAt: Date.now(),\n   279→          });\n   280→          this.processQueue();\n   281→        }\n   282→      }\n   283→    });\n   284→\n   285→    // Handle worker disconnect during execution — re-queue if retries remain\n   286→    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n   287→      if (executionId) {\n   288→        const exec = this.active.get(executionId);\n   289→        const retries = exec?.disconnectRetries ?? 0;\n   290→\n   291→        if (exec?.request && retries < MAX_DISCONNECT_RETRIES) {\n   292→          // Re-queue for retry\n   293→          const nextRetry = retries + 1;\n   294→          this.logTransition({\n   295→            executionId,\n   296→            previousState: 'running',\n   297→            newState: 'queued',\n   298→            trigger: 'disconnect-retry',\n   299→            workerId: _workerId,\n   300→            personaId: exec.request.personaId,\n   301→            disconnectRetries: nextRetry,\n   302→            errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n   303→          });\n   304→\n   305→          // Clear the active entry so dispatchToWorker can create a fresh one\n   306→          this.active.delete(executionId);\n   307→\n   308→          // Mark as queued in DB\n   309→          const disconnDb = this.resolveDbForExecution(executionId);\n   310→          if (disconnDb) {\n   311→            try {\n   312→              db.updateExecution(disconnDb, executionId, {\n   313→                status: 'queued',\n   314→                errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n   315→              });\n   316→            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on worker disconnect re-queue'); }\n   317→          }\n   318→\n   319→          // Temporarily store the retry count so dispatchToWorker picks it up\n   320→          const request = exec.request;\n   321→          // Create a placeholder active entry to carry retry count across re-dispatch\n   322→          this.active.set(executionId, {\n   323→            workerId: '',\n   324→            startedAt: 0,\n   325→            output: [],\n   326→            status: 'running',\n   327→            request,\n   328→            disconnectRetries: nextRetry,\n   329→          });\n   330→\n   331→          this.queue.unshift({ request, receivedAt: Date.now() });\n   332→          this.processQueue();\n   333→        } else {\n   334→          // Retries exhausted or no request stored — permanent failure\n   335→          this.logTransition({\n   336→            executionId,\n   337→            previousState: 'running',\n   338→            newState: 'failed',\n   339→            trigger: 'disconnect-exhausted',\n   340→            workerId: _workerId,\n   341→            disconnectRetries: retries,\n   342→            errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n   343→          });\n   344→          if (exec) {\n   345→            exec.status = 'failed';\n   346→            exec.completedAt = Date.now();\n   347→            setTimeout(() => this.active.delete(executionId), 30_000);\n   348→          }\n   349→\n   350→          const disconnDb = this.resolveDbForExecution(executionId);\n   351→          if (disconnDb) {\n   352→            try {\n   353→              db.updateExecution(disconnDb, executionId, {\n   354→                status: 'failed',\n   355→                errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n   356→                completedAt: new Date().toISOString(),\n   357→              });\n   358→            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:failed' }, 'Failed to persist execution failure on worker disconnect'); }\n   359→          }\n   360→          this.executionTenant.delete(executionId);\n   361→\n   362→          this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   363→            executionId,\n   364→            status: 'failed',\n   365→            error: 'Worker disconnected (retries exhausted)',\n   366→            durationMs: 0,\n   367→          }), executionId).catch(err => { this.logger.warn({ err, executionId, op: 'kafka:exec_lifecycle' }, 'Failed to produce disconnect failure lifecycle to Kafka'); });\n   368→        }\n   369→      }\n   370→    });\n   371→  }\n   372→\n   373→  setTenantDbManager(mgr: TenantDbManager): void {\n   374→    this.tenantDbManager = mgr;\n   375→  }\n   376→\n   377→  async setMasterKey(masterKeyHex: string): Promise<void> {\n   378→    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n   379→  }\n   380→\n   381→  setTenantKeyManager(mgr: TenantKeyManager): void {\n   382→    this.tenantKeyManager = mgr;\n   383→  }\n   384→\n   385→  setAuditLog(log: AuditLog): void {\n   386→    this.auditLog = log;\n   387→  }\n   388→\n   389→  /** Resolve the database for a given projectId via tenant DB manager. */\n   390→  private resolveDb(projectId?: string): Database.Database | null {\n   391→    if (this.tenantDbManager && projectId) {\n   392→      return this.tenantDbManager.getTenantDb(projectId);\n   393→    }\n   394→    return null;\n   395→  }\n   396→\n   397→  /** Resolve the database for an in-flight execution by its ID. */\n   398→  private resolveDbForExecution(executionId: string): Database.Database | null {\n   399→    const projectId = this.executionTenant.get(executionId);\n   400→    return this.resolveDb(projectId);\n   401→  }\n   402→\n   403→  /**\n   404→   * Emit a single structured log entry for every execution state transition.\n   405→   * Creates a queryable timeline: grep for \"Execution state transition\" to see\n   406→   * the full lifecycle of any