[2026-03-19T08:20:01.949Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gctaesc4K7XEJCGHc7349o","type":"tool_result","content":"     1→import pino from 'pino';\n     2→import { loadConfig } from './config.js';\n     3→import { createAuth } from './auth.js';\n     4→import { createTokenManager } from './tokenManager.js';\n     5→import { OAuthManager } from './oauth.js';\n     6→import { WorkerPool, type WorkerPoolEvents } from './workerPool.js';\n     7→import { createKafkaClient, createNoopKafkaClient } from './kafka.js';\n     8→import { Dispatcher } from './dispatcher.js';\n     9→import { createHttpApi } from './httpApi.js';\n    10→import { TenantDbManager } from './tenantDbManager.js';\n    11→import { TenantKeyManager, type TenantKeyEvents } from './tenantKeyManager.js';\n    12→import { AuditLog } from './auditLog.js';\n    13→import { AuditPolicy } from './auditPolicy.js';\n    14→import { AuditRetentionPolicy } from './auditRetentionPolicy.js';\n    15→import { AuditChainVerifier } from './auditChainVerifier.js';\n    16→import { startRetentionJob } from './retention.js';\n    17→import { startEventProcessor } from './eventProcessor.js';\n    18→import { startTriggerScheduler } from './triggerScheduler.js';\n    19→import { loadTlsConfig } from './tls.js';\n    20→import { TOPICS, type ExecRequest } from '@dac-cloud/shared';\n    21→\n    22→const logger = pino({ level: process.env['LOG_LEVEL'] || 'info' });\n    23→\n    24→async function main() {\n    25→  logger.info('Starting DAC Cloud Orchestrator...');\n    26→\n    27→  // Load configuration\n    28→  const config = loadConfig();\n    29→  logger.info({\n    30→    kafkaEnabled: config.kafkaEnabled,\n    31→    wsPort: config.wsPort,\n    32→    httpPort: config.httpPort,\n    33→    hasDirectToken: !!config.claudeToken,\n    34→  }, 'Configuration loaded');\n    35→\n    36→  // Initialize components\n    37→  const auth = createAuth(config.teamApiKey, config.supabaseJwtSecret || undefined);\n    38→  const tokenManager = await createTokenManager(config.masterKey, logger);\n    39→  const oauth = new OAuthManager(logger);\n    40→\n    41→  // If a direct Claude token is provided (from setup-token), store it\n    42→  if (config.claudeToken) {\n    43→    tokenManager.storeClaudeToken(config.claudeToken);\n    44→    logger.info('Direct Claude token loaded from environment');\n    45→  } else {\n    46→    logger.info('No direct Claude token — use OAuth flow via POST /api/oauth/authorize');\n    47→  }\n    48→\n    49→  // Tenant-isolated database manager\n    50→  const tenantDbManager = new TenantDbManager(config.dataDir, logger);\n    51→  logger.info({ dataDir: config.dataDir }, 'Tenant DB manager initialized');\n    52→\n    53→  // Worker pool (WebSocket server)\n    54→  const pool = new WorkerPool(config.workerToken, logger, {\n    55→    allowedDigests: config.allowedImageDigests,\n    56→    rejectUnverified: config.rejectUnverifiedWorkers,\n    57→  });\n    58→\n    59→  // Kafka client\n    60→  const kafka = config.kafkaEnabled\n    61→    ? createKafkaClient(config.kafkaBrokers, config.kafkaUsername, config.kafkaPassword, logger)\n    62→    : createNoopKafkaClient(logger);\n    63→\n    64→  // Audit log (separate append-only DB)\n    65→  const auditLog = new AuditLog(config.auditDbPath, logger);\n    66→  const auditRetention = new AuditRetentionPolicy(auditLog, config.auditRetentionDays, logger);\n    67→  auditRetention.startDailyPurge();\n    68→\n    69→  // Periodic hash chain integrity verification\n    70→  const auditChainVerifier = new AuditChainVerifier(\n    71→    auditLog, logger, config.auditChainVerifyIntervalMinutes * 60_000,\n    72→  );\n    73→  auditChainVerifier.start();\n    74→\n    75→  // Wire audit log into OAuth manager for token lifecycle events\n    76→  oauth.setAuditLog(auditLog, config.tokenExpiryWarningMinutes);\n    77→\n    78→  // Per-tenant key manager (cached key derivation with TTL)\n    79→  const tenantKeyManager = new TenantKeyManager(config.masterKey, logger);\n    80→\n    81→  // Declarative audit policy — maps emitter events to audit entries\n    82→  const auditPolicy = new AuditPolicy(auditLog);\n    83→\n    84→  auditPolicy.attach<TenantKeyEvents>(tenantKeyManager, {\n    85→    'key:derived': (e) => ({ action: 'key:derive', tenantId: e.tenantId }),\n    86→  });\n    87→\n    88→  auditPolicy.attach<WorkerPoolEvents>(pool, {\n    89→    'worker-connected': (info) => ({ action: 'worker:connected', detail: { workerId: info.workerId } }),\n    90→    'worker-disconnected': (workerId, executionId) => ({ action: 'worker:disconnected', detail: { workerId }, resourceId: executionId }),\n    91→  });\n    92→\n    93→  // Wire tenant ID source for key pre-warming and proactive renewal\n    94→  await tenantKeyManager.setTenantIdSource(() => tenantDbManager.listTenantIds());\n    95→  // Eagerly warm key cache when a new tenant is registered\n    96→  tenantDbManager.setTenantCreatedCallback((tenantId) => tenantKeyManager.warmTenant(tenantId));\n    97→\n    98→  // Dispatcher — uses OAuth manager for token refresh\n    99→  const dispatcher = new Dispatcher(pool, tokenManager, oauth, kafka, logger, {\n   100→    maxQueueDepth: config.maxQueueDepth,\n   101→    warningThreshold: config.queueWarningThreshold,\n   102→    criticalThreshold: config.queueCriticalThreshold,\n   103→    perTenantQuota: config.perTenantQueueQuota,\n   104→    retryAfterSeconds: config.queueRetryAfterSeconds,\n   105→  });\n   106→  dispatcher.setTenantDbManager(tenantDbManager);\n   107→  await dispatcher.setMasterKey(config.masterKey);\n   108→  dispatcher.setTenantKeyManager(tenantKeyManager);\n   109→  dispatcher.setAuditLog(auditLog);\n   110→\n   111→  // Connect Kafka\n   112→  if (config.kafkaEnabled) {\n   113→    await kafka.connect();\n   114→\n   115→    // Subscribe to execution requests\n   116→    await kafka.subscribe(async (topic: string, value: string) => {\n   117→      if (topic === TOPICS.EXEC_REQUESTS) {\n   118→        try {\n   119→          const request: ExecRequest = JSON.parse(value);\n   120→          const result = dispatcher.submit(request);\n   121→          if (!result.accepted) {\n   122→            logger.warn({ executionId: request.executionId, reason: result.reason }, 'Kafka execution rejected by backpressure, sending to DLQ');\n   123→            await kafka.produce(TOPICS.DLQ, JSON.stringify({\n   124→              originalTopic: TOPICS.EXEC_REQUESTS,\n   125→              reason: result.reason,\n   126→              payload: request,\n   127→              timestamp: Date.now(),\n   128→            }), request.executionId);\n   129→          }\n   130→        } catch (err) {\n   131→          logger.error({ err }, 'Failed to parse execution request from Kafka');\n   132→        }\n   133→      }\n   134→    });\n   135→  }\n   136→\n   137→  // Load TLS config and start WebSocket server for workers\n   138→  const tlsConfig = loadTlsConfig(logger);\n   139→  pool.listen(config.wsPort, tlsConfig.enabled ? tlsConfig : undefined);\n   140→\n   141→  // Start HTTP API (now includes OAuth endpoints + persona CRUD)\n   142→  // Set master key on Kafka for envelope encryption\n   143→  await kafka.setMasterKey(config.masterKey);\n   144→\n   145→  // Start event processor (demand-driven with 30s backstop) — tenant-aware\n   146→  const eventProcessor = startEventProcessor(null, dispatcher, logger, 30_000, tenantDbManager);\n   147→\n   148→  // Start heap-driven trigger scheduler — builds in-memory min-heap from DB on startup\n   149→  const triggerScheduler = startTriggerScheduler(null, logger, undefined, tenantDbManager, eventProcessor.nudge);\n   150→\n   151→  const httpServer = createHttpApi(auth, dispatcher, pool, tokenManager, oauth, logger, undefined, tenantDbManager, tenantKeyManager, auditLog, eventProcessor.getHealth, kafka, eventProcessor.nudge, triggerScheduler);\n   152→  httpServer.listen(config.httpPort, () => {\n   153→    logger.info({ port: config.httpPort }, 'HTTP API listening');\n   154→  });\n   155→\n   156→  // Start daily retention job (purge old executions/events, aggregate metrics)\n   157→  const retentionTimer = startRetentionJob(tenantDbManager, config.retentionDays, logger);\n   158→\n   159→  // Token refresh loop — refresh OAuth token proactively every 30 minutes\n   160→  setInterval(async () => {\n   161→    if (oauth.hasTokens()) {\n   162→      const token = await oauth.getValidAccessToken();\n   163→      if (token) {\n   164→        tokenManager.storeClaudeToken(token);\n   165→      }\n   166→    }\n   167→  }, 30 * 60 * 1000);\n   168→\n   169→  // Log status periodically\n   170→  setInterval(() => {\n   171→    const counts = pool.getWorkerCount();\n   172→    const queueLen = dispatcher.getQueueLength();\n   173→    if (counts.total > 0 || queueLen > 0) {\n   174→      logger.info({\n   175→        workers: counts,\n   176→        queueLength: queueLen,\n   177→        activeExecutions: dispatcher.getActiveExecutions().length,\n   178→        hasOAuth: oauth.hasTokens(),\n   179→      }, 'Status');\n   180→    }\n   181→\n   182→    // Database health stats — early warning for unbounded growth\n   183→    try {\n   184→      const dbHealth = tenantDbManager.getHealthStats();\n   185→\n   186→      // Audit DB size\n   187→      let auditSizeBytes = 0;\n   188→      let auditRowCount = 0;\n   189→      try {\n   190→        const auditDb = auditLog.getDb();\n   191→        const sizeRow = auditDb.prepare('SELECT page_count * page_size AS size FROM pragma_page_count(), pragma_page_size()').get() as { size: number } | undefined;\n   192→        auditSizeBytes = sizeRow?.size ?? 0;\n   193→        const countRow = auditDb.prepare('SELECT COUNT(*) AS cnt FROM audit_events').get() as { cnt: number };\n   194→        auditRowCount = countRow.cnt;\n   195→      } catch { /* audit DB stats are best-effort */ }\n   196→\n   197→      const oldestAgeDays = dbHealth.oldestUnpurgedAgeMs !== null\n   198→        ? Math.round(dbHealth.oldestUnpurgedAgeMs / (1000 * 60 * 60 * 24) * 10) / 10\n   199→        : null;\n   200→\n   201→      logger.info({\n   202→        totalSizeMB: Math.round(dbHealth.totalSizeBytes / (1024 * 1024) * 100) / 100,\n   203→        auditSizeMB: Math.round(auditSizeBytes / (1024 * 1024) * 100) / 100,\n   204→        tenantCount: dbHealth.tenantCount,\n   205→        executionRows: dbHealth.totalExecutionRows,\n   206→        eventRows: dbHealth.totalEventRows,\n   207→        auditRows: auditRowCount,\n   208→        oldestUnpurgedDays: oldestAgeDays,\n   209→        retentionDays: config.retentionDays,\n   210→      }, 'DB health');\n   211→    } catch (err) {\n   212→      logger.warn({ err }, 'Failed to collect DB health stats');\n   213→    }\n   214→  }, 60_000);\n   215→\n   216→  // Graceful shutdown\n   217→  const shutdown = async () => {\n   218→    logger.info('Shutting down...');\n   219→    clearInterval(eventProcessor.timer);\n   220→    triggerScheduler.close();\n   221→    clearInterval(retentionTimer);\n   222→    dispatcher.shutdown();\n   223→    pool.shutdown();\n   224→    await kafka.disconnect();\n   225→    httpServer.close();\n   226→    tenantKeyManager.close();\n   227→    auditChainVerifier.close();\n   228→    auditRetention.close();\n   229→    auditLog.close();\n   230→    tenantDbManager.close();\n   231→    oauth.dispose();\n   232→    process.exit(0);\n   233→  };\n   234→\n   235→  process.on('SIGINT', shutdown);\n   236→  process.on('SIGTERM', shutdown);\n   237→\n   238→  logger.info('DAC Cloud Orchestrator ready');\n   239→  logger.info(`  HTTP API: http://localhost:${config.httpPort}`);\n   240→  logger.info(`  Worker WS: ${tlsConfig.enabled ? 'wss' : 'ws'}://localhost:${config.wsPort}`);\n   241→  if (!config.claudeToken) {\n   242→    logger.info('  Connect subscription: POST /api/oauth/authorize');\n   