[2026-03-19T08:12:50.335Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015FEhGYipuWRA4tXCapY1Sy","type":"tool_result","content":"     1→import { randomBytes, createHash } from 'node:crypto';\n     2→import type { Logger } from 'pino';\n     3→import type { AuditLog } from './auditLog.js';\n     4→\n     5→// Anthropic OAuth constants (from Claude Code CLI)\n     6→const OAUTH_AUTHORIZE_URL = 'https://claude.ai/oauth/authorize';\n     7→const OAUTH_TOKEN_URL = 'https://console.anthropic.com/v1/oauth/token';\n     8→const OAUTH_REVOKE_URL = 'https://console.anthropic.com/v1/oauth/revoke';\n     9→const CLIENT_ID = '9d1c250a-e61b-44d9-88ed-5944d1962f5e';\n    10→const REDIRECT_URI = 'https://console.anthropic.com/oauth/code/callback';\n    11→const SCOPES = 'org:create_api_key user:profile user:inference';\n    12→\n    13→export interface OAuthTokens {\n    14→  accessToken: string;\n    15→  refreshToken: string;\n    16→  expiresAt: number;    // unix ms\n    17→  scopes: string[];\n    18→}\n    19→\n    20→export interface OAuthState {\n    21→  state: string;\n    22→  codeVerifier: string;\n    23→  createdAt: number;\n    24→  expiresAt: number;    // unix ms, 10 minute window\n    25→}\n    26→\n    27→export class OAuthManager {\n    28→  private pendingStates = new Map<string, OAuthState>();\n    29→  private tokens: OAuthTokens | null = null;\n    30→  private refreshPromise: Promise<OAuthTokens | null> | null = null;\n    31→  private sweepTimer: ReturnType<typeof setInterval> | null = null;\n    32→  private auditLog?: AuditLog;\n    33→  private expiryWarningMs = 30 * 60 * 1000; // default 30 minutes\n    34→  private expiryWarningEmitted = false;\n    35→\n    36→  private static readonly DEFAULT_SCOPES = ['user:inference', 'user:profile'];\n    37→\n    38→  constructor(private logger: Logger) {\n    39→    // Sweep expired pending states every 60 seconds\n    40→    this.sweepTimer = setInterval(() => this.sweepExpiredStates(), 60_000);\n    41→    this.sweepTimer.unref();\n    42→  }\n    43→\n    44→  /**\n    45→   * Wire in the audit log and configurable expiry warning threshold.\n    46→   * Called after construction once the audit log is available.\n    47→   */\n    48→  setAuditLog(auditLog: AuditLog, warningMinutes?: number): void {\n    49→    this.auditLog = auditLog;\n    50→    if (warningMinutes !== undefined && warningMinutes > 0) {\n    51→      this.expiryWarningMs = warningMinutes * 60 * 1000;\n    52→    }\n    53→  }\n    54→\n    55→  private sweepExpiredStates(): void {\n    56→    const now = Date.now();\n    57→    let swept = 0;\n    58→    for (const [key, entry] of this.pendingStates) {\n    59→      if (now > entry.expiresAt) {\n    60→        this.pendingStates.delete(key);\n    61→        swept++;\n    62→      }\n    63→    }\n    64→    if (swept > 0) {\n    65→      this.logger.debug({ swept, remaining: this.pendingStates.size }, 'Swept expired OAuth states');\n    66→    }\n    67→  }\n    68→\n    69→  /**\n    70→   * POST to the OAuth token endpoint, parse the response, and map to OAuthTokens.\n    71→   * Callers supply only the grant-specific body fields and a scope fallback.\n    72→   */\n    73→  private async postTokenEndpoint(\n    74→    body: Record<string, string>,\n    75→    fallbackScopes: string[],\n    76→    context: string,\n    77→  ): Promise<OAuthTokens | null> {\n    78→    try {\n    79→      const response = await fetch(OAUTH_TOKEN_URL, {\n    80→        method: 'POST',\n    81→        headers: {\n    82→          'Content-Type': 'application/json',\n    83→          'Accept': 'application/json',\n    84→        },\n    85→        body: JSON.stringify(body),\n    86→      });\n    87→\n    88→      if (!response.ok) {\n    89→        const errorText = await response.text();\n    90→        this.logger.error({ status: response.status, error: errorText }, `OAuth ${context} failed`);\n    91→        return null;\n    92→      }\n    93→\n    94→      const data = await response.json() as {\n    95→        access_token: string;\n    96→        refresh_token: string;\n    97→        expires_in: number;\n    98→        scope?: string;\n    99→      };\n   100→\n   101→      return {\n   102→        accessToken: data.access_token,\n   103→        refreshToken: data.refresh_token,\n   104→        expiresAt: Date.now() + data.expires_in * 1000,\n   105→        scopes: data.scope ? data.scope.split(' ') : fallbackScopes,\n   106→      };\n   107→    } catch (err) {\n   108→      this.logger.error({ err }, `OAuth ${context} request failed`);\n   109→      return null;\n   110→    }\n   111→  }\n   112→\n   113→  /**\n   114→   * Step 1: Generate the authorization URL for the user to visit.\n   115→   * Returns the URL and stores PKCE state internally.\n   116→   */\n   117→  generateAuthUrl(): { url: string; state: string } {\n   118→    const state = randomBytes(32).toString('hex');\n   119→    const codeVerifier = randomBytes(32).toString('base64url');\n   120→    const codeChallenge = createHash('sha256')\n   121→      .update(codeVerifier)\n   122→      .digest('base64url');\n   123→\n   124→    const oauthState: OAuthState = {\n   125→      state,\n   126→      codeVerifier,\n   127→      createdAt: Date.now(),\n   128→      expiresAt: Date.now() + 10 * 60 * 1000, // 10 minutes\n   129→    };\n   130→\n   131→    this.pendingStates.set(state, oauthState);\n   132→\n   133→    const params = new URLSearchParams({\n   134→      code: 'true',\n   135→      client_id: CLIENT_ID,\n   136→      response_type: 'code',\n   137→      redirect_uri: REDIRECT_URI,\n   138→      scope: SCOPES,\n   139→      code_challenge: codeChallenge,\n   140→      code_challenge_method: 'S256',\n   141→      state,\n   142→    });\n   143→\n   144→    const url = `${OAUTH_AUTHORIZE_URL}?${params.toString()}`;\n   145→\n   146→    this.logger.info('Generated OAuth authorization URL');\n   147→    return { url, state };\n   148→  }\n   149→\n   150→  /**\n   151→   * Step 2: Exchange the authorization code for tokens.\n   152→   * Called after user completes the OAuth flow and provides the code.\n   153→   */\n   154→  async exchangeCode(authorizationCode: string, state: string): Promise<OAuthTokens | null> {\n   155→    // Validate state\n   156→    const pending = this.pendingStates.get(state);\n   157→    if (!pending) {\n   158→      this.logger.error('OAuth state not found or already consumed');\n   159→      return null;\n   160→    }\n   161→\n   162→    if (Date.now() > pending.expiresAt) {\n   163→      this.logger.error('OAuth state expired');\n   164→      this.pendingStates.delete(state);\n   165→      return null;\n   166→    }\n   167→\n   168→    const cleanedCode = authorizationCode.split('#')[0]?.split('&')[0] ?? authorizationCode;\n   169→\n   170→    this.tokens = await this.postTokenEndpoint(\n   171→      {\n   172→        grant_type: 'authorization_code',\n   173→        client_id: CLIENT_ID,\n   174→        code: cleanedCode,\n   175→        redirect_uri: REDIRECT_URI,\n   176→        code_verifier: pending.codeVerifier,\n   177→        state: pending.state,\n   178→      },\n   179→      OAuthManager.DEFAULT_SCOPES,\n   180→      'token exchange',\n   181→    );\n   182→\n   183→    this.pendingStates.delete(state);\n   184→\n   185→    if (this.tokens) {\n   186→      this.logger.info({\n   187→        scopes: this.tokens.scopes,\n   188→        expiresAt: new Date(this.tokens.expiresAt).toISOString(),\n   189→      }, 'OAuth token exchange successful');\n   190→    }\n   191→\n   192→    return this.tokens;\n   193→  }\n   194→\n   195→  /**\n   196→   * Refresh the access token using the refresh token.\n   197→   * Called automatically before dispatching if token is near expiry.\n   198→   * Uses promise dedup so concurrent callers share one in-flight refresh,\n   199→   * preventing single-use rotating refresh tokens from being consumed twice.\n   200→   */\n   201→  async refreshAccessToken(): Promise<OAuthTokens | null> {\n   202→    if (!this.tokens) {\n   203→      this.logger.error('No tokens to refresh');\n   204→      return null;\n   205→    }\n   206→\n   207→    if (this.refreshPromise) {\n   208→      return this.refreshPromise;\n   209→    }\n   210→\n   211→    this.refreshPromise = this.executeRefresh().finally(() => {\n   212→      this.refreshPromise = null;\n   213→    });\n   214→    return this.refreshPromise;\n   215→  }\n   216→\n   217→  private async executeRefresh(): Promise<OAuthTokens | null> {\n   218→    const previousScopes = this.tokens!.scopes;\n   219→\n   220→    // Refresh tokens are single-use rotation — store the new one\n   221→    this.tokens = await this.postTokenEndpoint(\n   222→      {\n   223→        grant_type: 'refresh_token',\n   224→        client_id: CLIENT_ID,\n   225→        refresh_token: this.tokens!.refreshToken,\n   226→      },\n   227→      previousScopes,\n   228→      'token refresh',\n   229→    );\n   230→\n   231→    if (this.tokens) {\n   232→      this.logger.info({\n   233→        expiresAt: new Date(this.tokens.expiresAt).toISOString(),\n   234→      }, 'OAuth token refreshed');\n   235→      try { this.auditLog?.record({ action: 'oauth:refresh', resourceType: 'oauth', detail: { expiresAt: new Date(this.tokens.expiresAt).toISOString() } }); } catch { /* logged inside record() */ }\n   236→    } else {\n   237→      try { this.auditLog?.record({ action: 'oauth:refresh_failed', resourceType: 'oauth', detail: { reason: 'token endpoint returned null' } }); } catch { /* logged inside record() */ }\n   238→    }\n   239→\n   240→    return this.tokens;\n   241→  }\n   242→\n   243→  /**\n   244→   * Get a valid access token, refreshing if necessary.\n   245→   * Returns null if no tokens available or refresh fails.\n   246→   */\n   247→  async getValidAccessToken(): Promise<string | null> {\n   248→    if (!this.tokens) return null;\n   249→\n   250→    const now = Date.now();\n   251→    const remainingMs = this.tokens.expiresAt - now;\n   252→\n   253→    // Emit token:expiring_soon once per token when within the warning threshold\n   254→    if (remainingMs > 0 && remainingMs <= this.expiryWarningMs && !this.expiryWarningEmitted) {\n   255→      this.expiryWarningEmitted = true;\n   256→      try {\n   257→        this.auditLog?.record({\n   258→          action: 'token:expiring_soon',\n   259→          resourceType: 'oauth',\n   260→          detail: {\n   261→            expiresAt: new Date(this.tokens.expiresAt).toISOString(),\n   262→            remainingMinutes: Math.round(remainingMs / 60_000),\n   263→          },\n   264→        });\n   265→      } catch { /* logged inside record() */ }\n   266→      this.logger.warn({ remainingMinutes: Math.round(remainingMs / 60_000) }, 'OAuth token expiring soon');\n   267→    }\n   268→\n   269→    // Refresh if within 10 minutes of expiry\n   270→    const TEN_MINUTES = 10 * 60 * 1000;\n   271→    if (now > this.tokens.expiresAt - TEN_MINUTES) {\n   272→      this.logger.info('Access token near expiry, refreshing...');\n   273→      const refreshed = await this.refreshAccessToken();\n   274→      if (!refreshed) return null;\n   275→      // Reset expiry warning flag after successful refresh\n   276→      this.expiryWarningEmitted = false;\n   277→    }\n   278→\n   279→    return this.tokens.accessToken;\n   280→  }\n   281→\n   282→  /**\n   283→   * Load tokens directly (e.g. from encrypted storage on startup).\n   284→   */\n   285→  loadTokens(tokens: OAuthTokens): void {\n   286→    this.tokens = tokens;\n   287→    this.logger.info({\n   288→      expiresAt: new Date(tokens.expiresAt).toISOString(),\n   289→      scopes: tokens.scopes,\n   290→    }, 'OAuth tokens loaded');\n   291→  }\n   292→\n   293→  /**\n   294→   * Get current tokens for persistence/encryption.\n   295→   */\n   296→  getTokens(): OAuthTokens | null {\n   297→    return this.to