tity?: string;\n    56→  instructions?: string;\n    57→  toolGuidance?: string;\n    58→  examples?: string;\n    59→  errorHandling?: string;\n    60→  customSections?: Array<{ title?: string; label?: string; name?: string; key?: string; content?: string }>;\n    61→  webSearch?: string;\n    62→}\n    63→\n    64→// ---------------------------------------------------------------------------\n    65→// Inference profiles\n    66→// ---------------------------------------------------------------------------\n    67→\n    68→export type InferenceProvider = 'claude' | 'ollama' | 'litellm' | 'openai-compatible' | 'custom';\n    69→\n    70→export interface InferenceProviderEnvMapping {\n    71→  envVar: string;\n    72→  source: 'baseUrl' | 'authToken' | 'model';\n    73→}\n    74→\n    75→export interface InferenceProfile {\n    76→  id: string;\n    77→  projectId: string;\n    78→  name: string;\n    79→  provider: InferenceProvider;\n    80→  model?: string;\n    81→  baseUrl?: string;\n    82→  authTokenEncrypted?: string;\n    83→  authTokenIv?: string;\n    84→  authTokenTag?: string;\n    85→  envMappings: InferenceProviderEnvMapping[];\n    86→  removeEnvKeys?: string[];\n    87→  isPreset: boolean;\n    88→  createdAt: string;\n    89→  updatedAt: string;\n    90→}\n    91→\n    92→export interface PersonaCredential {\n    93→  id: string;\n    94→  projectId?: string;\n    95→  name: string;\n    96→  serviceType: string;\n    97→  encryptedData: string;\n    98→  iv: string;\n    99→  tag: string;\n   100→  metadata: string | null;\n   101→  lastUsedAt: string | null;\n   102→  createdAt: string;\n   103→  updatedAt: string;\n   104→}\n   105→\n   106→// ---------------------------------------------------------------------------\n   107→// Event lifecycle state machine\n   108→// ---------------------------------------------------------------------------\n   109→\n   110→/** All valid event statuses. */\n   111→export type EventStatus = 'pending' | 'processing' | 'delivered' | 'skipped' | 'failed' | 'partial' | 'partial-retry';\n   112→\n   113→/** All valid EventStatus values as a runtime array (for CHECK constraints, etc.). */\n   114→export const EVENT_STATUSES: readonly EventStatus[] = [\n   115→  'pending', 'processing', 'delivered', 'skipped', 'failed', 'partial', 'partial-retry',\n   116→] as const;\n   117→\n   118→/**\n   119→ * Legal state transitions for persona events.\n   120→ * Key = current status, Value = set of statuses it may transition to.\n   121→ */\n   122→export const EVENT_TRANSITIONS: Readonly<Record<EventStatus, ReadonlySet<EventStatus>>> = {\n   123→  'pending':       new Set<EventStatus>(['processing']),\n   124→  'processing':    new Set<EventStatus>(['delivered', 'skipped', 'failed', 'partial', 'partial-retry', 'pending']),\n   125→  'delivered':     new Set<EventStatus>([]),                       // terminal\n   126→  'skipped':       new Set<EventStatus>([]),                       // terminal\n   127→  'failed':        new Set<EventStatus>([]),                       // terminal\n   128→  'partial':       new Set<EventStatus>(['partial-retry']),        // can retry partial failures\n   129→  'partial-retry': new Set<EventStatus>(['processing']),           // retried partial goes back through processing\n   130→};\n   131→\n   132→/**\n   133→ * Validate that a transition from `from` → `to` is legal.\n   134→ * Throws if the transition is invalid.\n   135→ */\n   136→export function validateEventTransition(from: EventStatus, to: EventStatus): void {\n   137→  const allowed = EVENT_TRANSITIONS[from];\n   138→  if (!allowed || !allowed.has(to)) {\n   139→    throw new Error(`Invalid event status transition: '${from}' → '${to}'`);\n   140→  }\n   141→}\n   142→\n   143→export interface PersonaEvent {\n   144→  id: string;\n   145→  projectId: string;\n   146→  eventType: string;\n   147→  sourceType: string;\n   148→  sourceId: string | null;\n   149→  targetPersonaId: string | null;\n   150→  payload: string | null;\n   151→  status: EventStatus;\n   152→  errorMessage: string | null;\n   153→  processedAt: string | null;\n   154→  useCaseId: string | null;\n   155→  retryAfter: string | null;\n   156→  retryCount: number;\n   157→  createdAt: string;\n   158→}\n   159→\n   160→export interface PersonaEventSubscription {\n   161→  id: string;\n   162→  personaId: string;\n   163→  eventType: string;\n   164→  sourceFilter: string | null;\n   165→  enabled: boolean;\n   166→  useCaseId: string | null;\n   167→  createdAt: string;\n   168→  updatedAt: string;\n   169→}\n   170→\n   171→// ---------------------------------------------------------------------------\n   172→// Trigger config discriminated union\n   173→// ---------------------------------------------------------------------------\n   174→\n   175→export type TriggerType = 'manual' | 'schedule' | 'polling' | 'webhook' | 'chain';\n   176→\n   177→interface TriggerConfigBase {\n   178→  event_type?: string;\n   179→  payload?: unknown;\n   180→}\n   181→\n   182→export interface ScheduleTriggerConfig extends TriggerConfigBase {\n   183→  kind: 'schedule';\n   184→  cron?: string;\n   185→  interval_seconds?: number;\n   186→}\n   187→\n   188→export interface ManualTriggerConfig extends TriggerConfigBase {\n   189→  kind: 'manual';\n   190→}\n   191→\n   192→export interface PollingTriggerConfig extends TriggerConfigBase {\n   193→  kind: 'polling';\n   194→  poll_url?: string;\n   195→  poll_interval_seconds?: number;\n   196→}\n   197→\n   198→export interface WebhookTriggerConfig extends TriggerConfigBase {\n   199→  kind: 'webhook';\n   200→  url?: string;\n   201→  secret?: string;\n   202→}\n   203→\n   204→export interface ChainTriggerConfig extends TriggerConfigBase {\n   205→  kind: 'chain';\n   206→  source_persona_id?: string;\n   207→  source_event_type?: string;\n   208→}\n   209→\n   210→export type TriggerConfig =\n   211→  | ScheduleTriggerConfig\n   212→  | ManualTriggerConfig\n   213→  | PollingTriggerConfig\n   214→  | WebhookTriggerConfig\n   215→  | ChainTriggerConfig;\n   216→\n   217→export interface PersonaTrigger {\n   218→  id: string;\n   219→  personaId: string;\n   220→  triggerType: TriggerType;\n   221→  config: string | null;\n   222→  enabled: boolean;\n   223→  lastTriggeredAt: string | null;\n   224→  nextTriggerAt: string | null;\n   225→  useCaseId: string | null;\n   226→  createdAt: string;\n   227→  updatedAt: string;\n   228→}\n   229→\n   230→export type TriggerFireStatus = 'fired' | 'completed' | 'failed';\n   231→\n   232→export interface TriggerFire {\n   233→  id: string;\n   234→  triggerId: string;\n   235→  eventId: string | null;\n   236→  executionId: string | null;\n   237→  status: TriggerFireStatus;\n   238→  durationMs: number | null;\n   239→  errorMessage: string | null;\n   240→  firedAt: string;\n   241→}\n   242→\n   243→export interface TriggerStats {\n   244→  totalFires: number;\n   245→  successCount: number;\n   246→  failureCount: number;\n   247→  successRate: number;\n   248→  avgDurationMs: number | null;\n   249→  lastFireStatus: TriggerFireStatus | null;\n   250→  lastFiredAt: string | null;\n   251→}\n   252→\n   253→/** Fully hydrated persona with all related entities. */\n   254→export interface HydratedPersona extends Persona {\n   255→  tools: PersonaToolDefinition[];\n   256→  credentials: Omit<PersonaCredential, 'encryptedData' | 'iv' | 'tag'>[];\n   257→  subscriptions: PersonaEventSubscription[];\n   258→  triggers: PersonaTrigger[];\n   259→}\n   260→\n   261→export interface PersonaExecution {\n   262→  id: string;\n   263→  projectId?: string;\n   264→  personaId: string;\n   265→  triggerId: string | null;\n   266→  useCaseId: string | null;\n   267→  /** Originating event ID — enables bidirectional event↔execution tracing. */\n   268→  eventId: string | null;\n   269→  status: string;\n   270→  inputData: string | null;\n   271→  outputData: string | null;\n   272→  claudeSessionId: string | null;\n   273→  modelUsed: string | null;\n   274→  inputTokens: number;\n   275→  outputTokens: number;\n   276→  costUsd: number;\n   277→  errorMessage: string | null;\n   278→  durationMs: number | null;\n   279→  retryOfExecutionId: string | null;\n   280→  retryCount: number;\n   281→  startedAt: string | null;\n   282→  completedAt: string | null;\n   283→  createdAt: string;\n   284→}\n   285→\n   286→// ---------------------------------------------------------------------------\n   287→// Execution request — produced to Kafka by Vibeman, consumed by orchestrator\n   288→// ---------------------------------------------------------------------------\n   289→\n   290→export interface ExecRequest {\n   291→  executionId: string;\n   292→  personaId: string;\n   293→  prompt: string;\n   294→  projectId?: string;\n   295→  credentialIds?: string[];\n   296→  inputData?: unknown;\n   297→  config: {\n   298→    timeoutMs: number;\n   299→    maxConcurrent?: number;\n   300→  };\n   301→  triggerId?: string;\n   302→  triggerType?: string;\n   303→  /** Originating event ID — enables bidirectional event↔execution tracing. */\n   304→  eventId?: string;\n   305→}\n   306→\n   307→// Execution result — produced to Kafka by orchestrator\n   308→export interface ExecResult {\n   309→  executionId: string;\n   310→  personaId: string;\n   311→  status: 'completed' | 'failed' | 'cancelled';\n   312→  exitCode: number;\n   313→  durationMs: number;\n   314→  sessionId?: string;\n   315→  totalCostUsd?: number;\n   316→  phaseTimings?: import('./protocol.js').PhaseTimings;\n   317→  error?: string;\n   318→}\n   319→\n   320→// Worker info as tracked by orchestrator\n   321→export interface WorkerInfo {\n   322→  workerId: string;\n   323→  status: 'connecting' | 'idle' | 'executing' | 'disconnected';\n   324→  version: string;\n   325→  capabilities: string[];\n   326→  currentExecutionId?: string;\n   327→  connectedAt: number;\n   328→  lastHeartbeat: number;\n   329→  imageDigest?: string;\n   330→  claudeCliVersion?: string;\n   331→  verified: boolean;\n   332→}\n   333→\n   334→// Execution output chunk — produced to Kafka for Vibeman SSE consumption\n   335→export interface OutputChunk {\n   336→  executionId: string;\n   337→  chunk: string;\n   338→  timestamp: number;\n   339→}\n   340→\n   341→// Persona event — forwarded from worker to Kafka event bus\n   342→export interface PersonaCloudEvent {\n   343→  executionId: string;\n   344→  personaId: string;\n   345→  eventType: import('./protocolRegistry.js').ProtocolEventType;\n   346→  payload: unknown;\n   347→  timestamp: number;\n   348→}\n   349→\n   350→// Execution progress (ephemeral — tracked in-memory + Kafka only)\n   351→export interface ProgressInfo {\n   352→  phase: string;\n   353→  percent: number;\n   354→  detail?: string;\n   355→  updatedAt: number;\n   356→}\n   357→\n   358→// Kafka topic names\n   359→export const TOPICS = {\n   360→  EXEC_REQUESTS: 'persona.exec.v1',\n   361→  EXEC_OUTPUT: 'persona.output.v1',\n   362→  EXEC_LIFECYCLE: 'persona.lifecycle.v1',\n   363→  EXEC_PROGRESS: 'persona.progress.v1',\n   364→  EVENTS: 'persona.events.v1',\n   365→  DLQ: 'persona.dlq.v1',\n   366→  QUEUE_METRICS: 'persona.queue_metrics.v1',\n   367→} as const;\n   368→\n   369→// Protocol version\n   370→export const PROTOCOL_VERSION = '0.2.0';\n   371→"}]},"parent_tool_use_id":null,"session_id":"15018505-e9e4-4fac-9bcf-20e5f9f9c2a8","uuid":"83ecca61-e403-4739-b010-341141946328","timestamp":"2026-03-19T08:12:59.660Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\shared\\src\\types.ts","content":"// ---------------------------------------------------------------------------\n// Persona domain types (mirroring desktop Tauri models)\n// ---------------------------------------------------------------------------\n\nexport interface Persona {\n  id: string;\n  projectId: string;\n  name: string;\n  description: string | null;\n  systemPrompt: string;\n  structuredPrompt: string | null;\n  icon: string | null;\n  color: string | null;\n  enabled: boolean;\n  maxConcurrent: number;\n  timeoutMs: number;\n  inferenceProfileId: string | null;\n  networkPolicy: string | null;\n  maxBudgetUsd: number | null;\n  maxTurns: number | null;\n  designContext: string | null;\n  groupId: string | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\n/** Lightweight projection for list views — omits large text fields. */\nexport interface PersonaSummary {\n  id: string;\n  projectId: string;\n  name: string;\n  description: string | null;\n  icon: string | null;\n  color: string | null;\n  enabled: boolean;\n  groupId: string | null;\n}\n\nexport interface PersonaToolDefinition {\n  id: string;\n  name: string;\n  category: string;\n  description: string;\n  scriptPath: string;\n  inputSchema: string | null;\n  outputSchema: string | null;\n  requiresCredentialType: string | null;\n  implementationGuide: string | null;\n  isBuiltin: boolean;\n  createdAt: string;\n  updatedAt: string;\n}\n\nexport interface StructuredPrompt {\n  identity?: string;\n  instructions?: string;\n  toolGuidance?: string;\n  examples?: string;\n  errorHandling?: string;\n  customSections?: Array<{ title?: string; label?: string; name?: string; key?: string; content?: string }>;\n  webSearch?: string;\n}\n\n// ---------------------------------------------------------------------------\n// Inference profiles\n// ---------------------------------------------------------------------------\n\nexport type InferenceProvider = 'claude' | 'ollama' | 'litellm' | 'openai-compatible' | 'custom';\n\nexport interface InferenceProviderEnvMapping {\n  envVar: string;\n  source: 'baseUrl' | 'authToken' | 'model';\n}\n\nexport interface InferenceProfile {\n  id: string;\n  projectId: string;\n  name: string;\n  provider: InferenceProvider;\n  model?: string;\n  baseUrl?: string;\n  authTokenEncrypted?: string;\n  authTokenIv?: string;\n  authTokenTag?: string;\n  envMappings: InferenceProviderEnvMapping[];\n  removeEnvKeys?: string[];\n  isPreset: boolean;\n  createdAt: string;\n  updatedAt: string;\n}\n\nexport interface PersonaCredential {\n  id: string;\n  projectId?: string;\n  name: string;\n  serviceType: string;\n  encryptedData: string;\n  iv: string;\n  tag: string;\n  metadata: string | null;\n  lastUsedAt: string | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\n// ---------------------------------------------------------------------------\n// Event lifecycle state machine\n// ---------------------------------------------------------------------------\n\n/** All valid event statuses. */\nexport type EventStatus = 'pending' | 'processing' | 'delivered' | 'skipped' | 'failed' | 'partial' | 'partial-retry';\n\n/** All valid EventStatus values as a runtime array (for CHECK constraints, etc.). */\nexport const EVENT_STATUSES: readonly EventStatus[] = [\n  'pending', 'processing', 'delivered', 'skipped', 'failed', 'partial', 'partial-retry',\n] as const;\n\n/**\n * Legal state transitions for persona events.\n * Key = current status, Value = set of statuses it may transition to.\n */\nexport const EVENT_TRANSITIONS: Readonly<Record<EventStatus, ReadonlySet<EventStatus>>> = {\n  'pending':       new Set<EventStatus>(['processing']),\n  'processing':    new Set<EventStatus>(['delivered', 'skipped', 'failed', 'partial', 'partial-retry', 'pending']),\n  'delivered':     new Set<EventStatus>([]),                       // terminal\n  'skipped':       new Set<EventStatus>([]),                       // terminal\n  'failed':        new Set<EventStatus>([]),                       // terminal\n  'partial':       new Set<EventStatus>(['partial-retry']),        // can retry partial failures\n  'partial-retry': new Set<EventStatus>(['processing']),           // retried partial goes back through processing\n};\n\n/**\n * Validate that a transition from `from` → `to` is legal.\n * Throws if the transition is invalid.\n */\nexport function validateEventTransition(from: EventStatus, to: EventStatus): void {\n  const allowed = EVENT_TRANSITIONS[from];\n  if (!allowed || !allowed.has(to)) {\n    throw new Error(`Invalid event status transition: '${from}' → '${to}'`);\n  }\n}\n\nexport interface PersonaEvent {\n  id: string;\n  projectId: string;\n  eventType: string;\n  sourceType: string;\n  sourceId: string | null;\n  targetPersonaId: string | null;\n  payload: string | null;\n  status: EventStatus;\n  errorMessage: string | null;\n  processedAt: string | null;\n  useCaseId: string | null;\n  retryAfter: string | null;\n  retryCount: number;\n  createdAt: string;\n}\n\nexport interface PersonaEventSubscription {\n  id: string;\n  personaId: string;\n  eventType: string;\n  sourceFilter: string | null;\n  enabled: boolean;\n  useCaseId: string | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\n// ---------------------------------------------------------------------------\n// Trigger config discriminated union\n// ---------------------------------------------------------------------------\n\nexport type TriggerType = 'manual' | 'schedule' | 'polling' | 'webhook' | 'chain';\n\ninterface TriggerConfigBase {\n  event_type?: string;\n  payload?: unknown;\n}\n\nexport interface ScheduleTriggerConfig extends TriggerConfigBase {\n  kind: 'schedule';\n  cron?: string;\n  interval_seconds?: number;\n}\n\nexport interface ManualTriggerConfig extends TriggerConfigBase {\n  kind: 'manual';\n}\n\nexport interface PollingTriggerConfig extends TriggerConfigBase {\n  kind: 'polling';\n  poll_url?: string;\n  poll_interval_seconds?: number;\n}\n\nexport interface WebhookTriggerConfig extends TriggerConfigBase {\n  kind: 'webhook';\n  url?: string;\n  secret?: string;\n}\n\nexport interface ChainTriggerConfig extends TriggerConfigBase {\n  kind: 'chain';\n  source_persona_id?: string;\n  source_event_type?: string;\n}\n\nexport type TriggerConfig =\n  | ScheduleTriggerConfig\n  | ManualTriggerConfig\n  | PollingTriggerConfig\n  | WebhookTriggerConfig\n  | ChainTriggerConfig;\n\nexport interface PersonaTrigger {\n  id: string;\n  personaId: string;\n  triggerType: TriggerType;\n  config: string | null;\n  enabled: boolean;\n  lastTriggeredAt: string | null;\n  nextTriggerAt: string | null;\n  useCaseId: string | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\nexport type TriggerFireStatus = 'fired' | 'completed' | 'failed';\n\nexport interface TriggerFire {\n  id: string;\n  triggerId: string;\n  eventId: string | null;\n  executionId: string | null;\n  status: TriggerFireStatus;\n  durationMs: number | null;\n  errorMessage: string | null;\n  firedAt: string;\n}\n\nexport interface TriggerStats {\n  totalFires: number;\n  successCount: number;\n  failureCount: number;\n  successRate: number;\n  avgDurationMs: number | null;\n  lastFireStatus: TriggerFireStatus | null;\n  lastFiredAt: string | null;\n}\n\n/** Fully hydrated persona with all related entities. */\nexport interface HydratedPersona extends Persona {\n  tools: PersonaToolDefinition[];\n  credentials: Omit<PersonaCredential, 'encryptedData' | 'iv' | 'tag'>[];\n  subscriptions: PersonaEventSubscription[];\n  triggers: PersonaTrigger[];\n}\n\nexport interface PersonaExecution {\n  id: string;\n  projectId?: string;\n  personaId: string;\n  triggerId: string | null;\n  useCaseId: string | null;\n  /** Originating event ID — enables bidirectional event↔execution tracing. */\n  eventId: string | null;\n  status: string;\n  inputData: string | null;\n  outputData: string | null;\n  claudeSessionId: string | null;\n  modelUsed: string | null;\n  inputTokens: number;\n  outputTokens: number;\n  costUsd: number;\n  errorMessage: string | null;\n  durationMs: number | null;\n  retryOfExecutionId: string | null;\n  retryCount: number;\n  startedAt: string | null;\n  completedAt: string | null;\n  createdAt: string;\n}\n\n// ---------------------------------------------------------------------------\n// Execution request — produced to Kafka by Vibeman, consumed by orchestrator\n// ---------------------------------------------------------------------------\n\nexport interface ExecRequest {\n  executionId: string;\n  personaId: string;\n  prompt: string;\n  projectId?: string;\n  credentialIds?: string[];\n  inputData?: unknown;\n  config: {\n    timeoutMs: number;\n    maxConcurrent?: number;\n  };\n  triggerId?: string;\n  triggerType?: string;\n  /** Originating event ID — enables bidirectional event↔execution tracing. */\n  eventId?: string;\n}\n\n// Execution result — produced to Kafka by orchestrator\nexport interface ExecResult {\n  executionId: string;\n  personaId: string;\n  status: 'completed' | 'failed' | 'cancelled';\n  exitCode: number;\n  durationMs: number;\n  sessionId?: string;\n  totalCostUsd?: number;\n  phaseTimings?: import('./protocol.js').PhaseTimings;\n  error?: string;\n}\n\n// Worker info as tracked by orchestrator\nexport interface WorkerInfo {\n  workerId: string;\n  status: 'connecting' | 'idle' | 'executing' | 'disconnected';\n  version: string;\n  capabilities: string[];\n  currentExecutionId?: string;\n  connectedAt: number;\n  lastHeartbeat: number;\n  imageDigest?: string;\n  claudeCliVersion?: string;\n  verified: boolean;\n}\n\n// Execution output chunk — produced to Kafka for Vibeman SSE consumption\nexport interface OutputChunk {\n  executionId: string;\n  chunk: string;\n  timestamp: number;\n}\n\n// Persona event — forwarded from worker to Kafka event bus\nexport interface PersonaCloudEvent {\n  executionId: string;\n  personaId: string;\n  eventType: import('./protocolRegistry.js').ProtocolEventType;\n  payload: unknown;\n  timestamp: number;\n}\n\n// Execution progress (ephemeral — tracked in-memory + Kafka only)\nexport interface ProgressInfo {\n  phase: string;\n  percent: number;\n  detail?: string;\n  updatedAt: number;\n}\n\n// Kafka topic names\nexport const TOPICS = {\n  EXEC_REQUESTS: 'persona.exec.v1',\n  EXEC_OUTPUT: 'persona.output.v1',\n  EXEC_LIFECYCLE: 'persona.lifecycle.v1',\n  EXEC_PROGRESS: 'persona.progress.v1',\n  EVENTS: 'persona.events.v1',\n  DLQ: 'persona.dlq.v1',\n  QUEUE_METRICS: 'persona.queue_metrics.v1',\n} as const;\n\n// Protocol version\nexport const PROTOCOL_VERSION = '0.2.0';\n","numLines":371,"startLine":1,"totalLines":371}}}
