   42→    return true;\n    43→  }\n    44→  if (pathname === '/api/token' && method === 'POST') {\n    45→    await handleSetToken(req, res, tokenManager, logger, auditLog, ip);\n    46→    return true;\n    47→  }\n    48→  // Unrecognised OAuth/token sub-path\n    49→  json(res, 404, { error: 'Not found' });\n    50→  return false;\n    51→}\n    52→\n    53→// --- OAuth handlers ---\n    54→\n    55→function handleOAuthAuthorize(res: http.ServerResponse, oauth: OAuthManager, auditLog?: AuditLog, ip?: string): void {\n    56→  const { url, state } = oauth.generateAuthUrl();\n    57→  try { auditLog?.record({ action: 'oauth:authorize', resourceType: 'oauth', resourceId: state, ipAddress: ip }); } catch { /* logged inside record() */ }\n    58→  json(res, 200, {\n    59→    authUrl: url,\n    60→    state,\n    61→    instructions: [\n    62→      '1. Open the authUrl in a browser',\n    63→      '2. Log in with your Anthropic account and authorize',\n    64→      '3. You will be redirected to a page showing an authorization code',\n    65→      '4. Copy the code from the URL (the \"code\" query parameter)',\n    66→      '5. POST it to /api/oauth/callback with { \"code\": \"...\", \"state\": \"...\" }',\n    67→    ],\n    68→  });\n    69→}\n    70→\n    71→async function handleOAuthCallback(\n    72→  req: http.IncomingMessage,\n    73→  res: http.ServerResponse,\n    74→  oauth: OAuthManager,\n    75→  tokenManager: TokenManager,\n    76→  logger: Logger,\n    77→  auditLog?: AuditLog,\n    78→  ip?: string,\n    79→): Promise<void> {\n    80→  const body = await readBody(req);\n    81→  let parsed: { code?: string; state?: string };\n    82→\n    83→  try {\n    84→    parsed = JSON.parse(body);\n    85→  } catch {\n    86→    json(res, 400, { error: 'Invalid JSON body' });\n    87→    return;\n    88→  }\n    89→\n    90→  if (!parsed.code || !parsed.state) {\n    91→    json(res, 400, { error: 'Missing required fields: code, state' });\n    92→    return;\n 