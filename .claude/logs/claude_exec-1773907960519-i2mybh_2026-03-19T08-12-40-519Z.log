rs = process.env['KAFKA_BROKERS'] || '';\n    58→\n    59→  const dataDir = process.env['DAC_DATA_DIR'] || path.join(process.cwd(), 'data');\n    60→\n    61→  return {\n    62→    masterKey: required('MASTER_KEY'),\n    63→    claudeToken: process.env['CLAUDE_TOKEN'] || '',  // Optional: use OAuth flow if not provided\n    64→    teamApiKey: required('TEAM_API_KEY'),\n    65→    workerToken: required('WORKER_TOKEN'),\n    66→    kafkaBrokers,\n    67→    kafkaUsername: process.env['KAFKA_USERNAME'] || '',\n    68→    kafkaPassword: process.env['KAFKA_PASSWORD'] || '',\n    69→    kafkaEnabled: kafkaBrokers.length > 0,\n    70→    supabaseJwtSecret: process.env['SUPABASE_JWT_SECRET'] || '',\n    71→    wsPort: parseInt(optional('WS_PORT', '8443'), 10),\n    72→    httpPort: parseInt(optional('HTTP_PORT', '3001'), 10),\n    73→    // TLS\n    74→    tlsEnabled: process.env['TLS_ENABLED'] !== 'false',\n    75→    tlsCertPath: process.env['TLS_CERT_PATH'] || '',\n    76→    tlsKeyPath: process.env['TLS_KEY_PATH'] || '',\n    77→    tlsCaPath: process.env['TLS_CA_PATH'] || '',\n    78→    tlsRequireClientCert: process.env['TLS_REQUIRE_CLIENT_CERT'] === 'true',\n    79→    // Output scrubbing\n    80→    scrubberEnabled: process.env['SCRUBBER_ENABLED'] !== 'false',\n    81→    // Audit\n    82→    auditDbPath: process.env['AUDIT_DB_PATH'] || path.join(dataDir, 'audit.db'),\n    83→    auditRetentionDays: parseInt(process.env['AUDIT_RETENTION_DAYS'] || '90', 10),\n    84→    tokenExpiryWarningMinutes: parseInt(process.env['TOKEN_EXPIRY_WARNING_MINUTES'] || '30', 10),\n    85→    // Retention\n    86→    retentionDays: parseInt(process.env['RETENTION_DAYS'] || '30', 10),\n    87→    metricsRetentionDays: parseInt(process.env['METRICS_RETENTION_DAYS'] || '365', 10),\n    88→    // Data directory\n    89→    dataDir,\n    90→    // Worker verification\n    91→    allowedImageDigests: (process.env['ALLOWED_IMAGE_DIGESTS'] || '').split(',').map(s => s.trim()).filter(Boolean),\