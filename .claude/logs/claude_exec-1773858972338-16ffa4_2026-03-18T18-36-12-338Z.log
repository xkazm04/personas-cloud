key, entry] of this.pendingStates) {\n    44→      if (now > entry.expiresAt) {\n    45→        this.pendingStates.delete(key);\n    46→        swept++;\n    47→      }\n    48→    }\n    49→    if (swept > 0) {\n    50→      this.logger.debug({ swept, remaining: this.pendingStates.size }, 'Swept expired OAuth states');\n    51→    }\n    52→  }\n    53→\n    54→  /**\n    55→   * POST to the OAuth token endpoint, parse the response, and map to OAuthTokens.\n    56→   * Callers supply only the grant-specific body fields and a scope fallback.\n    57→   */\n    58→  private async postTokenEndpoint(\n    59→    body: Record<string, string>,\n    60→    fallbackScopes: string[],\n    61→    context: string,\n    62→  ): Promise<OAuthTokens | null> {\n    63→    try {\n    64→      const response = await fetch(OAUTH_TOKEN_URL, {\n    65→        method: 'POST',\n    66→        headers: {\n    67→          'Content-Type': 'application/json',\n    68→          'Accept': 'application/json',\n    69→        },\n    70→        body: JSON.stringify(body),\n    71→      });\n    72→\n    73→      if (!response.ok) {\n    74→        const errorText = await response.text();\n    75→        this.logger.error({ status: response.status, error: errorText }, `OAuth ${context} failed`);\n    76→        return null;\n    77→      }\n    78→\n    79→      const data = await response.json() as {\n    80→        access_token: string;\n    81→        refresh_token: string;\n    82→        expires_in: number;\n    83→        scope?: string;\n    84→      };\n    85→\n    86→      return {\n    87→        accessToken: data.access_token,\n    88→        refreshToken: data.refresh_token,\n    89→        expiresAt: Date.now() + data.expires_in * 1000,\n    90→        scopes: data.scope ? data.scope.split(' ') : fallbackScopes,\n    91→      };\n    92→    } catch (err) {\n    93→      this.logger.error({ err }, `OAuth ${context} request failed`);\n    94→      return null;\n    95→    }\n    96→  }\n    97→\n    98→  /**\n    99→   * Step 1: Generate the authorization URL for the user to visit.\n   100→   * Returns the URL and stores PKCE state internally.\n   101→   */\n   102→  generateAuthUrl(): { url: string; state: string } {\n   103→    const state = randomBytes(32).toString('hex');\n   104→    const codeVerifier = randomBytes(32).toString('base64url');\n   105→    const codeChallenge = createHash('sha256')\n   106→      .update(codeVerifier)\n   107→      .digest('base64url');\n   108→\n   109→    const oauthState: OAuthState = {\n   110→      state,\n   111→      codeVerifier,\n   112→      createdAt: Date.now(),\n   113→      expiresAt: Date.now() + 10 * 60 * 1000, // 10 minutes\n   114→    };\n   115→\n   116→    this.pendingStates.set(state, oauthState);\n   117→\n   118→    const params = new URLSearchParams({\n   119→      code: 'true',\n   120→      client_id: CLIENT_ID,\n   121→      response_type: 'code',\n   122→      redirect_uri: REDIRECT_URI,\n   123→      scope: SCOPES,\n   124→      code_challenge: codeChallenge,\n   125→      code_challenge_method: 'S256',\n   126→      state,\n   127→    });\n   128→\n   129→    const url = `${OAUTH_AUTHORIZE_URL}?${params.toString()}`;\n   130→\n   131→    this.logger.info('Generated OAuth authorization URL');\n   132→    return { url, state };\n   133→  }\n   134→\n   135→  /**\n   136→   * Step 2: Exchange the authorization code for tokens.\n   137→   * Called after user completes the OAuth flow and provides the code.\n   138→   */\n   139→  async exchangeCode(authorizationCode: string, state: string): Promise<OAuthTokens | null> {\n   140→    // Validate state\n   141→    const pending = this.pendingStates.get(state);\n   142→    if (!pending) {\n   143→      this.logger.error('OAuth state not found or already consumed');\n   144→      return null;\n   145→    }\n   146→\n   147→    if (Date.now() > pending.expiresAt) {\n   148→      this.logger.error('OAuth state expired');\n   149→      this.p