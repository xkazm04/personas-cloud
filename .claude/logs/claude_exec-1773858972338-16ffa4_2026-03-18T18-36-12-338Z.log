tokens.scopes,\n   101→    expiresAt: new Date(tokens.expiresAt).toISOString(),\n   102→  });\n   103→}\n   104→\n   105→function handleOAuthStatus(res: http.ServerResponse, oauth: OAuthManager): void {\n   106→  const tokens = oauth.getTokens();\n   107→  json(res, 200, {\n   108→    connected: oauth.hasTokens(),\n   109→    scopes: tokens?.scopes || [],\n   110→    expiresAt: tokens ? new Date(tokens.expiresAt).toISOString() : null,\n   111→    isExpired: tokens ? Date.now() > tokens.expiresAt : null,\n   112→  });\n   113→}\n   114→\n   115→async function handleOAuthRefresh(\n   116→  res: http.ServerResponse,\n   117→  oauth: OAuthManager,\n   118→  tokenManager: TokenManager,\n   119→  logger: Logger,\n   120→): Promise<void> {\n   121→  const tokens = await oauth.refreshAccessToken();\n   122→  if (!tokens) {\n   123→    json(res, 500, { error: 'Token refresh failed' });\n   124→    return;\n   125→  }\n   126→\n   127→  tokenManager.storeClaudeToken(tokens.accessToken);\n   128→  logger.info('OAuth token refreshed via API');\n   129→\n   130→  json(res, 200, {\n   131→    status: 'refreshed',\n   132→    expiresAt: new Date(tokens.expiresAt).toISOString(),\n   133→  });\n   134→}\n   135→\n   136→async function handleOAuthDisconnect(\n   137→  res: http.ServerResponse,\n   138→  oauth: OAuthManager,\n   139→  tokenManager: TokenManager,\n   140→  logger: Logger,\n   141→): Promise<void> {\n   142→  const { revoked } = await oauth.revokeAndClearTokens();\n   143→  tokenManager.clearToken();\n   144→\n   145→  if (!revoked) {\n   146→    logger.warn('OAuth tokens cleared locally but server-side revocation failed or was skipped');\n   147→  }\n   148→\n   149→  json(res, 200, { status: 'disconnected', serverRevoked: revoked });\n   150→}\n   151→\n   152→// --- Token injection ---\n   153→\n   154→async function handleSetToken(\n   155→  req: http.IncomingMessage,\n   156→  res: http.ServerResponse,\n   157→  tokenManager: TokenManager,\n   158→  logger: Logger,\n   159→): Promise<void> {\n   160→  const body = await readBody(req);\n   161→  let parsed: { token?: string };\n   162→\n   163→  try {\n   164→    parsed = JSON.parse(body);\n   165→  } catch {\n   166→    json(res, 400, { error: 'Invalid JSON body' });\n   167→    return;\n   168→  }\n   169→\n   170→  const token = typeof parsed.token === 'string' ? parsed.token.trim() : '';\n   171→\n   172→  if (!token) {\n   173→    json(res, 400, { error: 'Missing required field: token' });\n   174→    return;\n   175→  }\n   176→\n   177→  if (!token.startsWith('sk-ant-')) {\n   178→    json(res, 400, { error: 'Invalid token format: expected Anthropic API key starting with sk-ant-' });\n   179→    return;\n   180→  }\n   181→\n   182→  tokenManager.storeClaudeToken(token);\n   183→  logger.info('Claude token set via direct injection');\n   184→\n   185→  json(res, 200, { status: 'token_stored' });\n   186→}\n   187→\n   188→"}]},"parent_tool_use_id":null,"session_id":"326c1f74-f14e-454f-88fa-febf4d1ed560","uuid":"d8251ca6-af27-40d9-a6a7-0167f8b229e2","timestamp":"2026-03-18T18:36:29.218Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\oauthHttpHandlers.ts","content":"import http from 'node:http';\nimport type { OAuthManager } from './oauth.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { Logger } from 'pino';\nimport { readBody, json } from './httpUtils.js';\n\n/**\n * Attempt to handle an OAuth or token-injection route.\n * Returns `true` if the route was matched and handled, `false` otherwise.\n * Caller is responsible for auth/admin checks before invoking this.\n */\nexport async function handleOAuthRoute(\n  pathname: string,\n  method: string,\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  oauth: OAuthManager,\n  tokenManager: TokenManager,\n  logger: Logger,\n): Promise<boolean> {\n  if (pathname === '/api/oauth/authorize' && method === 'POST') {\n    handleOAuthAuthorize(res, oauth);\n    return true;\n  }\n  if (pathname === '/api/oauth/callback' && method === 'POST') {\n    await handleOAuthCallback(req, res, oauth, tokenManager, logger);\n    return true;\n  }\n  if (pathname === '/api/oauth/status' && method === 'GET') {\n    handleOAuthStatus(res, oauth);\n    return true;\n  }\n  if (pathname === '/api/oauth/refresh' && method === 'POST') {\n    await handleOAuthRefresh(res, oauth, tokenManager, logger);\n    return true;\n  }\n  if (pathname === '/api/oauth/disconnect' && method === 'DELETE') {\n    await handleOAuthDisconnect(res, oauth, tokenManager, logger);\n    return true;\n  }\n  if (pathname === '/api/token' && method === 'POST') {\n    await handleSetToken(req, res, tokenManager, logger);\n    return true;\n  }\n  // Unrecognised OAuth/token sub-path\n  json(res, 404, { error: 'Not found' });\n  return false;\n}\n\n// --- OAuth handlers ---\n\nfunction handleOAuthAuthorize(res: http.ServerResponse, oauth: OAuthManager): void {\n  const { url, state } = oauth.generateAuthUrl();\n  json(res, 200, {\n    authUrl: url,\n    state,\n    instructions: [\n      '1. Open the authUrl in a browser',\n      '2. Log in with your Anthropic account and authorize',\n      '3. You will be redirected to a page showing an authorization code',\n      '4. Copy the code from the URL (the \"code\" query parameter)',\n      '5. POST it to /api/oauth/callback with { \"code\": \"...\", \"state\": \"...\" }',\n    ],\n  });\n}\n\nasync function handleOAuthCallback(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  oauth: OAuthManager,\n  tokenManager: TokenManager,\n  logger: Logger,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { code?: string; state?: string };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    json(res, 400, { error: 'Invalid JSON body' });\n    return;\n  }\n\n  if (!parsed.code || !parsed.state) {\n    json(res, 400, { error: 'Missing required fields: code, state' });\n    return;\n  }\n\n  const tokens = await oauth.exchangeCode(parsed.code, parsed.state);\n  if (!tokens) {\n    json(res, 401, { error: 'OAuth token exchange failed' });\n    return;\n  }\n\n  tokenManager.storeClaudeToken(tokens.accessToken);\n  logger.info('OAuth flow completed, subscription connected');\n\n  json(res, 200, {\n    status: 'connected',\n    scopes: tokens.scopes,\n    expiresAt: new Date(tokens.expiresAt).toISOString(),\n  });\n}\n\nfunction handleOAuthStatus(res: http.ServerResponse, oauth: OAuthManager): void {\n  const tokens = oauth.getTokens();\n  json(res, 200, {\n    connected: oauth.hasTokens(),\n    scopes: tokens?.scopes || [],\n    expiresAt: tokens ? new Date(tokens.expiresAt).toISOString() : null,\n    isExpired: tokens ? Date.now() > tokens.expiresAt : null,\n  });\n}\n\nasync function handleOAuthRefresh(\n  res: http.ServerResponse,\n  oauth: OAuthManager,\n  tokenManager: TokenManager,\n  logger: Logger,\n): Promise<void> {\n  const tokens = await oauth.refreshAccessToken();\n  if (!tokens) {\n    json(res, 500, { error: 'Token refresh failed' });\n    return;\n  }\n\n  tokenManager.storeClaudeToken(tokens.accessToken);\n  logger.info('OAuth token refreshed via API');\n\n  json(res, 200, {\n    status: 'refreshed',\n    expiresAt: new Date(tokens.expiresAt).toISOString(),\n  });\n}\n\nasync function handleOAuthDisconnect(\n  res: http.ServerResponse,\n  oauth: OAuthManager,\n  tokenManager: TokenManager,\n  logger: Logger,\n): Promise<void> {\n  const { revoked } = await oauth.revokeAndClearTokens();\n  tokenManager.clearToken();\n\n  if (!revoked) {\n    logger.warn('OAuth tokens cleared locally but server-side revocation failed or was skipped');\n  }\n\n  json(res, 200, { status: 'disconnected', serverRevoked: revoked });\n}\n\n// --- Token injection ---\n\nasync function handleSetToken(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  tokenManager: TokenManager,\n  logger: Logger,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { token?: string };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    json(res, 400, { error: 'Invalid JSON body' });\n    return;\n  }\n\n  const token = typeof parsed.token === 'string' ? parsed.token.trim() : '';\n\n  if (!token) {\n    json(res, 400, { error: 'Missing required field: token' });\n    return;\n  }\n\n  if (!token.startsWith('sk-ant-')) {\n    json(res, 400, { error: 'Invalid token format: expected Anthropic API key starting with sk-ant-' });\n    return;\n  }\n\n  tokenManager.storeClaudeToken(token);\n  logger.info('Claude token set via direct injection');\n\n  json(res, 200, { status: 'token_stored' });\n}\n\n","numLines":188,"startLine":1,"totalLines":188}}}
