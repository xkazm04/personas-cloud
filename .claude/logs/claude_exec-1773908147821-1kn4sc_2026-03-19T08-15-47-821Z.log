[2026-03-19T08:15:58.390Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T9AEUi3XFkG2YyVXSVES1j","type":"tool_result","content":"     1→import { type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type PhaseTimings, type EncryptedPayload, TOPICS, decrypt, DecryptionError, deriveMasterKeyAsync } from '@dac-cloud/shared';\n     2→import type Database from 'better-sqlite3';\n     3→import type { WorkerPool } from './workerPool.js';\n     4→import type { TokenManager } from './tokenManager.js';\n     5→import type { OAuthManager } from './oauth.js';\n     6→import type { KafkaClient } from './kafka.js';\n     7→import type { TenantDbManager } from './tenantDbManager.js';\n     8→import type { TenantKeyManager } from './tenantKeyManager.js';\n     9→import type { AuditLog } from './auditLog.js';\n    10→import type { Logger } from 'pino';\n    11→import * as db from './db/index.js';\n    12→import { resolveToken, ExecutionPreparer, type Decryptor } from './dispatchPipeline.js';\n    13→\n    14→interface QueuedExecution {\n    15→  request: ExecRequest;\n    16→  receivedAt: number;\n    17→}\n    18→\n    19→// Maximum number of times an execution will be re-queued after worker disconnect\n    20→const MAX_DISCONNECT_RETRIES = 2;\n    21→\n    22→/** Backpressure configuration for the dispatch queue. */\n    23→export interface QueueBackpressureConfig {\n    24→  /** Maximum total queue depth. Submissions beyond this are rejected. 0 = unlimited. */\n    25→  maxQueueDepth: number;\n    26→  /** Queue depth at which a warning metric is emitted. 0 = disabled. */\n    27→  warningThreshold: number;\n    28→  /** Queue depth at which a critical metric is emitted. 0 = disabled. */\n    29→  criticalThreshold: number;\n    30→  /** Maximum queued items per tenant. 0 = unlimited (no per-tenant quota). */\n    31→  perTenantQuota: number;\n    32→  /** Retry-After value (seconds) included in rejection results. */\n    33→  retryAfterSeconds: number;\n    34→}\n    35→\n    36→/** Result of a submit() call — either accepted or rejected with a reason. */\n    37→export type SubmitResult =\n    38→  | { accepted: true }\n    39→  | { accepted: false; reason: 'queue_full' | 'tenant_quota_exceeded'; retryAfterSeconds: number };\n    40→\n    41→/** Which threshold band the queue is currently in. */\n    42→type ThresholdLevel = 'normal' | 'warning' | 'critical';\n    43→\n    44→/** All valid execution statuses. */\n    45→type ExecutionStatus = 'queued' | 'running' | 'completed' | 'failed' | 'cancelled';\n    46→\n    47→/** What triggered a state transition. */\n    48→type TransitionTrigger =\n    49→  | 'submit'\n    50→  | 'dispatch'\n    51→  | 'complete'\n    52→  | 'busy-nack'\n    53→  | 'disconnect-retry'\n    54→  | 'disconnect-exhausted'\n    55→  | 'assign-failure';\n    56→\n    57→// In-memory tracking for active executions (real-time output streaming)\n    58→interface ActiveExecution {\n    59→  workerId: string;\n    60→  startedAt: number;\n    61→  output: string[];\n    62→  status: 'running' | 'completed' | 'failed' | 'cancelled';\n    63→  progress?: ProgressInfo;\n    64→  completedAt?: number;\n    65→  exitCode?: number;\n    66→  durationMs?: number;\n    67→  sessionId?: string;\n    68→  totalCostUsd?: number;\n    69→  phaseTimings?: PhaseTimings;\n    70→  /** Original request kept for re-queuing on worker disconnect. Only present for in-flight executions. */\n    71→  request?: ExecRequest;\n    72→  /** How many times this execution has been re-queued after a worker disconnect. */\n    73→  disconnectRetries?: number;\n    74→}\n    75→\n    76→const OUTPUT_FLUSH_INTERVAL_MS = 500;\n    77→\n    78→export class Dispatcher {\n    79→  private queue: QueuedExecution[] = [];\n    80→  // In-memory map for real-time output + cancel routing (active executions only)\n    81→  private active = new Map<string, ActiveExecution>();\n    82→  private tenantDbManager: TenantDbManager | null = null;\n    83→  private masterKey: Buffer | null = null;\n    84→  private tenantKeyManager: TenantKeyManager | null = null;\n    85→  private auditLog: AuditLog | null = null;\n    86→  private preparer: ExecutionPreparer | null = null;\n    87→  // Maps executionId → projectId for DB resolution during callbacks\n    88→  private executionTenant = new Map<string, string>();\n    89→  // Batched output buffers: executionId → pending chunks\n    90→  private outputBuffers = new Map<string, string[]>();\n    91→  private outputFlushTimer: NodeJS.Timeout;\n    92→  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n    93→  private dispatching = false;\n    94→  // Backpressure state\n    95→  private backpressure: QueueBackpressureConfig;\n    96→  private tenantQueueCounts = new Map<string, number>();\n    97→  private currentThresholdLevel: ThresholdLevel = 'normal';\n    98→\n    99→  constructor(\n   100→    private pool: WorkerPool,\n   101→    private tokenManager: TokenManager,\n   102→    private oauth: OAuthManager | null,\n   103→    private kafka: KafkaClient,\n   104→    private logger: Logger,\n   105→    backpressureConfig?: Partial<QueueBackpressureConfig>,\n   106→  ) {\n   107→    this.backpressure = {\n   108→      maxQueueDepth: backpressureConfig?.maxQueueDepth ?? 1000,\n   109→      warningThreshold: backpressureConfig?.warningThreshold ?? 500,\n   110→      criticalThreshold: backpressureConfig?.criticalThreshold ?? 800,\n   111→      perTenantQuota: backpressureConfig?.perTenantQuota ?? 0,\n   112→      retryAfterSeconds: backpressureConfig?.retryAfterSeconds ?? 30,\n   113→    };\n   114→    // Periodic flush of batched output to DB\n   115→    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n   116→\n   117→    // When a worker becomes ready, try to dispatch queued work\n   118→    this.pool.on('worker-ready', () => {\n   119→      this.processQueue();\n   120→    });\n   121→\n   122→    // When a worker connects, try to dispatch\n   123→    this.pool.on('worker-connected', () => {\n   124→      this.processQueue();\n   125→    });\n   126→\n   127→    // Track stdout for execution output\n   128→    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n   129→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n   130→    });\n   131→\n   132→    // Track stderr for debugging failed executions\n   133→    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n   134→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n   135→      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n   136→    });\n   137→\n   138→    // Handle execution completion\n   139→    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n   140→      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   141→        executionId: msg.executionId,\n   142→        status: msg.status,\n   143→        exitCode: msg.exitCode,\n   144→        durationMs: msg.durationMs,\n   145→        sessionId: msg.sessionId,\n   146→        totalCostUsd: msg.totalCostUsd,\n   147→        ...(msg.phaseTimings ? { phaseTimings: msg.phaseTimings } : {}),\n   148→      }), msg.executionId).catch(err => {\n   149→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n   150→      });\n   151→\n   152→      // Flush any remaining buffered output before persisting completion\n   153→      this.flushOutputForExecution(msg.executionId);\n   154→\n   155→      // Update in-memory\n   156→      const exec = this.active.get(msg.executionId);\n   157→      const terminalStatus: ExecutionStatus = msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed';\n   158→      this.logTransition({\n   159→        executionId: msg.executionId,\n   160→        previousState: 'running',\n   161→        newState: terminalStatus,\n   162→        trigger: 'complete',\n   163→        workerId: exec?.workerId,\n   164→        disconnectRetries: exec?.disconnectRetries ?? 0,\n   165→      });\n   166→      if (exec) {\n   167→        exec.status = msg.status;\n   168→        exec.completedAt = Date.now();\n   169→        exec.exitCode = msg.exitCode;\n   170→        exec.durationMs = msg.durationMs;\n   171→        exec.sessionId = msg.sessionId;\n   172→        exec.totalCostUsd = msg.totalCostUsd;\n   173→        exec.phaseTimings = msg.phaseTimings;\n   174→        // Remove from active after a short delay (allow polling to pick up final state)\n   175→        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n   176→      }\n   177→\n   178→      // Persist to DB\n   179→      const completeDb = this.resolveDbForExecution(msg.executionId);\n   180→      if (completeDb) {\n   181→        try {\n   182→          db.updateExecution(completeDb, msg.executionId, {\n   183→            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n   184→            completedAt: new Date().toISOString(),\n   185→            durationMs: msg.durationMs,\n   186→            claudeSessionId: msg.sessionId,\n   187→            costUsd: msg.totalCostUsd ?? 0,\n   188→          });\n   189→        } catch (err) {\n   190→          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n   191→        }\n   192→      }\n   193→\n   194→      // Clean up tenant mapping after completion delay\n   195→      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n   196→\n   197→      // Process next queued item\n   198→      this.processQueue();\n   199→    });\n   200→\n   201→    // Track execution progress\n   202→    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n   203→      const exec = this.active.get(msg.executionId);\n   204→      if (exec) {\n   205→        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n   206→      }\n   207→      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n   208→        executionId: msg.executionId,\n   209→        phase: msg.phase,\n   210→        percent: msg.percent,\n   211→        detail: msg.detail,\n   212→        timestamp: msg.timestamp,\n   213→      }), msg.executionId).catch(err => {\n   214→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n   215→      });\n   216→    });\n   217→\n   218→    // Forward persona events to Kafka\n   219→    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n   220→      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n   221→        executionId: msg.executionId,\n   222→        eventType: msg.eventType,\n   223→        payload: msg.payload,\n   224→        timestamp: Date.now(),\n   225→      }), msg.executionId).catch(err => {\n   226→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n   227→      });\n   228→    });\n   229→\n   230→    // Handle worker busy nack — re-queue the rejected execution\n   231→    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n   232→      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n   233→      const exec = this.active.get(msg.executionId);\n   234→      if (exec?.request) {\n   235→        const request = exec.request;\n   236→        this.logTransition({\n   237→          executionId: msg.executionId,\n   238→          previousState: 'running',\n   239→          newState: 'queued',\n   240→          trigger: 'busy-nack',\n   241→          workerId: _workerId,\n   242→          personaId: request.personaId,\n   243→          disconnectRetries: exec.disconnectRetries ?? 0,\n   244→        });\n   245→        this.active.delete(msg.executionId);\n   246→        // Mark as queued in DB\n   247→        const reqDb = this.resolveDbForExecution(msg.executionId);\n   248→        if (reqDb) {\n   249→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack'); }\n   250→        }\n   251→        this.queue.unshift({ request, receivedAt: Date.now() });\n   252→        this.processQueue();\n   253→      } else {\n   254→        // Fallback: reconstruct from DB if request was not stored (should not happen)\n   255→        this.logTransition({\n   256→          executionId: msg.executionId,\n   257→          previousState: 'running',\n   258→          newState: 'queued',\n   259→          trigger: 'busy-nack',\n   260→          workerId: _workerId,\n   261→        });\n   262→        this.active.delete(msg.executionId);\n   263→        const projectId = this.executionTenant.get(msg.executionId) || 'default';\n   264→        const reqDb = this.resolveDb(projectId);\n   265→        if (reqDb) {\n   266→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack fallback'); }\n   267→        }\n   268→        const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n   269→        if (dbExec) {\n   270→          this.queue.unshift({\n   271→            request: {\n   272→              executionId: msg.executionId,\n   273→              personaId: dbExec.personaId,\n   274→              prompt: dbExec.inputData || '',\n   275→              projectId,\n   276→              config: { timeoutMs: 300_000 },\n   277→            },\n   278→            receivedAt: Date.now(),\n   279→          });\n   280→          this.processQueue();\n   281→        }\n   282→      }\n   283→    });\n   284→\n   285→    // Handle worker disconnect during execution — re-queue if retries remain\n   286→    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n   287→      if (executionId) {\n   288→        const exec = this.active.get(executionId);\n   289→        const retries = exec?.disconnectRetries ?? 0;\n   290→\n   291→        if (exec?.request && retries < MAX_DISCONNECT_RETRIES) {\n   292→          // Re-queue for retry\n   293→          const nextRetry = retries + 1;\n   294→          this.logTransition({\n   295→            executionId,\n   296→            previousState: 'running',\n   297→            newState: 'queued',\n   298→            trigger: 'disconnect-retry',\n   299→            workerId: _workerId,\n   300→            personaId: exec.request.personaId,\n   301→            disconnectRetries: nextRetry,\n   302→            errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n   303→          });\n   304→\n   305→          // Clear the active entry so dispatchToWorker can create a fresh one\n   306→          this.active.delete(executionId);\n   307→\n   308→          // Mark as queued in DB\n   309→          const disconnDb = this.resolveDbForExecution(executionId);\n   310→          if (disconnDb) {\n   311→            try {\n   312→              db.updateExecution(disconnDb, executionId, {\n   313→                status: 'queued',\n   314→                errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n   315→              });\n   316→            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on worker disconnect re-queue'); }\n   317→          }\n   318→\n   319→          // Temporarily store the retry count so dispatchToWorker picks it up\n   320→          const request = exec.request;\n   321→          // Create a placeholder active entry to carry retry count across re-dispatch\n   322→          this.active.set(executionId, {\n   323→            workerId: '',\n   324→            startedAt: 0,\n   325→            output: [],\n   326→            status: 'running',\n   327→            request,\n   328→            disconnectRetries: nextRetry,\n   329→          });\n   330→\n   331→          this.queue.unshift({ request, receivedAt: Date.now() });\n   332→          this.processQueue();\n   333→        } else {\n   334→          // Retries exhausted or no request stored — permanent failure\n   335→          this.logTransition({\n   336→            executionId,\n   337→            previousState: 'running',\n   338→            newState: 'failed',\n   339→            trigger: 'disconnect-exhausted',\n   340→            workerId: _workerId,\n   341→            disconnectRetries: retries,\n   342→            errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n   343→          });\n   344→          if (exec) {\n   345→            exec.status = 'failed';\n   346→            exec.completedAt = Date.now();\n   347→            setTimeout(() => this.active.delete(executionId), 30_000);\n   348→          }\n   349→\n   350→          const disconnDb = this.resolveDbForExecution(executionId);\n   351→          if (disconnDb) {\n   352→            try {\n   353→              db.updateExecution(disconnDb, executionId, {\n   354→                status: 'failed',\n   355→                errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n   356→                completedAt: new Date().toISOString(),\n   357→              });\n   358→            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:failed' }, 'Failed to persist execution failure on worker disconnect'); }\n   359→          }\n   360→          this.executionTenant.delete(executionId);\n   361→\n   362→          this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   363→            executionId,\n   364→            status: 'failed',\n   365→            error: 'Worker disconnected (retries exhausted)',\n   366→            durationMs: 0,\n   367→          }), executionId).catch(err => { this.logger.warn({ err, executionId, op: 'kafka:exec_lifecycle' }, 'Failed to produce disconnect failure lifecycle to Kafka'); });\n   368→        }\n   369→      }\n   370→    });\n   371→  }\n   372→\n   373→  setTenantDbManager(mgr: TenantDbManager): void {\n   374→    this.tenantDbManager = mgr;\n   375→  }\n   376→\n   377→  async setMasterKey(masterKeyHex: string): Promise<void> {\n   378→    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n   379→  }\n   380→\n   381→  setTenantKeyManager(mgr: TenantKeyManager): void {\n   382→    this.tenantKeyManager = mgr;\n   383→  }\n   384→\n   385→  setAuditLog(log: AuditLog): void {\n   386→    this.auditLog = log;\n   387→  }\n   388→\n   389→  /** Resolve the database for a given projectId via tenant DB manager. */\n   390→  private resolveDb(projectId?: string): Database.Database | null {\n   391→    if (this.tenantDbManager && projectId) {\n   392→      return this.tenantDbManager.getTenantDb(projectId);\n   393→    }\n   394→    return null;\n   395→  }\n   396→\n   397→  /** Resolve the database for an in-flight execution by its ID. */\n   398→  private resolveDbForExecution(executionId: string): Database.Database | null {\n   399→    const projectId = this.executionTenant.get(executionId);\n   400→    return this.resolveDb(projectId);\n   401→  }\n   402→\n   403→  /**\n   404→   * Emit a single structured log entry for every execution state transition.\n   405→   * Creates a queryable timeline: grep for \"Execution state transition\" to see\n   406→   * the full lifecycle of any execution.\n   407→   */\n   408→  private logTransition(opts: {\n   409→    executionId: string;\n   410→    previousState: ExecutionStatus | null;\n   411→    newState: ExecutionStatus;\n   412→    trigger: TransitionTrigger;\n   413→    workerId?: string;\n   414→    personaId?: string;\n   415→    queueWaitMs?: number;\n   416→    disconnectRetries?: number;\n   417→    errorMessage?: string;\n   418→  }): void {\n   419→    this.logger.info({\n   420→      executionId: opts.executionId,\n   421→      previousState: opts.previousState,\n   422→      newState: opts.newState,\n   423→      trigger: opts.trigger,\n   424→      ...(opts.workerId ? { workerId: opts.workerId } : {}),\n   425→      ...(opts.personaId ? { personaId: opts.personaId } : {}),\n   426→      ...(opts.queueWaitMs !== undefined ? { queueWaitMs: opts.queueWaitMs } : {}),\n   427→      ...(opts.disconnectRetries !== undefined ? { disconnectRetries: opts.disconnectRetries } : {}),\n   428→      ...(opts.errorMessage ? { errorMessage: opts.errorMessage } : {}),\n   429→    }, 'Execution state transition');\n   430→  }\n   431→\n   432→  /**\n   433→   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   434→   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   435→   */\n   436→  private async decryptWithAudit(\n   437→    payload: EncryptedPayload,\n   438→    tenantId: string,\n   439→    resourceId: string,\n   440→    logContext: Record<string, unknown>,\n   441→    logMessage: string,\n   442→  ): Promise<string | undefined> {\n   443→    const decryptKey = this.tenantKeyManager\n   444→      ? await this.tenantKeyManager.getKey(tenantId)\n   445→      : this.masterKey;\n   446→    if (!decryptKey) return undefined;\n   447→\n   448→    try {\n   449→      const decrypted = decrypt(payload, decryptKey, { tenantId, credentialId: resourceId, resourceType: 'credential' });\n   450→      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n   451→      return decrypted;\n   452→    } catch (err) {\n   453→      const reason = err instanceof DecryptionError ? err.message : (err instanceof Error ? err.message : String(err));\n   454→      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n   455→      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: { reason } }); } catch { /* logged inside record() */ }\n   456→      return undefined;\n   457→    }\n   458→  }\n   459→\n   460→  submit(request: ExecRequest): SubmitResult {\n   461→    const projectId = request.projectId || 'default';\n   462→\n   463→    // --- Backpressure checks ---\n   464→    const { maxQueueDepth, perTenantQuota, retryAfterSeconds } = this.backpressure;\n   465→\n   466→    // Global queue depth limit\n   467→    if (maxQueueDepth > 0 && this.queue.length >= maxQueueDepth) {\n   468→      this.logger.warn({\n   469→        executionId: request.executionId,\n   470→        personaId: request.personaId,\n   471→        queueDepth: this.queue.length,\n   472→        maxQueueDepth,\n   473→        projectId,\n   474→      }, 'Submission rejected: queue depth limit exceeded');\n   475→      return { accepted: false, reason: 'queue_full', retryAfterSeconds };\n   476→    }\n   477→\n   478→    // Per-tenant quota\n   479→    if (perTenantQuota > 0) {\n   480→      const tenantCount = this.tenantQueueCounts.get(projectId) ?? 0;\n   481→      if (tenantCount >= perTenantQuota) {\n   482→        this.logger.warn({\n   483→          executionId: request.executionId,\n   484→          personaId: request.personaId,\n   485→          projectId,\n   486→          tenantQueueCount: tenantCount,\n   487→          perTenantQuota,\n   488→        }, 'Submission rejected: per-tenant queue quota exceeded');\n   489→        return { accepted: false, reason: 'tenant_quota_exceeded', retryAfterSeconds };\n   490→      }\n   491→    }\n   492→\n   493→    this.logger.info({\n   494→      executionId: request.executionId,\n   495→      personaId: request.personaId,\n   496→      ...(request.eventId ? { eventId: request.eventId } : {}),\n   497→    }, 'Execution submitted');\n   498→\n   499→    // Track which tenant owns this execution (for callback DB resolution)\n   500→    this.executionTenant.set(request.executionId, projectId);\n   501→\n   502→    // Create DB record immediately\n   503→    const submitDb = this.resolveDb(projectId);\n   504→    if (submitDb) {\n   505→      try {\n   506→        db.createExecution(submitDb, {\n   507→          id: request.executionId,\n   508→          personaId: request.personaId,\n   509→          inputData: request.prompt,\n   510→          projectId,\n   511→          eventId: request.eventId ?? null,\n   512→        });\n   513→      } catch (err) {\n   514→        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n   515→      }\n   516→    }\n   517→\n   518→    this.logTransition({\n   519→      executionId: request.executionId,\n   520→      previousState: null,\n   521→      newState: 'queued',\n   522→      trigger: 'submit',\n   523→      personaId: request.personaId,\n   524→      disconnectRetries: 0,\n   525→    });\n   526→\n   527→    this.queue.push({ request, receivedAt: Date.now() });\n   528→    this.incrementTenantCount(projectId);\n   529→    this.checkThresholds();\n   530→    this.processQueue();\n   531→    return { accepted: true };\n   532→  }\n   533→\n   534→  private async processQueue(): Promise<void> {\n   535→    // Guard: only one processQueue loop runs at a time to prevent concurrent\n   536→    // calls from racing on getIdleWorker()/assign() and double-claiming a worker.\n   537→    if (this.dispatching) return;\n   538→    this.dispatching = true;\n   539→    try {\n   540→      while (this.queue.length > 0) {\n   541→        const workerId = this.pool.getIdleWorker();\n   542→        if (!workerId) {\n   543→          this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n   544→          return;\n   545→        }\n   546→\n   547→        const item = this.queue.shift()!;\n   548→        const tenantId = item.request.projectId || 'default';\n   549→        this.decrementTenantCount(tenantId);\n   550→        this.checkThresholds();\n   551→        await this.dispatchToWorker(workerId, item.request, item.receivedAt);\n   552→      }\n   553→    } finally {\n   554→      this.dispatching = false;\n   555→    }\n   556→  }\n   557→\n   558→  /** Exposes decryptWithAudit as the Decryptor interface for pipeline stages. */\n   559→  private getDecryptor(): Decryptor {\n   560→    return {\n   561→      decrypt: (payload, tenantId, resourceId, logContext, logMessage) =>\n   562→        this.decryptWithAudit(payload, tenantId, resourceId, logContext, logMessage),\n   563→    };\n   564→  }\n   565→\n   566→  /** Lazily initialise the ExecutionPreparer (depends on mutable setter state). */\n   567→  private ensurePreparer(): ExecutionPreparer {\n   568→    if (!this.preparer) {\n   569→      this.preparer = new ExecutionPreparer(\n   570→        (projectId) => this.resolveDb(projectId),\n   571→        this.getDecryptor(),\n   572→        this.logger,\n   573→      );\n   574→    }\n   575→    return this.preparer;\n   576→  }\n   577→\n   578→  private async dispatchToWorker(workerId: string, request: ExecRequest, queuedAt?: number): Promise<void> {\n   579→    const dispatchStartMs = Date.now();\n   580→    const queueWaitMs = queuedAt !== undefined ? dispatchStartMs - queuedAt : undefined;\n   581→\n   582→    // Stage 1: Resolve token (stays in Dispatcher)\n   583→    const tokenStartMs = Date.now();\n   584→    const token = await resolveToken(this.oauth, this.tokenManager);\n   585→    const tokenResolveMs = Date.now() - tokenStartMs;\n   586→    if (!token) {\n   587→      this.logger.error({ executionId: request.executionId, tokenResolveMs }, 'No Claude token available, re-queuing execution');\n   588→      this.queue.unshift({ request, receivedAt: Date.now() });\n   589→      return;\n   590→    }\n   591→\n   592→    // Stages 2-4: Persona resolution, payload assembly, assignment building\n   593→    const prepareStartMs = Date.now();\n   594→    const assignment = await this.ensurePreparer().prepare(request, token);\n   595→    const prepareDurationMs = Date.now() - prepareStartMs;\n   596→    const tenantId = request.projectId || 'default';\n   597→    const dispatchDb = this.resolveDb(tenantId);\n   598→\n   599→    // Track in-memory for real-time streaming (preserve retry count across re-dispatches)\n   600→    const prevRetries = this.active.get(request.executionId)?.disconnectRetries ?? 0;\n   601→    this.active.set(request.executionId, {\n   602→      workerId,\n   603→      startedAt: Date.now(),\n   604→      output: [],\n   605→      status: 'running',\n   606→      request,\n   607→      disconnectRetries: prevRetries,\n   608→    });\n   609→\n   610→    // Mark running in DB\n   611→    if (dispatchDb) {\n   612→      try {\n   613→        db.updateExecution(dispatchDb, request.executionId, {\n   614→          status: 'running',\n   615→          startedAt: new Date().toISOString(),\n   616→        });\n   617→      } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:running' }, 'Failed to mark execution as running in DB'); }\n   618→    }\n   619→\n   620→    const sent = this.pool.assign(workerId, assignment);\n   621→    const totalDispatchMs = Date.now() - dispatchStartMs;\n   622→    if (!sent) {\n   623→      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n   624→      this.active.delete(request.executionId);\n   625→      if (dispatchDb) {\n   626→        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:queued' }, 'Failed to re-queue execution in DB after assign failure'); }\n   627→      }\n   628→      this.logTransition({\n   629→        executionId: request.executionId,\n   630→        previousState: 'running',\n   631→        newState: 'queued',\n   632→        trigger: 'assign-failure',\n   633→        workerId,\n   634→        personaId: request.personaId,\n   635→        disconnectRetries: prevRetries,\n   636→      });\n   637→      this.queue.unshift({ request, receivedAt: Date.now() });\n   638→      this.processQueue();\n   639→    } else {\n   640→      this.logTransition({\n   641→        executionId: request.executionId,\n   642→        previousState: 'queued',\n   643→        newState: 'running',\n   644→        trigger: 'dispatch',\n   645→        workerId,\n   646→        personaId: request.personaId,\n   647→        queueWaitMs,\n   648→        disconnectRetries: prevRetries,\n   649→      });\n   650→    }\n   651→\n   652→    // Emit dispatch latency metrics for observability\n   653→    this.logger.info({\n   654→      executionId: request.executionId,\n   655→      personaId: request.personaId,\n   656→      workerId,\n   657→      queueWaitMs,\n   658→      tokenResolveMs,\n   659→      prepareDurationMs,\n   660→      totalDispatchMs,\n   661→    }, 'Dispatch latency');\n   662→  }\n   663→\n   664→  cancelExecution(executionId: string): boolean {\n   665→    const exec = this.active.get(executionId);\n   666→    if (!exec || exec.status !== 'running') return false;\n   667→\n   668→    return this.pool.send(exec.workerId, {\n   669→      type: 'cancel',\n   670→      executionId,\n   671→    });\n   672→  }\n   673→\n   674→  getQueueLength(): number {\n   675→    return this.queue.length;\n   676→  }\n   677→\n   678→  getBackpressureStatus(): { depth: number; maxDepth: number; level: ThresholdLevel; tenantCounts: Record<string, number> } {\n   679→    const tenantCounts: Record<string, number> = {};\n   680→    for (const [k, v] of this.tenantQueueCounts) {\n   681→      if (v > 0) tenantCounts[k] = v;\n   682→    }\n   683→    return { depth: this.queue.length, maxDepth: this.backpressure.maxQueueDepth, level: this.currentThresholdLevel, tenantCounts };\n   684→  }\n   685→\n   686→  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n   687→    return Array.from(this.active.entries())\n   688→      .filter(([, e]) => e.status === 'running')\n   689→      .map(([executionId, e]) => ({\n   690→        executionId,\n   691→        workerId: e.workerId,\n   692→        startedAt: e.startedAt,\n   693→      }));\n   694→  }\n   695→\n   696→  /**\n   697→   * Get execution state. Tries in-memory first (for real-time output),\n   698→   * then falls back to DB for completed/historical executions.\n   699→   */\n   700→  getExecution(executionId: string): ActiveExecution | null {\n   701→    // Check in-memory active executions first\n   702→    const active = this.active.get(executionId);\n   703→    if (active) return active;\n   704→\n   705→    const execDb = this.resolveDbForExecution(executionId);\n   706→    if (execDb) {\n   707→      const dbExec = db.getExecution(execDb, executionId);\n   708→      if (dbExec) {\n   709→        return {\n   710→          workerId: '',\n   711→          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n   712→          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n   713→          status: dbExec.status as ActiveExecution['status'],\n   714→          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n   715→          durationMs: dbExec.durationMs ?? undefined,\n   716→          sessionId: dbExec.claudeSessionId ?? undefined,\n   717→          totalCostUsd: dbExec.costUsd ?? undefined,\n   718→        };\n   719→      }\n   720→    }\n   721→\n   722→    return null;\n   723→  }\n   724→\n   725→  getExecutionOutput(executionId: string): string[] | null {\n   726→    const exec = this.getExecution(executionId);\n   727→    return exec?.output ?? null;\n   728→  }\n   729→\n   730→  /** Shared handler for stdout/stderr output chunks. */\n   731→  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n   732→    const line = prefix ? `${prefix}${chunk}` : chunk;\n   733→\n   734→    const exec = this.active.get(executionId);\n   735→    if (exec) {\n   736→      exec.output.push(line);\n   737→    }\n   738→\n   739→    this.bufferOutput(executionId, line + '\\n');\n   740→\n   741→    // Forward stdout to Kafka (stderr is not forwarded)\n   742→    if (!prefix) {\n   743→      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n   744→        executionId,\n   745→        chunk,\n   746→        timestamp,\n   747→      }), executionId).catch(err => {\n   748→        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n   749→      });\n   750→    }\n   751→  }\n   752→\n   753→  /** Buffer an output chunk for batched DB write. */\n   754→  private bufferOutput(executionId: string, chunk: string): void {\n   755→    let buf = this.outputBuffers.get(executionId);\n   756→    if (!buf) {\n   757→      buf = [];\n   758→      this.outputBuffers.set(executionId, buf);\n   759→    }\n   760→    buf.push(chunk);\n   761→  }\n   762→\n   763→  /** Flush buffered output for a specific execution to DB. */\n   764→  private flushOutputForExecution(executionId: string): void {\n   765→    const buf = this.outputBuffers.get(executionId);\n   766→    if (!buf || buf.length === 0) return;\n   767→\n   768→    const combined = buf.join('');\n   769→    this.outputBuffers.delete(executionId);\n   770→\n   771→    const outputDb = this.resolveDbForExecution(executionId);\n   772→    if (outputDb) {\n   773→      try { db.appendOutput(outputDb, executionId, combined); } catch (err) { this.logger.warn({ err, executionId, op: 'appendOutput' }, 'Failed to flush buffered output to DB'); }\n   774→    }\n   775→  }\n   776→\n   777→  /** Flush all buffered output across all executions to DB. */\n   778→  private flushOutputBuffers(): void {\n   779→    for (const executionId of this.outputBuffers.keys()) {\n   780→      this.flushOutputForExecution(executionId);\n   781→    }\n   782→  }\n   783→\n   784→  private incrementTenantCount(projectId: string): void {\n   785→    this.tenantQueueCounts.set(projectId, (this.tenantQueueCounts.get(projectId) ?? 0) + 1);\n   786→  }\n   787→\n   788→  private decrementTenantCount(projectId: string): void {\n   789→    const count = this.tenantQueueCounts.get(projectId) ?? 0;\n   790→    if (count <= 1) {\n   791→      this.tenantQueueCounts.delete(projectId);\n   792→    } else {\n   793→      this.tenantQueueCounts.set(projectId, count - 1);\n   794→    }\n   795→  }\n   796→\n   797→  /**\n   798→   * Check queue depth against warning/critical thresholds and emit Kafka\n   799→   * metrics when the level changes.\n   800→   */\n   801→  private checkThresholds(): void {\n   802→    const depth = this.queue.length;\n   803→    const { warningThreshold, criticalThreshold } = this.backpressure;\n   804→\n   805→    let newLevel: ThresholdLevel = 'normal';\n   806→    if (criticalThreshold > 0 && depth >= criticalThreshold) {\n   807→      newLevel = 'critical';\n   808→    } else if (warningThreshold > 0 && depth >= warningThreshold) {\n   809→      newLevel = 'warning';\n   810→    }\n   811→\n   812→    if (newLevel !== this.currentThresholdLevel) {\n   813→      const previousLevel = this.currentThresholdLevel;\n   814→      this.currentThresholdLevel = newLevel;\n   815→\n   816→      this.logger.warn({\n   817→        queueDepth: depth,\n   818→        previousLevel,\n   819→        newLevel,\n   820→        warningThreshold,\n   821→        criticalThreshold,\n   822→      }, 'Queue threshold level changed');\n   823→\n   824→      this.kafka.produce(TOPICS.QUEUE_METRICS, JSON.stringify({\n   825→        event: 'threshold_crossed',\n   826→        previousLevel,\n   827→        newLevel,\n   828→        queueDepth: depth,\n   829→        maxQueueDepth: this.backpressure.maxQueueDepth,\n   830→        timestamp: Date.now(),\n   831→      })).catch(err => {\n   832→        this.logger.error({ err }, 'Failed to produce queue metrics to Kafka');\n   833→      });\n   834→    }\n   835→  }\n   836→\n   837→  shutdown(): void {\n   838→    clearInterval(this.outputFlushTimer);\n   839→    this.flushOutputBuffers();\n   840→  }\n   841→}\n   842→"}]},"parent_tool_use_id":null,"session_id":"2fae1135-03d8-419c-8f90-568496f0fed8","uuid":"77241858-395b-438b-825c-7d83cd78886a","timestamp":"2026-03-19T08:15:58.311Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\dispatcher.ts","content":"import { type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type PhaseTimings, type EncryptedPayload, TOPICS, decrypt, DecryptionError, deriveMasterKeyAsync } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { resolveToken, ExecutionPreparer, type Decryptor } from './dispatchPipeline.js';\n\ninterface QueuedExecution {\n  request: ExecRequest;\n  receivedAt: number;\n}\n\n// Maximum number of times an execution will be re-queued after worker disconnect\nconst MAX_DISCONNECT_RETRIES = 2;\n\n/** Backpressure configuration for the dispatch queue. */\nexport interface QueueBackpressureConfig {\n  /** Maximum total queue depth. Submissions beyond this are rejected. 0 = unlimited. */\n  maxQueueDepth: number;\n  /** Queue depth at which a warning metric is emitted. 0 = disabled. */\n  warningThreshold: number;\n  /** Queue depth at which a critical metric is emitted. 0 = disabled. */\n  criticalThreshold: number;\n  /** Maximum queued items per tenant. 0 = unlimited (no per-tenant quota). */\n  perTenantQuota: number;\n  /** Retry-After value (seconds) included in rejection results. */\n  retryAfterSeconds: number;\n}\n\n/** Result of a submit() call — either accepted or rejected with a reason. */\nexport type SubmitResult =\n  | { accepted: true }\n  | { accepted: false; reason: 'queue_full' | 'tenant_quota_exceeded'; retryAfterSeconds: number };\n\n/** Which threshold band the queue is currently in. */\ntype ThresholdLevel = 'normal' | 'warning' | 'critical';\n\n/** All valid execution statuses. */\ntype ExecutionStatus = 'queued' | 'running' | 'completed' | 'failed' | 'cancelled';\n\n/** What triggered a state transition. */\ntype TransitionTrigger =\n  | 'submit'\n  | 'dispatch'\n  | 'complete'\n  | 'busy-nack'\n  | 'disconnect-retry'\n  | 'disconnect-exhausted'\n  | 'assign-failure';\n\n// In-memory tracking for active executions (real-time output streaming)\ninterface ActiveExecution {\n  workerId: string;\n  startedAt: number;\n  output: string[];\n  status: 'running' | 'completed' | 'failed' | 'cancelled';\n  progress?: ProgressInfo;\n  completedAt?: number;\n  exitCode?: number;\n  durationMs?: number;\n  sessionId?: string;\n  totalCostUsd?: number;\n  phaseTimings?: PhaseTimings;\n  /** Original request kept for re-queuing on worker disconnect. Only present for in-flight executions. */\n  request?: ExecRequest;\n  /** How many times this execution has been re-queued after a worker disconnect. */\n  disconnectRetries?: number;\n}\n\nconst OUTPUT_FLUSH_INTERVAL_MS = 500;\n\nexport class Dispatcher {\n  private queue: QueuedExecution[] = [];\n  // In-memory map for real-time output + cancel routing (active executions only)\n  private active = new Map<string, ActiveExecution>();\n  private tenantDbManager: TenantDbManager | null = null;\n  private masterKey: Buffer | null = null;\n  private tenantKeyManager: TenantKeyManager | null = null;\n  private auditLog: AuditLog | null = null;\n  private preparer: ExecutionPreparer | null = null;\n  // Maps executionId → projectId for DB resolution during callbacks\n  private executionTenant = new Map<string, string>();\n  // Batched output buffers: executionId → pending chunks\n  private outputBuffers = new Map<string, string[]>();\n  private outputFlushTimer: NodeJS.Timeout;\n  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n  private dispatching = false;\n  // Backpressure state\n  private backpressure: QueueBackpressureConfig;\n  private tenantQueueCounts = new Map<string, number>();\n  private currentThresholdLevel: ThresholdLevel = 'normal';\n\n  constructor(\n    private pool: WorkerPool,\n    private tokenManager: TokenManager,\n    private oauth: OAuthManager | null,\n    private kafka: KafkaClient,\n    private logger: Logger,\n    backpressureConfig?: Partial<QueueBackpressureConfig>,\n  ) {\n    this.backpressure = {\n      maxQueueDepth: backpressureConfig?.maxQueueDepth ?? 1000,\n      warningThreshold: backpressureConfig?.warningThreshold ?? 500,\n      criticalThreshold: backpressureConfig?.criticalThreshold ?? 800,\n      perTenantQuota: backpressureConfig?.perTenantQuota ?? 0,\n      retryAfterSeconds: backpressureConfig?.retryAfterSeconds ?? 30,\n    };\n    // Periodic flush of batched output to DB\n    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n\n    // When a worker becomes ready, try to dispatch queued work\n    this.pool.on('worker-ready', () => {\n      this.processQueue();\n    });\n\n    // When a worker connects, try to dispatch\n    this.pool.on('worker-connected', () => {\n      this.processQueue();\n    });\n\n    // Track stdout for execution output\n    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    });\n\n    // Track stderr for debugging failed executions\n    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    });\n\n    // Handle execution completion\n    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n        executionId: msg.executionId,\n        status: msg.status,\n        exitCode: msg.exitCode,\n        durationMs: msg.durationMs,\n        sessionId: msg.sessionId,\n        totalCostUsd: msg.totalCostUsd,\n        ...(msg.phaseTimings ? { phaseTimings: msg.phaseTimings } : {}),\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n      });\n\n      // Flush any remaining buffered output before persisting completion\n      this.flushOutputForExecution(msg.executionId);\n\n      // Update in-memory\n      const exec = this.active.get(msg.executionId);\n      const terminalStatus: ExecutionStatus = msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed';\n      this.logTransition({\n        executionId: msg.executionId,\n        previousState: 'running',\n        newState: terminalStatus,\n        trigger: 'complete',\n        workerId: exec?.workerId,\n        disconnectRetries: exec?.disconnectRetries ?? 0,\n      });\n      if (exec) {\n        exec.status = msg.status;\n        exec.completedAt = Date.now();\n        exec.exitCode = msg.exitCode;\n        exec.durationMs = msg.durationMs;\n        exec.sessionId = msg.sessionId;\n        exec.totalCostUsd = msg.totalCostUsd;\n        exec.phaseTimings = msg.phaseTimings;\n        // Remove from active after a short delay (allow polling to pick up final state)\n        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n      }\n\n      // Persist to DB\n      const completeDb = this.resolveDbForExecution(msg.executionId);\n      if (completeDb) {\n        try {\n          db.updateExecution(completeDb, msg.executionId, {\n            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n            completedAt: new Date().toISOString(),\n            durationMs: msg.durationMs,\n            claudeSessionId: msg.sessionId,\n            costUsd: msg.totalCostUsd ?? 0,\n          });\n        } catch (err) {\n          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n        }\n      }\n\n      // Clean up tenant mapping after completion delay\n      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n\n      // Process next queued item\n      this.processQueue();\n    });\n\n    // Track execution progress\n    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n      }\n      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n        executionId: msg.executionId,\n        phase: msg.phase,\n        percent: msg.percent,\n        detail: msg.detail,\n        timestamp: msg.timestamp,\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n      });\n    });\n\n    // Forward persona events to Kafka\n    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n        executionId: msg.executionId,\n        eventType: msg.eventType,\n        payload: msg.payload,\n        timestamp: Date.now(),\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n      });\n    });\n\n    // Handle worker busy nack — re-queue the rejected execution\n    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n      const exec = this.active.get(msg.executionId);\n      if (exec?.request) {\n        const request = exec.request;\n        this.logTransition({\n          executionId: msg.executionId,\n          previousState: 'running',\n          newState: 'queued',\n          trigger: 'busy-nack',\n          workerId: _workerId,\n          personaId: request.personaId,\n          disconnectRetries: exec.disconnectRetries ?? 0,\n        });\n        this.active.delete(msg.executionId);\n        // Mark as queued in DB\n        const reqDb = this.resolveDbForExecution(msg.executionId);\n        if (reqDb) {\n          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack'); }\n        }\n        this.queue.unshift({ request, receivedAt: Date.now() });\n        this.processQueue();\n      } else {\n        // Fallback: reconstruct from DB if request was not stored (should not happen)\n        this.logTransition({\n          executionId: msg.executionId,\n          previousState: 'running',\n          newState: 'queued',\n          trigger: 'busy-nack',\n          workerId: _workerId,\n        });\n        this.active.delete(msg.executionId);\n        const projectId = this.executionTenant.get(msg.executionId) || 'default';\n        const reqDb = this.resolveDb(projectId);\n        if (reqDb) {\n          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack fallback'); }\n        }\n        const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n        if (dbExec) {\n          this.queue.unshift({\n            request: {\n              executionId: msg.executionId,\n              personaId: dbExec.personaId,\n              prompt: dbExec.inputData || '',\n              projectId,\n              config: { timeoutMs: 300_000 },\n            },\n            receivedAt: Date.now(),\n          });\n          this.processQueue();\n        }\n      }\n    });\n\n    // Handle worker disconnect during execution — re-queue if retries remain\n    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n      if (executionId) {\n        const exec = this.active.get(executionId);\n        const retries = exec?.disconnectRetries ?? 0;\n\n        if (exec?.request && retries < MAX_DISCONNECT_RETRIES) {\n          // Re-queue for retry\n          const nextRetry = retries + 1;\n          this.logTransition({\n            executionId,\n            previousState: 'running',\n            newState: 'queued',\n            trigger: 'disconnect-retry',\n            workerId: _workerId,\n            personaId: exec.request.personaId,\n            disconnectRetries: nextRetry,\n            errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n          });\n\n          // Clear the active entry so dispatchToWorker can create a fresh one\n          this.active.delete(executionId);\n\n          // Mark as queued in DB\n          const disconnDb = this.resolveDbForExecution(executionId);\n          if (disconnDb) {\n            try {\n              db.updateExecution(disconnDb, executionId, {\n                status: 'queued',\n                errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n              });\n            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on worker disconnect re-queue'); }\n          }\n\n          // Temporarily store the retry count so dispatchToWorker picks it up\n          const request = exec.request;\n          // Create a placeholder active entry to carry retry count across re-dispatch\n          this.active.set(executionId, {\n            workerId: '',\n            startedAt: 0,\n            output: [],\n            status: 'running',\n            request,\n            disconnectRetries: nextRetry,\n          });\n\n          this.queue.unshift({ request, receivedAt: Date.now() });\n          this.processQueue();\n        } else {\n          // Retries exhausted or no request stored — permanent failure\n          this.logTransition({\n            executionId,\n            previousState: 'running',\n            newState: 'failed',\n            trigger: 'disconnect-exhausted',\n            workerId: _workerId,\n            disconnectRetries: retries,\n            errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n          });\n          if (exec) {\n            exec.status = 'failed';\n            exec.completedAt = Date.now();\n            setTimeout(() => this.active.delete(executionId), 30_000);\n          }\n\n          const disconnDb = this.resolveDbForExecution(executionId);\n          if (disconnDb) {\n            try {\n              db.updateExecution(disconnDb, executionId, {\n                status: 'failed',\n                errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n                completedAt: new Date().toISOString(),\n              });\n            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:failed' }, 'Failed to persist execution failure on worker disconnect'); }\n          }\n          this.executionTenant.delete(executionId);\n\n          this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n            executionId,\n            status: 'failed',\n            error: 'Worker disconnected (retries exhausted)',\n            durationMs: 0,\n          }), executionId).catch(err => { this.logger.warn({ err, executionId, op: 'kafka:exec_lifecycle' }, 'Failed to produce disconnect failure lifecycle to Kafka'); });\n        }\n      }\n    });\n  }\n\n  setTenantDbManager(mgr: TenantDbManager): void {\n    this.tenantDbManager = mgr;\n  }\n\n  async setMasterKey(masterKeyHex: string): Promise<void> {\n    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n  }\n\n  setTenantKeyManager(mgr: TenantKeyManager): void {\n    this.tenantKeyManager = mgr;\n  }\n\n  setAuditLog(log: AuditLog): void {\n    this.auditLog = log;\n  }\n\n  /** Resolve the database for a given projectId via tenant DB manager. */\n  private resolveDb(projectId?: string): Database.Database | null {\n    if (this.tenantDbManager && projectId) {\n      return this.tenantDbManager.getTenantDb(projectId);\n    }\n    return null;\n  }\n\n  /** Resolve the database for an in-flight execution by its ID. */\n  private resolveDbForExecution(executionId: string): Database.Database | null {\n    const projectId = this.executionTenant.get(executionId);\n    return this.resolveDb(projectId);\n  }\n\n  /**\n   * Emit a single structured log entry for every execution state transition.\n   * Creates a queryable timeline: grep for \"Execution state transition\" to see\n   * the full lifecycle of any execution.\n   */\n  private logTransition(opts: {\n    executionId: string;\n    previousState: ExecutionStatus | null;\n    newState: ExecutionStatus;\n    trigger: TransitionTrigger;\n    workerId?: string;\n    personaId?: string;\n    queueWaitMs?: number;\n    disconnectRetries?: number;\n    errorMessage?: string;\n  }): void {\n    this.logger.info({\n      executionId: opts.executionId,\n      previousState: opts.previousState,\n      newState: opts.newState,\n      trigger: opts.trigger,\n      ...(opts.workerId ? { workerId: opts.workerId } : {}),\n      ...(opts.personaId ? { personaId: opts.personaId } : {}),\n      ...(opts.queueWaitMs !== undefined ? { queueWaitMs: opts.queueWaitMs } : {}),\n      ...(opts.disconnectRetries !== undefined ? { disconnectRetries: opts.disconnectRetries } : {}),\n      ...(opts.errorMessage ? { errorMessage: opts.errorMessage } : {}),\n    }, 'Execution state transition');\n  }\n\n  /**\n   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   */\n  private async decryptWithAudit(\n    payload: EncryptedPayload,\n    tenantId: string,\n    resourceId: string,\n    logContext: Record<string, unknown>,\n    logMessage: string,\n  ): Promise<string | undefined> {\n    const decryptKey = this.tenantKeyManager\n      ? await this.tenantKeyManager.getKey(tenantId)\n      : this.masterKey;\n    if (!decryptKey) return undefined;\n\n    try {\n      const decrypted = decrypt(payload, decryptKey, { tenantId, credentialId: resourceId, resourceType: 'credential' });\n      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n      return decrypted;\n    } catch (err) {\n      const reason = err instanceof DecryptionError ? err.message : (err instanceof 