 185→\n   186→    ws.on('close', () => {\n   187→      clearTimeout(connectionTimeout);\n   188→      if (workerId) {\n   189→        this.unregisterWorker(workerId);\n   190→      }\n   191→    });\n   192→\n   193→    ws.on('error', (err) => {\n   194→      this.logger.error({ err, workerId }, 'Worker WebSocket error');\n   195→    });\n   196→  }\n   197→\n   198→  private registerWorker(workerId: string, ws: WebSocket, version: string, capabilities: string[], imageDigest?: string, claudeCliVersion?: string): void {\n   199→    // I10: If a worker with this ID already exists, disconnect the old one first\n   200→    const existing = this.workers.get(workerId);\n   201→    if (existing) {\n   202→      this.logger.warn({ workerId }, 'Duplicate worker ID — disconnecting previous connection');\n   203→      if (existing.heartbeatTimer) clearInterval(existing.heartbeatTimer);\n   204→      existing.ws.close(1001, 'Replaced by new connection');\n   205→      this.workers.delete(workerId);\n   206→      this.idleWorkers.delete(workerId);\n   207→    }\n   208→\n   209→    const verified = this.allowedDigests.length === 0 || (!!imageDigest && this.allowedDigests.includes(imageDigest));\n   210→\n   211→    if (this.rejectUnverified && !verified) {\n   212→      this.logger.warn({ workerId, imageDigest }, 'Rejecting unverified worker — digest not in allowlist');\n   213→      ws.close(1008, 'Unverified image digest');\n   214→      return;\n   215→    }\n   216→\n   217→    const info: WorkerInfo = {\n   218→      workerId,\n   219→      status: 'idle',\n   220→      version,\n   221→      capabilities,\n   222→      connectedAt: Date.now(),\n   223→      lastHeartbeat: Date.now(),\n   224→      imageDigest,\n   225→      claudeCliVersion,\n   226→      verified,\n   227→    };\n   228→\n   229→    const heartbeatTimer = setInterval(() => {\n   230→      const entry = this.workers.get(workerId);\n   231→      if (!entry) return;\n   232→\n   233→      const heartbeatAge 