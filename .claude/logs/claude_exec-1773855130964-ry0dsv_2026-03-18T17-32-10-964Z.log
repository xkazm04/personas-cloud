alse;\n    46→  let lastProduceError: string | null = null;\n    47→\n    48→  // Track produce errors to surface in health checks\n    49→  producer.on('producer.network.request_timeout', () => {\n    50→    lastProduceError = 'request_timeout';\n    51→  });\n    52→\n    53→  return {\n    54→    producer,\n    55→    consumer,\n    56→\n    57→    async setMasterKey(masterKeyHex: string) {\n    58→      masterKey = await deriveMasterKeyAsync(masterKeyHex);\n    59→    },\n    60→\n    61→    async connect() {\n    62→      await producer.connect();\n    63→      await consumer.connect();\n    64→      connected = true;\n    65→      lastProduceError = null;\n    66→      logger.info('Kafka connected');\n    67→    },\n    68→\n    69→    async disconnect() {\n    70→      connected = false;\n    71→      await producer.disconnect();\n    72→      await consumer.disconnect();\n    73→      logger.info('Kafka disconnected');\n    74→    },\n    75→\n    76→    async subscribe(handler: (topic: string, value: string, key?: string) => Promise<void>) {\n    77→      await consumer.subscribe({ topic: TOPICS.EXEC_REQUESTS, fromBeginning: false });\n    78→\n    79→      await consumer.run({\n    80→        eachMessage: async ({ topic, message }: EachMessagePayload) => {\n    81→          const value = message.value?.toString();\n    82→          const key = message.key?.toString();\n    83→          if (value) {\n    84→            try {\n    85→              await handler(topic, value, key);\n    86→            } catch (err) {\n    87→              logger.error({ err, topic, key }, 'Kafka message handler error');\n    88→            }\n    89→          }\n    90→        },\n    91→      });\n    92→\n    93→      logger.info({ topic: TOPICS.EXEC_REQUESTS }, 'Kafka consumer subscribed');\n    94→    },\n    95→\n    96→    async produce(topic: string, value: string, key?: string) {\n    97→      await producer.send({\n    98→        topic,\n    99→        messages: [{\n