tions: number;\n    44→  parseFailures: number;\n    45→  heartbeatNearMisses: number;\n    46→  /** Recent connection durations (ms) for the last N disconnects. */\n    47→  recentConnectionDurations: number[];\n    48→}\n    49→\n    50→/** Constant-time string comparison to prevent timing side-channel attacks on token validation. */\n    51→function timingSafeTokenEqual(a: string, b: string): boolean {\n    52→  const bufA = Buffer.from(a, 'utf8');\n    53→  const bufB = Buffer.from(b, 'utf8');\n    54→  if (bufA.length !== bufB.length) {\n    55→    // Compare against self to maintain constant timing, then return false\n    56→    crypto.timingSafeEqual(bufA, bufA);\n    57→    return false;\n    58→  }\n    59→  return crypto.timingSafeEqual(bufA, bufB);\n    60→}\n    61→\n    62→interface WorkerEntry {\n    63→  ws: WebSocket;\n    64→  info: WorkerInfo;\n    65→  heartbeatTimer?: ReturnType<typeof setInterval>;\n    66→}\n    67→\n    68→export class WorkerPool {\n    69→  private workers = new Map<string, WorkerEntry>();\n    70→  private idleWorkers = new Set<string>();\n    71→  private wss: WebSocketServer | null = null;\n    72→  private allowedDigests: string[];\n    73→  private rejectUnverified: boolean;\n    74→\n    75→  // Typed listener storage — one array per event name\n    76→  private listeners: { [K in keyof WorkerPoolEvents]?: WorkerPoolEvents[K][] } = {};\n    77→\n    78→  /** Connection lifecycle metrics. */\n    79→  private metrics: WorkerPoolMetrics = {\n    80→    totalConnections: 0,\n    81→    totalDisconnections: 0,\n    82→    parseFailures: 0,\n    83→    heartbeatNearMisses: 0,\n    84→    recentConnectionDurations: [],\n    85→  };\n    86→  private static readonly MAX_DURATION_HISTORY = 100;\n    87→\n    88→  constructor(\n    89→    private expectedWorkerToken: string,\n    90→    private logger: Logger,\n    91→    opts?: { allowedDigests?: string[]; rejectUnverified?: boolean },\n    92→  ) {\n    93→    this.allowedDigests = opts?.allowedDigests ?? [];\n    94→    this.rejectUnverified = opts?.rejectUnverified ?? false;\n    95→  }\n    96→\n    97→  /** Register a typed event listener. */\n    98→  on<K extends keyof WorkerPoolEvents>(event: K, listener: WorkerPoolEvents[K]): this {\n    99→    if (!this.listeners[event]) {\n   100→      this.listeners[event] = [];\n   101→    }\n   102→    this.listeners[event]!.push(listener);\n   103→    return this;\n   104→  }\n   105→\n   106→  /** Emit a typed event. */\n   107→  private emit<K extends keyof WorkerPoolEvents>(event: K, ...args: Parameters<WorkerPoolEvents[K]>): void {\n   108→    const fns = this.listeners[event];\n   109→    if (fns) {\n   110→      for (const fn of fns) {\n   111→        (fn as (...a: Parameters<WorkerPoolEvents[K]>) => void)(...args);\n   112→      }\n   113→    }\n   114→  }\n   115→\n   116→  listen(port: number, tlsConfig?: TlsConfig): void {\n   117→    if (tlsConfig?.enabled) {\n   118→      const httpsServer = https.createServer({\n   119→        cert: fs.readFileSync(tlsConfig.certPath),\n   120→        key: fs.readFileSync(tlsConfig.keyPath),\n   121→        ca: tlsConfig.caPath ? fs.readFileSync(tlsConfig.caPath) : undefined,\n   122→        requestCert: tlsConfig.requireClientCert,\n   123→        rejectUnauthorized: tlsConfig.requireClientCert,\n   124→      });\n   125→      this.wss = new WebSocketServer({ server: httpsServer });\n   126→      httpsServer.listen(port);\n   127→      this.logger.info({ port, tls: true, mTLS: tlsConfig.requireClientCert }, 'Worker pool listening (WSS)');\n   128→    } else {\n   129→      this.wss = new WebSocketServer({ port });\n   130→      this.logger.info({ port, tls: false }, 'Worker pool listening (WS — plaintext)');\n   131→    }\n   132→\n   133→    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n   134→      this.logger.info({ remoteAddr: req.socket.remoteAddress }, 'Worker connection attempt');\n   135→\n   136→      // Valida