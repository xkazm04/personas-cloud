[2026-03-18T17:32:28.197Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NX4a2tBorUdRML7tdh9pZt","type":"tool_result","content":"     1→import pino from 'pino';\n     2→import { loadConfig } from './config.js';\n     3→import { createAuth } from './auth.js';\n     4→import { createTokenManager } from './tokenManager.js';\n     5→import { OAuthManager } from './oauth.js';\n     6→import { WorkerPool, type WorkerPoolEvents } from './workerPool.js';\n     7→import { createKafkaClient, createNoopKafkaClient } from './kafka.js';\n     8→import { Dispatcher } from './dispatcher.js';\n     9→import { createHttpApi } from './httpApi.js';\n    10→import { TenantDbManager } from './tenantDbManager.js';\n    11→import { TenantKeyManager, type TenantKeyEvents } from './tenantKeyManager.js';\n    12→import { AuditLog } from './auditLog.js';\n    13→import { AuditPolicy } from './auditPolicy.js';\n    14→import { AuditRetentionPolicy } from './auditRetentionPolicy.js';\n    15→import { startRetentionJob } from './retention.js';\n    16→import { startEventProcessor } from './eventProcessor.js';\n    17→import { startTriggerScheduler } from './triggerScheduler.js';\n    18→import { loadTlsConfig } from './tls.js';\n    19→import { TOPICS, type ExecRequest } from '@dac-cloud/shared';\n    20→\n    21→const logger = pino({ level: process.env['LOG_LEVEL'] || 'info' });\n    22→\n    23→async function main() {\n    24→  logger.info('Starting DAC Cloud Orchestrator...');\n    25→\n    26→  // Load configuration\n    27→  const config = loadConfig();\n    28→  logger.info({\n    29→    kafkaEnabled: config.kafkaEnabled,\n    30→    wsPort: config.wsPort,\n    31→    httpPort: config.httpPort,\n    32→    hasDirectToken: !!config.claudeToken,\n    33→  }, 'Configuration loaded');\n    34→\n    35→  // Initialize components\n    36→  const auth = createAuth(config.teamApiKey, config.supabaseJwtSecret || undefined);\n    37→  const tokenManager = await createTokenManager(config.masterKey, logger);\n    38→  const oauth = new OAuthManager(logger);\n    39→\n    40→  // If a direct Claude token is provided (from setup-token), store it\n    41→  if (config.claudeToken) {\n    42→    tokenManager.storeClaudeToken(config.claudeToken);\n    43→    logger.info('Direct Claude token loaded from environment');\n    44→  } else {\n    45→    logger.info('No direct Claude token — use OAuth flow via POST /api/oauth/authorize');\n    46→  }\n    47→\n    48→  // Tenant-isolated database manager\n    49→  const tenantDbManager = new TenantDbManager(config.dataDir, logger);\n    50→  logger.info({ dataDir: config.dataDir }, 'Tenant DB manager initialized');\n    51→\n    52→  // Worker pool (WebSocket server)\n    53→  const pool = new WorkerPool(config.workerToken, logger, {\n    54→    allowedDigests: config.allowedImageDigests,\n    55→    rejectUnverified: config.rejectUnverifiedWorkers,\n    56→  });\n    57→\n    58→  // Kafka client\n    59→  const kafka = config.kafkaEnabled\n    60→    ? createKafkaClient(config.kafkaBrokers, config.kafkaUsername, config.kafkaPassword, logger)\n    61→    : createNoopKafkaClient(logger);\n    62→\n    63→  // Audit log (separate append-only DB)\n    64→  const auditLog = new AuditLog(config.auditDbPath, logger);\n    65→  const auditRetention = new AuditRetentionPolicy(auditLog, config.auditRetentionDays, logger);\n    66→  auditRetention.startDailyPurge();\n    67→\n    68→  // Per-tenant key manager (cached key derivation with TTL)\n    69→  const tenantKeyManager = new TenantKeyManager(config.masterKey, logger);\n    70→\n    71→  // Declarative audit policy — maps emitter events to audit entries\n    72→  const auditPolicy = new AuditPolicy(auditLog);\n    73→\n    74→  auditPolicy.attach<TenantKeyEvents>(tenantKeyManager, {\n    75→    'key:derived': (e) => ({ action: 'key:derive', tenantId: e.tenantId }),\n    76→  });\n    77→\n    78→  auditPolicy.attach<WorkerPoolEvents>(pool, {\n    79→    'worker-connected': (info) => ({ action: 'worker:connected', detail: info.workerId }),\n    80→    'worker-disconnected': (workerId, executionId) => ({ action: 'worker:disconnected', detail: workerId, resourceId: executionId }),\n    81→  });\n    82→\n    83→  // Wire tenant ID source for key pre-warming and proactive renewal\n    84→  await tenantKeyManager.setTenantIdSource(() => tenantDbManager.listTenantIds());\n    85→  // Eagerly warm key cache when a new tenant is registered\n    86→  tenantDbManager.setTenantCreatedCallback((tenantId) => tenantKeyManager.warmTenant(tenantId));\n    87→\n    88→  // Dispatcher — uses OAuth manager for token refresh\n    89→  const dispatcher = new Dispatcher(pool, tokenManager, oauth, kafka, logger);\n    90→  dispatcher.setTenantDbManager(tenantDbManager);\n    91→  await dispatcher.setMasterKey(config.masterKey);\n    92→  dispatcher.setTenantKeyManager(tenantKeyManager);\n    93→  dispatcher.setAuditLog(auditLog);\n    94→\n    95→  // Connect Kafka\n    96→  if (config.kafkaEnabled) {\n    97→    await kafka.connect();\n    98→\n    99→    // Subscribe to execution requests\n   100→    await kafka.subscribe(async (topic: string, value: string) => {\n   101→      if (topic === TOPICS.EXEC_REQUESTS) {\n   102→        try {\n   103→          const request: ExecRequest = JSON.parse(value);\n   104→          dispatcher.submit(request);\n   105→        } catch (err) {\n   106→          logger.error({ err }, 'Failed to parse execution request from Kafka');\n   107→        }\n   108→      }\n   109→    });\n   110→  }\n   111→\n   112→  // Load TLS config and start WebSocket server for workers\n   113→  const tlsConfig = loadTlsConfig(logger);\n   114→  pool.listen(config.wsPort, tlsConfig.enabled ? tlsConfig : undefined);\n   115→\n   116→  // Start HTTP API (now includes OAuth endpoints + persona CRUD)\n   117→  // Set master key on Kafka for envelope encryption\n   118→  await kafka.setMasterKey(config.masterKey);\n   119→\n   120→  // Start event processor (2s tick) — tenant-aware\n   121→  const eventProcessor = startEventProcessor(null, dispatcher, logger, 2000, tenantDbManager);\n   122→\n   123→  const httpServer = createHttpApi(auth, dispatcher, pool, tokenManager, oauth, logger, undefined, tenantDbManager, tenantKeyManager, auditLog, eventProcessor.getHealth);\n   124→  httpServer.listen(config.httpPort, () => {\n   125→    logger.info({ port: config.httpPort }, 'HTTP API listening');\n   126→  });\n   127→\n   128→  // Start trigger scheduler (5s tick) — tenant-aware\n   129→  const triggerSchedulerTimer = startTriggerScheduler(null, logger, 5000, tenantDbManager);\n   130→\n   131→  // Start daily retention job (purge old executions/events, aggregate metrics)\n   132→  const retentionTimer = startRetentionJob(tenantDbManager, config.retentionDays, logger);\n   133→\n   134→  // Token refresh loop — refresh OAuth token proactively every 30 minutes\n   135→  setInterval(async () => {\n   136→    if (oauth.hasTokens()) {\n   137→      const token = await oauth.getValidAccessToken();\n   138→      if (token) {\n   139→        tokenManager.storeClaudeToken(token);\n   140→      }\n   141→    }\n   142→  }, 30 * 60 * 1000);\n   143→\n   144→  // Log status periodically\n   145→  setInterval(() => {\n   146→    const counts = pool.getWorkerCount();\n   147→    const queueLen = dispatcher.getQueueLength();\n   148→    if (counts.total > 0 || queueLen > 0) {\n   149→      logger.info({\n   150→        workers: counts,\n   151→        queueLength: queueLen,\n   152→        activeExecutions: dispatcher.getActiveExecutions().length,\n   153→        hasOAuth: oauth.hasTokens(),\n   154→      }, 'Status');\n   155→    }\n   156→  }, 60_000);\n   157→\n   158→  // Graceful shutdown\n   159→  const shutdown = async () => {\n   160→    logger.info('Shutting down...');\n   161→    clearInterval(eventProcessor.timer);\n   162→    clearInterval(triggerSchedulerTimer);\n   163→    clearInterval(retentionTimer);\n   164→    dispatcher.shutdown();\n   165→    pool.shutdown();\n   166→    await kafka.disconnect();\n   167→    httpServer.close();\n   168→    tenantKeyManager.close();\n   169→    auditRetention.close();\n   170→    auditLog.close();\n   171→    tenantDbManager.close();\n   172→    oauth.dispose();\n   173→    process.exit(0);\n   174→  };\n   175→\n   176→  process.on('SIGINT', shutdown);\n   177→  process.on('SIGTERM', shutdown);\n   178→\n   179→  logger.info('DAC Cloud Orchestrator ready');\n   180→  logger.info(`  HTTP API: http://localhost:${config.httpPort}`);\n   181→  logger.info(`  Worker WS: ${tlsConfig.enabled ? 'wss' : 'ws'}://localhost:${config.wsPort}`);\n   182→  if (!config.claudeToken) {\n   183→    logger.info('  Connect subscription: POST /api/oauth/authorize');\n   184→  }\n   185→}\n   186→\n   187→main().catch((err) => {\n   188→  logger.fatal({ err }, 'Failed to start orchestrator');\n   189→  process.exit(1);\n   190→});\n   191→"}]},"parent_tool_use_id":null,"session_id":"90a8b635-e710-41f3-b833-6b6754d67d54","uuid":"dd52edce-fa6c-4e59-9f08-a2296f3fd89c","timestamp":"2026-03-18T17:32:28.114Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\index.ts","content":"import pino from 'pino';\nimport { loadConfig } from './config.js';\nimport { createAuth } from './auth.js';\nimport { createTokenManager } from './tokenManager.js';\nimport { OAuthManager } from './oauth.js';\nimport { WorkerPool, type WorkerPoolEvents } from './workerPool.js';\nimport { createKafkaClient, createNoopKafkaClient } from './kafka.js';\nimport { Dispatcher } from './dispatcher.js';\nimport { createHttpApi } from './httpApi.js';\nimport { TenantDbManager } from './tenantDbManager.js';\nimport { TenantKeyManager, type TenantKeyEvents } from './tenantKeyManager.js';\nimport { AuditLog } from './auditLog.js';\nimport { AuditPolicy } from './auditPolicy.js';\nimport { AuditRetentionPolicy } from './auditRetentionPolicy.js';\nimport { startRetentionJob } from './retention.js';\nimport { startEventProcessor } from './eventProcessor.js';\nimport { startTriggerScheduler } from './triggerScheduler.js';\nimport { loadTlsConfig } from './tls.js';\nimport { TOPICS, type ExecRequest } from '@dac-cloud/shared';\n\nconst logger = pino({ level: process.env['LOG_LEVEL'] || 'info' });\n\nasync function main() {\n  logger.info('Starting DAC Cloud Orchestrator...');\n\n  // Load configuration\n  const config = loadConfig();\n  logger.info({\n    kafkaEnabled: config.kafkaEnabled,\n    wsPort: config.wsPort,\n    httpPort: config.httpPort,\n    hasDirectToken: !!config.claudeToken,\n  }, 'Configuration loaded');\n\n  // Initialize components\n  const auth = createAuth(config.teamApiKey, config.supabaseJwtSecret || undefined);\n  const tokenManager = await createTokenManager(config.masterKey, logger);\n  const oauth = new OAuthManager(logger);\n\n  // If a direct Claude token is provided (from setup-token), store it\n  if (config.claudeToken) {\n    tokenManager.storeClaudeToken(config.claudeToken);\n    logger.info('Direct Claude token loaded from environment');\n  } else {\n    logger.info('No direct Claude token — use OAuth flow via POST /api/oauth/authorize');\n  }\n\n  // Tenant-isolated database manager\n  const tenantDbManager = new TenantDbManager(config.dataDir, logger);\n  logger.info({ dataDir: config.dataDir }, 'Tenant DB manager initialized');\n\n  // Worker pool (WebSocket server)\n  const pool = new WorkerPool(config.workerToken, logger, {\n    allowedDigests: config.allowedImageDigests,\n    rejectUnverified: config.rejectUnverifiedWorkers,\n  });\n\n  // Kafka client\n  const kafka = config.kafkaEnabled\n    ? createKafkaClient(config.kafkaBrokers, config.kafkaUsername, config.kafkaPassword, logger)\n    : createNoopKafkaClient(logger);\n\n  // Audit log (separate append-only DB)\n  const auditLog = new AuditLog(config.auditDbPath, logger);\n  const auditRetention = new AuditRetentionPolicy(auditLog, config.auditRetentionDays, logger);\n  auditRetention.startDailyPurge();\n\n  // Per-tenant key manager (cached key derivation with TTL)\n  const tenantKeyManager = new TenantKeyManager(config.masterKey, logger);\n\n  // Declarative audit policy — maps emitter events to audit entries\n  const auditPolicy = new AuditPolicy(auditLog);\n\n  auditPolicy.attach<TenantKeyEvents>(tenantKeyManager, {\n    'key:derived': (e) => ({ action: 'key:derive', tenantId: e.tenantId }),\n  });\n\n  auditPolicy.attach<WorkerPoolEvents>(pool, {\n    'worker-connected': (info) => ({ action: 'worker:connected', detail: info.workerId }),\n    'worker-disconnected': (workerId, executionId) => ({ action: 'worker:disconnected', detail: workerId, resourceId: executionId }),\n  });\n\n  // Wire tenant ID source for key pre-warming and proactive renewal\n  await tenantKeyManager.setTenantIdSource(() => tenantDbManager.listTenantIds());\n  // Eagerly warm key cache when a new tenant is registered\n  tenantDbManager.setTenantCreatedCallback((tenantId) => tenantKeyManager.warmTenant(tenantId));\n\n  // Dispatcher — uses OAuth manager for token refresh\n  const dispatcher = new Dispatcher(pool, tokenManager, oauth, kafka, logger);\n  dispatcher.setTenantDbManager(tenantDbManager);\n  await dispatcher.setMasterKey(config.masterKey);\n  dispatcher.setTenantKeyManager(tenantKeyManager);\n  dispatcher.setAuditLog(auditLog);\n\n  // Connect Kafka\n  if (config.kafkaEnabled) {\n    await kafka.connect();\n\n    // Subscribe to execution requests\n    await kafka.subscribe(async (topic: string, value: string) => {\n      if (topic === TOPICS.EXEC_REQUESTS) {\n        try {\n          const request: ExecRequest = JSON.parse(value);\n          dispatcher.submit(request);\n        } catch (err) {\n          logger.error({ err }, 'Failed to parse execution request from Kafka');\n        }\n      }\n    });\n  }\n\n  // Load TLS config and start WebSocket server for workers\n  const tlsConfig = loadTlsConfig(logger);\n  pool.listen(config.wsPort, tlsConfig.enabled ? tlsConfig : undefined);\n\n  // Start HTTP API (now includes OAuth endpoints + persona CRUD)\n  // Set master key on Kafka for envelope encryption\n  await kafka.setMasterKey(config.masterKey);\n\n  // Start event processor (2s tick) — tenant-aware\n  const eventProcessor = startEventProcessor(null, dispatcher, logger, 2000, tenantDbManager);\n\n  const httpServer = createHttpApi(auth, dispatcher, pool, tokenManager, oauth, logger, undefined, tenantDbManager, tenantKeyManager, auditLog, eventProcessor.getHealth);\n  httpServer.listen(config.httpPort, () => {\n    logger.info({ port: config.httpPort }, 'HTTP API listening');\n  });\n\n  // Start trigger scheduler (5s tick) — tenant-aware\n  const triggerSchedulerTimer = startTriggerScheduler(null, logger, 5000, tenantDbManager);\n\n  // Start daily retention job (purge old executions/events, aggregate metrics)\n  const retentionTimer = startRetentionJob(tenantDbManager, config.retentionDays, logger);\n\n  // Token refresh loop — refresh OAuth token proactively every 30 minutes\n  setInterval(async () => {\n    if (oauth.hasTokens()) {\n      const token = await oauth.getValidAccessToken();\n      if (token) {\n        tokenManager.storeClaudeToken(token);\n      }\n    }\n  }, 30 * 60 * 1000);\n\n  // Log status periodically\n  setInterval(() => {\n    const counts = pool.getWorkerCount();\n    const queueLen = dispatcher.getQueueLength();\n    if (counts.total > 0 || queueLen > 0) {\n      logger.info({\n        workers: counts,\n        queueLength: queueLen,\n        activeExecutions: dispatcher.getActiveExecutions().length,\n        hasOAuth: oauth.hasTokens(),\n      }, 'Status');\n    }\n  }, 60_000);\n\n  // Graceful shutdown\n  const shutdown = async () => {\n    logger.info('Shutting down...');\n    clearInterval(eventProcessor.timer);\n    clearInterval(triggerSchedulerTimer);\n    clearInterval(retentionTimer);\n    dispatcher.shutdown();\n    pool.shutdown();\n    await kafka.disconnect();\n    httpServer.close();\n    tenantKeyManager.close();\n    auditRetention.close();\n    auditLog.close();\n    tenantDbManager.close();\n    oauth.dispose();\n    process.exit(0);\n  };\n\n  process.on('SIGINT', shutdown);\n  process.on('SIGTERM', shutdown);\n\n  logger.info('DAC Cloud Orchestrator ready');\n  logger.info(`  HTTP API: http://localhost:${config.httpPort}`);\n  logger.info(`  Worker WS: ${tlsConfig.enabled ? 'wss' : 'ws'}://localhost:${config.wsPort}`);\n  if (!config.claudeToken) {\n    logger.info('  Connect subscription: POST /api/oauth/authorize');\n  }\n}\n\nmain().catch((err) => {\n  logger.fatal({ err }, 'Failed to start orchestrator');\n  process.exit(1);\n});\n","numLines":191,"startLine":1,"totalLines":191}}}
[2026-03-18T17:32:28.198Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FXs2j3uAa6DcVwVwvNUkG9","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import { matchEvent, assemblePrompt } from '@dac-cloud/shared';\n     4→import type { ExecRequest, EventMatch, PersonaEvent } from '@dac-cloud/shared';\n     5→import { nanoid } from 'nanoid';\n     6→import * as db from './db/index.js';\n     7→import type { Dispatcher } from './dispatcher.js';\n     8→import type { TenantDbManager } from './tenantDbManager.js';\n     9→\n    10→/** Default threshold (seconds) for the periodic stale-event reaper. */\n    11→const STALE_EVENT_REAPER_SECONDS = 120;\n    12→/** Run the reaper every N ticks (at 2s interval, 30 ticks = ~60s). */\n    13→const REAPER_TICK_INTERVAL = 30;\n    14→\n    15→export interface EventProcessorHealth {\n    16→  lastTickAt: number | null;\n    17→  pendingEvents: number;\n    18→  backlogAgeMs: number | null;\n    19→}\n    20→\n    21→export interface EventProcessorHandle {\n    22→  timer: NodeJS.Timeout;\n    23→  getHealth: () => EventProcessorHealth;\n    24→}\n    25→\n    26→/**\n    27→ * Recover events orphaned in 'processing' state from a prior crash.\n    28→ * Call once at startup before the tick loop begins.\n    29→ */\n    30→function recoverOrphanedEvents(\n    31→  database: Database.Database | null,\n    32→  logger: Logger,\n    33→  tenantDbManager?: TenantDbManager,\n    34→): void {\n    35→  if (tenantDbManager) {\n    36→    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    37→      const count = db.resetAllProcessingEvents(tenantDb);\n    38→      if (count > 0) {\n    39→        logger.warn({ projectId, count }, 'Reset orphaned processing events to pending at startup');\n    40→      }\n    41→    });\n    42→  } else if (database) {\n    43→    const count = db.resetAllProcessingEvents(database);\n    44→    if (count > 0) {\n    45→      logger.warn({ count }, 'Reset orphaned processing events to pending at startup');\n    46→    }\n    47→  }\n    48→}\n    49→\n    50→/**\n    51→ * Periodic reaper: reset events stuck in 'processing' longer than the threshold.\n    52→ * Guards against edge cases during normal operation.\n    53→ */\n    54→function reapStaleEvents(\n    55→  database: Database.Database | null,\n    56→  logger: Logger,\n    57→  tenantDbManager?: TenantDbManager,\n    58→): void {\n    59→  if (tenantDbManager) {\n    60→    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n    61→      const count = db.resetStaleProcessingEvents(tenantDb, STALE_EVENT_REAPER_SECONDS);\n    62→      if (count > 0) {\n    63→        logger.warn({ projectId, count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    64→      }\n    65→    });\n    66→  } else if (database) {\n    67→    const count = db.resetStaleProcessingEvents(database, STALE_EVENT_REAPER_SECONDS);\n    68→    if (count > 0) {\n    69→      logger.warn({ count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    70→    }\n    71→  }\n    72→}\n    73→\n    74→/**\n    75→ * Start the event processing loop.\n    76→ * Supports both tenant-isolated DBs (via TenantDbManager) and legacy single DB.\n    77→ */\n    78→export function startEventProcessor(\n    79→  database: Database.Database | null,\n    80→  dispatcher: Dispatcher,\n    81→  logger: Logger,\n    82→  interval: number = 2000,\n    83→  tenantDbManager?: TenantDbManager,\n    84→): EventProcessorHandle {\n    85→  // At startup, reset any events orphaned in 'processing' from a prior crash\n    86→  recoverOrphanedEvents(database, logger, tenantDbManager);\n    87→\n    88→  logger.info({ intervalMs: interval, tenantIsolated: !!tenantDbManager }, 'Event processor started');\n    89→\n    90→  let tickCount = 0;\n    91→\n    92→  // Shared health state updated on every tick\n    93→  const health: EventProcessorHealth = {\n    94→    lastTickAt: null,\n    95→    pendingEvents: 0,\n    96→    backlogAgeMs: null,\n    97→  };\n    98→\n    99→  const timer = setInterval(() => {\n   100→    try {\n   101→      tickCount++;\n   102→      health.lastTickAt = Date.now();\n   103→\n   104→      // Periodically reap stale processing events as a safety net\n   105→      if (tickCount % REAPER_TICK_INTERVAL === 0) {\n   106→        reapStaleEvents(database, logger, tenantDbManager);\n   107→      }\n   108→\n   109→      // Collect pending event stats for health reporting\n   110→      let totalPending = 0;\n   111→      let oldestCreatedAt: string | null = null;\n   112→\n   113→      if (tenantDbManager) {\n   114→        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n   115→          totalPending += db.countPendingEvents(tenantDb);\n   116→          const oldest = db.getOldestPendingEventCreatedAt(tenantDb);\n   117→          if (oldest && (!oldestCreatedAt || oldest < oldestCreatedAt)) {\n   118→            oldestCreatedAt = oldest;\n   119→          }\n   120→          eventBusTick(tenantDb, dispatcher, logger, projectId);\n   121→        });\n   122→      } else if (database) {\n   123→        totalPending = db.countPendingEvents(database);\n   124→        oldestCreatedAt = db.getOldestPendingEventCreatedAt(database);\n   125→        eventBusTick(database, dispatcher, logger);\n   126→      }\n   127→\n   128→      health.pendingEvents = totalPending;\n   129→      health.backlogAgeMs = oldestCreatedAt\n   130→        ? Math.max(0, Date.now() - new Date(oldestCreatedAt + 'Z').getTime())\n   131→        : null;\n   132→    } catch (err) {\n   133→      logger.error({ err }, 'Event processor tick failed');\n   134→    }\n   135→  }, interval);\n   136→\n   137→  return {\n   138→    timer,\n   139→    getHealth: () => ({ ...health }),\n   140→  };\n   141→}\n   142→\n   143→function eventBusTick(\n   144→  database: Database.Database,\n   145→  dispatcher: Dispatcher,\n   146→  logger: Logger,\n   147→  projectId?: string,\n   148→): void {\n   149→  const tickStartMs = performance.now();\n   150→  let eventsFetched = 0;\n   151→  let matchesFound = 0;\n   152→  let delivered = 0;\n   153→  let skipped = 0;\n   154→  let failed = 0;\n   155→\n   156→  try {\n   157→    const events = db.getPendingEvents(database, 50);\n   158→    eventsFetched = events.length;\n   159→    if (eventsFetched === 0) return;\n   160→\n   161→    // Collect dispatch requests to fire *after* the transaction commits so that\n   162→    // the dispatcher never sees stale DB state.\n   163→    const pendingDispatches: ExecRequest[] = [];\n   164→\n   165→    // Wrap all DB reads/writes in a single transaction to avoid per-statement\n   166→    // fsync overhead (up to 100 individual commits per tick otherwise).\n   167→    database.transaction(() => {\n   168→      // Cache subscription lookups per unique (eventType, projectId) to avoid\n   169→      // redundant DB queries when the same event type fires multiple times in a batch.\n   170→      const subsCache = new Map<string, ReturnType<typeof db.getSubscriptionsByEventType>>();\n   171→\n   172→      // Phase 1: Mark events as processing, compute matches, collect unique persona IDs.\n   173→      const eventMatches: Array<{ event: PersonaEvent; matches: EventMatch[] }> = [];\n   174→      const allPersonaIds = new Set<string>();\n   175→\n   176→      for (const event of events) {\n   177→        db.updateEventStatus(database, event.id, 'processing');\n   178→\n   179→        const cacheKey = `${event.eventType}\\0${event.projectId}`;\n   180→        let subs = subsCache.get(cacheKey);\n   181→        if (subs === undefined) {\n   182→          subs = db.getSubscriptionsByEventType(database, event.eventType, event.projectId);\n   183→          subsCache.set(cacheKey, subs);\n   184→        }\n   185→        const matches = matchEvent(event, subs);\n   186→\n   187→        if (matches.length === 0) {\n   188→          db.updateEventStatus(database, event.id, 'skipped');\n   189→          skipped++;\n   190→          continue;\n   191→        }\n   192→\n   193→        matchesFound += matches.length;\n   194→        eventMatches.push({ event, matches });\n   195→        for (const match of matches) {\n   196→          allPersonaIds.add(match.personaId);\n   197→        }\n   198→      }\n   199→\n   200→      if (allPersonaIds.size === 0) return;\n   201→\n   202→      // Phase 2: Batch-fetch personas, tools, and running counts (2-3 queries total).\n   203→      const personaIds = [...allPersonaIds];\n   204→      const personaMap = db.getPersonasByIds(database, personaIds);\n   205→      const toolsMap = db.getToolsForPersonaIds(database, personaIds);\n   206→      const runningMap = db.countRunningExecutionsByPersonaIds(database, personaIds);\n   207→\n   208→      // Phase 3: Dispatch using Map lookups instead of per-match queries.\n   209→      // Track persona slots claimed within this tick to prevent over-dispatch.\n   210→      const claimed = new Map<string, number>();\n   211→\n   212→      for (const { event, matches } of eventMatches) {\n   213→        let eventDelivered = 0;\n   214→        let eventFailed = 0;\n   215→        let throttled = 0;\n   216→\n   217→        for (const match of matches) {\n   218→          try {\n   219→            const persona = personaMap.get(match.personaId);\n   220→            if (!persona) {\n   221→              logger.warn({ personaId: match.personaId, eventId: event.id }, 'Persona not found for event match');\n   222→              eventFailed++;\n   223→              failed++;\n   224→              continue;\n   225→            }\n   226→\n   227→            // Check concurrency (in-tick claims + batched DB count)\n   228→            const tickClaimed = claimed.get(persona.id) ?? 0;\n   229→            const running = runningMap.get(persona.id) ?? 0;\n   230→            if (running + tickClaimed >= persona.maxConcurrent) {\n   231→              logger.info({ personaId: persona.id, running, tickClaimed, max: persona.maxConcurrent }, 'Persona at concurrency limit, deferring');\n   232→              throttled++;\n   233→              continue;\n   234→            }\n   235→\n   236→            // Build input data from event payload\n   237→            let inputData: Record<string, unknown> | undefined;\n   238→            if (match.payload) {\n   239→              try {\n   240→                inputData = JSON.parse(match.payload);\n   241→              } catch (parseError) {\n   242→                logger.warn({ eventId: event.id, personaId: match.personaId, parseError }, 'Event payload JSON parse failed, using raw');\n   243→                inputData = { raw: match.payload };\n   244→              }\n   245→            }\n   246→\n   247→            // Assemble prompt using batched persona + tools\n   248→            const tools = toolsMap.get(persona.id) ?? [];\n   249→            const prompt = assemblePrompt(persona, tools, inputData);\n   250→\n   251→            // Queue dispatch request (fired after transaction commits)\n   252→            const request: ExecRequest = {\n   253→              executionId: nanoid(),\n   254→              personaId: persona.id,\n   255→              prompt,\n   256→              projectId: projectId ?? persona.projectId,\n   257→              config: { timeoutMs: persona.timeoutMs },\n   258→            };\n   259→\n   260→            pendingDispatches.push(request);\n   261→            claimed.set(persona.id, (claimed.get(persona.id) ?? 0) + 1);\n   262→            eventDelivered++;\n   263→            delivered++;\n   264→\n   265→            logger.info({\n   266→              eventId: event.id,\n   267→              personaId: persona.id,\n   268→              executionId: request.executionId,\n   269→              eventType: event.eventType,\n   270→              useCaseId: match.useCaseId,\n   271→            }, 'Event dispatched to persona');\n   272→          } catch (err) {\n   273→            logger.error({ err, personaId: match.personaId, eventId: event.id }, 'Failed to dispatch event match');\n   274→            eventFailed++;\n   275→            failed++;\n   276→          }\n   277→        }\n   278→\n   279→        // Update event status\n   280→        if (eventDelivered > 0 && eventFailed === 0 && throttled === 0) {\n   281→          db.updateEventStatus(database, event.id, 'delivered');\n   282→        } else if (eventDelivered > 0 && throttled > 0) {\n   283→          // Some matches delivered but others were concurrency-limited.\n   284→          // Defer with backoff so throttled matches get retried later.\n   285→          db.deferEventForRetry(database, event.id, event.retryCount);\n   286→          logger.info({ eventId: event.id, delivered: eventDelivered, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event partially delivered, deferring throttled matches for retry');\n   287→        } else if (eventDelivered > 0 && eventFailed > 0) {\n   288→          // Some matches delivered but others failed — mark as partial-retry\n   289→          // so the event can be re-processed for the failed matches.\n   290→          db.updateEventStatus(database, event.id, 'partial-retry');\n   291→          logger.info({ eventId: event.id, delivered: eventDelivered, failed: eventFailed }, 'Event partially delivered with failures, marked for retry');\n   292→        } else if (throttled > 0) {\n   293→          // All (or remaining) matches were concurrency-limited — defer with backoff.\n   294→          db.deferEventForRetry(database, event.id, event.retryCount);\n   295→          logger.info({ eventId: event.id, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event deferred due to concurrency limits');\n   296→        } else {\n   297→          db.updateEventStatus(database, event.id, 'failed', 'All subscription matches failed');\n   298→        }\n   299→      }\n   300→    })();\n   301→\n   302→    // Fire dispatches after the transaction has committed successfully\n   303→    for (const request of pendingDispatches) {\n   304→      dispatcher.submit(request);\n   305→    }\n   306→  } finally {\n   307→    const tickDurationMs = performance.now() - tickStartMs;\n   308→    logger.info({\n   309→      tickDurationMs,\n   310→      eventsFetched,\n   311→      matchesFound,\n   312→      delivered,\n   313→      skipped,\n   314→      failed\n   315→    }, 'Event processor tick complete');\n   316→  }\n   317→}\n   318→"}]},"parent_tool_use_id":null,"session_id":"90a8b635-e710-41f3-b833-6b6754d67d54","uuid":"37af9b9a-5ecd-43ae-8b2d-d89b1a40adf5","timestamp":"2026-03-18T17:32:28.112Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\eventProcessor.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport { matchEvent, assemblePrompt } from '@dac-cloud/shared';\nimport type { ExecRequest, EventMatch, PersonaEvent } from '@dac-cloud/shared';\nimport { nanoid } from 'nanoid';\nimport * as db from './db/index.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\n\n/** Default threshold (seconds) for the periodic stale-event reaper. */\nconst STALE_EVENT_REAPER_SECONDS = 120;\n/** Run the reaper every N ticks (at 2s interval, 30 ticks = ~60s). */\nconst REAPER_TICK_INTERVAL = 30;\n\nexport interface EventProcessorHealth {\n  lastTickAt: number | null;\n  pendingEvents: number;\n  backlogAgeMs: number | null;\n}\n\nexport interface EventProcessorHandle {\n  timer: NodeJS.Timeout;\n  getHealth: () => EventProcessorHealth;\n}\n\n/**\n * Recover events orphaned in 'processing' state from a prior crash.\n * Call once at startup before the tick loop begins.\n */\nfunction recoverOrphanedEvents(\n  database: Database.Database | null,\n  logger: Logger,\n  tenantDbManager?: TenantDbManager,\n): void {\n  if (tenantDbManager) {\n    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n      const count = db.resetAllProcessingEvents(tenantDb);\n      if (count > 0) {\n        logger.warn({ projectId, count }, 'Reset orphaned processing events to pending at startup');\n      }\n    });\n  } else if (database) {\n    const count = db.resetAllProcessingEvents(database);\n    if (count > 0) {\n      logger.warn({ count }, 'Reset orphaned processing events to pending at startup');\n    }\n  }\n}\n\n/**\n * Periodic reaper: reset events stuck in 'processing' longer than the threshold.\n * Guards against edge cases during normal operation.\n */\nfunction reapStaleEvents(\n  database: Database.Database | null,\n  logger: Logger,\n  tenantDbManager?: TenantDbManager,\n): void {\n  if (tenantDbManager) {\n    tenantDbManager.forEachTenant((tenantDb, projectId) => {\n      const count = db.resetStaleProcessingEvents(tenantDb, STALE_EVENT_REAPER_SECONDS);\n      if (count > 0) {\n        logger.warn({ projectId, count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n      }\n    });\n  } else if (database) {\n    const count = db.resetStaleProcessingEvents(database, STALE_EVENT_REAPER_SECONDS);\n    if (count > 0) {\n      logger.warn({ count, thresholdSec: STALE_EVENT_REAPER_SECONDS }, 'Reaped stale processing events');\n    }\n  }\n}\n\n/**\n * Start the event processing loop.\n * Supports both tenant-isolated DBs (via TenantDbManager) and legacy single DB.\n */\nexport function startEventProcessor(\n  database: Database.Database | null,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  interval: number = 2000,\n  tenantDbManager?: TenantDbManager,\n): EventProcessorHandle {\n  // At startup, reset any events orphaned in 'processing' from a prior crash\n  recoverOrphanedEvents(database, logger, tenantDbManager);\n\n  logger.info({ intervalMs: interval, tenantIsolated: !!tenantDbManager }, 'Event processor started');\n\n  let tickCount = 0;\n\n  // Shared health state updated on every tick\n  const health: EventProcessorHealth = {\n    lastTickAt: null,\n    pendingEvents: 0,\n    backlogAgeMs: null,\n  };\n\n  const timer = setInterval(() => {\n    try {\n      tickCount++;\n      health.lastTickAt = Date.now();\n\n      // Periodically reap stale processing events as a safety net\n      if (tickCount % REAPER_TICK_INTERVAL === 0) {\n        reapStaleEvents(database, logger, tenantDbManager);\n      }\n\n      // Collect pending event stats for health reporting\n      let totalPending = 0;\n      let oldestCreatedAt: string | null = null;\n\n      if (tenantDbManager) {\n        tenantDbManager.forEachTenant((tenantDb, projectId) => {\n          totalPending += db.countPendingEvents(tenantDb);\n          const oldest = db.getOldestPendingEventCreatedAt(tenantDb);\n          if (oldest && (!oldestCreatedAt || oldest < oldestCreatedAt)) {\n            oldestCreatedAt = oldest;\n          }\n          eventBusTick(tenantDb, dispatcher, logger, projectId);\n        });\n      } else if (database) {\n        totalPending = db.countPendingEvents(database);\n        oldestCreatedAt = db.getOldestPendingEventCreatedAt(database);\n        eventBusTick(database, dispatcher, logger);\n      }\n\n      health.pendingEvents = totalPending;\n      health.backlogAgeMs = oldestCreatedAt\n        ? Math.max(0, Date.now() - new Date(oldestCreatedAt + 'Z').getTime())\n        : null;\n    } catch (err) {\n      logger.error({ err }, 'Event processor tick failed');\n    }\n  }, interval);\n\n  return {\n    timer,\n    getHealth: () => ({ ...health }),\n  };\n}\n\nfunction eventBusTick(\n  database: Database.Database,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  projectId?: string,\n): void {\n  const tickStartMs = performance.now();\n  let eventsFetched = 0;\n  let matchesFound = 0;\n  let delivered = 0;\n  let skipped = 0;\n  let failed = 0;\n\n  try {\n    const events = db.getPendingEvents(database, 50);\n    eventsFetched = events.length;\n    if (eventsFetched === 0) return;\n\n    // Collect dispatch requests to fire *after* the transaction commits so that\n    // the dispatcher never sees stale DB state.\n    const pendingDispatches: ExecRequest[] = [];\n\n    // Wrap all DB reads/writes in a single transaction to avoid per-statement\n    // fsync overhead (up to 100 individual commits per tick otherwise).\n    database.transaction(() => {\n      // Cache subscription lookups per unique (eventType, projectId) to avoid\n      // redundant DB queries when the same event type fires multiple times in a batch.\n      const subsCache = new Map<string, ReturnType<typeof db.getSubscriptionsByEventType>>();\n\n      // Phase 1: Mark events as processing, compute matches, collect unique persona IDs.\n      const eventMatches: Array<{ event: PersonaEvent; matches: EventMatch[] }> = [];\n      const allPersonaIds = new Set<string>();\n\n      for (const event of events) {\n        db.updateEventStatus(database, event.id, 'processing');\n\n        const cacheKey = `${event.eventType}\\0${event.projectId}`;\n        let subs = subsCache.get(cacheKey);\n        if (subs === undefined) {\n          subs = db.getSubscriptionsByEventType(database, event.eventType, event.projectId);\n          subsCache.set(cacheKey, subs);\n        }\n        const matches = matchEvent(event, subs);\n\n        if (matches.length === 0) {\n          db.updateEventStatus(database, event.id, 'skipped');\n          skipped++;\n          continue;\n        }\n\n        matchesFound += matches.length;\n        eventMatches.push({ event, matches });\n        for (const match of matches) {\n          allPersonaIds.add(match.personaId);\n        }\n      }\n\n      if (allPersonaIds.size === 0) return;\n\n      // Phase 2: Batch-fetch personas, tools, and running counts (2-3 queries total).\n      const personaIds = [...allPersonaIds];\n      const personaMap = db.getPersonasByIds(database, personaIds);\n      const toolsMap = db.getToolsForPersonaIds(database, personaIds);\n      const runningMap = db.countRunningExecutionsByPersonaIds(database, personaIds);\n\n      // Phase 3: Dispatch using Map lookups instead of per-match queries.\n      // Track persona slots claimed within this tick to prevent over-dispatch.\n      const claimed = new Map<string, number>();\n\n      for (const { event, matches } of eventMatches) {\n        let eventDelivered = 0;\n        let eventFailed = 0;\n        let throttled = 0;\n\n        for (const match of matches) {\n          try {\n            const persona = personaMap.get(match.personaId);\n            if (!persona) {\n              logger.warn({ personaId: match.personaId, eventId: event.id }, 'Persona not found for event match');\n              eventFailed++;\n              failed++;\n              continue;\n            }\n\n            // Check concurrency (in-tick claims + batched DB count)\n            const tickClaimed = claimed.get(persona.id) ?? 0;\n            const running = runningMap.get(persona.id) ?? 0;\n            if (running + tickClaimed >= persona.maxConcurrent) {\n              logger.info({ personaId: persona.id, running, tickClaimed, max: persona.maxConcurrent }, 'Persona at concurrency limit, deferring');\n              throttled++;\n              continue;\n            }\n\n            // Build input data from event payload\n            let inputData: Record<string, unknown> | undefined;\n            if (match.payload) {\n              try {\n                inputData = JSON.parse(match.payload);\n              } catch (parseError) {\n                logger.warn({ eventId: event.id, personaId: match.personaId, parseError }, 'Event payload JSON parse failed, using raw');\n                inputData = { raw: match.payload };\n              }\n            }\n\n            // Assemble prompt using batched persona + tools\n            const tools = toolsMap.get(persona.id) ?? [];\n            const prompt = assemblePrompt(persona, tools, inputData);\n\n            // Queue dispatch request (fired after transaction commits)\n            const request: ExecRequest = {\n              executionId: nanoid(),\n              personaId: persona.id,\n              prompt,\n              projectId: projectId ?? persona.projectId,\n              config: { timeoutMs: persona.timeoutMs },\n            };\n\n            pendingDispatches.push(request);\n            claimed.set(persona.id, (claimed.get(persona.id) ?? 0) + 1);\n            eventDelivered++;\n            delivered++;\n\n            logger.info({\n              eventId: event.id,\n              personaId: persona.id,\n              executionId: request.executionId,\n              eventType: event.eventType,\n              useCaseId: match.useCaseId,\n            }, 'Event dispatched to persona');\n          } catch (err) {\n            logger.error({ err, personaId: match.personaId, eventId: event.id }, 'Failed to dispatch event match');\n            eventFailed++;\n            failed++;\n          }\n        }\n\n        // Update event status\n        if (eventDelivered > 0 && eventFailed === 0 && throttled === 0) {\n          db.updateEventStatus(database, event.id, 'delivered');\n        } else if (eventDelivered > 0 && throttled > 0) {\n          // Some matches delivered but others were concurrency-limited.\n          // Defer with backoff so throttled matches get retried later.\n          db.deferEventForRetry(database, event.id, event.retryCount);\n          logger.info({ eventId: event.id, delivered: eventDelivered, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event partially delivered, deferring throttled matches for retry');\n        } else if (eventDelivered > 0 && eventFailed > 0) {\n          // Some matches delivered but others failed — mark as partial-retry\n          // so the event can be re-processed for the failed matches.\n          db.updateEventStatus(database, event.id, 'partial-retry');\n          logger.info({ eventId: event.id, delivered: eventDelivered, failed: eventFailed }, 'Event partially delivered with failures, marked for retry');\n        } else if (throttled > 0) {\n          // All (or remaining) matches were concurrency-limited — defer with backoff.\n          db.deferEventForRetry(database, event.id, event.retryCount);\n          logger.info({ eventId: event.id, throttled, failed: eventFailed, retryCount: event.retryCount + 1 }, 'Event deferred due to concurrency limits');\n        } else {\n          db.updateEventStatus(database, event.id, 'failed', 'All subscription matches failed');\n        }\n      }\n    })();\n\n    // Fire dispatches after the transaction has committed successfully\n    for (const request of pendingDispatches) {\n      dispatcher.submit(request);\n    }\n  } finally {\n    const tickDurationMs = performance.now() - tickStartMs;\n    logger.info({\n      tickDurationMs,\n      eventsFetched,\n      matchesFound,\n      delivered,\n      skipped,\n      failed\n    }, 'Event processor tick complete');\n  }\n}\n","numLines":318,"startLine":1,"totalLines":318}}}
