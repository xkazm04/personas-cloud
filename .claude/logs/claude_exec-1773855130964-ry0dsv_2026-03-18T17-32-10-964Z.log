[2026-03-18T17:32:22.654Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B9EVMRcpwMAyiNVqEeowoR","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    11→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    12→import type { TenantDbManager } from './tenantDbManager.js';\n    13→import type { TenantKeyManager } from './tenantKeyManager.js';\n    14→import type { AuditLog } from './auditLog.js';\n    15→import type { EventProcessorHealth } from './eventProcessor.js';\n    16→import type { Logger } from 'pino';\n    17→import * as db from './db/index.js';\n    18→import { readBody, json } from './httpUtils.js';\n    19→\n    20→export function createHttpApi(\n    21→  auth: Auth,\n    22→  dispatcher: Dispatcher,\n    23→  pool: WorkerPool,\n    24→  tokenManager: TokenManager,\n    25→  oauth: OAuthManager,\n    26→  logger: Logger,\n    27→  database?: Database.Database,\n    28→  tenantDbManager?: TenantDbManager,\n    29→  tenantKeyManager?: TenantKeyManager,\n    30→  auditLog?: AuditLog,\n    31→  getEventProcessorHealth?: () => EventProcessorHealth,\n    32→): http.Server {\n    33→  const server = http.createServer(async (req, res) => {\n    34→    // Security headers\n    35→    res.setHeader('X-Content-Type-Options', 'nosniff');\n    36→\n    37→    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    38→    const origin = req.headers.origin ?? '';\n    39→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    40→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    41→    if (isAdminRoute) {\n    42→      // Admin routes: only allow same-origin requests (no CORS wildcard)\n    43→      if (origin && origin === allowedOrigin) {\n    44→        res.setHeader('Access-Control-Allow-Origin', origin);\n    45→      }\n    46→      // If no match, omit the header entirely — browser blocks the request\n    47→    } else {\n    48→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    49→    }\n    50→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    51→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n    52→\n    53→    if (req.method === 'OPTIONS') {\n    54→      res.writeHead(204);\n    55→      res.end();\n    56→      return;\n    57→    }\n    58→\n    59→    const url = req.url || '/';\n    60→    const [pathname, queryString] = url.split('?');\n    61→    const route = parseRoute(pathname ?? '');\n    62→\n    63→    // Unauthenticated endpoints\n    64→    if (pathname === '/health' && req.method === 'GET') {\n    65→      handleHealth(res, pool, oauth, getEventProcessorHealth, database, tenantDbManager);\n    66→      return;\n    67→    }\n    68→\n    69→    // Auth check for everything else — dual auth (API key + optional JWT)\n    70→    const ctx = auth.validateAndExtractContext(req);\n    71→    if (!ctx) {\n    72→      res.writeHead(401, { 'Content-Type': 'application/json' });\n    73→      res.end(JSON.stringify({ error: 'Unauthorized' }));\n    74→      return;\n    75→    }\n    76→\n    77→    // Helper: project scoping (admin sees all, user sees own project)\n    78→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n    79→\n    80→    // Resolve tenant-specific database when available\n    81→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n    82→      if (tenantDbManager && projectId) {\n    83→        return tenantDbManager.getTenantDb(projectId);\n    84→      }\n    85→      return database;\n    86→    };\n    87→    const tenantDb = resolveDatabase(ctx.projectId);\n    88→\n    89→    try {\n    90→      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n    91→      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n    92→        if (requireAdmin(ctx, res)) return;\n    93→        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n    94→        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n    95→        return;\n    96→      }\n    97→      // --- Persona CRUD ---\n    98→      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n    99→        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n   100→      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n   101→        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   102→        const persona = createPersonaWithDefaults({\n   103→          ...body,\n   104→          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   105→        });\n   106→        db.upsertPersona(tenantDb, persona);\n   107→        logger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   108→        json(res, 201, persona);\n   109→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n   110→        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n   111→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n   112→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   113→        if (!persona) return;\n   114→        const body = JSON.parse(await readBody(req)) as { toolId: string };\n   115→        db.linkTool(tenantDb, route.id, body.toolId);\n   116→        logger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   117→        json(res, 200, { linked: true });\n   118→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n   119→        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, logger), scopedProjectId, res);\n   120→        if (!hydrated) return;\n   121→        json(res, 200, hydrated);\n   122→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n   123→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   124→        if (!persona) return;\n   125→        json(res, 200, persona);\n   126→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   127→        db.deletePersona(tenantDb, route.id, scopedProjectId);\n   128→        logger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   129→        json(res, 200, { deleted: true });\n   130→      }\n   131→      // --- Tool Definitions ---\n   132→      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n   133→        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   134→        const tool = createToolDefinitionWithDefaults(body);\n   135→        db.upsertToolDefinition(tenantDb, tool);\n   136→        logger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   137→        json(res, 201, tool);\n   138→      }\n   139→      // --- Credentials ---\n   140→      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n   141→        const body = JSON.parse(await readBody(req));\n   142→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   143→\n   144→        // Require plaintext — clients must never supply pre-encrypted data\n   145→        if (!body.plaintext || typeof body.plaintext !== 'string') {\n   146→          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   147→          return;\n   148→        }\n   149→\n   150→        // Reject oversized plaintext before synchronous encryption blocks the event loop\n   151→        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   152→          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   153→          return;\n   154→        }\n   155→\n   156→        // Encryption is mandatory — reject if the key manager is unavailable\n   157→        if (!tenantKeyManager) {\n   158→          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   159→          return;\n   160→        }\n   161→\n   162→        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n   163→        delete body.encryptedData;\n   164→        delete body.iv;\n   165→        delete body.tag;\n   166→\n   167→        // Server-side encryption with per-tenant key\n   168→        const tenantId = body.projectId || ctx.projectId || 'default';\n   169→        const key = await tenantKeyManager.getKey(tenantId);\n   170→        const encrypted = encrypt(body.plaintext, key);\n   171→        body.encryptedData = encrypted.encrypted;\n   172→        body.iv = encrypted.iv;\n   173→        body.tag = encrypted.tag;\n   174→        delete body.plaintext;\n   175→\n   176→        const cred = db.createCredential(tenantDb, body);\n   177→        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n   178→        logger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   179→        json(res, 201, cred);\n   180→      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   181→        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n   182→        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   183→        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   184→        logger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   185→        json(res, 200, { deleted: true });\n   186→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n   187→        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n   188→        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   189→        // Strip encrypted data from response\n   190→        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   191→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n   192→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   193→        if (!persona) return;\n   194→        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   195→        db.linkCredential(tenantDb, route.id, body.credentialId);\n   196→        logger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route.id, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   197→        json(res, 200, { linked: true });\n   198→      }\n   199→      // --- Event Subscriptions ---\n   200→      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n   201→        const body = JSON.parse(await readBody(req));\n   202→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   203→        const missing: string[] = [];\n   204→        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   205→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   206→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   207→        const sub = db.createSubscription(tenantDb, body);\n   208→        json(res, 201, sub);\n   209→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   210→        const body = JSON.parse(await readBody(req));\n   211→        db.updateSubscription(tenantDb, route.id, body);\n   212→        const updated = db.getSubscription(tenantDb, route.id);\n   213→        json(res, 200, updated);\n   214→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   215→        db.deleteSubscription(tenantDb, route.id);\n   216→        json(res, 200, { deleted: true });\n   217→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n   218→        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n   219→      }\n   220→      // --- Triggers (delegated to triggerHttpHandlers) ---\n   221→      else if (route && tenantDb && (\n   222→        route.resource === 'triggers' ||\n   223→        (route.resource === 'personas' && route.subResource === 'triggers')\n   224→      )) {\n   225→        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n   226→        return;\n   227→      }\n   228→      // --- Events ---\n   229→      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n   230→        const params = new URLSearchParams(queryString || '');\n   231→        const events = db.listEvents(tenantDb, {\n   232→          eventType: params.get('eventType') ?? undefined,\n   233→          status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n   234→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   235→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   236→          projectId: scopedProjectId,\n   237→        });\n   238→        json(res, 200, events);\n   239→      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n   240→        const body = JSON.parse(await readBody(req));\n   241→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   242→        const missing: string[] = [];\n   243→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   244→        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   245→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   246→        const event = db.publishEvent(tenantDb, body);\n   247→        json(res, 201, event);\n   248→      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   249→        const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n   250→        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n   251→        if (updated) {\n   252→          json(res, 200, updated);\n   253→        } else {\n   254→          res.writeHead(404, { 'Content-Type': 'application/json' });\n   255→          res.end(JSON.stringify({ error: 'Event not found' }));\n   256→        }\n   257→      }\n   258→      // --- Webhooks ---\n   259→      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n   260→        const personaId = route.id;\n   261→        const body = await readBody(req);\n   262→        const event = db.publishEvent(tenantDb, {\n   263→          eventType: 'webhook_received',\n   264→          sourceType: 'webhook',\n   265→          sourceId: personaId,\n   266→          targetPersonaId: personaId,\n   267→          payload: body,\n   268→        });\n   269→        json(res, 201, event);\n   270→      }\n   271→      // --- GitLab Webhook ---\n   272→      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n   273→        const body = await readBody(req);\n   274→        let parsed: Record<string, unknown> = {};\n   275→        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   276→        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   277→        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   278→        const event = db.publishEvent(tenantDb, {\n   279→          eventType: `gitlab_${objectKind}`,\n   280→          sourceType: 'gitlab',\n   281→          sourceId: projectPath ?? null,\n   282→          payload: body,\n   283→        });\n   284→        json(res, 201, event);\n   285→      }\n   286→      // --- Executions ---\n   287→      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n   288→        const params = new URLSearchParams(queryString || '');\n   289→        const executions = db.listExecutions(tenantDb, {\n   290→          personaId: params.get('personaId') ?? undefined,\n   291→          status: params.get('status') ?? undefined,\n   292→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   293→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   294→          projectId: scopedProjectId,\n   295→        });\n   296→        json(res, 200, executions);\n   297→      }\n   298→      // --- Existing execution endpoints ---\n   299→      else if (pathname === '/api/status' && req.method === 'GET') {\n   300→        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   301→      } else if (pathname === '/api/execute' && req.method === 'POST') {\n   302→        await handleExecute(req, res, dispatcher, logger, ctx);\n   303→      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n   304→        handleCancelExecution(res, dispatcher, route.id);\n   305→      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n   306→        const executionId = route.id;\n   307→        const params = new URLSearchParams(queryString || '');\n   308→        const offset = parseInt(params.get('offset') || '0', 10);\n   309→        handleGetExecution(res, dispatcher, executionId, offset);\n   310→      }\n   311→      // --- Admin-only routes ---\n   312→      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n   313→        if (requireAdmin(ctx, res)) return;\n   314→        if (tenantDbManager) {\n   315→          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   316→        } else if (database) {\n   317→          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   318→        } else {\n   319→          json(res, 200, { projectIds: [] });\n   320→        }\n   321→      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n   322→        if (requireAdmin(ctx, res)) return;\n   323→        if (tenantDbManager) {\n   324→          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   325→          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   326→          json(res, 200, allPersonas);\n   327→        } else if (database) {\n   328→          json(res, 200, db.listPersonasSummary(database));\n   329→        } else {\n   330→          json(res, 200, []);\n   331→        }\n   332→      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n   333→        if (requireAdmin(ctx, res)) return;\n   334→        const params = new URLSearchParams(queryString || '');\n   335→        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   336→        if (tenantDbManager) {\n   337→          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   338→          tenantDbManager.forEachTenant((tDb) => {\n   339→            allExecs.push(...db.listExecutions(tDb, { limit }));\n   340→          });\n   341→          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   342→          json(res, 200, allExecs.slice(0, limit));\n   343→        } else if (database) {\n   344→          json(res, 200, db.listExecutions(database, {\n   345→            limit,\n   346→            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   347→          }));\n   348→        } else {\n   349→          json(res, 200, []);\n   350→        }\n   351→      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n   352→        if (requireAdmin(ctx, res)) return;\n   353→        if (!auditLog) { json(res, 200, []); return; }\n   354→        const params = new URLSearchParams(queryString || '');\n   355→        json(res, 200, auditLog.query({\n   356→          tenantId: params.get('tenantId') ?? undefined,\n   357→          action: params.get('action') ?? undefined,\n   358→          since: params.get('since') ?? undefined,\n   359→          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   360→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   361→        }));\n   362→      } else {\n   363→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   364→        res.end(JSON.stringify({ error: 'Not found' }));\n   365→      }\n   366→    } catch (err) {\n   367→      if (err instanceof Error && err.message === 'Payload too large') {\n   368→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   369→        res.end(JSON.stringify({ error: 'Payload too large' }));\n   370→        return;\n   371→      }\n   372→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   373→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   374→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n   375→        return;\n   376→      }\n   377→      logger.error({ err, url }, 'HTTP handler error');\n   378→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   379→      res.end(JSON.stringify({ error: 'Internal server error' }));\n   380→    }\n   381→  });\n   382→\n   383→  return server;\n   384→}\n   385→\n   386→interface ParsedRoute {\n   387→  resource: string;\n   388→  id?: string;\n   389→  subResource?: string;\n   390→}\n   391→\n   392→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n   393→function parseRoute(pathname: string): ParsedRoute | null {\n   394→  if (!pathname.startsWith('/api/')) return null;\n   395→  const segments = pathname.slice(5).split('/').filter(Boolean);\n   396→  if (segments.length === 0) return null;\n   397→  return {\n   398→    resource: segments[0]!,\n   399→    id: segments[1],\n   400→    subResource: segments[2],\n   401→  };\n   402→}\n   403→\n   404→/**\n   405→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   406→ * Returns the entity on success, or null after sending a 404 response.\n   407→ */\n   408→function withScopedEntity<T extends { projectId?: string | null }>(\n   409→  entity: T | undefined,\n   410→  scopedProjectId: string | undefined,\n   411→  res: http.ServerResponse,\n   412→): T | null {\n   413→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   414→    json(res, 404, { error: 'Not found' });\n   415→    return null;\n   416→  }\n   417→  return entity;\n   418→}\n   419→\n   420→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   421→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   422→  if (ctx.authType !== 'admin') {\n   423→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   424→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   425→    return true;\n   426→  }\n   427→  return false;\n   428→}\n   429→\n   430→// --- Existing handlers ---\n   431→\n   432→function handleHealth(\n   433→  res: http.ServerResponse,\n   434→  pool: WorkerPool,\n   435→  oauth: OAuthManager,\n   436→  getEventProcessorHealth?: () => EventProcessorHealth,\n   437→  database?: Database.Database,\n   438→  tenantDbManager?: TenantDbManager,\n   439→): void {\n   440→  const counts = pool.getWorkerCount();\n   441→\n   442→  // Lightweight database connectivity check\n   443→  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n   444→  if (database) {\n   445→    try {\n   446→      database.prepare('SELECT 1').get();\n   447→      dbHealth.status = 'ok';\n   448→    } catch {\n   449→      dbHealth.status = 'error';\n   450→    }\n   451→  }\n   452→  if (tenantDbManager) {\n   453→    try {\n   454→      const tenantIds = tenantDbManager.listTenantIds();\n   455→      dbHealth.tenantCount = tenantIds.length;\n   456→    } catch {\n   457→      dbHealth.tenantCount = -1;\n   458→    }\n   459→  }\n   460→\n   461→  const body: Record<string, unknown> = {\n   462→    status: 'ok',\n   463→    workers: counts,\n   464→    hasSubscription: oauth.hasTokens(),\n   465→    database: dbHealth,\n   466→    timestamp: Date.now(),\n   467→  };\n   468→  if (getEventProcessorHealth) {\n   469→    body.eventProcessor = getEventProcessorHealth();\n   470→  }\n   471→\n   472→  // Degrade overall status if database is unhealthy\n   473→  if (dbHealth.status === 'error') {\n   474→    body.status = 'degraded';\n   475→  }\n   476→\n   477→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   478→  res.end(JSON.stringify(body));\n   479→}\n   480→\n   481→function handleStatus(\n   482→  res: http.ServerResponse,\n   483→  pool: WorkerPool,\n   484→  dispatcher: Dispatcher,\n   485→  tokenManager: TokenManager,\n   486→  oauth: OAuthManager,\n   487→): void {\n   488→  const oauthTokens = oauth.getTokens();\n   489→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   490→  res.end(JSON.stringify({\n   491→    workers: pool.getWorkers(),\n   492→    workerCounts: pool.getWorkerCount(),\n   493→    workerPoolMetrics: pool.getMetrics(),\n   494→    queueLength: dispatcher.getQueueLength(),\n   495→    activeExecutions: dispatcher.getActiveExecutions(),\n   496→    hasClaudeToken: tokenManager.hasToken(),\n   497→    oauth: {\n   498→      connected: oauth.hasTokens(),\n   499→      scopes: oauthTokens?.scopes || [],\n   500→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   501→    },\n   502→  }));\n   503→}\n   504→\n   505→async function handleExecute(\n   506→  req: http.IncomingMessage,\n   507→  res: http.ServerResponse,\n   508→  dispatcher: Dispatcher,\n   509→  logger: Logger,\n   510→  ctx?: RequestContext,\n   511→): Promise<void> {\n   512→  const body = await readBody(req);\n   513→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   514→\n   515→  try {\n   516→    parsed = JSON.parse(body);\n   517→  } catch {\n   518→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   519→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   520→    return;\n   521→  }\n   522→\n   523→  if (!parsed.prompt) {\n   524→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   525→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   526→    return;\n   527→  }\n   528→\n   529→  const request: ExecRequest = {\n   530→    executionId: nanoid(),\n   531→    personaId: parsed.personaId || 'manual',\n   532→    prompt: parsed.prompt,\n   533→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   534→    config: {\n   535→      timeoutMs: parsed.timeoutMs || 300_000,\n   536→    },\n   537→  };\n   538→\n   539→  dispatcher.submit(request);\n   540→\n   541→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   542→\n   543→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   544→  res.end(JSON.stringify({\n   545→    executionId: request.executionId,\n   546→    status: 'queued',\n   547→  }));\n   548→}\n   549→\n   550→function handleGetExecution(\n   551→  res: http.ServerResponse,\n   552→  dispatcher: Dispatcher,\n   553→  executionId: string,\n   554→  offset: number = 0,\n   555→): void {\n   556→  const exec = dispatcher.getExecution(executionId);\n   557→\n   558→  if (!exec) {\n   559→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   560→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   561→    return;\n   562→  }\n   563→\n   564→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   565→\n   566→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   567→  res.end(JSON.stringify({\n   568→    executionId,\n   569→    status: exec.status,\n   570→    outputLines: exec.output.length,\n   571→    output,\n   572→    durationMs: exec.durationMs,\n   573→    sessionId: exec.sessionId,\n   574→    totalCostUsd: exec.totalCostUsd,\n   575→    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n   576→  }));\n   577→}\n   578→\n   579→function handleCancelExecution(\n   580→  res: http.ServerResponse,\n   581→  dispatcher: Dispatcher,\n   582→  executionId: string,\n   583→): void {\n   584→  const cancelled = dispatcher.cancelExecution(executionId);\n   585→\n   586→  if (!cancelled) {\n   587→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   588→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   589→    return;\n   590→  }\n   591→\n   592→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   593→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   594→}\n   595→\n   596→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\n   597→const MAX_QUERY_LIMIT = 500;\n   598→const MAX_QUERY_OFFSET = 100_000;\n   599→\n   600→/** Parse an integer query param and clamp it to safe bounds. */\n   601→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   602→  if (!value) return defaultValue;\n   603→  const parsed = parseInt(value, 10);\n   604→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   605→  return Math.min(parsed, max);\n   606→}\n   607→"}]},"parent_tool_use_id":null,"session_id":"90a8b635-e710-41f3-b833-6b6754d67d54","uuid":"610f0008-3111-4ba4-b3bc-a6c7c131c6c3","timestamp":"2026-03-18T17:32:22.184Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { EventProcessorHealth } from './eventProcessor.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n): http.Server {\n  const server = http.createServer(async (req, res) => {\n    // Security headers\n    res.setHeader('X-Content-Type-Options', 'nosniff');\n\n    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    const origin = req.headers.origin ?? '';\n    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    if (isAdminRoute) {\n      // Admin routes: only allow same-origin requests (no CORS wildcard)\n      if (origin && origin === allowedOrigin) {\n        res.setHeader('Access-Control-Allow-Origin', origin);\n      }\n      // If no match, omit the header entirely — browser blocks the request\n    } else {\n      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    }\n    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n\n    if (req.method === 'OPTIONS') {\n      res.writeHead(204);\n      res.end();\n      return;\n    }\n\n    const url = req.url || '/';\n    const [pathname, queryString] = url.split('?');\n    const route = parseRoute(pathname ?? '');\n\n    // Unauthenticated endpoints\n    if (pathname === '/health' && req.method === 'GET') {\n      handleHealth(res, pool, oauth, getEventProcessorHealth, database, tenantDbManager);\n      return;\n    }\n\n    // Auth check for everything else — dual auth (API key + optional JWT)\n    const ctx = auth.validateAndExtractContext(req);\n    if (!ctx) {\n      res.writeHead(401, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Unauthorized' }));\n      return;\n    }\n\n    // Helper: project scoping (admin sees all, user sees own project)\n    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n\n    // Resolve tenant-specific database when available\n    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n      if (tenantDbManager && projectId) {\n        return tenantDbManager.getTenantDb(projectId);\n      }\n      return database;\n    };\n    const tenantDb = resolveDatabase(ctx.projectId);\n\n    try {\n      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n        if (requireAdmin(ctx, res)) return;\n        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n        return;\n      }\n      // --- Persona CRUD ---\n      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n        const persona = createPersonaWithDefaults({\n          ...body,\n          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n        });\n        db.upsertPersona(tenantDb, persona);\n        logger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n        json(res, 201, persona);\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { toolId: string };\n        db.linkTool(tenantDb, route.id, body.toolId);\n        logger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n        json(res, 200, { linked: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, logger), scopedProjectId, res);\n        if (!hydrated) return;\n        json(res, 200, hydrated);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        json(res, 200, persona);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deletePersona(tenantDb, route.id, scopedProjectId);\n        logger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n        json(res, 200, { deleted: true });\n      }\n      // --- Tool Definitions ---\n      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n        const tool = createToolDefinitionWithDefaults(body);\n        db.upsertToolDefinition(tenantDb, tool);\n        logger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n        json(res, 201, tool);\n      }\n      // --- Credentials ---\n      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n\n        // Require plaintext — clients must never supply pre-encrypted data\n        if (!body.plaintext || typeof body.plaintext !== 'string') {\n          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n          return;\n        }\n\n        // Reject oversized plaintext before synchronous encryption blocks the event loop\n        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n          return;\n        }\n\n        // Encryption is mandatory — reject if the key manager is unavailable\n        if (!tenantKeyManager) {\n          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n          return;\n        }\n\n        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n        delete body.encryptedData;\n        delete body.iv;\n        delete body.tag;\n\n        // Server-side encryption with per-tenant key\n        const tenantId = body.projectId || ctx.projectId || 'default';\n        const key = await tenantKeyManager.getKey(tenantId);\n        const encrypted = encrypt(body.plaintext, key);\n        body.encryptedData = encrypted.encrypted;\n        body.iv = encrypted.iv;\n        body.tag = encrypted.tag;\n        delete body.plaintext;\n\n        const cred = db.createCredential(tenantDb, body);\n        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n        json(res, 201, cred);\n      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n        // Strip encrypted data from response\n        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n        db.linkCredential(tenantDb, route.id, body.credentialId);\n        logger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route.id, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n        json(res, 200, { linked: true });\n      }\n      // --- Event Subscriptions ---\n      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const sub = db.createSubscription(tenantDb, body);\n        json(res, 201, sub);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        db.updateSubscription(tenantDb, route.id, body);\n        const updated = db.getSubscription(tenantDb, route.id);\n        json(res, 200, updated);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deleteSubscription(tenantDb, route.id);\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n      }\n      // --- Triggers (delegated to triggerHttpHandlers) ---\n      else if (route && tenantDb && (\n        route.resource === 'triggers' ||\n        (route.resource === 'personas' && route.subResource === 'triggers')\n      )) {\n        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n        return;\n      }\n      // --- Events ---\n      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const events = db.listEvents(tenantDb, {\n          eventType: params.get('eventType') ?? undefined,\n          status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, events);\n      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const event = db.publishEvent(tenantDb, body);\n        json(res, 201, event);\n      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n        if (updated) {\n          json(res, 200, updated);\n        } else {\n          res.writeHead(404, { 'Content-Type': 'application/json' });\n          res.end(JSON.stringify({ error: 'Event not found' }));\n        }\n      }\n      // --- Webhooks ---\n      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n        const personaId = route.id;\n        const body = await readBody(req);\n        const event = db.publishEvent(tenantDb, {\n          eventType: 'webhook_received',\n          sourceType: 'webhook',\n          sourceId: personaId,\n          targetPersonaId: personaId,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- GitLab Webhook ---\n      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n        const body = await readBody(req);\n        let parsed: Record<string, unknown> = {};\n        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n        const event = db.publishEvent(tenantDb, {\n          eventType: `gitlab_${objectKind}`,\n          sourceType: 'gitlab',\n          sourceId: projectPath ?? null,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- Executions ---\n      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const executions = db.listExecutions(tenantDb, {\n          personaId: params.get('personaId') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, executions);\n      }\n      // --- Existing execution endpoints ---\n      else if (pathname === '/api/status' && req.method === 'GET') {\n        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n      } else if (pathname === '/api/execute' && req.method === 'POST') {\n        await handleExecute(req, res, dispatcher, logger, ctx);\n      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n        handleCancelExecution(res, dispatcher, route.id);\n      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n        const executionId = route.id;\n        const params = new URLSearchParams(queryString || '');\n        const offset = parseInt(params.get('offset') || '0', 10);\n        handleGetExecution(res, dispatcher, executionId, offset);\n      }\n      // --- Admin-only routes ---\n      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n        } else if (database) {\n          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n        } else {\n          json(res, 200, { projectIds: [] });\n        }\n      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n          json(res, 200, allPersonas);\n        } else if (database) {\n          json(res, 200, db.listPersonasSummary(database));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        const params = new URLSearchParams(queryString || '');\n        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n        if (tenantDbManager) {\n          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n          tenantDbManager.forEachTenant((tDb) => {\n            allExecs.push(...db.listExecutions(tDb, { limit }));\n          });\n          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n          json(res, 200, allExecs.slice(0, limit));\n        } else if (database) {\n          json(res, 200, db.listExecutions(database, {\n            limit,\n            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          }));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (!auditLog) { json(res, 200, []); return; }\n        const params = new URLSearchParams(queryString || '');\n        json(res, 200, auditLog.query({\n          tenantId: params.get('tenantId') ?? undefined,\n          action: params.get('action') ?? undefined,\n          since: params.get('since') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        }));\n      } else {\n        res.writeHead(404, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Not found' }));\n      }\n    } catch (err) {\n      if (err instanceof Error && err.message === 'Payload too large') {\n        res.writeHead(413, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Payload too large' }));\n        return;\n      }\n      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n        res.writeHead(409, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n        return;\n      }\n      logger.error({ err, url }, 'HTTP handler error');\n      res.writeHead(500, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Internal server error' }));\n    }\n  });\n\n  return server;\n}\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\n/**\n * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n * Returns the entity on success, or null after sending a 404 response.\n */\nfunction withScopedEntity<T extends { projectId?: string | null }>(\n  entity: T | undefined,\n  scopedProjectId: string | undefined,\n  res: http.ServerResponse,\n): T | null {\n  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n    json(res, 404, { error: 'Not found' });\n    return null;\n  }\n  return entity;\n}\n\n/** Returns true (and sends 403) if the caller is NOT an admin. */\nfunction requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n  if (ctx.authType !== 'admin') {\n    res.writeHead(403, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Admin access required' }));\n    return true;\n  }\n  return false;\n}\n\n// --- Existing handlers ---\n\nfunction handleHealth(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  oauth: OAuthManager,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n): void {\n  const counts = pool.getWorkerCount();\n\n  // Lightweight database connectivity check\n  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n  if (database) {\n    try {\n      database.prepare('SELECT 1').get();\n      dbHealth.status = 'ok';\n    } catch {\n      dbHealth.status = 'error';\n    }\n  }\n  if (tenantDbManager) {\n    try {\n      const tenantIds = tenantDbManager.listTenantIds();\n      dbHealth.tenantCount = tenantIds.length;\n    } catch {\n      dbHealth.tenantCount = -1;\n    }\n  }\n\n  const body: Record<string, unknown> = {\n    status: 'ok',\n    workers: counts,\n    hasSubscription: oauth.hasTokens(),\n    database: dbHealth,\n    timestamp: Date.now(),\n  };\n  if (getEventProcessorHealth) {\n    body.eventProcessor = getEventProcessorHealth();\n  }\n\n  // Degrade overall status if database is unhealthy\n  if (dbHealth.status === 'error') {\n    body.status = 'degraded';\n  }\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify(body));\n}\n\nfunction handleStatus(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n): void {\n  const oauthTokens = oauth.getTokens();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    workers: pool.getWorkers(),\n    workerCounts: pool.getWorkerCount(),\n    workerPoolMetrics: pool.getMetrics(),\n    queueLength: dispatcher.getQueueLength(),\n    activeExecutions: dispatcher.getActiveExecutions(),\n    hasClaudeToken: tokenManager.hasToken(),\n    oauth: {\n      connected: oauth.hasTokens(),\n      scopes: oauthTokens?.scopes || [],\n      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n    },\n  }));\n}\n\nasync function handleExecute(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  ctx?: RequestContext,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.prompt) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n    return;\n  }\n\n  const request: ExecRequest = {\n    executionId: nanoid(),\n    personaId: parsed.personaId || 'manual',\n    prompt: parsed.prompt,\n    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n    config: {\n      timeoutMs: parsed.timeoutMs || 300_000,\n    },\n  };\n\n  dispatcher.submit(request);\n\n  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n\n  res.writeHead(202, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId: request.executionId,\n    status: 'queued',\n  }));\n}\n\nfunction handleGetExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n  offset: number = 0,\n): void {\n  const exec = dispatcher.getExecution(executionId);\n\n  if (!exec) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found' }));\n    return;\n  }\n\n  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId,\n    status: exec.status,\n    outputLines: exec.output.length,\n    output,\n    durationMs: exec.durationMs,\n    sessionId: exec.sessionId,\n    totalCostUsd: exec.totalCostUsd,\n    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n  }));\n}\n\nfunction handleCancelExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n): void {\n  const cancelled = dispatcher.cancelExecution(executionId);\n\n  if (!cancelled) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n    return;\n  }\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n}\n\nconst MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\nconst MAX_QUERY_LIMIT = 500;\nconst MAX_QUERY_OFFSET = 100_000;\n\n/** Parse an integer query param and clamp it to safe bounds. */\nfunction clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n  if (!value) return defaultValue;\n  const parsed = parseInt(value, 10);\n  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n  return Math.min(parsed, max);\n}\n","numLines":607,"startLine":1,"totalLines":607}}}
