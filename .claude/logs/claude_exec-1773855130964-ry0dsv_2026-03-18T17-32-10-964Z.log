[2026-03-18T17:34:34.427Z] [STDOUT] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_014Ngrc9fJPgHkVhbu8Eks3t","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016ZaRy1BvV22kfpauDtnNH5","name":"Edit","input":{"replace_all":false,"file_path":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","old_string":"function handleHealth(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  oauth: OAuthManager,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n): void {\n  const counts = pool.getWorkerCount();\n\n  // Lightweight database connectivity check\n  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n  if (database) {\n    try {\n      database.prepare('SELECT 1').get();\n      dbHealth.status = 'ok';\n    } catch {\n      dbHealth.status = 'error';\n    }\n  }\n  if (tenantDbManager) {\n    try {\n      const tenantIds = tenantDbManager.listTenantIds();\n      dbHealth.tenantCount = tenantIds.length;\n    } catch {\n      dbHealth.tenantCount = -1;\n    }\n  }\n\n  const body: Record<string, unknown> = {\n    status: 'ok',\n    workers: counts,\n    hasSubscription: oauth.hasTokens(),\n    database: dbHealth,\n    timestamp: Date.now(),\n  };\n  if (getEventProcessorHealth) {\n    body.eventProcessor = getEventProcessorHealth();\n  }\n\n  // Degrade overall status if database is unhealthy\n  if (dbHealth.status === 'error') {\n    body.status = 'degraded';\n  }\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify(body));\n}","new_string":"async function handleHealth(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  oauth: OAuthManager,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  kafka?: KafkaClient,\n): Promise<void> {\n  type DepStatus = 'ok' | 'degraded' | 'error' | 'unavailable' | 'disabled';\n\n  // --- Database ---\n  const dbHealth: { status: DepStatus; tenantCount?: number } = { status: 'unavailable' };\n  if (database) {\n    try {\n      database.prepare('SELECT 1').get();\n      dbHealth.status = 'ok';\n    } catch {\n      dbHealth.status = 'error';\n    }\n  }\n  if (tenantDbManager) {\n    try {\n      const tenantIds = tenantDbManager.listTenantIds();\n      dbHealth.tenantCount = tenantIds.length;\n      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n    } catch {\n      dbHealth.tenantCount = -1;\n      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n    }\n  }\n\n  // --- Kafka ---\n  const kafkaHealth = kafka\n    ? await kafka.checkHealth()\n    : { status: 'disabled' as const };\n\n  // --- Workers ---\n  const counts = pool.getWorkerCount();\n  const staleWorkers = pool.getStaleWorkers();\n  const workersHealth: {\n    status: DepStatus;\n    total: number;\n    idle: number;\n    executing: number;\n    staleHeartbeats: Array<{ workerId: string; heartbeatAgeMs: number }>;\n  } = {\n    status: counts.total > 0 ? (staleWorkers.length > 0 ? 'degraded' : 'ok') : 'ok',\n    ...counts,\n    staleHeartbeats: staleWorkers,\n  };\n\n  // --- Queue ---\n  const queueDepth = dispatcher.getQueueLength();\n\n  // --- Event processor ---\n  const eventProcessorHealth = getEventProcessorHealth?.();\n\n  // --- Overall verdict ---\n  const depStatuses: DepStatus[] = [\n    dbHealth.status,\n    kafkaHealth.status === 'disabled' ? 'ok' : kafkaHealth.status,\n    workersHealth.status,\n  ];\n  let overall: 'healthy' | 'degraded' | 'unhealthy' = 'healthy';\n  if (depStatuses.includes('error')) {\n    overall = 'unhealthy';\n  } else if (depStatuses.includes('degraded') || depStatuses.includes('unavailable')) {\n    overall = 'degraded';\n  }\n\n  const body = {\n    status: overall,\n    dependencies: {\n      database: dbHealth,\n      kafka: kafkaHealth,\n      workers: workersHealth,\n    },\n    queue: { depth: queueDepth },\n    oauth: { connected: oauth.hasTokens() },\n    ...(eventProcessorHealth ? { eventProcessor: eventProcessorHealth } : {}),\n    timestamp: Date.now(),\n  };\n\n  const httpStatus = overall === 'unhealthy' ? 503 : 200;\n  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify(body));\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":951,"cache_read_input_tokens":62783,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":951},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"90a8b635-e710-41f3-b833-6b6754d67d54","uuid":"18bf262e-2f6c-4e78-8e6a-086e1e14e38d"}
