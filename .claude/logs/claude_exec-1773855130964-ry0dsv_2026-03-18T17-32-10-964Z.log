nectionDurations.length > WorkerPool.MAX_DURATION_HISTORY) {\n   282→      this.metrics.recentConnectionDurations.shift();\n   283→    }\n   284→\n   285→    this.logger.info({ workerId, hadExecution, connectionDurationMs }, 'Worker disconnected');\n   286→    this.emit('worker-disconnected', workerId, hadExecution);\n   287→  }\n   288→\n   289→  private handleWorkerMessage(workerId: string, msg: WorkerMessage): void {\n   290→    const entry = this.workers.get(workerId);\n   291→    if (!entry) return;\n   292→\n   293→    switch (msg.type) {\n   294→      case 'heartbeat':\n   295→        entry.info.lastHeartbeat = Date.now();\n   296→        break;\n   297→\n   298→      case 'ready':\n   299→        entry.info.status = 'idle';\n   300→        entry.info.currentExecutionId = undefined;\n   301→        this.idleWorkers.add(workerId);\n   302→        this.emit('worker-ready', workerId);\n   303→        break;\n   304→\n   305→      case 'stdout':\n   306→        this.emit('stdout', workerId, msg);\n   307→        break;\n   308→\n   309→      case 'stderr':\n   310→        this.emit('stderr', workerId, msg);\n   311→        break;\n   312→\n   313→      case 'complete':\n   314→        entry.info.status = 'idle';\n   315→        entry.info.currentExecutionId = undefined;\n   316→        this.idleWorkers.add(workerId);\n   317→        this.logger.info({\n   318→          workerId,\n   319→          executionId: msg.executionId,\n   320→          status: msg.status,\n   321→          durationMs: msg.durationMs,\n   322→          ...(msg.phaseTimings ? { phaseTimings: msg.phaseTimings } : {}),\n   323→        }, 'Execution complete');\n   324→        this.emit('complete', workerId, msg);\n   325→        break;\n   326→\n   327→      case 'event':\n   328→        this.emit('persona-event', workerId, msg);\n   329→        break;\n   330→\n   331→      case 'progress':\n   332→        this.emit('progress', workerId, msg);\n   333→        break;\n   334→\n   335→      ca