[2026-03-18T17:32:22.904Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VuH7yo1C4BUfGMHkkwywxQ","type":"tool_result","content":"     1→import { type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type PhaseTimings, type EncryptedPayload, TOPICS, decrypt, DecryptionError, deriveMasterKeyAsync } from '@dac-cloud/shared';\n     2→import type Database from 'better-sqlite3';\n     3→import type { WorkerPool } from './workerPool.js';\n     4→import type { TokenManager } from './tokenManager.js';\n     5→import type { OAuthManager } from './oauth.js';\n     6→import type { KafkaClient } from './kafka.js';\n     7→import type { TenantDbManager } from './tenantDbManager.js';\n     8→import type { TenantKeyManager } from './tenantKeyManager.js';\n     9→import type { AuditLog } from './auditLog.js';\n    10→import type { Logger } from 'pino';\n    11→import * as db from './db/index.js';\n    12→import { resolveToken, resolvePersona, assemblePayload, buildAssignment, type Decryptor } from './dispatchPipeline.js';\n    13→\n    14→interface QueuedExecution {\n    15→  request: ExecRequest;\n    16→  receivedAt: number;\n    17→}\n    18→\n    19→// Maximum number of times an execution will be re-queued after worker disconnect\n    20→const MAX_DISCONNECT_RETRIES = 2;\n    21→\n    22→// In-memory tracking for active executions (real-time output streaming)\n    23→interface ActiveExecution {\n    24→  workerId: string;\n    25→  startedAt: number;\n    26→  output: string[];\n    27→  status: 'running' | 'completed' | 'failed' | 'cancelled';\n    28→  progress?: ProgressInfo;\n    29→  completedAt?: number;\n    30→  exitCode?: number;\n    31→  durationMs?: number;\n    32→  sessionId?: string;\n    33→  totalCostUsd?: number;\n    34→  phaseTimings?: PhaseTimings;\n    35→  /** Original request kept for re-queuing on worker disconnect. Only present for in-flight executions. */\n    36→  request?: ExecRequest;\n    37→  /** How many times this execution has been re-queued after a worker disconnect. */\n    38→  disconnectRetries?: number;\n    39→}\n    40→\n    41→const OUTPUT_FLUSH_INTERVAL_MS = 500;\n    42→\n    43→export class Dispatcher {\n    44→  private queue: QueuedExecution[] = [];\n    45→  // In-memory map for real-time output + cancel routing (active executions only)\n    46→  private active = new Map<string, ActiveExecution>();\n    47→  private tenantDbManager: TenantDbManager | null = null;\n    48→  private masterKey: Buffer | null = null;\n    49→  private tenantKeyManager: TenantKeyManager | null = null;\n    50→  private auditLog: AuditLog | null = null;\n    51→  // Maps executionId → projectId for DB resolution during callbacks\n    52→  private executionTenant = new Map<string, string>();\n    53→  // Batched output buffers: executionId → pending chunks\n    54→  private outputBuffers = new Map<string, string[]>();\n    55→  private outputFlushTimer: NodeJS.Timeout;\n    56→  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n    57→  private dispatching = false;\n    58→\n    59→  constructor(\n    60→    private pool: WorkerPool,\n    61→    private tokenManager: TokenManager,\n    62→    private oauth: OAuthManager | null,\n    63→    private kafka: KafkaClient,\n    64→    private logger: Logger,\n    65→  ) {\n    66→    // Periodic flush of batched output to DB\n    67→    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n    68→\n    69→    // When a worker becomes ready, try to dispatch queued work\n    70→    this.pool.on('worker-ready', () => {\n    71→      this.processQueue();\n    72→    });\n    73→\n    74→    // When a worker connects, try to dispatch\n    75→    this.pool.on('worker-connected', () => {\n    76→      this.processQueue();\n    77→    });\n    78→\n    79→    // Track stdout for execution output\n    80→    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n    81→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    82→    });\n    83→\n    84→    // Track stderr for debugging failed executions\n    85→    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n    86→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n    87→      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    88→    });\n    89→\n    90→    // Handle execution completion\n    91→    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n    92→      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n    93→        executionId: msg.executionId,\n    94→        status: msg.status,\n    95→        exitCode: msg.exitCode,\n    96→        durationMs: msg.durationMs,\n    97→        sessionId: msg.sessionId,\n    98→        totalCostUsd: msg.totalCostUsd,\n    99→        ...(msg.phaseTimings ? { phaseTimings: msg.phaseTimings } : {}),\n   100→      }), msg.executionId).catch(err => {\n   101→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n   102→      });\n   103→\n   104→      // Flush any remaining buffered output before persisting completion\n   105→      this.flushOutputForExecution(msg.executionId);\n   106→\n   107→      // Update in-memory\n   108→      const exec = this.active.get(msg.executionId);\n   109→      if (exec) {\n   110→        exec.status = msg.status;\n   111→        exec.completedAt = Date.now();\n   112→        exec.exitCode = msg.exitCode;\n   113→        exec.durationMs = msg.durationMs;\n   114→        exec.sessionId = msg.sessionId;\n   115→        exec.totalCostUsd = msg.totalCostUsd;\n   116→        exec.phaseTimings = msg.phaseTimings;\n   117→        // Remove from active after a short delay (allow polling to pick up final state)\n   118→        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n   119→      }\n   120→\n   121→      // Persist to DB\n   122→      const completeDb = this.resolveDbForExecution(msg.executionId);\n   123→      if (completeDb) {\n   124→        try {\n   125→          db.updateExecution(completeDb, msg.executionId, {\n   126→            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n   127→            completedAt: new Date().toISOString(),\n   128→            durationMs: msg.durationMs,\n   129→            claudeSessionId: msg.sessionId,\n   130→            costUsd: msg.totalCostUsd ?? 0,\n   131→          });\n   132→        } catch (err) {\n   133→          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n   134→        }\n   135→      }\n   136→\n   137→      // Clean up tenant mapping after completion delay\n   138→      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n   139→\n   140→      // Process next queued item\n   141→      this.processQueue();\n   142→    });\n   143→\n   144→    // Track execution progress\n   145→    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n   146→      const exec = this.active.get(msg.executionId);\n   147→      if (exec) {\n   148→        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n   149→      }\n   150→      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n   151→        executionId: msg.executionId,\n   152→        phase: msg.phase,\n   153→        percent: msg.percent,\n   154→        detail: msg.detail,\n   155→        timestamp: msg.timestamp,\n   156→      }), msg.executionId).catch(err => {\n   157→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n   158→      });\n   159→    });\n   160→\n   161→    // Forward persona events to Kafka\n   162→    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n   163→      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n   164→        executionId: msg.executionId,\n   165→        eventType: msg.eventType,\n   166→        payload: msg.payload,\n   167→        timestamp: Date.now(),\n   168→      }), msg.executionId).catch(err => {\n   169→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n   170→      });\n   171→    });\n   172→\n   173→    // Handle worker busy nack — re-queue the rejected execution\n   174→    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n   175→      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n   176→      const exec = this.active.get(msg.executionId);\n   177→      if (exec?.request) {\n   178→        const request = exec.request;\n   179→        this.active.delete(msg.executionId);\n   180→        // Mark as queued in DB\n   181→        const reqDb = this.resolveDbForExecution(msg.executionId);\n   182→        if (reqDb) {\n   183→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack'); }\n   184→        }\n   185→        this.queue.unshift({ request, receivedAt: Date.now() });\n   186→        this.processQueue();\n   187→      } else {\n   188→        // Fallback: reconstruct from DB if request was not stored (should not happen)\n   189→        this.active.delete(msg.executionId);\n   190→        const projectId = this.executionTenant.get(msg.executionId) || 'default';\n   191→        const reqDb = this.resolveDb(projectId);\n   192→        if (reqDb) {\n   193→          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack fallback'); }\n   194→        }\n   195→        const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n   196→        if (dbExec) {\n   197→          this.queue.unshift({\n   198→            request: {\n   199→              executionId: msg.executionId,\n   200→              personaId: dbExec.personaId,\n   201→              prompt: dbExec.inputData || '',\n   202→              projectId,\n   203→              config: { timeoutMs: 300_000 },\n   204→            },\n   205→            receivedAt: Date.now(),\n   206→          });\n   207→          this.processQueue();\n   208→        }\n   209→      }\n   210→    });\n   211→\n   212→    // Handle worker disconnect during execution — re-queue if retries remain\n   213→    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n   214→      if (executionId) {\n   215→        const exec = this.active.get(executionId);\n   216→        const retries = exec?.disconnectRetries ?? 0;\n   217→\n   218→        if (exec?.request && retries < MAX_DISCONNECT_RETRIES) {\n   219→          // Re-queue for retry\n   220→          const nextRetry = retries + 1;\n   221→          this.logger.warn({ executionId, retry: nextRetry, maxRetries: MAX_DISCONNECT_RETRIES }, 'Worker disconnected during execution, re-queuing');\n   222→\n   223→          // Clear the active entry so dispatchToWorker can create a fresh one\n   224→          this.active.delete(executionId);\n   225→\n   226→          // Mark as queued in DB\n   227→          const disconnDb = this.resolveDbForExecution(executionId);\n   228→          if (disconnDb) {\n   229→            try {\n   230→              db.updateExecution(disconnDb, executionId, {\n   231→                status: 'queued',\n   232→                errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n   233→              });\n   234→            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on worker disconnect re-queue'); }\n   235→          }\n   236→\n   237→          // Temporarily store the retry count so dispatchToWorker picks it up\n   238→          const request = exec.request;\n   239→          // Create a placeholder active entry to carry retry count across re-dispatch\n   240→          this.active.set(executionId, {\n   241→            workerId: '',\n   242→            startedAt: 0,\n   243→            output: [],\n   244→            status: 'running',\n   245→            request,\n   246→            disconnectRetries: nextRetry,\n   247→          });\n   248→\n   249→          this.queue.unshift({ request, receivedAt: Date.now() });\n   250→          this.processQueue();\n   251→        } else {\n   252→          // Retries exhausted or no request stored — permanent failure\n   253→          this.logger.error({ executionId, retries }, 'Worker disconnected during execution, retries exhausted');\n   254→          if (exec) {\n   255→            exec.status = 'failed';\n   256→            exec.completedAt = Date.now();\n   257→            setTimeout(() => this.active.delete(executionId), 30_000);\n   258→          }\n   259→\n   260→          const disconnDb = this.resolveDbForExecution(executionId);\n   261→          if (disconnDb) {\n   262→            try {\n   263→              db.updateExecution(disconnDb, executionId, {\n   264→                status: 'failed',\n   265→                errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n   266→                completedAt: new Date().toISOString(),\n   267→              });\n   268→            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:failed' }, 'Failed to persist execution failure on worker disconnect'); }\n   269→          }\n   270→          this.executionTenant.delete(executionId);\n   271→\n   272→          this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   273→            executionId,\n   274→            status: 'failed',\n   275→            error: 'Worker disconnected (retries exhausted)',\n   276→            durationMs: 0,\n   277→          }), executionId).catch(err => { this.logger.warn({ err, executionId, op: 'kafka:exec_lifecycle' }, 'Failed to produce disconnect failure lifecycle to Kafka'); });\n   278→        }\n   279→      }\n   280→    });\n   281→  }\n   282→\n   283→  setTenantDbManager(mgr: TenantDbManager): void {\n   284→    this.tenantDbManager = mgr;\n   285→  }\n   286→\n   287→  async setMasterKey(masterKeyHex: string): Promise<void> {\n   288→    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n   289→  }\n   290→\n   291→  setTenantKeyManager(mgr: TenantKeyManager): void {\n   292→    this.tenantKeyManager = mgr;\n   293→  }\n   294→\n   295→  setAuditLog(log: AuditLog): void {\n   296→    this.auditLog = log;\n   297→  }\n   298→\n   299→  /** Resolve the database for a given projectId via tenant DB manager. */\n   300→  private resolveDb(projectId?: string): Database.Database | null {\n   301→    if (this.tenantDbManager && projectId) {\n   302→      return this.tenantDbManager.getTenantDb(projectId);\n   303→    }\n   304→    return null;\n   305→  }\n   306→\n   307→  /** Resolve the database for an in-flight execution by its ID. */\n   308→  private resolveDbForExecution(executionId: string): Database.Database | null {\n   309→    const projectId = this.executionTenant.get(executionId);\n   310→    return this.resolveDb(projectId);\n   311→  }\n   312→\n   313→  /**\n   314→   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   315→   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   316→   */\n   317→  private async decryptWithAudit(\n   318→    payload: EncryptedPayload,\n   319→    tenantId: string,\n   320→    resourceId: string,\n   321→    logContext: Record<string, unknown>,\n   322→    logMessage: string,\n   323→  ): Promise<string | undefined> {\n   324→    const decryptKey = this.tenantKeyManager\n   325→      ? await this.tenantKeyManager.getKey(tenantId)\n   326→      : this.masterKey;\n   327→    if (!decryptKey) return undefined;\n   328→\n   329→    try {\n   330→      const decrypted = decrypt(payload, decryptKey, { tenantId, credentialId: resourceId, resourceType: 'credential' });\n   331→      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n   332→      return decrypted;\n   333→    } catch (err) {\n   334→      const reason = err instanceof DecryptionError ? err.message : (err instanceof Error ? err.message : String(err));\n   335→      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n   336→      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: reason }); } catch { /* logged inside record() */ }\n   337→      return undefined;\n   338→    }\n   339→  }\n   340→\n   341→  submit(request: ExecRequest): void {\n   342→    this.logger.info({\n   343→      executionId: request.executionId,\n   344→      personaId: request.personaId,\n   345→    }, 'Execution submitted');\n   346→\n   347→    // Track which tenant owns this execution (for callback DB resolution)\n   348→    const projectId = request.projectId || 'default';\n   349→    this.executionTenant.set(request.executionId, projectId);\n   350→\n   351→    // Create DB record immediately\n   352→    const submitDb = this.resolveDb(projectId);\n   353→    if (submitDb) {\n   354→      try {\n   355→        db.createExecution(submitDb, {\n   356→          id: request.executionId,\n   357→          personaId: request.personaId,\n   358→          inputData: request.prompt,\n   359→          projectId,\n   360→        });\n   361→      } catch (err) {\n   362→        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n   363→      }\n   364→    }\n   365→\n   366→    this.queue.push({ request, receivedAt: Date.now() });\n   367→    this.processQueue();\n   368→  }\n   369→\n   370→  private async processQueue(): Promise<void> {\n   371→    // Guard: only one processQueue loop runs at a time to prevent concurrent\n   372→    // calls from racing on getIdleWorker()/assign() and double-claiming a worker.\n   373→    if (this.dispatching) return;\n   374→    this.dispatching = true;\n   375→    try {\n   376→      while (this.queue.length > 0) {\n   377→        const workerId = this.pool.getIdleWorker();\n   378→        if (!workerId) {\n   379→          this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n   380→          return;\n   381→        }\n   382→\n   383→        const item = this.queue.shift()!;\n   384→        await this.dispatchToWorker(workerId, item.request);\n   385→      }\n   386→    } finally {\n   387→      this.dispatching = false;\n   388→    }\n   389→  }\n   390→\n   391→  /** Exposes decryptWithAudit as the Decryptor interface for pipeline stages. */\n   392→  private getDecryptor(): Decryptor {\n   393→    return {\n   394→      decrypt: (payload, tenantId, resourceId, logContext, logMessage) =>\n   395→        this.decryptWithAudit(payload, tenantId, resourceId, logContext, logMessage),\n   396→    };\n   397→  }\n   398→\n   399→  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n   400→    // Stage 1: Resolve token\n   401→    const token = await resolveToken(this.oauth, this.tokenManager);\n   402→    if (!token) {\n   403→      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n   404→      this.queue.unshift({ request, receivedAt: Date.now() });\n   405→      return;\n   406→    }\n   407→\n   408→    // Stage 2: Resolve persona (credentials, inference profile)\n   409→    const tenantId = request.projectId || 'default';\n   410→    const dispatchDb = this.resolveDb(tenantId);\n   411→    const resolution = await resolvePersona(\n   412→      dispatchDb,\n   413→      request.personaId,\n   414→      tenantId,\n   415→      this.getDecryptor(),\n   416→      this.logger,\n   417→    );\n   418→\n   419→    // Stage 3: Assemble payload (prompt, env, network policy)\n   420→    const payload = assemblePayload(request, token, resolution);\n   421→\n   422→    // Stage 4: Build assignment and send\n   423→    const assignment = buildAssignment(request, payload);\n   424→\n   425→    // Track in-memory for real-time streaming (preserve retry count across re-dispatches)\n   426→    const prevRetries = this.active.get(request.executionId)?.disconnectRetries ?? 0;\n   427→    this.active.set(request.executionId, {\n   428→      workerId,\n   429→      startedAt: Date.now(),\n   430→      output: [],\n   431→      status: 'running',\n   432→      request,\n   433→      disconnectRetries: prevRetries,\n   434→    });\n   435→\n   436→    // Mark running in DB\n   437→    if (dispatchDb) {\n   438→      try {\n   439→        db.updateExecution(dispatchDb, request.executionId, {\n   440→          status: 'running',\n   441→          startedAt: new Date().toISOString(),\n   442→        });\n   443→      } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:running' }, 'Failed to mark execution as running in DB'); }\n   444→    }\n   445→\n   446→    const sent = this.pool.assign(workerId, assignment);\n   447→    if (!sent) {\n   448→      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n   449→      this.active.delete(request.executionId);\n   450→      if (dispatchDb) {\n   451→        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:queued' }, 'Failed to re-queue execution in DB after assign failure'); }\n   452→      }\n   453→      this.queue.unshift({ request, receivedAt: Date.now() });\n   454→      this.processQueue();\n   455→    } else {\n   456→      this.logger.info({\n   457→        workerId,\n   458→        executionId: request.executionId,\n   459→        personaId: request.personaId,\n   460→      }, 'Execution dispatched to worker');\n   461→    }\n   462→  }\n   463→\n   464→  cancelExecution(executionId: string): boolean {\n   465→    const exec = this.active.get(executionId);\n   466→    if (!exec || exec.status !== 'running') return false;\n   467→\n   468→    return this.pool.send(exec.workerId, {\n   469→      type: 'cancel',\n   470→      executionId,\n   471→    });\n   472→  }\n   473→\n   474→  getQueueLength(): number {\n   475→    return this.queue.length;\n   476→  }\n   477→\n   478→  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n   479→    return Array.from(this.active.entries())\n   480→      .filter(([, e]) => e.status === 'running')\n   481→      .map(([executionId, e]) => ({\n   482→        executionId,\n   483→        workerId: e.workerId,\n   484→        startedAt: e.startedAt,\n   485→      }));\n   486→  }\n   487→\n   488→  /**\n   489→   * Get execution state. Tries in-memory first (for real-time output),\n   490→   * then falls back to DB for completed/historical executions.\n   491→   */\n   492→  getExecution(executionId: string): ActiveExecution | null {\n   493→    // Check in-memory active executions first\n   494→    const active = this.active.get(executionId);\n   495→    if (active) return active;\n   496→\n   497→    const execDb = this.resolveDbForExecution(executionId);\n   498→    if (execDb) {\n   499→      const dbExec = db.getExecution(execDb, executionId);\n   500→      if (dbExec) {\n   501→        return {\n   502→          workerId: '',\n   503→          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n   504→          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n   505→          status: dbExec.status as ActiveExecution['status'],\n   506→          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n   507→          durationMs: dbExec.durationMs ?? undefined,\n   508→          sessionId: dbExec.claudeSessionId ?? undefined,\n   509→          totalCostUsd: dbExec.costUsd ?? undefined,\n   510→        };\n   511→      }\n   512→    }\n   513→\n   514→    return null;\n   515→  }\n   516→\n   517→  getExecutionOutput(executionId: string): string[] | null {\n   518→    const exec = this.getExecution(executionId);\n   519→    return exec?.output ?? null;\n   520→  }\n   521→\n   522→  /** Shared handler for stdout/stderr output chunks. */\n   523→  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n   524→    const line = prefix ? `${prefix}${chunk}` : chunk;\n   525→\n   526→    const exec = this.active.get(executionId);\n   527→    if (exec) {\n   528→      exec.output.push(line);\n   529→    }\n   530→\n   531→    this.bufferOutput(executionId, line + '\\n');\n   532→\n   533→    // Forward stdout to Kafka (stderr is not forwarded)\n   534→    if (!prefix) {\n   535→      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n   536→        executionId,\n   537→        chunk,\n   538→        timestamp,\n   539→      }), executionId).catch(err => {\n   540→        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n   541→      });\n   542→    }\n   543→  }\n   544→\n   545→  /** Buffer an output chunk for batched DB write. */\n   546→  private bufferOutput(executionId: string, chunk: string): void {\n   547→    let buf = this.outputBuffers.get(executionId);\n   548→    if (!buf) {\n   549→      buf = [];\n   550→      this.outputBuffers.set(executionId, buf);\n   551→    }\n   552→    buf.push(chunk);\n   553→  }\n   554→\n   555→  /** Flush buffered output for a specific execution to DB. */\n   556→  private flushOutputForExecution(executionId: string): void {\n   557→    const buf = this.outputBuffers.get(executionId);\n   558→    if (!buf || buf.length === 0) return;\n   559→\n   560→    const combined = buf.join('');\n   561→    this.outputBuffers.delete(executionId);\n   562→\n   563→    const outputDb = this.resolveDbForExecution(executionId);\n   564→    if (outputDb) {\n   565→      try { db.appendOutput(outputDb, executionId, combined); } catch (err) { this.logger.warn({ err, executionId, op: 'appendOutput' }, 'Failed to flush buffered output to DB'); }\n   566→    }\n   567→  }\n   568→\n   569→  /** Flush all buffered output across all executions to DB. */\n   570→  private flushOutputBuffers(): void {\n   571→    for (const executionId of this.outputBuffers.keys()) {\n   572→      this.flushOutputForExecution(executionId);\n   573→    }\n   574→  }\n   575→\n   576→  shutdown(): void {\n   577→    clearInterval(this.outputFlushTimer);\n   578→    this.flushOutputBuffers();\n   579→  }\n   580→}\n   581→"}]},"parent_tool_use_id":null,"session_id":"90a8b635-e710-41f3-b833-6b6754d67d54","uuid":"618b9829-089f-4a93-8925-1fd511040f6a","timestamp":"2026-03-18T17:32:22.816Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\dispatcher.ts","content":"import { type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type PhaseTimings, type EncryptedPayload, TOPICS, decrypt, DecryptionError, deriveMasterKeyAsync } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { resolveToken, resolvePersona, assemblePayload, buildAssignment, type Decryptor } from './dispatchPipeline.js';\n\ninterface QueuedExecution {\n  request: ExecRequest;\n  receivedAt: number;\n}\n\n// Maximum number of times an execution will be re-queued after worker disconnect\nconst MAX_DISCONNECT_RETRIES = 2;\n\n// In-memory tracking for active executions (real-time output streaming)\ninterface ActiveExecution {\n  workerId: string;\n  startedAt: number;\n  output: string[];\n  status: 'running' | 'completed' | 'failed' | 'cancelled';\n  progress?: ProgressInfo;\n  completedAt?: number;\n  exitCode?: number;\n  durationMs?: number;\n  sessionId?: string;\n  totalCostUsd?: number;\n  phaseTimings?: PhaseTimings;\n  /** Original request kept for re-queuing on worker disconnect. Only present for in-flight executions. */\n  request?: ExecRequest;\n  /** How many times this execution has been re-queued after a worker disconnect. */\n  disconnectRetries?: number;\n}\n\nconst OUTPUT_FLUSH_INTERVAL_MS = 500;\n\nexport class Dispatcher {\n  private queue: QueuedExecution[] = [];\n  // In-memory map for real-time output + cancel routing (active executions only)\n  private active = new Map<string, ActiveExecution>();\n  private tenantDbManager: TenantDbManager | null = null;\n  private masterKey: Buffer | null = null;\n  private tenantKeyManager: TenantKeyManager | null = null;\n  private auditLog: AuditLog | null = null;\n  // Maps executionId → projectId for DB resolution during callbacks\n  private executionTenant = new Map<string, string>();\n  // Batched output buffers: executionId → pending chunks\n  private outputBuffers = new Map<string, string[]>();\n  private outputFlushTimer: NodeJS.Timeout;\n  // Guard flag to prevent concurrent processQueue runs from racing on getIdleWorker/assign\n  private dispatching = false;\n\n  constructor(\n    private pool: WorkerPool,\n    private tokenManager: TokenManager,\n    private oauth: OAuthManager | null,\n    private kafka: KafkaClient,\n    private logger: Logger,\n  ) {\n    // Periodic flush of batched output to DB\n    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n\n    // When a worker becomes ready, try to dispatch queued work\n    this.pool.on('worker-ready', () => {\n      this.processQueue();\n    });\n\n    // When a worker connects, try to dispatch\n    this.pool.on('worker-connected', () => {\n      this.processQueue();\n    });\n\n    // Track stdout for execution output\n    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    });\n\n    // Track stderr for debugging failed executions\n    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    });\n\n    // Handle execution completion\n    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n        executionId: msg.executionId,\n        status: msg.status,\n        exitCode: msg.exitCode,\n        durationMs: msg.durationMs,\n        sessionId: msg.sessionId,\n        totalCostUsd: msg.totalCostUsd,\n        ...(msg.phaseTimings ? { phaseTimings: msg.phaseTimings } : {}),\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n      });\n\n      // Flush any remaining buffered output before persisting completion\n      this.flushOutputForExecution(msg.executionId);\n\n      // Update in-memory\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.status = msg.status;\n        exec.completedAt = Date.now();\n        exec.exitCode = msg.exitCode;\n        exec.durationMs = msg.durationMs;\n        exec.sessionId = msg.sessionId;\n        exec.totalCostUsd = msg.totalCostUsd;\n        exec.phaseTimings = msg.phaseTimings;\n        // Remove from active after a short delay (allow polling to pick up final state)\n        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n      }\n\n      // Persist to DB\n      const completeDb = this.resolveDbForExecution(msg.executionId);\n      if (completeDb) {\n        try {\n          db.updateExecution(completeDb, msg.executionId, {\n            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n            completedAt: new Date().toISOString(),\n            durationMs: msg.durationMs,\n            claudeSessionId: msg.sessionId,\n            costUsd: msg.totalCostUsd ?? 0,\n          });\n        } catch (err) {\n          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n        }\n      }\n\n      // Clean up tenant mapping after completion delay\n      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n\n      // Process next queued item\n      this.processQueue();\n    });\n\n    // Track execution progress\n    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n      }\n      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n        executionId: msg.executionId,\n        phase: msg.phase,\n        percent: msg.percent,\n        detail: msg.detail,\n        timestamp: msg.timestamp,\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n      });\n    });\n\n    // Forward persona events to Kafka\n    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n        executionId: msg.executionId,\n        eventType: msg.eventType,\n        payload: msg.payload,\n        timestamp: Date.now(),\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n      });\n    });\n\n    // Handle worker busy nack — re-queue the rejected execution\n    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n      const exec = this.active.get(msg.executionId);\n      if (exec?.request) {\n        const request = exec.request;\n        this.active.delete(msg.executionId);\n        // Mark as queued in DB\n        const reqDb = this.resolveDbForExecution(msg.executionId);\n        if (reqDb) {\n          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack'); }\n        }\n        this.queue.unshift({ request, receivedAt: Date.now() });\n        this.processQueue();\n      } else {\n        // Fallback: reconstruct from DB if request was not stored (should not happen)\n        this.active.delete(msg.executionId);\n        const projectId = this.executionTenant.get(msg.executionId) || 'default';\n        const reqDb = this.resolveDb(projectId);\n        if (reqDb) {\n          try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: msg.executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on busy nack fallback'); }\n        }\n        const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n        if (dbExec) {\n          this.queue.unshift({\n            request: {\n              executionId: msg.executionId,\n              personaId: dbExec.personaId,\n              prompt: dbExec.inputData || '',\n              projectId,\n              config: { timeoutMs: 300_000 },\n            },\n            receivedAt: Date.now(),\n          });\n          this.processQueue();\n        }\n      }\n    });\n\n    // Handle worker disconnect during execution — re-queue if retries remain\n    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n      if (executionId) {\n        const exec = this.active.get(executionId);\n        const retries = exec?.disconnectRetries ?? 0;\n\n        if (exec?.request && retries < MAX_DISCONNECT_RETRIES) {\n          // Re-queue for retry\n          const nextRetry = retries + 1;\n          this.logger.warn({ executionId, retry: nextRetry, maxRetries: MAX_DISCONNECT_RETRIES }, 'Worker disconnected during execution, re-queuing');\n\n          // Clear the active entry so dispatchToWorker can create a fresh one\n          this.active.delete(executionId);\n\n          // Mark as queued in DB\n          const disconnDb = this.resolveDbForExecution(executionId);\n          if (disconnDb) {\n            try {\n              db.updateExecution(disconnDb, executionId, {\n                status: 'queued',\n                errorMessage: `Worker disconnected (retry ${nextRetry}/${MAX_DISCONNECT_RETRIES})`,\n              });\n            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:queued' }, 'Failed to update execution status on worker disconnect re-queue'); }\n          }\n\n          // Temporarily store the retry count so dispatchToWorker picks it up\n          const request = exec.request;\n          // Create a placeholder active entry to carry retry count across re-dispatch\n          this.active.set(executionId, {\n            workerId: '',\n            startedAt: 0,\n            output: [],\n            status: 'running',\n            request,\n            disconnectRetries: nextRetry,\n          });\n\n          this.queue.unshift({ request, receivedAt: Date.now() });\n          this.processQueue();\n        } else {\n          // Retries exhausted or no request stored — permanent failure\n          this.logger.error({ executionId, retries }, 'Worker disconnected during execution, retries exhausted');\n          if (exec) {\n            exec.status = 'failed';\n            exec.completedAt = Date.now();\n            setTimeout(() => this.active.delete(executionId), 30_000);\n          }\n\n          const disconnDb = this.resolveDbForExecution(executionId);\n          if (disconnDb) {\n            try {\n              db.updateExecution(disconnDb, executionId, {\n                status: 'failed',\n                errorMessage: `Worker disconnected (retries exhausted: ${retries}/${MAX_DISCONNECT_RETRIES})`,\n                completedAt: new Date().toISOString(),\n              });\n            } catch (err) { this.logger.warn({ err, executionId, op: 'updateExecution:failed' }, 'Failed to persist execution failure on worker disconnect'); }\n          }\n          this.executionTenant.delete(executionId);\n\n          this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n            executionId,\n            status: 'failed',\n            error: 'Worker disconnected (retries exhausted)',\n            durationMs: 0,\n          }), executionId).catch(err => { this.logger.warn({ err, executionId, op: 'kafka:exec_lifecycle' }, 'Failed to produce disconnect failure lifecycle to Kafka'); });\n        }\n      }\n    });\n  }\n\n  setTenantDbManager(mgr: TenantDbManager): void {\n    this.tenantDbManager = mgr;\n  }\n\n  async setMasterKey(masterKeyHex: string): Promise<void> {\n    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n  }\n\n  setTenantKeyManager(mgr: TenantKeyManager): void {\n    this.tenantKeyManager = mgr;\n  }\n\n  setAuditLog(log: AuditLog): void {\n    this.auditLog = log;\n  }\n\n  /** Resolve the database for a given projectId via tenant DB manager. */\n  private resolveDb(projectId?: string): Database.Database | null {\n    if (this.tenantDbManager && projectId) {\n      return this.tenantDbManager.getTenantDb(projectId);\n    }\n    return null;\n  }\n\n  /** Resolve the database for an in-flight execution by its ID. */\n  private resolveDbForExecution(executionId: string): Database.Database | null {\n    const projectId = this.executionTenant.get(executionId);\n    return this.resolveDb(projectId);\n  }\n\n  /**\n   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   */\n  private async decryptWithAudit(\n    payload: EncryptedPayload,\n    tenantId: string,\n    resourceId: string,\n    logContext: Record<string, unknown>,\n    logMessage: string,\n  ): Promise<string | undefined> {\n    const decryptKey = this.tenantKeyManager\n      ? await this.tenantKeyManager.getKey(tenantId)\n      : this.masterKey;\n    if (!decryptKey) return undefined;\n\n    try {\n      const decrypted = decrypt(payload, decryptKey, { tenantId, credentialId: resourceId, resourceType: 'credential' });\n      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n      return decrypted;\n    } catch (err) {\n      const reason = err instanceof DecryptionError ? err.message : (err instanceof Error ? err.message : String(err));\n      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: reason }); } catch { /* logged inside record() */ }\n      return undefined;\n    }\n  }\n\n  submit(request: ExecRequest): void {\n    this.logger.info({\n      executionId: request.executionId,\n      personaId: request.personaId,\n    }, 'Execution submitted');\n\n    // Track which tenant owns this execution (for callback DB resolution)\n    const projectId = request.projectId || 'default';\n    this.executionTenant.set(request.executionId, projectId);\n\n    // Create DB record immediately\n    const submitDb = this.resolveDb(projectId);\n    if (submitDb) {\n      try {\n        db.createExecution(submitDb, {\n          id: request.executionId,\n          personaId: request.personaId,\n          inputData: request.prompt,\n          projectId,\n        });\n      } catch (err) {\n        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n      }\n    }\n\n    this.queue.push({ request, receivedAt: Date.now() });\n    this.processQueue();\n  }\n\n  private async processQueue(): Promise<void> {\n    // Guard: only one processQueue loop runs at a time to prevent concurrent\n    // calls from racing on getIdleWorker()/assign() and double-claiming a worker.\n    if (this.dispatching) return;\n    this.dispatching = true;\n    try {\n      while (this.queue.length > 0) {\n        const workerId = this.pool.getIdleWorker();\n        if (!workerId) {\n          this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n          return;\n        }\n\n        const item = this.queue.shift()!;\n        await this.dispatchToWorker(workerId, item.request);\n      }\n    } finally {\n      this.dispatching = false;\n    }\n  }\n\n  /** Exposes decryptWithAudit as the Decryptor interface for pipeline stages. */\n  private getDecryptor(): Decryptor {\n    return {\n      decrypt: (payload, tenantId, resourceId, logContext, logMessage) =>\n        this.decryptWithAudit(payload, tenantId, resourceId, logContext, logMessage),\n    };\n  }\n\n  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n    // Stage 1: Resolve token\n    const token = await resolveToken(this.oauth, this.tokenManager);\n    if (!token) {\n      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      return;\n    }\n\n    // Stage 2: Resolve persona (credentials, inference profile)\n    const tenantId = request.projectId || 'default';\n    const dispatchDb = this.resolveDb(tenantId);\n    const resolution = await resolvePersona(\n      dispatchDb,\n      request.personaId,\n      tenantId,\n      this.getDecryptor(),\n      this.logger,\n    );\n\n    // Stage 3: Assemble payload (prompt, env, network policy)\n    const payload = assemblePayload(request, token, resolution);\n\n    // Stage 4: Build assignment and send\n    const assignment = buildAssignment(request, payload);\n\n    // Track in-memory for real-time streaming (preserve retry count across re-dispatches)\n    const prevRetries = this.active.get(request.executionId)?.disconnectRetries ?? 0;\n    this.active.set(request.executionId, {\n      workerId,\n      startedAt: Date.now(),\n      output: [],\n      status: 'running',\n      request,\n      disconnectRetries: prevRetries,\n    });\n\n    // Mark running in DB\n    if (dispatchDb) {\n      try {\n        db.updateExecution(dispatchDb, request.executionId, {\n          status: 'running',\n          startedAt: new Date().toISOString(),\n        });\n      } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:running' }, 'Failed to mark execution as running in DB'); }\n    }\n\n    const sent = this.pool.assign(workerId, assignment);\n    if (!sent) {\n      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n      this.active.delete(request.executionId);\n      if (dispatchDb) {\n        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch (err) { this.logger.warn({ err, executionId: request.executionId, op: 'updateExecution:queued' }, 'Failed to re-queue execution in DB after assign failure'); }\n      }\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      this.processQueue();\n    } else {\n      this.logger.info({\n        workerId,\n        executionId: request.executionId,\n        personaId: request.personaId,\n      }, 'Execution dispatched to worker');\n    }\n  }\n\n  cancelExecution(executionId: string): boolean {\n    const exec = this.active.get(executionId);\n    if (!exec || exec.status !== 'running') return false;\n\n    return this.pool.send(exec.workerId, {\n      type: 'cancel',\n      executionId,\n    });\n  }\n\n  getQueueLength(): number {\n    return this.queue.length;\n  }\n\n  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n    return Array.from(this.active.entries())\n      .filter(([, e]) => e.status === 'running')\n      .map(([executionId, e]) => ({\n        executionId,\n        workerId: e.workerId,\n        startedAt: e.startedAt,\n      }));\n  }\n\n  /**\n   * Get execution state. Tries in-memory first (for real-time output),\n   * then falls back to DB for completed/historical executions.\n   */\n  getExecution(executionId: string): ActiveExecution | null {\n    // Check in-memory active executions first\n    const active = this.active.get(executionId);\n    if (active) return active;\n\n    const execDb = this.resolveDbForExecution(executionId);\n    if (execDb) {\n      const dbExec = db.getExecution(execDb, executionId);\n      if (dbExec) {\n        return {\n          workerId: '',\n          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n          status: dbExec.status as ActiveExecution['status'],\n          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n          durationMs: dbExec.durationMs ?? undefined,\n          sessionId: dbExec.claudeSessionId ?? undefined,\n          totalCostUsd: dbExec.costUsd ?? undefined,\n        };\n      }\n    }\n\n    return null;\n  }\n\n  getExecutionOutput(executionId: string): string[] | null {\n    const exec = this.getExecution(executionId);\n    return exec?.output ?? null;\n  }\n\n  /** Shared handler for stdout/stderr output chunks. */\n  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n    const line = prefix ? `${prefix}${chunk}` : chunk;\n\n    const exec = this.active.get(executionId);\n    if (exec) {\n      exec.output.push(line);\n    }\n\n    this.bufferOutput(executionId, line + '\\n');\n\n    // Forward stdout to Kafka (stderr is not forwarded)\n    if (!prefix) {\n      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n        executionId,\n        chunk,\n        timestamp,\n      }), executionId).catch(err => {\n        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n      });\n    }\n  }\n\n  /** Buffer an output chunk for batched DB write. */\n  private bufferOutput(executionId: string, chunk: string): void {\n    let buf = this.outputBuffers.get(executionId);\n    if (!buf) {\n      buf = [];\n      this.outputBuffers.set(executionId, buf);\n    }\n    buf.push(chunk);\n  }\n\n  /** Flush buffered output for a specific execution to DB. */\n  private flushOutputForExecution(executionId: string): void {\n    const buf = this.outputBuffers.get(executionId);\n    if (!buf || buf.length === 0) return;\n\n    const combined = buf.join('');\n    this.outputBuffers.delete(executionId);\n\n    const outputDb = this.resolveDbForExecution(executionId);\n    if (outputDb) {\n      try { db.appendOutput(outputDb, executionId, combined); } catch (err) { this.logger.warn({ err, executionId, op: 'appendOutput' }, 'Failed to flush buffered output to DB'); }\n    }\n  }\n\n  /** Flush all buffered output across all executions to DB. */\n  private flushOutputBuffers(): void {\n    for (const executionId of this.outputBuffers.keys()) {\n      this.flushOutputForExecution(executionId);\n    }\n  }\n\n  shutdown(): void {\n    clearInterval(this.outputFlushTimer);\n    this.flushOutputBuffers();\n  }\n}\n","numLines":581,"startLine":1,"totalLines":581}}}
