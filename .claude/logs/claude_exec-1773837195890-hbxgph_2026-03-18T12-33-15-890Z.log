[2026-03-18T12:33:33.745Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L633gJei35DxV3XrD9wpm8","type":"tool_result","content":"     1→import { WebSocketServer, WebSocket } from 'ws';\n     2→import https from 'node:https';\n     3→import crypto from 'node:crypto';\n     4→import fs from 'node:fs';\n     5→import {\n     6→  parseWorkerMessage,\n     7→  serializeMessage,\n     8→  type WorkerMessage,\n     9→  type OrchestratorMessage,\n    10→  type ExecAssign,\n    11→  type ExecStdout,\n    12→  type ExecStderr,\n    13→  type ExecComplete,\n    14→  type ExecProgress,\n    15→  type WorkerEvent,\n    16→  type WorkerBusy,\n    17→  type WorkerInfo,\n    18→} from '@dac-cloud/shared';\n    19→import type { Logger } from 'pino';\n    20→import type { IncomingMessage } from 'node:http';\n    21→import type { TlsConfig } from './tls.js';\n    22→\n    23→/** Typed event map for WorkerPool → Dispatcher communication. */\n    24→export interface WorkerPoolEvents {\n    25→  'worker-connected': (info: WorkerInfo) => void;\n    26→  'worker-disconnected': (workerId: string, executionId: string | undefined) => void;\n    27→  'worker-ready': (workerId: string) => void;\n    28→  'stdout': (workerId: string, msg: ExecStdout) => void;\n    29→  'stderr': (workerId: string, msg: ExecStderr) => void;\n    30→  'complete': (workerId: string, msg: ExecComplete) => void;\n    31→  'persona-event': (workerId: string, msg: WorkerEvent) => void;\n    32→  'progress': (workerId: string, msg: ExecProgress) => void;\n    33→  'busy': (workerId: string, msg: WorkerBusy) => void;\n    34→}\n    35→\n    36→const HEARTBEAT_INTERVAL_MS = 30_000;\n    37→const HEARTBEAT_TIMEOUT_MS = 90_000;\n    38→\n    39→/** Constant-time string comparison to prevent timing side-channel attacks on token validation. */\n    40→function timingSafeTokenEqual(a: string, b: string): boolean {\n    41→  const bufA = Buffer.from(a, 'utf8');\n    42→  const bufB = Buffer.from(b, 'utf8');\n    43→  if (bufA.length !== bufB.length) {\n    44→    // Compare against self to maintain constant timing, then return false\n    45→    crypto.timingSafeEqual(bufA, bufA);\n    46→    return false;\n    47→  }\n    48→  return crypto.timingSafeEqual(bufA, bufB);\n    49→}\n    50→\n    51→interface WorkerEntry {\n    52→  ws: WebSocket;\n    53→  info: WorkerInfo;\n    54→  heartbeatTimer?: ReturnType<typeof setInterval>;\n    55→}\n    56→\n    57→export class WorkerPool {\n    58→  private workers = new Map<string, WorkerEntry>();\n    59→  private idleWorkers = new Set<string>();\n    60→  private wss: WebSocketServer | null = null;\n    61→  private allowedDigests: string[];\n    62→  private rejectUnverified: boolean;\n    63→\n    64→  // Typed listener storage — one array per event name\n    65→  private listeners: { [K in keyof WorkerPoolEvents]?: WorkerPoolEvents[K][] } = {};\n    66→\n    67→  constructor(\n    68→    private expectedWorkerToken: string,\n    69→    private logger: Logger,\n    70→    opts?: { allowedDigests?: string[]; rejectUnverified?: boolean },\n    71→  ) {\n    72→    this.allowedDigests = opts?.allowedDigests ?? [];\n    73→    this.rejectUnverified = opts?.rejectUnverified ?? false;\n    74→  }\n    75→\n    76→  /** Register a typed event listener. */\n    77→  on<K extends keyof WorkerPoolEvents>(event: K, listener: WorkerPoolEvents[K]): this {\n    78→    if (!this.listeners[event]) {\n    79→      this.listeners[event] = [];\n    80→    }\n    81→    this.listeners[event]!.push(listener);\n    82→    return this;\n    83→  }\n    84→\n    85→  /** Emit a typed event. */\n    86→  private emit<K extends keyof WorkerPoolEvents>(event: K, ...args: Parameters<WorkerPoolEvents[K]>): void {\n    87→    const fns = this.listeners[event];\n    88→    if (fns) {\n    89→      for (const fn of fns) {\n    90→        (fn as (...a: Parameters<WorkerPoolEvents[K]>) => void)(...args);\n    91→      }\n    92→    }\n    93→  }\n    94→\n    95→  listen(port: number, tlsConfig?: TlsConfig): void {\n    96→    if (tlsConfig?.enabled) {\n    97→      const httpsServer = https.createServer({\n    98→        cert: fs.readFileSync(tlsConfig.certPath),\n    99→        key: fs.readFileSync(tlsConfig.keyPath),\n   100→        ca: tlsConfig.caPath ? fs.readFileSync(tlsConfig.caPath) : undefined,\n   101→        requestCert: tlsConfig.requireClientCert,\n   102→        rejectUnauthorized: tlsConfig.requireClientCert,\n   103→      });\n   104→      this.wss = new WebSocketServer({ server: httpsServer });\n   105→      httpsServer.listen(port);\n   106→      this.logger.info({ port, tls: true, mTLS: tlsConfig.requireClientCert }, 'Worker pool listening (WSS)');\n   107→    } else {\n   108→      this.wss = new WebSocketServer({ port });\n   109→      this.logger.info({ port, tls: false }, 'Worker pool listening (WS — plaintext)');\n   110→    }\n   111→\n   112→    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n   113→      this.logger.info({ remoteAddr: req.socket.remoteAddress }, 'Worker connection attempt');\n   114→\n   115→      // Validate worker token from Authorization header (timing-safe comparison)\n   116→      const authHeader = req.headers.authorization;\n   117→      const token = authHeader?.startsWith('Bearer ') ? authHeader.slice(7) : null;\n   118→      if (!token || !timingSafeTokenEqual(token, this.expectedWorkerToken)) {\n   119→        this.logger.warn({ remoteAddr: req.socket.remoteAddress }, 'Worker rejected: invalid token');\n   120→        ws.close(1008, 'Invalid worker token');\n   121→        return;\n   122→      }\n   123→\n   124→      this.handleConnection(ws);\n   125→    });\n   126→\n   127→    this.wss.on('error', (err) => {\n   128→      this.logger.error({ err }, 'WebSocket server error');\n   129→    });\n   130→  }\n   131→\n   132→  private handleConnection(ws: WebSocket): void {\n   133→    let workerId: string | null = null;\n   134→\n   135→    const connectionTimeout = setTimeout(() => {\n   136→      if (!workerId) {\n   137→        this.logger.warn('Worker did not send hello within timeout, closing');\n   138→        ws.close(1008, 'Hello timeout');\n   139→      }\n   140→    }, 10_000);\n   141→\n   142→    ws.on('message', (raw: Buffer) => {\n   143→      const msg = parseWorkerMessage(raw.toString());\n   144→      if (!msg) {\n   145→        this.logger.warn('Invalid message from worker');\n   146→        return;\n   147→      }\n   148→\n   149→      if (msg.type === 'hello') {\n   150→        clearTimeout(connectionTimeout);\n   151→        workerId = msg.workerId;\n   152→        this.registerWorker(workerId, ws, msg.version, msg.capabilities, msg.imageDigest, msg.claudeCliVersion);\n   153→        return;\n   154→      }\n   155→\n   156→      if (!workerId) {\n   157→        this.logger.warn({ type: msg.type }, 'Message before hello');\n   158→        return;\n   159→      }\n   160→\n   161→      this.handleWorkerMessage(workerId, msg);\n   162→    });\n   163→\n   164→    ws.on('close', () => {\n   165→      clearTimeout(connectionTimeout);\n   166→      if (workerId) {\n   167→        this.unregisterWorker(workerId);\n   168→      }\n   169→    });\n   170→\n   171→    ws.on('error', (err) => {\n   172→      this.logger.error({ err, workerId }, 'Worker WebSocket error');\n   173→    });\n   174→  }\n   175→\n   176→  private registerWorker(workerId: string, ws: WebSocket, version: string, capabilities: string[], imageDigest?: string, claudeCliVersion?: string): void {\n   177→    // I10: If a worker with this ID already exists, disconnect the old one first\n   178→    const existing = this.workers.get(workerId);\n   179→    if (existing) {\n   180→      this.logger.warn({ workerId }, 'Duplicate worker ID — disconnecting previous connection');\n   181→      if (existing.heartbeatTimer) clearInterval(existing.heartbeatTimer);\n   182→      existing.ws.close(1001, 'Replaced by new connection');\n   183→      this.workers.delete(workerId);\n   184→      this.idleWorkers.delete(workerId);\n   185→    }\n   186→\n   187→    const verified = this.allowedDigests.length === 0 || (!!imageDigest && this.allowedDigests.includes(imageDigest));\n   188→\n   189→    if (this.rejectUnverified && !verified) {\n   190→      this.logger.warn({ workerId, imageDigest }, 'Rejecting unverified worker — digest not in allowlist');\n   191→      ws.close(1008, 'Unverified image digest');\n   192→      return;\n   193→    }\n   194→\n   195→    const info: WorkerInfo = {\n   196→      workerId,\n   197→      status: 'idle',\n   198→      version,\n   199→      capabilities,\n   200→      connectedAt: Date.now(),\n   201→      lastHeartbeat: Date.now(),\n   202→      imageDigest,\n   203→      claudeCliVersion,\n   204→      verified,\n   205→    };\n   206→\n   207→    const heartbeatTimer = setInterval(() => {\n   208→      const entry = this.workers.get(workerId);\n   209→      if (!entry) return;\n   210→\n   211→      if (Date.now() - entry.info.lastHeartbeat > HEARTBEAT_TIMEOUT_MS) {\n   212→        this.logger.warn({ workerId }, 'Worker heartbeat timeout');\n   213→        entry.ws.close(1001, 'Heartbeat timeout');\n   214→        return;\n   215→      }\n   216→\n   217→      this.send(workerId, { type: 'heartbeat', timestamp: Date.now() });\n   218→    }, HEARTBEAT_INTERVAL_MS);\n   219→\n   220→    this.workers.set(workerId, { ws, info, heartbeatTimer });\n   221→    this.idleWorkers.add(workerId);\n   222→\n   223→    // Send ack\n   224→    this.send(workerId, {\n   225→      type: 'ack',\n   226→      workerId,\n   227→      sessionToken: `session-${Date.now()}`,\n   228→    });\n   229→\n   230→    this.logger.info({ workerId, version, capabilities, imageDigest, claudeCliVersion, verified }, 'Worker registered');\n   231→    this.emit('worker-connected', info);\n   232→  }\n   233→\n   234→  private unregisterWorker(workerId: string): void {\n   235→    const entry = this.workers.get(workerId);\n   236→    if (!entry) return;\n   237→\n   238→    if (entry.heartbeatTimer) {\n   239→      clearInterval(entry.heartbeatTimer);\n   240→    }\n   241→\n   242→    const hadExecution = entry.info.currentExecutionId;\n   243→    this.workers.delete(workerId);\n   244→    this.idleWorkers.delete(workerId);\n   245→\n   246→    this.logger.info({ workerId, hadExecution }, 'Worker disconnected');\n   247→    this.emit('worker-disconnected', workerId, hadExecution);\n   248→  }\n   249→\n   250→  private handleWorkerMessage(workerId: string, msg: WorkerMessage): void {\n   251→    const entry = this.workers.get(workerId);\n   252→    if (!entry) return;\n   253→\n   254→    switch (msg.type) {\n   255→      case 'heartbeat':\n   256→        entry.info.lastHeartbeat = Date.now();\n   257→        break;\n   258→\n   259→      case 'ready':\n   260→        entry.info.status = 'idle';\n   261→        entry.info.currentExecutionId = undefined;\n   262→        this.idleWorkers.add(workerId);\n   263→        this.emit('worker-ready', workerId);\n   264→        break;\n   265→\n   266→      case 'stdout':\n   267→        this.emit('stdout', workerId, msg);\n   268→        break;\n   269→\n   270→      case 'stderr':\n   271→        this.emit('stderr', workerId, msg);\n   272→        break;\n   273→\n   274→      case 'complete':\n   275→        entry.info.status = 'idle';\n   276→        entry.info.currentExecutionId = undefined;\n   277→        this.idleWorkers.add(workerId);\n   278→        this.logger.info({\n   279→          workerId,\n   280→          executionId: msg.executionId,\n   281→          status: msg.status,\n   282→          durationMs: msg.durationMs,\n   283→        }, 'Execution complete');\n   284→        this.emit('complete', workerId, msg);\n   285→        break;\n   286→\n   287→      case 'event':\n   288→        this.emit('persona-event', workerId, msg);\n   289→        break;\n   290→\n   291→      case 'progress':\n   292→        this.emit('progress', workerId, msg);\n   293→        break;\n   294→\n   295→      case 'busy':\n   296→        this.logger.warn({ workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment (busy)');\n   297→        // Mark worker as idle again so it can receive future work once it finishes\n   298→        entry.info.status = 'idle';\n   299→        entry.info.currentExecutionId = undefined;\n   300→        this.idleWorkers.add(workerId);\n   301→        this.emit('busy', workerId, msg);\n   302→        break;\n   303→\n   304→      default:\n   305→        this.logger.warn({ workerId, type: (msg as WorkerMessage).type }, 'Unknown message type');\n   306→    }\n   307→  }\n   308→\n   309→  send(workerId: string, msg: OrchestratorMessage): boolean {\n   310→    const entry = this.workers.get(workerId);\n   311→    if (!entry || entry.ws.readyState !== WebSocket.OPEN) return false;\n   312→\n   313→    entry.ws.send(serializeMessage(msg));\n   314→    return true;\n   315→  }\n   316→\n   317→  assign(workerId: string, assignment: ExecAssign): boolean {\n   318→    const entry = this.workers.get(workerId);\n   319→    if (!entry || entry.info.status !== 'idle') return false;\n   320→\n   321→    entry.info.status = 'executing';\n   322→    entry.info.currentExecutionId = assignment.executionId;\n   323→    this.idleWorkers.delete(workerId);\n   324→    return this.send(workerId, assignment);\n   325→  }\n   326→\n   327→  getIdleWorker(): string | null {\n   328→    const first = this.idleWorkers.values().next();\n   329→    return first.done ? null : first.value;\n   330→  }\n   331→\n   332→  getWorkers(): WorkerInfo[] {\n   333→    return Array.from(this.workers.values()).map(e => ({ ...e.info }));\n   334→  }\n   335→\n   336→  getWorkerCount(): { total: number; idle: number; executing: number } {\n   337→    const idle = this.idleWorkers.size;\n   338→    return { total: this.workers.size, idle, executing: this.workers.size - idle };\n   339→  }\n   340→\n   341→  shutdown(): void {\n   342→    for (const [workerId] of this.workers) {\n   343→      this.send(workerId, {\n   344→        type: 'shutdown',\n   345→        reason: 'Orchestrator shutting down',\n   346→        gracePeriodMs: 30_000,\n   347→      });\n   348→    }\n   349→    this.wss?.close();\n   350→    for (const entry of this.workers.values()) {\n   351→      if (entry.heartbeatTimer) clearInterval(entry.heartbeatTimer);\n   352→    }\n   353→  }\n   354→}\n   355→"}]},"parent_tool_use_id":null,"session_id":"489d76e2-f864-48d4-83b2-3b0aced8addc","uuid":"c297ce23-4e6e-4dd4-9e60-92b15c32e4e9","timestamp":"2026-03-18T12:33:33.289Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\workerPool.ts","content":"import { WebSocketServer, WebSocket } from 'ws';\nimport https from 'node:https';\nimport crypto from 'node:crypto';\nimport fs from 'node:fs';\nimport {\n  parseWorkerMessage,\n  serializeMessage,\n  type WorkerMessage,\n  type OrchestratorMessage,\n  type ExecAssign,\n  type ExecStdout,\n  type ExecStderr,\n  type ExecComplete,\n  type ExecProgress,\n  type WorkerEvent,\n  type WorkerBusy,\n  type WorkerInfo,\n} from '@dac-cloud/shared';\nimport type { Logger } from 'pino';\nimport type { IncomingMessage } from 'node:http';\nimport type { TlsConfig } from './tls.js';\n\n/** Typed event map for WorkerPool → Dispatcher communication. */\nexport interface WorkerPoolEvents {\n  'worker-connected': (info: WorkerInfo) => void;\n  'worker-disconnected': (workerId: string, executionId: string | undefined) => void;\n  'worker-ready': (workerId: string) => void;\n  'stdout': (workerId: string, msg: ExecStdout) => void;\n  'stderr': (workerId: string, msg: ExecStderr) => void;\n  'complete': (workerId: string, msg: ExecComplete) => void;\n  'persona-event': (workerId: string, msg: WorkerEvent) => void;\n  'progress': (workerId: string, msg: ExecProgress) => void;\n  'busy': (workerId: string, msg: WorkerBusy) => void;\n}\n\nconst HEARTBEAT_INTERVAL_MS = 30_000;\nconst HEARTBEAT_TIMEOUT_MS = 90_000;\n\n/** Constant-time string comparison to prevent timing side-channel attacks on token validation. */\nfunction timingSafeTokenEqual(a: string, b: string): boolean {\n  const bufA = Buffer.from(a, 'utf8');\n  const bufB = Buffer.from(b, 'utf8');\n  if (bufA.length !== bufB.length) {\n    // Compare against self to maintain constant timing, then return false\n    crypto.timingSafeEqual(bufA, bufA);\n    return false;\n  }\n  return crypto.timingSafeEqual(bufA, bufB);\n}\n\ninterface WorkerEntry {\n  ws: WebSocket;\n  info: WorkerInfo;\n  heartbeatTimer?: ReturnType<typeof setInterval>;\n}\n\nexport class WorkerPool {\n  private workers = new Map<string, WorkerEntry>();\n  private idleWorkers = new Set<string>();\n  private wss: WebSocketServer | null = null;\n  private allowedDigests: string[];\n  private rejectUnverified: boolean;\n\n  // Typed listener storage — one array per event name\n  private listeners: { [K in keyof WorkerPoolEvents]?: WorkerPoolEvents[K][] } = {};\n\n  constructor(\n    private expectedWorkerToken: string,\n    private logger: Logger,\n    opts?: { allowedDigests?: string[]; rejectUnverified?: boolean },\n  ) {\n    this.allowedDigests = opts?.allowedDigests ?? [];\n    this.rejectUnverified = opts?.rejectUnverified ?? false;\n  }\n\n  /** Register a typed event listener. */\n  on<K extends keyof WorkerPoolEvents>(event: K, listener: WorkerPoolEvents[K]): this {\n    if (!this.listeners[event]) {\n      this.listeners[event] = [];\n    }\n    this.listeners[event]!.push(listener);\n    return this;\n  }\n\n  /** Emit a typed event. */\n  private emit<K extends keyof WorkerPoolEvents>(event: K, ...args: Parameters<WorkerPoolEvents[K]>): void {\n    const fns = this.listeners[event];\n    if (fns) {\n      for (const fn of fns) {\n        (fn as (...a: Parameters<WorkerPoolEvents[K]>) => void)(...args);\n      }\n    }\n  }\n\n  listen(port: number, tlsConfig?: TlsConfig): void {\n    if (tlsConfig?.enabled) {\n      const httpsServer = https.createServer({\n        cert: fs.readFileSync(tlsConfig.certPath),\n        key: fs.readFileSync(tlsConfig.keyPath),\n        ca: tlsConfig.caPath ? fs.readFileSync(tlsConfig.caPath) : undefined,\n        requestCert: tlsConfig.requireClientCert,\n        rejectUnauthorized: tlsConfig.requireClientCert,\n      });\n      this.wss = new WebSocketServer({ server: httpsServer });\n      httpsServer.listen(port);\n      this.logger.info({ port, tls: true, mTLS: tlsConfig.requireClientCert }, 'Worker pool listening (WSS)');\n    } else {\n      this.wss = new WebSocketServer({ port });\n      this.logger.info({ port, tls: false }, 'Worker pool listening (WS — plaintext)');\n    }\n\n    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n      this.logger.info({ remoteAddr: req.socket.remoteAddress }, 'Worker connection attempt');\n\n      // Validate worker token from Authorization header (timing-safe comparison)\n      const authHeader = req.headers.authorization;\n      const token = authHeader?.startsWith('Bearer ') ? authHeader.slice(7) : null;\n      if (!token || !timingSafeTokenEqual(token, this.expectedWorkerToken)) {\n        this.logger.warn({ remoteAddr: req.socket.remoteAddress }, 'Worker rejected: invalid token');\n        ws.close(1008, 'Invalid worker token');\n        return;\n      }\n\n      this.handleConnection(ws);\n    });\n\n    this.wss.on('error', (err) => {\n      this.logger.error({ err }, 'WebSocket server error');\n    });\n  }\n\n  private handleConnection(ws: WebSocket): void {\n    let workerId: string | null = null;\n\n    const connectionTimeout = setTimeout(() => {\n      if (!workerId) {\n        this.logger.warn('Worker did not send hello within timeout, closing');\n        ws.close(1008, 'Hello timeout');\n      }\n    }, 10_000);\n\n    ws.on('message', (raw: Buffer) => {\n      const msg = parseWorkerMessage(raw.toString());\n      if (!msg) {\n        this.logger.warn('Invalid message from worker');\n        return;\n      }\n\n      if (msg.type === 'hello') {\n        clearTimeout(connectionTimeout);\n        workerId = msg.workerId;\n        this.registerWorker(workerId, ws, msg.version, msg.capabilities, msg.imageDigest, msg.claudeCliVersion);\n        return;\n      }\n\n      if (!workerId) {\n        this.logger.warn({ type: msg.type }, 'Message before hello');\n        return;\n      }\n\n      this.handleWorkerMessage(workerId, msg);\n    });\n\n    ws.on('close', () => {\n      clearTimeout(connectionTimeout);\n      if (workerId) {\n        this.unregisterWorker(workerId);\n      }\n    });\n\n    ws.on('error', (err) => {\n      this.logger.error({ err, workerId }, 'Worker WebSocket error');\n    });\n  }\n\n  private registerWorker(workerId: string, ws: WebSocket, version: string, capabilities: string[], imageDigest?: string, claudeCliVersion?: string): void {\n    // I10: If a worker with this ID already exists, disconnect the old one first\n    const existing = this.workers.get(workerId);\n    if (existing) {\n      this.logger.warn({ workerId }, 'Duplicate worker ID — disconnecting previous connection');\n      if (existing.heartbeatTimer) clearInterval(existing.heartbeatTimer);\n      existing.ws.close(1001, 'Replaced by new connection');\n      this.workers.delete(workerId);\n      this.idleWorkers.delete(workerId);\n    }\n\n    const verified = this.allowedDigests.length === 0 || (!!imageDigest && this.allowedDigests.includes(imageDigest));\n\n    if (this.rejectUnverified && !verified) {\n      this.logger.warn({ workerId, imageDigest }, 'Rejecting unverified worker — digest not in allowlist');\n      ws.close(1008, 'Unverified image digest');\n      return;\n    }\n\n    const info: WorkerInfo = {\n      workerId,\n      status: 'idle',\n      version,\n      capabilities,\n      connectedAt: Date.now(),\n      lastHeartbeat: Date.now(),\n      imageDigest,\n      claudeCliVersion,\n      verified,\n    };\n\n    const heartbeatTimer = setInterval(() => {\n      const entry = this.workers.get(workerId);\n      if (!entry) return;\n\n      if (Date.now() - entry.info.lastHeartbeat > HEARTBEAT_TIMEOUT_MS) {\n        this.logger.warn({ workerId }, 'Worker heartbeat timeout');\n        entry.ws.close(1001, 'Heartbeat timeout');\n        return;\n      }\n\n      this.send(workerId, { type: 'heartbeat', timestamp: Date.now() });\n    }, HEARTBEAT_INTERVAL_MS);\n\n    this.workers.set(workerId, { ws, info, heartbeatTimer });\n    this.idleWorkers.add(workerId);\n\n    // Send ack\n    this.send(workerId, {\n      type: 'ack',\n      workerId,\n      sessionToken: `session-${Date.now()}`,\n    });\n\n    this.logger.info({ workerId, version, capabilities, imageDigest, claudeCliVersion, verified }, 'Worker registered');\n    this.emit('worker-connected', info);\n  }\n\n  private unregisterWorker(workerId: string): void {\n    const entry = this.workers.get(workerId);\n    if (!entry) return;\n\n    if (entry.heartbeatTimer) {\n      clearInterval(entry.heartbeatTimer);\n    }\n\n    const hadExecution = entry.info.currentExecutionId;\n    this.workers.delete(workerId);\n    this.idleWorkers.delete(workerId);\n\n    this.logger.info({ workerId, hadExecution }, 'Worker disconnected');\n    this.emit('worker-disconnected', workerId, hadExecution);\n  }\n\n  private handleWorkerMessage(workerId: string, msg: WorkerMessage): void {\n    const entry = this.workers.get(workerId);\n    if (!entry) return;\n\n    switch (msg.type) {\n      case 'heartbeat':\n        entry.info.lastHeartbeat = Date.now();\n        break;\n\n      case 'ready':\n        entry.info.status = 'idle';\n        entry.info.currentExecutionId = undefined;\n        this.idleWorkers.add(workerId);\n        this.emit('worker-ready', workerId);\n        break;\n\n      case 'stdout':\n        this.emit('stdout', workerId, msg);\n        break;\n\n      case 'stderr':\n        this.emit('stderr', workerId, msg);\n        break;\n\n      case 'complete':\n        entry.info.status = 'idle';\n        entry.info.currentExecutionId = undefined;\n        this.idleWorkers.add(workerId);\n        this.logger.info({\n          workerId,\n          executionId: msg.executionId,\n          status: msg.status,\n          durationMs: msg.durationMs,\n        }, 'Execution complete');\n        this.emit('complete', workerId, msg);\n        break;\n\n      case 'event':\n        this.emit('persona-event', workerId, msg);\n        break;\n\n      case 'progress':\n        this.emit('progress', workerId, msg);\n        break;\n\n      case 'busy':\n        this.logger.warn({ workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment (busy)');\n        // Mark worker as idle again so it can receive future work once it finishes\n        entry.info.status = 'idle';\n        entry.info.currentExecutionId = undefined;\n        this.idleWorkers.add(workerId);\n        this.emit('busy', workerId, msg);\n        break;\n\n      default:\n        this.logger.warn({ workerId, type: (msg as WorkerMessage).type }, 'Unknown message type');\n    }\n  }\n\n  send(workerId: string, msg: OrchestratorMessage): boolean {\n    const entry = this.workers.get(workerId);\n    if (!entry || entry.ws.readyState !== WebSocket.OPEN) return false;\n\n    entry.ws.send(serializeMessage(msg));\n    return true;\n  }\n\n  assign(workerId: string, assignment: ExecAssign): boolean {\n    const entry = this.workers.get(workerId);\n    if (!entry || entry.info.status !== 'idle') return false;\n\n    entry.info.status = 'executing';\n    entry.info.currentExecutionId = assignment.executionId;\n    this.idleWorkers.delete(workerId);\n    return this.send(workerId, assignment);\n  }\n\n  getIdleWorker(): string | null {\n    const first = this.idleWorkers.values().next();\n    return first.done ? null : first.value;\n  }\n\n  getWorkers(): WorkerInfo[] {\n    return Array.from(this.workers.values()).map(e => ({ ...e.info }));\n  }\n\n  getWorkerCount(): { total: number; idle: number; executing: number } {\n    const idle = this.idleWorkers.size;\n    return { total: this.workers.size, idle, executing: this.workers.size - idle };\n  }\n\n  shutdown(): void {\n    for (const [workerId] of this.workers) {\n      this.send(workerId, {\n        type: 'shutdown',\n        reason: 'Orchestrator shutting down',\n        gracePeriodMs: 30_000,\n      });\n    }\n    this.wss?.close();\n    for (const entry of this.workers.values()) {\n      if (entry.heartbeatTimer) clearInterval(entry.heartbeatTimer);\n    }\n  }\n}\n","numLines":355,"startLine":1,"totalLines":355}}}
