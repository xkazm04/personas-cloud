[2026-03-18T12:33:34.165Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XjWneraQTXddSvvbK6yeFr","type":"tool_result","content":"     1→import 'dotenv/config';\n     2→import path from 'node:path';\n     3→\n     4→export interface OrchestratorConfig {\n     5→  masterKey: string;\n     6→  claudeToken: string;\n     7→  teamApiKey: string;\n     8→  workerToken: string;\n     9→  kafkaBrokers: string;\n    10→  kafkaUsername: string;\n    11→  kafkaPassword: string;\n    12→  kafkaEnabled: boolean;\n    13→  supabaseJwtSecret: string;\n    14→  wsPort: number;\n    15→  httpPort: number;\n    16→  // TLS\n    17→  tlsEnabled: boolean;\n    18→  tlsCertPath: string;\n    19→  tlsKeyPath: string;\n    20→  tlsCaPath: string;\n    21→  tlsRequireClientCert: boolean;\n    22→  // Output scrubbing\n    23→  scrubberEnabled: boolean;\n    24→  // Audit\n    25→  auditDbPath: string;\n    26→  auditRetentionDays: number;\n    27→  // Retention\n    28→  retentionDays: number;\n    29→  metricsRetentionDays: number;\n    30→  // Data directory\n    31→  dataDir: string;\n    32→  // Worker verification\n    33→  allowedImageDigests: string[];\n    34→  rejectUnverifiedWorkers: boolean;\n    35→}\n    36→\n    37→function required(name: string): string {\n    38→  const value = process.env[name];\n    39→  if (!value) {\n    40→    throw new Error(`Missing required environment variable: ${name}`);\n    41→  }\n    42→  return value;\n    43→}\n    44→\n    45→function optional(name: string, fallback: string): string {\n    46→  return process.env[name] || fallback;\n    47→}\n    48→\n    49→export function loadConfig(): OrchestratorConfig {\n    50→  const kafkaBrokers = process.env['KAFKA_BROKERS'] || '';\n    51→\n    52→  const dataDir = process.env['DAC_DATA_DIR'] || path.join(process.cwd(), 'data');\n    53→\n    54→  return {\n    55→    masterKey: required('MASTER_KEY'),\n    56→    claudeToken: process.env['CLAUDE_TOKEN'] || '',  // Optional: use OAuth flow if not provided\n    57→    teamApiKey: required('TEAM_API_KEY'),\n    58→    workerToken: required('WORKER_TOKEN'),\n    59→    kafkaBrokers,\n    60→    kafkaUsername: process.env['KAFKA_USERNAME'] || '',\n    61→    kafkaPassword: process.env['KAFKA_PASSWORD'] || '',\n    62→    kafkaEnabled: kafkaBrokers.length > 0,\n    63→    supabaseJwtSecret: process.env['SUPABASE_JWT_SECRET'] || '',\n    64→    wsPort: parseInt(optional('WS_PORT', '8443'), 10),\n    65→    httpPort: parseInt(optional('HTTP_PORT', '3001'), 10),\n    66→    // TLS\n    67→    tlsEnabled: process.env['TLS_ENABLED'] !== 'false',\n    68→    tlsCertPath: process.env['TLS_CERT_PATH'] || '',\n    69→    tlsKeyPath: process.env['TLS_KEY_PATH'] || '',\n    70→    tlsCaPath: process.env['TLS_CA_PATH'] || '',\n    71→    tlsRequireClientCert: process.env['TLS_REQUIRE_CLIENT_CERT'] === 'true',\n    72→    // Output scrubbing\n    73→    scrubberEnabled: process.env['SCRUBBER_ENABLED'] !== 'false',\n    74→    // Audit\n    75→    auditDbPath: process.env['AUDIT_DB_PATH'] || path.join(dataDir, 'audit.db'),\n    76→    auditRetentionDays: parseInt(process.env['AUDIT_RETENTION_DAYS'] || '90', 10),\n    77→    // Retention\n    78→    retentionDays: parseInt(process.env['RETENTION_DAYS'] || '30', 10),\n    79→    metricsRetentionDays: parseInt(process.env['METRICS_RETENTION_DAYS'] || '365', 10),\n    80→    // Data directory\n    81→    dataDir,\n    82→    // Worker verification\n    83→    allowedImageDigests: (process.env['ALLOWED_IMAGE_DIGESTS'] || '').split(',').map(s => s.trim()).filter(Boolean),\n    84→    rejectUnverifiedWorkers: process.env['REJECT_UNVERIFIED_WORKERS'] === 'true',\n    85→  };\n    86→}\n    87→"}]},"parent_tool_use_id":null,"session_id":"489d76e2-f864-48d4-83b2-3b0aced8addc","uuid":"06f203b7-854e-41d6-8c18-854096bd2d92","timestamp":"2026-03-18T12:33:34.085Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\config.ts","content":"import 'dotenv/config';\nimport path from 'node:path';\n\nexport interface OrchestratorConfig {\n  masterKey: string;\n  claudeToken: string;\n  teamApiKey: string;\n  workerToken: string;\n  kafkaBrokers: string;\n  kafkaUsername: string;\n  kafkaPassword: string;\n  kafkaEnabled: boolean;\n  supabaseJwtSecret: string;\n  wsPort: number;\n  httpPort: number;\n  // TLS\n  tlsEnabled: boolean;\n  tlsCertPath: string;\n  tlsKeyPath: string;\n  tlsCaPath: string;\n  tlsRequireClientCert: boolean;\n  // Output scrubbing\n  scrubberEnabled: boolean;\n  // Audit\n  auditDbPath: string;\n  auditRetentionDays: number;\n  // Retention\n  retentionDays: number;\n  metricsRetentionDays: number;\n  // Data directory\n  dataDir: string;\n  // Worker verification\n  allowedImageDigests: string[];\n  rejectUnverifiedWorkers: boolean;\n}\n\nfunction required(name: string): string {\n  const value = process.env[name];\n  if (!value) {\n    throw new Error(`Missing required environment variable: ${name}`);\n  }\n  return value;\n}\n\nfunction optional(name: string, fallback: string): string {\n  return process.env[name] || fallback;\n}\n\nexport function loadConfig(): OrchestratorConfig {\n  const kafkaBrokers = process.env['KAFKA_BROKERS'] || '';\n\n  const dataDir = process.env['DAC_DATA_DIR'] || path.join(process.cwd(), 'data');\n\n  return {\n    masterKey: required('MASTER_KEY'),\n    claudeToken: process.env['CLAUDE_TOKEN'] || '',  // Optional: use OAuth flow if not provided\n    teamApiKey: required('TEAM_API_KEY'),\n    workerToken: required('WORKER_TOKEN'),\n    kafkaBrokers,\n    kafkaUsername: process.env['KAFKA_USERNAME'] || '',\n    kafkaPassword: process.env['KAFKA_PASSWORD'] || '',\n    kafkaEnabled: kafkaBrokers.length > 0,\n    supabaseJwtSecret: process.env['SUPABASE_JWT_SECRET'] || '',\n    wsPort: parseInt(optional('WS_PORT', '8443'), 10),\n    httpPort: parseInt(optional('HTTP_PORT', '3001'), 10),\n    // TLS\n    tlsEnabled: process.env['TLS_ENABLED'] !== 'false',\n    tlsCertPath: process.env['TLS_CERT_PATH'] || '',\n    tlsKeyPath: process.env['TLS_KEY_PATH'] || '',\n    tlsCaPath: process.env['TLS_CA_PATH'] || '',\n    tlsRequireClientCert: process.env['TLS_REQUIRE_CLIENT_CERT'] === 'true',\n    // Output scrubbing\n    scrubberEnabled: process.env['SCRUBBER_ENABLED'] !== 'false',\n    // Audit\n    auditDbPath: process.env['AUDIT_DB_PATH'] || path.join(dataDir, 'audit.db'),\n    auditRetentionDays: parseInt(process.env['AUDIT_RETENTION_DAYS'] || '90', 10),\n    // Retention\n    retentionDays: parseInt(process.env['RETENTION_DAYS'] || '30', 10),\n    metricsRetentionDays: parseInt(process.env['METRICS_RETENTION_DAYS'] || '365', 10),\n    // Data directory\n    dataDir,\n    // Worker verification\n    allowedImageDigests: (process.env['ALLOWED_IMAGE_DIGESTS'] || '').split(',').map(s => s.trim()).filter(Boolean),\n    rejectUnverifiedWorkers: process.env['REJECT_UNVERIFIED_WORKERS'] === 'true',\n  };\n}\n","numLines":87,"startLine":1,"totalLines":87}}}
[2026-03-18T12:33:34.221Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YYRSNHBuVyFD5gaLajwGmE","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    11→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    12→import type { TenantDbManager } from './tenantDbManager.js';\n    13→import type { TenantKeyManager } from './tenantKeyManager.js';\n    14→import type { AuditLog } from './auditLog.js';\n    15→import type { Logger } from 'pino';\n    16→import * as db from './db/index.js';\n    17→import { readBody, json } from './httpUtils.js';\n    18→\n    19→export function createHttpApi(\n    20→  auth: Auth,\n    21→  dispatcher: Dispatcher,\n    22→  pool: WorkerPool,\n    23→  tokenManager: TokenManager,\n    24→  oauth: OAuthManager,\n    25→  logger: Logger,\n    26→  database?: Database.Database,\n    27→  tenantDbManager?: TenantDbManager,\n    28→  tenantKeyManager?: TenantKeyManager,\n    29→  auditLog?: AuditLog,\n    30→): http.Server {\n    31→  const server = http.createServer(async (req, res) => {\n    32→    // Security headers\n    33→    res.setHeader('X-Content-Type-Options', 'nosniff');\n    34→\n    35→    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    36→    const origin = req.headers.origin ?? '';\n    37→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    38→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    39→    if (isAdminRoute) {\n    40→      // Admin routes: only allow same-origin requests (no CORS wildcard)\n    41→      if (origin && origin === allowedOrigin) {\n    42→        res.setHeader('Access-Control-Allow-Origin', origin);\n    43→      }\n    44→      // If no match, omit the header entirely — browser blocks the request\n    45→    } else {\n    46→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    47→    }\n    48→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    49→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n    50→\n    51→    if (req.method === 'OPTIONS') {\n    52→      res.writeHead(204);\n    53→      res.end();\n    54→      return;\n    55→    }\n    56→\n    57→    const url = req.url || '/';\n    58→    const [pathname, queryString] = url.split('?');\n    59→    const route = parseRoute(pathname ?? '');\n    60→\n    61→    // Unauthenticated endpoints\n    62→    if (pathname === '/health' && req.method === 'GET') {\n    63→      handleHealth(res, pool, oauth);\n    64→      return;\n    65→    }\n    66→\n    67→    // Auth check for everything else — dual auth (API key + optional JWT)\n    68→    const ctx = auth.validateAndExtractContext(req);\n    69→    if (!ctx) {\n    70→      res.writeHead(401, { 'Content-Type': 'application/json' });\n    71→      res.end(JSON.stringify({ error: 'Unauthorized' }));\n    72→      return;\n    73→    }\n    74→\n    75→    // Helper: project scoping (admin sees all, user sees own project)\n    76→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n    77→\n    78→    // Resolve tenant-specific database when available\n    79→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n    80→      if (tenantDbManager && projectId) {\n    81→        return tenantDbManager.getTenantDb(projectId);\n    82→      }\n    83→      return database;\n    84→    };\n    85→    const tenantDb = resolveDatabase(ctx.projectId);\n    86→\n    87→    try {\n    88→      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n    89→      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n    90→        if (requireAdmin(ctx, res)) return;\n    91→        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n    92→        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n    93→        return;\n    94→      }\n    95→      // --- Persona CRUD ---\n    96→      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n    97→        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n    98→      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n    99→        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   100→        const persona = createPersonaWithDefaults({\n   101→          ...body,\n   102→          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   103→        });\n   104→        db.upsertPersona(tenantDb, persona);\n   105→        logger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   106→        json(res, 201, persona);\n   107→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n   108→        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n   109→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n   110→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   111→        if (!persona) return;\n   112→        const body = JSON.parse(await readBody(req)) as { toolId: string };\n   113→        db.linkTool(tenantDb, route.id, body.toolId);\n   114→        logger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   115→        json(res, 200, { linked: true });\n   116→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n   117→        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, logger), scopedProjectId, res);\n   118→        if (!hydrated) return;\n   119→        json(res, 200, hydrated);\n   120→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n   121→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   122→        if (!persona) return;\n   123→        json(res, 200, persona);\n   124→      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   125→        db.deletePersona(tenantDb, route.id, scopedProjectId);\n   126→        logger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   127→        json(res, 200, { deleted: true });\n   128→      }\n   129→      // --- Tool Definitions ---\n   130→      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n   131→        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   132→        const tool = createToolDefinitionWithDefaults(body);\n   133→        db.upsertToolDefinition(tenantDb, tool);\n   134→        logger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   135→        json(res, 201, tool);\n   136→      }\n   137→      // --- Credentials ---\n   138→      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n   139→        const body = JSON.parse(await readBody(req));\n   140→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   141→\n   142→        // Require plaintext — clients must never supply pre-encrypted data\n   143→        if (!body.plaintext || typeof body.plaintext !== 'string') {\n   144→          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   145→          return;\n   146→        }\n   147→\n   148→        // Reject oversized plaintext before synchronous encryption blocks the event loop\n   149→        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   150→          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   151→          return;\n   152→        }\n   153→\n   154→        // Encryption is mandatory — reject if the key manager is unavailable\n   155→        if (!tenantKeyManager) {\n   156→          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   157→          return;\n   158→        }\n   159→\n   160→        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n   161→        delete body.encryptedData;\n   162→        delete body.iv;\n   163→        delete body.tag;\n   164→\n   165→        // Server-side encryption with per-tenant key\n   166→        const tenantId = body.projectId || ctx.projectId || 'default';\n   167→        const key = await tenantKeyManager.getKey(tenantId);\n   168→        const encrypted = encrypt(body.plaintext, key);\n   169→        body.encryptedData = encrypted.encrypted;\n   170→        body.iv = encrypted.iv;\n   171→        body.tag = encrypted.tag;\n   172→        delete body.plaintext;\n   173→\n   174→        const cred = db.createCredential(tenantDb, body);\n   175→        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n   176→        logger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   177→        json(res, 201, cred);\n   178→      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   179→        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n   180→        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   181→        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   182→        logger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   183→        json(res, 200, { deleted: true });\n   184→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n   185→        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n   186→        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n   187→        // Strip encrypted data from response\n   188→        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   189→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n   190→        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n   191→        if (!persona) return;\n   192→        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   193→        db.linkCredential(tenantDb, route.id, body.credentialId);\n   194→        json(res, 200, { linked: true });\n   195→      }\n   196→      // --- Event Subscriptions ---\n   197→      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n   198→        const body = JSON.parse(await readBody(req));\n   199→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   200→        const missing: string[] = [];\n   201→        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   202→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   203→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   204→        const sub = db.createSubscription(tenantDb, body);\n   205→        json(res, 201, sub);\n   206→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   207→        const body = JSON.parse(await readBody(req));\n   208→        db.updateSubscription(tenantDb, route.id, body);\n   209→        const updated = db.getSubscription(tenantDb, route.id);\n   210→        json(res, 200, updated);\n   211→      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n   212→        db.deleteSubscription(tenantDb, route.id);\n   213→        json(res, 200, { deleted: true });\n   214→      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n   215→        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n   216→      }\n   217→      // --- Triggers (delegated to triggerHttpHandlers) ---\n   218→      else if (route && tenantDb && (\n   219→        route.resource === 'triggers' ||\n   220→        (route.resource === 'personas' && route.subResource === 'triggers')\n   221→      )) {\n   222→        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n   223→        return;\n   224→      }\n   225→      // --- Events ---\n   226→      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n   227→        const params = new URLSearchParams(queryString || '');\n   228→        const events = db.listEvents(tenantDb, {\n   229→          eventType: params.get('eventType') ?? undefined,\n   230→          status: params.get('status') ?? undefined,\n   231→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   232→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   233→          projectId: scopedProjectId,\n   234→        });\n   235→        json(res, 200, events);\n   236→      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n   237→        const body = JSON.parse(await readBody(req));\n   238→        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   239→        const missing: string[] = [];\n   240→        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   241→        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   242→        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   243→        const event = db.publishEvent(tenantDb, body);\n   244→        json(res, 201, event);\n   245→      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n   246→        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n   247→        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n   248→        if (updated) {\n   249→          json(res, 200, updated);\n   250→        } else {\n   251→          res.writeHead(404, { 'Content-Type': 'application/json' });\n   252→          res.end(JSON.stringify({ error: 'Event not found' }));\n   253→        }\n   254→      }\n   255→      // --- Webhooks ---\n   256→      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n   257→        const personaId = route.id;\n   258→        const body = await readBody(req);\n   259→        const event = db.publishEvent(tenantDb, {\n   260→          eventType: 'webhook_received',\n   261→          sourceType: 'webhook',\n   262→          sourceId: personaId,\n   263→          targetPersonaId: personaId,\n   264→          payload: body,\n   265→        });\n   266→        json(res, 201, event);\n   267→      }\n   268→      // --- GitLab Webhook ---\n   269→      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n   270→        const body = await readBody(req);\n   271→        let parsed: Record<string, unknown> = {};\n   272→        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   273→        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   274→        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   275→        const event = db.publishEvent(tenantDb, {\n   276→          eventType: `gitlab_${objectKind}`,\n   277→          sourceType: 'gitlab',\n   278→          sourceId: projectPath ?? null,\n   279→          payload: body,\n   280→        });\n   281→        json(res, 201, event);\n   282→      }\n   283→      // --- Executions ---\n   284→      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n   285→        const params = new URLSearchParams(queryString || '');\n   286→        const executions = db.listExecutions(tenantDb, {\n   287→          personaId: params.get('personaId') ?? undefined,\n   288→          status: params.get('status') ?? undefined,\n   289→          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   290→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   291→          projectId: scopedProjectId,\n   292→        });\n   293→        json(res, 200, executions);\n   294→      }\n   295→      // --- Existing execution endpoints ---\n   296→      else if (pathname === '/api/status' && req.method === 'GET') {\n   297→        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   298→      } else if (pathname === '/api/execute' && req.method === 'POST') {\n   299→        await handleExecute(req, res, dispatcher, logger, ctx);\n   300→      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n   301→        handleCancelExecution(res, dispatcher, route.id);\n   302→      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n   303→        const executionId = route.id;\n   304→        const params = new URLSearchParams(queryString || '');\n   305→        const offset = parseInt(params.get('offset') || '0', 10);\n   306→        handleGetExecution(res, dispatcher, executionId, offset);\n   307→      }\n   308→      // --- Admin-only routes ---\n   309→      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n   310→        if (requireAdmin(ctx, res)) return;\n   311→        if (tenantDbManager) {\n   312→          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   313→        } else if (database) {\n   314→          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   315→        } else {\n   316→          json(res, 200, { projectIds: [] });\n   317→        }\n   318→      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n   319→        if (requireAdmin(ctx, res)) return;\n   320→        if (tenantDbManager) {\n   321→          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   322→          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   323→          json(res, 200, allPersonas);\n   324→        } else if (database) {\n   325→          json(res, 200, db.listPersonasSummary(database));\n   326→        } else {\n   327→          json(res, 200, []);\n   328→        }\n   329→      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n   330→        if (requireAdmin(ctx, res)) return;\n   331→        const params = new URLSearchParams(queryString || '');\n   332→        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   333→        if (tenantDbManager) {\n   334→          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   335→          tenantDbManager.forEachTenant((tDb) => {\n   336→            allExecs.push(...db.listExecutions(tDb, { limit }));\n   337→          });\n   338→          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   339→          json(res, 200, allExecs.slice(0, limit));\n   340→        } else if (database) {\n   341→          json(res, 200, db.listExecutions(database, {\n   342→            limit,\n   343→            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   344→          }));\n   345→        } else {\n   346→          json(res, 200, []);\n   347→        }\n   348→      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n   349→        if (requireAdmin(ctx, res)) return;\n   350→        if (!auditLog) { json(res, 200, []); return; }\n   351→        const params = new URLSearchParams(queryString || '');\n   352→        json(res, 200, auditLog.query({\n   353→          tenantId: params.get('tenantId') ?? undefined,\n   354→          action: params.get('action') ?? undefined,\n   355→          since: params.get('since') ?? undefined,\n   356→          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   357→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   358→        }));\n   359→      } else {\n   360→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   361→        res.end(JSON.stringify({ error: 'Not found' }));\n   362→      }\n   363→    } catch (err) {\n   364→      if (err instanceof Error && err.message === 'Payload too large') {\n   365→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   366→        res.end(JSON.stringify({ error: 'Payload too large' }));\n   367→        return;\n   368→      }\n   369→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   370→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   371→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n   372→        return;\n   373→      }\n   374→      logger.error({ err, url }, 'HTTP handler error');\n   375→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   376→      res.end(JSON.stringify({ error: 'Internal server error' }));\n   377→    }\n   378→  });\n   379→\n   380→  return server;\n   381→}\n   382→\n   383→interface ParsedRoute {\n   384→  resource: string;\n   385→  id?: string;\n   386→  subResource?: string;\n   387→}\n   388→\n   389→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n   390→function parseRoute(pathname: string): ParsedRoute | null {\n   391→  if (!pathname.startsWith('/api/')) return null;\n   392→  const segments = pathname.slice(5).split('/').filter(Boolean);\n   393→  if (segments.length === 0) return null;\n   394→  return {\n   395→    resource: segments[0]!,\n   396→    id: segments[1],\n   397→    subResource: segments[2],\n   398→  };\n   399→}\n   400→\n   401→/**\n   402→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   403→ * Returns the entity on success, or null after sending a 404 response.\n   404→ */\n   405→function withScopedEntity<T extends { projectId?: string | null }>(\n   406→  entity: T | undefined,\n   407→  scopedProjectId: string | undefined,\n   408→  res: http.ServerResponse,\n   409→): T | null {\n   410→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   411→    json(res, 404, { error: 'Not found' });\n   412→    return null;\n   413→  }\n   414→  return entity;\n   415→}\n   416→\n   417→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   418→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   419→  if (ctx.authType !== 'admin') {\n   420→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   421→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   422→    return true;\n   423→  }\n   424→  return false;\n   425→}\n   426→\n   427→// --- Existing handlers ---\n   428→\n   429→function handleHealth(res: http.ServerResponse, pool: WorkerPool, oauth: OAuthManager): void {\n   430→  const counts = pool.getWorkerCount();\n   431→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   432→  res.end(JSON.stringify({\n   433→    status: 'ok',\n   434→    workers: counts,\n   435→    hasSubscription: oauth.hasTokens(),\n   436→    timestamp: Date.now(),\n   437→  }));\n   438→}\n   439→\n   440→function handleStatus(\n   441→  res: http.ServerResponse,\n   442→  pool: WorkerPool,\n   443→  dispatcher: Dispatcher,\n   444→  tokenManager: TokenManager,\n   445→  oauth: OAuthManager,\n   446→): void {\n   447→  const oauthTokens = oauth.getTokens();\n   448→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   449→  res.end(JSON.stringify({\n   450→    workers: pool.getWorkers(),\n   451→    workerCounts: pool.getWorkerCount(),\n   452→    queueLength: dispatcher.getQueueLength(),\n   453→    activeExecutions: dispatcher.getActiveExecutions(),\n   454→    hasClaudeToken: tokenManager.hasToken(),\n   455→    oauth: {\n   456→      connected: oauth.hasTokens(),\n   457→      scopes: oauthTokens?.scopes || [],\n   458→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   459→    },\n   460→  }));\n   461→}\n   462→\n   463→async function handleExecute(\n   464→  req: http.IncomingMessage,\n   465→  res: http.ServerResponse,\n   466→  dispatcher: Dispatcher,\n   467→  logger: Logger,\n   468→  ctx?: RequestContext,\n   469→): Promise<void> {\n   470→  const body = await readBody(req);\n   471→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   472→\n   473→  try {\n   474→    parsed = JSON.parse(body);\n   475→  } catch {\n   476→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   477→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   478→    return;\n   479→  }\n   480→\n   481→  if (!parsed.prompt) {\n   482→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   483→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   484→    return;\n   485→  }\n   486→\n   487→  const request: ExecRequest = {\n   488→    executionId: nanoid(),\n   489→    personaId: parsed.personaId || 'manual',\n   490→    prompt: parsed.prompt,\n   491→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   492→    config: {\n   493→      timeoutMs: parsed.timeoutMs || 300_000,\n   494→    },\n   495→  };\n   496→\n   497→  dispatcher.submit(request);\n   498→\n   499→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   500→\n   501→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   502→  res.end(JSON.stringify({\n   503→    executionId: request.executionId,\n   504→    status: 'queued',\n   505→  }));\n   506→}\n   507→\n   508→function handleGetExecution(\n   509→  res: http.ServerResponse,\n   510→  dispatcher: Dispatcher,\n   511→  executionId: string,\n   512→  offset: number = 0,\n   513→): void {\n   514→  const exec = dispatcher.getExecution(executionId);\n   515→\n   516→  if (!exec) {\n   517→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   518→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   519→    return;\n   520→  }\n   521→\n   522→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   523→\n   524→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   525→  res.end(JSON.stringify({\n   526→    executionId,\n   527→    status: exec.status,\n   528→    outputLines: exec.output.length,\n   529→    output,\n   530→    durationMs: exec.durationMs,\n   531→    sessionId: exec.sessionId,\n   532→    totalCostUsd: exec.totalCostUsd,\n   533→  }));\n   534→}\n   535→\n   536→function handleCancelExecution(\n   537→  res: http.ServerResponse,\n   538→  dispatcher: Dispatcher,\n   539→  executionId: string,\n   540→): void {\n   541→  const cancelled = dispatcher.cancelExecution(executionId);\n   542→\n   543→  if (!cancelled) {\n   544→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   545→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   546→    return;\n   547→  }\n   548→\n   549→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   550→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   551→}\n   552→\n   553→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\n   554→const MAX_QUERY_LIMIT = 500;\n   555→const MAX_QUERY_OFFSET = 100_000;\n   556→\n   557→/** Parse an integer query param and clamp it to safe bounds. */\n   558→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   559→  if (!value) return defaultValue;\n   560→  const parsed = parseInt(value, 10);\n   561→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   562→  return Math.min(parsed, max);\n   563→}\n   564→"}]},"parent_tool_use_id":null,"session_id":"489d76e2-f864-48d4-83b2-3b0aced8addc","uuid":"d5a9d382-a014-488e-96f4-67f700f88158","timestamp":"2026-03-18T12:33:34.142Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n): http.Server {\n  const server = http.createServer(async (req, res) => {\n    // Security headers\n    res.setHeader('X-Content-Type-Options', 'nosniff');\n\n    // CORS headers — admin endpoints deny cross-origin; others allow configured origins\n    const origin = req.headers.origin ?? '';\n    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n    if (isAdminRoute) {\n      // Admin routes: only allow same-origin requests (no CORS wildcard)\n      if (origin && origin === allowedOrigin) {\n        res.setHeader('Access-Control-Allow-Origin', origin);\n      }\n      // If no match, omit the header entirely — browser blocks the request\n    } else {\n      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n    }\n    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n\n    if (req.method === 'OPTIONS') {\n      res.writeHead(204);\n      res.end();\n      return;\n    }\n\n    const url = req.url || '/';\n    const [pathname, queryString] = url.split('?');\n    const route = parseRoute(pathname ?? '');\n\n    // Unauthenticated endpoints\n    if (pathname === '/health' && req.method === 'GET') {\n      handleHealth(res, pool, oauth);\n      return;\n    }\n\n    // Auth check for everything else — dual auth (API key + optional JWT)\n    const ctx = auth.validateAndExtractContext(req);\n    if (!ctx) {\n      res.writeHead(401, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Unauthorized' }));\n      return;\n    }\n\n    // Helper: project scoping (admin sees all, user sees own project)\n    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n\n    // Resolve tenant-specific database when available\n    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n      if (tenantDbManager && projectId) {\n        return tenantDbManager.getTenantDb(projectId);\n      }\n      return database;\n    };\n    const tenantDb = resolveDatabase(ctx.projectId);\n\n    try {\n      // --- OAuth + Token injection (admin-only, delegated to oauthHttpHandlers) ---\n      if (pathname?.startsWith('/api/oauth/') || (pathname === '/api/token' && req.method === 'POST')) {\n        if (requireAdmin(ctx, res)) return;\n        await handleOAuthRoute(pathname!, req.method!, req, res, oauth, tokenManager, logger);\n        // Always return — handleOAuthRoute sends 404 for unrecognised sub-paths\n        return;\n      }\n      // --- Persona CRUD ---\n      else if (route?.resource === 'personas' && !route.id && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listPersonasSummary(tenantDb, scopedProjectId));\n      } else if (route?.resource === 'personas' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n        const persona = createPersonaWithDefaults({\n          ...body,\n          projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n        });\n        db.upsertPersona(tenantDb, persona);\n        logger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n        json(res, 201, persona);\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.getToolsForPersona(tenantDb, route.id));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'tools' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { toolId: string };\n        db.linkTool(tenantDb, route.id, body.toolId);\n        logger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route.id, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n        json(res, 200, { linked: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'full' && req.method === 'GET' && tenantDb) {\n        const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb, route.id, logger), scopedProjectId, res);\n        if (!hydrated) return;\n        json(res, 200, hydrated);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'GET' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        json(res, 200, persona);\n      } else if (route?.resource === 'personas' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deletePersona(tenantDb, route.id, scopedProjectId);\n        logger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n        json(res, 200, { deleted: true });\n      }\n      // --- Tool Definitions ---\n      else if (route?.resource === 'tool-definitions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n        const tool = createToolDefinitionWithDefaults(body);\n        db.upsertToolDefinition(tenantDb, tool);\n        logger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n        json(res, 201, tool);\n      }\n      // --- Credentials ---\n      else if (route?.resource === 'credentials' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n\n        // Require plaintext — clients must never supply pre-encrypted data\n        if (!body.plaintext || typeof body.plaintext !== 'string') {\n          json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n          return;\n        }\n\n        // Reject oversized plaintext before synchronous encryption blocks the event loop\n        if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n          json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n          return;\n        }\n\n        // Encryption is mandatory — reject if the key manager is unavailable\n        if (!tenantKeyManager) {\n          json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n          return;\n        }\n\n        // Strip any client-supplied encrypted fields — server is the sole trust boundary\n        delete body.encryptedData;\n        delete body.iv;\n        delete body.tag;\n\n        // Server-side encryption with per-tenant key\n        const tenantId = body.projectId || ctx.projectId || 'default';\n        const key = await tenantKeyManager.getKey(tenantId);\n        const encrypted = encrypt(body.plaintext, key);\n        body.encryptedData = encrypted.encrypted;\n        body.iv = encrypted.iv;\n        body.tag = encrypted.tag;\n        delete body.plaintext;\n\n        const cred = db.createCredential(tenantDb, body);\n        try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', resourceType: 'credential', resourceId: cred.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n        json(res, 201, cred);\n      } else if (route?.resource === 'credentials' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        const changes = db.deleteCredential(tenantDb, route.id, scopedProjectId);\n        if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n        try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n        logger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route.id, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'GET' && tenantDb) {\n        const creds = db.listCredentialsForPersona(tenantDb, route.id);\n        try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', resourceType: 'credential', resourceId: route.id }); } catch { /* logged inside record() */ }\n        // Strip encrypted data from response\n        json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'credentials' && req.method === 'POST' && tenantDb) {\n        const persona = withScopedEntity(db.getPersona(tenantDb, route.id), scopedProjectId, res);\n        if (!persona) return;\n        const body = JSON.parse(await readBody(req)) as { credentialId: string };\n        db.linkCredential(tenantDb, route.id, body.credentialId);\n        json(res, 200, { linked: true });\n      }\n      // --- Event Subscriptions ---\n      else if (route?.resource === 'subscriptions' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const sub = db.createSubscription(tenantDb, body);\n        json(res, 201, sub);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        db.updateSubscription(tenantDb, route.id, body);\n        const updated = db.getSubscription(tenantDb, route.id);\n        json(res, 200, updated);\n      } else if (route?.resource === 'subscriptions' && route.id && !route.subResource && req.method === 'DELETE' && tenantDb) {\n        db.deleteSubscription(tenantDb, route.id);\n        json(res, 200, { deleted: true });\n      } else if (route?.resource === 'personas' && route.id && route.subResource === 'subscriptions' && req.method === 'GET' && tenantDb) {\n        json(res, 200, db.listSubscriptionsForPersona(tenantDb, route.id));\n      }\n      // --- Triggers (delegated to triggerHttpHandlers) ---\n      else if (route && tenantDb && (\n        route.resource === 'triggers' ||\n        (route.resource === 'personas' && route.subResource === 'triggers')\n      )) {\n        await handleTriggerRoute(route, req.method!, req, res, tenantDb, ctx);\n        return;\n      }\n      // --- Events ---\n      else if (route?.resource === 'events' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const events = db.listEvents(tenantDb, {\n          eventType: params.get('eventType') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, events);\n      } else if (route?.resource === 'events' && !route.id && req.method === 'POST' && tenantDb) {\n        const body = JSON.parse(await readBody(req));\n        if (ctx.authType === 'user') body.projectId = ctx.projectId;\n        const missing: string[] = [];\n        if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n        if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n        if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n        const event = db.publishEvent(tenantDb, body);\n        json(res, 201, event);\n      } else if (route?.resource === 'events' && route.id && !route.subResource && req.method === 'PUT' && tenantDb) {\n        const body = JSON.parse(await readBody(req)) as { status: string; metadata?: string };\n        const updated = db.updateEventWithMetadata(tenantDb, route.id, body.status, body.metadata);\n        if (updated) {\n          json(res, 200, updated);\n        } else {\n          res.writeHead(404, { 'Content-Type': 'application/json' });\n          res.end(JSON.stringify({ error: 'Event not found' }));\n        }\n      }\n      // --- Webhooks ---\n      else if (route?.resource === 'webhooks' && route.id && !route.subResource && req.method === 'POST' && tenantDb) {\n        const personaId = route.id;\n        const body = await readBody(req);\n        const event = db.publishEvent(tenantDb, {\n          eventType: 'webhook_received',\n          sourceType: 'webhook',\n          sourceId: personaId,\n          targetPersonaId: personaId,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- GitLab Webhook ---\n      else if (pathname === '/api/gitlab/webhook' && req.method === 'POST' && tenantDb) {\n        const body = await readBody(req);\n        let parsed: Record<string, unknown> = {};\n        try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n        const objectKind = (parsed['object_kind'] as string) || 'unknown';\n        const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n        const event = db.publishEvent(tenantDb, {\n          eventType: `gitlab_${objectKind}`,\n          sourceType: 'gitlab',\n          sourceId: projectPath ?? null,\n          payload: body,\n        });\n        json(res, 201, event);\n      }\n      // --- Executions ---\n      else if (route?.resource === 'executions' && !route.id && req.method === 'GET' && tenantDb) {\n        const params = new URLSearchParams(queryString || '');\n        const executions = db.listExecutions(tenantDb, {\n          personaId: params.get('personaId') ?? undefined,\n          status: params.get('status') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          projectId: scopedProjectId,\n        });\n        json(res, 200, executions);\n      }\n      // --- Existing execution endpoints ---\n      else if (pathname === '/api/status' && req.method === 'GET') {\n        handleStatus(res, pool, dispatcher, tokenManager, oauth);\n      } else if (pathname === '/api/execute' && req.method === 'POST') {\n        await handleExecute(req, res, dispatcher, logger, ctx);\n      } else if (route?.resource === 'executions' && route.id && route.subResource === 'cancel' && req.method === 'POST') {\n        handleCancelExecution(res, dispatcher, route.id);\n      } else if (route?.resource === 'executions' && route.id && !route.subResource && req.method === 'GET') {\n        const executionId = route.id;\n        const params = new URLSearchParams(queryString || '');\n        const offset = parseInt(params.get('offset') || '0', 10);\n        handleGetExecution(res, dispatcher, executionId, offset);\n      }\n      // --- Admin-only routes ---\n      else if (pathname === '/api/admin/users' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n        } else if (database) {\n          json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n        } else {\n          json(res, 200, { projectIds: [] });\n        }\n      } else if (pathname === '/api/admin/personas' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (tenantDbManager) {\n          const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n          tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n          json(res, 200, allPersonas);\n        } else if (database) {\n          json(res, 200, db.listPersonasSummary(database));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/executions' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        const params = new URLSearchParams(queryString || '');\n        const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n        if (tenantDbManager) {\n          const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n          tenantDbManager.forEachTenant((tDb) => {\n            allExecs.push(...db.listExecutions(tDb, { limit }));\n          });\n          allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n          json(res, 200, allExecs.slice(0, limit));\n        } else if (database) {\n          json(res, 200, db.listExecutions(database, {\n            limit,\n            offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n          }));\n        } else {\n          json(res, 200, []);\n        }\n      } else if (pathname === '/api/admin/audit' && req.method === 'GET') {\n        if (requireAdmin(ctx, res)) return;\n        if (!auditLog) { json(res, 200, []); return; }\n        const params = new URLSearchParams(queryString || '');\n        json(res, 200, auditLog.query({\n          tenantId: params.get('tenantId') ?? undefined,\n          action: params.get('action') ?? undefined,\n          since: params.get('since') ?? undefined,\n          limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        }));\n      } else {\n        res.writeHead(404, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Not found' }));\n      }\n    } catch (err) {\n      if (err instanceof Error && err.message === 'Payload too large') {\n        res.writeHead(413, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Payload too large' }));\n        return;\n      }\n      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n        res.writeHead(409, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists' }));\n        return;\n      }\n      logger.error({ err, url }, 'HTTP handler error');\n      res.writeHead(500, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Internal server error' }));\n    }\n  });\n\n  return server;\n}\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\n/**\n * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n * Returns the entity on success, or null after sending a 404 response.\n */\nfunction withScopedEntity<T extends { projectId?: string | null }>(\n  entity: T | undefined,\n  scopedProjectId: string | undefined,\n  res: http.ServerResponse,\n): T | null {\n  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n    json(res, 404, { error: 'Not found' });\n    return null;\n  }\n  return entity;\n}\n\n/** Returns true (and sends 403) if the caller is NOT an admin. */\nfunction requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n  if (ctx.authType !== 'admin') {\n    res.writeHead(403, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Admin access required' }));\n    return true;\n  }\n  return false;\n}\n\n// --- Existing handlers ---\n\nfunction handleHealth(res: http.ServerResponse, pool: WorkerPool, oauth: OAuthManager): void {\n  const counts = pool.getWorkerCount();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    status: 'ok',\n    workers: counts,\n    hasSubscription: oauth.hasTokens(),\n    timestamp: Date.now(),\n  }));\n}\n\nfunction handleStatus(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n): void {\n  const oauthTokens = oauth.getTokens();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    workers: pool.getWorkers(),\n    workerCounts: pool.getWorkerCount(),\n    queueLength: dispatcher.getQueueLength(),\n    activeExecutions: dispatcher.getActiveExecutions(),\n    hasClaudeToken: tokenManager.hasToken(),\n    oauth: {\n      connected: oauth.hasTokens(),\n      scopes: oauthTokens?.scopes || [],\n      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n    },\n  }));\n}\n\nasync function handleExecute(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  ctx?: RequestContext,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.prompt) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n    return;\n  }\n\n  const request: ExecRequest = {\n    executionId: nanoid(),\n    personaId: parsed.personaId || 'manual',\n    prompt: parsed.prompt,\n    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n    config: {\n      timeoutMs: parsed.timeoutMs || 300_000,\n    },\n  };\n\n  dispatcher.submit(request);\n\n  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n\n  res.writeHead(202, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId: request.executionId,\n    status: 'queued',\n  }));\n}\n\nfunction handleGetExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n  offset: number = 0,\n): void {\n  const exec = dispatcher.getExecution(executionId);\n\n  if (!exec) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found' }));\n    return;\n  }\n\n  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId,\n    status: exec.status,\n    outputLines: exec.output.length,\n    output,\n    durationMs: exec.durationMs,\n    sessionId: exec.sessionId,\n    totalCostUsd: exec.totalCostUsd,\n  }));\n}\n\nfunction handleCancelExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n): void {\n  const cancelled = dispatcher.cancelExecution(executionId);\n\n  if (!cancelled) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n    return;\n  }\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n}\n\nconst MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB – generous limit for credential secrets\nconst MAX_QUERY_LIMIT = 500;\nconst MAX_QUERY_OFFSET = 100_000;\n\n/** Parse an integer query param and clamp it to safe bounds. */\nfunction clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n  if (!value) return defaultValue;\n  const parsed = parseInt(value, 10);\n  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n  return Math.min(parsed, max);\n}\n","numLines":564,"startLine":1,"totalLines":564}}}
