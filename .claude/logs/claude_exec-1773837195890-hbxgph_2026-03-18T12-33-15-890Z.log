 = {};\n\n  /** Connection lifecycle metrics. */\n  private metrics: WorkerPoolMetrics = {\n    totalConnections: 0,\n    totalDisconnections: 0,\n    parseFailures: 0,\n    heartbeatNearMisses: 0,\n    recentConnectionDurations: [],\n  };","numLines":50,"startLine":36,"totalLines":398}}}
