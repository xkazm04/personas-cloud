[2026-03-18T17:59:56.505Z] [STDOUT] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01MLTBrXPfVi7RviF6w9KkjE","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0111s8fUF9rnE32bQp9V8giJ","name":"Write","input":{"file_path":"C:\\Users\\kazda\\kiro\\personas-cloud\\.claude\\worktrees\\snappy-skipping-hejlsberg\\packages\\shared\\src\\auditedCrypto.ts","content":"import { encrypt, decrypt, type EncryptedPayload } from './crypto.js';\n\n// ---------------------------------------------------------------------------\n// Audit event types\n// ---------------------------------------------------------------------------\n\nexport interface CryptoAuditEvent {\n  operation: 'encrypt' | 'decrypt';\n  timestamp: number;\n  success: boolean;\n  error?: string;\n  /** Optional caller-supplied context (e.g. credential name, execution id) */\n  context?: Record<string, string>;\n}\n\n/**\n * Receives every audit event emitted by an AuditedCryptoService.\n * Implementations may log, persist to DB, forward to Kafka, etc.\n */\nexport interface CryptoAuditEmitter {\n  emit(event: CryptoAuditEvent): void;\n}\n\n// ---------------------------------------------------------------------------\n// Audited crypto service — structural audit guarantee\n// ---------------------------------------------------------------------------\n\n/**\n * A crypto service whose encrypt/decrypt operations *always* produce an audit\n * record. Consumers that obtain crypto capabilities through this interface\n * cannot bypass auditing.\n */\nexport interface CryptoService {\n  encrypt(plaintext: string, context?: Record<string, string>): EncryptedPayload;\n  decrypt(payload: EncryptedPayload, context?: Record<string, string>): string;\n}\n\n/**\n * Creates a CryptoService that structurally emits an audit event on every\n * encrypt/decrypt call. The master key is captured at construction time so\n * callers never handle it directly.\n */\nexport function createAuditedCryptoService(\n  masterKey: Buffer,\n  emitter: CryptoAuditEmitter,\n): CryptoService {\n  return {\n    encrypt(plaintext: string, context?: Record<string, string>): EncryptedPayload {\n      try {\n        const result = encrypt(plaintext, masterKey);\n        emitter.emit({ operation: 'encrypt', timestamp: Date.now(), success: true, context });\n        return result;\n      } catch (err) {\n        const message = err instanceof Error ? err.message : String(err);\n        emitter.emit({ operation: 'encrypt', timestamp: Date.now(), success: false, error: message, context });\n        throw err;\n      }\n    },\n\n    decrypt(payload: EncryptedPayload, context?: Record<string, string>): string {\n      try {\n        const result = decrypt(payload, masterKey);\n        emitter.emit({ operation: 'decrypt', timestamp: Date.now(), success: true, context });\n        return result;\n      } catch (err) {\n        const message = err instanceof Error ? err.message : String(err);\n        emitter.emit({ operation: 'decrypt', timestamp: Date.now(), success: false, error: message, context });\n        throw err;\n      }\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":720,"cache_read_input_tokens":53854,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":720},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7da28a8a-a7e0-42ee-af9d-b1b1bce35418","uuid":"48bed0de-902e-4594-b2d3-216ad849954e"}
