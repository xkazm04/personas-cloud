te().toISOString();\n  systemDb.transaction(() => {\n    const upsert = systemDb.prepare(`\n      INSERT INTO system_daily_metrics\n        (date, total_executions, completed, failed, total_cost_usd, total_duration_ms, tenant_count, aggregated_at)\n      VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n      ON CONFLICT(date) DO UPDATE SET\n        total_executions = excluded.total_executions,\n        completed = excluded.completed,\n        failed = excluded.failed,\n        total_cost_usd = excluded.total_cost_usd,\n        total_duration_ms = excluded.total_duration_ms,\n        tenant_count = excluded.tenant_count,\n        aggregated_at = excluded.aggregated_at\n    `);\n    for (const [date, m] of dayMap) {\n      upsert.run(date, m.total_executions, m.completed, m.failed, m.total_cost_usd, m.total_duration_ms, m.tenant_count, now);\n    }\n  })();\n\n  logger.info({ days: dayMap.size, tenants: tenantIds.length }, 'System-wide metrics aggregation complete');\n}\n","structuredPatch":[{"oldStart":57,"oldLines":6,"newStart":57,"newLines":21,"lines":["   ).run(LAST_RUN_KEY, date);"," }"," ","+/** Persist the ISO timestamp of the last successful run. */","+function setLastRunAt(tenantDbManager: TenantDbManager, isoTimestamp: string): void {","+  tenantDbManager.getSystemDb().prepare(","+    'INSERT INTO system_kv (key, value) VALUES (?, ?) ON CONFLICT(key) DO UPDATE SET value = excluded.value',","+  ).run(LAST_RUN_AT_KEY, isoTimestamp);","+}","+","+/** Read the ISO timestamp of the last successful run, or null. */","+function getLastRunAt(tenantDbManager: TenantDbManager): string | null {","+  const row = tenantDbManager.getSystemDb().prepare(","+    'SELECT value FROM system_kv WHERE key = ?',","+  ).get(LAST_RUN_AT_KEY) as { value: string } | undefined;","+  return row?.value ?? null;","+}","+"," /**","  * Daily retention job: purge old executions/events and aggregate daily metrics.","  *"]}],"userModified":false,"replaceAll":false}}
