n    86→    try {\n    87→      await runRetention(tenantDbManager, retentionDays, metricsRetentionDays, logger);\n    88→      setLastRunDate(tenantDbManager, today);\n    89→      logger.info({ today }, 'Retention job completed, next run tomorrow');\n    90→    } catch (err) {\n    91→      logger.error({ err }, 'Retention job failed — will retry next tick');\n    92→    } finally {\n    93→      running = false;\n    94→    }\n    95→  }\n    96→\n    97→  // First check shortly after startup, then every 60 seconds\n    98→  setTimeout(() => tick(), 5000);\n    99→\n   100→  return setInterval(() => {\n   101→    tick();\n   102→  }, SCHEDULE_CHECK_MS);\n   103→}\n   104→\n   105→async function runRetention(\n   106→  tenantDbManager: TenantDbManager,\n   107→  retentionDays: number,\n   108→  metricsRetentionDays: number,\n   109→  logger: Logger,\n   110→): Promise<void> {\n   111→  const cutoff = new Date(Date.now() - retentionDays * 86_400_000).toISOString();\n   112→  const stuckCutoff = new Date(Date.now() - retentionDays * 7 * 86_400_000).toISOString();\n   113→  const metricsCutoff = new Date(Date.now() - metricsRetentionDays * 86_400_000).toISOString().slice(0, 10);\n   114→\n   115→  const tenantIds = tenantDbManager.listTenantIds();\n   116→  for (const projectId of tenantIds) {\n   117→    try {\n   118→      const db = tenantDbManager.getTenantDb(projectId);\n   119→      const ctx = { projectId };\n   120→\n   121→      const purgedExecutions = await execPolicy.purge(db, cutoff, logger, ctx);\n   122→      const purgedEvents = await eventsPolicy.purge(db, cutoff, logger, ctx);\n   123→      const purgedStuckEvents = await stuckEventsPolicy.purge(db, stuckCutoff, logger, ctx);\n   124→\n   125→      const purgedMetrics = await dailyMetricsPolicy.purge(db, metricsCutoff, logger, ctx);\n   126→\n   127→      if (purgedExecutions > 0 || purgedEvents > 0 || purgedStuckEvents > 0 || purgedMetrics > 0) {\n   128→        logger.info({ projectId, purgedExecutions, purgedEvents, purgedStuckEvents, purgedMetrics }, 'Retention cleanup complete');\n   129→      }\n   130→    } catch (err) {\n   131→      logger.error({ err, projectId }, 'Retention cleanup failed for tenant');\n   132→    }\n   133→    // Yield between tenants so the event loop stays responsive\n   134→    await yieldTick();\n   135→  }\n   136→\n   137→  // ── Reduce phase: aggregate all tenant metrics into system.db ──\n   138→  try {\n   139→    aggregateSystemMetrics(tenantDbManager, logger);\n   140→  } catch (err) {\n   141→    logger.error({ err }, 'System-wide metrics aggregation failed');\n   142→  }\n   143→\n   144→  // ── Purge old system-wide metrics ──\n   145→  try {\n   146→    const purged = await systemDailyMetricsPolicy.purge(\n   147→      tenantDbManager.getSystemDb(), metricsCutoff, logger,\n   148→    );\n   149→    if (purged > 0) {\n   150→      logger.info({ purged }, 'Purged old system_daily_metrics rows');\n   151→    }\n   152→  } catch (err) {\n   153→    logger.error({ err }, 'system_daily_metrics purge failed');\n   154→  }\n   155→}\n   156→\n   157→/**\n   158→ * Map-reduce step: read daily_metrics from every tenant DB and write\n   159→ * a system-wide summary to the system_daily_metrics table in system.db.\n   160→ * Replaces rows wholesale each run so the system view is always consistent.\n   161→ */\n   162→function aggregateSystemMetrics(\n   163→  tenantDbManager: TenantDbManager,\n   164→  logger: Logger,\n   165→): void {\n   166→  const systemDb = tenantDbManager.getSystemDb();\n   167→  const tenantIds = tenantDbManager.listTenantIds();\n   168→\n   169→  // Accumulate per-day totals across all tenants\n   170→  const dayMap = new Map<string, {\n   171→    total_executions: number;\n   172→    completed: number;\n   173→    failed: number;\n   174→    total_cost_usd: number;\n   175→    total_duration_ms: number;\n   176→    tenant_count: number;\n   177→  }>();\n   178→\n   179→  for (const projectId of tenantIds) {\n   180→    try {\n   181→      const db = tenantDbManager.getTenantDb(projectId);\n   182→      const rows = db.prepare(\n   183→        'SELECT date, total_executions, completed, failed, total_cost_usd, total_duration_ms FROM daily_metrics',\n   184→      ).all() as Array<{\n   185→        date: string;\n   186→        total_executions: number;\n   187→        completed: number;\n   188→        failed: number;\n   189→        total_cost_usd: number;\n   190→        total_duration_ms: number;\n   191→      }>;\n   192→\n   193→      for (const row of rows) {\n   194→        const existing = dayMap.get(row.date);\n   195→        if (existing) {\n   196→          existing.total_executions += row.total_executions;\n   197→          existing.completed += row.completed;\n   198→          existing.failed += row.failed;\n   199→          existing.total_cost_usd += row.total_cost_usd;\n   200→          existing.total_duration_ms += row.total_duration_ms;\n   201→          existing.tenant_count += 1;\n   202→        } else {\n   203→          dayMap.set(row.date, {\n   204→            total_executions: row.total_executions,\n   205→            completed: row.completed,\n   206→            failed: row.failed,\n   207→            total_cost_usd: row.total_cost_usd,\n   208→            total_duration_ms: row.total_duration_ms,\n   209→            tenant_count: 1,\n   210→          });\n   211→        }\n   212→      }\n   213→    } catch (err) {\n   214→      logger.warn({ err, projectId }, 'Failed to read metrics for tenant during aggregation');\n   215→    }\n   216→  }\n   217→\n   218→  if (dayMap.size === 0) return;\n   219→\n   220→  // Write aggregated metrics in a single transaction\n   221→  const now = new Date().toISOString();\n   222→  systemDb.transaction(() => {\n   223→    const upsert = systemDb.prepare(`\n   224→      INSERT INTO system_daily_metrics\n   225→        (date, total_executions, completed, failed, total_cost_usd, total_duration_ms, tenant_count, aggregated_at)\n   226→      VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n   227→      ON CONFLICT(date) DO UPDATE SET\n   228→        total_executions = excluded.total_executions,\n   229→        completed = excluded.completed,\n   230→        failed = excluded.failed,\n   231→        total_cost_usd = excluded.total_cost_usd,\n   232→        total_duration_ms = excluded.total_duration_ms,\n   233→        tenant_count = excluded.tenant_count,\n   234→        aggregated_at = excluded.aggregated_at\n   235→    `);\n   236→    for (const [date, m] of dayMap) {\n   237→      upsert.run(date, m.total_executions, m.completed, m.failed, m.total_cost_usd, m.total_duration_ms, m.tenant_count, now);\n   238→    }\n   239→  })();\n   240→\n   241→  logger.info({ days: dayMap.size, tenants: tenantIds.length }, 'System-wide metrics aggregation complete');\n   242→}\n   243→"}]},"parent_tool_use_id":null,"session_id":"d67c851b-7b5f-4c98-8ae2-96df495f65de","uuid":"7726f266-7d71-431f-9e73-8a68621120f7","timestamp":"2026-03-19T08:31:20.412Z","tool_use_result":{"type":"text","file":{"filePath":"C:/Users/kazda/kiro/personas-cloud/packages/orchestrator/src/retention.ts","content":"import type Database from 'better-sqlite3';\nimport type { Logger } from 'pino';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport { RetentionPolicy } from './retentionPolicy.js';\n\n// ── Declarative retention policies for tenant tables ────────────────────\n// Each policy is parameterised by its TABLE_REGISTRY spec; the shared\n// RetentionPolicy class handles safety-fraction checks and chunked deletes.\n\nconst execPolicy = new RetentionPolicy({\n  table: 'persona_executions',\n  deleteFilter: \"status IN ('completed', 'failed', 'cancelled')\",\n});\n\nconst eventsPolicy = new RetentionPolicy({\n  table: 'persona_events',\n  deleteFilter: \"status NOT IN ('pending', 'processing', 'partial-retry')\",\n});\n\nconst stuckEventsPolicy = new RetentionPolicy({\n  table: 'persona_events',\n  deleteFilter: \"status IN ('pending', 'processing', 'partial-retry')\",\n});\n\nconst dailyMetricsPolicy = new RetentionPolicy({ table: 'daily_metrics' });\nconst systemDailyMetricsPolicy = new RetentionPolicy({ table: 'system_daily_metrics' });\n\n/** Yield the event loop so concurrent reads/writes can proceed between tenants. */\nfunction yieldTick(): Promise<void> {\n  return new Promise((resolve) => setImmediate(resolve));\n}\n\n/** How often we check whether it's time for the daily run (60 seconds). */\nconst SCHEDULE_CHECK_MS = 60_000;\n\n/** system_kv key used to persist the last successful run date (UTC). */\nconst LAST_RUN_KEY = 'retention_last_run_date';\n\n/** Return today's UTC date as YYYY-MM-DD. */\nfunction utcToday(): string {\n  return new Date().toISOString().slice(0, 10);\n}\n\n/** Read the last-run UTC date from system_kv, or null if never run. */\nfunction getLastRunDate(tenantDbManager: TenantDbManager): string | null {\n  const row = tenantDbManager.getSystemDb().prepare(\n    'SELECT value FROM system_kv WHERE key = ?',\n  ).get(LAST_RUN_KEY) as { value: string } | undefined;\n  return row?.value ?? null;\n}\n\n/** Persist the current UTC date as the last-run date. */\nfunction setLastRunDate(tenantDbManager: TenantDbManager, date: string): void {\n  tenantDbManager.getSystemDb().prepare(\n    'INSERT INTO system_kv (key, value) VALUES (?, ?) ON CONFLICT(key) DO UPDATE SET value = excluded.value',\n  ).run(LAST_RUN_KEY, date);\n}\n\n/**\n * Daily retention job: purge old executions/events and aggregate daily metrics.\n *\n * Uses a 60-second wall-clock poll instead of a drifting 24-hour setInterval.\n * The last successful run date is persisted in system_kv so the job runs\n * exactly once per UTC calendar day regardless of restarts or event-loop delays.\n */\nexport function startRetentionJob(\n  tenantDbManager: TenantDbManager,\n  retentionDays: number,\n  metricsRetentionDays: number,\n  logger: Logger,\n): NodeJS.Timeout {\n  logger.info({ retentionDays, metricsRetentionDays }, 'Retention job scheduled (wall-clock daily)');\n\n  let running = false;\n\n  async function tick(): Promise<void> {\n    if (running) return;\n\n    const today = utcToday();\n    const lastRun = getLastRunDate(tenantDbManager);\n\n    if (lastRun === today) return; // already ran today\n\n    running = true;\n    logger.info({ today, lastRun }, 'Retention job triggered');\n    try {\n      await runRetention(tenantDbManager, retentionDays, metricsRetentionDays, logger);\n      setLastRunDate(tenantDbManager, today);\n      logger.info({ today }, 'Retention job completed, next run tomorrow');\n    } catch (err) {\n      logger.error({ err }, 'Retention job failed — will retry next tick');\n    } finally {\n      running = false;\n    }\n  }\n\n  // First check shortly after startup, then every 60 seconds\n  setTimeout(() => tick(), 5000);\n\n  return setInterval(() => {\n    tick();\n  }, SCHEDULE_CHECK_MS);\n}\n\nasync function runRetention(\n  tenantDbManager: TenantDbManager,\n  retentionDays: number,\n  metricsRetentionDays: number,\n  logger: Logger,\n): Promise<void> {\n  const cutoff = new Date(Date.now() - retentionDays * 86_400_000).toISOString();\n  const stuckCutoff = new Date(Date.now() - retentionDays * 7 * 86_400_000).toISOString();\n  const metricsCutoff = new Date(Date.now() - metricsRetentionDays * 86_400_000).toISOString().slice(0, 10);\n\n  const tenantIds = tenantDbManager.listTenantIds();\n  for (const projectId of tenantIds) {\n    try {\n      const db = tenantDbManager.getTenantDb(projectId);\n      const ctx = { projectId };\n\n      const purgedExecutions = await execPolicy.purge(db, cutoff, logger, ctx);\n      const purgedEvents = await eventsPolicy.purge(db, cutoff, logger, ctx);\n      const purgedStuckEvents = await stuckEventsPolicy.purge(db, stuckCutoff, logger, ctx);\n\n      const purgedMetrics = await dailyMetricsPolicy.purge(db, metricsCutoff, logger, ctx);\n\n      if (purgedExecutions > 0 || purgedEvents > 0 || purgedStuckEvents > 0 || purgedMetrics > 0) {\n        logger.info({ projectId, purgedExecutions, purgedEvents, purgedStuckEvents, purgedMetrics }, 'Retention cleanup complete');\n      }\n    } catch (err) {\n      logger.error({ err, projectId }, 'Retention cleanup failed for tenant');\n    }\n    // Yield between tenants so the event loop stays responsive\n    await yieldTick();\n  }\n\n  // ── Reduce phase: aggregate all tenant metrics into system.db ──\n  try {\n    aggregateSystemMetrics(tenantDbManager, logger);\n  } catch (err) {\n    logger.error({ err }, 'System-wide metrics aggregation failed');\n  }\n\n  // ── Purge old system-wide metrics ──\n  try {\n    const purged = await systemDailyMetricsPolicy.purge(\n      tenantDbManager.getSystemDb(), metricsCutoff, logger,\n    );\n    if (purged > 0) {\n      logger.info({ purged }, 'Purged old system_daily_metrics rows');\n    }\n  } catch (err) {\n    logger.error({ err }, 'system_daily_metrics purge failed');\n  }\n}\n\n/**\n * Map-reduce step: read daily_metrics from every tenant DB and write\n * a system-wide summary to the system_daily_metrics table in system.db.\n * Replaces rows wholesale each run so the system view is always consistent.\n */\nfunction aggregateSystemMetrics(\n  tenantDbManager: TenantDbManager,\n  logger: Logger,\n): void {\n  const systemDb = tenantDbManager.getSystemDb();\n  const tenantIds = tenantDbManager.listTenantIds();\n\n  // Accumulate per-day totals across all tenants\n  const dayMap = new Map<string, {\n    total_executions: number;\n    completed: number;\n    failed: number;\n    total_cost_usd: number;\n    total_duration_ms: number;\n    tenant_count: number;\n  }>();\n\n  for (const projectId of tenantIds) {\n    try {\n      const db = tenantDbManager.getTenantDb(projectId);\n      const rows = db.prepare(\n        'SELECT date, total_executions, completed, failed, total_cost_usd, total_duration_ms FROM daily_metrics',\n      ).all() as Array<{\n        date: string;\n        total_executions: number;\n        completed: number;\n        failed: number;\n        total_cost_usd: number;\n        total_duration_ms: number;\n      }>;\n\n      for (const row of rows) {\n        const existing = dayMap.get(row.date);\n        if (existing) {\n          existing.total_executions += row.total_executions;\n          existing.completed += row.completed;\n          existing.failed += row.failed;\n          existing.total_cost_usd += row.total_cost_usd;\n          existing.total_duration_ms += row.total_duration_ms;\n          existing.tenant_count += 1;\n        } else {\n          dayMap.set(row.date, {\n            total_executions: row.total_executions,\n            completed: row.completed,\n            failed: row.failed,\n            total_cost_usd: row.total_cost_usd,\n            total_duration_ms: row.total_duration_ms,\n            tenant_count: 1,\n          });\n        }\n      }\n    } catch (err) {\n      logger.warn({ err, projectId }, 'Failed to read metrics for tenant during aggregation');\n    }\n  }\n\n  if (dayMap.size === 0) return;\n\n  // Write aggregated metrics in a single transaction\n  const now = new Date().toISOString();\n  systemDb.transaction(() => {\n    const upsert = systemDb.prepare(`\n      INSERT INTO system_daily_metrics\n        (date, total_executions, completed, failed, total_cost_usd, total_duration_ms, tenant_count, aggregated_at)\n      VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n      ON CONFLICT(date) DO UPDATE SET\n        total_executions = excluded.total_executions,\n        completed = excluded.completed,\n        failed = excluded.failed,\n        total_cost_usd = excluded.total_cost_usd,\n        total_duration_ms = excluded.total_duration_ms,\n        tenant_count = excluded.tenant_count,\n        aggregated_at = excluded.aggregated_at\n    `);\n    for (const [date, m] of dayMap) {\n      upsert.run(date, m.total_executions, m.completed, m.failed, m.total_cost_usd, m.total_duration_ms, m.tenant_count, now);\n    }\n  })();\n\n  logger.info({ days: dayMap.size, tenants: tenantIds.length }, 'System-wide metrics aggregation complete');\n}\n","numLines":243,"startLine":1,"totalLines":243}}}
