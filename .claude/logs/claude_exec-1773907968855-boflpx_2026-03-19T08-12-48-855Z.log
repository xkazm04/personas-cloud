OT EXISTS daily_metrics (\n    55→  date TEXT NOT NULL,\n    56→  total_executions INTEGER DEFAULT 0,\n    57→  completed INTEGER DEFAULT 0,\n    58→  failed INTEGER DEFAULT 0,\n    59→  total_cost_usd REAL DEFAULT 0,\n    60→  total_duration_ms INTEGER DEFAULT 0,\n    61→  PRIMARY KEY (date)\n    62→);\n    63→\n    64→CREATE TABLE IF NOT EXISTS retention_watermark (\n    65→  key TEXT PRIMARY KEY DEFAULT 'executions',\n    66→  last_rowid INTEGER NOT NULL DEFAULT 0\n    67→);\n    68→`;\n    69→\n    70→// ---------------------------------------------------------------------------\n    71→// Shared entity tables (used by both legacy single-db and per-tenant dbs)\n    72→// ---------------------------------------------------------------------------\n    73→\n    74→const SHARED_TABLES = `\n    75→CREATE TABLE IF NOT EXISTS personas (\n    76→  id TEXT PRIMARY KEY,\n    77→  project_id TEXT NOT NULL DEFAULT 'default',\n    78→  name TEXT NOT NULL,\n    79→  description TEXT,\n    80→  system_prompt TEXT NOT NULL DEFAULT '',\n    81→  structured_prompt TEXT,\n    82→  icon TEXT,\n    83→  color TEXT,\n    84→  enabled INTEGER NOT NULL DEFAULT 1,\n    85→  max_concurrent INTEGER NOT NULL DEFAULT 1,\n    86→  timeout_ms INTEGER NOT NULL DEFAULT 300000,\n    87→  inference_profile_id TEXT,\n    88→  network_policy TEXT,\n    89→  max_budget_usd REAL,\n    90→  max_turns INTEGER,\n    91→  design_context TEXT,\n    92→  group_id TEXT,\n    93→  created_at TEXT NOT NULL,\n    94→  updated_at TEXT NOT NULL\n    95→);\n    96→\n    97→CREATE TABLE IF NOT EXISTS persona_tool_definitions (\n    98→  id TEXT PRIMARY KEY,\n    99→  name TEXT NOT NULL UNIQUE,\n   100→  category TEXT NOT NULL,\n   101→  description TEXT NOT NULL,\n   102→  script_path TEXT NOT NULL DEFAULT '',\n   103→  input_schema TEXT,\n   104→  output_schema TEXT,\n   105→  requires_credential_type TEXT,\n   106→  implementation_guide TEXT,\n   107→  is_builtin INTEGER NOT NULL DEFAULT 0,\n   108→  created_at