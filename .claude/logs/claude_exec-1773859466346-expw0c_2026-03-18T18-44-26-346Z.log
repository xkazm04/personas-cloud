[2026-03-18T18:44:58.687Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HXMzBkbH2Mk6KbCN3ydbYj","type":"tool_result","content":"     1→import crypto from 'node:crypto';\n     2→import Database from 'better-sqlite3';\n     3→import type { Logger } from 'pino';\n     4→\n     5→/** SHA-256 hash chain genesis value (64 hex zeros). */\n     6→const GENESIS_HASH = '0'.repeat(64);\n     7→\n     8→/**\n     9→ * Compute a chain hash: SHA-256(previousHash + deterministic JSON of entry fields).\n    10→ * Each entry's hash commits to the entire chain history before it.\n    11→ */\n    12→function computeChainHash(prevHash: string, entry: BufferedEntry): string {\n    13→  const payload = prevHash + JSON.stringify([\n    14→    entry.timestamp,\n    15→    entry.action,\n    16→    entry.tenantId,\n    17→    entry.actor,\n    18→    entry.resourceType,\n    19→    entry.resourceId,\n    20→    entry.detail,\n    21→    entry.ipAddress,\n    22→  ]);\n    23→  return crypto.createHash('sha256').update(payload).digest('hex');\n    24→}\n    25→\n    26→const AUDIT_SCHEMA = `\n    27→CREATE TABLE IF NOT EXISTS audit_events (\n    28→  id INTEGER PRIMARY KEY AUTOINCREMENT,\n    29→  timestamp TEXT NOT NULL,\n    30→  action TEXT NOT NULL,\n    31→  tenant_id TEXT,\n    32→  actor TEXT,\n    33→  resource_type TEXT,\n    34→  resource_id TEXT,\n    35→  detail TEXT,\n    36→  ip_address TEXT,\n    37→  prev_hash TEXT\n    38→);\n    39→CREATE INDEX IF NOT EXISTS idx_audit_ts ON audit_events(timestamp);\n    40→CREATE INDEX IF NOT EXISTS idx_audit_tenant_action_ts ON audit_events(tenant_id, action, timestamp);\n    41→CREATE INDEX IF NOT EXISTS idx_audit_actor ON audit_events(actor);\n    42→CREATE INDEX IF NOT EXISTS idx_audit_resource_type ON audit_events(resource_type);\n    43→DROP INDEX IF EXISTS idx_audit_tenant_ts;\n    44→DROP INDEX IF EXISTS idx_audit_action;\n    45→`;\n    46→\n    47→/** Thrown when an audit event fails to persist — signals an audit trail gap. */\n    48→export class AuditWriteError extends Error {\n    49→  constructor(\n    50→    public readonly entry: AuditEntry,\n    51→    cause: unknown,\n    52→  ) {\n    53→    super(`Audit write failed for action \"${entry.action}\"`);\n    54→    this.name = 'AuditWriteError';\n    55→    this.cause = cause;\n    56→  }\n    57→}\n    58→\n    59→// ---------------------------------------------------------------------------\n    60→// Discriminated-union audit entries — each action carries its own typed payload\n    61→// ---------------------------------------------------------------------------\n    62→\n    63→/** Fields common to every audit entry. */\n    64→interface AuditEntryBase {\n    65→  tenantId?: string;\n    66→  actor?: string;\n    67→  ipAddress?: string;\n    68→}\n    69→\n    70→// --- Key management ---\n    71→interface KeyEncryptEntry extends AuditEntryBase {\n    72→  action: 'key:encrypt';\n    73→  resourceType: 'credential';\n    74→  resourceId: string;\n    75→}\n    76→\n    77→interface KeyDecryptEntry extends AuditEntryBase {\n    78→  action: 'key:decrypt';\n    79→  resourceType: 'credential';\n    80→  resourceId: string;\n    81→}\n    82→\n    83→interface KeyDecryptFailedEntry extends AuditEntryBase {\n    84→  action: 'key:decrypt_failed';\n    85→  resourceType: 'credential';\n    86→  resourceId: string;\n    87→  detail: { reason: string };\n    88→}\n    89→\n    90→interface KeyDeleteEntry extends AuditEntryBase {\n    91→  action: 'key:delete';\n    92→  resourceType: 'credential';\n    93→  resourceId: string;\n    94→}\n    95→\n    96→interface KeyAccessEntry extends AuditEntryBase {\n    97→  action: 'key:access';\n    98→  resourceType: 'credential';\n    99→  resourceId: string;\n   100→}\n   101→\n   102→interface KeyDeriveEntry extends AuditEntryBase {\n   103→  action: 'key:derive';\n   104→}\n   105→\n   106→// --- Persona management ---\n   107→interface PersonaCreateEntry extends AuditEntryBase {\n   108→  action: 'persona:create';\n   109→  resourceType: 'persona';\n   110→  resourceId: string;\n   111→}\n   112→\n   113→interface PersonaDeleteEntry extends AuditEntryBase {\n   114→  action: 'persona:delete';\n   115→  resourceType: 'persona';\n   116→  resourceId: string;\n   117→}\n   118→\n   119→// --- Tool management ---\n   120→interface ToolLinkEntry extends AuditEntryBase {\n   121→  action: 'tool:link';\n   122→  resourceType: 'persona';\n   123→  resourceId: string;\n   124→  detail: { toolId: string };\n   125→}\n   126→\n   127→interface ToolDefinitionCreateEntry extends AuditEntryBase {\n   128→  action: 'tool-definition:create';\n   129→  resourceType: 'toolDefinition';\n   130→  resourceId: string;\n   131→}\n   132→\n   133→// --- Credential linking ---\n   134→interface CredentialLinkEntry extends AuditEntryBase {\n   135→  action: 'credential:link';\n   136→  resourceType: 'persona';\n   137→  resourceId: string;\n   138→  detail: { credentialId: string };\n   139→}\n   140→\n   141→// --- Subscriptions ---\n   142→interface SubscriptionCreateEntry extends AuditEntryBase {\n   143→  action: 'subscription:create';\n   144→  resourceType: 'subscription';\n   145→  resourceId: string;\n   146→  detail: { personaId: string; eventType: string };\n   147→}\n   148→\n   149→interface SubscriptionUpdateEntry extends AuditEntryBase {\n   150→  action: 'subscription:update';\n   151→  resourceType: 'subscription';\n   152→  resourceId: string;\n   153→}\n   154→\n   155→interface SubscriptionDeleteEntry extends AuditEntryBase {\n   156→  action: 'subscription:delete';\n   157→  resourceType: 'subscription';\n   158→  resourceId: string;\n   159→}\n   160→\n   161→// --- Worker pool ---\n   162→interface WorkerConnectedEntry extends AuditEntryBase {\n   163→  action: 'worker:connected';\n   164→  detail: { workerId: string };\n   165→}\n   166→\n   167→interface WorkerDisconnectedEntry extends AuditEntryBase {\n   168→  action: 'worker:disconnected';\n   169→  detail: { workerId: string };\n   170→  resourceId?: string;\n   171→}\n   172→\n   173→// --- Triggers ---\n   174→interface TriggerCreateEntry extends AuditEntryBase {\n   175→  action: 'trigger:create';\n   176→  resourceType: 'trigger';\n   177→  resourceId?: string;\n   178→}\n   179→\n   180→interface TriggerUpdateEntry extends AuditEntryBase {\n   181→  action: 'trigger:update';\n   182→  resourceType: 'trigger';\n   183→  resourceId: string;\n   184→}\n   185→\n   186→interface TriggerDeleteEntry extends AuditEntryBase {\n   187→  action: 'trigger:delete';\n   188→  resourceType: 'trigger';\n   189→  resourceId: string;\n   190→}\n   191→\n   192→// --- Events ---\n   193→interface EventPublishEntry extends AuditEntryBase {\n   194→  action: 'event:publish';\n   195→  resourceType: 'event';\n   196→  resourceId?: string;\n   197→}\n   198→\n   199→interface EventUpdateEntry extends AuditEntryBase {\n   200→  action: 'event:update';\n   201→  resourceType: 'event';\n   202→  resourceId: string;\n   203→}\n   204→\n   205→// --- Executions ---\n   206→interface ExecutionSubmitEntry extends AuditEntryBase {\n   207→  action: 'execution:submit';\n   208→  resourceType: 'execution';\n   209→  resourceId?: string;\n   210→}\n   211→\n   212→// --- Webhooks ---\n   213→interface WebhookReceiveEntry extends AuditEntryBase {\n   214→  action: 'webhook:receive';\n   215→  resourceType: 'webhook';\n   216→  resourceId: string;\n   217→}\n   218→\n   219→// --- OAuth lifecycle ---\n   220→interface OAuthAuthorizeEntry extends AuditEntryBase {\n   221→  action: 'oauth:authorize';\n   222→  resourceType: 'oauth';\n   223→  resourceId: string; // state parameter\n   224→}\n   225→\n   226→interface OAuthExchangeEntry extends AuditEntryBase {\n   227→  action: 'oauth:exchange';\n   228→  resourceType: 'oauth';\n   229→  detail: { scopes: string[]; expiresAt: string };\n   230→}\n   231→\n   232→interface OAuthRefreshEntry extends AuditEntryBase {\n   233→  action: 'oauth:refresh';\n   234→  resourceType: 'oauth';\n   235→  detail: { expiresAt: string };\n   236→}\n   237→\n   238→interface OAuthRefreshFailedEntry extends AuditEntryBase {\n   239→  action: 'oauth:refresh_failed';\n   240→  resourceType: 'oauth';\n   241→  detail: { reason: string };\n   242→}\n   243→\n   244→interface OAuthDisconnectEntry extends AuditEntryBase {\n   245→  action: 'oauth:disconnect';\n   246→  resourceType: 'oauth';\n   247→  detail: { serverRevoked: boolean };\n   248→}\n   249→\n   250→// --- Token lifecycle ---\n   251→interface TokenInjectEntry extends AuditEntryBase {\n   252→  action: 'token:inject';\n   253→  resourceType: 'token';\n   254→}\n   255→\n   256→interface TokenExpiringSoonEntry extends AuditEntryBase {\n   257→  action: 'token:expiring_soon';\n   258→  resourceType: 'oauth';\n   259→  detail: { expiresAt: string; remainingMinutes: number };\n   260→}\n   261→\n   262→/** Discriminated union of all audit event types. */\n   263→export type AuditEntry =\n   264→  | KeyEncryptEntry\n   265→  | KeyDecryptEntry\n   266→  | KeyDecryptFailedEntry\n   267→  | KeyDeleteEntry\n   268→  | KeyAccessEntry\n   269→  | KeyDeriveEntry\n   270→  | PersonaCreateEntry\n   271→  | PersonaDeleteEntry\n   272→  | ToolLinkEntry\n   273→  | ToolDefinitionCreateEntry\n   274→  | CredentialLinkEntry\n   275→  | SubscriptionCreateEntry\n   276→  | SubscriptionUpdateEntry\n   277→  | SubscriptionDeleteEntry\n   278→  | WorkerConnectedEntry\n   279→  | WorkerDisconnectedEntry\n   280→  | TriggerCreateEntry\n   281→  | TriggerUpdateEntry\n   282→  | TriggerDeleteEntry\n   283→  | EventPublishEntry\n   284→  | EventUpdateEntry\n   285→  | ExecutionSubmitEntry\n   286→  | WebhookReceiveEntry\n   287→  | OAuthAuthorizeEntry\n   288→  | OAuthExchangeEntry\n   289→  | OAuthRefreshEntry\n   290→  | OAuthRefreshFailedEntry\n   291→  | OAuthDisconnectEntry\n   292→  | TokenInjectEntry\n   293→  | TokenExpiringSoonEntry;\n   294→\n   295→/** String-literal union of all valid audit actions. */\n   296→export type AuditAction = AuditEntry['action'];\n   297→\n   298→/** Row shape returned by audit_events queries. */\n   299→export interface AuditEvent {\n   300→  id: number;\n   301→  timestamp: string;\n   302→  action: string;\n   303→  tenant_id: string | null;\n   304→  actor: string | null;\n   305→  resource_type: string | null;\n   306→  resource_id: string | null;\n   307→  detail: string | null;\n   308→  ip_address: string | null;\n   309→  prev_hash: string | null;\n   310→}\n   311→\n   312→/** Result of verifying the audit hash chain. */\n   313→export interface ChainVerifyResult {\n   314→  valid: boolean;\n   315→  verifiedCount: number;\n   316→  brokenAtId?: number;\n   317→}\n   318→\n   319→/** Max entries buffered before an automatic flush. */\n   320→const BUFFER_FLUSH_SIZE = 50;\n   321→/** Interval (ms) between timer-based flushes. */\n   322→const BUFFER_FLUSH_INTERVAL_MS = 100;\n   323→\n   324→interface BufferedEntry {\n   325→  timestamp: string;\n   326→  action: string;\n   327→  tenantId: string | null;\n   328→  actor: string | null;\n   329→  resourceType: string | null;\n   330→  resourceId: string | null;\n   331→  detail: string | null;\n   332→  ipAddress: string | null;\n   333→}\n   334→\n   335→export class AuditLog {\n   336→  private db: Database.Database;\n   337→  private insertStmt: Database.Statement;\n   338→  private queryStmtCache = new Map<string, Database.Statement>();\n   339→  private buffer: BufferedEntry[] = [];\n   340→  private flushTimer: NodeJS.Timeout | null = null;\n   341→  private batchInsert: (entries: BufferedEntry[], hashes: string[]) => void;\n   342→  private lastHash: string;\n   343→\n   344→  constructor(\n   345→    dbPath: string,\n   346→    private logger: Logger,\n   347→  ) {\n   348→    this.db = new Database(dbPath);\n   349→    this.db.pragma('journal_mode = WAL');\n   350→    this.db.exec(AUDIT_SCHEMA);\n   351→\n   352→    // Migration: add prev_hash column to existing databases that lack it\n   353→    const cols = this.db.pragma('table_info(audit_events)') as { name: string }[];\n   354→    if (!cols.some((c) => c.name === 'prev_hash')) {\n   355→      this.db.exec('ALTER TABLE audit_events ADD COLUMN prev_hash TEXT');\n   356→    }\n   357→\n   358→    this.insertStmt = this.db.prepare(\n   359→      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address, prev_hash) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)',\n   360→    );\n   361→\n   362→    // Initialize chain from last stored hash (or genesis for empty / pre-chain DBs)\n   363→    const lastRow = this.db.prepare(\n   364→      'SELECT prev_hash FROM audit_events WHERE prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n   365→    ).get() as { prev_hash: string } | undefined;\n   366→    this.lastHash = lastRow?.prev_hash ?? GENESIS_HASH;\n   367→\n   368→    // Wrap N inserts in a single transaction — one fsync instead of N\n   369→    const stmt = this.insertStmt;\n   370→    this.batchInsert = this.db.transaction((entries: BufferedEntry[], hashes: string[]) => {\n   371→      for (let i = 0; i < entries.length; i++) {\n   372→        const e = entries[i];\n   373→        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress, hashes[i]);\n   374→      }\n   375→    });\n   376→\n   377→    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n   378→\n   379→    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled, hash-chain active)');\n   380→  }\n   381→\n   382→  /** Expose the underlying database for use by RetentionPolicy. */\n   383→  getDb(): Database.Database {\n   384→    return this.db;\n   385→  }\n   386→\n   387→  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n   388→  countEvents(before?: string): number {\n   389→    const stmt = before\n   390→      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n   391→      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n   392→    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n   393→    return row.cnt;\n   394→  }\n   395→\n   396→  /**\n   397→   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   398→   * yielding the event loop between batches so concurrent DB operations\n   399→   * are not starved during large purges.\n   400→   */\n   401→  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n   402→    const deleteChunk = this.db.prepare(\n   403→      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n   404→    );\n   405→    let totalDeleted = 0;\n   406→    while (true) {\n   407→      const result = deleteChunk.run(cutoff, chunkSize);\n   408→      totalDeleted += result.changes;\n   409→      if (result.changes < chunkSize) break;\n   410→      await new Promise<void>((resolve) => setImmediate(resolve));\n   411→    }\n   412→    return totalDeleted;\n   413→  }\n   414→\n   415→  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n   416→  record(entry: AuditEntry): void {\n   417→    this.buffer.push({\n   418→      timestamp: new Date().toISOString(),\n   419→      action: entry.action,\n   420→      tenantId: entry.tenantId ?? null,\n   421→      actor: entry.actor ?? null,\n   422→      resourceType: 'resourceType' in entry ? entry.resourceType : null,\n   423→      resourceId: 'resourceId' in entry ? (entry.resourceId ?? null) : null,\n   424→      detail: 'detail' in entry ? JSON.stringify(entry.detail) : null,\n   425→      ipAddress: entry.ipAddress ?? null,\n   426→    });\n   427→    if (this.buffer.length >= BUFFER_FLUSH_SIZE) {\n   428→      this.flush();\n   429→    }\n   430→  }\n   431→\n   432→  /** Flush buffered entries to SQLite in a single transaction, computing chain hashes. */\n   433→  flush(): void {\n   434→    if (this.buffer.length === 0) return;\n   435→    const batch = this.buffer;\n   436→    this.buffer = [];\n   437→\n   438→    // Compute chain hashes for the batch\n   439→    const hashes: string[] = [];\n   440→    let prevHash = this.lastHash;\n   441→    for (const entry of batch) {\n   442→      prevHash = computeChainHash(prevHash, entry);\n   443→      hashes.push(prevHash);\n   444→    }\n   445→\n   446→    try {\n   447→      this.batchInsert(batch, hashes);\n   448→      this.lastHash = prevHash;\n   449→    } catch (err) {\n   450→      this.logger.error({ err, count: batch.length }, 'Audit batch write failed — audit trail gap');\n   451→    }\n   452→  }\n   453→\n   454→  /** Aggregated audit event statistics for dashboard consumption. */\n   455→  stats(opts?: {\n   456→    tenantId?: string;\n   457→    since?: string;\n   458→    until?: string;\n   459→    bucket?: 'hour' | 'day';\n   460→  }): {\n   461→    byAction: { action: string; count: number }[];\n   462→    byTenant: { tenant_id: string; count: number }[];\n   463→    topActors: { actor: string; count: number }[];\n   464→    trend: { bucket: string; count: number }[];\n   465→  } {\n   466→    this.flush(); // ensure buffered entries are visible\n   467→\n   468→    const params: unknown[] = [];\n   469→    const clauses: string[] = [];\n   470→    if (opts?.tenantId) { clauses.push('tenant_id = ?'); params.push(opts.tenantId); }\n   471→    if (opts?.since) { clauses.push('timestamp >= ?'); params.push(opts.since); }\n   472→    if (opts?.until) { clauses.push('timestamp < ?'); params.push(opts.until); }\n   473→    const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   474→\n   475→    const bucketExpr = opts?.bucket === 'hour'\n   476→      ? \"substr(timestamp, 1, 13)\"  // YYYY-MM-DDTHH\n   477→      : \"substr(timestamp, 1, 10)\"; // YYYY-MM-DD\n   478→\n   479→    const byAction = this.db.prepare(\n   480→      `SELECT action, COUNT(*) as count FROM audit_events ${where} GROUP BY action ORDER BY count DESC`,\n   481→    ).all(...params) as { action: string; count: number }[];\n   482→\n   483→    const byTenant = this.db.prepare(\n   484→      `SELECT COALESCE(tenant_id, '__none__') as tenant_id, COUNT(*) as count FROM audit_events ${where} GROUP BY tenant_id ORDER BY count DESC LIMIT 50`,\n   485→    ).all(...params) as { tenant_id: string; count: number }[];\n   486→\n   487→    const topActors = this.db.prepare(\n   488→      `SELECT COALESCE(actor, '__none__') as actor, COUNT(*) as count FROM audit_events ${where} GROUP BY actor ORDER BY count DESC LIMIT 20`,\n   489→    ).all(...params) as { actor: string; count: number }[];\n   490→\n   491→    const trend = this.db.prepare(\n   492→      `SELECT ${bucketExpr} as bucket, COUNT(*) as count FROM audit_events ${where} GROUP BY bucket ORDER BY bucket ASC`,\n   493→    ).all(...params) as { bucket: string; count: number }[];\n   494→\n   495→    return { byAction, byTenant, topActors, trend };\n   496→  }\n   497→\n   498→  /** Query audit events with optional filters. */\n   499→  query(opts?: {\n   500→    tenantId?: string;\n   501→    action?: AuditAction;\n   502→    since?: string;\n   503→    until?: string;\n   504→    actor?: string;\n   505→    resourceType?: string;\n   506→    resourceId?: string;\n   507→    limit?: number;\n   508→    offset?: number;\n   509→  }): AuditEvent[] {\n   510→    const params: unknown[] = [];\n   511→    const clauses: string[] = [];\n   512→    const keyParts: string[] = [];\n   513→\n   514→    if (opts?.tenantId) { clauses.push('tenant_id = ?'); keyParts.push('tenant'); params.push(opts.tenantId); }\n   515→    if (opts?.action) { clauses.push('action = ?'); keyParts.push('action'); params.push(opts.action); }\n   516→    if (opts?.since) { clauses.push('timestamp >= ?'); keyParts.push('since'); params.push(opts.since); }\n   517→    if (opts?.until) { clauses.push('timestamp <= ?'); keyParts.push('until'); params.push(opts.until); }\n   518→    if (opts?.actor) { clauses.push('actor = ?'); keyParts.push('actor'); params.push(opts.actor); }\n   519→    if (opts?.resourceType) { clauses.push('resource_type = ?'); keyParts.push('rtype'); params.push(opts.resourceType); }\n   520→    if (opts?.resourceId) { clauses.push('resource_id = ?'); keyParts.push('rid'); params.push(opts.resourceId); }\n   521→\n   522→    const key = keyParts.join('-') || 'none';\n   523→    let stmt = this.queryStmtCache.get(key);\n   524→    if (!stmt) {\n   525→      const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   526→      stmt = this.db.prepare(\n   527→        `SELECT * FROM audit_events ${where} ORDER BY id DESC LIMIT ? OFFSET ?`,\n   528→      );\n   529→      this.queryStmtCache.set(key, stmt);\n   530→    }\n   531→\n   532→    const limit = opts?.limit ?? 100;\n   533→    const offset = opts?.offset ?? 0;\n   534→\n   535→    return stmt.all(...params, limit, offset) as AuditEvent[];\n   536→  }\n   537→\n   538→  /**\n   539→   * Verify the integrity of the audit hash chain.\n   540→   * Iterates all chained rows and checks that each hash is consistent with\n   541→   * its predecessor. Pre-chain rows (migrated without prev_hash) are skipped.\n   542→   * If rows were purged, the chain will break at the first remaining row\n   543→   * — this is by design (deletions are detectable).\n   544→   *\n   545→   * When `since`/`until` are provided, only rows within that timestamp range\n   546→   * are checked. The initial previous-hash is seeded from the last chained\n   547→   * row before the range (or genesis if none exists).\n   548→   */\n   549→  verify(opts?: { since?: string; until?: string }): ChainVerifyResult {\n   550→    this.flush(); // ensure all buffered entries are persisted\n   551→\n   552→    const hasRange = opts?.since || opts?.until;\n   553→    const clauses: string[] = [];\n   554→    const params: unknown[] = [];\n   555→    if (opts?.since) { clauses.push('timestamp >= ?'); params.push(opts.since); }\n   556→    if (opts?.until) { clauses.push('timestamp < ?'); params.push(opts.until); }\n   557→    const where = clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '';\n   558→\n   559→    const iter = this.db.prepare(\n   560→      `SELECT * FROM audit_events ${where} ORDER BY id ASC`,\n   561→    ).iterate(...params);\n   562→\n   563→    // Seed the previous hash: for ranged queries, look up the last chained\n   564→    // row before the first matching row; for full scans use genesis.\n   565→    let prevHash = GENESIS_HASH;\n   566→    let seeded = !hasRange; // full scan is pre-seeded with genesis\n   567→\n   568→    let verifiedCount = 0;\n   569→\n   570→    for (const raw of iter) {\n   571→      const row = raw as AuditEvent;\n   572→      if (row.prev_hash === null) continue; // pre-chain row\n   573→\n   574→      // Lazily seed prevHash on the first chained row of a ranged query\n   575→      if (!seeded) {\n   576→        const prev = this.db.prepare(\n   577→          'SELECT prev_hash FROM audit_events WHERE id < ? AND prev_hash IS NOT NULL ORDER BY id DESC LIMIT 1',\n   578→        ).get(row.id) as { prev_hash: string } | undefined;\n   579→        prevHash = prev?.prev_hash ?? GENESIS_HASH;\n   580→        seeded = true;\n   581→      }\n   582→\n   583→      const expected = computeChainHash(prevHash, {\n   584→        timestamp: row.timestamp,\n   585→        action: row.action,\n   586→        tenantId: row.tenant_id,\n   587→        actor: row.actor,\n   588→        resourceType: row.resource_type,\n   589→        resourceId: row.resource_id,\n   590→        detail: row.detail,\n   591→        ipAddress: row.ip_address,\n   592→      });\n   593→\n   594→      if (row.prev_hash !== expected) {\n   595→        return { valid: false, verifiedCount, brokenAtId: row.id };\n   596→      }\n   597→\n   598→      prevHash = row.prev_hash;\n   599→      verifiedCount++;\n   600→    }\n   601→\n   602→    return { valid: true, verifiedCount };\n   603→  }\n   604→\n   605→  close(): void {\n   606→    if (this.flushTimer) {\n   607→      clearInterval(this.flushTimer);\n   608→      this.flushTimer = null;\n   609→    }\n   610→    this.flush();\n   611→    try { this.db.close(); } catch { /* best effort */ }\n   612→  }\n   613→}\n   614→"}]},"parent_tool_use_id":"toolu_019rNayeDQiCV4g9yReh3JfL","session_id":"9fe338af-0a15-4609-9054-9655c25cf426","uuid":"ec1b6d08-cd88-4be3-afe3-326e8704741a","timestamp":"2026-03-18T18:44:58.550Z"}
