[2026-03-18T18:44:56.410Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DjczptDQc4fWAABAZhycWu","type":"tool_result","content":"     1→// ============================================================\n     2→// dac-wire: WebSocket protocol between orchestrator and workers\n     3→// ============================================================\n     4→\n     5→import type { ProtocolEventType } from './protocolRegistry.js';\n     6→\n     7→// --- Worker → Orchestrator ---\n     8→\n     9→export interface WorkerHello {\n    10→  type: 'hello';\n    11→  workerId: string;\n    12→  version: string;\n    13→  capabilities: string[];\n    14→  imageDigest?: string;\n    15→  claudeCliVersion?: string;\n    16→}\n    17→\n    18→export interface WorkerReady {\n    19→  type: 'ready';\n    20→}\n    21→\n    22→export interface ExecStdout {\n    23→  type: 'stdout';\n    24→  executionId: string;\n    25→  chunk: string;\n    26→  timestamp: number;\n    27→}\n    28→\n    29→export interface ExecStderr {\n    30→  type: 'stderr';\n    31→  executionId: string;\n    32→  chunk: string;\n    33→  timestamp: number;\n    34→}\n    35→\n    36→export interface PhaseTimings {\n    37→  sandboxSetupMs: number;\n    38→  credentialInjectionMs: number;\n    39→  proxyStartupMs: number | null;\n    40→  cliRuntimeMs: number;\n    41→  cleanupMs: number;\n    42→}\n    43→\n    44→export interface ExecComplete {\n    45→  type: 'complete';\n    46→  executionId: string;\n    47→  status: 'completed' | 'failed' | 'cancelled';\n    48→  exitCode: number;\n    49→  durationMs: number;\n    50→  sessionId?: string;\n    51→  totalCostUsd?: number;\n    52→  phaseTimings?: PhaseTimings;\n    53→}\n    54→\n    55→export interface WorkerEvent {\n    56→  type: 'event';\n    57→  executionId: string;\n    58→  eventType: ProtocolEventType;\n    59→  payload: unknown;\n    60→}\n    61→\n    62→export interface ExecProgress {\n    63→  type: 'progress';\n    64→  executionId: string;\n    65→  phase: string;\n    66→  percent: number;\n    67→  detail?: string;\n    68→  timestamp: number;\n    69→}\n    70→\n    71→export interface WorkerHeartbeat {\n    72→  type: 'heartbeat';\n    73→  timestamp: number;\n    74→}\n    75→\n    76→export interface WorkerBusy {\n    77→  type: 'busy';\n    78→  executionId: string;\n    79→  reason: string;\n    80→}\n    81→\n    82→export type WorkerMessage =\n    83→  | WorkerHello\n    84→  | WorkerReady\n    85→  | ExecStdout\n    86→  | ExecStderr\n    87→  | ExecComplete\n    88→  | WorkerEvent\n    89→  | ExecProgress\n    90→  | WorkerHeartbeat\n    91→  | WorkerBusy;\n    92→\n    93→// --- Orchestrator → Worker ---\n    94→\n    95→export interface OrchestratorAck {\n    96→  type: 'ack';\n    97→  workerId: string;\n    98→  sessionToken: string;\n    99→}\n   100→\n   101→export interface ExecAssign {\n   102→  type: 'assign';\n   103→  executionId: string;\n   104→  personaId: string;\n   105→  prompt: string;\n   106→  env: Record<string, string>;\n   107→  config: {\n   108→    timeoutMs: number;\n   109→    maxOutputBytes: number;\n   110→    networkPolicy?: import('./networkPolicy.js').NetworkPolicy;\n   111→    maxBudgetUsd?: number;\n   112→    maxTurns?: number;\n   113→  };\n   114→}\n   115→\n   116→export interface ExecCancel {\n   117→  type: 'cancel';\n   118→  executionId: string;\n   119→}\n   120→\n   121→export interface OrchestratorShutdown {\n   122→  type: 'shutdown';\n   123→  reason: string;\n   124→  gracePeriodMs: number;\n   125→}\n   126→\n   127→export interface OrchestratorHeartbeat {\n   128→  type: 'heartbeat';\n   129→  timestamp: number;\n   130→}\n   131→\n   132→export type OrchestratorMessage =\n   133→  | OrchestratorAck\n   134→  | ExecAssign\n   135→  | ExecCancel\n   136→  | OrchestratorShutdown\n   137→  | OrchestratorHeartbeat;\n   138→\n   139→// --- Runtime validators ---\n   140→\n   141→function isObj(v: unknown): v is Record<string, unknown> {\n   142→  return typeof v === 'object' && v !== null && !Array.isArray(v);\n   143→}\n   144→\n   145→function hasStr(o: Record<string, unknown>, k: string): boolean {\n   146→  return typeof o[k] === 'string';\n   147→}\n   148→\n   149→function hasNum(o: Record<string, unknown>, k: string): boolean {\n   150→  return typeof o[k] === 'number';\n   151→}\n   152→\n   153→function hasStrArr(o: Record<string, unknown>, k: string): boolean {\n   154→  return Array.isArray(o[k]) && (o[k] as unknown[]).every(v => typeof v === 'string');\n   155→}\n   156→\n   157→export function validateWorkerMessage(msg: unknown): WorkerMessage | null {\n   158→  if (!isObj(msg) || !hasStr(msg, 'type')) return null;\n   159→  const m = msg as Record<string, unknown> & { type: string };\n   160→  switch (m.type) {\n   161→    case 'hello':\n   162→      return hasStr(m, 'workerId') && hasStr(m, 'version') && hasStrArr(m, 'capabilities')\n   163→        ? (m as unknown as WorkerHello) : null;\n   164→    case 'ready':\n   165→      return m as unknown as WorkerReady;\n   166→    case 'stdout':\n   167→    case 'stderr':\n   168→      return hasStr(m, 'executionId') && hasStr(m, 'chunk') && hasNum(m, 'timestamp')\n   169→        ? (m as unknown as ExecStdout & ExecStderr) : null;\n   170→    case 'complete':\n   171→      return hasStr(m, 'executionId') && hasStr(m, 'status') && hasNum(m, 'exitCode') && hasNum(m, 'durationMs')\n   172→        ? (m as unknown as ExecComplete) : null;\n   173→    case 'event':\n   174→      return hasStr(m, 'executionId') && hasStr(m, 'eventType') && 'payload' in m\n   175→        ? (m as unknown as WorkerEvent) : null;\n   176→    case 'progress':\n   177→      return hasStr(m, 'executionId') && hasStr(m, 'phase') && hasNum(m, 'percent') && hasNum(m, 'timestamp')\n   178→        ? (m as unknown as ExecProgress) : null;\n   179→    case 'heartbeat':\n   180→      return hasNum(m, 'timestamp') ? (m as unknown as WorkerHeartbeat) : null;\n   181→    case 'busy':\n   182→      return hasStr(m, 'executionId') && hasStr(m, 'reason')\n   183→        ? (m as unknown as WorkerBusy) : null;\n   184→    default:\n   185→      return null;\n   186→  }\n   187→}\n   188→\n   189→export function validateOrchestratorMessage(msg: unknown): OrchestratorMessage | null {\n   190→  if (!isObj(msg) || !hasStr(msg, 'type')) return null;\n   191→  const m = msg as Record<string, unknown> & { type: string };\n   192→  switch (m.type) {\n   193→    case 'ack':\n   194→      return hasStr(m, 'workerId') && hasStr(m, 'sessionToken')\n   195→        ? (m as unknown as OrchestratorAck) : null;\n   196→    case 'assign':\n   197→      return hasStr(m, 'executionId') && hasStr(m, 'personaId') && hasStr(m, 'prompt') && isObj(m.env) && isObj(m.config)\n   198→        ? (m as unknown as ExecAssign) : null;\n   199→    case 'cancel':\n   200→      return hasStr(m, 'executionId') ? (m as unknown as ExecCancel) : null;\n   201→    case 'shutdown':\n   202→      return hasStr(m, 'reason') && hasNum(m, 'gracePeriodMs')\n   203→        ? (m as unknown as OrchestratorShutdown) : null;\n   204→    case 'heartbeat':\n   205→      return hasNum(m, 'timestamp') ? (m as unknown as OrchestratorHeartbeat) : null;\n   206→    default:\n   207→      return null;\n   208→  }\n   209→}\n   210→\n   211→// --- Helpers ---\n   212→\n   213→export function parseWorkerMessage(raw: string): WorkerMessage | null {\n   214→  try {\n   215→    return validateWorkerMessage(JSON.parse(raw));\n   216→  } catch {\n   217→    return null;\n   218→  }\n   219→}\n   220→\n   221→export function parseOrchestratorMessage(raw: string): OrchestratorMessage | null {\n   222→  try {\n   223→    return validateOrchestratorMessage(JSON.parse(raw));\n   224→  } catch {\n   225→    return null;\n   226→  }\n   227→}\n   228→\n   229→export function serializeMessage(msg: WorkerMessage | OrchestratorMessage): string {\n   230→  return JSON.stringify(msg);\n   231→}\n   