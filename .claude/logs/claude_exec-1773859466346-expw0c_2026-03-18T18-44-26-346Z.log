[2026-03-18T18:44:52.873Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E5jFsbNmYsxkAK23cRFPyR","type":"tool_result","content":"     1→import 'dotenv/config';\n     2→import path from 'node:path';\n     3→\n     4→export interface OrchestratorConfig {\n     5→  masterKey: string;\n     6→  claudeToken: string;\n     7→  teamApiKey: string;\n     8→  workerToken: string;\n     9→  kafkaBrokers: string;\n    10→  kafkaUsername: string;\n    11→  kafkaPassword: string;\n    12→  kafkaEnabled: boolean;\n    13→  supabaseJwtSecret: string;\n    14→  wsPort: number;\n    15→  httpPort: number;\n    16→  // TLS\n    17→  tlsEnabled: boolean;\n    18→  tlsCertPath: string;\n    19→  tlsKeyPath: string;\n    20→  tlsCaPath: string;\n    21→  tlsRequireClientCert: boolean;\n    22→  // Output scrubbing\n    23→  scrubberEnabled: boolean;\n    24→  // Audit\n    25→  auditDbPath: string;\n    26→  auditRetentionDays: number;\n    27→  tokenExpiryWarningMinutes: number;\n    28→  // Retention\n    29→  retentionDays: number;\n    30→  metricsRetentionDays: number;\n    31→  // Data directory\n    32→  dataDir: string;\n    33→  // Worker verification\n    34→  allowedImageDigests: string[];\n    35→  rejectUnverifiedWorkers: boolean;\n    36→  // Queue backpressure\n    37→  maxQueueDepth: number;\n    38→  queueWarningThreshold: number;\n    39→  queueCriticalThreshold: number;\n    40→  perTenantQueueQuota: number;\n    41→  queueRetryAfterSeconds: number;\n    42→}\n    43→\n    44→function required(name: string): string {\n    45→  const value = process.env[name];\n    46→  if (!value) {\n    47→    throw new Error(`Missing required environment variable: ${name}`);\n    48→  }\n    49→  return value;\n    50→}\n    51→\n    52→function optional(name: string, fallback: string): string {\n    53→  return process.env[name] || fallback;\n    54→}\n    55→\n    56→export function loadConfig(): OrchestratorConfig {\n    57→  const kafkaBrokers = process.env['KAFKA_BROKERS'] || '';\n    58→\n    59→  const dataDir = process.env['DAC_DATA_DIR'] || path.join(process.cwd(), 'data');\n    60→\n    61→  return {\n    62→    masterKey: required('MASTER_KEY'),\n    63→    claudeToken: process.env['CLAUDE_TOKEN'] || '',  // Optional: use OAuth flow if not provided\n    64→    teamApiKey: required('TEAM_API_KEY'),\n    65→    workerToken: required('WORKER_TOKEN'),\n    66→    kafkaBrokers,\n    67→    kafkaUsername: process.env['KAFKA_USERNAME'] || '',\n    68→    kafkaPassword: process.env['KAFKA_PASSWORD'] || '',\n    69→    kafkaEnabled: kafkaBrokers.length > 0,\n    70→    supabaseJwtSecret: process.env['SUPABASE_JWT_SECRET'] || '',\n    71→    wsPort: parseInt(optional('WS_PORT', '8443'), 10),\n    72→    httpPort: parseInt(optional('HTTP_PORT', '3001'), 10),\n    73→    // TLS\n    74→    tlsEnabled: process.env['TLS_ENABLED'] !== 'false',\n    75→    tlsCertPath: process.env['TLS_CERT_PATH'] || '',\n    76→    tlsKeyPath: process.env['TLS_KEY_PATH'] || '',\n    77→    tlsCaPath: process.env['TLS_CA_PATH'] || '',\n    78→    tlsRequireClientCert: process.env['TLS_REQUIRE_CLIENT_CERT'] === 'true',\n    79→    // Output scrubbing\n    80→    scrubberEnabled: process.env['SCRUBBER_ENABLED'] !== 'false',\n    81→    // Audit\n    82→    auditDbPath: process.env['AUDIT_DB_PATH'] || path.join(dataDir, 'audit.db'),\n    83→    auditRetentionDays: parseInt(process.env['AUDIT_RETENTION_DAYS'] || '90', 10),\n    84→    tokenExpiryWarningMinutes: parseInt(process.env['TOKEN_EXPIRY_WARNING_MINUTES'] || '30', 10),\n    85→    // Retention\n    86→    retentionDays: parseInt(process.env['RETENTION_DAYS'] || '30', 10),\n    87→    metricsRetentionDays: parseInt(process.env['METRICS_RETENTION_DAYS'] || '365', 10),\n    88→    // Data directory\n    89→    dataDir,\n    90→    // Worker verification\n    91→    allowedImageDigests: (process.env['ALLOWED_IMAGE_DIGESTS'] || '').split(',').map(s => s.trim()).filter(Boolean),\n    92→    rejectUnverifiedWorkers: process.env['REJECT_UNVERIFIED_WORKERS'] === 'true',\n    93→    // Queue backpressure\n    94→    maxQueueDepth: parseInt(process.env['MAX_QUEUE_DEPTH'] || '1000', 10),\n    95→    queueWarningThreshold: parseInt(process.env['QUEUE_WARNING_THRESHOLD'] || '500', 10),\n    96→    queueCriticalThreshold: parseInt(process.env['QUEUE_CRITICAL_THRESHOLD'] || '800', 10),\n    97→    perTenantQueueQuota: parseInt(process.env['PER_TENANT_QUEUE_QUOTA'] || '0', 10),\n    98→    queueRetryAfterSeconds: parseInt(process.env['QUEUE_RETRY_AFTER_SECONDS'] || '30', 10),\n    99→  };\n   100→}\n   101→"}]},"parent_tool_use_id":"toolu_019rNayeDQiCV4g9yReh3JfL","session_id":"9fe338af-0a15-4609-9054-9655c25cf426","uuid":"5a71f8ea-63cd-4bbc-9750-9be3b3ae2c74","timestamp":"2026-03-18T18:44:52.775Z"}
