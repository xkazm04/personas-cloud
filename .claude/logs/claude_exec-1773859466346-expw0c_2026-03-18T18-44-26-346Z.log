TEXT');\n   279→    logger.info('Migration: added event_id to persona_executions');\n   280→  }\n   281→}\n   282→\n   283→// ---------------------------------------------------------------------------\n   284→// Initialization\n   285→// ---------------------------------------------------------------------------\n   286→\n   287→/** Legacy: initialize a single monolithic database (used by migration script). */\n   288→export function initDb(dbPath: string, logger: Logger): Database.Database {\n   289→  const db = new Database(dbPath);\n   290→  db.pragma('journal_mode = WAL');\n   291→  db.pragma('foreign_keys = ON');\n   292→\n   293→  db.exec(SHARED_TABLES);\n   294→  runLegacyMigrations(db, logger);\n   295→  logger.info({ dbPath }, 'Database initialized (legacy single-db)');\n   296→  return db;\n   297→}\n   298→\n   299→/** Initialize the system-level database (tenant registry). */\n   300→export function initSystemDb(dbPath: string, logger: Logger): Database.Database {\n   301→  const db = new Database(dbPath);\n   302→  db.pragma('journal_mode = WAL');\n   303→  db.pragma('foreign_keys = ON');\n   304→\n   305→  db.exec(SYSTEM_SCHEMA);\n   306→  logger.info({ dbPath }, 'System database initialized');\n   307→  return db;\n   308→}\n   309→\n   310→/** Initialize a per-tenant database. */\n   311→export function initTenantDb(dbPath: string, logger: Logger): Database.Database {\n   312→  const db = new Database(dbPath);\n   313→  db.pragma('journal_mode = WAL');\n   314→  db.pragma('foreign_keys = ON');\n   315→\n   316→  db.exec(SHARED_TABLES);\n   317→  runTenantMigrations(db, logger);\n   318→  logger.info({ dbPath }, 'Tenant database initialized');\n   319→  return db;\n   320→}\n   321→\n   322→/** Migrations applied to per-tenant databases. */\n   323→function runTenantMigrations(db: Database.Database, logger: Logger): void {\n   324→  const eventCols = stmt(db,'PRAGMA table_info(persona_events)').all() as Array<{ name: string }>;\n   325→  if (!eventCols.some(c => c.name === 'retry_after')) {\n   326→    db.exec('ALTER TABLE persona_events ADD COLUMN retry_after TEXT');\n   327→    logger.info('Tenant migration: added retry_after to persona_events');\n   328→  }\n   329→  if (!eventCols.some(c => c.name === 'retry_count')) {\n   330→    db.exec('ALTER TABLE persona_events ADD COLUMN retry_count INTEGER NOT NULL DEFAULT 0');\n   331→    logger.info('Tenant migration: added retry_count to persona_events');\n   332→  }\n   333→\n   334→  // Add event_id to persona_executions for event↔execution correlation tracing\n   335→  const execCols = stmt(db,'PRAGMA table_info(persona_executions)').all() as Array<{ name: string }>;\n   336→  if (!execCols.some(c => c.name === 'event_id')) {\n   337→    db.exec('ALTER TABLE persona_executions ADD COLUMN event_id TEXT');\n   338→    logger.info('Tenant migration: added event_id to persona_executions');\n   339→  }\n   340→}\n   341→"}]},"parent_tool_use_id":"toolu_019rNayeDQiCV4g9yReh3JfL","session_id":"9fe338af-0a15-4609-9054-9655c25cf426","uuid":"479af3d2-c6e4-4a89-ba3f-c30cc2f27cf7","timestamp":"2026-03-18T18:44:59.152Z"}
