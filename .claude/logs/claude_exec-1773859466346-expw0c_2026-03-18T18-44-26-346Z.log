[2026-03-18T18:44:55.956Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PvQ6GxtnHMjFtmjrEABv3m","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import type Database from 'better-sqlite3';\n     3→import type { RequestContext } from './auth.js';\n     4→import { readBody, json } from './httpUtils.js';\n     5→import * as db from './db/index.js';\n     6→import type { TriggerSchedulerHandle } from './triggerScheduler.js';\n     7→\n     8→interface ParsedRoute {\n     9→  resource: string;\n    10→  id?: string;\n    11→  subResource?: string;\n    12→}\n    13→\n    14→/**\n    15→ * Attempt to handle a trigger CRUD route.\n    16→ * Caller is responsible for auth checks before invoking this.\n    17→ * Sends a 404 for unrecognised trigger sub-paths.\n    18→ *\n    19→ * When a `scheduler` handle is provided, CRUD operations update the\n    20→ * in-memory trigger heap so the scheduler fires without a DB scan.\n    21→ */\n    22→export async function handleTriggerRoute(\n    23→  route: ParsedRoute,\n    24→  method: string,\n    25→  req: http.IncomingMessage,\n    26→  res: http.ServerResponse,\n    27→  tenantDb: Database.Database,\n    28→  ctx: RequestContext,\n    29→  scheduler?: TriggerSchedulerHandle,\n    30→): Promise<void> {\n    31→  const tenantId = ctx.projectId ?? 'default';\n    32→\n    33→  // POST /api/triggers — create trigger\n    34→  if (route.resource === 'triggers' && !route.id && method === 'POST') {\n    35→    const body = JSON.parse(await readBody(req));\n    36→    if (ctx.authType === 'user') body.projectId = ctx.projectId;\n    37→    const trigger = db.createTrigger(tenantDb, body);\n    38→    scheduler?.heapPush(trigger.id, tenantId, trigger.nextTriggerAt);\n    39→    scheduler?.nudge();\n    40→    json(res, 201, trigger);\n    41→    return;\n    42→  }\n    43→\n    44→  // PUT /api/triggers/:id — update trigger\n    45→  if (route.resource === 'triggers' && route.id && !route.subResource && method === 'PUT') {\n    46→    const body = JSON.parse(await readBody(req));\n    47→    db.updateTrigger(tenantDb, route.id, body);\n    48→    const updated = db.getTrigger(tenantDb, route.id);\n    49→    if (updated) {\n    50→      if (updated.enabled && updated.nextTriggerAt) {\n    51→        scheduler?.heapPush(updated.id, tenantId, updated.nextTriggerAt);\n    52→      } else {\n    53→        scheduler?.heapRemove(updated.id);\n    54→      }\n    55→      scheduler?.nudge();\n    56→    }\n    57→    json(res, 200, updated);\n    58→    return;\n    59→  }\n    60→\n    61→  // DELETE /api/triggers/:id — delete trigger\n    62→  if (route.resource === 'triggers' && route.id && !route.subResource && method === 'DELETE') {\n    63→    scheduler?.heapRemove(route.id);\n    64→    db.deleteTrigger(tenantDb, route.id);\n    65→    json(res, 200, { deleted: true });\n    66→    return;\n    67→  }\n    68→\n    69→  // GET /api/personas/:id/triggers — list triggers for persona\n    70→  if (route.resource === 'personas' && route.id && route.subResource === 'triggers' && method === 'GET') {\n    71→    json(res, 200, db.listTriggersForPersona(tenantDb, route.id));\n    72→    return;\n    73→  }\n    74→\n    75→  // Unrecognised trigger sub-path\n    76→  json(res, 404, { error: 'Not found' });\n    77→}\n    78→"}]},"parent_tool_use_id":"toolu_019rNayeDQiCV4g9yReh3JfL","session_id":"9fe338af-0a15-4609-9054-9655c25cf426","uuid":"c64eaca7-82d0-4681-9aff-8c63e4cc89ac","timestamp":"2026-03-18T18:44:55.731Z"}
