tity?: string;\n    56→  instructions?: string;\n    57→  toolGuidance?: string;\n    58→  examples?: string;\n    59→  errorHandling?: string;\n    60→  customSections?: Array<{ title?: string; label?: string; name?: string; key?: string; content?: string }>;\n    61→  webSearch?: string;\n    62→}\n    63→\n    64→// ---------------------------------------------------------------------------\n    65→// Inference profiles\n    66→// ---------------------------------------------------------------------------\n    67→\n    68→export type InferenceProvider = 'claude' | 'ollama' | 'litellm' | 'openai-compatible' | 'custom';\n    69→\n    70→export interface InferenceProviderEnvMapping {\n    71→  envVar: string;\n    72→  source: 'baseUrl' | 'authToken' | 'model';\n    73→}\n    74→\n    75→export interface InferenceProfile {\n    76→  id: string;\n    77→  projectId: string;\n    78→  name: string;\n    79→  provider: InferenceProvider;\n    80→  model?: string;\n    81→  baseUrl?: string;\n    82→  authTokenEncrypted?: string;\n    83→  authTokenIv?: string;\n    84→  authTokenTag?: string;\n    85→  envMappings: InferenceProviderEnvMapping[];\n    86→  removeEnvKeys?: string[];\n    87→  isPreset: boolean;\n    88→  createdAt: string;\n    89→  updatedAt: string;\n    90→}\n    91→\n    92→export interface PersonaCredential {\n    93→  id: string;\n    94→  projectId?: string;\n    95→  name: string;\n    96→  serviceType: string;\n    97→  encryptedData: string;\n    98→  iv: string;\n    99→  tag: string;\n   100→  metadata: string | null;\n   101→  lastUsedAt: string | null;\n   102→  createdAt: string;\n   103→  updatedAt: string;\n   104→}\n   105→\n   106→// ---------------------------------------------------------------------------\n   107→// Event lifecycle state machine\n   108→// ---------------------------------------------------------------------------\n   109→\n   110→/** All valid event statuses. */\n   111→export type EventStatus = 'pending' | 'processing' | 'delivered' | 'skipped' | 'failed' | 'partial' | 'partial-retry';\n   112→\n   113→/** All valid EventStatus values as a runtime array (for CHECK constraints, etc.). */\n   114→export const EVENT_STATUSES: readonly EventStatus[] = [\n   115→  'pending', 'processing', 'delivered', 'skipped', 'failed', 'partial', 'partial-retry',\n   116→] as const;\n   117→\n   118→/**\n   119→ * Legal state transitions for persona events.\n   120→ * Key = current status, Value = set of statuses it may transition to.\n   121→ */\n   122→export const EVENT_TRANSITIONS: Readonly<Record<EventStatus, ReadonlySet<EventStatus>>> = {\n   123→  'pending':       new Set<EventStatus>(['processing']),\n   124→  'processing':    new Set<EventStatus>(['delivered', 'skipped', 'failed', 'partial', 'partial-retry', 'pending']),\n   125→  'delivered':     new Set<EventStatus>([]),                       // terminal\n   126→  'skipped':       new Set<EventStatus>([]),                       // terminal\n   127→  'failed':        new Set<EventStatus>([]),                       // terminal\n   128→  'partial':       new Set<EventStatus>(['partial-retry']),        // can retry partial failures\n   129→  'partial-retry': new Set<EventStatus>(['processing']),           // retried partial goes back through processing\n   130→};\n   131→\n   132→/**\n   133→ * Validate that a transition from `from` → `to` is legal.\n   134→ * Throws if the transition is invalid.\n   135→ */\n   136→export function validateEventTransition(from: EventStatus, to: EventStatus): void {\n   137→  const allowed = EVENT_TRANSITIONS[from];\n   138→  if (!allowed || !allowed.has(to)) {\n   139→    throw new Error(`Invalid event status transition: '${from}' → '${to}'`);\n   140→  }\n   141→}\n   142→\n   143→export interface PersonaEvent {\n   144→  id: string;\n   145→  projectId: string;\n   146→  eventType: string;\n   147→  sourceType: string;\n   148→  sourceId: string | null;\n   149→  targetPersonaId: string | null;\n   150→  payload: string | null;\n   151→  status: EventStatus;\n   152→  errorMessage: string | null;\n   153→  processedAt: string | null;\n   154→  useCaseId: string | null;\n   155→  retryAfter: string | null;\n   156→  retryCount: number;\n   157→  createdAt: string;\n   158→}\n   159→\n   160→export interface PersonaEventSubscription {\n   161→  id: string;\n   162→  personaId: string;\n   163→  eventType: string;\n   164→  sourceFilter: string | null;\n   165→  enabled: boolean;\n   166→  useCaseId: string | null;\n   167→  createdAt: string;\n   168→  updatedAt: string;\n   169→}\n   170→\n   171→// ---------------------------------------------------------------------------\n   172→// Trigger config discriminated union\n   173→// ---------------------------------------------------------------------------\n   174→\n   175→export type TriggerType = 'manual' | 'schedule' | 'polling' | 'webhook' | 'chain';\n   176→\n   177→interface TriggerConfigBase {\n   178→  event_type?: string;\n   179→  payload?: unknown;\n   180→}\n   181→\n   182→export interface ScheduleTriggerConfig extends TriggerConfigBase {\n   183→  kind: 'schedule';\n   184→  cron?: string;\n   185→  interval_seconds?: number;\n   186→}\n   187→\n   188→export interface ManualTriggerConfig extends TriggerConfigBase {\n   189→  kind: 'manual';\n   190→}\n   191→\n   192→export interface PollingTriggerConfig extends TriggerConfigBase {\n   193→  kind: 'polling';\n   194→  poll_url?: string;\n   195→  poll_interval_seconds?: number;\n   196→}\n   197→\n   198→export interface WebhookTriggerConfig extends TriggerConfigBase {\n   199→  kind: 'webhook';\n   200→  url?: string;\n   201→  secret?: string;\n   202→}\n   203→\n   204→export interface ChainTriggerConfig extends TriggerConfigBase {\n   205→  kind: 'chain';\n   206→  source_persona_id?: string;\n   207→  source_event_type?: string;\n   208→}\n   209→\n   210→export type TriggerConfig =\n   211→  | ScheduleTriggerConfig\n   212→  | ManualTriggerConfig\n   213→  | PollingTriggerConfig\n   214→  | WebhookTriggerConfig\n   215→  | ChainTriggerConfig;\n   216→\n   217→export interface PersonaTrigger {\n   218→  id: string;\n   219→  personaId: string;\n   220→  triggerType: TriggerType;\n   221→  config: string | null;\n   222→  enabled: boolean;\n   223→  lastTriggeredAt: string | null;\n   224→  nextTriggerAt: string | null;\n   225→  useCaseId: string | null;\n   226→  createdAt: string;\n   227→  updatedAt: string;\n   228→}\n   229→\n   230→/** Fully hydrated persona with all related entities. */\n   231→export interface HydratedPersona extends Persona {\n   232→  tools: PersonaToolDefinition[];\n   233→  credentials: Omit<PersonaCredential, 'encryptedData' | 'iv' | 'tag'>[];\n   234→  subscriptions: PersonaEventSubscription[];\n   235→  triggers: PersonaTrigger[];\n   236→}\n   237→\n   238→export interface PersonaExecution {\n   239→  id: string;\n   240→  projectId?: string;\n   241→  personaId: string;\n   242→  triggerId: string | null;\n   243→  useCaseId: string | null;\n   244→  /** Originating event ID — enables bidirectional event↔execution tracing. */\n   245→  eventId: string | null;\n   246→  status: string;\n   247→  inputData: string | null;\n   248→  outputData: string | null;\n   249→  claudeSessionId: string | null;\n   250→  modelUsed: string | null;\n   251→  inputTokens: number;\n   252→  outputTokens: number;\n   253→  costUsd: number;\n   254→  errorMessage: string | null;\n   255→  durationMs: number | null;\n   256→  retryOfExecutionId: string | null;\n   257→  retryCount: number;\n   258→  startedAt: string | null;\n   259→  completedAt: string | null;\n   260→  createdAt: string;\n   261→}\n   262→\n   263→// ---------------------------------------------------------------------------\n   264→// Execution request — produced to Kafka by Vibeman, consumed by orchestrator\n   265→// ---------------------------------------------------------------------------\n   266→\n   267→export interface ExecRequest {\n   268→  executionId: string;\n   269→  personaId: string;\n   270→  prompt: string;\n   271→  projectId?: string;\n   272→  credentialIds?: string[];\n   273→  inputData?: unknown;\n   274→  config: {\n   275→    timeoutMs: number;\n   276→    maxConcurrent?: number;\n   277→  };\n   278→  triggerId?: string;\n   279→  triggerType?: string;\n   280→  /** Originating event ID — enables bidirectional event↔execution tracing. */\n   281→  eventId?: string;\n   282→}\n   283→\n   284→// Execution result — produced to Kafka by orchestrator\n   285→export interface ExecResult {\n   286→  executionId: string;\n   287→  personaId: string;\n   288→  status: 'completed' | 'failed' | 'cancelled';\n   289→  exitCode: number;\n   290→  durationMs: number;\n   291→  sessionId?: string;\n   292→  totalCostUsd?: number;\n   293→  phaseTimings?: import('./protocol.js').PhaseTimings;\n   294→  error?: string;\n   295→}\n   296→\n   297→// Worker info as tracked by orchestrator\n   298→export interface WorkerInfo {\n   299→  workerId: string;\n   300→  status: 'connecting' | 'idle' | 'executing' | 'disconnected';\n   301→  version: string;\n   302→  capabilities: string[];\n   303→  currentExecutionId?: string;\n   304→  connectedAt: number;\n   305→  lastHeartbeat: number;\n   306→  imageDigest?: string;\n   307→  claudeCliVersion?: string;\n   308→  verified: boolean;\n   309→}\n   310→\n   311→// Execution output chunk — produced to Kafka for Vibeman SSE consumption\n   312→export interface OutputChunk {\n   313→  executionId: string;\n   314→  chunk: string;\n   315→  timestamp: number;\n   316→}\n   317→\n   318→// Persona event — forwarded from worker to Kafka event bus\n   319→export interface PersonaCloudEvent {\n   320→  executionId: string;\n   321→  personaId: string;\n   322→  eventType: import('./protocolRegistry.js').ProtocolEventType;\n   323→  payload: unknown;\n   324→  timestamp: number;\n   325→}\n   326→\n   327→// Execution progress (ephemeral