[2026-03-18T18:44:52.687Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PMKzPg6JV2YWHAyYW4ZT3b","type":"tool_result","content":"     1→import type Database from 'better-sqlite3';\n     2→import type { Logger } from 'pino';\n     3→import * as db from './db/index.js';\n     4→import { TriggerHeap, type HeapEntry } from './triggerHeap.js';\n     5→import type { TenantDbManager } from './tenantDbManager.js';\n     6→\n     7→const MIN_DELAY_MS = 100;\n     8→const MAX_DELAY_MS = 60_000;\n     9→const HEARTBEAT_INTERVAL_MS = 60_000;\n    10→\n    11→export interface SchedulerMetrics {\n    12→  heap_size: number;\n    13→  next_due_at: string | null;\n    14→  triggers_fired_total: number;\n    15→  triggers_missed_total: number;\n    16→  avg_tick_latency_ms: number;\n    17→  last_tick_at: string | null;\n    18→}\n    19→\n    20→export interface TriggerSchedulerHandle {\n    21→  /** Stop the scheduler. */\n    22→  close(): void;\n    23→  /** Nudge the scheduler to re-evaluate immediately (e.g. after trigger create/update). */\n    24→  nudge(): void;\n    25→  /** Push or update a trigger in the heap after CRUD. */\n    26→  heapPush(triggerId: string, tenantId: string, nextTriggerAt: string | null): void;\n    27→  /** Remove a trigger from the heap (e.g. after delete or disable). */\n    28→  heapRemove(triggerId: string): void;\n    29→  /** Return current scheduler metrics for observability. */\n    30→  getMetrics(): SchedulerMetrics;\n    31→}\n    32→\n    33→/**\n    34→ * Start the heap-driven trigger scheduler.\n    35→ *\n    36→ * On startup the scheduler loads all enabled triggers from the DB into an\n    37→ * in-memory min-heap keyed by next_trigger_at.  On each tick it pops entries\n    38→ * whose time has passed, fires them, and pushes the updated next-fire times\n    39→ * back into the heap.  The DB remains the source of truth — the heap is a\n    40→ * hot-path cache that eliminates full table scans.\n    41→ */\n    42→export function startTriggerScheduler(\n    43→  database: Database.Database | null,\n    44→  logger: Logger,\n    45→  _interval?: number, // kept for signature compat; ignored\n    46→  tenantDbManager?: TenantDbManager,\n    47→  onEventPublished?: () => void,\n    48→): TriggerSchedulerHandle {\n    49→  let timer: ReturnType<typeof setTimeout> | null = null;\n    50→  let heartbeatTimer: ReturnType<typeof setInterval> | null = null;\n    51→  let stopped = false;\n    52→  const heap = new TriggerHeap();\n    53→\n    54→  // ---- Metrics accumulators ----\n    55→  let triggersFiredTotal = 0;\n    56→  let triggersMissedTotal = 0;\n    57→  let tickCount = 0;\n    58→  let tickLatencySum = 0;\n    59→  let lastTickAt: number | null = null;\n    60→\n    61→  // ---- Heap bootstrap: load all enabled triggers from DB ----\n    62→  buildHeap(heap, database, tenantDbManager, logger);\n    63→\n    64→  logger.info(\n    65→    { heapSize: heap.size, minDelayMs: MIN_DELAY_MS, maxDelayMs: MAX_DELAY_MS, tenantIsolated: !!tenantDbManager },\n    66→    'Heap-driven trigger scheduler started',\n    67→  );\n    68→\n    69→  function scheduleTick(delayMs: number): void {\n    70→    if (stopped) return;\n    71→    timer = setTimeout(tick, delayMs);\n    72→  }\n    73→\n    74→  function tick(): void {\n    75→    if (stopped) return;\n    76→    const tickStart = Date.now();\n    77→    try {\n    78→      const now = tickStart;\n    79→      const due = heap.popDue(now);\n    80→\n    81→      if (due.length > 0) {\n    82→        // Count missed triggers (due more than 60 s ago)\n    83→        for (const entry of due) {\n    84→          if (now - entry.nextTriggerAt > MAX_DELAY_MS) {\n    85→            triggersMissedTotal++;\n    86→          }\n    87→        }\n    88→        const firedCount = fireDueEntries(due, database, tenantDbManager, heap, logger, onEventPublished);\n    89→        triggersFiredTotal += firedCount;\n    90→      }\n    91→    } catch (err) {\n    92→      logger.error({ err }, 'Trigger scheduler tick failed');\n    93→    }\n    94→\n    95→    // Track tick latency\n    96→    const tickEnd = Date.now();\n    97→    tickCount++;\n    98→    tickLatencySum += tickEnd - tickStart;\n    99→    lastTickAt = tickEnd;\n   100→\n   101→    // Schedule next tick based on heap peek\n   102→    const delayMs = computeNextDelay(heap);\n   103→    scheduleTick(delayMs);\n   104→  }\n   105→\n   106→  // Kick off the first tick immediately\n   107→  scheduleTick(0);\n   108→\n   109→  // ---- Heartbeat log every 60 seconds ----\n   110→  heartbeatTimer = setInterval(() => {\n   111→    if (stopped) return;\n   112→    const top = heap.peek();\n   113→    logger.info({\n   114→      heap_size: heap.size,\n   115→      next_due_at: top ? new Date(top.nextTriggerAt).toISOString() : null,\n   116→      triggers_fired_total: triggersFiredTotal,\n   117→      triggers_missed_total: triggersMissedTotal,\n   118→      avg_tick_latency_ms: tickCount > 0 ? Math.round(tickLatencySum / tickCount * 100) / 100 : 0,\n   119→      last_tick_at: lastTickAt ? new Date(lastTickAt).toISOString() : null,\n   120→    }, 'Scheduler heartbeat');\n   121→  }, HEARTBEAT_INTERVAL_MS);\n   122→\n   123→  return {\n   124→    close() {\n   125→      stopped = true;\n   126→      if (timer != null) {\n   127→        clearTimeout(timer);\n   128→        timer = null;\n   129→      }\n   130→      if (heartbeatTimer != null) {\n   131→        clearInterval(heartbeatTimer);\n   132→        heartbeatTimer = null;\n   133→      }\n   134→    },\n   135→    nudge() {\n   136→      if (stopped) return;\n   137→      if (timer != null) {\n   138→        clearTimeout(timer);\n   139→        timer = null;\n   140→      }\n   141→      scheduleTick(0);\n   142→    },\n   143→    heapPush(triggerId: string, tenantId: string, nextTriggerAt: string | null) {\n   144→      if (!nextTriggerAt) {\n   145→        heap.remove(triggerId);\n   146→        return;\n   147→      }\n   148→      heap.push({ triggerId, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });\n   149→    },\n   150→    heapRemove(triggerId: string) {\n   151→      heap.remove(triggerId);\n   152→    },\n   153→    getMetrics(): SchedulerMetrics {\n   154→      const top = heap.peek();\n   155→      return {\n   156→        heap_size: heap.size,\n   157→        next_due_at: top ? new Date(top.nextTriggerAt).toISOString() : null,\n   158→        triggers_fired_total: triggersFiredTotal,\n   159→        triggers_missed_total: triggersMissedTotal,\n   160→        avg_tick_latency_ms: tickCount > 0 ? Math.round(tickLatencySum / tickCount * 100) / 100 : 0,\n   161→        last_tick_at: lastTickAt ? new Date(lastTickAt).toISOString() : null,\n   162→      };\n   163→    },\n   164→  };\n   165→}\n   166→\n   167→// ---------------------------------------------------------------------------\n   168→// Heap bootstrap — load all enabled triggers from every tenant DB\n   169→// ---------------------------------------------------------------------------\n   170→\n   171→function buildHeap(\n   172→  heap: TriggerHeap,\n   173→  database: Database.Database | null,\n   174→  tenantDbManager: TenantDbManager | undefined,\n   175→  logger: Logger,\n   176→): void {\n   177→  heap.clear();\n   178→\n   179→  if (tenantDbManager) {\n   180→    const tenantIds = tenantDbManager.listTenantIds();\n   181→    for (const tenantId of tenantIds) {\n   182→      try {\n   183→        const tenantDb = tenantDbManager.getTenantDb(tenantId);\n   184→        loadDbIntoHeap(heap, tenantDb, tenantId);\n   185→      } catch (err) {\n   186→        logger.error({ err, tenantId }, 'Failed to load triggers for tenant into heap');\n   187→      }\n   188→    }\n   189→  } else if (database) {\n   190→    loadDbIntoHeap(heap, database, 'default');\n   191→  }\n   192→}\n   193→\n   194→function loadDbIntoHeap(heap: TriggerHeap, dbConn: Database.Database, tenantId: string): void {\n   195→  const rows = db.loadEnabledTriggerTimes(dbConn);\n   196→  for (const row of rows) {\n   197→    heap.push({\n   198→      triggerId: row.id,\n   199→      tenantId,\n   200→      nextTriggerAt: new Date(row.nextTriggerAt).getTime(),\n   201→    });\n   202→  }\n   203→}\n   204→\n   205→// ---------------------------------------------------------------------------\n   206→// Compute next delay from the heap (O(1) peek)\n   207→// ---------------------------------------------------------------------------\n   208→\n   209→function computeNextDelay(heap: TriggerHeap): number {\n   210→  const top = heap.peek();\n   211→  if (!top) return MAX_DELAY_MS;\n   212→  const deltaMs = top.nextTriggerAt - Date.now();\n   213→  return Math.min(MAX_DELAY_MS, Math.max(MIN_DELAY_MS, deltaMs));\n   214→}\n   215→\n   216→// ---------------------------------------------------------------------------\n   217→// Fire due triggers — batch-fetch from DB by ID, then process\n   218→// ---------------------------------------------------------------------------\n   219→\n   220→function fireDueEntries(\n   221→  due: HeapEntry[],\n   222→  database: Database.Database | null,\n   223→  tenantDbManager: TenantDbManager | undefined,\n   224→  heap: TriggerHeap,\n   225→  logger: Logger,\n   226→  onEventPublished?: () => void,\n   227→): number {\n   228→  let firedCount = 0;\n   229→  // Group by tenantId so we hit each DB once with a batch query\n   230→  const byTenant = new Map<string, HeapEntry[]>();\n   231→  for (const entry of due) {\n   232→    let list = byTenant.get(entry.tenantId);\n   233→    if (!list) {\n   234→      list = [];\n   235→      byTenant.set(entry.tenantId, list);\n   236→    }\n   237→    list.push(entry);\n   238→  }\n   239→\n   240→  for (const [tenantId, entries] of byTenant) {\n   241→    try {\n   242→      const tenantDb = tenantDbManager\n   243→        ? tenantDbManager.getTenantDb(tenantId)\n   244→        : database;\n   245→      if (!tenantDb) continue;\n   246→\n   247→      const ids = entries.map(e => e.triggerId);\n   248→      const triggers = db.getTriggersByIdsWithPersona(tenantDb, ids);\n   249→\n   250→      for (const trigger of triggers) {\n   251→        // Skip polling triggers\n   252→        if (trigger.triggerType === 'polling') continue;\n   253→\n   254→        try {\n   255→          const parsedConfig = trigger.parsedConfig;\n   256→          let eventType = 'trigger_fired';\n   257→          let payload: string | null = null;\n   258→          if (parsedConfig) {\n   259→            if (parsedConfig.event_type) eventType = parsedConfig.event_type;\n   260→            if (parsedConfig.payload) payload = JSON.stringify(parsedConfig.payload);\n   261→          }\n   262→\n   263→          // Skip triggers for deleted or disabled personas\n   264→          if (trigger.personaProjectId == null) {\n   265→            logger.warn({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona not found (deleted?)');\n   266→            continue;\n   267→          }\n   268→          if (!trigger.personaEnabled) {\n   269→            logger.debug({ triggerId: trigger.id, personaId: trigger.personaId }, 'Skipping trigger: persona is disabled');\n   270→            continue;\n   271→          }\n   272→\n   273→          const triggerProjectId = tenantId !== 'default' ? tenantId : trigger.personaProjectId;\n   274→\n   275→          // Publish event\n   276→          db.publishEvent(tenantDb, {\n   277→            eventType,\n   278→            sourceType: 'trigger',\n   279→            sourceId: trigger.id,\n   280→            targetPersonaId: trigger.personaId,\n   281→            projectId: triggerProjectId,\n   282→            useCaseId: trigger.useCaseId,\n   283→            payload,\n   284→          });\n   285→          onEventPublished?.();\n   286→\n   287→          // Compute next trigger time and update DB\n   288→          const now = new Date().toISOString();\n   289→          const nextTriggerAt = db.computeNextTriggerAtFromParsed(trigger.triggerType, parsedConfig);\n   290→          db.updateTriggerTimings(tenantDb, trigger.id, now, nextTriggerAt);\n   291→\n   292→          // Push updated time back into heap\n   293→          if (nextTriggerAt) {\n   294→            heap.push({ triggerId: trigger.id, tenantId, nextTriggerAt: new Date(nextTriggerAt).getTime() });\n   295→          }\n   296→\n   297→          logger.info({\n   298→            triggerId: trigger.id,\n   299→            personaId: trigger.personaId,\n   300→            eventType,\n   301→            nextTriggerAt,\n   302→          }, 'Trigger fired');\n   303→          firedCount++;\n   304→        } catch (err) {\n   305→          logger.error({ err, triggerId: trigger.id }, 'Failed to fire trigger');\n   306→        }\n   307→      }\n   308→    } catch (err) {\n   309→      logger.error({ err, tenantId }, 'Trigger scheduler tick failed for tenant');\n   310→    }\n   311→  }\n   312→  return firedCount;\n   313→}\n   314→"}]},"parent_tool_use_id":"toolu_019rNayeDQiCV4g9yReh3JfL","session_id":"9fe338af-0a15-4609-9054-9655c25cf426","uuid":"6c48672f-64b1-48ad-b237-2cd585877f83","timestamp":"2026-03-18T18:44:52.594Z"}
