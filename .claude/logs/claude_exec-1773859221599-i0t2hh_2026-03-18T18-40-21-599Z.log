alse;\n    46→  let lastProduceError: string | null = null;\n    47→\n    48→  // Track produce errors to surface in health checks\n    49→  producer.on('producer.network.request_timeout', () => {\n    50→    lastProduceError = 'request_timeout';\n    51→  });\n    52→\n    53→  return {\n    54→    producer,\n    55→    consumer,\n    56→\n    57→    async setMasterKey(masterKeyHex: string) {\n    58→      masterKey = await deriveMasterKeyAsync(masterKeyHex);\n    59→    },\n    60→\n    61→    async connect() {\n    62→      await producer.connect();\n    63→      await consumer.connect();\n    64→      connected = true;\n    65→      lastProduceError = null;\n    66→      logger.info('Kafka connected');\n    67→    },\n    68→\n    69→    async disconnect() {\n    70→      connected = false;\n    71→      await producer.disconnect();\n    72→      await consumer.disconnect();\n    73→      logger.info('Kafka disconnected');\n    74→    },\n    75→\n    76→    async subscribe(handler: (topic: string, value: string, key?: string) => Promise<void>) {\n    77→      await consumer.subscribe({ topic: TOPICS.EXEC_REQUESTS, fromBeginning: false });\n    78→\n    79→      await consumer.run({\n    80→        eachMessage: async ({ topic, message }: EachMessagePayload) => {\n    81→          const value = message.value?.toString();\n    82→          const key = message.key?.toString();\n    83→          if (value) {\n    84→            try {\n    85→              await handler(topic, value, key);\n    86→            } catch (err) {\n    87→              logger.error({ err, topic, key }, 'Kafka message handler error');\n    88→            }\n    89→          }\n    90→        },\n    91→      });\n    92→\n    93→      logger.info({ topic: TOPICS.EXEC_REQUESTS }, 'Kafka consumer subscribed');\n    94→    },\n    95→\n    96→    async produce(topic: string, value: string, key?: string) {\n    97→      await producer.send({\n    98→        topic,\n    99→        messages: [{\n   100→          key: key || undefined,\n   101→          value,\n   102→        }],\n   103→      });\n   104→    },\n   105→\n   106→    async produceEncrypted(topic: string, payload: unknown, tenantId: string, key?: string) {\n   107→      if (!masterKey) {\n   108→        // Fallback to plaintext if no master key configured\n   109→        await this.produce(topic, JSON.stringify(payload), key);\n   110→        return;\n   111→      }\n   112→      const envelope = sealEnvelope(tenantId, payload, masterKey);\n   113→      await producer.send({\n   114→        topic,\n   115→        messages: [{\n   116→          key: key || undefined,\n   117→          value: JSON.stringify(envelope),\n   118→        }],\n   119→      });\n   120→    },\n   121→\n   122→    async checkHealth(): Promise<KafkaHealthStatus> {\n   123→      if (!connected) return { status: 'error', detail: 'not connected' };\n   124→      if (lastProduceError) return { status: 'error', detail: lastProduceError };\n   125→      return { status: 'ok' };\n   126→    },\n   127→  };\n   128→}\n   129→\n   130→// No-op Kafka client for when Kafka is not configured (local testing)\n   131→export function createNoopKafkaClient(logger: Logger): KafkaClient {\n   132→  logger.info('Kafka disabled — using no-op client');\n   133→\n   134→  return {\n   135→    producer: {} as Producer,\n   136→    consumer: {} as Consumer,\n   137→    async setMasterKey() {},\n   138→    async connect() {},\n   139→    async disconnect() {},\n   140→    async subscribe() {},\n   141→    async produce(topic: string, value: string) {\n   142→      logger.debug({ topic, valueLength: value.length }, 'No-op Kafka produce');\n   143→    },\n   144→    async produceEncrypted(topic: string, payload: unknown) {\n   145→      logger.debug({ topic }, 'No-op Kafka produceEncrypted');\n   146→    },\n   147→    async checkHealth(): Promise<KafkaHealthStatus> {\n   148→      return { status: 'disabled' };\n   149→    },\n   150→  };\n   151→}\n   152→"}]},"parent_tool_use_id":null,"session_id":"605152c5-6e13-4552-9149-cc731512a899","uuid":"d6f80f04-63d8-4f95-9382-d9197c25d3e3","timestamp":"2026-03-18T18:40:34.457Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\kafka.ts","content":"import { Kafka, type Producer, type Consumer, type EachMessagePayload, logLevel } from 'kafkajs';\nimport { TOPICS, sealEnvelope, deriveMasterKeyAsync } from '@dac-cloud/shared';\nimport type { Logger } from 'pino';\n\nexport interface KafkaHealthStatus {\n  status: 'ok' | 'error' | 'disabled';\n  detail?: string;\n}\n\nexport interface KafkaClient {\n  producer: Producer;\n  consumer: Consumer;\n  connect(): Promise<void>;\n  disconnect(): Promise<void>;\n  subscribe(handler: (topic: string, value: string, key?: string) => Promise<void>): Promise<void>;\n  produce(topic: string, value: string, key?: string): Promise<void>;\n  /** Produce a message encrypted with per-tenant envelope encryption. */\n  produceEncrypted(topic: string, payload: unknown, tenantId: string, key?: string): Promise<void>;\n  setMasterKey(masterKeyHex: string): Promise<void>;\n  /** Lightweight connectivity probe for health checks. */\n  checkHealth(): Promise<KafkaHealthStatus>;\n}\n\nexport function createKafkaClient(\n  brokers: string,\n  username: string,\n  password: string,\n  logger: Logger,\n): KafkaClient {\n  const kafka = new Kafka({\n    clientId: 'dac-orchestrator',\n    brokers: brokers.split(','),\n    ssl: true,\n    sasl: {\n      mechanism: 'scram-sha-256',\n      username,\n      password,\n    },\n    logLevel: logLevel.WARN,\n  });\n\n  const producer = kafka.producer();\n  const consumer = kafka.consumer({ groupId: 'dac-orchestrator' });\n  let masterKey: Buffer | null = null;\n  let connected = false;\n  let lastProduceError: string | null = null;\n\n  // Track produce errors to surface in health checks\n  producer.on('producer.network.request_timeout', () => {\n    lastProduceError = 'request_timeout';\n  });\n\n  return {\n    producer,\n    consumer,\n\n    async setMasterKey(masterKeyHex: string) {\n      masterKey = await deriveMasterKeyAsync(masterKeyHex);\n    },\n\n    async connect() {\n      await producer.connect();\n      await consumer.connect();\n      connected = true;\n      lastProduceError = null;\n      logger.info('Kafka connected');\n    },\n\n    async disconnect() {\n      connected = false;\n      await producer.disconnect();\n      await consumer.disconnect();\n      logger.info('Kafka disconnected');\n    },\n\n    async subscribe(handler: (topic: string, value: string, key?: string) => Promise<void>) {\n      await consumer.subscribe({ topic: TOPICS.EXEC_REQUESTS, fromBeginning: false });\n\n      await consumer.run({\n        eachMessage: async ({ topic, message }: EachMessagePayload) => {\n          const value = message.value?.toString();\n          const key = message.key?.toString();\n          if (value) {\n            try {\n              await handler(topic, value, key);\n            } catch (err) {\n              logger.error({ err, topic, key }, 'Kafka message handler error');\n            }\n          }\n        },\n      });\n\n      logger.info({ topic: TOPICS.EXEC_REQUESTS }, 'Kafka consumer subscribed');\n    },\n\n    async produce(topic: string, value: string, key?: string) {\n      await producer.send({\n        topic,\n        messages: [{\n          key: key || undefined,\n          value,\n        }],\n      });\n    },\n\n    async produceEncrypted(topic: string, payload: unknown, tenantId: string, key?: string) {\n      if (!masterKey) {\n        // Fallback to plaintext if no master key configured\n        await this.produce(topic, JSON.stringify(payload), key);\n        return;\n      }\n      const envelope = sealEnvelope(tenantId, payload, masterKey);\n      await producer.send({\n        topic,\n        messages: [{\n          key: key || undefined,\n          value: JSON.stringify(envelope),\n        }],\n      });\n    },\n\n    async checkHealth(): Promise<KafkaHealthStatus> {\n      if (!connected) return { status: 'error', detail: 'not connected' };\n      if (lastProduceError) return { status: 'error', detail: lastProduceError };\n      return { status: 'ok' };\n    },\n  };\n}\n\n// No-op Kafka client for when Kafka is not configured (local testing)\nexport function createNoopKafkaClient(logger: Logger): KafkaClient {\n  logger.info('Kafka disabled — using no-op client');\n\n  return {\n    producer: {} as Producer,\n    consumer: {} as Consumer,\n    async setMasterKey() {},\n    async connect() {},\n    async disconnect() {},\n    async subscribe() {},\n    async produce(topic: string, value: string) {\n      logger.debug({ topic, valueLength: value.length }, 'No-op Kafka produce');\n    },\n    async produceEncrypted(topic: string, payload: unknown) {\n      logger.debug({ topic }, 'No-op Kafka produceEncrypted');\n    },\n    async checkHealth(): Promise<KafkaHealthStatus> {\n      return { status: 'disabled' };\n    },\n  };\n}\n","numLines":152,"startLine":1,"totalLines":152}}}
[2026-03-18T18:40:34.562Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KPCcDMrNWeaYvxetwdQQPf","type":"tool_result","content":"     1→import http from 'node:http';\n     2→import { nanoid } from 'nanoid';\n     3→import { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\n     4→import type Database from 'better-sqlite3';\n     5→import type { Auth, RequestContext } from './auth.js';\n     6→import type { Dispatcher } from './dispatcher.js';\n     7→import type { WorkerPool } from './workerPool.js';\n     8→import type { TokenManager } from './tokenManager.js';\n     9→import type { OAuthManager } from './oauth.js';\n    10→import type { KafkaClient } from './kafka.js';\n    11→import { handleOAuthRoute } from './oauthHttpHandlers.js';\n    12→import { handleTriggerRoute } from './triggerHttpHandlers.js';\n    13→import type { TriggerSchedulerHandle } from './triggerScheduler.js';\n    14→import type { TenantDbManager } from './tenantDbManager.js';\n    15→import type { TenantKeyManager } from './tenantKeyManager.js';\n    16→import type { AuditLog, AuditEntry, AuditAction } from './auditLog.js';\n    17→import type { EventProcessorHealth } from './eventProcessor.js';\n    18→import type { Logger } from 'pino';\n    19→import * as db from './db/index.js';\n    20→import { readBody, json } from './httpUtils.js';\n    21→\n    22→// --- Route types ---\n    23→\n    24→interface ParsedRoute {\n    25→  resource: string;\n    26→  id?: string;\n    27→  subResource?: string;\n    28→}\n    29→\n    30→type RouteHandler = (\n    31→  req: http.IncomingMessage,\n    32→  res: http.ServerResponse,\n    33→  ctx: RequestContext,\n    34→  route: ParsedRoute | null,\n    35→  queryString: string | undefined,\n    36→  tenantDb: Database.Database | undefined,\n    37→  scopedProjectId: string | undefined,\n    38→  reqLogger: Logger,\n    39→) => Promise<void> | void;\n    40→\n    41→interface RouteEntry {\n    42→  handler: RouteHandler;\n    43→  needsDb?: boolean;\n    44→  adminOnly?: boolean;\n    45→}\n    46→\n    47→/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\n    48→function resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n    49→  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n    50→}\n    51→\n    52→/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\n    53→function parseRoute(pathname: string): ParsedRoute | null {\n    54→  if (!pathname.startsWith('/api/')) return null;\n    55→  const segments = pathname.slice(5).split('/').filter(Boolean);\n    56→  if (segments.length === 0) return null;\n    57→  return {\n    58→    resource: segments[0]!,\n    59→    id: segments[1],\n    60→    subResource: segments[2],\n    61→  };\n    62→}\n    63→\n    64→export function createHttpApi(\n    65→  auth: Auth,\n    66→  dispatcher: Dispatcher,\n    67→  pool: WorkerPool,\n    68→  tokenManager: TokenManager,\n    69→  oauth: OAuthManager,\n    70→  logger: Logger,\n    71→  database?: Database.Database,\n    72→  tenantDbManager?: TenantDbManager,\n    73→  tenantKeyManager?: TenantKeyManager,\n    74→  auditLog?: AuditLog,\n    75→  getEventProcessorHealth?: () => EventProcessorHealth,\n    76→  kafka?: KafkaClient,\n    77→  onEventPublished?: () => void,\n    78→  triggerScheduler?: TriggerSchedulerHandle,\n    79→): http.Server {\n    80→\n    81→  /** Wrap a mutation handler to emit an audit event on successful response. */\n    82→  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    83→    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n    84→      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n    85→      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n    86→        try {\n    87→          auditLog.record({\n    88→            action,\n    89→            tenantId: ctx.projectId || 'default',\n    90→            actor: ctx.userEmail || ctx.projectId,\n    91→            resourceType,\n    92→            resourceId: route?.id,\n    93→            ipAddress: req.socket.remoteAddress,\n    94→          } as AuditEntry);\n    95→        } catch { /* logged inside record() */ }\n    96→      }\n    97→    };\n    98→  }\n    99→\n   100→  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n   101→  const exactRoutes = new Map<string, RouteEntry>();\n   102→\n   103→  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n   104→  for (const [path, method] of [\n   105→    ['/api/oauth/authorize', 'POST'],\n   106→    ['/api/oauth/callback', 'POST'],\n   107→    ['/api/oauth/status', 'GET'],\n   108→    ['/api/oauth/refresh', 'POST'],\n   109→    ['/api/oauth/disconnect', 'DELETE'],\n   110→    ['/api/token', 'POST'],\n   111→  ] as const) {\n   112→    exactRoutes.set(`${method}:${path}`, {\n   113→      adminOnly: true,\n   114→      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   115→        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger, auditLog);\n   116→      },\n   117→    });\n   118→  }\n   119→\n   120→  exactRoutes.set('GET:/api/status', {\n   121→    handler: (_req, res) => {\n   122→      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n   123→    },\n   124→  });\n   125→\n   126→  exactRoutes.set('POST:/api/execute', {\n   127→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n   128→      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n   129→    }, 'execution:submit', 'execution'),\n   130→  });\n   131→\n   132→  exactRoutes.set('POST:/api/gitlab/webhook', {\n   133→    needsDb: true,\n   134→    handler: withHttpAudit(async (req, res, _ctx, _route, _qs, tenantDb) => {\n   135→      const body = await readBody(req);\n   136→      let parsed: Record<string, unknown> = {};\n   137→      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n   138→      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n   139→      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n   140→      const event = db.publishEvent(tenantDb!, {\n   141→        eventType: `gitlab_${objectKind}`,\n   142→        sourceType: 'gitlab',\n   143→        sourceId: projectPath ?? null,\n   144→        payload: body,\n   145→      });\n   146→      onEventPublished?.();\n   147→      json(res, 201, event);\n   148→    }, 'event:publish', 'event'),\n   149→  });\n   150→\n   151→  // Admin routes\n   152→  exactRoutes.set('GET:/api/admin/users', {\n   153→    adminOnly: true,\n   154→    handler: (_req, res) => {\n   155→      if (tenantDbManager) {\n   156→        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n   157→      } else if (database) {\n   158→        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n   159→      } else {\n   160→        json(res, 200, { projectIds: [] });\n   161→      }\n   162→    },\n   163→  });\n   164→\n   165→  exactRoutes.set('GET:/api/admin/personas', {\n   166→    adminOnly: true,\n   167→    handler: (_req, res) => {\n   168→      if (tenantDbManager) {\n   169→        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n   170→        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n   171→        json(res, 200, allPersonas);\n   172→      } else if (database) {\n   173→        json(res, 200, db.listPersonasSummary(database));\n   174→      } else {\n   175→        json(res, 200, []);\n   176→      }\n   177→    },\n   178→  });\n   179→\n   180→  exactRoutes.set('GET:/api/admin/executions', {\n   181→    adminOnly: true,\n   182→    handler: (_req, res, _ctx, _route, queryString) => {\n   183→      const params = new URLSearchParams(queryString || '');\n   184→      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n   185→      if (tenantDbManager) {\n   186→        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n   187→        tenantDbManager.forEachTenant((tDb) => {\n   188→          allExecs.push(...db.listExecutions(tDb, { limit }));\n   189→        });\n   190→        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n   191→        json(res, 200, allExecs.slice(0, limit));\n   192→      } else if (database) {\n   193→        json(res, 200, db.listExecutions(database, {\n   194→          limit,\n   195→          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   196→        }));\n   197→      } else {\n   198→        json(res, 200, []);\n   199→      }\n   200→    },\n   201→  });\n   202→\n   203→  exactRoutes.set('GET:/api/admin/audit', {\n   204→    adminOnly: true,\n   205→    handler: (_req, res, _ctx, _route, queryString) => {\n   206→      if (!auditLog) { json(res, 200, []); return; }\n   207→      const params = new URLSearchParams(queryString || '');\n   208→      json(res, 200, auditLog.query({\n   209→        tenantId: params.get('tenantId') ?? undefined,\n   210→        action: (params.get('action') ?? undefined) as AuditAction | undefined,\n   211→        since: params.get('since') ?? undefined,\n   212→        until: params.get('until') ?? undefined,\n   213→        actor: params.get('actor') ?? undefined,\n   214→        resourceType: params.get('resourceType') ?? undefined,\n   215→        resourceId: params.get('resourceId') ?? undefined,\n   216→        limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n   217→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   218→      }));\n   219→    },\n   220→  });\n   221→\n   222→  exactRoutes.set('GET:/api/admin/audit/stats', {\n   223→    adminOnly: true,\n   224→    handler: (_req, res, _ctx, _route, queryString) => {\n   225→      if (!auditLog) { json(res, 200, { byAction: [], byTenant: [], topActors: [], trend: [] }); return; }\n   226→      const params = new URLSearchParams(queryString || '');\n   227→      const bucket = params.get('bucket') === 'hour' ? 'hour' : 'day';\n   228→      json(res, 200, auditLog.stats({\n   229→        tenantId: params.get('tenantId') ?? undefined,\n   230→        since: params.get('since') ?? undefined,\n   231→        until: params.get('until') ?? undefined,\n   232→        bucket,\n   233→      }));\n   234→    },\n   235→  });\n   236→\n   237→  exactRoutes.set('POST:/api/admin/audit/verify', {\n   238→    adminOnly: true,\n   239→    handler: async (req, res) => {\n   240→      if (!auditLog) { json(res, 200, { valid: true, verifiedCount: 0 }); return; }\n   241→      const body = await readBody(req);\n   242→      let opts: { since?: string; until?: string } | undefined;\n   243→      if (body) {\n   244→        try {\n   245→          const parsed = JSON.parse(body) as { since?: string; until?: string };\n   246→          if (parsed.since || parsed.until) opts = { since: parsed.since, until: parsed.until };\n   247→        } catch { /* empty body or non-JSON — verify entire chain */ }\n   248→      }\n   249→      json(res, 200, auditLog.verify(opts));\n   250→    },\n   251→  });\n   252→\n   253→  // ── Resource route table (O(1) lookup by `METHOD:resource[:id][:sub]`) ──\n   254→  const resourceRoutes = new Map<string, RouteEntry>();\n   255→\n   256→  // --- Persona CRUD ---\n   257→  resourceRoutes.set(resourceKey('GET', 'personas', false), {\n   258→    needsDb: true,\n   259→    handler: (_req, res, _ctx, _route, _qs, tenantDb, scopedProjectId) => {\n   260→      json(res, 200, db.listPersonasSummary(tenantDb!, scopedProjectId));\n   261→    },\n   262→  });\n   263→\n   264→  resourceRoutes.set(resourceKey('POST', 'personas', false), {\n   265→    needsDb: true,\n   266→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   267→      const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n   268→      const persona = createPersonaWithDefaults({\n   269→        ...body,\n   270→        projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n   271→      });\n   272→      db.upsertPersona(tenantDb!, persona);\n   273→      try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: persona.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   274→      reqLogger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n   275→      json(res, 201, persona);\n   276→    },\n   277→  });\n   278→\n   279→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'tools'), {\n   280→    needsDb: true,\n   281→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   282→      json(res, 200, db.getToolsForPersona(tenantDb!, route!.id!));\n   283→    },\n   284→  });\n   285→\n   286→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'tools'), {\n   287→    needsDb: true,\n   288→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   289→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   290→      if (!persona) return;\n   291→      const body = JSON.parse(await readBody(req)) as { toolId: string };\n   292→      db.linkTool(tenantDb!, route!.id!, body.toolId);\n   293→      try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { toolId: body.toolId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   294→      reqLogger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route!.id!, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n   295→      json(res, 200, { linked: true });\n   296→    },\n   297→  });\n   298→\n   299→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'full'), {\n   300→    needsDb: true,\n   301→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   302→      const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb!, route!.id!, reqLogger), scopedProjectId, res);\n   303→      if (!hydrated) return;\n   304→      json(res, 200, hydrated);\n   305→    },\n   306→  });\n   307→\n   308→  resourceRoutes.set(resourceKey('GET', 'personas', true), {\n   309→    needsDb: true,\n   310→    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId) => {\n   311→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   312→      if (!persona) return;\n   313→      json(res, 200, persona);\n   314→    },\n   315→  });\n   316→\n   317→  resourceRoutes.set(resourceKey('DELETE', 'personas', true), {\n   318→    needsDb: true,\n   319→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   320→      db.deletePersona(tenantDb!, route!.id!, scopedProjectId);\n   321→      try { auditLog?.record({ action: 'persona:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   322→      reqLogger.info({ op: 'persona.delete', resourceType: 'persona', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Persona deleted');\n   323→      json(res, 200, { deleted: true });\n   324→    },\n   325→  });\n   326→\n   327→  // --- Persona sub-resources: credentials ---\n   328→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'credentials'), {\n   329→    needsDb: true,\n   330→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   331→      const creds = db.listCredentialsForPersona(tenantDb!, route!.id!);\n   332→      try { auditLog?.record({ action: 'key:access', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   333→      json(res, 200, creds.map(c => ({ ...c, encryptedData: '[REDACTED]', iv: '[REDACTED]', tag: '[REDACTED]' })));\n   334→    },\n   335→  });\n   336→\n   337→  resourceRoutes.set(resourceKey('POST', 'personas', true, 'credentials'), {\n   338→    needsDb: true,\n   339→    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   340→      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n   341→      if (!persona) return;\n   342→      const body = JSON.parse(await readBody(req)) as { credentialId: string };\n   343→      db.linkCredential(tenantDb!, route!.id!, body.credentialId);\n   344→      try { auditLog?.record({ action: 'credential:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { credentialId: body.credentialId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   345→      reqLogger.info({ op: 'persona.linkCredential', resourceType: 'persona', resourceId: route!.id!, credentialId: body.credentialId, projectId: ctx.projectId, status: 200 }, 'Credential linked to persona');\n   346→      json(res, 200, { linked: true });\n   347→    },\n   348→  });\n   349→\n   350→  // --- Persona sub-resources: subscriptions ---\n   351→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'subscriptions'), {\n   352→    needsDb: true,\n   353→    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n   354→      json(res, 200, db.listSubscriptionsForPersona(tenantDb!, route!.id!));\n   355→    },\n   356→  });\n   357→\n   358→  // --- Tool Definitions ---\n   359→  resourceRoutes.set(resourceKey('POST', 'tool-definitions', false), {\n   360→    needsDb: true,\n   361→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   362→      const body = JSON.parse(await readBody(req)) as Partial<PersonaToolDefinition>;\n   363→      const tool = createToolDefinitionWithDefaults(body);\n   364→      db.upsertToolDefinition(tenantDb!, tool);\n   365→      try { auditLog?.record({ action: 'tool-definition:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'toolDefinition', resourceId: tool.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   366→      reqLogger.info({ op: 'toolDefinition.create', resourceType: 'toolDefinition', resourceId: tool.id, projectId: ctx.projectId, status: 201 }, 'Tool definition created');\n   367→      json(res, 201, tool);\n   368→    },\n   369→  });\n   370→\n   371→  // --- Credentials ---\n   372→  resourceRoutes.set(resourceKey('POST', 'credentials', false), {\n   373→    needsDb: true,\n   374→    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n   375→      const body = JSON.parse(await readBody(req));\n   376→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   377→\n   378→      if (!body.plaintext || typeof body.plaintext !== 'string') {\n   379→        json(res, 400, { error: 'Missing required field: plaintext. Credentials must be submitted as plaintext for server-side encryption.' });\n   380→        return;\n   381→      }\n   382→      if (body.plaintext.length > MAX_PLAINTEXT_CHARS) {\n   383→        json(res, 400, { error: `Plaintext exceeds maximum allowed size of ${MAX_PLAINTEXT_CHARS} characters` });\n   384→        return;\n   385→      }\n   386→      if (!tenantKeyManager) {\n   387→        json(res, 503, { error: 'Credential encryption is unavailable. Server key manager is not configured.' });\n   388→        return;\n   389→      }\n   390→\n   391→      delete body.encryptedData;\n   392→      delete body.iv;\n   393→      delete body.tag;\n   394→\n   395→      const tenantId = body.projectId || ctx.projectId || 'default';\n   396→      const key = await tenantKeyManager.getKey(tenantId);\n   397→      const encrypted = encrypt(body.plaintext, key);\n   398→      body.encryptedData = encrypted.encrypted;\n   399→      body.iv = encrypted.iv;\n   400→      body.tag = encrypted.tag;\n   401→      delete body.plaintext;\n   402→\n   403→      const cred = db.createCredential(tenantDb!, body);\n   404→      try { auditLog?.record({ action: 'key:encrypt', tenantId: body.projectId || ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: cred.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   405→      reqLogger.info({ op: 'credential.create', resourceType: 'credential', resourceId: cred.id, projectId: ctx.projectId, status: 201 }, 'Credential created');\n   406→      json(res, 201, cred);\n   407→    },\n   408→  });\n   409→\n   410→  resourceRoutes.set(resourceKey('DELETE', 'credentials', true), {\n   411→    needsDb: true,\n   412→    handler: (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n   413→      const changes = db.deleteCredential(tenantDb!, route!.id!, scopedProjectId);\n   414→      if (changes === 0) { json(res, 404, { error: 'Not found' }); return; }\n   415→      try { auditLog?.record({ action: 'key:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'credential', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   416→      reqLogger.info({ op: 'credential.delete', resourceType: 'credential', resourceId: route!.id!, projectId: ctx.projectId, status: 200 }, 'Credential deleted');\n   417→      json(res, 200, { deleted: true });\n   418→    },\n   419→  });\n   420→\n   421→  // --- Event Subscriptions ---\n   422→  resourceRoutes.set(resourceKey('POST', 'subscriptions', false), {\n   423→    needsDb: true,\n   424→    handler: async (req, res, ctx, _route, _qs, tenantDb) => {\n   425→      const body = JSON.parse(await readBody(req));\n   426→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   427→      const missing: string[] = [];\n   428→      if (!body.personaId || typeof body.personaId !== 'string') missing.push('personaId');\n   429→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   430→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   431→      const sub = db.createSubscription(tenantDb!, body);\n   432→      try { auditLog?.record({ action: 'subscription:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: sub.id, detail: { personaId: body.personaId, eventType: body.eventType }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   433→      json(res, 201, sub);\n   434→    },\n   435→  });\n   436→\n   437→  resourceRoutes.set(resourceKey('PUT', 'subscriptions', true), {\n   438→    needsDb: true,\n   439→    handler: async (req, res, ctx, route, _qs, tenantDb) => {\n   440→      const body = JSON.parse(await readBody(req));\n   441→      db.updateSubscription(tenantDb!, route!.id!, body);\n   442→      const updated = db.getSubscription(tenantDb!, route!.id!);\n   443→      try { auditLog?.record({ action: 'subscription:update', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   444→      json(res, 200, updated);\n   445→    },\n   446→  });\n   447→\n   448→  resourceRoutes.set(resourceKey('DELETE', 'subscriptions', true), {\n   449→    needsDb: true,\n   450→    handler: (req, res, ctx, route, _qs, tenantDb) => {\n   451→      db.deleteSubscription(tenantDb!, route!.id!);\n   452→      try { auditLog?.record({ action: 'subscription:delete', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'subscription', resourceId: route!.id!, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n   453→      json(res, 200, { deleted: true });\n   454→    },\n   455→  });\n   456→\n   457→  // --- Triggers (delegated to triggerHttpHandlers) ---\n   458→  const triggerHandler: RouteHandler = async (req, res, ctx, route, _qs, tenantDb) => {\n   459→    await handleTriggerRoute(route!, req.method!, req, res, tenantDb!, ctx, triggerScheduler);\n   460→  };\n   461→  resourceRoutes.set(resourceKey('POST', 'triggers', false), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:create', 'trigger') });\n   462→  resourceRoutes.set(resourceKey('PUT', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:update', 'trigger') });\n   463→  resourceRoutes.set(resourceKey('DELETE', 'triggers', true), { needsDb: true, handler: withHttpAudit(triggerHandler, 'trigger:delete', 'trigger') });\n   464→  resourceRoutes.set(resourceKey('GET', 'personas', true, 'triggers'), { needsDb: true, handler: triggerHandler });\n   465→\n   466→  // --- Events ---\n   467→  resourceRoutes.set(resourceKey('GET', 'events', false), {\n   468→    needsDb: true,\n   469→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   470→      const params = new URLSearchParams(queryString || '');\n   471→      const events = db.listEvents(tenantDb!, {\n   472→        eventType: params.get('eventType') ?? undefined,\n   473→        status: (params.get('status') ?? undefined) as import('@dac-cloud/shared').EventStatus | undefined,\n   474→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   475→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   476→        projectId: scopedProjectId,\n   477→      });\n   478→      json(res, 200, events);\n   479→    },\n   480→  });\n   481→\n   482→  resourceRoutes.set(resourceKey('POST', 'events', false), {\n   483→    needsDb: true,\n   484→    handler: withHttpAudit(async (req, res, ctx, _route, _qs, tenantDb) => {\n   485→      const body = JSON.parse(await readBody(req));\n   486→      if (ctx.authType === 'user') body.projectId = ctx.projectId;\n   487→      const missing: string[] = [];\n   488→      if (!body.eventType || typeof body.eventType !== 'string') missing.push('eventType');\n   489→      if (!body.sourceType || typeof body.sourceType !== 'string') missing.push('sourceType');\n   490→      if (missing.length > 0) { json(res, 400, { error: `Missing required fields: ${missing.join(', ')}` }); return; }\n   491→      const event = db.publishEvent(tenantDb!, body);\n   492→      onEventPublished?.();\n   493→      json(res, 201, event);\n   494→    }, 'event:publish', 'event'),\n   495→  });\n   496→\n   497→  resourceRoutes.set(resourceKey('PUT', 'events', true), {\n   498→    needsDb: true,\n   499→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   500→      const body = JSON.parse(await readBody(req)) as { status: import('@dac-cloud/shared').EventStatus; metadata?: string };\n   501→      const updated = db.updateEventWithMetadata(tenantDb!, route!.id!, body.status, body.metadata);\n   502→      if (updated) {\n   503→        json(res, 200, updated);\n   504→      } else {\n   505→        res.writeHead(404, { 'Content-Type': 'application/json' });\n   506→        res.end(JSON.stringify({ error: 'Event not found' }));\n   507→      }\n   508→    }, 'event:update', 'event'),\n   509→  });\n   510→\n   511→  // --- Webhooks ---\n   512→  resourceRoutes.set(resourceKey('POST', 'webhooks', true), {\n   513→    needsDb: true,\n   514→    handler: withHttpAudit(async (req, res, _ctx, route, _qs, tenantDb) => {\n   515→      const personaId = route!.id!;\n   516→      const body = await readBody(req);\n   517→      const event = db.publishEvent(tenantDb!, {\n   518→        eventType: 'webhook_received',\n   519→        sourceType: 'webhook',\n   520→        sourceId: personaId,\n   521→        targetPersonaId: personaId,\n   522→        payload: body,\n   523→      });\n   524→      onEventPublished?.();\n   525→      json(res, 201, event);\n   526→    }, 'webhook:receive', 'webhook'),\n   527→  });\n   528→\n   529→  // --- Executions ---\n   530→  resourceRoutes.set(resourceKey('GET', 'executions', false), {\n   531→    needsDb: true,\n   532→    handler: (_req, res, _ctx, _route, queryString, tenantDb, scopedProjectId) => {\n   533→      const params = new URLSearchParams(queryString || '');\n   534→      const executions = db.listExecutions(tenantDb!, {\n   535→        personaId: params.get('personaId') ?? undefined,\n   536→        status: params.get('status') ?? undefined,\n   537→        limit: clampQueryInt(params.get('limit'), 50, MAX_QUERY_LIMIT),\n   538→        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n   539→        projectId: scopedProjectId,\n   540→      });\n   541→      json(res, 200, executions);\n   542→    },\n   543→  });\n   544→\n   545→  resourceRoutes.set(resourceKey('POST', 'executions', true, 'cancel'), {\n   546→    handler: (_req, res, _ctx, route) => {\n   547→      handleCancelExecution(res, dispatcher, route!.id!);\n   548→    },\n   549→  });\n   550→\n   551→  resourceRoutes.set(resourceKey('GET', 'executions', true), {\n   552→    handler: (_req, res, _ctx, route, queryString) => {\n   553→      const params = new URLSearchParams(queryString || '');\n   554→      const offset = parseInt(params.get('offset') || '0', 10);\n   555→      handleGetExecution(res, dispatcher, route!.id!, offset);\n   556→    },\n   557→  });\n   558→\n   559→  // ── Request handler ──\n   560→  const server = http.createServer(async (req, res) => {\n   561→    // Request correlation ID\n   562→    const reqId = nanoid();\n   563→    const reqLogger = logger.child({ reqId });\n   564→    res.setHeader('X-Request-Id', reqId);\n   565→\n   566→    // Security headers\n   567→    res.setHeader('X-Content-Type-Options', 'nosniff');\n   568→\n   569→    // CORS headers\n   570→    const origin = req.headers.origin ?? '';\n   571→    const allowedOrigin = process.env['CORS_ALLOWED_ORIGIN'] || '*';\n   572→    const isAdminRoute = (req.url ?? '').startsWith('/api/admin');\n   573→    if (isAdminRoute) {\n   574→      if (origin && origin === allowedOrigin) {\n   575→        res.setHeader('Access-Control-Allow-Origin', origin);\n   576→      }\n   577→    } else {\n   578→      res.setHeader('Access-Control-Allow-Origin', allowedOrigin);\n   579→    }\n   580→    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');\n   581→    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-User-Token');\n   582→\n   583→    if (req.method === 'OPTIONS') {\n   584→      res.writeHead(204);\n   585→      res.end();\n   586→      return;\n   587→    }\n   588→\n   589→    const url = req.url || '/';\n   590→    const [pathname, queryString] = url.split('?');\n   591→    const route = parseRoute(pathname ?? '');\n   592→\n   593→    // Unauthenticated endpoint\n   594→    if (pathname === '/health' && req.method === 'GET') {\n   595→      await handleHealth(res, pool, dispatcher, oauth, getEventProcessorHealth, database, tenantDbManager, kafka, triggerScheduler);\n   596→      return;\n   597→    }\n   598→\n   599→    // Auth check\n   600→    const ctx = auth.validateAndExtractContext(req);\n   601→    if (!ctx) {\n   602→      res.writeHead(401, { 'Content-Type': 'application/json' });\n   603→      res.end(JSON.stringify({ error: 'Unauthorized', reqId }));\n   604→      return;\n   605→    }\n   606→\n   607→    const scopedProjectId = ctx.authType === 'admin' ? undefined : ctx.projectId;\n   608→\n   609→    const resolveDatabase = (projectId?: string): Database.Database | undefined => {\n   610→      if (tenantDbManager && projectId) {\n   611→        return tenantDbManager.getTenantDb(projectId);\n   612→      }\n   613→      return database;\n   614→    };\n   615→    const tenantDb = resolveDatabase(ctx.projectId);\n   616→\n   617→    try {\n   618→      // O(1) exact-path lookup\n   619→      const exactEntry = exactRoutes.get(`${req.method}:${pathname}`);\n   620→      if (exactEntry) {\n   621→        if (exactEntry.adminOnly && requireAdmin(ctx, res)) return;\n   622→        if (exactEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   623→        await exactEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   624→        return;\n   625→      }\n   626→\n   627→      // O(1) resource-route lookup\n   628→      if (route) {\n   629→        const resKey = resourceKey(req.method!, route.resource, !!route.id, route.subResource);\n   630→        const resEntry = resourceRoutes.get(resKey);\n   631→        if (resEntry) {\n   632→          if (resEntry.adminOnly && requireAdmin(ctx, res)) return;\n   633→          if (resEntry.needsDb && !tenantDb) { json(res, 404, { error: 'Not found', reqId }); return; }\n   634→          await resEntry.handler(req, res, ctx, route, queryString, tenantDb, scopedProjectId, reqLogger);\n   635→          return;\n   636→        }\n   637→      }\n   638→\n   639→      // No matching route\n   640→      json(res, 404, { error: 'Not found', reqId });\n   641→    } catch (err) {\n   642→      if (err instanceof Error && err.message === 'Payload too large') {\n   643→        res.writeHead(413, { 'Content-Type': 'application/json' });\n   644→        res.end(JSON.stringify({ error: 'Payload too large', reqId }));\n   645→        return;\n   646→      }\n   647→      if (err instanceof Error && err.message.includes('UNIQUE constraint failed')) {\n   648→        res.writeHead(409, { 'Content-Type': 'application/json' });\n   649→        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists', reqId }));\n   650→        return;\n   651→      }\n   652→      reqLogger.error({ err, url }, 'HTTP handler error');\n   653→      res.writeHead(500, { 'Content-Type': 'application/json' });\n   654→      res.end(JSON.stringify({ error: 'Internal server error', reqId }));\n   655→    }\n   656→  });\n   657→\n   658→  return server;\n   659→}\n   660→\n   661→/**\n   662→ * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n   663→ * Returns the entity on success, or null after sending a 404 response.\n   664→ */\n   665→function withScopedEntity<T extends { projectId?: string | null }>(\n   666→  entity: T | undefined,\n   667→  scopedProjectId: string | undefined,\n   668→  res: http.ServerResponse,\n   669→): T | null {\n   670→  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n   671→    json(res, 404, { error: 'Not found' });\n   672→    return null;\n   673→  }\n   674→  return entity;\n   675→}\n   676→\n   677→/** Returns true (and sends 403) if the caller is NOT an admin. */\n   678→function requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n   679→  if (ctx.authType !== 'admin') {\n   680→    res.writeHead(403, { 'Content-Type': 'application/json' });\n   681→    res.end(JSON.stringify({ error: 'Admin access required' }));\n   682→    return true;\n   683→  }\n   684→  return false;\n   685→}\n   686→\n   687→// --- Existing handlers ---\n   688→\n   689→/** Heartbeat age (ms) beyond which a worker is considered stale. */\n   690→const STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n   691→\n   692→async function handleHealth(\n   693→  res: http.ServerResponse,\n   694→  pool: WorkerPool,\n   695→  dispatcher: Dispatcher,\n   696→  oauth: OAuthManager,\n   697→  getEventProcessorHealth?: () => EventProcessorHealth,\n   698→  database?: Database.Database,\n   699→  tenantDbManager?: TenantDbManager,\n   700→  kafka?: KafkaClient,\n   701→  triggerScheduler?: TriggerSchedulerHandle,\n   702→): Promise<void> {\n   703→  const issues: string[] = [];\n   704→\n   705→  const counts = pool.getWorkerCount();\n   706→  const workers = pool.getWorkers();\n   707→  const now = Date.now();\n   708→  const staleWorkers = workers\n   709→    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n   710→    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n   711→\n   712→  if (staleWorkers.length > 0) {\n   713→    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n   714→  }\n   715→\n   716→  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n   717→  if (database) {\n   718→    try {\n   719→      database.prepare('SELECT 1').get();\n   720→      dbHealth.status = 'ok';\n   721→    } catch {\n   722→      dbHealth.status = 'error';\n   723→      issues.push('database unreachable');\n   724→    }\n   725→  }\n   726→  if (tenantDbManager) {\n   727→    try {\n   728→      const tenantIds = tenantDbManager.listTenantIds();\n   729→      dbHealth.tenantCount = tenantIds.length;\n   730→      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n   731→    } catch {\n   732→      dbHealth.tenantCount = -1;\n   733→      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n   734→      issues.push('tenant DB listing failed');\n   735→    }\n   736→  }\n   737→\n   738→  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n   739→  if (kafka) {\n   740→    const kh = await kafka.checkHealth();\n   741→    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n   742→    if (kh.status === 'error') {\n   743→      issues.push(`kafka: ${kh.detail || 'error'}`);\n   744→    }\n   745→  }\n   746→\n   747→  const queueDepth = dispatcher.getQueueLength();\n   748→  const activeExecutions = dispatcher.getActiveExecutions().length;\n   749→\n   750→  let eventProcessorHealth: EventProcessorHealth | undefined;\n   751→  if (getEventProcessorHealth) {\n   752→    eventProcessorHealth = getEventProcessorHealth();\n   753→  }\n   754→\n   755→  let verdict: 'healthy' | 'degraded' | 'unhealthy';\n   756→  if (issues.some(i => i.includes('database unreachable') || i.includes('kafka: '))) {\n   757→    verdict = 'unhealthy';\n   758→  } else if (issues.length > 0) {\n   759→    verdict = 'degraded';\n   760→  } else {\n   761→    verdict = 'healthy';\n   762→  }\n   763→\n   764→  const body: Record<string, unknown> = {\n   765→    status: verdict,\n   766→    timestamp: Date.now(),\n   767→    dependencies: {\n   768→      database: dbHealth,\n   769→      kafka: kafkaHealth,\n   770→      workers: {\n   771→        ...counts,\n   772→        staleWorkers: staleWorkers.length > 0 ? staleWorkers : undefined,\n   773→      },\n   774→    },\n   775→    queue: {\n   776→      depth: queueDepth,\n   777→      activeExecutions,\n   778→    },\n   779→    hasSubscription: oauth.hasTokens(),\n   780→  };\n   781→\n   782→  if (eventProcessorHealth) {\n   783→    (body.dependencies as Record<string, unknown>).eventProcessor = eventProcessorHealth;\n   784→  }\n   785→\n   786→  if (triggerScheduler) {\n   787→    (body as Record<string, unknown>).scheduler = triggerScheduler.getMetrics();\n   788→  }\n   789→\n   790→  if (issues.length > 0) {\n   791→    body.issues = issues;\n   792→  }\n   793→\n   794→  const httpStatus = verdict === 'unhealthy' ? 503 : 200;\n   795→  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n   796→  res.end(JSON.stringify(body));\n   797→}\n   798→\n   799→function handleStatus(\n   800→  res: http.ServerResponse,\n   801→  pool: WorkerPool,\n   802→  dispatcher: Dispatcher,\n   803→  tokenManager: TokenManager,\n   804→  oauth: OAuthManager,\n   805→): void {\n   806→  const oauthTokens = oauth.getTokens();\n   807→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   808→  res.end(JSON.stringify({\n   809→    workers: pool.getWorkers(),\n   810→    workerCounts: pool.getWorkerCount(),\n   811→    workerPoolMetrics: pool.getMetrics(),\n   812→    queueLength: dispatcher.getQueueLength(),\n   813→    activeExecutions: dispatcher.getActiveExecutions(),\n   814→    hasClaudeToken: tokenManager.hasToken(),\n   815→    oauth: {\n   816→      connected: oauth.hasTokens(),\n   817→      scopes: oauthTokens?.scopes || [],\n   818→      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n   819→    },\n   820→  }));\n   821→}\n   822→\n   823→async function handleExecute(\n   824→  req: http.IncomingMessage,\n   825→  res: http.ServerResponse,\n   826→  dispatcher: Dispatcher,\n   827→  logger: Logger,\n   828→  ctx?: RequestContext,\n   829→): Promise<void> {\n   830→  const body = await readBody(req);\n   831→  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n   832→\n   833→  try {\n   834→    parsed = JSON.parse(body);\n   835→  } catch {\n   836→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   837→    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n   838→    return;\n   839→  }\n   840→\n   841→  if (!parsed.prompt) {\n   842→    res.writeHead(400, { 'Content-Type': 'application/json' });\n   843→    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n   844→    return;\n   845→  }\n   846→\n   847→  const request: ExecRequest = {\n   848→    executionId: nanoid(),\n   849→    personaId: parsed.personaId || 'manual',\n   850→    prompt: parsed.prompt,\n   851→    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n   852→    config: {\n   853→      timeoutMs: parsed.timeoutMs || 300_000,\n   854→    },\n   855→  };\n   856→\n   857→  dispatcher.submit(request);\n   858→\n   859→  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n   860→\n   861→  res.writeHead(202, { 'Content-Type': 'application/json' });\n   862→  res.end(JSON.stringify({\n   863→    executionId: request.executionId,\n   864→    status: 'queued',\n   865→  }));\n   866→}\n   867→\n   868→function handleGetExecution(\n   869→  res: http.ServerResponse,\n   870→  dispatcher: Dispatcher,\n   871→  executionId: string,\n   872→  offset: number = 0,\n   873→): void {\n   874→  const exec = dispatcher.getExecution(executionId);\n   875→\n   876→  if (!exec) {\n   877→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   878→    res.end(JSON.stringify({ error: 'Execution not found' }));\n   879→    return;\n   880→  }\n   881→\n   882→  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n   883→\n   884→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   885→  res.end(JSON.stringify({\n   886→    executionId,\n   887→    status: exec.status,\n   888→    outputLines: exec.output.length,\n   889→    output,\n   890→    durationMs: exec.durationMs,\n   891→    sessionId: exec.sessionId,\n   892→    totalCostUsd: exec.totalCostUsd,\n   893→    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n   894→  }));\n   895→}\n   896→\n   897→function handleCancelExecution(\n   898→  res: http.ServerResponse,\n   899→  dispatcher: Dispatcher,\n   900→  executionId: string,\n   901→): void {\n   902→  const cancelled = dispatcher.cancelExecution(executionId);\n   903→\n   904→  if (!cancelled) {\n   905→    res.writeHead(404, { 'Content-Type': 'application/json' });\n   906→    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n   907→    return;\n   908→  }\n   909→\n   910→  res.writeHead(200, { 'Content-Type': 'application/json' });\n   911→  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n   912→}\n   913→\n   914→const MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB\n   915→const MAX_QUERY_LIMIT = 500;\n   916→const MAX_QUERY_OFFSET = 100_000;\n   917→\n   918→/** Parse an integer query param and clamp it to safe bounds. */\n   919→function clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n   920→  if (!value) return defaultValue;\n   921→  const parsed = parseInt(value, 10);\n   922→  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n   923→  return Math.min(parsed, max);\n   924→}\n   925→"}]},"parent_tool_use_id":null,"session_id":"605152c5-6e13-4552-9149-cc731512a899","uuid":"8648d89d-ba3d-4317-8287-23bfc46815d4","timestamp":"2026-03-18T18:40:34.483Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\httpApi.ts","content":"import http from 'node:http';\nimport { nanoid } from 'nanoid';\nimport { encrypt, createPersonaWithDefaults, createToolDefinitionWithDefaults, type ExecRequest, type Persona, type PersonaToolDefinition } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { Auth, RequestContext } from './auth.js';\nimport type { Dispatcher } from './dispatcher.js';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport { handleOAuthRoute } from './oauthHttpHandlers.js';\nimport { handleTriggerRoute } from './triggerHttpHandlers.js';\nimport type { TriggerSchedulerHandle } from './triggerScheduler.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog, AuditEntry, AuditAction } from './auditLog.js';\nimport type { EventProcessorHealth } from './eventProcessor.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\nimport { readBody, json } from './httpUtils.js';\n\n// --- Route types ---\n\ninterface ParsedRoute {\n  resource: string;\n  id?: string;\n  subResource?: string;\n}\n\ntype RouteHandler = (\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  ctx: RequestContext,\n  route: ParsedRoute | null,\n  queryString: string | undefined,\n  tenantDb: Database.Database | undefined,\n  scopedProjectId: string | undefined,\n  reqLogger: Logger,\n) => Promise<void> | void;\n\ninterface RouteEntry {\n  handler: RouteHandler;\n  needsDb?: boolean;\n  adminOnly?: boolean;\n}\n\n/** Build a lookup key for resource-based routes: `METHOD:resource[:id][:subResource]` */\nfunction resourceKey(method: string, resource: string, hasId: boolean, subResource?: string): string {\n  return `${method}:${resource}${hasId ? ':id' : ''}${subResource ? ':' + subResource : ''}`;\n}\n\n/** Parse `/api/{resource}[/{id}[/{subResource}]]` into structured parts. */\nfunction parseRoute(pathname: string): ParsedRoute | null {\n  if (!pathname.startsWith('/api/')) return null;\n  const segments = pathname.slice(5).split('/').filter(Boolean);\n  if (segments.length === 0) return null;\n  return {\n    resource: segments[0]!,\n    id: segments[1],\n    subResource: segments[2],\n  };\n}\n\nexport function createHttpApi(\n  auth: Auth,\n  dispatcher: Dispatcher,\n  pool: WorkerPool,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n  logger: Logger,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  tenantKeyManager?: TenantKeyManager,\n  auditLog?: AuditLog,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  kafka?: KafkaClient,\n  onEventPublished?: () => void,\n  triggerScheduler?: TriggerSchedulerHandle,\n): http.Server {\n\n  /** Wrap a mutation handler to emit an audit event on successful response. */\n  function withHttpAudit(handler: RouteHandler, action: AuditAction, resourceType: string): RouteHandler {\n    return async (req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger) => {\n      await handler(req, res, ctx, route, qs, tenantDb, scopedProjectId, reqLogger);\n      if (res.statusCode >= 200 && res.statusCode < 300 && auditLog) {\n        try {\n          auditLog.record({\n            action,\n            tenantId: ctx.projectId || 'default',\n            actor: ctx.userEmail || ctx.projectId,\n            resourceType,\n            resourceId: route?.id,\n            ipAddress: req.socket.remoteAddress,\n          } as AuditEntry);\n        } catch { /* logged inside record() */ }\n      }\n    };\n  }\n\n  // ── Exact-path route table (O(1) lookup by `METHOD:/path`) ──\n  const exactRoutes = new Map<string, RouteEntry>();\n\n  // OAuth + token injection (admin-only, delegated to oauthHttpHandlers)\n  for (const [path, method] of [\n    ['/api/oauth/authorize', 'POST'],\n    ['/api/oauth/callback', 'POST'],\n    ['/api/oauth/status', 'GET'],\n    ['/api/oauth/refresh', 'POST'],\n    ['/api/oauth/disconnect', 'DELETE'],\n    ['/api/token', 'POST'],\n  ] as const) {\n    exactRoutes.set(`${method}:${path}`, {\n      adminOnly: true,\n      handler: async (req, res, _ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n        await handleOAuthRoute(path, method, req, res, oauth, tokenManager, reqLogger, auditLog);\n      },\n    });\n  }\n\n  exactRoutes.set('GET:/api/status', {\n    handler: (_req, res) => {\n      handleStatus(res, pool, dispatcher, tokenManager, oauth);\n    },\n  });\n\n  exactRoutes.set('POST:/api/execute', {\n    handler: withHttpAudit(async (req, res, ctx, _route, _qs, _tenantDb, _scopedProjectId, reqLogger) => {\n      await handleExecute(req, res, dispatcher, reqLogger, ctx);\n    }, 'execution:submit', 'execution'),\n  });\n\n  exactRoutes.set('POST:/api/gitlab/webhook', {\n    needsDb: true,\n    handler: withHttpAudit(async (req, res, _ctx, _route, _qs, tenantDb) => {\n      const body = await readBody(req);\n      let parsed: Record<string, unknown> = {};\n      try { parsed = JSON.parse(body); } catch { /* raw payload */ }\n      const objectKind = (parsed['object_kind'] as string) || 'unknown';\n      const projectPath = (parsed['project'] as Record<string, unknown>)?.['path_with_namespace'] as string | undefined;\n      const event = db.publishEvent(tenantDb!, {\n        eventType: `gitlab_${objectKind}`,\n        sourceType: 'gitlab',\n        sourceId: projectPath ?? null,\n        payload: body,\n      });\n      onEventPublished?.();\n      json(res, 201, event);\n    }, 'event:publish', 'event'),\n  });\n\n  // Admin routes\n  exactRoutes.set('GET:/api/admin/users', {\n    adminOnly: true,\n    handler: (_req, res) => {\n      if (tenantDbManager) {\n        json(res, 200, { projectIds: tenantDbManager.listTenantIds() });\n      } else if (database) {\n        json(res, 200, { projectIds: db.listDistinctProjectIds(database) });\n      } else {\n        json(res, 200, { projectIds: [] });\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/personas', {\n    adminOnly: true,\n    handler: (_req, res) => {\n      if (tenantDbManager) {\n        const allPersonas: import('@dac-cloud/shared').PersonaSummary[] = [];\n        tenantDbManager.forEachTenant((tDb) => { allPersonas.push(...db.listPersonasSummary(tDb)); });\n        json(res, 200, allPersonas);\n      } else if (database) {\n        json(res, 200, db.listPersonasSummary(database));\n      } else {\n        json(res, 200, []);\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/executions', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      const params = new URLSearchParams(queryString || '');\n      const limit = clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT);\n      if (tenantDbManager) {\n        const allExecs: import('@dac-cloud/shared').PersonaExecution[] = [];\n        tenantDbManager.forEachTenant((tDb) => {\n          allExecs.push(...db.listExecutions(tDb, { limit }));\n        });\n        allExecs.sort((a, b) => b.createdAt.localeCompare(a.createdAt));\n        json(res, 200, allExecs.slice(0, limit));\n      } else if (database) {\n        json(res, 200, db.listExecutions(database, {\n          limit,\n          offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n        }));\n      } else {\n        json(res, 200, []);\n      }\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/audit', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      if (!auditLog) { json(res, 200, []); return; }\n      const params = new URLSearchParams(queryString || '');\n      json(res, 200, auditLog.query({\n        tenantId: params.get('tenantId') ?? undefined,\n        action: (params.get('action') ?? undefined) as AuditAction | undefined,\n        since: params.get('since') ?? undefined,\n        until: params.get('until') ?? undefined,\n        actor: params.get('actor') ?? undefined,\n        resourceType: params.get('resourceType') ?? undefined,\n        resourceId: params.get('resourceId') ?? undefined,\n        limit: clampQueryInt(params.get('limit'), 100, MAX_QUERY_LIMIT),\n        offset: clampQueryInt(params.get('offset'), 0, MAX_QUERY_OFFSET),\n      }));\n    },\n  });\n\n  exactRoutes.set('GET:/api/admin/audit/stats', {\n    adminOnly: true,\n    handler: (_req, res, _ctx, _route, queryString) => {\n      if (!auditLog) { json(res, 200, { byAction: [], byTenant: [], topActors: [], trend: [] }); return; }\n      const params = new URLSearchParams(queryString || '');\n      const bucket = params.get('bucket') === 'hour' ? 'hour' : 'day';\n      json(res, 200, auditLog.stats({\n        tenantId: params.get('tenantId') ?? undefined,\n        since: params.get('since') ?? undefined,\n        until: params.get('until') ?? undefined,\n        bucket,\n      }));\n    },\n  });\n\n  exactRoutes.set('POST:/api/admin/audit/verify', {\n    adminOnly: true,\n    handler: async (req, res) => {\n      if (!auditLog) { json(res, 200, { valid: true, verifiedCount: 0 }); return; }\n      const body = await readBody(req);\n      let opts: { since?: string; until?: string } | undefined;\n      if (body) {\n        try {\n          const parsed = JSON.parse(body) as { since?: string; until?: string };\n          if (parsed.since || parsed.until) opts = { since: parsed.since, until: parsed.until };\n        } catch { /* empty body or non-JSON — verify entire chain */ }\n      }\n      json(res, 200, auditLog.verify(opts));\n    },\n  });\n\n  // ── Resource route table (O(1) lookup by `METHOD:resource[:id][:sub]`) ──\n  const resourceRoutes = new Map<string, RouteEntry>();\n\n  // --- Persona CRUD ---\n  resourceRoutes.set(resourceKey('GET', 'personas', false), {\n    needsDb: true,\n    handler: (_req, res, _ctx, _route, _qs, tenantDb, scopedProjectId) => {\n      json(res, 200, db.listPersonasSummary(tenantDb!, scopedProjectId));\n    },\n  });\n\n  resourceRoutes.set(resourceKey('POST', 'personas', false), {\n    needsDb: true,\n    handler: async (req, res, ctx, _route, _qs, tenantDb, _scopedProjectId, reqLogger) => {\n      const body = JSON.parse(await readBody(req)) as Partial<Persona>;\n      const persona = createPersonaWithDefaults({\n        ...body,\n        projectIdOverride: ctx.authType === 'user' ? ctx.projectId : undefined,\n      });\n      db.upsertPersona(tenantDb!, persona);\n      try { auditLog?.record({ action: 'persona:create', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: persona.id, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'persona.create', resourceType: 'persona', resourceId: persona.id, projectId: ctx.projectId, status: 201 }, 'Persona created');\n      json(res, 201, persona);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'tools'), {\n    needsDb: true,\n    handler: (_req, res, _ctx, route, _qs, tenantDb) => {\n      json(res, 200, db.getToolsForPersona(tenantDb!, route!.id!));\n    },\n  });\n\n  resourceRoutes.set(resourceKey('POST', 'personas', true, 'tools'), {\n    needsDb: true,\n    handler: async (req, res, ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      const persona = withScopedEntity(db.getPersona(tenantDb!, route!.id!), scopedProjectId, res);\n      if (!persona) return;\n      const body = JSON.parse(await readBody(req)) as { toolId: string };\n      db.linkTool(tenantDb!, route!.id!, body.toolId);\n      try { auditLog?.record({ action: 'tool:link', tenantId: ctx.projectId || 'default', actor: ctx.userEmail || ctx.projectId, resourceType: 'persona', resourceId: route!.id!, detail: { toolId: body.toolId }, ipAddress: req.socket.remoteAddress }); } catch { /* logged inside record() */ }\n      reqLogger.info({ op: 'persona.linkTool', resourceType: 'persona', resourceId: route!.id!, toolId: body.toolId, projectId: ctx.projectId, status: 200 }, 'Tool linked to persona');\n      json(res, 200, { linked: true });\n    },\n  });\n\n  resourceRoutes.set(resourceKey('GET', 'personas', true, 'full'), {\n    needsDb: true,\n    handler: (_req, res, _ctx, route, _qs, tenantDb, scopedProjectId, reqLogger) => {\n      const hydrated = withScopedEntity(db.getHydratedPersona(tenantDb!, route!.id!, reqLogger), scopedProjectId, res);\n      if (!hydrated) return;\n      json(res, 200, hydrated);\n    },\n  });\n\n  resourceRoutes.set(resourceKey('GET', 'personas', true), {\n    needsDb: true,\n    handler: (