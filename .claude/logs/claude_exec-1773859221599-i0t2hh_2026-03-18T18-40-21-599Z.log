th > 0 && this.queue.length >= maxQueueDepth) {","+      this.logger.warn({","+        executionId: request.executionId,","+        personaId: request.personaId,","+        queueDepth: this.queue.length,","+        maxQueueDepth,","+        projectId,","+      }, 'Submission rejected: queue depth limit exceeded');","+      return { accepted: false, reason: 'queue_full', retryAfterSeconds };","+    }","+","+    // Per-tenant quota","+    if (perTenantQuota > 0) {","+      const tenantCount = this.tenantQueueCounts.get(projectId) ?? 0;","+      if (tenantCount >= perTenantQuota) {","+        this.logger.warn({","+          executionId: request.executionId,","+          personaId: request.personaId,","+          projectId,","+          tenantQueueCount: tenantCount,","+          perTenantQuota,","+        }, 'Submission rejected: per-tenant queue quota exceeded');","+        return { accepted: false, reason: 'tenant_quota_exceeded', retryAfterSeconds };","+      }","+    }","+","     this.logger.info({","       executionId: request.executionId,","       personaId: request.personaId,"]},{"oldStart":465,"oldLines":7,"newStart":497,"newLines":6,"lines":["     }, 'Execution submitted');"," ","     // Track which tenant owns this execution (for callback DB resolution)","-    const projectId = request.projectId || 'default';","     this.executionTenant.set(request.executionId, projectId);"," ","     // Create DB record immediately"]},{"oldStart":494,"oldLines":7,"newStart":525,"newLines":10,"lines":["     });"," ","     this.queue.push({ request, receivedAt: Date.now() });","+    this.incrementTenantCount(projectId);","+    this.checkThresholds();","     this.processQueue();","+    return { accepted: true };","   }"," ","   private async processQueue(): Promise<void> {"]}],"userModified":false,"replaceAll":false}}
