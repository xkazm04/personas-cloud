[2026-03-19T08:16:10.469Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ScQdybN3bTLiiB9mGZeFPd","type":"tool_result","content":"     1→import pino from 'pino';\n     2→import { loadConfig } from './config.js';\n     3→import { createAuth } from './auth.js';\n     4→import { createTokenManager } from './tokenManager.js';\n     5→import { OAuthManager } from './oauth.js';\n     6→import { WorkerPool, type WorkerPoolEvents } from './workerPool.js';\n     7→import { createKafkaClient, createNoopKafkaClient } from './kafka.js';\n     8→import { Dispatcher } from './dispatcher.js';\n     9→import { createHttpApi } from './httpApi.js';\n    10→import { TenantDbManager } from './tenantDbManager.js';\n    11→import { TenantKeyManager, type TenantKeyEvents } from './tenantKeyManager.js';\n    12→import { AuditLog } from './auditLog.js';\n    13→import { AuditPolicy } from './auditPolicy.js';\n    14→import { AuditRetentionPolicy } from './auditRetentionPolicy.js';\n    15→import { startRetentionJob } from './retention.js';\n    16→import { startEventProcessor } from './eventProcessor.js';\n    17→import { startTriggerScheduler } from './triggerScheduler.js';\n    18→import { loadTlsConfig } from './tls.js';\n    19→import { TOPICS, type ExecRequest } from '@dac-cloud/shared';\n    20→\n    21→const logger = pino({ level: process.env['LOG_LEVEL'] || 'info' });\n    22→\n    23→async function main() {\n    24→  logger.info('Starting DAC Cloud Orchestrator...');\n    25→\n    26→  // Load configuration\n    27→  const config = loadConfig();\n    28→  logger.info({\n    29→    kafkaEnabled: config.kafkaEnabled,\n    30→    wsPort: config.wsPort,\n    31→    httpPort: config.httpPort,\n    32→    hasDirectToken: !!config.claudeToken,\n    33→  }, 'Configuration loaded');\n    34→\n    35→  // Initialize components\n    36→  const auth = createAuth(config.teamApiKey, config.supabaseJwtSecret || undefined);\n    37→  const tokenManager = await createTokenManager(config.masterKey, logger);\n    38→  const oauth = new OAuthManager(logger);\n    39→\n    40→  // If a direct Claude token is provided (from setup-token), store it\n    41→  if (config.claudeToken) {\n    42→    tokenManager.storeClaudeToken(config.claudeToken);\n    43→    logger.info('Direct Claude token loaded from environment');\n    44→  } else {\n    45→    logger.info('No direct Claude token — use OAuth flow via POST /api/oauth/authorize');\n    46→  }\n    47→\n    48→  // Tenant-isolated database manager\n    49→  const tenantDbManager = new TenantDbManager(config.dataDir, logger);\n    50→  logger.info({ dataDir: config.dataDir }, 'Tenant DB manager initialized');\n    51→\n    52→  // Worker pool (WebSocket server)\n    53→  const pool = new WorkerPool(config.workerToken, logger, {\n    54→    allowedDigests: config.allowedImageDigests,\n    55→    rejectUnverified: config.rejectUnverifiedWorkers,\n    56→  });\n    57→\n    58→  // Kafka client\n    59→  const kafka = config.kafkaEnabled\n    60→    ? createKafkaClient(config.kafkaBrokers, config.kafkaUsername, config.kafkaPassword, logger)\n    61→    : createNoopKafkaClient(logger);\n    62→\n    63→  // Audit log (separate append-only DB)\n    64→  const auditLog = new AuditLog(config.auditDbPath, logger);\n    65→  const auditRetention = new AuditRetentionPolicy(auditLog, config.auditRetentionDays, logger);\n    66→  auditRetention.startDailyPurge();\n    67→\n    68→  // Wire audit log into OAuth manager for token lifecycle events\n    69→  oauth.setAuditLog(auditLog, config.tokenExpiryWarningMinutes);\n    70→\n    71→  // Per-tenant key manager (cached key derivation with TTL)\n    72→  const tenantKeyManager = new TenantKeyManager(config.masterKey, logger);\n    73→\n    74→  // Declarative audit policy — maps emitter events to audit entries\n    75→  const auditPolicy = new AuditPolicy(auditLog);\n    76→\n    77→  auditPolicy.attach<TenantKeyEvents>(tenantKeyManager, {\n    78→    'key:derived': (e) => ({ action: 'key:derive', tenantId: e.tenantId }),\n    79→  });\n    80→\n    81→  auditPolicy.attach<WorkerPoolEvents>(pool, {\n    82→    'worker-connected': (info) => ({ action: 'worker:connected', detail: { workerId: info.workerId } }),\n    83→    'worker-disconnected': (workerId, executionId) => ({ action: 'worker:disconnected', detail: { workerId }, resourceId: executionId }),\n    84→  });\n    85→\n    86→  // Wire tenant ID source for key pre-warming and proactive renewal\n    87→  await tenantKeyManager.setTenantIdSource(() => tenantDbManager.listTenantIds());\n    88→  // Eagerly warm key cache when a new tenant is registered\n    89→  tenantDbManager.setTenantCreatedCallback((tenantId) => tenantKeyManager.warmTenant(tenantId));\n    90→\n    91→  // Dispatcher — uses OAuth manager for token refresh\n    92→  const dispatcher = new Dispatcher(pool, tokenManager, oauth, kafka, logger, {\n    93→    maxQueueDepth: config.maxQueueDepth,\n    94→    warningThreshold: config.queueWarningThreshold,\n    95→    criticalThreshold: config.queueCriticalThreshold,\n    96→    perTenantQuota: config.perTenantQueueQuota,\n    97→    retryAfterSeconds: config.queueRetryAfterSeconds,\n    98→  });\n    99→  dispatcher.setTenantDbManager(tenantDbManager);\n   100→  await dispatcher.setMasterKey(config.masterKey);\n   101→  dispatcher.setTenantKeyManager(tenantKeyManager);\n   102→  dispatcher.setAuditLog(auditLog);\n   103→\n   104→  // Connect Kafka\n   105→  if (config.kafkaEnabled) {\n   106→    await kafka.connect();\n   107→\n   108→    // Subscribe to execution requests\n   109→    await kafka.subscribe(async (topic: string, value: string) => {\n   110→      if (topic === TOPICS.EXEC_REQUESTS) {\n   111→        try {\n   112→          const request: ExecRequest = JSON.parse(value);\n   113→          const result = dispatcher.submit(request);\n   114→          if (!result.accepted) {\n   115→            logger.warn({ executionId: request.executionId, reason: result.reason }, 'Kafka execution rejected by backpressure, sending to DLQ');\n   116→            await kafka.produce(TOPICS.DLQ, JSON.stringify({\n   117→              originalTopic: TOPICS.EXEC_REQUESTS,\n   118→              reason: result.reason,\n   119→              payload: request,\n   120→              timestamp: Date.now(),\n   121→            }), request.executionId);\n   122→          }\n   123→        } catch (err) {\n   124→          logger.error({ err }, 'Failed to parse execution request from Kafka');\n   125→        }\n   126→      }\n   127→    });\n   128→  }\n   129→\n   130→  // Load TLS config and start WebSocket server for workers\n   131→  const tlsConfig = loadTlsConfig(logger);\n   132→  pool.listen(config.wsPort, tlsConfig.enabled ? tlsConfig : undefined);\n   133→\n   134→  // Start HTTP API (now includes OAuth endpoints + persona CRUD)\n   135→  // Set master key on Kafka for envelope encryption\n   136→  await kafka.setMasterKey(config.masterKey);\n   137→\n   138→  // Start event processor (demand-driven with 30s backstop) — tenant-aware\n   139→  const eventProcessor = startEventProcessor(null, dispatcher, logger, 30_000, tenantDbManager);\n   140→\n   141→  // Start heap-driven trigger scheduler — builds in-memory min-heap from DB on startup\n   142→  const triggerScheduler = startTriggerScheduler(null, logger, undefined, tenantDbManager, eventProcessor.nudge);\n   143→\n   144→  const httpServer = createHttpApi(auth, dispatcher, pool, tokenManager, oauth, logger, undefined, tenantDbManager, tenantKeyManager, auditLog, eventProcessor.getHealth, kafka, eventProcessor.nudge, triggerScheduler);\n   145→  httpServer.listen(config.httpPort, () => {\n   146→    logger.info({ port: config.httpPort }, 'HTTP API listening');\n   147→  });\n   148→\n   149→  // Start daily retention job (purge old executions/events, aggregate metrics)\n   150→  const retentionTimer = startRetentionJob(tenantDbManager, config.retentionDays, logger);\n   151→\n   152→  // Token refresh loop — refresh OAuth token proactively every 30 minutes\n   153→  setInterval(async () => {\n   154→    if (oauth.hasTokens()) {\n   155→      const token = await oauth.getValidAccessToken();\n   156→      if (token) {\n   157→        tokenManager.storeClaudeToken(token);\n   158→      }\n   159→    }\n   160→  }, 30 * 60 * 1000);\n   161→\n   162→  // Log status periodically\n   163→  setInterval(() => {\n   164→    const counts = pool.getWorkerCount();\n   165→    const queueLen = dispatcher.getQueueLength();\n   166→    if (counts.total > 0 || queueLen > 0) {\n   167→      logger.info({\n   168→        workers: counts,\n   169→        queueLength: queueLen,\n   170→        activeExecutions: dispatcher.getActiveExecutions().length,\n   171→        hasOAuth: oauth.hasTokens(),\n   172→      }, 'Status');\n   173→    }\n   174→\n   175→    // Database health stats — early warning for unbounded growth\n   176→    try {\n   177→      const dbHealth = tenantDbManager.getHealthStats();\n   178→\n   179→      // Audit DB size\n   180→      let auditSizeBytes = 0;\n   181→      let auditRowCount = 0;\n   182→      try {\n   183→        const auditDb = auditLog.getDb();\n   184→        const sizeRow = auditDb.prepare('SELECT page_count * page_size AS size FROM pragma_page_count(), pragma_page_size()').get() as { size: number } | undefined;\n   185→        auditSizeBytes = sizeRow?.size ?? 0;\n   186→        const countRow = auditDb.prepare('SELECT COUNT(*) AS cnt FROM audit_events').get() as { cnt: number };\n   187→        auditRowCount = countRow.cnt;\n   188→      } catch { /* audit DB stats are best-effort */ }\n   189→\n   190→      const oldestAgeDays = dbHealth.oldestUnpurgedAgeMs !== null\n   191→        ? Math.round(dbHealth.oldestUnpurgedAgeMs / (1000 * 60 * 60 * 24) * 10) / 10\n   192→        : null;\n   193→\n   194→      logger.info({\n   195→        totalSizeMB: Math.round(dbHealth.totalSizeBytes / (1024 * 1024)