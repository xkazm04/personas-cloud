[2026-03-19T08:18:00.629Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017SEX2QZefCAh8g32qN1ExS","type":"tool_result","content":"   400→    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n   401→\n   402→    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled, hash-chain active)');\n   403→  }\n   404→\n   405→  /** Expose the underlying database for use by RetentionPolicy. */\n   406→  getDb(): Database.Database {\n   407→    return this.db;\n   408→  }\n   409→\n   410→  /** Health snapshot — a nonzero droppedEvents value means the audit trail has gaps. */\n   411→  getHealth(): AuditLogHealth {\n   412→    return {\n   413→      droppedEvents: this.droppedEvents,\n   414→      bufferedEvents: this.buffer.length,\n   415→    };\n   416→  }\n   417→\n   418→  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n   419→  countEvents(before?: string): number {\n   420→    const stmt = before\n   421→      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n   422→      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n   423→    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n   424→    return row.cnt;\n   425→  }\n   426→\n   427→  /**\n   428→   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   429→   * yielding the event loop between batches so concurrent DB operations\n   430→   * are not starved during large purges.\n   431→   */\n   432→  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n   433→    const deleteChunk = this.db.prepare(\n   434→      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n   435→    );\n   436→    let totalDeleted = 0;\n   437→    while (true) {\n   438→      const result = deleteChunk.run(cutoff, chunkSize);\n   439→      totalDeleted += result.changes;\n   440→      if (result.changes < chunkSize) break;\n   441→      await new Promise<void>((resolve) => setImmediate(resolve));\n   442→    }\n   443→    return totalDeleted;\n   444→  }\n   445→\n   446→  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n   447→  record(entry: AuditEntry): void {\n   448→    this.buffer.push({\n   449→      timestamp: new Date().toISOString(),\n   450→      action: entry.action,\n   451→      tenantId: entry.tenantId ?? null,\n   452→      actor: entry.actor ?? null,\n   453→      resourceType: 'resourceType' in entry ? entry.resourceType : null,\n   454→      resourceId: 'resourceId' in entry ? (entry.resourceId ?? null) : null,\n   455→      detail: 'detail' in entry ? JSON.stringify(entry.detail) : null,\n   456→      ipAddress: entry.ipAddress ?? null,\n   457→    });\n   458→    if (this.buffer.length >= BUFFER_FLUSH_SIZE) {\n   459→      this.flush();\n   460→    }\n   461→  }\n   462→\n   463→  /** Flush buffered entries to SQLite in a single transaction, computing chain hashes. */\n   464→  flush(): void {\n   465→    if (this.buffer.length === 0) return;\n   466→    const batch = this.buffer;\n   467→    this.buffer = [];\n   468→\n   469→    // Compute chain hashes for the batch\n   470→    const hashes: string[] = [];\n   471→    let prevHash = this.lastHash;\n   472→    for (const entry of batch) {\n   473→      prevHash = computeChainHash(prevHash, entry);\n   474→      hashes.push(prevHash);\n   475→    }\n   476→\n   477→    const flushStart = performance.now();\n   478→    try {\n   479→      this.batchInsert(batch, hashes);\n   480→      this.lastHash = prevHash;\n   481→      this.totalEventsWritten += batch.length;\n   482→    } catch (err) {\n   483→      this.droppedEvents += batch.length;\n   484→      this.logger.error({ err, count: batch.length, totalDropped: this.droppedEvents }, 'Audit batch write failed — audit trail gap');\n   485→    }\n   486→   