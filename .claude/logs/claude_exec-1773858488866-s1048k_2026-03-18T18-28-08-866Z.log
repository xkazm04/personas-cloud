) {\n        res.writeHead(409, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ error: 'Conflict: a resource with the same unique identifier already exists', reqId }));\n        return;\n      }\n      reqLogger.error({ err, url }, 'HTTP handler error');\n      res.writeHead(500, { 'Content-Type': 'application/json' });\n      res.end(JSON.stringify({ error: 'Internal server error', reqId }));\n    }\n  });\n\n  return server;\n}\n\n/**\n * Checks that an entity exists and belongs to the scoped project (if scoping is active).\n * Returns the entity on success, or null after sending a 404 response.\n */\nfunction withScopedEntity<T extends { projectId?: string | null }>(\n  entity: T | undefined,\n  scopedProjectId: string | undefined,\n  res: http.ServerResponse,\n): T | null {\n  if (!entity || (scopedProjectId && entity.projectId !== scopedProjectId)) {\n    json(res, 404, { error: 'Not found' });\n    return null;\n  }\n  return entity;\n}\n\n/** Returns true (and sends 403) if the caller is NOT an admin. */\nfunction requireAdmin(ctx: RequestContext, res: http.ServerResponse): boolean {\n  if (ctx.authType !== 'admin') {\n    res.writeHead(403, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Admin access required' }));\n    return true;\n  }\n  return false;\n}\n\n// --- Existing handlers ---\n\n/** Heartbeat age (ms) beyond which a worker is considered stale. */\nconst STALE_HEARTBEAT_THRESHOLD_MS = 60_000;\n\nasync function handleHealth(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  oauth: OAuthManager,\n  getEventProcessorHealth?: () => EventProcessorHealth,\n  database?: Database.Database,\n  tenantDbManager?: TenantDbManager,\n  kafka?: KafkaClient,\n  triggerScheduler?: TriggerSchedulerHandle,\n): Promise<void> {\n  const issues: string[] = [];\n\n  const counts = pool.getWorkerCount();\n  const workers = pool.getWorkers();\n  const now = Date.now();\n  const staleWorkers = workers\n    .filter(w => (now - w.lastHeartbeat) > STALE_HEARTBEAT_THRESHOLD_MS)\n    .map(w => ({ workerId: w.workerId, heartbeatAgeMs: now - w.lastHeartbeat }));\n\n  if (staleWorkers.length > 0) {\n    issues.push(`${staleWorkers.length} worker(s) with stale heartbeat`);\n  }\n\n  const dbHealth: Record<string, unknown> = { status: 'unavailable' };\n  if (database) {\n    try {\n      database.prepare('SELECT 1').get();\n      dbHealth.status = 'ok';\n    } catch {\n      dbHealth.status = 'error';\n      issues.push('database unreachable');\n    }\n  }\n  if (tenantDbManager) {\n    try {\n      const tenantIds = tenantDbManager.listTenantIds();\n      dbHealth.tenantCount = tenantIds.length;\n      if (dbHealth.status === 'unavailable') dbHealth.status = 'ok';\n    } catch {\n      dbHealth.tenantCount = -1;\n      if (dbHealth.status !== 'error') dbHealth.status = 'error';\n      issues.push('tenant DB listing failed');\n    }\n  }\n\n  let kafkaHealth: Record<string, unknown> = { status: 'disabled' };\n  if (kafka) {\n    const kh = await kafka.checkHealth();\n    kafkaHealth = { status: kh.status, ...(kh.detail ? { detail: kh.detail } : {}) };\n    if (kh.status === 'error') {\n      issues.push(`kafka: ${kh.detail || 'error'}`);\n    }\n  }\n\n  const queueDepth = dispatcher.getQueueLength();\n  const activeExecutions = dispatcher.getActiveExecutions().length;\n\n  let eventProcessorHealth: EventProcessorHealth | undefined;\n  if (getEventProcessorHealth) {\n    eventProcessorHealth = getEventProcessorHealth();\n  }\n\n  let verdict: 'healthy' | 'degraded' | 'unhealthy';\n  if (issues.some(i => i.includes('database unreachable') || i.includes('kafka: '))) {\n    verdict = 'unhealthy';\n  } else if (issues.length > 0) {\n    verdict = 'degraded';\n  } else {\n    verdict = 'healthy';\n  }\n\n  const body: Record<string, unknown> = {\n    status: verdict,\n    timestamp: Date.now(),\n    dependencies: {\n      database: dbHealth,\n      kafka: kafkaHealth,\n      workers: {\n        ...counts,\n        staleWorkers: staleWorkers.length > 0 ? staleWorkers : undefined,\n      },\n    },\n    queue: {\n      depth: queueDepth,\n      activeExecutions,\n    },\n    hasSubscription: oauth.hasTokens(),\n  };\n\n  if (eventProcessorHealth) {\n    (body.dependencies as Record<string, unknown>).eventProcessor = eventProcessorHealth;\n  }\n\n  if (issues.length > 0) {\n    body.issues = issues;\n  }\n\n  const httpStatus = verdict === 'unhealthy' ? 503 : 200;\n  res.writeHead(httpStatus, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify(body));\n}\n\nfunction handleStatus(\n  res: http.ServerResponse,\n  pool: WorkerPool,\n  dispatcher: Dispatcher,\n  tokenManager: TokenManager,\n  oauth: OAuthManager,\n): void {\n  const oauthTokens = oauth.getTokens();\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    workers: pool.getWorkers(),\n    workerCounts: pool.getWorkerCount(),\n    workerPoolMetrics: pool.getMetrics(),\n    queueLength: dispatcher.getQueueLength(),\n    activeExecutions: dispatcher.getActiveExecutions(),\n    hasClaudeToken: tokenManager.hasToken(),\n    oauth: {\n      connected: oauth.hasTokens(),\n      scopes: oauthTokens?.scopes || [],\n      expiresAt: oauthTokens ? new Date(oauthTokens.expiresAt).toISOString() : null,\n    },\n  }));\n}\n\nasync function handleExecute(\n  req: http.IncomingMessage,\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  logger: Logger,\n  ctx?: RequestContext,\n): Promise<void> {\n  const body = await readBody(req);\n  let parsed: { prompt?: string; personaId?: string; timeoutMs?: number };\n\n  try {\n    parsed = JSON.parse(body);\n  } catch {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Invalid JSON body' }));\n    return;\n  }\n\n  if (!parsed.prompt) {\n    res.writeHead(400, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Missing required field: prompt' }));\n    return;\n  }\n\n  const request: ExecRequest = {\n    executionId: nanoid(),\n    personaId: parsed.personaId || 'manual',\n    prompt: parsed.prompt,\n    projectId: ctx?.authType === 'user' ? ctx.projectId : undefined,\n    config: {\n      timeoutMs: parsed.timeoutMs || 300_000,\n    },\n  };\n\n  dispatcher.submit(request);\n\n  logger.info({ executionId: request.executionId }, 'Execution submitted via HTTP');\n\n  res.writeHead(202, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId: request.executionId,\n    status: 'queued',\n  }));\n}\n\nfunction handleGetExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n  offset: number = 0,\n): void {\n  const exec = dispatcher.getExecution(executionId);\n\n  if (!exec) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found' }));\n    return;\n  }\n\n  const output = offset > 0 ? exec.output.slice(offset) : exec.output;\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({\n    executionId,\n    status: exec.status,\n    outputLines: exec.output.length,\n    output,\n    durationMs: exec.durationMs,\n    sessionId: exec.sessionId,\n    totalCostUsd: exec.totalCostUsd,\n    ...(exec.phaseTimings ? { phaseTimings: exec.phaseTimings } : {}),\n  }));\n}\n\nfunction handleCancelExecution(\n  res: http.ServerResponse,\n  dispatcher: Dispatcher,\n  executionId: string,\n): void {\n  const cancelled = dispatcher.cancelExecution(executionId);\n\n  if (!cancelled) {\n    res.writeHead(404, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ error: 'Execution not found or not running' }));\n    return;\n  }\n\n  res.writeHead(200, { 'Content-Type': 'application/json' });\n  res.end(JSON.stringify({ executionId, status: 'cancelling' }));\n}\n\nconst MAX_PLAINTEXT_CHARS = 64 * 1024; // 64 KB\nconst MAX_QUERY_LIMIT = 500;\nconst MAX_QUERY_OFFSET = 100_000;\n\n/** Parse an integer query param and clamp it to safe bounds. */\nfunction clampQueryInt(value: string | null, defaultValue: number, max: number): number {\n  if (!value) return defaultValue;\n  const parsed = parseInt(value, 10);\n  if (!Number.isFinite(parsed) || parsed < 0) return defaultValue;\n  return Math.min(parsed, max);\n}\n","numLines":886,"startLine":1,"totalLines":886}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017Thxti5RhaVkYGbBUa33a6","type":"tool_result","content":"     1→// ---------------------------------------------------------------------------\n     2→// Persona domain types (mirroring desktop Tauri models)\n     3→// ---------------------------------------------------------------------------\n     4→\n     5→export interface Persona {\n     6→  id: string;\n     7→  projectId: string;\n     8→  name: string;\n     9→  description: string | null;\n    10→  systemPrompt: string;\n    11→  structuredPrompt: string | null;\n    12→  icon: string | null;\n    13→  color: string | null;\n    14→  enabled: boolean;\n    15→  maxConcurrent: number;\n    16→  timeoutMs: number;\n    17→  inferenceProfileId: string | null;\n    18→  networkPolicy: string | null;\n    19→  maxBudgetUsd: number | null;\n    20→  maxTurns: number | null;\n    21→  designContext: string | null;\n    22→  groupId: string | null;\n    23→  createdAt: string;\n    24→  updatedAt: string;\n    25→}\n    26→\n    27→/** Lightweight projection for list views — omits large text fields. */\n    28→export interface PersonaSummary {\n    29→  id: string;\n    30→  projectId: string;\n    31→  name: string;\n    32→  description: string | null;\n    33→  icon: string | null;\n    34→  color: string | null;\n    35→  enabled: boolean;\n    36→  groupId: string | null;\n    37→}\n    38→\n    39→export interface PersonaToolDefinition {\n    40→  id: string;\n    41→  name: string;\n    42→  category: string;\n    43→  description: string;\n    44→  scriptPath: string;\n    45→  inputSchema: string | null;\n    46→  outputSchema: string | null;\n    47→  requiresCredentialType: string | null;\n    48→  implementationGuide: string | null;\n    49→  isBuiltin: boolean;\n    50→  createdAt: string;\n    51→  updatedAt: string;\n    52→}\n    53→\n    54→export interface StructuredPrompt {\n    55→  identity?: string;\n    56→  instructions?: string;\n    57→  toolGuidance?: string;\n    58→  examples?: string;\n    59→  errorHandling?: string;\n    60→  customSections?: Array<{ title?: string; label?: string; name?: string; key?: string; content?: string }>;\n    61→  webSearch?: string;\n    62→}\n    63→\n    64→// ---------------------------------------------------------------------------\n    65→// Inference profiles\n    66→// ---------------------------------------------------------------------------\n    67→\n    68→export type InferenceProvider = 'claude' | 'ollama' | 'litellm' | 'openai-compatible' | 'custom';\n    69→\n    70→export interface InferenceProviderEnvMapping {\n    71→  envVar: string;\n    72→  source: 'baseUrl' | 'authToken' | 'model';\n    73→}\n    74→\n    75→export interface InferenceProfile {\n    76→  id: string;\n    77→  projectId: string;\n    78→  name: string;\n    79→  provider: InferenceProvider;\n    80→  model?: string;\n    81→  baseUrl?: string;\n    82→  authTokenEncrypted?: string;\n    83→  authTokenIv?: string;\n    84→  authTokenTag?: string;\n    85→  envMappings: InferenceProviderEnvMapping[];\n    86→  removeEnvKeys?: string[];\n    87→  isPreset: boolean;\n    88→  createdAt: string;\n    89→  updatedAt: string;\n    90→}\n    91→\n    92→export interface PersonaCredential {\n    93→  id: string;\n    94→  projectId?: string;\n    95→  name: string;\n    96→  serviceType: string;\n    97→  encryptedData: string;\n    98→  iv: string;\n    99→  tag: string;\n   100→  metadata: string | null;\n   101→  lastUsedAt: string | null;\n   102→  createdAt: string;\n   103→  updatedAt: string;\n   104→}\n   105→\n   106→// ---------------------------------------------------------------------------\n   107→// Event lifecycle state machine\n   108→// ---------------------------------------------------------------------------\n   109→\n   110→/** All valid event statuses. */\n   111→export type EventStatus = 'pending' | 'processing' | 'delivered' | 'skipped' | 'failed' | 'partial' | 'partial-retry';\n   112→\n   113→/** All valid EventStatus values as a runtime array (for CHECK constraints, etc.). */\n   114→export const EVENT_STATUSES: readonly EventStatus[] = [\n   115→  'pending', 'processing', 'delivered', 'skipped', 'failed', 'partial', 'partial-retry',\n   116→] as const;\n   117→\n   118→/**\n   119→ * Legal state transitions for persona events.\n   120→ * Key = current status, Value = set of statuses it may transition to.\n   121→ */\n   122→export const EVENT_TRANSITIONS: Readonly<Record<EventStatus, ReadonlySet<EventStatus>>> = {\n   123→  'pending':       new Set<EventStatus>(['processing']),\n   124→  'processing':    new Set<EventStatus>(['delivered', 'skipped', 'failed', 'partial', 'partial-retry', 'pending']),\n   125→  'delivered':     new Set<EventStatus>([]),                       // terminal\n   126→  'skipped':       new Set<EventStatus>([]),                       // terminal\n   127→  'failed':        new Set<EventStatus>([]),                       // terminal\n   128→  'partial':       new Set<EventStatus>(['partial-retry']),        // can retry partial failures\n   129→  'partial-retry': new Set<EventStatus>(['processing']),           // retried partial goes back through processing\n   130→};\n   131→\n   132→/**\n   133→ * Validate that a transition from `from` → `to` is legal.\n   134→ * Throws if the transition is invalid.\n   135→ */\n   136→export function validateEventTransition(from: EventStatus, to: EventStatus): void {\n   137→  const allowed = EVENT_TRANSITIONS[from];\n   138→  if (!allowed || !allowed.has(to)) {\n   139→    throw new Error(`Invalid event status transition: '${from}' → '${to}'`);\n   140→  }\n   141→}\n   142→\n   143→export interface PersonaEvent {\n   144→  id: string;\n   145→  projectId: string;\n   146→  eventType: string;\n   147→  sourceType: string;\n   148→  sourceId: string | null;\n   149→  targetPersonaId: string | null;\n   150→  payload: string | null;\n   151→  status: EventStatus;\n   152→  errorMessage: string | null;\n   153→  processedAt: string | null;\n   154→  useCaseId: string | null;\n   155→  retryAfter: string | null;\n   156→  retryCount: number;\n   157→  createdAt: string;\n   158→}\n   159→\n   160→export interface PersonaEventSubscription {\n   161→  id: string;\n   162→  personaId: string;\n   163→  eventType: string;\n   164→  sourceFilter: string | null;\n   165→  enabled: boolean;\n   166→  useCaseId: string | null;\n   167→  createdAt: string;\n   168→  updatedAt: string;\n   169→}\n   170→\n   171→// ---------------------------------------------------------------------------\n   172→// Trigger config discriminated union\n   173→// ---------------------------------------------------------------------------\n   174→\n   175→export type TriggerType = 'manual' | 'schedule' | 'polling' | 'webhook' | 'chain';\n   176→\n   177→interface TriggerConfigBase {\n   178→  event_type?: string;\n   179→  payload?: unknown;\n   180→}\n   181→\n   182→export interface ScheduleTriggerConfig extends TriggerConfigBase {\n   183→  kind: 'schedule';\n   184→  cron?: string;\n   185→  interval_seconds?: number;\n   186→}\n   187→\n   188→export interface ManualTriggerConfig extends TriggerConfigBase {\n   189→  kind: 'manual';\n   190→}\n   191→\n   192→export interface PollingTriggerConfig extends TriggerConfigBase {\n   193→  kind: 'polling';\n   194→  poll_url?: string;\n   195→  poll_interval_seconds?: number;\n   196→}\n   197→\n   198→export interface WebhookTriggerConfig extends TriggerConfigBase {\n   199→  kind: 'webhook';\n   200→  url?: string;\n   201→  secret?: string;\n   202→}\n   203→\n   204→export interface ChainTriggerConfig extends TriggerConfigBase {\n   205→  kind: 'chain';\n   206→  source_persona_id?: string;\n   207→  source_event_type?: string;\n   208→}\n   209→\n   210→export type TriggerConfig =\n   211→  | ScheduleTriggerConfig\n   212→  | ManualTriggerConfig\n   213→  | PollingTriggerConfig\n   214→  | WebhookTriggerConfig\n   215→  | ChainTriggerConfig;\n   216→\n   217→export interface PersonaTrigger {\n   218→  id: string;\n   219→  personaId: string;\n   220→  triggerType: TriggerType;\n   221→  config: string | null;\n   222→  enabled: boolean;\n   223→  lastTriggeredAt: string | null;\n   224→  nextTriggerAt: string | null;\n   225→  useCaseId: string | null;\n   226→  createdAt: string;\n   227→  updatedAt: string;\n   228→}\n   229→\n   230→/** Fully hydrated persona with all related entities. */\n   231→export interface HydratedPersona extends Persona {\n   232→  tools: PersonaToolDefinition[];\n   233→  credentials: Omit<PersonaCredential, 'encryptedData' | 'iv' | 'tag'>[];\n   234→  subscriptions: PersonaEventSubscription[];\n   235→  triggers: PersonaTrigger[];\n   236→}\n   237→\n   238→export interface PersonaExecution {\n   239→  id: string;\n   240→  projectId?: string;\n   241→  personaId: string;\n   242→  triggerId: string | null;\n   243→  useCaseId: string | null;\n   244→  /** Originating event ID — enables bidirectional event↔execution tracing. */\n   245→  eventId: string | null;\n   246→  status: string;\n   247→  inputData: string | null;\n   248→  outputData: string | null;\n   249→  claudeSessionId: string | null;\n   250→  modelUsed: string | null;\n   251→  inputTokens: number;\n   252→  outputTokens: number;\n   253→  costUsd: number;\n   254→  errorMessage: string | null;\n   255→  durationMs: number | null;\n   256→  retryOfExecutionId: string | null;\n   257→  retryCount: number;\n   258→  startedAt: string | null;\n   259→  completedAt: string | null;\n   260→  createdAt: string;\n   261→}\n   262→\n   263→// ---------------------------------------------------------------------------\n   264→// Execution request — produced to Kafka by Vibeman, consumed by orchestrator\n   265→// ---------------------------------------------------------------------------\n   266→\n   267→export interface ExecRequest {\n   268→  executionId: string;\n   269→  personaId: string;\n   270→  prompt: string;\n   271→  projectId?: string;\n   272→  credentialIds?: string[];\n   273→  inputData?: unknown;\n   274→  config: {\n   275→    timeoutMs: number;\n   276→    maxConcurrent?: number;\n   277→  };\n   278→  triggerId?: string;\n   279→  triggerType?: string;\n   280→  /** Originating event ID — enables bidirectional event↔execution tracing. */\n   281→  eventId?: string;\n   282→}\n   283→\n   284→// Execution result — produced to Kafka by orchestrator\n   285→export interface ExecResult {\n   286→  executionId: string;\n   287→  personaId: string;\n   288→  status: 'completed' | 'failed' | 'cancelled';\n   289→  exitCode: number;\n   290→  durationMs: number;\n   291→  sessionId?: string;\n   292→  totalCostUsd?: number;\n   293→  phaseTimings?: import('./protocol.js').PhaseTimings;\n   294→  error?: string;\n   295→}\n   296→\n   297→// Worker info as tracked by orchestrator\n   298→export interface WorkerInfo {\n   299→  workerId: string;\n   300→  status: 'connecting' | 'idle' | 'executing' | 'disconnected';\n   301→  version: string;\n   302→  capabilities: string[];\n   303→  currentExecutionId?: string;\n   304→  connectedAt: number;\n   305→  lastHeartbeat: number;\n   306→  imageDigest?: string;\n   307→  claudeCliVersion?: string;\n   308→  verified: boolean;\n   309→}\n   310→\n   311→// Execution output chunk — produced to Kafka for Vibeman SSE consumption\n   312→export interface OutputChunk {\n   313→  executionId: string;\n   314→  chunk: string;\n   315→  timestamp: number;\n   316→}\n   317→\n   318→// Persona event — forwarded from worker to Kafka event bus\n   319→export interface PersonaCloudEvent {\n   320→  executionId: string;\n   321→  personaId: string;\n   322→  eventType: import('./protocolRegistry.js').ProtocolEventType;\n   323→  payload: unknown;\n   324→  timestamp: number;\n   325→}\n   326→\n   327→// Execution progress (ephemeral — tracked in-memory + Kafka only)\n   328→export interface ProgressInfo {\n   329→  phase: string;\n   330→  percent: number;\n   331→  detail?: string;\n   332→  updatedAt: number;\n   333→}\n   334→\n   335→// Kafka topic names\n   336→export const TOPICS = {\n   337→  EXEC_REQUESTS: 'persona.exec.v1',\n   338→  EXEC_OUTPUT: 'persona.output.v1',\n   339→  EXEC_LIFECYCLE: 'persona.lifecycle.v1',\n   340→  EXEC_PROGRESS: 'persona.progress.v1',\n   341→  EVENTS: 'persona.events.v1',\n   342→  DLQ: 'persona.dlq.v1',\n   343→} as const;\n   344→\n   345→// Protocol version\n   346→export const PROTOCOL_VERSION = '0.2.0';\n   347→"}]},"parent_tool_use_id":null,"session_id":"6dd816c1-b554-488e-a9b3-8bdcd96f90b4","uuid":"d55d5600-ae8c-4e57-b1dc-6c20a544f1d5","timestamp":"2026-03-18T18:28:21.004Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\shared\\src\\types.ts","content":"// ---------------------------------------------------------------------------\n// Persona domain types (mirroring desktop Tauri models)\n// ---------------------------------------------------------------------------\n\nexport interface Persona {\n  id: string;\n  projectId: string;\n  name: string;\n  description: string | null;\n  systemPrompt: string;\n  structuredPrompt: string | null;\n  icon: string | null;\n  color: string | null;\n  enabled: boolean;\n  maxConcurrent: number;\n  timeoutMs: number;\n  inferenceProfileId: string | null;\n  networkPolicy: string | null;\n  maxBudgetUsd: number | null;\n  maxTurns: number | null;\n  designContext: string | null;\n  groupId: string | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\n/** Lightweight projection for list views — omits large text fields. */\nexport interface PersonaSummary {\n  id: string;\n  projectId: string;\n  name: string;\n  description: string | null;\n  icon: string | null;\n  color: string | null;\n  enabled: boolean;\n  groupId: string | null;\n}\n\nexport interface PersonaToolDefinition {\n  id: string;\n  name: string;\n  category: string;\n  description: string;\n  scriptPath: string;\n  inputSchema: string | null;\n  outputSchema: string | null;\n  requiresCredentialType: string | null;\n  implementationGuide: string | null;\n  isBuiltin: boolean;\n  createdAt: string;\n  updatedAt: string;\n}\n\nexport interface StructuredPrompt {\n  identity?: string;\n  instructions?: string;\n  toolGuidance?: string;\n  examples?: string;\n  errorHandling?: string;\n  customSections?: Array<{ title?: string; label?: string; name?: string; key?: string; content?: string }>;\n  webSearch?: string;\n}\n\n// ---------------------------------------------------------------------------\n// Inference profiles\n// ---------------------------------------------------------------------------\n\nexport type InferenceProvider = 'claude' | 'ollama' | 'litellm' | 'openai-compatible' | 'custom';\n\nexport interface InferenceProviderEnvMapping {\n  envVar: string;\n  source: 'baseUrl' | 'authToken' | 'model';\n}\n\nexport interface InferenceProfile {\n  id: string;\n  projectId: string;\n  name: string;\n  provider: InferenceProvider;\n  model?: string;\n  baseUrl?: string;\n  authTokenEncrypted?: string;\n  authTokenIv?: string;\n  authTokenTag?: string;\n  envMappings: InferenceProviderEnvMapping[];\n  removeEnvKeys?: string[];\n  isPreset: boolean;\n  createdAt: string;\n  updatedAt: string;\n}\n\nexport interface PersonaCredential {\n  id: string;\n  projectId?: string;\n  name: string;\n  serviceType: string;\n  encryptedData: string;\n  iv: string;\n  tag: string;\n  metadata: string | null;\n  lastUsedAt: string | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\n// ---------------------------------------------------------------------------\n// Event lifecycle state machine\n// ---------------------------------------------------------------------------\n\n/** All valid event statuses. */\nexport type EventStatus = 'pending' | 'processing' | 'delivered' | 'skipped' | 'failed' | 'partial' | 'partial-retry';\n\n/** All valid EventStatus values as a runtime array (for CHECK constraints, etc.). */\nexport const EVENT_STATUSES: readonly EventStatus[] = [\n  'pending', 'processing', 'delivered', 'skipped', 'failed', 'partial', 'partial-retry',\n] as const;\n\n/**\n * Legal state transitions for persona events.\n * Key = current status, Value = set of statuses it may transition to.\n */\nexport const EVENT_TRANSITIONS: Readonly<Record<EventStatus, ReadonlySet<EventStatus>>> = {\n  'pending':       new Set<EventStatus>(['processing']),\n  'processing':    new Set<EventStatus>(['delivered', 'skipped', 'failed', 'partial', 'partial-retry', 'pending']),\n  'delivered':     new Set<EventStatus>([]),                       // terminal\n  'skipped':       new Set<EventStatus>([]),                       // terminal\n  'failed':        new Set<EventStatus>([]),                       // terminal\n  'partial':       new Set<EventStatus>(['partial-retry']),        // can retry partial failures\n  'partial-retry': new Set<EventStatus>(['processing']),           // retried partial goes back through processing\n};\n\n/**\n * Validate that a transition from `from` → `to` is legal.\n * Throws if the transition is invalid.\n */\nexport function validateEventTransition(from: EventStatus, to: EventStatus): void {\n  const allowed = EVENT_TRANSITIONS[from];\n  if (!allowed || !allowed.has(to)) {\n    throw new Error(`Invalid event status transition: '${from}' → '${to}'`);\n  }\n}\n\nexport interface PersonaEvent {\n  id: string;\n  projectId: string;\n  eventType: string;\n  sourceType: string;\n  sourceId: string | null;\n  targetPersonaId: string | null;\n  payload: string | null;\n  status: EventStatus;\n  errorMessage: string | null;\n  processedAt: string | null;\n  useCaseId: string | null;\n  retryAfter: string | null;\n  retryCount: number;\n  createdAt: string;\n}\n\nexport interface PersonaEventSubscription {\n  id: string;\n  personaId: string;\n  eventType: string;\n  sourceFilter: string | null;\n  enabled: boolean;\n  useCaseId: string | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\n// ---------------------------------------------------------------------------\n// Trigger config discriminated union\n// ---------------------------------------------------------------------------\n\nexport type TriggerType = 'manual' | 'schedule' | 'polling' | 'webhook' | 'chain';\n\ninterface TriggerConfigBase {\n  event_type?: string;\n  payload?: unknown;\n}\n\nexport interface ScheduleTriggerConfig extends TriggerConfigBase {\n  kind: 'schedule';\n  cron?: string;\n  interval_seconds?: number;\n}\n\nexport interface ManualTriggerConfig extends TriggerConfigBase {\n  kind: 'manual';\n}\n\nexport interface PollingTriggerConfig extends TriggerConfigBase {\n  kind: 'polling';\n  poll_url?: string;\n  poll_interval_seconds?: number;\n}\n\nexport interface WebhookTriggerConfig extends TriggerConfigBase {\n  kind: 'webhook';\n  url?: string;\n  secret?: string;\n}\n\nexport interface ChainTriggerConfig extends TriggerConfigBase {\n  kind: 'chain';\n  source_persona_id?: string;\n  source_event_type?: string;\n}\n\nexport type TriggerConfig =\n  | ScheduleTriggerConfig\n  | ManualTriggerConfig\n  | PollingTriggerConfig\n  | WebhookTriggerConfig\n  | ChainTriggerConfig;\n\nexport interface PersonaTrigger {\n  id: string;\n  personaId: string;\n  triggerType: TriggerType;\n  config: string | null;\n  enabled: boolean;\n  lastTriggeredAt: string | null;\n  nextTriggerAt: string | null;\n  useCaseId: string | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\n/** Fully hydrated persona with all related entities. */\nexport interface HydratedPersona extends Persona {\n  tools: PersonaToolDefinition[];\n  credentials: Omit<PersonaCredential, 'encryptedData' | 'iv' | 'tag'>[];\n  subscriptions: PersonaEventSubscription[];\n  triggers: PersonaTrigger[];\n}\n\nexport interface PersonaExecution {\n  id: string;\n  projectId?: string;\n  personaId: string;\n  triggerId: string | null;\n  useCaseId: string | null;\n  /** Originating event ID — enables bidirectional event↔execution tracing. */\n  eventId: string | null;\n  status: string;\n  inputData: string | null;\n  outputData: string | null;\n  claudeSessionId: string | null;\n  modelUsed: string | null;\n  inputTokens: number;\n  outputTokens: number;\n  costUsd: number;\n  errorMessage: string | null;\n  durationMs: number | null;\n  retryOfExecutionId: string | null;\n  retryCount: number;\n  startedAt: string | null;\n  completedAt: string | null;\n  createdAt: string;\n}\n\n// ---------------------------------------------------------------------------\n// Execution request — produced to Kafka by Vibeman, consumed by orchestrator\n// ---------------------------------------------------------------------------\n\nexport interface ExecRequest {\n  executionId: string;\n  personaId: string;\n  prompt: string;\n  projectId?: string;\n  credentialIds?: string[];\n  inputData?: unknown;\n  config: {\n    timeoutMs: number;\n    maxConcurrent?: number;\n  };\n  triggerId?: string;\n  triggerType?: string;\n  /** Originating event ID — enables bidirectional event↔execution tracing. */\n  eventId?: string;\n}\n\n// Execution result — produced to Kafka by orchestrator\nexport interface ExecResult {\n  executionId: string;\n  personaId: string;\n  status: 'completed' | 'failed' | 'cancelled';\n  exitCode: number;\n  durationMs: number;\n  sessionId?: string;\n  totalCostUsd?: number;\n  phaseTimings?: import('./protocol.js').PhaseTimings;\n  error?: string;\n}\n\n// Worker info as tracked by orchestrator\nexport interface WorkerInfo {\n  workerId: string;\n  status: 'connecting' | 'idle' | 'executing' | 'disconnected';\n  version: string;\n  capabilities: string[];\n  currentExecutionId?: string;\n  connectedAt: number;\n  lastHeartbeat: number;\n  imageDigest?: string;\n  claudeCliVersion?: string;\n  verified: boolean;\n}\n\n// Execution output chunk — produced to Kafka for Vibeman SSE consumption\nexport interface OutputChunk {\n  executionId: string;\n  chunk: string;\n  timestamp: number;\n}\n\n// Persona event — forwarded from worker to Kafka event bus\nexport interface PersonaCloudEvent {\n  executionId: string;\n  personaId: string;\n  eventType: import('./protocolRegistry.js').ProtocolEventType;\n  payload: unknown;\n  timestamp: number;\n}\n\n// Execution progress (ephemeral — tracked in-memory + Kafka only)\nexport interface ProgressInfo {\n  phase: string;\n  percent: number;\n  detail?: string;\n  updatedAt: number;\n}\n\n// Kafka topic names\nexport const TOPICS = {\n  EXEC_REQUESTS: 'persona.exec.v1',\n  EXEC_OUTPUT: 'persona.output.v1',\n  EXEC_LIFECYCLE: 'persona.lifecycle.v1',\n  EXEC_PROGRESS: 'persona.progress.v1',\n  EVENTS: 'persona.events.v1',\n  DLQ: 'persona.dlq.v1',\n} as const;\n\n// Protocol version\nexport const PROTOCOL_VERSION = '0.2.0';\n","numLines":347,"startLine":1,"totalLines":347}}}
