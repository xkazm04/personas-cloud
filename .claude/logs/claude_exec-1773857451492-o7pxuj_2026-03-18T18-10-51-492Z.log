[2026-03-18T18:14:22.909Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012bUSQP63vDpxVCN6ap3mKo","type":"tool_result","content":"     1→// ---------------------------------------------------------------------------\n     2→// Table lifecycle classification registry\n     3→// ---------------------------------------------------------------------------\n     4→//\n     5→// Every time-series table (one with a temporal column subject to retention)\n     6→// is classified as either *metrizable* or *ephemeral*:\n     7→//\n     8→//   metrizable  – contains numeric columns worth aggregating into summary\n     9→//                 metrics before rows are purged (e.g. cost_usd, duration_ms).\n    10→//   ephemeral   – rows are simply deleted after the retention window; no\n    11→//                 pre-purge aggregation is performed.\n    12→//\n    13→// This registry is the single source of truth for that classification.\n    14→// The retention engine and any future table additions should consult it\n    15→// rather than hard-coding lifecycle decisions in procedural code.\n    16→// ---------------------------------------------------------------------------\n    17→\n    18→/** Lifecycle category for a time-series table. */\n    19→export type TableLifecycle = 'metrizable' | 'ephemeral';\n    20→\n    21→/** Describes a numeric column that should be aggregated before purge. */\n    22→export interface MetrizableColumn {\n    23→  /** SQLite column name. */\n    24→  column: string;\n    25→  /** SQL aggregation function applied during rollup (SUM, AVG, COUNT, etc.). */\n    26→  aggregation: 'SUM' | 'COUNT' | 'AVG' | 'MAX' | 'MIN';\n    27→}\n    28→\n    29→/** Retention spec for a metrizable table. */\n    30→export interface MetrizableTableSpec {\n    31→  lifecycle: 'metrizable';\n    32→  /** The SQLite table name. */\n    33→  table: string;\n    34→  /** Temporal column used to determine row age. */\n    35→  timestampColumn: string;\n    36→  /** Numeric columns aggregated into a summary table before purge. */\n    37→  metrizableColumns: MetrizableColumn[];\n    38→  /** Target table where aggregated metrics are written. */\n    39→  aggregationTarget: string;\n    40→  /** Maximum fraction of rows deletable in a single purge cycle (safety cap). */\n    41→  maxPurgeFraction?: number;\n    42→}\n    43→\n    44→/** Retention spec for an ephemeral table. */\n    45→export interface EphemeralTableSpec {\n    46→  lifecycle: 'ephemeral';\n    47→  /** The SQLite table name. */\n    48→  table: string;\n    49→  /** Temporal column used to determine row age. */\n    50→  timestampColumn: string;\n    51→  /** Minimum retention days (e.g. compliance floor for audit data). */\n    52→  minRetentionDays?: number;\n    53→  /** Maximum fraction of rows deletable in a single purge cycle (safety cap). */\n    54→  maxPurgeFraction?: number;\n    55→}\n    56→\n    57→export type TableRetentionSpec = MetrizableTableSpec | EphemeralTableSpec;\n    58→\n    59→// ---------------------------------------------------------------------------\n    60→// Registry of all time-series tables and their lifecycle classification\n    61→// ---------------------------------------------------------------------------\n    62→\n    63→export const TABLE_REGISTRY: readonly TableRetentionSpec[] = [\n    64→  // ── Metrizable: numeric data aggregated into daily_metrics before purge ──\n    65→  {\n    66→    lifecycle: 'metrizable',\n    67→    table: 'persona_executions',\n    68→    timestampColumn: 'created_at',\n    69→    metrizableColumns: [\n    70→      { column: 'cost_usd', aggregation: 'SUM' },\n    71→      { column: 'duration_ms', aggregation: 'SUM' },\n    72→      { column: 'input_tokens', aggregation: 'SUM' },\n    73→      { column: 'output_tokens', aggregation: 'SUM' },\n    74→    ],\n    75→    aggregationTarget: 'daily_metrics',\n    76→    maxPurgeFraction: 0.8,\n    77→  },\n    78→\n    79→  // ── Ephemeral: purged without aggregation ────────────────────────────────\n    80→  {\n    81→    lifecycle: 'ephemeral',\n    82→    table: 'persona_events',\n    83→    timestampColumn: 'created_at',\n    84→    maxPurgeFraction: 0.8,\n    85→  },\n    86→  {\n    87→    lifecycle: 'ephemeral',\n    88→    table: 'audit_events',\n    89→    timestampColumn: 'timestamp',\n    90→    minRetentionDays: 90,\n    91→    maxPurgeFraction: 0.8,\n    92→  },\n    93→] as const;\n    94→\n    95→// ---------------------------------------------------------------------------\n    96→// Lookup helpers\n    97→// ---------------------------------------------------------------------------\n    98→\n    99→/** Look up the retention spec for a table by name. */\n   100→export function getTableSpec(tableName: string): TableRetentionSpec | undefined {\n   101→  return TABLE_REGISTRY.find((s) => s.table === tableName);\n   102→}\n   103→\n   104→/** Return all tables classified with the given lifecycle. */\n   105→export function getTablesByLifecycle(lifecycle: TableLifecycle): readonly TableRetentionSpec[] {\n   106→  return TABLE_REGISTRY.filter((s) => s.lifecycle === lifecycle);\n   107→}\n   108→\n   109→/** Type guard: is this spec metrizable? */\n   110→export function isMetrizable(spec: TableRetentionSpec): spec is MetrizableTableSpec {\n   111→  return spec.lifecycle === 'metrizable';\n   112→}\n   113→\n   114→/** Type guard: is this spec ephemeral? */\n   115→export function isEphemeral(spec: TableRetentionSpec): spec is EphemeralTableSpec {\n   116→  return spec.lifecycle === 'ephemeral';\n   117→}\n   118→"}]},"parent_tool_use_id":null,"session_id":"a406f229-b97a-4ebf-a68f-d55c6981f4d6","uuid":"65c2fc3a-99c9-412d-8508-6bad58a359f3","timestamp":"2026-03-18T18:14:22.827Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\shared\\src\\tableRegistry.ts","content":"// ---------------------------------------------------------------------------\n// Table lifecycle classification registry\n// ---------------------------------------------------------------------------\n//\n// Every time-series table (one with a temporal column subject to retention)\n// is classified as either *metrizable* or *ephemeral*:\n//\n//   metrizable  – contains numeric columns worth aggregating into summary\n//                 metrics before rows are purged (e.g. cost_usd, duration_ms).\n//   ephemeral   – rows are simply deleted after the retention window; no\n//                 pre-purge aggregation is performed.\n//\n// This registry is the single source of truth for that classification.\n// The retention engine and any future table additions should consult it\n// rather than hard-coding lifecycle decisions in procedural code.\n// ---------------------------------------------------------------------------\n\n/** Lifecycle category for a time-series table. */\nexport type TableLifecycle = 'metrizable' | 'ephemeral';\n\n/** Describes a numeric column that should be aggregated before purge. */\nexport interface MetrizableColumn {\n  /** SQLite column name. */\n  column: string;\n  /** SQL aggregation function applied during rollup (SUM, AVG, COUNT, etc.). */\n  aggregation: 'SUM' | 'COUNT' | 'AVG' | 'MAX' | 'MIN';\n}\n\n/** Retention spec for a metrizable table. */\nexport interface MetrizableTableSpec {\n  lifecycle: 'metrizable';\n  /** The SQLite table name. */\n  table: string;\n  /** Temporal column used to determine row age. */\n  timestampColumn: string;\n  /** Numeric columns aggregated into a summary table before purge. */\n  metrizableColumns: MetrizableColumn[];\n  /** Target table where aggregated metrics are written. */\n  aggregationTarget: string;\n  /** Maximum fraction of rows deletable in a single purge cycle (safety cap). */\n  maxPurgeFraction?: number;\n}\n\n/** Retention spec for an ephemeral table. */\nexport interface EphemeralTableSpec {\n  lifecycle: 'ephemeral';\n  /** The SQLite table name. */\n  table: string;\n  /** Temporal column used to determine row age. */\n  timestampColumn: string;\n  /** Minimum retention days (e.g. compliance floor for audit data). */\n  minRetentionDays?: number;\n  /** Maximum fraction of rows deletable in a single purge cycle (safety cap). */\n  maxPurgeFraction?: number;\n}\n\nexport type TableRetentionSpec = MetrizableTableSpec | EphemeralTableSpec;\n\n// ---------------------------------------------------------------------------\n// Registry of all time-series tables and their lifecycle classification\n// ---------------------------------------------------------------------------\n\nexport const TABLE_REGISTRY: readonly TableRetentionSpec[] = [\n  // ── Metrizable: numeric data aggregated into daily_metrics before purge ──\n  {\n    lifecycle: 'metrizable',\n    table: 'persona_executions',\n    timestampColumn: 'created_at',\n    metrizableColumns: [\n      { column: 'cost_usd', aggregation: 'SUM' },\n      { column: 'duration_ms', aggregation: 'SUM' },\n      { column: 'input_tokens', aggregation: 'SUM' },\n      { column: 'output_tokens', aggregation: 'SUM' },\n    ],\n    aggregationTarget: 'daily_metrics',\n    maxPurgeFraction: 0.8,\n  },\n\n  // ── Ephemeral: purged without aggregation ────────────────────────────────\n  {\n    lifecycle: 'ephemeral',\n    table: 'persona_events',\n    timestampColumn: 'created_at',\n    maxPurgeFraction: 0.8,\n  },\n  {\n    lifecycle: 'ephemeral',\n    table: 'audit_events',\n    timestampColumn: 'timestamp',\n    minRetentionDays: 90,\n    maxPurgeFraction: 0.8,\n  },\n] as const;\n\n// ---------------------------------------------------------------------------\n// Lookup helpers\n// ---------------------------------------------------------------------------\n\n/** Look up the retention spec for a table by name. */\nexport function getTableSpec(tableName: string): TableRetentionSpec | undefined {\n  return TABLE_REGISTRY.find((s) => s.table === tableName);\n}\n\n/** Return all tables classified with the given lifecycle. */\nexport function getTablesByLifecycle(lifecycle: TableLifecycle): readonly TableRetentionSpec[] {\n  return TABLE_REGISTRY.filter((s) => s.lifecycle === lifecycle);\n}\n\n/** Type guard: is this spec metrizable? */\nexport function isMetrizable(spec: TableRetentionSpec): spec is MetrizableTableSpec {\n  return spec.lifecycle === 'metrizable';\n}\n\n/** Type guard: is this spec ephemeral? */\nexport function isEphemeral(spec: TableRetentionSpec): spec is EphemeralTableSpec {\n  return spec.lifecycle === 'ephemeral';\n}\n","numLines":118,"startLine":1,"totalLines":118}}}
