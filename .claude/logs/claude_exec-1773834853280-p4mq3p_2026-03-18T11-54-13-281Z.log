[2026-03-18T11:54:24.908Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014s2Xw5JtZFGWiJEk5N2sxf","type":"tool_result","content":"     1→import { EventEmitter } from 'node:events';\n     2→import { deriveTenantKeyAsync } from '@dac-cloud/shared';\n     3→import type { Logger } from 'pino';\n     4→\n     5→interface CachedKey {\n     6→  key: Buffer;\n     7→  createdAt: number;\n     8→}\n     9→\n    10→const DEFAULT_TTL_MS = 30 * 60 * 1000; // 30 minutes\n    11→const DEFAULT_RENEW_AHEAD_MS = 5 * 60 * 1000; // renew 5 min before expiry\n    12→\n    13→export type TenantIdSource = () => string[];\n    14→\n    15→export interface KeyDerivedEvent { tenantId: string; timestamp: number }\n    16→export interface TenantKeyEvents {\n    17→  'key:derived': [KeyDerivedEvent];\n    18→}\n    19→\n    20→/**\n    21→ * Manages per-tenant encryption keys with caching.\n    22→ *\n    23→ * Keys are derived from the master secret + tenant ID via PBKDF2 (shared/crypto.ts).\n    24→ * A single maintenance timer handles both renewal and eviction in a fixed order\n    25→ * (renew first, then evict) to prevent races between independent timers.\n    26→ *\n    27→ * Emits `key:derived` so audit concerns can subscribe externally.\n    28→ */\n    29→export class TenantKeyManager extends EventEmitter<TenantKeyEvents> {\n    30→  private cache = new Map<string, CachedKey>();\n    31→  private maintenanceTimer: NodeJS.Timeout;\n    32→  private tenantIdSource: TenantIdSource | null = null;\n    33→\n    34→  constructor(\n    35→    private masterSecret: string,\n    36→    private logger: Logger,\n    37→    private ttlMs: number = DEFAULT_TTL_MS,\n    38→    private renewAheadMs: number = DEFAULT_RENEW_AHEAD_MS,\n    39→  ) {\n    40→    super();\n    41→    // Single timer for cache maintenance: renewal before eviction\n    42→    this.maintenanceTimer = setInterval(() => this.maintainCache(), 60_000);\n    43→  }\n    44→\n    45→  /**\n    46→   * Set a source function that returns all known tenant IDs.\n    47→   * Once set, pre-warms the cache. Proactive renewal runs automatically\n    48→   * via the unified maintenance timer when a tenant source is available.\n    49→   */\n    50→  async setTenantIdSource(source: TenantIdSource): Promise<void> {\n    51→    this.tenantIdSource = source;\n    52→    await this.warmAll();\n    53→  }\n    54→\n    55→  /**\n    56→   * Pre-derive and cache keys for all known tenants.\n    57→   */\n    58→  async warmAll(): Promise<void> {\n    59→    if (!this.tenantIdSource) return;\n    60→\n    61→    const tenantIds = this.tenantIdSource();\n    62→    let warmed = 0;\n    63→    const promises: Promise<void>[] = [];\n    64→    for (const tenantId of tenantIds) {\n    65→      const cached = this.cache.get(tenantId);\n    66→      if (!cached || Date.now() - cached.createdAt >= this.ttlMs) {\n    67→        promises.push(this.deriveAndCache(tenantId).then(() => { warmed++; }));\n    68→      }\n    69→    }\n    70→    await Promise.all(promises);\n    71→    if (warmed > 0) {\n    72→      this.logger.info({ warmed, total: tenantIds.length }, 'Pre-warmed tenant key cache');\n    73→    }\n    74→  }\n    75→\n    76→  /**\n    77→   * Eagerly warm the key cache for a single tenant (e.g., on tenant creation).\n    78→   */\n    79→  async warmTenant(tenantId: string): Promise<void> {\n    80→    await this.deriveAndCache(tenantId);\n    81→    this.logger.debug({ tenantId }, 'Eagerly warmed tenant key');\n    82→  }\n    83→\n    84→  /**\n    85→   * Get the encryption key for a tenant. Derives on first access, caches thereafter.\n    86→   */\n    87→  async getKey(tenantId: string): Promise<Buffer> {\n    88→    const cached = this.cache.get(tenantId);\n    89→    if (cached && Date.now() - cached.createdAt < this.ttlMs) {\n    90→      return cached.key;\n    91→    }\n    92→\n    93→    return this.deriveAndCache(tenantId);\n    94→  }\n    95→\n    96→  /**\n    97→   * Invalidate all cached keys (e.g., after master key rotation).\n    98→   */\n    99→  invalidateAll(): void {\n   100→    this.zeroAllKeys();\n   101→    this.cache.clear();\n   102→    this.logger.info('All cached tenant keys invalidated');\n   103→  }\n   104→\n   105→  close(): void {\n   106→    clearInterval(this.maintenanceTimer);\n   107→    this.zeroAllKeys();\n   108→    this.cache.clear();\n   109→    this.removeAllListeners();\n   110→  }\n   111→\n   112→  private async deriveAndCache(tenantId: string): Promise<Buffer> {\n   113→    const existing = this.cache.get(tenantId);\n   114→    if (existing) existing.key.fill(0);\n   115→\n   116→    const key = await deriveTenantKeyAsync(this.masterSecret, tenantId);\n   117→    this.cache.set(tenantId, { key, createdAt: Date.now() });\n   118→\n   119→    this.emit('key:derived', { tenantId, timestamp: Date.now() });\n   120→\n   121→    this.logger.debug({ tenantId }, 'Tenant key derived');\n   122→    return key;\n   123→  }\n   124→\n   125→  /** Zero all cached key buffers. */\n   126→  private zeroAllKeys(): void {\n   127→    for (const cached of this.cache.values()) {\n   128→      cached.key.fill(0);\n   129→    }\n   130→  }\n   131→\n   132→  /**\n   133→   * Unified cache maintenance: renew near-expiry keys first, then evict expired ones.\n   134→   * Running both phases in a single callback with fixed ordering prevents the race\n   135→   * where independent timers could evict a key before renewal refreshes it, or\n   136→   * renewal re-derives a key that eviction immediately deletes.\n   137→   */\n   138→  private async maintainCache(): Promise<void> {\n   139→    const now = Date.now();\n   140→\n   141→    // Phase 1: Renew keys approaching expiry (only when a tenant source is set)\n   142→    if (this.tenantIdSource) {\n   143→      const renewThreshold = this.ttlMs - this.renewAheadMs;\n   144→      const promises: Promise<void>[] = [];\n   145→\n   146→      for (const [t