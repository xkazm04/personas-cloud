tiveExecution>();\n    38→  private tenantDbManager: TenantDbManager | null = null;\n    39→  private masterKey: Buffer | null = null;\n    40→  private tenantKeyManager: TenantKeyManager | null = null;\n    41→  private auditLog: AuditLog | null = null;\n    42→  // Maps executionId → projectId for DB resolution during callbacks\n    43→  private executionTenant = new Map<string, string>();\n    44→  // Batched output buffers: executionId → pending chunks\n    45→  private outputBuffers = new Map<string, string[]>();\n    46→  private outputFlushTimer: NodeJS.Timeout;\n    47→\n    48→  constructor(\n    49→    private pool: WorkerPool,\n    50→    private tokenManager: TokenManager,\n    51→    private oauth: OAuthManager | null,\n    52→    private kafka: KafkaClient,\n    53→    private logger: Logger,\n    54→  ) {\n    55→    // Periodic flush of batched output to DB\n    56→    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n    57→\n    58→    // When a worker becomes ready, try to dispatch queued work\n    59→    this.pool.on('worker-ready', () => {\n    60→      this.processQueue();\n    61→    });\n    62→\n    63→    // When a worker connects, try to dispatch\n    64→    this.pool.on('worker-connected', () => {\n    65→      this.processQueue();\n    66→    });\n    67→\n    68→    // Track stdout for execution output\n    69→    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n    70→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    71→    });\n    72→\n    73→    // Track stderr for debugging failed executions\n    74→    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n    75→      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n    76→      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    77→    });\n    78→\n    79→    // Handle execution completion\n    80→    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n    81→      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n    82→        executionId: msg.executionId,\n    83→        status: msg.status,\n    84→        exitCode: msg.exitCode,\n    85→        durationMs: msg.durationMs,\n    86→        sessionId: msg.sessionId,\n    87→        totalCostUsd: msg.totalCostUsd,\n    88→      }), msg.executionId).catch(err => {\n    89→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n    90→      });\n    91→\n    92→      // Flush any remaining buffered output before persisting completion\n    93→      this.flushOutputForExecution(msg.executionId);\n    94→\n    95→      // Update in-memory\n    96→      const exec = this.active.get(msg.executionId);\n    97→      if (exec) {\n    98→        exec.status = msg.status;\n    99→        exec.completedAt = Date.now();\n   100→        exec.exitCode = msg.exitCode;\n   101→        exec.durationMs = msg.durationMs;\n   102→        exec.sessionId = msg.sessionId;\n   103→        exec.totalCostUsd = msg.totalCostUsd;\n   104→        // Remove from active after a short delay (allow polling to pick up final state)\n   105→        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n   106→      }\n   107→\n   108→      // Persist to DB\n   109→      const completeDb = this.resolveDbForExecution(msg.executionId);\n   110→      if (completeDb) {\n   111→        try {\n   112→          db.updateExecution(completeDb, msg.executionId, {\n   113→            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n   114→            completedAt: new Date().toISOString(),\n   115→            durationMs: msg.durationMs,\n   116→            claudeSessionId: msg.sessionId,\n   117→            costUsd: msg.totalCostUsd ?? 0,\n   118→          });\n   119→        } catch (err) {\n   120→          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n   121→        }\n   122→      }\n   123→\n   124→      // Clean up tenant mapping after completion delay\n   125→      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n   126→\n   127→      // Process next queued item\n   128→      this.processQueue();\n   129→    });\n   130→\n   131→    // Track execution progress\n   132→    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n   133→      const exec = this.active.get(msg.executionId);\n   134→      if (exec) {\n   135→        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n   136→      }\n   137→      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n   138→        executionId: msg.executionId,\n   139→        phase: msg.phase,\n   140→        percent: msg.percent,\n   141→        detail: msg.detail,\n   142→        timestamp: msg.timestamp,\n   143→      }), msg.executionId).catch(err => {\n   144→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n   145→      });\n   146→    });\n   147→\n   148→    // Forward persona events to Kafka\n   149→    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n   150→      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n   151→        executionId: msg.executionId,\n   152→        eventType: msg.eventType,\n   153→        payload: msg.payload,\n   154→        timestamp: Date.now(),\n   155→      }), msg.executionId).catch(err => {\n   156→        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n   157→      });\n   158→    });\n   159→\n   160→    // Handle worker busy nack — re-queue the rejected execution\n   161→    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n   162→      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n   163→      const exec = this.active.get(msg.executionId);\n   164→      if (exec) {\n   165→        this.active.delete(msg.executionId);\n   166→      }\n   167→      // Re-queue so it can be dispatched to another idle worker\n   168→      const projectId = this.executionTenant.get(msg.executionId) || 'default';\n   169→      const reqDb = this.resolveDb(projectId);\n   170→      if (reqDb) {\n   171→        try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch { /* best effort */ }\n   172→      }\n   173→      // Reconstruct a minimal request from what we know and re-queue\n   174→      // The execution was already created in the DB, so we need to find the original request data\n   175→      const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n   176→      if (dbExec) {\n   177→        this.queue.unshift({\n   178→          request: {\n   179→            executionId: msg.executionId,\n   180→            personaId: dbExec.personaId,\n   181→            prompt: dbExec.inputData || '',\n   182→            projectId,\n   183→            config: { timeoutMs: 300_000 },\n   184→          },\n   185→          receivedAt: Date.now(),\n   186→        });\n   187→        this.processQueue();\n   188→      }\n   189→    });\n   190→\n   191→    // Handle worker disconnect during execution\n   192→    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n   193→      if (executionId) {\n   194→        this.logger.error({ executionId }, 'Worker disconnected during execution');\n   195→        const exec = this.active.get(executionId);\n   196→        if (exec) {\n   197→          exec.status = 'failed';\n   198→          exec.completedAt = Date.now();\n   199→          setTimeout(() => this.active.delete(executionId), 30_000);\n   200→        }\n   201→\n   202→        // Persist failure\n   203→        const disconnDb = this.resolveDbForExecution(executionId);\n   204→        if (disconnDb) {\n   205→          try {\n   206→            db.updateExecution(disconnDb, executionId, {\n   207→              status: 'failed',\n   208→              errorMessage: 'Worker disconnected',\n   209→              completedAt: new Date().toISOString(),\n   210→            });\n   211→          } catch { /* best effort */ }\n   212→        }\n   213→        this.executionTenant.delete(executionId);\n   214→\n   215→        this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n   216→          executionId,\n   217→          status: 'failed',\n   218→          error: 'Worker disconnected',\n   219→          durationMs: 0,\n   220→        }), executionId).catch(() => {});\n   221→      }\n   222→    });\n   223→  }\n   224→\n   225→  setTenantDbManager(mgr: TenantDbManager): void {\n   226→    this.tenantDbManager = mgr;\n   227→  }\n   228→\n   229→  async setMasterKey(masterKeyHex: string): Promise<void> {\n   230→    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n   231→  }\n   232→\n   233→  setTenantKeyManager(mgr: TenantKeyManager): void {\n   234→    this.tenantKeyManager = mgr;\n   235→  }\n   236→\n   237→  setAuditLog(log: AuditLog): void {\n   238→    this.auditLog = log;\n   239→  }\n   240→\n   241→  /** Resolve the database for a given projectId via tenant DB manager. */\n   242→  private resolveDb(projectId?: string): Database.Database | null {\n   243→    if (this.tenantDbManager && projectId) {\n   244→      return this.tenantDbManager.getTenantDb(projectId);\n   245→    }\n   246→    return null;\n   247→  }\n   248→\n   249→  /** Resolve the database for an in-flight execution by its ID. */\n   250→  private resolveDbForExecution(executionId: string): Database.Database | null {\n   251→    const projectId = this.executionTenant.get(executionId);\n   252→    return this.resolveDb(projectId);\n   253→  }\n   254→\n   255→  /**\n   256→   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   257→   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   258→   */\n   259→  private async decryptWithAudit(\n   260→    payload: EncryptedPayload,\n   261→    tenantId: string,\n   262→    resourceId: string,\n   263→    logContext: Record<string, unknown>,\n   264→    logMessage: string,\n   265→  ): Promise<string | undefined> {\n   266→    const decryptKey = this.tenantKeyManager\n   267→      ? await this.tenantKeyManager.getKey(tenantId)\n   268→      : this.masterKey;\n   269→    if (!decryptKey) return undefined;\n   270→\n   271→    try {\n   272→      const decrypted = decrypt(payload, decryptKey);\n   273→      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n   274→      return decrypted;\n   275→    } catch (err) {\n   276→      const reason = err instanceof Error ? err.message : String(err);\n   277→      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n   278→      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: reason }); } catch { /* logged inside record() */ }\n   279→      return undefined;\n   280→    }\n   281→  }\n   282→\n   283→  submit(request: ExecRequest): void {\n   284→    this.logger.info({\n   285→      executionId: request.executionId,\n   286→      personaId: request.personaId,\n   287→    }, 'Execution submitted');\n   288→\n   289→    // Track which tenant owns this execution (for callback DB resolution)\n   290→    const projectId = request.projectId || 'default';\n   291→    this.executionTenant.set(request.executionId, projectId);\n   292→\n   293→    // Create DB record immediately\n   294→    const submitDb = this.resolveDb(projectId);\n   295→    if (submitDb) {\n   296→      try {\n   297→        db.createExecution(submitDb, {\n   298→          id: request.executionId,\n   299→          personaId: request.personaId,\n   300→          inputData: request.prompt,\n   301→          projectId,\n   302→        });\n   303→      } catch (err) {\n   304→        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n   305→      }\n   306→    }\n   307→\n   308→    this.queue.push({ request, receivedAt: Date.now() });\n   309→    this.processQueue();\n   310→  }\n   311→\n   312→  private async processQueue(): Promise<void> {\n   313→    while (this.queue.length > 0) {\n   314→      const workerId = this.pool.getIdleWorker();\n   315→      if (!workerId) {\n   316→        this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n   317→        return;\n   318→      }\n   319→\n   320→      const item = this.queue.shift()!;\n   321→      await this.dispatchToWorker(workerId, item.request);\n   322→    }\n   323→  }\n   324→\n   325→  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n   326→    // Try to get a fresh token via OAuth (auto-refreshes if near expiry)\n   327→    let claudeToken: string | null = null;\n   328→    if (this.oauth?.hasTokens()) {\n   329→      claudeToken = await this.oauth.getValidAccessToken();\n   330→      if (claudeToken) {\n   331→        this.tokenManager.storeClaudeToken(claudeToken);\n   332→      }\n   333→    }\n   334→    // Fallback to stored token\n   335→    if (!claudeToken) {\n   336→      claudeToken = this.tokenManager.getClaudeToken();\n   337→    }\n   338→    if (!claudeToken) {\n   339→      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n   340→      this.queue.unshift({ request, receivedAt: Date.now() });\n   341→      return;\n   342→    }\n   343→\n   344→    // Build environment variables for the worker\n   345→    const env: Record<string, string> = {\n   346→      ANTHROPIC_API_KEY: claudeToken,\n   347→    };\n   348→\n   349→    // If persona exists in DB, assemble prompt from persona config and inject credentials\n   350→    let prompt = request.prompt;\n   351→    const dispatchDb = this.resolveDb(request.projectId || 'default');\n   352→    const persona = dispatchDb ? db.getPersona(dispatchDb, request.personaId) : null;\n   353→    if (dispatchDb) {\n   354→      if (persona) {\n   355→        const tools = db.getToolsForPersona(dispatchDb, persona.id);\n   356→        const creds = db.listCredentialsForPersona(dispatchDb, persona.id);\n   357→\n   358→        // Decrypt credentials and inject as env vars\n   359→        const credentialHints: string[] = [];\n   360→        const tenantId = request.projectId || 'default';\n   361→        for (const cred of creds) {\n   362→          const envName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   363→          credentialHints.push(envName);\n   364→\n   365→          const decrypted = await this.decryptWithAudit(\n   366→            toEncryptedPayload(cred),\n   367→            tenantId,\n   368→            cred.id,\n   369→            { credentialId: cred.id, credentialName: cred.name },\n   370→            'Failed to decrypt credential',\n   371→          );\n   372→          if (decrypted !== undefined) {\n   373→            // Try to parse as JSON with multiple fields\n   374→            try {\n   375→              const fields = JSON.parse(decrypted) as Record<string, string>;\n   376→              for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n   377→                const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n   378→                env[fieldEnvName] = String(fieldValue);\n   379→              }\n   380→            } catch {\n   381→              // Not JSON — inject as single value\n   382→              env[envName] = decrypted;\n   383→            }\n   384→          }\n   385→        }\n   386→\n   387→        const inputData = request.inputData ? (request.inputData as Record<string, unknown>) : undefined;\n   388→        prompt = assemblePrompt(persona, tools, inputData, credentialHints.length > 0 ? credentialHints : undefined);\n   389→\n   390→        // Apply inference profile or legacy model profile env overrides\n   391→        let inferenceProfile: InferenceProfile | undefined;\n   392→        if (persona.inferenceProfileId) {\n   393→          inferenceProfile = db.getInferenceProfile(dispatchDb, persona.inferenceProfileId);\n   394→        }\n   395→        if (inferenceProfile) {\n   396→          // Decrypt auth token first so resolveEnvOverrides can map it to env vars\n   397→          let decryptedAuthToken: string | undefined;\n   398→          if (inferenceProfile.authTokenEncrypted && inferenceProfile.authTokenIv && inferenceProfile.authTokenTag) {\n   399→            decryptedAuthToken = await this.decryptWithAudit(\n   400→              { encrypted: inferenceProfile.authTokenEncrypted, iv: inferenceProfile.authTokenIv, tag: inferenceProfile.authTokenTag },\n   401→              tenantId,\n   402→              `inference-profile:${inferenceProfile.id}`,\n   403→              { profileId: inferenceProfile.id },\n   404→              'Failed to decrypt inference profile auth token',\n   405→            );\n   406→          }\n   407→          const overrides = resolveEnvOverrides(inferenceProfile, decryptedAuthToken);\n   408→          for (const [k, v] of Object.entries(overrides.set)) env[k] = v;\n   409→          for (const k of overrides.remove) delete env[k];\n   410→        }\n   411→\n   412→        this.logger.info({ personaId: persona.id, toolCount: tools.length, credCount: creds.length }, 'Assembled prompt from DB persona');\n   413→      }\n   414→    }\n   415→\n   416→    // Resolve network policy from persona config\n   417→    let networkPolicy: NetworkPolicy | undefined;\n   418→    if (persona?.networkPolicy) {\n   419→      networkPolicy = parseNetworkPolicy(persona.networkPolicy) ?? undefined;\n   420→    }\n   421→\n   422→    const assignment: ExecAssign = {\n   423→      type: 'assign',\n   424→      executionId: request.executionId,\n   425→      personaId: request.personaId,\n   426→      prompt,\n   427→      env,\n   428→      config: {\n   429→        timeoutMs: request.config.timeoutMs || 300_000,\n   430→        maxOutputBytes: 10 * 1024 * 1024, // 10MB\n   431→        ...(networkPolicy ? { networkPolicy } : {}),\n   432→        ...(persona?.maxBudgetUsd ? { maxBudgetUsd: persona.maxBudgetUsd } : {}),\n   433→        ...(persona?.maxTurns ? { maxTurns: persona.maxTurns } : {}),\n   434→      },\n   435→    };\n   436→\n   437→    // Track in-memory for real-time streaming\n   438→    this.active.set(request.executionId, {\n   439→      workerId,\n   440→      startedAt: Date.now(),\n   441→      output: [],\n   442→      status: 'running',\n   443→    });\n   444→\n   445→    // Mark running in DB\n   446→    if (dispatchDb) {\n   447→      try {\n   448→        db.updateExecution(dispatchDb, request.executionId, {\n   449→          status: 'running',\n   450→          startedAt: new Date().toISOString(),\n   451→        });\n   452→      } catch { /* best effort */ }\n   453→    }\n   454→\n   455→    const sent = this.pool.assign(workerId, assignment);\n   456→    if (!sent) {\n   457→      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n   458→      this.active.delete(request.executionId);\n   459→      if (dispatchDb) {\n   460→        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch { /* best effort */ }\n   461→      }\n   462→      // Re-queue and retry dispatch — another idle worker may be available\n   463→      this.queue.unshift({ request, receivedAt: Date.now() });\n   464→      this.processQueue();\n   465→    } else {\n   466→      this.logger.info({\n   467→        workerId,\n   468→        executionId: request.executionId,\n   469→        personaId: request.personaId,\n   470→      }, 'Execution dispatched to worker');\n   471→    }\n   472→  }\n   473→\n   474→  cancelExecution(executionId: string): boolean {\n   475→    const exec = this.active.get(executionId);\n   476→    if (!exec || exec.status !== 'running') return false;\n   477→\n   478→    return this.pool.send(exec.workerId, {\n   479→      type: 'cancel',\n   480→      executionId,\n   481→    });\n   482→  }\n   483→\n   484→  getQueueLength(): number {\n   485→    return this.queue.length;\n   486→  }\n   487→\n   488→  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n   489→    return Array.from(this.active.entries())\n   490→      .filter(([, e]) => e.status === 'running')\n   491→      .map(([executionId, e]) => ({\n   492→        executionId,\n   493→        workerId: e.workerId,\n   494→        startedAt: e.startedAt,\n   495→      }));\n   496→  }\n   497→\n   498→  /**\n   499→   * Get execution state. Tries in-memory first (for real-time output),\n   500→   * then falls back to DB for completed/historical executions.\n   501→   */\n   502→  getExecution(executionId: string): ActiveExecution | null {\n   503→    // Check in-memory active executions first\n   504→    const active = this.active.get(executionId);\n   505→    if (active) return active;\n   506→\n   507→    const execDb = this.resolveDbForExecution(executionId);\n   508→    if (execDb) {\n   509→      const dbExec = db.getExecution(execDb, executionId);\n   510→      if (dbExec) {\n   511→        return {\n   512→          workerId: '',\n   513→          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n   514→          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n   515→          status: dbExec.status as ActiveExecution['status'],\n   516→          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n   517→          durationMs: dbExec.durationMs ?? undefined,\n   518→          sessionId: dbExec.claudeSessionId ?? undefined,\n   519→          totalCostUsd: dbExec.costUsd ?? undefined,\n   520→        };\n   521→      }\n   522→    }\n   523→\n   524→    return null;\n   525→  }\n   526→\n   527→  getExecutionOutput(executionId: string): string[] | null {\n   528→    const exec = this.getExecution(executionId);\n   529→    return exec?.output ?? null;\n   530→  }\n   531→\n   532→  /** Shared handler for stdout/stderr output chunks. */\n   533→  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n   534→    const line = prefix ? `${prefix}${chunk}` : chunk;\n   535→\n   536→    const exec = this.active.get(executionId);\n   537→    if (exec) {\n   538→      exec.output.push(line);\n   539→    }\n   540→\n   541→    this.bufferOutput(executionId, line + '\\n');\n   542→\n   543→    // Forward stdout to Kafka (stderr is not forwarded)\n   544→    if (!prefix) {\n   545→      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n   546→        executionId,\n   547→        chunk,\n   548→        timestamp,\n   549→      }), executionId).catch(err => {\n   550→        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n   551→      });\n   552→    }\n   553→  }\n   554→\n   555→  /** Buffer an output chunk for batched DB write. */\n   556→  private bufferOutput(executionId: string, chunk: string): void {\n   557→    let buf = this.outputBuffers.get(executionId);\n   558→    if (!buf) {\n   559→      buf = [];\n   560→      this.outputBuffers.set(executionId, buf);\n   561→    }\n   562→    buf.push(chunk);\n   563→  }\n   564→\n   565→  /** Flush buffered output for a specific execution to DB. */\n   566→  private flushOutputForExecution(executionId: string): void {\n   567→    const buf = this.outputBuffers.get(executionId);\n   568→    if (!buf || buf.length === 0) return;\n   569→\n   570→    const combined = buf.join('');\n   571→    this.outputBuffers.delete(executionId);\n   572→\n   573→    const outputDb = this.resolveDbForExecution(executionId);\n   574→    if (outputDb) {\n   575→      try { db.appendOutput(outputDb, executionId, combined); } catch { /* best effort */ }\n   576→    }\n   577→  }\n   578→\n   579→  /** Flush all buffered output across all executions to DB. */\n   580→  private flushOutputBuffers(): void {\n   581→    for (const executionId of this.outputBuffers.keys()) {\n   582→      this.flushOutputForExecution(executionId);\n   583→    }\n   584→  }\n   585→\n   586→  shutdown(): void {\n   587→    clearInterval(this.outputFlushTimer);\n   588→    this.flushOutputBuffers();\n   589→  }\n   590→}\n   591→"}]},"parent_tool_use_id":null,"session_id":"aefd2344-322a-4270-982f-2978aca96abe","uuid":"09aee3d0-5005-4c77-a976-e584050f8457","timestamp":"2026-03-18T11:26:31.798Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\kazda\\kiro\\personas-cloud\\packages\\orchestrator\\src\\dispatcher.ts","content":"import { type ExecAssign, type ExecRequest, type ExecStdout, type ExecStderr, type ExecComplete, type ExecProgress, type WorkerEvent, type WorkerBusy, type ProgressInfo, type InferenceProfile, type NetworkPolicy, type EncryptedPayload, TOPICS, assemblePrompt, decrypt, deriveMasterKeyAsync, toEncryptedPayload, resolveEnvOverrides, parseNetworkPolicy } from '@dac-cloud/shared';\nimport type Database from 'better-sqlite3';\nimport type { WorkerPool } from './workerPool.js';\nimport type { TokenManager } from './tokenManager.js';\nimport type { OAuthManager } from './oauth.js';\nimport type { KafkaClient } from './kafka.js';\nimport type { TenantDbManager } from './tenantDbManager.js';\nimport type { TenantKeyManager } from './tenantKeyManager.js';\nimport type { AuditLog } from './auditLog.js';\nimport type { Logger } from 'pino';\nimport * as db from './db/index.js';\n\ninterface QueuedExecution {\n  request: ExecRequest;\n  receivedAt: number;\n}\n\n// In-memory tracking for active executions (real-time output streaming)\ninterface ActiveExecution {\n  workerId: string;\n  startedAt: number;\n  output: string[];\n  status: 'running' | 'completed' | 'failed' | 'cancelled';\n  progress?: ProgressInfo;\n  completedAt?: number;\n  exitCode?: number;\n  durationMs?: number;\n  sessionId?: string;\n  totalCostUsd?: number;\n}\n\nconst OUTPUT_FLUSH_INTERVAL_MS = 500;\n\nexport class Dispatcher {\n  private queue: QueuedExecution[] = [];\n  // In-memory map for real-time output + cancel routing (active executions only)\n  private active = new Map<string, ActiveExecution>();\n  private tenantDbManager: TenantDbManager | null = null;\n  private masterKey: Buffer | null = null;\n  private tenantKeyManager: TenantKeyManager | null = null;\n  private auditLog: AuditLog | null = null;\n  // Maps executionId → projectId for DB resolution during callbacks\n  private executionTenant = new Map<string, string>();\n  // Batched output buffers: executionId → pending chunks\n  private outputBuffers = new Map<string, string[]>();\n  private outputFlushTimer: NodeJS.Timeout;\n\n  constructor(\n    private pool: WorkerPool,\n    private tokenManager: TokenManager,\n    private oauth: OAuthManager | null,\n    private kafka: KafkaClient,\n    private logger: Logger,\n  ) {\n    // Periodic flush of batched output to DB\n    this.outputFlushTimer = setInterval(() => this.flushOutputBuffers(), OUTPUT_FLUSH_INTERVAL_MS);\n\n    // When a worker becomes ready, try to dispatch queued work\n    this.pool.on('worker-ready', () => {\n      this.processQueue();\n    });\n\n    // When a worker connects, try to dispatch\n    this.pool.on('worker-connected', () => {\n      this.processQueue();\n    });\n\n    // Track stdout for execution output\n    this.pool.on('stdout', (_workerId: string, msg: ExecStdout) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp);\n    });\n\n    // Track stderr for debugging failed executions\n    this.pool.on('stderr', (_workerId: string, msg: ExecStderr) => {\n      this.handleOutputChunk(msg.executionId, msg.chunk, msg.timestamp, '[STDERR] ');\n      this.logger.warn({ executionId: msg.executionId, stderr: msg.chunk }, 'Execution stderr');\n    });\n\n    // Handle execution completion\n    this.pool.on('complete', (_workerId: string, msg: ExecComplete) => {\n      this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n        executionId: msg.executionId,\n        status: msg.status,\n        exitCode: msg.exitCode,\n        durationMs: msg.durationMs,\n        sessionId: msg.sessionId,\n        totalCostUsd: msg.totalCostUsd,\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce lifecycle to Kafka');\n      });\n\n      // Flush any remaining buffered output before persisting completion\n      this.flushOutputForExecution(msg.executionId);\n\n      // Update in-memory\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.status = msg.status;\n        exec.completedAt = Date.now();\n        exec.exitCode = msg.exitCode;\n        exec.durationMs = msg.durationMs;\n        exec.sessionId = msg.sessionId;\n        exec.totalCostUsd = msg.totalCostUsd;\n        // Remove from active after a short delay (allow polling to pick up final state)\n        setTimeout(() => this.active.delete(msg.executionId), 30_000);\n      }\n\n      // Persist to DB\n      const completeDb = this.resolveDbForExecution(msg.executionId);\n      if (completeDb) {\n        try {\n          db.updateExecution(completeDb, msg.executionId, {\n            status: msg.status === 'completed' ? 'completed' : msg.status === 'cancelled' ? 'cancelled' : 'failed',\n            completedAt: new Date().toISOString(),\n            durationMs: msg.durationMs,\n            claudeSessionId: msg.sessionId,\n            costUsd: msg.totalCostUsd ?? 0,\n          });\n        } catch (err) {\n          this.logger.error({ err, executionId: msg.executionId }, 'Failed to persist execution completion');\n        }\n      }\n\n      // Clean up tenant mapping after completion delay\n      setTimeout(() => this.executionTenant.delete(msg.executionId), 35_000);\n\n      // Process next queued item\n      this.processQueue();\n    });\n\n    // Track execution progress\n    this.pool.on('progress', (_workerId: string, msg: ExecProgress) => {\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        exec.progress = { phase: msg.phase, percent: msg.percent, detail: msg.detail, updatedAt: msg.timestamp };\n      }\n      this.kafka.produce(TOPICS.EXEC_PROGRESS, JSON.stringify({\n        executionId: msg.executionId,\n        phase: msg.phase,\n        percent: msg.percent,\n        detail: msg.detail,\n        timestamp: msg.timestamp,\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce progress to Kafka');\n      });\n    });\n\n    // Forward persona events to Kafka\n    this.pool.on('persona-event', (_workerId: string, msg: WorkerEvent) => {\n      this.kafka.produce(TOPICS.EVENTS, JSON.stringify({\n        executionId: msg.executionId,\n        eventType: msg.eventType,\n        payload: msg.payload,\n        timestamp: Date.now(),\n      }), msg.executionId).catch(err => {\n        this.logger.error({ err, executionId: msg.executionId }, 'Failed to produce event to Kafka');\n      });\n    });\n\n    // Handle worker busy nack — re-queue the rejected execution\n    this.pool.on('busy', (_workerId: string, msg: WorkerBusy) => {\n      this.logger.warn({ workerId: _workerId, executionId: msg.executionId, reason: msg.reason }, 'Worker rejected assignment, re-queuing');\n      const exec = this.active.get(msg.executionId);\n      if (exec) {\n        this.active.delete(msg.executionId);\n      }\n      // Re-queue so it can be dispatched to another idle worker\n      const projectId = this.executionTenant.get(msg.executionId) || 'default';\n      const reqDb = this.resolveDb(projectId);\n      if (reqDb) {\n        try { db.updateExecution(reqDb, msg.executionId, { status: 'queued' }); } catch { /* best effort */ }\n      }\n      // Reconstruct a minimal request from what we know and re-queue\n      // The execution was already created in the DB, so we need to find the original request data\n      const dbExec = reqDb ? db.getExecution(reqDb, msg.executionId) : null;\n      if (dbExec) {\n        this.queue.unshift({\n          request: {\n            executionId: msg.executionId,\n            personaId: dbExec.personaId,\n            prompt: dbExec.inputData || '',\n            projectId,\n            config: { timeoutMs: 300_000 },\n          },\n          receivedAt: Date.now(),\n        });\n        this.processQueue();\n      }\n    });\n\n    // Handle worker disconnect during execution\n    this.pool.on('worker-disconnected', (_workerId: string, executionId: string | undefined) => {\n      if (executionId) {\n        this.logger.error({ executionId }, 'Worker disconnected during execution');\n        const exec = this.active.get(executionId);\n        if (exec) {\n          exec.status = 'failed';\n          exec.completedAt = Date.now();\n          setTimeout(() => this.active.delete(executionId), 30_000);\n        }\n\n        // Persist failure\n        const disconnDb = this.resolveDbForExecution(executionId);\n        if (disconnDb) {\n          try {\n            db.updateExecution(disconnDb, executionId, {\n              status: 'failed',\n              errorMessage: 'Worker disconnected',\n              completedAt: new Date().toISOString(),\n            });\n          } catch { /* best effort */ }\n        }\n        this.executionTenant.delete(executionId);\n\n        this.kafka.produce(TOPICS.EXEC_LIFECYCLE, JSON.stringify({\n          executionId,\n          status: 'failed',\n          error: 'Worker disconnected',\n          durationMs: 0,\n        }), executionId).catch(() => {});\n      }\n    });\n  }\n\n  setTenantDbManager(mgr: TenantDbManager): void {\n    this.tenantDbManager = mgr;\n  }\n\n  async setMasterKey(masterKeyHex: string): Promise<void> {\n    this.masterKey = await deriveMasterKeyAsync(masterKeyHex);\n  }\n\n  setTenantKeyManager(mgr: TenantKeyManager): void {\n    this.tenantKeyManager = mgr;\n  }\n\n  setAuditLog(log: AuditLog): void {\n    this.auditLog = log;\n  }\n\n  /** Resolve the database for a given projectId via tenant DB manager. */\n  private resolveDb(projectId?: string): Database.Database | null {\n    if (this.tenantDbManager && projectId) {\n      return this.tenantDbManager.getTenantDb(projectId);\n    }\n    return null;\n  }\n\n  /** Resolve the database for an in-flight execution by its ID. */\n  private resolveDbForExecution(executionId: string): Database.Database | null {\n    const projectId = this.executionTenant.get(executionId);\n    return this.resolveDb(projectId);\n  }\n\n  /**\n   * Resolve the tenant/master key, decrypt a payload, and emit audit events.\n   * Returns the plaintext on success or undefined on failure (key missing or decrypt error).\n   */\n  private async decryptWithAudit(\n    payload: EncryptedPayload,\n    tenantId: string,\n    resourceId: string,\n    logContext: Record<string, unknown>,\n    logMessage: string,\n  ): Promise<string | undefined> {\n    const decryptKey = this.tenantKeyManager\n      ? await this.tenantKeyManager.getKey(tenantId)\n      : this.masterKey;\n    if (!decryptKey) return undefined;\n\n    try {\n      const decrypted = decrypt(payload, decryptKey);\n      try { this.auditLog?.record({ action: 'key:decrypt', tenantId, resourceType: 'credential', resourceId }); } catch { /* logged inside record() */ }\n      return decrypted;\n    } catch (err) {\n      const reason = err instanceof Error ? err.message : String(err);\n      this.logger.error({ err, ...logContext, tenantId }, logMessage);\n      try { this.auditLog?.record({ action: 'key:decrypt_failed', tenantId, resourceType: 'credential', resourceId, detail: reason }); } catch { /* logged inside record() */ }\n      return undefined;\n    }\n  }\n\n  submit(request: ExecRequest): void {\n    this.logger.info({\n      executionId: request.executionId,\n      personaId: request.personaId,\n    }, 'Execution submitted');\n\n    // Track which tenant owns this execution (for callback DB resolution)\n    const projectId = request.projectId || 'default';\n    this.executionTenant.set(request.executionId, projectId);\n\n    // Create DB record immediately\n    const submitDb = this.resolveDb(projectId);\n    if (submitDb) {\n      try {\n        db.createExecution(submitDb, {\n          id: request.executionId,\n          personaId: request.personaId,\n          inputData: request.prompt,\n          projectId,\n        });\n      } catch (err) {\n        this.logger.error({ err, executionId: request.executionId }, 'Failed to create execution record');\n      }\n    }\n\n    this.queue.push({ request, receivedAt: Date.now() });\n    this.processQueue();\n  }\n\n  private async processQueue(): Promise<void> {\n    while (this.queue.length > 0) {\n      const workerId = this.pool.getIdleWorker();\n      if (!workerId) {\n        this.logger.debug({ queueLength: this.queue.length }, 'No idle worker, execution queued');\n        return;\n      }\n\n      const item = this.queue.shift()!;\n      await this.dispatchToWorker(workerId, item.request);\n    }\n  }\n\n  private async dispatchToWorker(workerId: string, request: ExecRequest): Promise<void> {\n    // Try to get a fresh token via OAuth (auto-refreshes if near expiry)\n    let claudeToken: string | null = null;\n    if (this.oauth?.hasTokens()) {\n      claudeToken = await this.oauth.getValidAccessToken();\n      if (claudeToken) {\n        this.tokenManager.storeClaudeToken(claudeToken);\n      }\n    }\n    // Fallback to stored token\n    if (!claudeToken) {\n      claudeToken = this.tokenManager.getClaudeToken();\n    }\n    if (!claudeToken) {\n      this.logger.error({ executionId: request.executionId }, 'No Claude token available, re-queuing execution');\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      return;\n    }\n\n    // Build environment variables for the worker\n    const env: Record<string, string> = {\n      ANTHROPIC_API_KEY: claudeToken,\n    };\n\n    // If persona exists in DB, assemble prompt from persona config and inject credentials\n    let prompt = request.prompt;\n    const dispatchDb = this.resolveDb(request.projectId || 'default');\n    const persona = dispatchDb ? db.getPersona(dispatchDb, request.personaId) : null;\n    if (dispatchDb) {\n      if (persona) {\n        const tools = db.getToolsForPersona(dispatchDb, persona.id);\n        const creds = db.listCredentialsForPersona(dispatchDb, persona.id);\n\n        // Decrypt credentials and inject as env vars\n        const credentialHints: string[] = [];\n        const tenantId = request.projectId || 'default';\n        for (const cred of creds) {\n          const envName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n          credentialHints.push(envName);\n\n          const decrypted = await this.decryptWithAudit(\n            toEncryptedPayload(cred),\n            tenantId,\n            cred.id,\n            { credentialId: cred.id, credentialName: cred.name },\n            'Failed to decrypt credential',\n          );\n          if (decrypted !== undefined) {\n            // Try to parse as JSON with multiple fields\n            try {\n              const fields = JSON.parse(decrypted) as Record<string, string>;\n              for (const [fieldKey, fieldValue] of Object.entries(fields)) {\n                const fieldEnvName = `CONNECTOR_${cred.name.toUpperCase().replace(/[^A-Z0-9]/g, '_')}_${fieldKey.toUpperCase().replace(/[^A-Z0-9]/g, '_')}`;\n                env[fieldEnvName] = String(fieldValue);\n              }\n            } catch {\n              // Not JSON — inject as single value\n              env[envName] = decrypted;\n            }\n          }\n        }\n\n        const inputData = request.inputData ? (request.inputData as Record<string, unknown>) : undefined;\n        prompt = assemblePrompt(persona, tools, inputData, credentialHints.length > 0 ? credentialHints : undefined);\n\n        // Apply inference profile or legacy model profile env overrides\n        let inferenceProfile: InferenceProfile | undefined;\n        if (persona.inferenceProfileId) {\n          inferenceProfile = db.getInferenceProfile(dispatchDb, persona.inferenceProfileId);\n        }\n        if (inferenceProfile) {\n          // Decrypt auth token first so resolveEnvOverrides can map it to env vars\n          let decryptedAuthToken: string | undefined;\n          if (inferenceProfile.authTokenEncrypted && inferenceProfile.authTokenIv && inferenceProfile.authTokenTag) {\n            decryptedAuthToken = await this.decryptWithAudit(\n              { encrypted: inferenceProfile.authTokenEncrypted, iv: inferenceProfile.authTokenIv, tag: inferenceProfile.authTokenTag },\n              tenantId,\n              `inference-profile:${inferenceProfile.id}`,\n              { profileId: inferenceProfile.id },\n              'Failed to decrypt inference profile auth token',\n            );\n          }\n          const overrides = resolveEnvOverrides(inferenceProfile, decryptedAuthToken);\n          for (const [k, v] of Object.entries(overrides.set)) env[k] = v;\n          for (const k of overrides.remove) delete env[k];\n        }\n\n        this.logger.info({ personaId: persona.id, toolCount: tools.length, credCount: creds.length }, 'Assembled prompt from DB persona');\n      }\n    }\n\n    // Resolve network policy from persona config\n    let networkPolicy: NetworkPolicy | undefined;\n    if (persona?.networkPolicy) {\n      networkPolicy = parseNetworkPolicy(persona.networkPolicy) ?? undefined;\n    }\n\n    const assignment: ExecAssign = {\n      type: 'assign',\n      executionId: request.executionId,\n      personaId: request.personaId,\n      prompt,\n      env,\n      config: {\n        timeoutMs: request.config.timeoutMs || 300_000,\n        maxOutputBytes: 10 * 1024 * 1024, // 10MB\n        ...(networkPolicy ? { networkPolicy } : {}),\n        ...(persona?.maxBudgetUsd ? { maxBudgetUsd: persona.maxBudgetUsd } : {}),\n        ...(persona?.maxTurns ? { maxTurns: persona.maxTurns } : {}),\n      },\n    };\n\n    // Track in-memory for real-time streaming\n    this.active.set(request.executionId, {\n      workerId,\n      startedAt: Date.now(),\n      output: [],\n      status: 'running',\n    });\n\n    // Mark running in DB\n    if (dispatchDb) {\n      try {\n        db.updateExecution(dispatchDb, request.executionId, {\n          status: 'running',\n          startedAt: new Date().toISOString(),\n        });\n      } catch { /* best effort */ }\n    }\n\n    const sent = this.pool.assign(workerId, assignment);\n    if (!sent) {\n      this.logger.error({ workerId, executionId: request.executionId }, 'Failed to assign to worker');\n      this.active.delete(request.executionId);\n      if (dispatchDb) {\n        try { db.updateExecution(dispatchDb, request.executionId, { status: 'queued' }); } catch { /* best effort */ }\n      }\n      // Re-queue and retry dispatch — another idle worker may be available\n      this.queue.unshift({ request, receivedAt: Date.now() });\n      this.processQueue();\n    } else {\n      this.logger.info({\n        workerId,\n        executionId: request.executionId,\n        personaId: request.personaId,\n      }, 'Execution dispatched to worker');\n    }\n  }\n\n  cancelExecution(executionId: string): boolean {\n    const exec = this.active.get(executionId);\n    if (!exec || exec.status !== 'running') return false;\n\n    return this.pool.send(exec.workerId, {\n      type: 'cancel',\n      executionId,\n    });\n  }\n\n  getQueueLength(): number {\n    return this.queue.length;\n  }\n\n  getActiveExecutions(): Array<{ executionId: string; workerId: string; startedAt: number }> {\n    return Array.from(this.active.entries())\n      .filter(([, e]) => e.status === 'running')\n      .map(([executionId, e]) => ({\n        executionId,\n        workerId: e.workerId,\n        startedAt: e.startedAt,\n      }));\n  }\n\n  /**\n   * Get execution state. Tries in-memory first (for real-time output),\n   * then falls back to DB for completed/historical executions.\n   */\n  getExecution(executionId: string): ActiveExecution | null {\n    // Check in-memory active executions first\n    const active = this.active.get(executionId);\n    if (active) return active;\n\n    const execDb = this.resolveDbForExecution(executionId);\n    if (execDb) {\n      const dbExec = db.getExecution(execDb, executionId);\n      if (dbExec) {\n        return {\n          workerId: '',\n          startedAt: dbExec.startedAt ? new Date(dbExec.startedAt).getTime() : 0,\n          output: dbExec.outputData ? dbExec.outputData.split('\\n').filter(Boolean) : [],\n          status: dbExec.status as ActiveExecution['status'],\n          completedAt: dbExec.completedAt ? new Date(dbExec.completedAt).getTime() : undefined,\n          durationMs: dbExec.durationMs ?? undefined,\n          sessionId: dbExec.claudeSessionId ?? undefined,\n          totalCostUsd: dbExec.costUsd ?? undefined,\n        };\n      }\n    }\n\n    return null;\n  }\n\n  getExecutionOutput(executionId: string): string[] | null {\n    const exec = this.getExecution(executionId);\n    return exec?.output ?? null;\n  }\n\n  /** Shared handler for stdout/stderr output chunks. */\n  private handleOutputChunk(executionId: string, chunk: string, timestamp: number, prefix?: string): void {\n    const line = prefix ? `${prefix}${chunk}` : chunk;\n\n    const exec = this.active.get(executionId);\n    if (exec) {\n      exec.output.push(line);\n    }\n\n    this.bufferOutput(executionId, line + '\\n');\n\n    // Forward stdout to Kafka (stderr is not forwarded)\n    if (!prefix) {\n      this.kafka.produce(TOPICS.EXEC_OUTPUT, JSON.stringify({\n        executionId,\n        chunk,\n        timestamp,\n      }), executionId).catch(err => {\n        this.logger.error({ err, executionId }, 'Failed to produce output to Kafka');\n      });\n    }\n  }\n\n  /** Buffer an output chunk for batched DB write. */\n  private bufferOutput(executionId: string, chunk: string): void {\n    let buf = this.outputBuffers.get(executionId);\n    if (!buf) {\n      buf = [];\n      this.outputBuffers.set(executionId, buf);\n    }\n    buf.push(chunk);\n  }\n\n  /** Flush buffered output for a specific execution to DB. */\n  private flushOutputForExecution(executionId: string): void {\n    const buf = this.outputBuffers.get(executionId);\n    if (!buf || buf.length === 0) return;\n\n    const combined = buf.join('');\n    this.outputBuffers.delete(executionId);\n\n    const outputDb = this.resolveDbForExecution(executionId);\n    if (outputDb) {\n      try { db.appendOutput(outputDb, executionId, combined); } catch { /* best effort */ }\n    }\n  }\n\n  /** Flush all buffered output across all executions to DB. */\n  private flushOutputBuffers(): void {\n    for (const executionId of this.outputBuffers.keys()) {\n      this.flushOutputForExecution(executionId);\n    }\n  }\n\n  shutdown(): void {\n    clearInterval(this.outputFlushTimer);\n    this.flushOutputBuffers();\n  }\n}\n","numLines":591,"startLine":1,"totalLines":591}}}
