ng | null;\n    55→}\n    56→\n    57→/** Max entries buffered before an automatic flush. */\n    58→const BUFFER_FLUSH_SIZE = 50;\n    59→/** Interval (ms) between timer-based flushes. */\n    60→const BUFFER_FLUSH_INTERVAL_MS = 100;\n    61→\n    62→interface BufferedEntry {\n    63→  timestamp: string;\n    64→  action: string;\n    65→  tenantId: string | null;\n    66→  actor: string | null;\n    67→  resourceType: string | null;\n    68→  resourceId: string | null;\n    69→  detail: string | null;\n    70→  ipAddress: string | null;\n    71→}\n    72→\n    73→export class AuditLog {\n    74→  private db: Database.Database;\n    75→  private insertStmt: Database.Statement;\n    76→  private queryStmtCache = new Map<string, Database.Statement>();\n    77→  private buffer: BufferedEntry[] = [];\n    78→  private flushTimer: NodeJS.Timeout | null = null;\n    79→  private batchInsert: (...entries: BufferedEntry[]) => void;\n    80→\n    81→  constructor(\n    82→    dbPath: string,\n    83→    private logger: Logger,\n    84→  ) {\n    85→    this.db = new Database(dbPath);\n    86→    this.db.pragma('journal_mode = WAL');\n    87→    this.db.exec(AUDIT_SCHEMA);\n    88→    this.insertStmt = this.db.prepare(\n    89→      'INSERT INTO audit_events (timestamp, action, tenant_id, actor, resource_type, resource_id, detail, ip_address) VALUES (?, ?, ?, ?, ?, ?, ?, ?)',\n    90→    );\n    91→\n    92→    // Wrap N inserts in a single transaction — one fsync instead of N\n    93→    const stmt = this.insertStmt;\n    94→    this.batchInsert = this.db.transaction((...entries: BufferedEntry[]) => {\n    95→      for (const e of entries) {\n    96→        stmt.run(e.timestamp, e.action, e.tenantId, e.actor, e.resourceType, e.resourceId, e.detail, e.ipAddress);\n    97→      }\n    98→    });\n    99→\n   100→    this.flushTimer = setInterval(() => this.flush(), BUFFER_FLUSH_INTERVAL_MS);\n   101→\n   102→    logger.info({ dbPath }, 'Audit log initialized (buffered writes enabled)');\n   103→  }\n   104→\n   105→  /** Count audit events, optionally only those with timestamp before `cutoff`. */\n   106→  countEvents(before?: string): number {\n   107→    const stmt = before\n   108→      ? this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events WHERE timestamp < ?')\n   109→      : this.db.prepare('SELECT COUNT(*) as cnt FROM audit_events');\n   110→    const row = (before ? stmt.get(before) : stmt.get()) as { cnt: number };\n   111→    return row.cnt;\n   112→  }\n   113→\n   114→  /**\n   115→   * Delete audit events older than `cutoff` in chunks of `chunkSize`,\n   116→   * yielding the event loop between batches so concurrent DB operations\n   117→   * are not starved during large purges.\n   118→   */\n   119→  async purgeOlderThan(cutoff: string, chunkSize: number): Promise<number> {\n   120→    const deleteChunk = this.db.prepare(\n   121→      'DELETE FROM audit_events WHERE rowid IN (SELECT rowid FROM audit_events WHERE timestamp < ? LIMIT ?)',\n   122→    );\n   123→    let totalDeleted = 0;\n   124→    while (true) {\n   125→      const result = deleteChunk.run(cutoff, chunkSize);\n   126→      totalDeleted += result.changes;\n   127→      if (result.changes < chunkSize) break;\n   128→      await new Promise<void>((resolve) => setImmediate(resolve));\n   129→    }\n   130→    return totalDeleted;\n   131→  }\n   132→\n   133→  /** Append an audit event to the in-memory buffer.  Flushed to disk every 100ms or at 50 entries. */\n   134→  record(entry: AuditEntry): void {\n   135→    this.buffer.push({\n   136→      timestamp: new Date().toISOString(),\n   137→      action: entry.action,\n   138→      tenantId: entry.tenantId ?? null,\n   139→      actor: entry.actor ?? null,\n   140→      resourceType: entry.resourceType ?? null,\n   141→      resourceId: entry.resourceId ?? null,\n   142→      detail: entry.detail ?? null,\n   143→      ipAddress: entry.ipAddress ?? null,\n   144→    });\n   145→    if (this.buffer.length