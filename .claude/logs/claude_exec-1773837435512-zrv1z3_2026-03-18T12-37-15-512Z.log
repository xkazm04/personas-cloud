[2026-03-18T12:37:40.329Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F9HDcnkYAvLfXX1AahD9wV","type":"tool_result","content":"     1→import WebSocket from 'ws';\n     2→import {\n     3→  parseMessage,\n     4→  serializeMessage,\n     5→  PROTOCOL_VERSION,\n     6→  type OrchestratorMessage,\n     7→  type WorkerMessage,\n     8→} from '@dac-cloud/shared';\n     9→import type { Logger } from 'pino';\n    10→\n    11→const HEARTBEAT_INTERVAL_MS = 30_000;\n    12→const MAX_RECONNECT_DELAY_MS = 30_000;\n    13→const INITIAL_RECONNECT_DELAY_MS = 1_000;\n    14→\n    15→export interface ConnectionCallbacks {\n    16→  onAssign(msg: OrchestratorMessage & { type: 'assign' }): void;\n    17→  onCancel(msg: OrchestratorMessage & { type: 'cancel' }): void;\n    18→  onShutdown(msg: OrchestratorMessage & { type: 'shutdown' }): void;\n    19→}\n    20→\n    21→export class Connection {\n    22→  private ws: WebSocket | null = null;\n    23→  private connected = false;\n    24→  private reconnectDelay = INITIAL_RECONNECT_DELAY_MS;\n    25→  private heartbeatTimer?: ReturnType<typeof setInterval>;\n    26→  private reconnectTimer?: ReturnType<typeof setTimeout>;\n    27→  private shuttingDown = false;\n    28→\n    29→  constructor(\n    30→    private orchestratorUrl: string,\n    31→    private workerId: string,\n    32→    private workerToken: string,\n    33→    private callbacks: ConnectionCallbacks,\n    34→    private logger: Logger,\n    35→  ) {}\n    36→\n    37→  connect(): void {\n    38→    if (this.shuttingDown) return;\n    39→\n    40→    this.logger.info({ url: this.orchestratorUrl, workerId: this.workerId }, 'Connecting to orchestrator');\n    41→\n    42→    // Append worker token as query parameter for authentication\n    43→    const urlWithToken = `${this.orchestratorUrl}?token=${encodeURIComponent(this.workerToken)}`;\n    44→    this.ws = new WebSocket(urlWithToken);\n    45→\n    46→    this.ws.on('open', () => {\n    47→      this.connected = true;\n    48→      this.reconnectDelay = INITIAL_RECONNECT_DELAY_MS;\n    49→\n    50→      // Send hello\n    51→      this.send({\n    52→        type: 'hello',\n    53→        workerId: this.workerId,\n    54→        version: PROTOCOL_VERSION,\n    55→        capabilities: ['claude-cli', 'node', 'git'],\n    56→      });\n    57→\n    58→      // Start heartbeat\n    59→      this.heartbeatTimer = setInterval(() => {\n    60→        this.send({ type: 'heartbeat', timestamp: Date.now() });\n    61→      }, HEARTBEAT_INTERVAL_MS);\n    62→\n    63→      this.logger.info('Connected to orchestrator');\n    64→    });\n    65→\n    66→    this.ws.on('message', (raw: Buffer) => {\n    67→      const msg = parseMessage<OrchestratorMessage>(raw.toString());\n    68→      if (!msg) {\n    69→        this.logger.warn('Invalid message from orchestrator');\n    70→        return;\n    71→      }\n    72→\n    73→      this.handleMessage(msg);\n    74→    });\n    75→\n    76→    this.ws.on('close', (code: number, reason: Buffer) => {\n    77→      this.logger.info({ code, reason: reason.toString() }, 'Disconnected from orchestrator');\n    78→      this.cleanup();\n    79→      this.scheduleReconnect();\n    80→    });\n    81→\n    82→    this.ws.on('error', (err: Error) => {\n    83→      this.logger.error({ err }, 'WebSocket error');\n    84→      // 'close' will follow, which handles reconnection\n    85→    });\n    86→  }\n    87→\n    88→  private handleMessage(msg: OrchestratorMessage): void {\n    89→    switch (msg.type) {\n    90→      case 'ack':\n    91→        this.logger.info({ workerId: msg.workerId }, 'Received ack from orchestrator');\n    92→        // Send ready after ack\n    93→        this.sendReady();\n    94→        break;\n    95→\n    96→      case 'assign':\n    97→        this.logger.info({ executionId: msg.executionId, personaId: msg.personaId }, 'Received execution assignment');\n    98→        this.callbacks.onAssign(msg as any);\n    99→        break;\n   100→\n   101→      case 'cancel':\n   102→        this.logger.info({ executionId: msg.executionId }, 'Received cancel');\n   103→        this.callbacks.onCancel(msg as any);\n   104→        break;\n   105→\n   106→      case 'shutdown':\n   107→        this.logger.info({ reason: msg.reason }, 'Received shutdown');\n   108→        this.shuttingDown = true;\n   109→        this.callbacks.onShutdown(msg as any);\n   110→        break;\n   111→\n   112→      case 'heartbeat':\n   113→        // Orchestrator heartbeat — no action needed\n   114→        break;\n   115→    }\n   116→  }\n   117→\n   118→  send(msg: WorkerMessage): boolean {\n   119→    if (!this.ws || this.ws.readyState !== WebSocket.OPEN) {\n   120→      this.logger.warn({ type: msg.type }, 'Cannot send — not connected');\n   121→      return false;\n   122→    }\n   123→\n   124→    this.ws.send(serializeMessage(msg));\n   125→    return true;\n   126→  }\n   127→\n   128→  sendReady(): void {\n   129→    this.send({ type: 'ready' });\n   130→  }\n   131→\n   132→  sendStdout(executionId: string, chunk: string): void {\n   133→    this.send({\n   134→      type: 'stdout',\n   135→      executionId,\n   136→      chunk,\n   137→      timestamp: Date.now(),\n   138→    });\n   139→  }\n   140→\n   141→  sendStderr(executionId: string, chunk: string): void {\n   142→    this.send({\n   143→      type: 'stderr',\n   144→      executionId,\n   145→      chunk,\n   146→      timestamp: Date.now(),\n   147→    });\n   148→  }\n   149→\n   150→  sendComplete(\n   151→    executionId: string,\n   152→    status: 'completed' | 'failed' | 'cancelled',\n   153→    exitCode: number,\n   154→    durationMs: number,\n   155→    sessionId?: string,\n   156→    totalCostUsd?: number,\n   157→  ): void {\n   158→    this.send({\n   159→      type: 'complete',\n   160→      executionId,\n   161→      status,\n   162→      exitCode,\n   163→      durationMs,\n   164→      sessionId,\n   165→      totalCostUsd,\n   166→    });\n   167→  }\n   168→\n   169→  sendEvent(executionId: string, eventType: string, payload: unknown): void {\n   170→    this.send({\n   171→      type: 'event',\n   172→      executionId,\n   173→      eventType: eventType as any,\n   174→      payload,\n   175→    });\n   176→  }\n   177→\n   178→  private cleanup(): void {\n   179→    this.connected = false;\n   180→    if (this.heartbeatTimer) {\n   181→      clearInterval(this.heartbeatTimer);\n   182→      this.heartbeatTimer = undefined;\n   183→    }\n   184→  }\n   185→\n   186→  private scheduleReconnect(): void {\n   187→    if (this.shuttingDown) return;\n   188→\n   189→    this.logger.info({ delayMs: this.reconnectDelay }, 'Scheduling reconnect');\n   190→\n   191→    this.reconnectTimer = setTimeout(() => {\n   192→      this.connect();\n   193→    }, this.reconnectDelay);\n   194→\n   195→    // Exponential backoff\n   196→    this.reconnectDelay = Math.min(this.reconnectDelay * 2, MAX_RECONNECT_DELAY_MS);\n   197→  }\n   198→\n   199→  disconnect(): void {\n   200→    this.shuttingDown = true;\n   201→    this.cleanup();\n   202→    if (this.reconnectTimer) {\n   203→      clearTimeout(this.reconnectTimer);\n   204→    }\n   205→    if (this.ws) {\n   206→      this.ws.close(1000, 'Worker shutting down');\n   207→    }\n   208→  }\n   209→\n   210→  isConnected(): boolean {\n   211→    return this.connected;\n   212→  }\n   213→}\n   214→"}]},"parent_tool_use_id":"toolu_01RgM3zvCunojH3kPm4PviZ5","session_id":"2d4a0d60-146a-40b9-aacb-9f1e746615f1","uuid":"1639ecd7-ff45-4743-a347-9ec720562995","timestamp":"2026-03-18T12:37:40.101Z"}
