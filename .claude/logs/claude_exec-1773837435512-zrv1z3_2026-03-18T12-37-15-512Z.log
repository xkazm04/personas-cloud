[2026-03-18T12:37:53.643Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Nv9WUgK5vwRJumCuZBGwpL","type":"tool_result","content":"     1→import { WebSocketServer, WebSocket } from 'ws';\n     2→import { EventEmitter } from 'node:events';\n     3→import {\n     4→  parseMessage,\n     5→  serializeMessage,\n     6→  type WorkerMessage,\n     7→  type OrchestratorMessage,\n     8→  type ExecAssign,\n     9→  type WorkerInfo,\n    10→} from '@dac-cloud/shared';\n    11→import type { Logger } from 'pino';\n    12→import type { IncomingMessage } from 'node:http';\n    13→\n    14→const HEARTBEAT_INTERVAL_MS = 30_000;\n    15→const HEARTBEAT_TIMEOUT_MS = 90_000;\n    16→\n    17→interface WorkerEntry {\n    18→  ws: WebSocket;\n    19→  info: WorkerInfo;\n    20→  heartbeatTimer?: ReturnType<typeof setInterval>;\n    21→}\n    22→\n    23→export class WorkerPool extends EventEmitter {\n    24→  private workers = new Map<string, WorkerEntry>();\n    25→  private wss: WebSocketServer | null = null;\n    26→\n    27→  constructor(\n    28→    private expectedWorkerToken: string,\n    29→    private logger: Logger,\n    30→  ) {\n    31→    super();\n    32→  }\n    33→\n    34→  listen(port: number): void {\n    35→    this.wss = new WebSocketServer({ port });\n    36→\n    37→    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n    38→      this.logger.info({ remoteAddr: req.socket.remoteAddress }, 'Worker connection attempt');\n    39→\n    40→      // C3: Validate worker token from query string (?token=...)\n    41→      const url = new URL(req.url || '/', `http://${req.headers.host || 'localhost'}`);\n    42→      const token = url.searchParams.get('token');\n    43→      if (!token || token !== this.expectedWorkerToken) {\n    44→        this.logger.warn({ remoteAddr: req.socket.remoteAddress }, 'Worker rejected: invalid token');\n    45→        ws.close(1008, 'Invalid worker token');\n    46→        return;\n    47→      }\n    48→\n    49→      this.handleConnection(ws);\n    50→    });\n    51→\n    52→    this.wss.on('error', (err) => {\n    53→      this.logger.error({ err }, 'WebSocket server error');\n    54→    });\n    55→\n    56→    this.logger.info({ port }, 'Worker pool listening');\n    57→  }\n    58→\n    59→  private handleConnection(ws: WebSocket): void {\n    60→    let workerId: string | null = null;\n    61→\n    62→    const connectionTimeout = setTimeout(() => {\n    63→      if (!workerId) {\n    64→        this.logger.warn('Worker did not send hello within timeout, closing');\n    65→        ws.close(1008, 'Hello timeout');\n    66→      }\n    67→    }, 10_000);\n    68→\n    69→    ws.on('message', (raw: Buffer) => {\n    70→      const msg = parseMessage<WorkerMessage>(raw.toString());\n    71→      if (!msg) {\n    72→        this.logger.warn('Invalid message from worker');\n    73→        return;\n    74→      }\n    75→\n    76→      if (msg.type === 'hello') {\n    77→        clearTimeout(connectionTimeout);\n    78→        workerId = msg.workerId;\n    79→        this.registerWorker(workerId, ws, msg.version, msg.capabilities);\n    80→        return;\n    81→      }\n    82→\n    83→      if (!workerId) {\n    84→        this.logger.warn({ type: msg.type }, 'Message before hello');\n    85→        return;\n    86→      }\n    87→\n    88→      this.handleWorkerMessage(workerId, msg);\n    89→    });\n    90→\n    91→    ws.on('close', () => {\n    92→      clearTimeout(connectionTimeout);\n    93→      if (workerId) {\n    94→        this.unregisterWorker(workerId);\n    95→      }\n    96→    });\n    97→\n    98→    ws.on('error', (err) => {\n    99→      this.logger.error({ err, workerId }, 'Worker WebSocket error');\n   100→    });"}]},"parent_tool_use_id":"toolu_01RgM3zvCunojH3kPm4PviZ5","session_id":"2d4a0d60-146a-40b9-aacb-9f1e746615f1","uuid":"f68d64ee-4cf5-47d1-8315-afe34062cd5c","timestamp":"2026-03-18T12:37:53.562Z"}
