[2026-03-18T12:37:55.816Z] [STDOUT] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015hgGVFx2aPd6hvUnG1d7sg","type":"tool_result","content":"   100→    });\n   101→  }\n   102→\n   103→  private registerWorker(workerId: string, ws: WebSocket, version: string, capabilities: string[]): void {\n   104→    // I10: If a worker with this ID already exists, disconnect the old one first\n   105→    const existing = this.workers.get(workerId);\n   106→    if (existing) {\n   107→      this.logger.warn({ workerId }, 'Duplicate worker ID — disconnecting previous connection');\n   108→      if (existing.heartbeatTimer) clearInterval(existing.heartbeatTimer);\n   109→      existing.ws.close(1001, 'Replaced by new connection');\n   110→      this.workers.delete(workerId);\n   111→    }\n   112→\n   113→    const info: WorkerInfo = {\n   114→      workerId,\n   115→      status: 'idle',\n   116→      version,\n   117→      capabilities,\n   118→      connectedAt: Date.now(),\n   119→      lastHeartbeat: Date.now(),\n   120→    };\n   121→\n   122→    const heartbeatTimer = setInterval(() => {\n   123→      const entry = this.workers.get(workerId);\n   124→      if (!entry) return;\n   125→\n   126→      if (Date.now() - entry.info.lastHeartbeat > HEARTBEAT_TIMEOUT_MS) {\n   127→        this.logger.warn({ workerId }, 'Worker heartbeat timeout');\n   128→        entry.ws.close(1001, 'Heartbeat timeout');\n   129→        return;\n   130→      }\n   131→\n   132→      this.send(workerId, { type: 'heartbeat', timestamp: Date.now() });\n   133→    }, HEARTBEAT_INTERVAL_MS);\n   134→\n   135→    this.workers.set(workerId, { ws, info, heartbeatTimer });\n   136→\n   137→    // Send ack\n   138→    this.send(workerId, {\n   139→      type: 'ack',\n   140→      workerId,\n   141→      sessionToken: `session-${Date.now()}`,\n   142→    });\n   143→\n   144→    this.logger.info({ workerId, version, capabilities }, 'Worker registered');\n   145→    this.emit('worker-connected', info);\n   146→  }\n   147→\n   148→  private unregisterWorker(workerId: string): void {\n   149→    const entry = this.workers.get(workerId);\n   150→    if (!entry) return;\n   151→\n   152→    if (entry.heartbeatTimer) {\n   153→      clearInterval(entry.heartbeatTimer);\n   154→    }\n   155→\n   156→    const hadExecution = entry.info.currentExecutionId;\n   157→    this.workers.delete(workerId);\n   158→\n   159→    this.logger.info({ workerId, hadExecution }, 'Worker disconnected');\n   160→    this.emit('worker-disconnected', workerId, hadExecution);\n   161→  }\n   162→\n   163→  private handleWorkerMessage(workerId: string, msg: WorkerMessage): void {\n   164→    const entry = this.workers.get(workerId);\n   165→    if (!entry) return;\n   166→\n   167→    switch (msg.type) {\n   168→      case 'heartbeat':\n   169→        entry.info.lastHeartbeat = Date.now();\n   170→        break;\n   171→\n   172→      case 'ready':\n   173→        entry.info.status = 'idle';\n   174→        entry.info.currentExecutionId = undefined;\n   175→        this.emit('worker-ready', workerId);\n   176→        break;\n   177→\n   178→      case 'stdout':\n   179→        this.emit('stdout', workerId, msg);\n   180→        break;\n   181→\n   182→      case 'stderr':\n   183→        this.emit('stderr', workerId, msg);\n   184→        break;\n   185→\n   186→      case 'complete':\n   187→        entry.info.status = 'idle';\n   188→        entry.info.currentExecutionId = undefined;\n   189→        this.logger.info({\n   190→          workerId,\n   191→          executionId: msg.executionId,\n   192→          status: msg.status,\n   193→          durationMs: msg.durationMs,\n   194→        }, 'Execution complete');\n   195→        this.emit('complete', workerId, msg);\n   196→        break;\n   197→\n   198→      case 'event':\n   199→        this.emit('persona-event', workerId, msg);\n   200→        break;\n   201→\n   202→      default:\n   203→        this.logger.warn({ workerId, type: (msg as WorkerMessage).type }, 'Unknown message type');\n   204→    }\n   205→  }\n   206→\n   207→  send(workerId: string, msg: OrchestratorMessage): boolean {\n   208→    const entry = this.workers.get(workerId);\n   209→    if (!entry || entry.ws.readyState !== WebSocket.OPEN) return false;\n   210→\n   211→    entry.ws.send(serializeMessage(msg));\n   212→    return true;\n   213→  }\n   214→\n   215→  assign(workerId: string, assignment: ExecAssign): boolean {\n   216→    const entry = this.workers.get(workerId);\n   217→    if (!entry || entry.info.status !== 'idle') return false;\n   218→\n   219→    entry.info.status = 'executing';\n   220→    entry.info.currentExecutionId = assignment.executionId;\n   221→    return this.send(workerId, assignment);\n   222→  }\n   223→\n   224→  getIdleWorker(): string | null {\n   225→    for (const [workerId, entry] of this.workers) {\n   226→      if (entry.info.status === 'idle') {\n   227→        return workerId;\n   228→      }\n   229→    }\n   230→    return null;\n   231→  }\n   232→\n   233→  getWorkers(): WorkerInfo[] {\n   234→    return Array.from(this.workers.values()).map(e => ({ ...e.info }));\n   235→  }\n   236→\n   237→  getWorkerCount(): { total: number; idle: number; executing: number } {\n   238→    let idle = 0;\n   239→    let executing = 0;\n   240→    for (const entry of this.workers.values()) {\n   241→      if (entry.info.status === 'idle') idle++;\n   242→      if (entry.info.status === 'executing') executing++;\n   243→    }\n   244→    return { total: this.workers.size, idle, executing };\n   245→  }\n   246→\n   247→  shutdown(): void {\n   248→    for (const [workerId] of this.workers) {\n   249→      this.send(workerId, {\n   250→        type: 'shutdown',\n   251→        reason: 'Orchestrator shutting down',\n   252→        gracePeriodMs: 30_000,\n   253→      });\n   254→    }\n   255→    this.wss?.close();\n   256→    for (const entry of this.workers.values()) {\n   257→      if (entry.heartbeatTimer) clearInterval(entry.heartbeatTimer);\n   258→    }\n   259→  }\n   260→}\n   261→"}]},"parent_tool_use_id":"toolu_01RgM3zvCunojH3kPm4PviZ5","session_id":"2d4a0d60-146a-40b9-aacb-9f1e746615f1","uuid":"3c4575a4-512d-4f2e-9be3-3417c894eafc","timestamp":"2026-03-18T12:37:55.619Z"}
